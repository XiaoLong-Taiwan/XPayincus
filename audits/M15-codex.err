 509: /**
 510:  * 处理 AFF 返利（新购或续费时调用）
 511:  * @param originalAmount 订单原始金额（未打折前）
 512:  */
 513: export async function processAffCommission(
 514:   affCodeId: number,
 515:   instanceId: number,
 516:   originalAmount: number,
 517:   type: 'new_purchase' | 'renew',
 518:   tx?: Prisma.TransactionClient
 519: ): Promise<void> {
 520:   const client = tx || prisma
 521: 
 522:   // 1. 获取优惠码信息
 523:   const affCode = await client.affCode.findUnique({
 524:     where: { id: affCodeId }
 525:   })
 526: 
 527:   if (!affCode) return
 528: 
 529:   // 2. 计算返利金额
 530:   const commissionRate = Number(affCode.commissionRate)
 531:   const commission = Math.round(originalAmount * commissionRate * 100) / 100
 532: 
 533:   if (commission <= 0) return
 534: 
 535:   // 3. 给优惠码创建者增加 AFF 余额
 536:   await changeAffBalance({
 537:     userId: affCode.userId,
 538:     type,
 539:     amount: commission,
 540:     affCodeId,
 541:     instanceId,
 542:     originalAmount,
 543:     remark: type === 'new_purchase' ? '新购返利' : '续费返利'
 544:   }, client as PrismaClient)
 545: 
 546:   // 4. 更新优惠码统计
 547:   await client.affCode.update({
 548:     where: { id: affCodeId },
 549:     data: {
 550:       usedCount: type === 'new_purchase' ? { increment: 1 } : undefined,
 551:       totalEarnings: { increment: commission }
 552:     }
 553:   })
 554: }
