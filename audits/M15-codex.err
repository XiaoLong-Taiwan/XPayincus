 650: // ==================== AFF 转化申请 ====================
 651: 
 652: /**
 653:  * 创建转化申请（自动审批通过）
 654:  * 提交申请后系统自动完成审批，无需管理员手动操作
 655:  * 管理员后台仍可查看所有转化记录
 656:  */
 657: export async function createAffWithdrawal(
 658:   userId: number,
 659:   amount: number
 660: ): Promise<{ success: boolean; withdrawal?: AffWithdrawal; error?: string }> {
 661:   try {
 662:     // 1. 检查最低转化金额（0.1 元起）
 663:     if (!Number.isFinite(amount) || amount < 0.1) {
 664:       return { success: false, error: '最低转化金额为 0.1 元' }
 665:     }
 666: 
 667:     // 2. 在事务中完成：创建申请 + 自动审批
 668:     const withdrawal = await prisma.$transaction(async (tx) => {
 669:       await advisoryTransactionLock(tx, USER_AFF_BALANCE_LOCK_NAMESPACE, userId)
 670:       await advisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, userId)
 671: 
 672:       // 2.1 获取用户当前余额
 673:       const user = await tx.user.findUnique({
 674:         where: { id: userId },
 675:         select: { affBalance: true, balance: true }
 676:       })
 677: 
 678:       if (!user) {
 679:         throw new Error('用户不存在')
 680:       }
 681: 
 682:       const affBalanceBefore = Number(user.affBalance)
 683:       const balanceBefore = Number(user.balance)
 684: 
 685:       // 2.2 检查 AFF 余额
 686:       if (affBalanceBefore < amount) {
 687:         throw new Error('AFF 余额不足')
 688:       }
 689: 
 690:       // 2.3 创建申请记录（直接标记为已通过，方便管理员后台查看）
 691:       const newWithdrawal = await tx.affWithdrawal.create({
 692:         data: {
 693:           userId,
 694:           amount,
 695:           status: 'approved',
 696:           reviewedBy: null, // 系统自动审批，无审核人
 697:           reviewedAt: new Date()
 698:         }
 699:       })
 700: 
 701:       // 2.4 扣除 AFF 余额并增加用户主余额
 702:       const affBalanceAfter = affBalanceBefore - amount
 703:       const updatedUser = await tx.user.update({
 704:         where: { id: userId },
 705:         data: {
 706:           affBalance: { decrement: amount },
 707:           balance: { increment: amount }
 708:         },
 709:         select: { balance: true }
 710:       })
 711:       const balanceAfter = Number(updatedUser.balance)
 712: 
 713:       // 2.5 记录 AFF 日志
 714:       await tx.affLog.create({
 715:         data: {
 716:           userId,
 717:           type: 'convert',
 718:           amount: -amount,
 719:           balanceBefore: affBalanceBefore,
 720:           balanceAfter: affBalanceAfter,
 721:           remark: `转化申请 #${newWithdrawal.id} 审核通过`
 722:         }
 723:       })
 724: 
 725:       // 2.6 记录余额日志
 726:       await tx.balanceLog.create({
 727:         data: {
 728:           userId,
 729:           type: 'gift',
 730:           amount,
 731:           balanceBefore,
 732:           balanceAfter,
 733:           remark: `AFF 余额转化 #${newWithdrawal.id}`
 734:         }
 735:       })
 736: 
 737:       return newWithdrawal
 738:     })
 739: 
 740:     return { success: true, withdrawal }
 741:   } catch (error) {
 742:     return {
 743:       success: false,
 744:       error: error instanceof Error ? error.message : '转化失败'
 745:     }
 746:   }
 747: }
