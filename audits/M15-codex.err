 798: /**
 799:  * 获取所有待审核的转化申请（管理员）
 800:  */
 801: export async function getPendingAffWithdrawals(options: {
 802:   page?: number
 803:   pageSize?: number
 804:   status?: AffWithdrawalStatus
 805: } = {}): Promise<{
 806:   withdrawals: (AffWithdrawal & { user: { id: number; username: string; affBalance: number } })[]
 807:   total: number
 808:   page: number
 809:   pageSize: number
 810: }> {
 811:   const { page, pageSize } = clampPagination(options.page, options.pageSize)
 812:   const status = normalizeAffWithdrawalStatus(options.status)
 813:   const skip = (page - 1) * pageSize
 814: 
 815:   const where: Prisma.AffWithdrawalWhereInput = status ? { status } : {}
 816: 
 817:   const [withdrawals, total] = await Promise.all([
 818:     prisma.affWithdrawal.findMany({
 819:       where,
 820:       include: {
 821:         user: {
 822:           select: { id: true, username: true, affBalance: true }
 823:         }
 824:       },
 825:       orderBy: { createdAt: 'desc' },
 826:       skip,
 827:       take: pageSize
 828:     }),
 829:     prisma.affWithdrawal.count({ where })
 830:   ])
 831: 
 832:   return {
 833:     withdrawals: withdrawals.map(w => ({
 834:       ...w,
 835:       user: { ...w.user, affBalance: Number(w.user.affBalance) }
 836:     })),
 837:     total,
 838:     page,
 839:     pageSize
 840:   }
 841: }
