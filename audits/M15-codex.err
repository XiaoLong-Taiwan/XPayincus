 431:         amount: Number(w.amount),
 432:         status: w.status,
 433:         rejectReason: w.rejectReason,
 434:         reviewedBy: w.reviewedBy,
 435:         reviewedAt: w.reviewedAt?.toISOString() || null,
 436:         createdAt: w.createdAt.toISOString()
 437:       })),
 438:       total: result.total,
 439:       page: result.page,
 440:       pageSize: result.pageSize
 441:     }
 442:   })
 443: 
 444:   // 审核通过转化申请（管理员）
 445:   fastify.post<{
 446:     Params: { withdrawalId: string }
 447:   }>('/admin/withdrawals/:withdrawalId/approve', {
 448:     onRequest: [fastify.authenticate, fastify.requireAdmin],
 449:     config: { rateLimit: { max: 20, timeWindow: '1 minute' } }
 450:   }, async (request: FastifyRequest<{ Params: { withdrawalId: string } }>, reply: FastifyReply) => {
 451:     const { user } = request
 452:     const withdrawalId = parsePositiveRouteId(request.params.withdrawalId)
 453: 
 454:     if (!withdrawalId) {
 455:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 456:     }
 457: 
 458:     // 先查询申请信息以获取用户ID和金额
 459:     const withdrawal = await db.getAffWithdrawalById(withdrawalId)
 460:     if (!withdrawal) {
 461:       return reply.code(400).send({ error: '申请不存在' })
 462:     }
 463: 
 464:     const result = await db.approveAffWithdrawal(withdrawalId, user.id)
 465: 
 466:     if (!result.success) {
 467:       return reply.code(400).send({ error: result.error })
 468:     }
 469: 
 470:     await createLog(
 471:       user.id,
 472:       'admin',
 473:       'aff.approve_convert',
 474:       `Approved AFF convert request #${withdrawalId}`,
 475:       'success'
 476:     )
 477: 
 478:     // 发送站内信通知用户
 479:     await createInboxMessage({
 480:       userId: withdrawal.userId,
 481:       eventType: 'aff_convert_approved',
 482:       title: 'AFF 转化审核通过',
 483:       content: `您的 AFF 余额转化申请已审核通过，¥${Number(withdrawal.amount).toFixed(2)} 已转入您的账户余额。`,
 484:       data: { withdrawalId, amount: Number(withdrawal.amount) }
 485:     })
 486: 
 487:     return { message: '审核通过，已转入用户余额' }
 488:   })
 489: 
 490:   // 审核拒绝转化申请（管理员）
 491:   fastify.post<{
 492:     Params: { withdrawalId: string }
 493:     Body: { reason: string }
 494:   }>('/admin/withdrawals/:withdrawalId/reject', {
 495:     onRequest: [fastify.authenticate, fastify.requireAdmin],
 496:     config: { rateLimit: { max: 20, timeWindow: '1 minute' } }
 497:   }, async (request: FastifyRequest<{ Params: { withdrawalId: string }; Body: { reason: string } }>, reply: FastifyReply) => {
 498:     const { user } = request
 499:     const withdrawalId = parsePositiveRouteId(request.params.withdrawalId)
 500:     const { reason: rawReason } = request.body
 501:     const reason = normalizeRequiredText(rawReason, AFF_REJECT_REASON_MAX_LENGTH)
 502: 
 503:     if (!withdrawalId) {
 504:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 505:     }
 506: 
 507:     if (!reason) {
 508:       return reply.code(400).send({ error: '请填写拒绝原因' })
 509:     }
 510: 
 511:     // 先查询申请信息以获取用户ID和金额
 512:     const withdrawal = await db.getAffWithdrawalById(withdrawalId)
 513:     if (!withdrawal) {
 514:       return reply.code(400).send({ error: '申请不存在' })
 515:     }
 516: 
 517:     const result = await db.rejectAffWithdrawal(withdrawalId, user.id, reason)
 518: 
 519:     if (!result.success) {
 520:       return reply.code(400).send({ error: result.error })
 521:     }
 522: 
 523:     await createLog(
 524:       user.id,
 525:       'admin',
 526:       'aff.reject_convert',
 527:       `Rejected AFF convert request #${withdrawalId}: ${reason}`,
 528:       'success'
 529:     )
 530: 
 531:     // 发送站内信通知用户
 532:     await createInboxMessage({
 533:       userId: withdrawal.userId,
 534:       eventType: 'aff_convert_rejected',
 535:       title: 'AFF 转化申请被拒绝',
 536:       content: `您的 AFF 余额转化申请（¥${Number(withdrawal.amount).toFixed(2)}）已被拒绝。\n拒绝原因：${reason}`,
 537:       data: { withdrawalId, amount: Number(withdrawal.amount), reason }
 538:     })
 539: 
 540:     return { message: '已拒绝' }
 541:   })
 542: }
===== server/src/routes/user-invites.ts =====
   1: /**
   2:  * 用户邀请码管理
   3:  */
   4: 
   5: import { nanoid } from 'nanoid'
   6: import type { Prisma } from '@prisma/client'
   7: import type { FastifyInstance, FastifyReply, FastifyRequest } from 'fastify'
   8: import { prisma } from '../db/prisma.js'
   9: import { apiError, ErrorCode } from '../lib/errors.js'
  10: import {
  11:   chargeInviteGenerationCost,
  12:   getInviteCostOptions,
  13:   getInviteCostQuotes,
  14:   getInviteExpiryDays,
  15:   getUserInviteBalances
  16: } from '../lib/invite-pricing.js'
  17: 
  18: interface GenerateInviteBody {
  19:   costResource: string
  20:   count?: number
  21: }
  22: 
  23: const INVITE_GENERATION_MAX_COUNT = 10
  24: const INVITE_COST_RESOURCE_MAX_LENGTH = 64
  25: 
  26: function isPlainRecord(value: unknown): value is Record<string, unknown> {
  27:   return typeof value === 'object' && value !== null && !Array.isArray(value)
  28: }
  29: 
  30: function normalizeGenerateInviteBody(input: unknown): GenerateInviteBody {
  31:   if (!isPlainRecord(input)) {
  32:     throw { error: '请求参数无效' }
  33:   }
  34: 
  35:   if (typeof input.costResource !== 'string') {
  36:     throw { error: '请选择生成方式' }
  37:   }
  38:   const costResource = input.costResource.trim()
  39:   if (!costResource || costResource.length > INVITE_COST_RESOURCE_MAX_LENGTH) {
  40:     throw { error: '生成方式无效' }
  41:   }
  42: 
  43:   let count = 1
  44:   const countInput = input.count
  45:   if (countInput !== undefined) {
  46:     if (typeof countInput !== 'number' || !Number.isSafeInteger(countInput) || countInput < 1 || countInput > INVITE_GENERATION_MAX_COUNT) {
  47:       throw { error: `生成数量需为 1-${INVITE_GENERATION_MAX_COUNT} 的整数` }
  48:     }
  49:     count = countInput
  50:   }
  51: 
  52:   return { costResource, count }
  53: }
  54: 
  55: function parsePositiveInteger(value: string | undefined, fallback: number): number {
  56:   const parsed = parseInt(value || '', 10)
  57:   return Number.isInteger(parsed) && parsed > 0 ? parsed : fallback
  58: }
  59: 
  60: function toInviteCodePayload(invite: {
  61:   id: number
  62:   code: string
  63:   createdBy: number
  64:   usedBy: number | null
  65:   usedAt: Date | null
  66:   expiresAt: Date | null
  67:   createdAt: Date
  68:   costSnapshot: unknown
  69:   user?: {
  70:     id: number
  71:     username: string
  72:     email: string | null
  73:     avatarStyle: string
  74:     avatarBadgeId: string | null
  75:     createdAt: Date
  76:   } | null
  77: }) {
  78:   return {
  79:     id: invite.id,
  80:     code: invite.code,
  81:     createdBy: invite.createdBy,
  82:     usedBy: invite.usedBy,
  83:     usedAt: invite.usedAt?.toISOString() ?? null,
  84:     expiresAt: invite.expiresAt?.toISOString() ?? null,
  85:     createdAt: invite.createdAt.toISOString(),
  86:     costSnapshot: invite.costSnapshot,
  87:     registerUrl: `/register/${invite.code}`,
  88:     usedByUser: invite.user
  89:       ? {
  90:           id: invite.user.id,
  91:           username: invite.user.username,
  92:           email: invite.user.email,
  93:           avatarStyle: invite.user.avatarStyle,
  94:           avatarBadgeId: invite.user.avatarBadgeId,
  95:           createdAt: invite.user.createdAt.toISOString()
  96:         }
  97:       : null
  98:   }
  99: }
 100: 
 101: export default async function userInviteRoutes(fastify: FastifyInstance) {
 102:   fastify.get('/summary', {
 103:     onRequest: [fastify.authenticateUser]
 104:   }, async (request: FastifyRequest) => {
 105:     const userId = request.user.id
 106:     const [costOptions, balances, total, used] = await Promise.all([
 107:       getInviteCostQuotes(),
 108:       getUserInviteBalances(userId),
 109:       prisma.inviteCode.count({ where: { createdBy: userId } }),
 110:       prisma.inviteCode.count({ where: { createdBy: userId, usedBy: { not: null } } })
 111:     ])
 112: 
 113:     return {
 114:       costOptions,
 115:       balances,
 116:       stats: {
 117:         total,
 118:         used,
 119:         unused: total - used,
 120:         usageRate: total > 0 ? Math.round((used / total) * 1000) / 10 : 0
 121:       }
 122:     }
 123:   })
 124: 
 125:   fastify.get<{
 126:     Querystring: { page?: string; pageSize?: string }
 127:   }>('/', {
 128:     onRequest: [fastify.authenticateUser]
 129:   }, async (request: FastifyRequest<{ Querystring: { page?: string; pageSize?: string } }>) => {
 130:     const page = parsePositiveInteger(request.query.page, 1)
 131:     const pageSize = Math.min(100, parsePositiveInteger(request.query.pageSize, 20))
 132:     const userId = request.user.id
 133: 
 134:     const [total, invites] = await Promise.all([
 135:       prisma.inviteCode.count({ where: { createdBy: userId } }),
 136:       prisma.inviteCode.findMany({
 137:         where: { createdBy: userId },
 138:         include: {
 139:           user: {
 140:             select: {
 141:               id: true,
 142:               username: true,
 143:               email: true,
 144:               avatarStyle: true,
 145:               avatarBadgeId: true,
 146:               createdAt: true
 147:             }
 148:           }
 149:         },
 150:         orderBy: { id: 'desc' },
 151:         skip: (page - 1) * pageSize,
 152:         take: pageSize
 153:       })
 154:     ])
 155: 
 156:     return {
 157:       invites: invites.map(toInviteCodePayload),
 158:       total,
 159:       page,
 160:       pageSize,
 161:       totalPages: Math.max(1, Math.ceil(total / pageSize))
 162:     }
 163:   })
 164: 
 165:   fastify.post<{ Body: GenerateInviteBody }>('/', {
 166:     onRequest: [fastify.authenticateUser],
 167:     config: { rateLimit: { max: 20, timeWindow: '1 minute' } },
 168:     schema: {
 169:       body: {
 170:         type: 'object',
 171:         required: ['costResource'],
 172:         properties: {
 173:           costResource: { type: 'string', minLength: 1, maxLength: 64 },
 174:           count: { type: 'integer', minimum: 1, maximum: 10 }
 175:         }
 176:       }
 177:     }
 178:   }, async (request: FastifyRequest<{ Body: GenerateInviteBody }>, reply: FastifyReply) => {
 179:     const userId = request.user.id
 180:     let input: GenerateInviteBody
 181:     try {
 182:       input = normalizeGenerateInviteBody(request.body)
 183:     } catch (error) {
 184:       return reply.code(400).send(error)
 185:     }
 186:     const { count = 1, costResource } = input
 187:     const [expiryDays, costOptions] = await Promise.all([
 188:       getInviteExpiryDays(),
 189:       getInviteCostOptions()
 190:     ])
 191:     const expiresAt = expiryDays > 0
 192:       ? new Date(Date.now() + expiryDays * 24 * 60 * 60 * 1000)
 193:       : null
 194: 
 195:     try {
 196:       const createdInvites = await prisma.$transaction(async (tx) => {
 197:         const results: Awaited<ReturnType<typeof tx.inviteCode.create>>[] = []
 198: 
 199:         for (let index = 0; index < count; index++) {
 200:           const code = nanoid(12)
 201:           const costSnapshot = await chargeInviteGenerationCost(tx, userId, code, costResource, costOptions)
 202:           const invite = await tx.inviteCode.create({
 203:             data: {
 204:               code,
 205:               createdBy: userId,
 206:               expiresAt,
 207:               costSnapshot: costSnapshot as unknown as Prisma.InputJsonObject
 208:             }
 209:           })
 210:           results.push(invite)
 211:         }
 212: 
 213:         return results
 214:       })
 215: 
 216:       return {
 217:         invites: createdInvites.map(invite => toInviteCodePayload({ ...invite, user: null })),
 218:         count: createdInvites.length
 219:       }
 220:     } catch (err) {
 221:       const message = err instanceof Error ? err.message : String(err)
 222:       if (message === 'INVITE_COST_OPTION_UNAVAILABLE') {
 223:         return reply.code(400).send({ error: '当前邀请码生成方式不可用', code: 'INVITE_COST_OPTION_UNAVAILABLE' })
 224:       }
 225:       if (message === 'INVITE_COST_RESOURCE_UNSUPPORTED') {
 226:         return reply.code(400).send({ error: '暂不支持该生成方式', code: 'INVITE_COST_RESOURCE_UNSUPPORTED' })
 227:       }
 228:       if (message === 'INSUFFICIENT_BALANCE') {
 229:         return reply.code(400).send({ error: '余额不足', code: 'INSUFFICIENT_BALANCE' })
 230:       }
 231:       if (message === 'INSUFFICIENT_POINTS') {
 232:         return reply.code(400).send({ error: '积分不足', code: 'INSUFFICIENT_POINTS' })
 233:       }
 234:       if (message === 'USER_NOT_FOUND') {
 235:         return reply.code(404).send(apiError(ErrorCode.USER_NOT_FOUND))
 236:       }
 237:       throw err
 238:     }
 239:   })
 240: }
===== server/src/routes/friends.ts =====
   1: /**
   2:  * 好友系统 API 路由
   3:  * 提供好友添加、删除、请求管理等功能
   4:  */
   5: 
   6: import type { FastifyInstance, FastifyRequest, FastifyReply } from 'fastify'
   7: import * as db from '../db/index.js'
   8: import { createLog } from '../db/logs.js'
   9: import { apiError, ErrorCode } from '../lib/errors.js'
  10: import { sendNotification } from '../lib/notifier.js'
  11: 
  12: type FriendHistoryFilter = 'accepted' | 'rejected' | 'removed' | 'all'
  13: 
  14: const POSITIVE_ROUTE_ID_PATTERN = /^[1-9]\d*$/
  15: const friendHistoryFilters = new Set<FriendHistoryFilter>(['accepted', 'rejected', 'removed', 'all'])
  16: 
  17: function parsePositiveRouteId(value: string): number | null {
  18:   if (!POSITIVE_ROUTE_ID_PATTERN.test(value)) {
  19:     return null
  20:   }
  21: 
  22:   const parsed = Number(value)
  23:   return Number.isSafeInteger(parsed) ? parsed : null
  24: }
  25: 
  26: function parseFriendHistoryFilter(value: string | undefined): FriendHistoryFilter | undefined | null {
  27:   if (!value) {
  28:     return undefined
  29:   }
  30: 
  31:   return friendHistoryFilters.has(value as FriendHistoryFilter)
  32:     ? value as FriendHistoryFilter
  33:     : null
  34: }
  35: 
  36: export default async function friendsRoutes(fastify: FastifyInstance) {
  37:   // ==================== 好友列表 ====================
  38: 
  39:   /**
  40:    * 获取好友列表
  41:    * GET /api/friends
  42:    */
  43:   fastify.get('/', {
  44:     onRequest: [fastify.authenticateUser]
  45:   }, async (request: FastifyRequest, reply: FastifyReply) => {
  46:     const { user } = request
  47: 
  48:     try {
  49:       const friends = await db.getFriendList(user.id)
  50:       return { friends }
  51:     } catch (error) {
  52:       const message = error instanceof Error ? error.message : String(error)
  53:       console.error('[Friends] Failed to get friend list:', message)
  54:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, message))
  55:     }
  56:   })
  57: 
  58:   // ==================== 好友请求 ====================
  59: 
  60:   /**
  61:    * 发送好友请求
  62:    * POST /api/friends/request
  63:    */
  64:   fastify.post<{
  65:     Body: { username: string; remark?: string }
  66:   }>('/request', {
  67:     onRequest: [fastify.authenticateUser],
  68:     schema: {
  69:       body: {
  70:         type: 'object',
  71:         required: ['username'],
  72:         properties: {
  73:           username: { type: 'string', minLength: 1 },
  74:           remark: { type: 'string', maxLength: 200 }
  75:         }
  76:       }
  77:     }
  78:   }, async (request: FastifyRequest<{
  79:     Body: { username: string; remark?: string }
  80:   }>, reply: FastifyReply) => {
  81:     const { user } = request
  82:     const { username, remark } = request.body
  83: 
  84:     try {
  85:       // 搜索目标用户
  86:       const targetUser = await db.searchUserByUsername(username, user.id)
  87:       if (!targetUser) {
  88:         return reply.code(404).send(apiError(ErrorCode.USER_NOT_FOUND))
  89:       }
  90: 
  91:       // 发送好友请求
  92:       const result = await db.sendFriendRequest(user.id, targetUser.id, remark)
  93: 
  94:       // 如果是自动接受（对方已发送请求给我）
  95:       if (result.status === 'accepted') {
  96:         await createLog(
  97:           user.id,
  98:           'friend',
  99:           'friend.request_auto_accepted',
 100:           `Auto accepted friend request with user "${targetUser.username}"`,
 101:           'success'
 102:         )
 103: 
 104:         // 通知对方：他之前发的请求被接受了
 105:         await sendNotification(targetUser.id, 'friend_accepted', {
 106:           toUsername: user.username
 107:         }).catch(err => console.error('[Friends] Notification error:', err))
 108: 
 109:         // 通知当前用户：你们成为好友了（使用 friend_request 通知表示对方之前发过请求）
 110:         await sendNotification(user.id, 'friend_request', {
 111:           fromUsername: targetUser.username
 112:         }).catch(err => console.error('[Friends] Notification error:', err))
 113: 
 114:         return { message: '好友添加成功（对方已向您发送请求）', friendship: result }
 115:       }
 116: 
 117:       await createLog(
 118:         user.id,
 119:         'friend',
 120:         'friend.request_sent',
 121:         `Sent friend request to user "${targetUser.username}"`,
 122:         'success'
 123:       )
 124: 
 125:       // 通知目标用户收到好友请求
 126:       await sendNotification(targetUser.id, 'friend_request', {
 127:         fromUsername: user.username
 128:       }).catch(err => console.error('[Friends] Notification error:', err))
 129: 
 130:       return { message: '好友请求已发送', request: { id: result.id } }
 131:     } catch (error) {
 132:       const message = error instanceof Error ? error.message : String(error)
 133: 
 134:       if (message === 'ALREADY_FRIENDS') {
 135:         return reply.code(400).send(apiError(ErrorCode.ALREADY_FRIENDS))
 136:       }
 137:       if (message === 'REQUEST_PENDING') {
 138:         return reply.code(400).send(apiError(ErrorCode.FRIEND_REQUEST_PENDING))
 139:       }
 140: 
 141:       console.error('[Friends] Failed to send friend request:', message)
 142:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, message))
 143:     }
 144:   })
 145: 
 146:   /**
 147:    * 获取收到的待处理好友请求
 148:    * GET /api/friends/requests
 149:    */
 150:   fastify.get('/requests', {
 151:     onRequest: [fastify.authenticateUser]
 152:   }, async (request: FastifyRequest, reply: FastifyReply) => {
 153:     const { user } = request
 154: 
 155:     try {
 156:       const requests = await db.getPendingFriendRequests(user.id)
 157:       return { requests }
 158:     } catch (error) {
 159:       const message = error instanceof Error ? error.message : String(error)
 160:       console.error('[Friends] Failed to get pending requests:', message)
 161:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, message))
 162:     }
 163:   })
 164: 
 165:   /**
 166:    * 获取已发送的待处理好友请求
 167:    * GET /api/friends/requests/sent
 168:    */
 169:   fastify.get('/requests/sent', {
 170:     onRequest: [fastify.authenticateUser]
 171:   }, async (request: FastifyRequest, reply: FastifyReply) => {
 172:     const { user } = request
 173: 
 174:     try {
 175:       const requests = await db.getSentFriendRequests(user.id)
 176:       return { requests }
 177:     } catch (error) {
 178:       const message = error instanceof Error ? error.message : String(error)
 179:       console.error('[Friends] Failed to get sent requests:', message)
 180:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, message))
 181:     }
 182:   })
 183: 
 184:   /**
 185:    * 取消已发送的好友请求
 186:    * DELETE /api/friends/request/:id
 187:    */
 188:   fastify.delete<{
 189:     Params: { id: string }
 190:   }>('/request/:id', {
 191:     onRequest: [fastify.authenticateUser]
 192:   }, async (request: FastifyRequest<{
 193:     Params: { id: string }
 194:   }>, reply: FastifyReply) => {
 195:     const { user } = request
 196:     const requestId = parsePositiveRouteId(request.params.id)
 197: 
 198:     if (!requestId) {
 199:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 200:     }
 201: 
 202:     try {
 203:       await db.cancelFriendRequest(requestId, user.id)
 204: 
 205:       await createLog(
 206:         user.id,
 207:         'friend',
 208:         'friend.request_cancelled',
 209:         `Cancelled friend request #${requestId}`,
 210:         'success'
 211:       )
 212: 
 213:       return { message: '已取消好友请求' }
 214:     } catch (error) {
 215:       const message = error instanceof Error ? error.message : String(error)
 216: 
 217:       if (message === 'REQUEST_NOT_FOUND') {
 218:         return reply.code(404).send(apiError(ErrorCode.NOT_FOUND, '请求不存在'))
 219:       }
 220:       if (message === 'FORBIDDEN') {
 221:         return reply.code(403).send(apiError(ErrorCode.FORBIDDEN, '无权取消此请求'))
 222:       }
 223:       if (message === 'REQUEST_NOT_PENDING') {
 224:         return reply.code(400).send(apiError(ErrorCode.FRIEND_REQUEST_NOT_PENDING))
 225:       }
 226: 
 227:       console.error('[Friends] Failed to cancel request:', message)
 228:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, message))
 229:     }
 230:   })
 231: 
 232:   // ==================== 请求处理 ====================
 233: 
 234:   /**
 235:    * 接受好友请求
 236:    * POST /api/friends/:id/accept
 237:    */
 238:   fastify.post<{
 239:     Params: { id: string }
 240:   }>('/:id/accept', {
 241:     onRequest: [fastify.authenticateUser]
 242:   }, async (request: FastifyRequest<{
 243:     Params: { id: string }
 244:   }>, reply: FastifyReply) => {
 245:     const { user } = request
 246:     const requestId = parsePositiveRouteId(request.params.id)
 247: 
 248:     if (!requestId) {
 249:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 250:     }
 251: 
 252:     try {
 253:       // 获取请求信息
 254:       const friendship = await db.getFriendshipById(requestId)
 255:       if (!friendship) {
 256:         return reply.code(404).send(apiError(ErrorCode.FRIEND_REQUEST_NOT_FOUND))
 257:       }
 258: 
 259:       // 接受请求
 260:       const result = await db.acceptFriendRequest(requestId, user.id)
 261: 
 262:       await createLog(
 263:         user.id,
 264:         'friend',
 265:         'friend.request_accepted',
 266:         `Accepted friend request from user "${friendship.user.username}"`,
 267:         'success'
 268:       )
 269: 
 270:       // 通知发送者请求已被接受
 271:       await sendNotification(friendship.userId, 'friend_accepted', {
 272:         toUsername: user.username
 273:       }).catch(err => console.error('[Friends] Notification error:', err))
 274: 
 275:       return { message: '已接受好友请求', friendship: result }
 276:     } catch (error) {
 277:       const message = error instanceof Error ? error.message : String(error)
 278: 
 279:       if (message === 'REQUEST_NOT_FOUND') {
 280:         return reply.code(404).send(apiError(ErrorCode.FRIEND_REQUEST_NOT_FOUND))
 281:       }
 282:       if (message === 'FORBIDDEN') {
 283:         return reply.code(403).send(apiError(ErrorCode.FORBIDDEN, '无权处理此请求'))
 284:       }
 285:       if (message === 'REQUEST_NOT_PENDING') {
 286:         return reply.code(400).send(apiError(ErrorCode.FRIEND_REQUEST_NOT_PENDING))
 287:       }
 288: 
 289:       console.error('[Friends] Failed to accept request:', message)
 290:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, message))
 291:     }
 292:   })
 293: 
 294:   /**
 295:    * 拒绝好友请求
 296:    * POST /api/friends/:id/reject
 297:    */
 298:   fastify.post<{
 299:     Params: { id: string }
 300:   }>('/:id/reject', {
 301:     onRequest: [fastify.authenticateUser]
 302:   }, async (request: FastifyRequest<{
 303:     Params: { id: string }
 304:   }>, reply: FastifyReply) => {
 305:     const { user } = request
 306:     const requestId = parsePositiveRouteId(request.params.id)
 307: 
 308:     if (!requestId) {
 309:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 310:     }
 311: 
 312:     try {
 313:       // 获取请求信息用于日志
 314:       const friendship = await db.getFriendshipById(requestId)
 315:       if (!friendship) {
 316:         return reply.code(404).send(apiError(ErrorCode.FRIEND_REQUEST_NOT_FOUND))
 317:       }
 318: 
 319:       await db.rejectFriendRequest(requestId, user.id)
 320: 
 321:       await createLog(
 322:         user.id,
 323:         'friend',
 324:         'friend.request_rejected',
 325:         `Rejected friend request from user "${friendship.user.username}"`,
 326:         'success'
 327:       )
 328: 
 329:       // 通知发送者请求已被拒绝
 330:       await sendNotification(friendship.userId, 'friend_rejected', {
 331:         toUsername: user.username
 332:       }).catch(err => console.error('[Friends] Notification error:', err))
 333: 
 334:       return { message: '已拒绝好友请求' }
 335:     } catch (error) {
 336:       const message = error instanceof Error ? error.message : String(error)
 337: 
 338:       if (message === 'REQUEST_NOT_FOUND') {
 339:         return reply.code(404).send(apiError(ErrorCode.FRIEND_REQUEST_NOT_FOUND))
 340:       }
 341:       if (message === 'FORBIDDEN') {
 342:         return reply.code(403).send(apiError(ErrorCode.FORBIDDEN, '无权处理此请求'))
 343:       }
 344:       if (message === 'REQUEST_NOT_PENDING') {
 345:         return reply.code(400).send(apiError(ErrorCode.FRIEND_REQUEST_NOT_PENDING))
 346:       }
 347: 
 348:       console.error('[Friends] Failed to reject request:', message)
 349:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, message))
 350:     }
 351:   })
 352: 
 353:   // ==================== 好友管理 ====================
 354: 
 355:   /**
 356:    * 删除好友
 357:    * DELETE /api/friends/:id
 358:    */
 359:   fastify.delete<{
 360:     Params: { id: string }
 361:   }>('/:id', {
 362:     onRequest: [fastify.authenticateUser]
 363:   }, async (request: FastifyRequest<{
 364:     Params: { id: string }
 365:   }>, reply: FastifyReply) => {
 366:     const { user } = request
 367:     const friendshipId = parsePositiveRouteId(request.params.id)
 368: 
 369:     if (!friendshipId) {
 370:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 371:     }
 372: 
 373:     try {
 374:       // 获取好友关系信息
 375:       const friendship = await db.getFriendshipById(friendshipId)
 376:       if (!friendship) {
 377:         return reply.code(404).send(apiError(ErrorCode.FRIENDSHIP_NOT_FOUND))
 378:       }
 379: 
 380:       // 确定对方用户信息用于日志和通知
 381:       const friendUsername = friendship.userId === user.id ? friendship.friend.username : friendship.user.username
 382:       const friendUserId = friendship.userId === user.id ? friendship.friendId : friendship.userId
 383: 
 384:       await db.removeFriend(friendshipId, user.id)
 385: 
 386:       await createLog(
 387:         user.id,
 388:         'friend',
 389:         'friend.removed',
 390:         `Removed friend "${friendUsername}"`,
 391:         'success'
 392:       )
 393: 
 394:       // 通知被删除的好友
 395:       await sendNotification(friendUserId, 'friend_removed', {
 396:         fromUsername: user.username
 397:       }).catch(err => console.error('[Friends] Notification error:', err))
 398: 
 399:       return { message: '已删除好友' }
 400:     } catch (error) {
 401:       const message = error instanceof Error ? error.message : String(error)
 402: 
 403:       if (message === 'FRIENDSHIP_NOT_FOUND') {
 404:         return reply.code(404).send(apiError(ErrorCode.FRIENDSHIP_NOT_FOUND))
 405:       }
 406:       if (message === 'FORBIDDEN') {
 407:         return reply.code(403).send(apiError(ErrorCode.FORBIDDEN, '无权删除此好友'))
 408:       }
 409: 
 410:       console.error('[Friends] Failed to remove friend:', message)
 411:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, message))
 412:     }
 413:   })
 414: 
 415:   // ==================== 历史记录与搜索 ====================
 416: 
 417:   /**
 418:    * 获取好友请求历史记录
 419:    * GET /api/friends/history
 420:    */
 421:   fastify.get<{
 422:     Querystring: { filter?: 'accepted' | 'rejected' | 'removed' | 'all' }
 423:   }>('/history', {
 424:     onRequest: [fastify.authenticateUser]
 425:   }, async (request: FastifyRequest<{
 426:     Querystring: { filter?: 'accepted' | 'rejected' | 'removed' | 'all' }
 427:   }>, reply: FastifyReply) => {
 428:     const { user } = request
 429:     const filter = parseFriendHistoryFilter(request.query.filter)
 430: 
 431:     if (filter === null) {
 432:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid history filter'))
 433:     }
 434: 
 435:     try {
 436:       const history = await db.getRequestHistory(user.id, filter)
 437:       return { history }
 438:     } catch (error) {
 439:       const message = error instanceof Error ? error.message : String(error)
 440:       console.error('[Friends] Failed to get history:', message)
 441:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, message))
 442:     }
 443:   })
 444: 
 445:   /**
 446:    * 搜索用户（用于添加好友）
 447:    * GET /api/friends/search
 448:    */
 449:   fastify.get<{
 450:     Querystring: { username: string }
 451:   }>('/search', {
 452:     onRequest: [fastify.authenticateUser],
 453:     schema: {
 454:       querystring: {
 455:         type: 'object',
 456:         required: ['username'],
 457:         properties: {
 458:           username: { type: 'string', minLength: 1 }
 459:         }
 460:       }
 461:     }
 462:   }, async (request: FastifyRequest<{
 463:     Querystring: { username: string }
 464:   }>, reply: FastifyReply) => {
 465:     const { user } = request
 466:     const { username } = request.query
 467: 
 468:     try {
 469:       const targetUser = await db.searchUserByUsername(username, user.id)
 470:       if (!targetUser) {
 471:         return reply.code(404).send(apiError(ErrorCode.USER_NOT_FOUND, '用户不存在'))
 472:       }
 473: 
 474:       // 检查是否已是好友
 475:       const isFriend = await db.areFriends(user.id, targetUser.id)
 476: 
 477:       return {
 478:         user: {
 479:           id: targetUser.id,
 480:           username: targetUser.username,
 481:           avatarStyle: targetUser.avatarStyle,
 482:           isFriend
 483:         }
 484:       }
 485:     } catch (error) {
 486:       const message = error instanceof Error ? error.message : String(error)
 487:       console.error('[Friends] Failed to search user:', message)
 488:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, message))
 489:     }
 490:   })
 491: 
 492:   /**
 493:    * 获取好友的资源统计
 494:    * GET /api/friends/:id/resources
 495:    */
 496:   fastify.get<{
 497:     Params: { id: string }
 498:   }>('/:id/resources', {
 499:     onRequest: [fastify.authenticateUser]
 500:   }, async (request: FastifyRequest<{
 501:     Params: { id: string }
 502:   }>, reply: FastifyReply) => {
 503:     const { user } = request
 504:     const friendshipId = parsePositiveRouteId(request.params.id)
 505: 
 506:     if (!friendshipId) {
 507:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 508:     }
 509: 
 510:     try {
 511:       const friendship = await db.getFriendshipById(friendshipId)
 512:       if (!friendship) {
 513:         return reply.code(404).send(apiError(ErrorCode.NOT_FOUND, '好友关系不存在'))
 514:       }
 515: 
 516:       // 验证权限
 517:       if (friendship.userId !== user.id && friendship.friendId !== user.id) {
 518:         return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 519:       }
 520: 
 521:       // 确定好友的用户ID
 522:       const friendUserId = friendship.userId === user.id ? friendship.friendId : friendship.userId
 523: 
 524:       // 获取好友的资源统计 - 使用 prisma 直接查询
 525:       const { prisma } = await import('../db/prisma.js')
 526:       const [hostCount, packageCount] = await Promise.all([
 527:         prisma.host.count({ where: { userId: friendUserId } }),
 528:         prisma.package.count({ where: { userId: friendUserId } })
 529:       ])
 530: 
 531:       return {
 532:         resources: {
 533:           hosts: hostCount,
 534:           images: 0, // 镜像是节点级别的，不是用户级别
 535:           packages: packageCount
 536:         }
 537:       }
 538:     } catch (error) {
 539:       const message = error instanceof Error ? error.message : String(error)
 540:       console.error('[Friends] Failed to get friend resources:', message)
 541:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, message))
 542:     }
 543:   })
 544: }
===== server/src/lib/invite-pricing.ts =====
   1: import { Prisma } from '@prisma/client'
   2: import { prisma } from '../db/prisma.js'
   3: import {
   4:   USER_BALANCE_LOCK_NAMESPACE,
   5:   USER_POINTS_LOCK_NAMESPACE,
   6:   advisoryTransactionLock
   7: } from '../db/advisory-locks.js'
   8: import { getSystemConfig, getSystemConfigNumber } from '../db/system-config.js'
   9: 
  10: export type InviteCostResource = 'balance' | 'points' | (string & {})
  11: 
  12: export interface InviteCostOption {
  13:   resource: InviteCostResource
  14:   amount: number
  15:   enabled: boolean
  16: }
  17: 
  18: export interface InviteCostQuote extends InviteCostOption {
  19:   label: string
  20:   unit: string
  21:   displayAmount: string
  22: }
  23: 
  24: export interface InviteGenerationCostSnapshot {
  25:   resource: InviteCostResource
  26:   amount: number
  27:   label: string
  28:   unit: string
  29:   displayAmount: string
  30:   chargedAt: string
  31: }
  32: 
  33: interface InviteCostResourceHandler {
  34:   resource: InviteCostResource
  35:   label: string
  36:   unit: string
  37:   normalizeAmount(amount: number): number
  38:   format(amount: number): string
  39:   charge(tx: Prisma.TransactionClient, userId: number, amount: number, inviteCode: string): Promise<void>
  40: }
  41: 
  42: const defaultInviteCostOptions: InviteCostOption[] = [
  43:   { resource: 'balance', amount: 0, enabled: false },
  44:   { resource: 'points', amount: 0, enabled: false }
  45: ]
  46: 
  47: const inviteCostResourceHandlers: Record<string, InviteCostResourceHandler> = {
  48:   balance: {
  49:     resource: 'balance',
  50:     label: '余额',
  51:     unit: '元',
  52:     normalizeAmount(amount: number) {
  53:       return Math.round(Math.max(0, amount) * 100) / 100
  54:     },
  55:     format(amount: number) {
  56:       return `¥${amount.toFixed(2)}`
  57:     },
  58:     async charge(tx, userId, amount, inviteCode) {
  59:       if (amount <= 0) return
  60: 
  61:       await advisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, userId)
  62: 
  63:       const rows = await tx.$queryRaw<Array<{ balanceBefore: unknown; balanceAfter: unknown }>>(Prisma.sql`
  64:         UPDATE users
  65:         SET balance = balance - ${amount}
  66:         WHERE id = ${userId} AND balance >= ${amount}
  67:         RETURNING (balance + ${amount})::numeric AS "balanceBefore", balance::numeric AS "balanceAfter"
  68:       `)
  69: 
  70:       if (rows.length !== 1) {
  71:         const userExists = await tx.user.findUnique({
  72:           where: { id: userId },
  73:           select: { id: true }
  74:         })
  75:         if (!userExists) {
  76:           throw new Error('USER_NOT_FOUND')
  77:         }
  78:         throw new Error('INSUFFICIENT_BALANCE')
  79:       }
  80: 
  81:       const balanceBefore = Number(rows[0].balanceBefore)
  82:       const balanceAfter = Number(rows[0].balanceAfter)
  83: 
  84:       await tx.balanceLog.create({
  85:         data: {
  86:           userId,
  87:           type: 'invite_generate',
  88:           amount: -amount,
  89:           balanceBefore,
  90:           balanceAfter,
  91:           remark: `生成邀请码 ${inviteCode}`
  92:         }
  93:       })
  94:     }
  95:   },
  96:   points: {
  97:     resource: 'points',
  98:     label: '积分',
  99:     unit: '积分',
 100:     normalizeAmount(amount: number) {
 101:       return Math.max(0, Math.floor(amount))
 102:     },
 103:     format(amount: number) {
 104:       return `${Math.floor(amount)} 积分`
 105:     },
 106:     async charge(tx, userId, amount, inviteCode) {
 107:       if (amount <= 0) return
 108: 
 109:       await advisoryTransactionLock(tx, USER_POINTS_LOCK_NAMESPACE, userId)
 110: 
 111:       await tx.userPoints.upsert({
 112:         where: { userId },
 113:         update: {},
 114:         create: { userId }
 115:       })
 116: 
 117:       const rows = await tx.$queryRaw<Array<{ pointsBefore: number; pointsAfter: number }>>(Prisma.sql`
 118:         UPDATE user_points
 119:         SET points = points - ${amount},
 120:             total_spent = total_spent + ${amount},
 121:             updated_at = NOW()
 122:         WHERE user_id = ${userId} AND points >= ${amount}
 123:         RETURNING points + ${amount} AS "pointsBefore", points AS "pointsAfter"
 124:       `)
 125: 
 126:       if (rows.length !== 1) {
 127:         throw new Error('INSUFFICIENT_POINTS')
 128:       }
 129: 
 130:       await tx.pointsLog.create({
 131:         data: {
 132:           userId,
 133:           type: 'invite_generate',
 134:           amount: -amount,
 135:           pointsBefore: rows[0].pointsBefore,
 136:           pointsAfter: rows[0].pointsAfter,
 137:           remark: `生成邀请码 ${inviteCode}`
 138:         }
 139:       })
 140:     }
 141:   }
 142: }
 143: 
 144: export function isSupportedInviteCostResource(resource: string): boolean {
 145:   return resource in inviteCostResourceHandlers
 146: }
 147: 
 148: function parseInviteCostConfig(raw: string | null): InviteCostOption[] {
 149:   if (!raw) return defaultInviteCostOptions
 150: 
 151:   try {
 152:     const parsed = JSON.parse(raw)
 153:     if (!Array.isArray(parsed)) return defaultInviteCostOptions
 154: 
 155:     return parsed
 156:       .map((item): InviteCostOption | null => {
 157:         if (!item || typeof item !== 'object') return null
 158:         const resource = String((item as { resource?: unknown }).resource || '').trim()
 159:         if (!resource) return null
 160:         const amount = Number((item as { amount?: unknown }).amount)
 161:         const handler = inviteCostResourceHandlers[resource]
 162:         const normalizedAmount = handler
 163:           ? handler.normalizeAmount(Number.isFinite(amount) ? amount : 0)
 164:           : Math.max(0, Number.isFinite(amount) ? amount : 0)
 165: 
 166:         return {
 167:           resource,
 168:           amount: normalizedAmount,
 169:           enabled: (item as { enabled?: unknown }).enabled === true
 170:         }
 171:       })
 172:       .filter((item): item is InviteCostOption => item !== null)
 173:   } catch {
 174:     return defaultInviteCostOptions
 175:   }
 176: }
 177: 
 178: function ensureDefaultCostOptions(options: InviteCostOption[]): InviteCostOption[] {
 179:   const map = new Map(options.map(option => [option.resource, option]))
 180:   for (const option of defaultInviteCostOptions) {
 181:     if (!map.has(option.resource)) {
 182:       map.set(option.resource, option)
 183:     }
 184:   }
 185:   return Array.from(map.values())
 186: }
 187: 
 188: export function normalizeInviteCostOptions(options: InviteCostOption[]): InviteCostOption[] {
 189:   return ensureDefaultCostOptions(options).map(option => {
 190:     const handler = inviteCostResourceHandlers[option.resource]
 191:     const amount = handler
 192:       ? handler.normalizeAmount(option.amount)
 193:       : Math.max(0, Number.isFinite(option.amount) ? option.amount : 0)
 194: 
 195:     return {
 196:       resource: option.resource,
 197:       amount,
 198:       enabled: option.enabled
 199:     }
 200:   })
 201: }
 202: 
 203: export function serializeInviteCostOptions(options: InviteCostOption[]): string {
 204:   return JSON.stringify(normalizeInviteCostOptions(options))
 205: }
 206: 
 207: export async function getInviteCostOptions(): Promise<InviteCostOption[]> {
 208:   const raw = await getSystemConfig('invite_generation_costs')
 209:   return normalizeInviteCostOptions(parseInviteCostConfig(raw))
 210: }
 211: 
 212: export async function getInviteExpiryDays(): Promise<number> {
 213:   return Math.max(0, await getSystemConfigNumber('invite_default_expire_days', 0))
 214: }
 215: 
 216: export async function getInviteCostQuotes(): Promise<InviteCostQuote[]> {
 217:   return (await getInviteCostOptions()).map(option => {
 218:     const handler = inviteCostResourceHandlers[option.resource]
 219:     const label = handler?.label || option.resource
 220:     const unit = handler?.unit || ''
 221:     const displayAmount = handler?.format(option.amount) || `${option.amount}${unit}`
 222: 
 223:     return {
 224:       ...option,
 225:       label,
 226:       unit,
 227:       displayAmount
 228:     }
 229:   })
 230: }
 231: 
 232: export async function chargeInviteGenerationCost(
 233:   tx: Prisma.TransactionClient,
 234:   userId: number,
 235:   inviteCode: string,
 236:   resource: string,
 237:   costOptions?: InviteCostOption[]
 238: ): Promise<InviteGenerationCostSnapshot> {
 239:   const options = costOptions ?? await getInviteCostOptions()
 240:   const option = options.find(cost => cost.resource === resource && cost.enabled)
 241:   if (!option) {
 242:     throw new Error('INVITE_COST_OPTION_UNAVAILABLE')
 243:   }
 244: 
 245:   const handler = inviteCostResourceHandlers[option.resource]
 246:   if (!handler) {
 247:     throw new Error('INVITE_COST_RESOURCE_UNSUPPORTED')
 248:   }
 249: 
 250:   await handler.charge(tx, userId, option.amount, inviteCode)
 251: 
 252:   return {
 253:     resource: option.resource,
 254:     amount: option.amount,
 255:     label: handler.label,
 256:     unit: handler.unit,
 257:     displayAmount: handler.format(option.amount),
 258:     chargedAt: new Date().toISOString()
 259:   }
 260: }
 261: 
 262: export async function getUserInviteBalances(userId: number): Promise<{
 263:   balance: number
 264:   points: number
 265: }> {
 266:   const [user, userPoints] = await Promise.all([
 267:     prisma.user.findUnique({
 268:       where: { id: userId },
 269:       select: { balance: true }
 270:     }),
 271:     prisma.userPoints.upsert({
 272:       where: { userId },
 273:       update: {},
 274:       create: { userId }
 275:     })
 276:   ])
 277: 
 278:   return {
 279:     balance: user ? Number(user.balance) : 0,
 280:     points: userPoints.points
 281:   }
 282: }

