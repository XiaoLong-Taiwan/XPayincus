 472: /**
 473:  * 创建实例与优惠码的绑定关系（开通时调用）
 474:  */
 475: export async function createAffBinding(
 476:   instanceId: number,
 477:   affCodeId: number,
 478:   tx?: Prisma.TransactionClient
 479: ): Promise<void> {
 480:   const client = tx || prisma
 481:   await client.affBinding.create({
 482:     data: { instanceId, affCodeId }
 483:   })
 484: }
