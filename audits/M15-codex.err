 410:       }
 411: 
 412:       const existingUsername = await tx.user.findUnique({
 413:         where: { username: input.username },
 414:         select: { id: true }
 415:       })
 416:       if (existingUsername) {
 417:         throw new Error('USER_EXISTS')
 418:       }
 419: 
 420:       if (normalizedEmail) {
 421:         const existingEmail = await tx.user.findFirst({
 422:           where: {
 423:             email: {
 424:               equals: normalizedEmail,
 425:               mode: 'insensitive'
 426:             }
 427:           },
 428:           select: { id: true }
 429:         })
 430:         if (existingEmail) {
 431:           throw new Error('EMAIL_ALREADY_REGISTERED')
 432:         }
 433:       }
 434: 
