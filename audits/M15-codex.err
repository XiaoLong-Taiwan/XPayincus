 758: /**
 759:  * 获取用户的转化申请（分页）
 760:  */
 761: export async function getUserAffWithdrawals(
 762:   userId: number,
 763:   options: {
 764:     page?: number
 765:     pageSize?: number
 766:     status?: AffWithdrawalStatus
 767:   } = {}
 768: ): Promise<{
 769:   withdrawals: AffWithdrawal[]
 770:   total: number
 771:   page: number
 772:   pageSize: number
 773: }> {
 774:   const { page, pageSize } = clampPagination(options.page, options.pageSize)
 775:   const status = normalizeAffWithdrawalStatus(options.status)
 776:   const skip = (page - 1) * pageSize
 777: 
 778:   const where: Prisma.AffWithdrawalWhereInput = {
 779:     userId,
 780:     ...(status ? { status } : {})
 781:   }
 782: 
 783:   const [withdrawals, total] = await Promise.all([
 784:     prisma.affWithdrawal.findMany({
 785:       where,
 786:       orderBy: { createdAt: 'desc' },
 787:       skip,
 788:       take: pageSize
 789:     }),
 790:     prisma.affWithdrawal.count({ where })
 791:   ])
 792: 
 793:   return { withdrawals, total, page, pageSize }
 794: }
