 286: /**
 287:  * 创建优惠码（支持方案专有码和全局码）
 288:  * @param packagePlanId 不传或传 undefined 则创建全局码
 289:  * 折扣率和返利率固定为 5%/5%
 290:  */
 291: export async function createAffCode(
 292:   userId: number,
 293:   packagePlanId?: number
 294: ): Promise<{ success: boolean; affCode?: AffCode; error?: string }> {
 295:   try {
 296:     // 1. 检查是否已激活 AFF
 297:     const activated = await isAffActivated(userId)
 298:     if (!activated) {
 299:       return { success: false, error: '推荐计划尚未激活，请先充值任意金额' }
 300:     }
 301: 
 302:     // 固定折扣率和返利率为 5%/5%
 303:     const discountRate = 0.05
 304:     const commissionRate = 0.05
 305: 
 306:     // 全局码逻辑 - 允许创建多个
 307:     if (packagePlanId === undefined) {
 308:       try {
 309:         const code = generateAffCode(userId)
 310:         const affCode = await prisma.affCode.create({
 311:           data: {
 312:             code,
 313:             userId,
 314:             packagePlanId: null,
 315:             discountRate,
 316:             commissionRate
 317:           }
 318:         })
 319:         return { success: true, affCode }
 320:       } catch (error) {
 321:         return { success: false, error: '创建全局优惠码失败' }
 322:       }
 323:     }
 324: 
 325:     // 方案专有码逻辑（原有逻辑）
 326:     // 2. 检查方案是否存在且为付费方案
 327:     const plan = await prisma.packagePlan.findUnique({
 328:       where: { id: packagePlanId },
 329:       select: { id: true, price: true, isActive: true }
 330:     })
 331:     if (!plan || Number(plan.price) <= 0) {
 332:       return { success: false, error: '方案不存在或不是付费方案' }
 333:     }
 334:     if (!plan.isActive) {
 335:       return { success: false, error: '方案已下架' }
 336:     }
 337: 
 338:     // 3. 检查用户是否购买过该方案
 339:     const hasPurchased = await prisma.instance.count({
 340:       where: {
 341:         userId,
 342:         packagePlanId
 343:       }
 344:     })
 345:     if (hasPurchased === 0) {
 346:       return { success: false, error: '您尚未购买过此方案，无法创建优惠码' }
 347:     }
 348: 
 349:     // 4. 检查是否已创建过（唯一约束会自动阻止，但这里提前检查给出友好提示）
 350:     const existing = await prisma.affCode.findUnique({
 351:       where: { userId_packagePlanId: { userId, packagePlanId } }
 352:     })
 353:     if (existing) {
 354:       return { success: false, error: '该方案已创建过优惠码' }
 355:     }
 356: 
 357:     // 5. 创建优惠码
 358:     const code = generateAffCode(userId)
 359:     const affCode = await prisma.affCode.create({
 360:       data: {
 361:         code,
 362:         userId,
 363:         packagePlanId,
 364:         discountRate,
 365:         commissionRate
 366:       }
 367:     })
 368: 
 369:     return { success: true, affCode }
 370:   } catch (error) {
 371:     return {
 372:       success: false,
 373:       error: error instanceof Error ? error.message : '创建优惠码失败'
 374:     }
 375:   }
 376: }
 377: 
 378: /**
 379:  * 删除优惠码（仅允许删除未产生收益且未绑定任何订阅的优惠码）
 380:  */
 381: export async function deleteAffCode(
 382:   userId: number,
 383:   codeId: number
 384: ): Promise<{ success: boolean; code?: string; error?: string }> {
 385:   try {
 386:     // 1. 查找优惠码
 387:     const affCode = await prisma.affCode.findUnique({
 388:       where: { id: codeId },
 389:       select: { id: true, code: true, userId: true, usedCount: true }
 390:     })
 391: 
 392:     if (!affCode) {
 393:       return { success: false, error: '优惠码不存在' }
 394:     }
 395: 
 396:     // 2. 检查所有权
 397:     if (affCode.userId !== userId) {
 398:       return { success: false, error: '无权删除此优惠码' }
 399:     }
 400: 
 401:     // 3. 检查使用次数和现有绑定
 402:     if (affCode.usedCount > 0) {
 403:       return { success: false, error: '该优惠码已被使用，无法删除' }
 404:     }
 405: 
 406:     const [instanceBindingCount, mailBindingCount] = await Promise.all([
 407:       prisma.affBinding.count({ where: { affCodeId: codeId } }),
 408:       prisma.mailSubscriptionAffBinding.count({ where: { affCodeId: codeId } })
 409:     ])
 410: 
 411:     if (instanceBindingCount > 0 || mailBindingCount > 0) {
 412:       return { success: false, error: '该优惠码已绑定订阅，无法删除' }
 413:     }
 414: 
 415:     // 4. 删除优惠码
 416:     await prisma.affCode.delete({
 417:       where: { id: codeId }
 418:     })
 419: 
 420:     return { success: true, code: affCode.code }
 421:   } catch (error) {
 422:     return {
 423:       success: false,
 424:       error: error instanceof Error ? error.message : '删除优惠码失败'
 425:     }
 426:   }
 427: }
 428: 
 429: /**
 430:  * 验证优惠码（支持全局码）
 431:  */
 432: export async function validateAffCode(
 433:   code: string,
 434:   packagePlanId: number,
 435:   userId: number
 436: ): Promise<{
 437:   valid: boolean
 438:   affCode?: AffCode
 439:   discountRate?: number
 440:   commissionRate?: number
 441:   error?: string
 442: }> {
 443:   // 1. 查询优惠码
 444:   const affCode = await prisma.affCode.findUnique({
 445:     where: { code: code.toUpperCase() }
 446:   })
 447: 
 448:   if (!affCode) {
 449:     return { valid: false, error: '优惠码不存在' }
 450:   }
 451: 
 452:   // 2. 检查方案是否匹配（全局码跳过此检查）
 453:   if (affCode.packagePlanId !== null && affCode.packagePlanId !== packagePlanId) {
 454:     return { valid: false, error: '优惠码不适用于此方案' }
 455:   }
 456: 
 457:   // 3. 检查是否自己的优惠码
 458:   if (affCode.userId === userId) {
 459:     return { valid: false, error: '不能使用自己的优惠码' }
 460:   }
 461: 
 462:   return {
 463:     valid: true,
 464:     affCode,
 465:     discountRate: Number(affCode.discountRate),
 466:     commissionRate: Number(affCode.commissionRate)
 467:   }
 468: }
