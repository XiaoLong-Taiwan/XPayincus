===== server/src/routes/aff.ts =====
   1: /**
   2:  * AFF 推荐计划路由
   3:  */
   4: 
   5: import type { FastifyInstance, FastifyRequest, FastifyReply } from 'fastify'
   6: import type { AffLogType, AffWithdrawalStatus } from '@prisma/client'
   7: import * as db from '../db/index.js'
   8: import { createLog } from '../db/logs.js'
   9: import { createInboxMessage } from '../db/inbox.js'
  10: import { apiError, ErrorCode } from '../lib/errors.js'
  11: 
  12: const POSITIVE_ROUTE_ID_PATTERN = /^[1-9]\d*$/
  13: const AFF_ROUTE_MAX_PAGE_SIZE = 100
  14: const AFF_REJECT_REASON_MAX_LENGTH = 500
  15: const AFF_LOG_TYPES = new Set<AffLogType>(['new_purchase', 'renew', 'convert'])
  16: const AFF_WITHDRAWAL_STATUSES = new Set<AffWithdrawalStatus>(['pending', 'approved', 'rejected'])
  17: 
  18: function parsePositiveRouteId(value: string): number | null {
  19:   if (!POSITIVE_ROUTE_ID_PATTERN.test(value)) {
  20:     return null
  21:   }
  22: 
  23:   const parsed = Number(value)
  24:   return Number.isSafeInteger(parsed) ? parsed : null
  25: }
  26: 
  27: function parseOptionalPositiveQueryInteger(value: string | undefined): number | null | undefined {
  28:   if (value === undefined) {
  29:     return undefined
  30:   }
  31: 
  32:   return parsePositiveRouteId(value)
  33: }
  34: 
  35: function parseClampedPositiveQueryInteger(value: string | undefined, fallback: number, max: number): number | null {
  36:   const parsed = parseOptionalPositiveQueryInteger(value)
  37:   if (parsed === null) {
  38:     return null
  39:   }
  40: 
  41:   return Math.min(parsed ?? fallback, max)
  42: }
  43: 
  44: function parseOptionalAffLogType(value: string | undefined): AffLogType | null | undefined {
  45:   if (value === undefined) {
  46:     return undefined
  47:   }
  48: 
  49:   return AFF_LOG_TYPES.has(value as AffLogType) ? value as AffLogType : null
  50: }
  51: 
  52: function parseOptionalAffWithdrawalStatus(value: string | undefined): AffWithdrawalStatus | null | undefined {
  53:   if (value === undefined) {
  54:     return undefined
  55:   }
  56: 
  57:   return AFF_WITHDRAWAL_STATUSES.has(value as AffWithdrawalStatus) ? value as AffWithdrawalStatus : null
  58: }
  59: 
  60: function normalizeRequiredText(value: unknown, maxLength: number): string | null {
  61:   if (typeof value !== 'string') {
  62:     return null
  63:   }
  64: 
  65:   const trimmed = value.trim()
  66:   if (!trimmed || trimmed.length > maxLength) {
  67:     return null
  68:   }
  69: 
  70:   return trimmed
  71: }
  72: 
  73: export default async function affRoutes(fastify: FastifyInstance) {
  74:   // ==================== 用户 AFF API ====================
  75: 
  76:   // 获取 AFF 状态和统计
  77:   fastify.get('/me', {
  78:     onRequest: [fastify.authenticate]
  79:   }, async (request: FastifyRequest) => {
  80:     const { user } = request
  81:     const [activated, stats] = await Promise.all([
  82:       db.isAffActivated(user.id),
  83:       db.getAffStats(user.id)
  84:     ])
  85: 
  86:     return {
  87:       activated,
  88:       ...stats
  89:     }
  90:   })
  91: 
  92:   // 获取我的优惠码列表（包括全局码）
  93:   fastify.get('/me/codes', {
  94:     onRequest: [fastify.authenticate]
  95:   }, async (request: FastifyRequest) => {
  96:     const { user } = request
  97:     const codes = await db.getUserAffCodes(user.id)
  98: 
  99:     return {
 100:       codes: codes.map(code => ({
 101:         id: code.id,
 102:         code: code.code,
 103:         packagePlanId: code.packagePlanId,
 104:         planName: code.packagePlan?.name || null,
 105:         packageName: code.packagePlan?.package.name || null,
 106:         price: code.packagePlan?.price || null,
 107:         isGlobal: code.packagePlanId === null,
 108:         discountRate: Number(code.discountRate),
 109:         commissionRate: Number(code.commissionRate),
 110:         usedCount: code.usedCount,
 111:         totalEarnings: Number(code.totalEarnings),
 112:         createdAt: code.createdAt.toISOString()
 113:       }))
 114:     }
 115:   })
 116: 
 117:   // 获取可创建优惠码的方案列表（包含全局码状态）
 118:   fastify.get('/me/available-plans', {
 119:     onRequest: [fastify.authenticate]
 120:   }, async (request: FastifyRequest, reply: FastifyReply) => {
 121:     const { user } = request
 122: 
 123:     // 检查是否已激活
 124:     const activated = await db.isAffActivated(user.id)
 125:     if (!activated) {
 126:       return reply.code(400).send({ error: '推荐计划尚未激活，请先充值任意金额' })
 127:     }
 128: 
 129:     const result = await db.getAvailablePlansForAffCode(user.id)
 130: 
 131:     return {
 132:       plans: result.plans.map(plan => ({
 133:         id: plan.id,
 134:         name: plan.name,
 135:         price: plan.price,
 136:         packageName: plan.package.name,
 137:         hasCode: plan.hasCode
 138:       })),
 139:       hasGlobalCode: result.hasGlobalCode
 140:     }
 141:   })
 142: 
 143:   // 创建优惠码（支持方案专有码和全局码，固定 5% 折扣/5% 返利）
 144:   fastify.post<{
 145:     Body: { packagePlanId?: number }
 146:   }>('/me/codes', {
 147:     onRequest: [fastify.authenticate],
 148:     config: { rateLimit: { max: 10, timeWindow: '1 minute' } }
 149:   }, async (request: FastifyRequest<{ Body: { packagePlanId?: number } }>, reply: FastifyReply) => {
 150:     const { user } = request
 151:     const { packagePlanId } = request.body
 152: 
 153:     // 验证 packagePlanId 如果提供必须是正整数
 154:     if (packagePlanId !== undefined) {
 155:       if (typeof packagePlanId !== 'number' || !Number.isInteger(packagePlanId) || packagePlanId <= 0) {
 156:         return reply.code(400).send({ error: '方案 ID 无效' })
 157:       }
 158:     }
 159: 
 160:     // packagePlanId 为 undefined 时创建全局码
 161:     const result = await db.createAffCode(user.id, packagePlanId)
 162: 
 163:     if (!result.success) {
 164:       return reply.code(400).send({ error: result.error })
 165:     }
 166: 
 167:     const isGlobal = result.affCode!.packagePlanId === null
 168:     await createLog(
 169:       user.id,
 170:       'user',
 171:       'aff.create_code',
 172:       isGlobal 
 173:         ? `Created global AFF code ${result.affCode!.code}`
 174:         : `Created AFF code ${result.affCode!.code} for plan #${packagePlanId}`,
 175:       'success'
 176:     )
 177: 
 178:     return {
 179:       message: isGlobal ? '全局优惠码创建成功' : '优惠码创建成功',
 180:       code: {
 181:         id: result.affCode!.id,
 182:         code: result.affCode!.code,
 183:         packagePlanId: result.affCode!.packagePlanId,
 184:         isGlobal,
 185:         discountRate: Number(result.affCode!.discountRate),
 186:         commissionRate: Number(result.affCode!.commissionRate),
 187:         createdAt: result.affCode!.createdAt.toISOString()
 188:       }
 189:     }
 190:   })
 191: 
 192:   // 删除优惠码（仅允许删除使用次数为 0 的优惠码）
 193:   fastify.delete<{
 194:     Params: { codeId: string }
 195:   }>('/me/codes/:codeId', {
 196:     onRequest: [fastify.authenticate],
 197:     config: { rateLimit: { max: 10, timeWindow: '1 minute' } }
 198:   }, async (request: FastifyRequest<{ Params: { codeId: string } }>, reply: FastifyReply) => {
 199:     const { user } = request
 200:     const codeId = parsePositiveRouteId(request.params.codeId)
 201: 
 202:     if (!codeId) {
 203:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 204:     }
 205: 
 206:     const result = await db.deleteAffCode(user.id, codeId)
 207: 
 208:     if (!result.success) {
 209:       return reply.code(400).send({ error: result.error })
 210:     }
 211: 
 212:     await createLog(
 213:       user.id,
 214:       'user',
 215:       'aff.delete_code',
 216:       `Deleted AFF code ${result.code}`,
 217:       'success'
 218:     )
 219: 
 220:     return { message: '优惠码已删除' }
 221:   })
 222: 
 223:   // 获取 AFF 收益日志
 224:   fastify.get<{
 225:     Querystring: {
 226:       page?: string
 227:       pageSize?: string
 228:       type?: string
 229:     }
 230:   }>('/me/logs', {
 231:     onRequest: [fastify.authenticate]
 232:   }, async (request: FastifyRequest<{ Querystring: { page?: string; pageSize?: string; type?: string } }>, reply: FastifyReply) => {
 233:     const { user } = request
 234:     const { page = '1', pageSize = '20', type } = request.query
 235:     const parsedPage = parseClampedPositiveQueryInteger(page, 1, Number.MAX_SAFE_INTEGER)
 236:     const parsedPageSize = parseClampedPositiveQueryInteger(pageSize, 20, AFF_ROUTE_MAX_PAGE_SIZE)
 237:     const parsedType = parseOptionalAffLogType(type)
 238: 
 239:     if (parsedPage === null || parsedPageSize === null || parsedType === null) {
 240:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS))
 241:     }
 242: 
 243:     const result = await db.getAffLogs(user.id, {
 244:       page: parsedPage,
 245:       pageSize: parsedPageSize,
 246:       type: parsedType
 247:     })
 248: 
 249:     return {
 250:       logs: result.logs.map(log => ({
 251:         id: log.id,
 252:         type: log.type,
 253:         amount: Number(log.amount),
 254:         originalAmount: log.originalAmount ? Number(log.originalAmount) : null,
 255:         balanceBefore: Number(log.balanceBefore),
 256:         balanceAfter: Number(log.balanceAfter),
 257:         affCodeId: log.affCodeId,
 258:         affCode: log.affCode?.code || null,
 259:         instanceId: log.instanceId,
 260:         remark: log.remark,
 261:         createdAt: log.createdAt.toISOString()
 262:       })),
 263:       total: result.total,
 264:       page: result.page,
 265:       pageSize: result.pageSize
 266:     }
 267:   })
 268: 
 269:   // 获取 AFF 收益榜单 TOP 10
 270:   fastify.get('/leaderboard', {
 271:     onRequest: [fastify.authenticate],
 272:     config: { rateLimit: { max: 30, timeWindow: '1 minute' } }
 273:   }, async (request: FastifyRequest) => {
 274:     const { user } = request
 275:     const leaderboard = await db.getAffLeaderboard(user.id)
 276:     return { leaderboard }
 277:   })
 278: 
 279:   // 验证优惠码（开通实例时调用）
 280:   fastify.post<{
 281:     Body: {
 282:       code: string
 283:       packagePlanId: number
 284:     }
 285:   }>('/validate', {
 286:     onRequest: [fastify.authenticate],
 287:     config: { rateLimit: { max: 30, timeWindow: '1 minute' } }
 288:   }, async (request: FastifyRequest<{ Body: { code: string; packagePlanId: number } }>, reply: FastifyReply) => {
 289:     const { user } = request
 290:     const { code, packagePlanId } = request.body
 291: 
 292:     if (!code || !code.trim()) {
 293:       return reply.code(400).send({ error: '请输入优惠码' })
 294:     }
 295: 
 296:     if (!packagePlanId || typeof packagePlanId !== 'number') {
 297:       return reply.code(400).send({ error: '方案 ID 无效' })
 298:     }
 299: 
 300:     const result = await db.validateAffCode(code.trim(), packagePlanId, user.id)
 301: 
 302:     if (!result.valid) {
 303:       return reply.code(400).send({ error: result.error })
 304:     }
 305: 
 306:     return {
 307:       valid: true,
 308:       discountRate: result.discountRate,
 309:       commissionRate: result.commissionRate
 310:     }
 311:   })
 312: 
 313:   // ==================== 转化申请 API ====================
 314: 
 315:   // 创建转化申请
 316:   fastify.post<{
 317:     Body: { amount: number }
 318:   }>('/me/convert', {
 319:     onRequest: [fastify.authenticate],
 320:     config: { rateLimit: { max: 5, timeWindow: '1 minute' } }
 321:   }, async (request: FastifyRequest<{ Body: { amount: number } }>, reply: FastifyReply) => {
 322:     const { user } = request
 323:     const { amount } = request.body
 324: 
 325:     if (!amount || typeof amount !== 'number' || !Number.isFinite(amount) || amount <= 0) {
 326:       return reply.code(400).send({ error: '请输入有效的转化金额' })
 327:     }
 328: 
 329:     // 规范化金额（两位小数）
 330:     const normalizedAmount = Math.round(amount * 100) / 100
 331: 
 332:     const result = await db.createAffWithdrawal(user.id, normalizedAmount)
 333: 
 334:     if (!result.success) {
 335:       return reply.code(400).send({ error: result.error })
 336:     }
 337: 
 338:     await createLog(
 339:       user.id,
 340:       'user',
 341:       'aff.convert_request',
 342:       `AFF balance converted: ${normalizedAmount}`,
 343:       'success'
 344:     )
 345: 
 346:     return {
 347:       message: '转化成功，已转入账户余额',
 348:       withdrawal: {
 349:         id: result.withdrawal!.id,
 350:         amount: Number(result.withdrawal!.amount),
 351:         status: result.withdrawal!.status,
 352:         createdAt: result.withdrawal!.createdAt.toISOString()
 353:       }
 354:     }
 355:   })
 356: 
 357:   // 获取我的转化申请
 358:   fastify.get<{
 359:     Querystring: {
 360:       page?: string
 361:       pageSize?: string
 362:       status?: string
 363:     }
 364:   }>('/me/withdrawals', {
 365:     onRequest: [fastify.authenticate]
 366:   }, async (request: FastifyRequest<{ Querystring: { page?: string; pageSize?: string; status?: string } }>, reply: FastifyReply) => {
 367:     const { user } = request
 368:     const { page = '1', pageSize = '20', status } = request.query
 369:     const parsedPage = parseClampedPositiveQueryInteger(page, 1, Number.MAX_SAFE_INTEGER)
 370:     const parsedPageSize = parseClampedPositiveQueryInteger(pageSize, 20, AFF_ROUTE_MAX_PAGE_SIZE)
 371:     const parsedStatus = parseOptionalAffWithdrawalStatus(status)
 372: 
 373:     if (parsedPage === null || parsedPageSize === null || parsedStatus === null) {
 374:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS))
 375:     }
 376: 
 377:     const result = await db.getUserAffWithdrawals(user.id, {
 378:       page: parsedPage,
 379:       pageSize: parsedPageSize,
 380:       status: parsedStatus
 381:     })
 382: 
 383:     return {
 384:       withdrawals: result.withdrawals.map(w => ({
 385:         id: w.id,
 386:         amount: Number(w.amount),
 387:         status: w.status,
 388:         rejectReason: w.rejectReason,
 389:         reviewedAt: w.reviewedAt?.toISOString() || null,
 390:         createdAt: w.createdAt.toISOString()
 391:       })),
 392:       total: result.total,
 393:       page: result.page,
 394:       pageSize: result.pageSize
 395:     }
 396:   })
 397: 
 398:   // ==================== 管理员 API ====================
 399: 
 400:   // 获取所有转化申请（管理员）
 401:   fastify.get<{
 402:     Querystring: {
 403:       page?: string
 404:       pageSize?: string
 405:       status?: string
 406:     }
 407:   }>('/admin/withdrawals', {
 408:     onRequest: [fastify.authenticate, fastify.requireAdmin]
 409:   }, async (request: FastifyRequest<{ Querystring: { page?: string; pageSize?: string; status?: string } }>, reply: FastifyReply) => {
 410:     const { page = '1', pageSize = '20', status } = request.query
 411:     const parsedPage = parseClampedPositiveQueryInteger(page, 1, Number.MAX_SAFE_INTEGER)
 412:     const parsedPageSize = parseClampedPositiveQueryInteger(pageSize, 20, AFF_ROUTE_MAX_PAGE_SIZE)
 413:     const parsedStatus = parseOptionalAffWithdrawalStatus(status)
 414: 
 415:     if (parsedPage === null || parsedPageSize === null || parsedStatus === null) {
 416:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS))
 417:     }
 418: 
 419:     const result = await db.getPendingAffWithdrawals({
 420:       page: parsedPage,
 421:       pageSize: parsedPageSize,
 422:       status: parsedStatus
 423:     })
 424: 
 425:     return {
 426:       withdrawals: result.withdrawals.map(w => ({
 427:         id: w.id,
 428:         userId: w.userId,
