 390: export async function createRegisteredUser(
 391:   input: {
 392:     username: string
 393:     email: string | null
 394:     passwordHash: string
 395:     inviteCode?: string
 396:   }
 397: ): Promise<CreateRegisteredUserResult> {
 398:   const { getDefaultQuotaConfig } = await import('./system-config.js')
 399:   const [defaultQuota, giftConfig] = await Promise.all([
 400:     getDefaultQuotaConfig(),
 401:     getFreeSiteRegisterGiftConfig()
 402:   ])
