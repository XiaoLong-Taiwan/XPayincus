 192: /**
 193:  * 删除好友关系（双向删除：将状态更新为 removed，保留历史记录）
 194:  */
 195: export async function removeFriend(friendshipId: number, userId: number) {
 196:     const friendship = await prisma.friendship.findUnique({
 197:         where: { id: friendshipId }
 198:     })
 199: 
 200:     if (!friendship) {
 201:         throw new Error('FRIENDSHIP_NOT_FOUND')
 202:     }
 203: 
 204:     // 任一方都可以删除好友
 205:     if (friendship.userId !== userId && friendship.friendId !== userId) {
 206:         throw new Error('FORBIDDEN')
 207:     }
 208: 
 209:     // 不删除记录，而是更新状态为 removed，以保留历史记录
 210:     // 这样可以实现双向删除：双方的好友列表都不会显示对方，但历史记录仍然保留
 211:     return prisma.friendship.update({
 212:         where: { id: friendshipId },
 213:         data: {
 214:             status: 'removed'
 215:         }
 216:     })
 217: }
