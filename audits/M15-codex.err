  59:   ['user AFF withdrawal list', sectionBetween(affRouteSource, "}>('/me/withdrawals'", '// ==================== 管理员 API'), 'parsedStatus'],
  60:   ['admin AFF withdrawal list', sectionBetween(affRouteSource, "}>('/admin/withdrawals'", '// 审核通过转化申请'), 'parsedStatus']
  61: ] as const) {
