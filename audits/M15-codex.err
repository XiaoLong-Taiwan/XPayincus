 253:                 <td class="truncate px-4 py-3 text-sm text-themed-muted">{{ w.rejectReason || '-' }}</td>
 254:                 <td class="px-4 py-3">
 255:                   <template v-if="w.status === 'pending'">
 256:                     <div class="flex flex-wrap gap-2">
