===== client/src/views/InvitesView.vue 1-165 =====
   1: <script setup lang="ts">
   2: import { computed, onMounted, ref } from 'vue'
   3: import { RouterLink } from 'vue-router'
   4: import api from '@/api'
   5: import type { InviteCostOption, UserInvite, UserInviteSummary } from '@/types/api'
   6: import { useToast } from '@/stores/toast'
   7: import { useThemeStore } from '@/stores/theme'
   8: import { dashboardPath } from '@/utils/app-paths'
   9: import UserAvatar from '@/components/UserAvatar.vue'
  10: import ThemeTemplateSlot from '@/components/theme/ThemeTemplateSlot.vue'
  11: 
  12: defineOptions({ name: 'InvitesView' })
  13: 
  14: const toast = useToast()
  15: const themeStore = useThemeStore()
  16: 
  17: const loading = ref(true)
  18: const listLoading = ref(false)
  19: const generating = ref(false)
  20: const summary = ref<UserInviteSummary | null>(null)
  21: const invites = ref<UserInvite[]>([])
  22: const page = ref(1)
  23: const pageSize = ref(20)
  24: const total = ref(0)
  25: const totalPages = ref(1)
  26: const selectedCostResource = ref('')
  27: const generatedInvites = ref<UserInvite[]>([])
  28: 
  29: const enabledCostOptions = computed(() => {
  30:   return (summary.value?.costOptions || []).filter(option => option.enabled)
  31: })
  32: 
  33: const selectedCostOption = computed(() => {
  34:   return enabledCostOptions.value.find(option => option.resource === selectedCostResource.value) || null
  35: })
  36: 
  37: const canGenerate = computed(() => {
  38:   const option = selectedCostOption.value
  39:   if (!option || generating.value) return false
  40:   return hasEnoughResource(option)
  41: })
  42: 
  43: onMounted(loadPage)
  44: 
  45: async function loadPage(): Promise<void> {
  46:   loading.value = true
  47:   try {
  48:     await Promise.all([loadSummary(), loadInvites()])
  49:   } finally {
  50:     loading.value = false
  51:   }
  52: }
  53: 
  54: async function loadSummary(): Promise<void> {
  55:   summary.value = await api.userInvites.summary()
  56:   if (!selectedCostResource.value && enabledCostOptions.value.length > 0) {
  57:     selectedCostResource.value = enabledCostOptions.value[0].resource
  58:   }
  59:   if (selectedCostResource.value && !enabledCostOptions.value.some(option => option.resource === selectedCostResource.value)) {
  60:     selectedCostResource.value = enabledCostOptions.value[0]?.resource || ''
  61:   }
  62: }
  63: 
  64: async function loadInvites(): Promise<void> {
  65:   listLoading.value = true
  66:   try {
  67:     const res = await api.userInvites.list({ page: page.value, pageSize: pageSize.value })
  68:     invites.value = res.invites || []
  69:     total.value = res.total || 0
  70:     totalPages.value = res.totalPages || 1
  71:     if (page.value > totalPages.value && totalPages.value > 0) {
  72:       page.value = totalPages.value
  73:       await loadInvites()
  74:     }
  75:   } finally {
  76:     listLoading.value = false
  77:   }
  78: }
  79: 
  80: async function generateInvite(): Promise<void> {
  81:   if (!selectedCostResource.value || !canGenerate.value) return
  82: 
  83:   generating.value = true
  84:   try {
  85:     const res = await api.userInvites.generate({ costResource: selectedCostResource.value })
  86:     generatedInvites.value = res.invites || []
  87:     toast.success('邀请码已生成')
  88:     page.value = 1
  89:     await Promise.all([loadSummary(), loadInvites()])
  90:   } catch (err: any) {
  91:     toast.error(err?.message || '生成邀请码失败')
  92:   } finally {
  93:     generating.value = false
  94:   }
  95: }
  96: 
  97: function hasEnoughResource(option: InviteCostOption): boolean {
  98:   if (!summary.value) return false
  99:   if (option.amount <= 0) return true
 100:   if (option.resource === 'balance') return summary.value.balances.balance >= option.amount
 101:   if (option.resource === 'points') return summary.value.balances.points >= option.amount
 102:   return false
 103: }
 104: 
 105: function getBalanceLabel(resource: string): string {
 106:   if (!summary.value) return '-'
 107:   if (resource === 'balance') return `¥${summary.value.balances.balance.toFixed(2)}`
 108:   if (resource === 'points') return `${summary.value.balances.points} 积分`
 109:   return '-'
 110: }
 111: 
 112: function getStatus(invite: UserInvite): { label: string; className: string } {
 113:   if (invite.usedBy) {
 114:     return { label: '已使用', className: 'badge-success' }
 115:   }
 116:   if (invite.expiresAt && new Date(invite.expiresAt) < new Date()) {
 117:     return { label: '已过期', className: 'badge-error' }
 118:   }
 119:   return { label: '未使用', className: 'badge-warning' }
 120: }
 121: 
 122: function formatDate(value: string | null): string {
 123:   if (!value) return '-'
 124:   return new Date(value).toLocaleString()
 125: }
 126: 
 127: function getInviteLink(invite: UserInvite): string {
 128:   const origin = window.location.origin
 129:   return `${origin}${invite.registerUrl}`
 130: }
 131: 
 132: async function copyText(text: string, successMessage: string): Promise<void> {
 133:   try {
 134:     await navigator.clipboard.writeText(text)
 135:     toast.success(successMessage)
 136:   } catch {
 137:     toast.error('复制失败')
 138:   }
 139: }
 140: 
 141: function previousPage(): void {
 142:   if (page.value <= 1) return
 143:   page.value -= 1
 144:   loadInvites()
 145: }
 146: 
 147: function nextPage(): void {
 148:   if (page.value >= totalPages.value) return
 149:   page.value += 1
 150:   loadInvites()
 151: }
 152: </script>
 153: 
 154: <template>
 155:   <div class="kawaii-page space-y-6 animate-fade-in">
 156:     <div class="page-header flex-col gap-4 sm:flex-row sm:gap-0">
 157:       <div>
 158:         <h1 class="page-title">邀请码管理</h1>
 159:         <p class="page-description">生成新的注册链接，并查看每个邀请码的使用情况。</p>
 160:       </div>
 161:       <RouterLink :to="dashboardPath()" class="btn-ghost w-full justify-center sm:w-auto">
 162:         返回概览
 163:       </RouterLink>
 164:     </div>
