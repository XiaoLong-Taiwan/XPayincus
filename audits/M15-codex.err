 265:                         class="btn btn-xs btn-ghost text-rose-600 dark:text-rose-400 hover:bg-rose-500/10"
 266:                         @click="openRejectModal(w)"
 267:                       >
 268:                         {{ $t('aff.reject') }}
 269:                       </button>
 270:                     </div>
 271:                   </template>
 272:                   <template v-else>
 273:                     <span class="text-themed-muted">-</span>
 274:                   </template>
 275:                 </td>
 276:               </tr>
 277:             </tbody>
 278:           </table>
