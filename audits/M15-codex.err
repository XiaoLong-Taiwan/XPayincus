  23: const INVITE_GENERATION_MAX_COUNT = 10
  24: const INVITE_COST_RESOURCE_MAX_LENGTH = 64
  25: 
  26: function isPlainRecord(value: unknown): value is Record<string, unknown> {
  27:   return typeof value === 'object' && value !== null && !Array.isArray(value)
  28: }
  29: 
  30: function normalizeGenerateInviteBody(input: unknown): GenerateInviteBody {
  31:   if (!isPlainRecord(input)) {
  32:     throw { error: '请求参数无效' }
  33:   }
  34: 
  35:   if (typeof input.costResource !== 'string') {
  36:     throw { error: '请选择生成方式' }
  37:   }
  38:   const costResource = input.costResource.trim()
  39:   if (!costResource || costResource.length > INVITE_COST_RESOURCE_MAX_LENGTH) {
  40:     throw { error: '生成方式无效' }
  41:   }
  42: 
  43:   let count = 1
  44:   const countInput = input.count
  45:   if (countInput !== undefined) {
  46:     if (typeof countInput !== 'number' || !Number.isSafeInteger(countInput) || countInput < 1 || countInput > INVITE_GENERATION_MAX_COUNT) {
  47:       throw { error: `生成数量需为 1-${INVITE_GENERATION_MAX_COUNT} 的整数` }
  48:     }
  49:     count = countInput
  50:   }
  51: 
  52:   return { costResource, count }
  53: }
