   1: import assert from 'node:assert/strict'
   2: import { readFileSync } from 'node:fs'
   3: import { dirname, resolve } from 'node:path'
   4: import { fileURLToPath } from 'node:url'
   5: 
   6: const __filename = fileURLToPath(import.meta.url)
   7: const __dirname = dirname(__filename)
   8: 
   9: const affDbSource = readFileSync(resolve(__dirname, '../src/db/aff.ts'), 'utf8')
  10: const pointsDbSource = readFileSync(resolve(__dirname, '../src/db/points.ts'), 'utf8')
  11: const affRouteSource = readFileSync(resolve(__dirname, '../src/routes/aff.ts'), 'utf8')
  12: 
  13: function sectionBetween(source: string, startMarker: string, endMarker: string): string {
  14:   const start = source.indexOf(startMarker)
  15:   assert.notEqual(start, -1, `missing start marker: ${startMarker}`)
  16:   const end = source.indexOf(endMarker, start + startMarker.length)
  17:   assert.notEqual(end, -1, `missing end marker: ${endMarker}`)
  18:   return source.slice(start, end)
  19: }
  20: 
  21: function sectionFrom(source: string, startMarker: string): string {
  22:   const start = source.indexOf(startMarker)
  23:   assert.notEqual(start, -1, `missing start marker: ${startMarker}`)
  24:   return source.slice(start)
  25: }
  26: 
  27: for (const [name, source] of [
  28:   ['AFF', affDbSource],
  29:   ['points', pointsDbSource]
  30: ] as const) {
  31:   assert.ok(
  32:     source.includes('function clampPagination(') &&
  33:       source.includes('page: Number.isInteger(page) && page !== undefined && page > 0 ? page : 1') &&
  34:       source.includes('Math.min(Math.max(pageSize, 1), maxPageSize)'),
  35:     `${name} helpers must clamp invalid page/pageSize values`
  36:   )
  37: }
  38: 
  39: assert.ok(
  40:   affDbSource.includes('const AFF_LOG_TYPES = new Set<AffLogType>') &&
  41:     affDbSource.includes('function normalizeAffLogType(type: AffLogType | undefined): AffLogType | undefined') &&
  42:     affDbSource.includes('const AFF_WITHDRAWAL_STATUSES = new Set<AffWithdrawalStatus>') &&
  43:     affDbSource.includes('function normalizeAffWithdrawalStatus(status: AffWithdrawalStatus | undefined): AffWithdrawalStatus | undefined'),
  44:   'AFF helpers must allowlist log types and withdrawal statuses before Prisma filters'
  45: )
  46: 
  47: assert.ok(
  48:   affRouteSource.includes('const AFF_ROUTE_MAX_PAGE_SIZE = 100') &&
  49:     affRouteSource.includes('const AFF_REJECT_REASON_MAX_LENGTH = 500') &&
  50:     affRouteSource.includes('function parseClampedPositiveQueryInteger(value: string | undefined, fallback: number, max: number): number | null') &&
  51:     affRouteSource.includes('function parseOptionalAffLogType(value: string | undefined): AffLogType | null | undefined') &&
  52:     affRouteSource.includes('function parseOptionalAffWithdrawalStatus(value: string | undefined): AffWithdrawalStatus | null | undefined') &&
  53:     affRouteSource.includes('function normalizeRequiredText(value: unknown, maxLength: number): string | null'),
  54:   'AFF routes must parse pagination, enum filters, and required text bodies before DB calls'
  55: )
  56: 
  57: for (const [name, route, enumVariable] of [
