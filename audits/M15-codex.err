 486: /**
 487:  * 获取实例绑定的优惠码
 488:  */
 489: export async function getInstanceAffBinding(instanceId: number, tx?: Prisma.TransactionClient): Promise<{
 490:   affCode: AffCode
 491:   userId: number // 优惠码创建者
 492: } | null> {
 493:   const client = tx || prisma
 494:   const binding = await client.affBinding.findUnique({
 495:     where: { instanceId },
 496:     include: {
 497:       affCode: true
 498:     }
 499:   })
