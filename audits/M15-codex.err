 230:                 <th class="w-[12%] px-4 py-3 font-medium">{{ $t('aff.requestAmount') }}</th>
 231:                 <th class="w-[12%] px-4 py-3 font-medium">{{ $t('aff.userBalance') }}</th>
 232:                 <th class="w-[10%] px-4 py-3 font-medium">{{ $t('aff.status') }}</th>
 233:                 <th class="w-[16%] px-4 py-3 font-medium">{{ $t('aff.requestTime') }}</th>
 234:                 <th class="w-[14%] px-4 py-3 font-medium">{{ $t('aff.rejectReason') }}</th>
 235:                 <th class="w-[12%] px-4 py-3 font-medium">{{ $t('common.actions') }}</th>
