   9: const authRouteSource = readFileSync(resolve(__dirname, '../src/routes/auth.ts'), 'utf8')
  10: const userInvitesRouteSource = readFileSync(resolve(__dirname, '../src/routes/user-invites.ts'), 'utf8')
  11: const inviteCodesDbSource = readFileSync(resolve(__dirname, '../src/db/invite-codes.ts'), 'utf8')
