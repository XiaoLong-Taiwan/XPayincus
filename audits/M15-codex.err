  54: // ==================== 好友请求操作 ====================
  55: 
  56: /**
  57:  * 发送好友请求
  58:  */
  59: export async function sendFriendRequest(userId: number, friendId: number, remark?: string) {
  60:     // 检查是否已经存在关系（任一方向）
  61:     const existing = await prisma.friendship.findFirst({
  62:         where: {
  63:             OR: [
  64:                 { userId, friendId },
  65:                 { userId: friendId, friendId: userId }
  66:             ]
  67:         }
  68:     })
  69: 
  70:     if (existing) {
  71:         if (existing.status === 'accepted') {
  72:             throw new Error('ALREADY_FRIENDS')
  73:         }
  74:         if (existing.status === 'pending') {
  75:             // 如果对方已经向我发送了请求，直接接受
  76:             if (existing.userId === friendId && existing.friendId === userId) {
  77:                 return acceptFriendRequest(existing.id, userId)
  78:             }
  79:             throw new Error('REQUEST_PENDING')
  80:         }
  81:         // 如果之前被拒绝过，允许重新发送请求
  82:         if (existing.status === 'rejected') {
  83:             return prisma.friendship.update({
  84:                 where: { id: existing.id },
  85:                 data: {
  86:                     status: 'pending',
  87:                     remark: remark || null,
  88:                     rejectedAt: null
  89:                 }
  90:             })
  91:         }
  92:     }
  93: 
  94:     return prisma.friendship.create({
  95:         data: {
  96:             userId,
  97:             friendId,
  98:             status: 'pending',
  99:             remark: remark || null
 100:         }
 101:     })
 102: }
 103: 
 104: /**
 105:  * 接受好友请求
 106:  */
 107: export async function acceptFriendRequest(requestId: number, userId: number) {
 108:     const request = await prisma.friendship.findUnique({
 109:         where: { id: requestId }
 110:     })
 111: 
 112:     if (!request) {
 113:         throw new Error('REQUEST_NOT_FOUND')
 114:     }
 115: 
 116:     // 只有接收者才能接受
 117:     if (request.friendId !== userId) {
 118:         throw new Error('FORBIDDEN')
 119:     }
 120: 
 121:     if (request.status !== 'pending') {
 122:         throw new Error('REQUEST_NOT_PENDING')
 123:     }
 124: 
 125:     return prisma.friendship.update({
 126:         where: { id: requestId },
 127:         data: {
 128:             status: 'accepted',
 129:             acceptedAt: new Date()
 130:         }
 131:     })
 132: }
 133: 
 134: /**
 135:  * 拒绝好友请求（更新状态为 rejected）
 136:  */
 137: export async function rejectFriendRequest(requestId: number, userId: number) {
 138:     const request = await prisma.friendship.findUnique({
 139:         where: { id: requestId }
 140:     })
 141: 
 142:     if (!request) {
 143:         throw new Error('REQUEST_NOT_FOUND')
 144:     }
 145: 
 146:     // 只有接收者才能拒绝
 147:     if (request.friendId !== userId) {
 148:         throw new Error('FORBIDDEN')
 149:     }
 150: 
 151:     if (request.status !== 'pending') {
 152:         throw new Error('REQUEST_NOT_PENDING')
 153:     }
 154: 
 155:     return prisma.friendship.update({
 156:         where: { id: requestId },
 157:         data: {
 158:             status: 'rejected',
 159:             rejectedAt: new Date()
 160:         }
 161:     })
 162: }
 163: 
 164: /**
 165:  * 取消已发送的好友请求
 166:  */
 167: export async function cancelFriendRequest(requestId: number, userId: number) {
 168:     const request = await prisma.friendship.findUnique({
 169:         where: { id: requestId }
 170:     })
 171: 
 172:     if (!request) {
 173:         throw new Error('REQUEST_NOT_FOUND')
 174:     }
 175: 
 176:     // 只有发起者才能取消
 177:     if (request.userId !== userId) {
 178:         throw new Error('FORBIDDEN')
 179:     }
 180: 
 181:     if (request.status !== 'pending') {
 182:         throw new Error('REQUEST_NOT_PENDING')
 183:     }
 184: 
 185:     return prisma.friendship.delete({
 186:         where: { id: requestId }
 187:     })
 188: }
