 563: /**
 564:  * 获取用户的 AFF 收益日志（分页）
 565:  */
 566: export async function getAffLogs(
 567:   userId: number,
 568:   options: {
 569:     page?: number
 570:     pageSize?: number
 571:     type?: AffLogType
 572:   } = {}
 573: ): Promise<{
 574:   logs: AffLogWithDetails[]
 575:   total: number
 576:   page: number
 577:   pageSize: number
 578: }> {
 579:   const { page, pageSize } = clampPagination(options.page, options.pageSize)
 580:   const type = normalizeAffLogType(options.type)
 581:   const skip = (page - 1) * pageSize
 582: 
 583:   const where: Prisma.AffLogWhereInput = {
 584:     userId,
 585:     ...(type ? { type } : {})
 586:   }
 587: 
 588:   const [logs, total] = await Promise.all([
 589:     prisma.affLog.findMany({
 590:       where,
 591:       include: {
 592:         affCode: { select: { code: true } }
 593:       },
 594:       orderBy: { createdAt: 'desc' },
 595:       skip,
 596:       take: pageSize
 597:     }),
 598:     prisma.affLog.count({ where })
 599:   ])
 600: 
 601:   return { logs, total, page, pageSize }
 602: }
