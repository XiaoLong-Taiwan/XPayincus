  13: function sectionBetween(source: string, startMarker: string, endMarker: string): string {
  14:   const start = source.indexOf(startMarker)
  15:   assert.notEqual(start, -1, `missing start marker: ${startMarker}`)
  16:   const end = source.indexOf(endMarker, start + startMarker.length)
  17:   assert.notEqual(end, -1, `missing end marker: ${endMarker}`)
  18:   return source.slice(start, end)
  19: }
  20: 
  21: const adminInviteListRoute = sectionBetween(
  22:   authRouteSource,
  23:   "}>('/invites', {",
  24:   '  // 删除邀请码'
  25: )
  26: const adminInviteDeleteRoute = sectionBetween(
  27:   authRouteSource,
  28:   "fastify.delete<{ Params: { id: string } }>('/invites/:id'",
  29:   '  // ==================== 2FA 双因素认证 ===================='
  30: )
  31: 
  32: const userInviteListRoute = sectionBetween(
  33:   userInvitesRouteSource,
  34:   "}>('/', {",
  35:   "  fastify.post<{ Body: GenerateInviteBody }>"
  36: )
  37: 
  38: assert.ok(
  39:     authRouteSource.includes('const POSITIVE_INTEGER_PATTERN = /^[1-9]\\d*$/') &&
  40:     authRouteSource.includes('function parsePositiveInteger(value: string | undefined, fallback: number): number') &&
  41:     authRouteSource.includes('function parsePositiveRouteId(value: string): number | null') &&
  42:     authRouteSource.includes('Number.isSafeInteger(parsed)') &&
  43:     userInvitesRouteSource.includes('function parsePositiveInteger(value: string | undefined, fallback: number): number'),
  44:   'auth invite routes must use strict positive safe-integer parsers'
  45: )
  46: 
  47: for (const [name, route] of [
  48:   ['admin invite list', adminInviteListRoute],
  49:   ['user invite list', userInviteListRoute]
  50: ] as const) {
  51:   assert.ok(
  52:     route.includes('const page = parsePositiveInteger(request.query.page, 1)') &&
  53:       route.includes('const pageSize = Math.min(100, parsePositiveInteger(request.query.pageSize, 20))'),
  54:     `${name} must clamp invalid page and pageSize query values before querying`
  55:   )
  56:   assert.ok(
  57:     !route.includes('Math.max(1, parseInt(request.query.page') &&
  58:       !route.includes('Math.max(1, parseInt(request.query.pageSize'),
  59:     `${name} must not use Math.max with parseInt because NaN survives that expression`
  60:   )
  61: }
  62: 
  63: assert.ok(
  64:   adminInviteDeleteRoute.includes('const inviteId = parsePositiveRouteId(request.params.id)') &&
  65:     adminInviteDeleteRoute.includes('if (inviteId === null)') &&
  66:     adminInviteDeleteRoute.includes('ErrorCode.INVALID_ID'),
  67:   'admin invite delete route must reject malformed, decimal, non-positive, and unsafe invite IDs'
  68: )
  69: 
  70: for (const forbiddenPattern of [
  71:   'const inviteId = Number(id)',
  72:   'const inviteId = Number(request.params.id)',
  73:   'isNaN(inviteId)',
  74:   'parseInt(request.params.id'
  75: ] as const) {
  76:   assert.ok(
  77:     !adminInviteDeleteRoute.includes(forbiddenPattern),
  78:     `admin invite delete route must not use loose path ID parsing: ${forbiddenPattern}`
  79:   )
  80: }
  81: 
  82: assert.ok(
  83:   inviteCodesDbSource.includes('function clampInvitePagination(page: number, pageSize: number)') &&
  84:     inviteCodesDbSource.includes('page: Number.isInteger(page) && page > 0 ? page : 1') &&
  85:     inviteCodesDbSource.includes('pageSize: Number.isInteger(pageSize) ? Math.min(Math.max(pageSize, 1), 100) : 20'),
  86:   'invite-code DB helpers must clamp invalid pagination inputs defensively'
  87: )
  88: 
  89: for (const marker of [
  90:   'export async function getInviteCodesWithUsers(',
  91:   'export async function getUserInviteCodesWithUsers('
  92: ] as const) {
  93:   const helperSection = sectionBetween(inviteCodesDbSource, marker, '/**')
  94:   assert.ok(
  95:     helperSection.includes('const pagination = clampInvitePagination(page, pageSize)') &&
  96:       helperSection.includes('skip: (pagination.page - 1) * pagination.pageSize') &&
  97:       helperSection.includes('take: pagination.pageSize'),
  98:     `${marker} must use sanitized pagination values for Prisma skip/take`
  99:   )
 100: }
 101: 
 102: console.log('invite pagination guard tests passed')

