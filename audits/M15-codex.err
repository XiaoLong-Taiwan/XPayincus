 843: /**
 844:  * 审核通过转化申请（管理员）
 845:  */
 846: export async function approveAffWithdrawal(
 847:   withdrawalId: number,
 848:   adminId: number
 849: ): Promise<{ success: boolean; error?: string }> {
 850:   try {
 851:     await prisma.$transaction(async (tx) => {
 852:       // 1. 获取申请信息
 853:       const withdrawal = await tx.affWithdrawal.findUnique({
 854:         where: { id: withdrawalId },
 855:         select: { id: true, userId: true, amount: true, status: true }
 856:       })
 857: 
 858:       if (!withdrawal) {
 859:         throw new Error('申请不存在')
 860:       }
 861:       if (withdrawal.status !== 'pending') {
 862:         throw new Error('申请已处理')
 863:       }
 864: 
 865:       await advisoryTransactionLock(tx, USER_AFF_BALANCE_LOCK_NAMESPACE, withdrawal.userId)
 866:       await advisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, withdrawal.userId)
 867: 
 868:       const pendingWithdrawal = await tx.affWithdrawal.findUnique({
 869:         where: { id: withdrawalId },
 870:         select: { id: true, userId: true, amount: true, status: true }
 871:       })
 872: 
 873:       if (!pendingWithdrawal) {
 874:         throw new Error('申请不存在')
 875:       }
 876:       if (pendingWithdrawal.status !== 'pending') {
 877:         throw new Error('申请已处理')
 878:       }
 879: 
 880:       const user = await tx.user.findUnique({
 881:         where: { id: pendingWithdrawal.userId },
 882:         select: { affBalance: true, balance: true }
 883:       })
 884: 
 885:       if (!user) {
 886:         throw new Error('用户不存在')
 887:       }
 888: 
 889:       const amount = Number(withdrawal.amount)
 890:       const affBalanceBefore = Number(user.affBalance)
 891:       const balanceBefore = Number(user.balance)
 892: 
 893:       if (affBalanceBefore < amount) {
 894:         throw new Error('AFF 余额不足')
 895:       }
 896: 
 897:       const updatedWithdrawal = await tx.affWithdrawal.updateMany({
 898:         where: { id: withdrawalId, status: 'pending' },
 899:         data: {
 900:           status: 'approved',
 901:           reviewedBy: adminId,
 902:           reviewedAt: new Date()
 903:         }
 904:       })
 905: 
 906:       if (updatedWithdrawal.count !== 1) {
 907:         throw new Error('申请已处理')
 908:       }
 909: 
 910:       // 2. 扣除 AFF 余额并增加用户主余额
 911:       const affBalanceAfter = affBalanceBefore - amount
 912:       const updatedUser = await tx.user.update({
 913:         where: { id: pendingWithdrawal.userId },
 914:         data: {
 915:           affBalance: { decrement: amount },
 916:           balance: { increment: amount }
 917:         },
 918:         select: { balance: true }
 919:       })
 920:       const balanceAfter = Number(updatedUser.balance)
 921: 
 922:       // 3. 记录 AFF 日志
 923:       await tx.affLog.create({
 924:         data: {
 925:           userId: pendingWithdrawal.userId,
 926:           type: 'convert',
 927:           amount: -amount,
 928:           balanceBefore: affBalanceBefore,
 929:           balanceAfter: affBalanceAfter,
 930:           remark: `转化申请 #${withdrawalId} 审核通过`
 931:         }
 932:       })
 933: 
 934:       // 4. 记录余额日志
 935:       await tx.balanceLog.create({
 936:         data: {
 937:           userId: pendingWithdrawal.userId,
 938:           type: 'gift',
 939:           amount,
 940:           balanceBefore,
 941:           balanceAfter,
 942:           remark: `AFF 余额转化 #${withdrawalId}`
 943:         }
 944:       })
 945:     })
 946: 
 947:     return { success: true }
 948:   } catch (error) {
 949:     return {
 950:       success: false,
 951:       error: error instanceof Error ? error.message : '审核失败'
 952:     }
 953:   }
 954: }
 955: 
 956: /**
 957:  * 审核拒绝转化申请（管理员）
 958:  */
 959: export async function rejectAffWithdrawal(
 960:   withdrawalId: number,
 961:   adminId: number,
 962:   reason: string
 963: ): Promise<{ success: boolean; error?: string }> {
 964:   try {
 965:     const updatedWithdrawal = await prisma.affWithdrawal.updateMany({
 966:       where: { id: withdrawalId, status: 'pending' },
 967:       data: {
 968:         status: 'rejected',
 969:         rejectReason: reason,
 970:         reviewedBy: adminId,
 971:         reviewedAt: new Date()
 972:       }
 973:     })
 974: 
 975:     if (updatedWithdrawal.count !== 1) {
 976:       const withdrawal = await prisma.affWithdrawal.findUnique({
 977:         where: { id: withdrawalId },
 978:         select: { id: true }
 979:       })
 980: 
 981:       return { success: false, error: withdrawal ? '申请已处理' : '申请不存在' }
 982:     }
 983: 
 984:     return { success: true }
 985:   } catch (error) {
 986:     return {
 987:       success: false,
 988:       error: error instanceof Error ? error.message : '拒绝失败'
 989:     }
 990:   }
 991: }
