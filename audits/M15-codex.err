===== server/scripts/test-invite-generation-accounting-guards.ts =====
   1: import assert from 'node:assert/strict'
   2: import { readFileSync } from 'node:fs'
   3: import { dirname, resolve } from 'node:path'
   4: import { fileURLToPath } from 'node:url'
   5: 
   6: const __filename = fileURLToPath(import.meta.url)
   7: const __dirname = dirname(__filename)
   8: 
   9: const invitePricingSource = readFileSync(resolve(__dirname, '../src/lib/invite-pricing.ts'), 'utf8')
  10: const userInvitesRouteSource = readFileSync(resolve(__dirname, '../src/routes/user-invites.ts'), 'utf8')
  11: const systemConfigRouteSource = readFileSync(resolve(__dirname, '../src/routes/system-config.ts'), 'utf8')
  12: 
  13: function sectionBetween(source: string, startMarker: string, endMarker: string): string {
  14:   const start = source.indexOf(startMarker)
  15:   assert.notEqual(start, -1, `missing start marker: ${startMarker}`)
  16:   const end = source.indexOf(endMarker, start + startMarker.length)
  17:   assert.notEqual(end, -1, `missing end marker: ${endMarker}`)
  18:   return source.slice(start, end)
  19: }
  20: 
  21: const balanceHandler = sectionBetween(
  22:   invitePricingSource,
  23:   "balance: {",
  24:   "points: {"
  25: )
  26: 
  27: const pointsHandler = sectionBetween(
  28:   invitePricingSource,
  29:   "points: {",
  30:   'export function isSupportedInviteCostResource'
  31: )
  32: 
  33: assert.ok(
  34:   invitePricingSource.includes('USER_BALANCE_LOCK_NAMESPACE') &&
  35:     invitePricingSource.includes('USER_POINTS_LOCK_NAMESPACE') &&
  36:     invitePricingSource.includes('advisoryTransactionLock'),
  37:   'invite generation accounting must import the shared user balance and points lock helpers'
  38: )
  39: 
  40: assert.ok(
  41:   balanceHandler.includes('await advisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, userId)') &&
  42:     balanceHandler.indexOf('await advisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, userId)') <
  43:       balanceHandler.indexOf('UPDATE users'),
  44:   'balance-paid invite generation must acquire the shared user balance lock before deducting balance'
  45: )
  46: 
  47: assert.ok(
  48:   balanceHandler.includes('WHERE id = ${userId} AND balance >= ${amount}') &&
  49:     balanceHandler.includes('RETURNING (balance + ${amount})::numeric AS "balanceBefore", balance::numeric AS "balanceAfter"') &&
  50:     balanceHandler.includes("type: 'invite_generate'"),
  51:   'balance-paid invite generation must keep conditional deduction and persisted balance-log snapshots'
  52: )
  53: 
  54: assert.ok(
  55:   pointsHandler.includes('await advisoryTransactionLock(tx, USER_POINTS_LOCK_NAMESPACE, userId)') &&
  56:     pointsHandler.indexOf('await advisoryTransactionLock(tx, USER_POINTS_LOCK_NAMESPACE, userId)') <
  57:       pointsHandler.indexOf('await tx.userPoints.upsert({'),
  58:   'points-paid invite generation must acquire the shared user points lock before touching user_points'
  59: )
  60: 
  61: assert.ok(
  62:   pointsHandler.includes('WHERE user_id = ${userId} AND points >= ${amount}') &&
  63:     pointsHandler.includes('RETURNING points + ${amount} AS "pointsBefore", points AS "pointsAfter"') &&
  64:     pointsHandler.includes("type: 'invite_generate'"),
  65:   'points-paid invite generation must keep conditional deduction and persisted points-log snapshots'
  66: )
  67: 
  68: assert.ok(
  69:   userInvitesRouteSource.includes('config: { rateLimit: { max: 20, timeWindow: \'1 minute\' } }') &&
  70:     userInvitesRouteSource.includes("maximum: 10"),
  71:   'user invite generation must keep per-request and rate-limit bounds'
  72: )
  73: 
  74: assert.ok(
  75:   userInvitesRouteSource.includes('const INVITE_GENERATION_MAX_COUNT = 10') &&
  76:     userInvitesRouteSource.includes('const INVITE_COST_RESOURCE_MAX_LENGTH = 64') &&
  77:     userInvitesRouteSource.includes('function isPlainRecord(value: unknown): value is Record<string, unknown>') &&
  78:     userInvitesRouteSource.includes('function normalizeGenerateInviteBody(input: unknown): GenerateInviteBody'),
  79:   'user invite generation must define a runtime body normalizer'
  80: )
  81: 
  82: assert.ok(
  83:     userInvitesRouteSource.includes("typeof input.costResource !== 'string'") &&
  84:     userInvitesRouteSource.includes('input.costResource.trim()') &&
  85:     userInvitesRouteSource.includes('costResource.length > INVITE_COST_RESOURCE_MAX_LENGTH') &&
  86:     userInvitesRouteSource.includes("typeof countInput !== 'number' || !Number.isSafeInteger(countInput) || countInput < 1 || countInput > INVITE_GENERATION_MAX_COUNT"),
  87:   'user invite generation body normalizer must validate cost resource and count before accounting work'
  88: )
  89: 
  90: assert.ok(
  91:   userInvitesRouteSource.includes('input = normalizeGenerateInviteBody(request.body)') &&
  92:     userInvitesRouteSource.includes('const { count = 1, costResource } = input'),
  93:   'user invite generation route must use normalized body values before charging resources'
  94: )
  95: 
  96: assert.ok(
  97:   !userInvitesRouteSource.includes('const count = request.body.count ?? 1') &&
  98:     !userInvitesRouteSource.includes('const costResource = request.body.costResource'),
  99:   'user invite generation route must not read raw typed body fields before runtime validation'
 100: )
 101: 
 102: assert.ok(
 103:   systemConfigRouteSource.includes("config.key === 'invite_generation_costs'") &&
 104:     systemConfigRouteSource.includes("typeof amount !== 'number' || !Number.isFinite(amount) || amount < 0") &&
 105:     systemConfigRouteSource.includes("resource === 'balance' && amount > maxRegisterGiftBalance") &&
 106:     systemConfigRouteSource.includes("resource === 'points' && (!Number.isSafeInteger(amount) || amount > maxRegisterGiftPoints)"),
 107:   'invite generation cost config must reject invalid, non-finite, negative, and excessive prices'
 108: )
 109: 
 110: console.log('invite generation accounting guard tests passed')
===== server/scripts/test-invite-pagination-guards.ts =====
   1: import assert from 'node:assert/strict'
   2: import { readFileSync } from 'node:fs'
