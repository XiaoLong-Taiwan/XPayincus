  574: export async function revokeOAuthAccessToken(rawToken: string): Promise<OAuthAccessToken | null> {
  575:   const tokenHash = hashOAuthSecret(rawToken)
  576:   const token = await prisma.oAuthAccessToken.findUnique({ where: { tokenHash } })
  577:   if (!token) return null
  578:   if (token.revokedAt) return token
  579:   return await prisma.oAuthAccessToken.update({
  580:     where: { id: token.id },
  581:     data: { revokedAt: new Date() }
  582:   })
  583: }
  584: 
  585: export async function revokeOAuthToken(rawToken: string): Promise<{ userId: number } | null> {
  586:   const tokenHash = hashOAuthSecret(rawToken)
  587:   const accessToken = await revokeOAuthAccessToken(rawToken)
  588:   if (accessToken) return { userId: accessToken.userId }
  589:   const refreshToken = await prisma.oAuthRefreshToken.findUnique({ where: { tokenHash } })
  590:   if (!refreshToken) return null
  591:   if (refreshToken.revokedAt) return { userId: refreshToken.userId }
  592:   const revoked = await prisma.oAuthRefreshToken.update({
  593:     where: { id: refreshToken.id },
  594:     data: { revokedAt: new Date() }
  595:   })
  596:   return { userId: revoked.userId }
  597: }
  598: 
  599: export async function listOAuthAuthorizations(userId: number) {
  600:   return await prisma.oAuthGrant.findMany({
  601:     where: { userId },
  602:     orderBy: { lastAuthorizedAt: 'desc' },
  603:     include: {
  604:       app: { select: { id: true, name: true, clientId: true, enabled: true } }
  605:     }
  606:   })
  607: }
  608: 
  609: export async function revokeOAuthAuthorization(userId: number, grantId: number) {
  610:   return await prisma.$transaction(async tx => {
  611:     const grant = await tx.oAuthGrant.findFirst({
  612:       where: { id: grantId, userId },
  613:       include: { app: { select: { id: true, name: true, clientId: true, enabled: true } } }
  614:     })
  615:     if (!grant) return null
  616:     const revokedAt = new Date()
  617:     const revokedGrant = await tx.oAuthGrant.update({
  618:       where: { id: grant.id },
  619:       data: { revokedAt },
  620:       include: { app: { select: { id: true, name: true, clientId: true, enabled: true } } }
  621:     })
  622:     await tx.oAuthAccessToken.updateMany({
  623:       where: { grantId: grant.id, revokedAt: null },
  624:       data: { revokedAt }
  625:     })
  626:     await tx.oAuthRefreshToken.updateMany({
  627:       where: { grantId: grant.id, revokedAt: null },
  628:       data: { revokedAt }
  629:     })
  630:     return revokedGrant
  631:   })
  632: }
  633: 
  634: export async function revokeOAuthAuthorizationById(grantId: number) {
  635:   return await prisma.$transaction(async tx => {
  636:     const grant = await tx.oAuthGrant.findUnique({
  637:       where: { id: grantId },
  638:       include: {
  639:         app: { select: { id: true, name: true, clientId: true, enabled: true } },
  640:         user: { select: { id: true, username: true, email: true, role: true, status: true } }
  641:       }
  642:     })
  643:     if (!grant) return null
  644:     const revokedAt = new Date()
  645:     const revokedGrant = await tx.oAuthGrant.update({
  646:       where: { id: grant.id },
  647:       data: { revokedAt },
  648:       include: {
  649:         app: { select: { id: true, name: true, clientId: true, enabled: true } },
  650:         user: { select: { id: true, username: true, email: true, role: true, status: true } }
  651:       }
  652:     })
  653:     await tx.oAuthAccessToken.updateMany({
  654:       where: { grantId: grant.id, revokedAt: null },
  655:       data: { revokedAt }
  656:     })
  657:     await tx.oAuthRefreshToken.updateMany({
  658:       where: { grantId: grant.id, revokedAt: null },
  659:       data: { revokedAt }
  660:     })
  661:     return revokedGrant
  662:   })
  663: }
