  668: async function assertPublicServiceOperationAllowed(
  669:   service: { id: number; status: string; suspendReason?: string | null },
  670:   action: PublicApiServiceOperation
  671: ): Promise<{ ok: true } | { ok: false; status: number; code: string; message: string; details?: Record<string, unknown> }> {
  672:   if (service.status === 'deleted') {
  673:     return { ok: false, status: 404, code: 'SERVICE_NOT_FOUND', message: 'Service not found' }
  674:   }
  675:   if (service.status === 'suspended') {
  676:     return {
  677:       ok: false,
  678:       status: 403,
  679:       code: service.suspendReason === 'expired' ? 'SERVICE_SUSPENDED_EXPIRED' : 'SERVICE_SUSPENDED',
  680:       message: 'Suspended services cannot be operated through the public API'
  681:     }
  682:   }
  683:   if (action === 'start' && service.status === 'running') {
  684:     return { ok: false, status: 409, code: 'SERVICE_ALREADY_RUNNING', message: 'Service is already running' }
  685:   }
  686:   if (action === 'stop' && service.status === 'stopped') {
  687:     return { ok: false, status: 409, code: 'SERVICE_ALREADY_STOPPED', message: 'Service is already stopped' }
  688:   }
  689: 
  690:   const [pendingTransfer, activeRestoreTask, activeUploadTask, activeInstanceTask] = await Promise.all([
  691:     prisma.instanceTransfer.findFirst({
  692:       where: { instanceId: service.id, status: { in: ['pending', 'processing'] } },
  693:       select: { id: true, status: true }
  694:     }),
  695:     prisma.restoreTask.findFirst({
  696:       where: { instanceId: service.id, status: { in: ['PENDING', 'PROCESSING'] } },
  697:       select: { id: true, status: true }
  698:     }),
  699:     prisma.backupUploadTask.findFirst({
  700:       where: { instanceId: service.id, status: { in: ['PENDING', 'PROCESSING'] } },
  701:       select: { id: true, status: true }
  702:     }),
  703:     prisma.instanceTask.findFirst({
  704:       where: { instanceId: service.id, status: { in: ['PENDING', 'PROCESSING'] } },
  705:       select: { id: true, taskType: true, status: true }
  706:     })
  707:   ])
  708: 
  709:   if (pendingTransfer) {
  710:     return {
  711:       ok: false,
  712:       status: 409,
  713:       code: 'SERVICE_TRANSFER_LOCKED',
  714:       message: 'Service has a pending transfer',
  715:       details: { transferId: pendingTransfer.id, transferStatus: pendingTransfer.status }
  716:     }
  717:   }
  718:   if (activeRestoreTask) {
  719:     return {
  720:       ok: false,
  721:       status: 409,
  722:       code: 'SERVICE_RESTORE_IN_PROGRESS',
  723:       message: 'Service has an active restore task',
  724:       details: { taskId: activeRestoreTask.id, status: activeRestoreTask.status }
  725:     }
  726:   }
  727:   if (activeUploadTask) {
  728:     return {
  729:       ok: false,
  730:       status: 409,
  731:       code: 'SERVICE_UPLOAD_IN_PROGRESS',
  732:       message: 'Service has an active backup upload task',
  733:       details: { taskId: activeUploadTask.id, status: activeUploadTask.status }
  734:     }
  735:   }
  736:   if (activeInstanceTask) {
  737:     return {
  738:       ok: false,
  739:       status: 409,
  740:       code: 'SERVICE_TASK_IN_PROGRESS',
  741:       message: 'Service has an active operation task',
  742:       details: { taskId: activeInstanceTask.id, taskType: activeInstanceTask.taskType, status: activeInstanceTask.status }
  743:     }
  744:   }
  745: 
  746:   return { ok: true }
  747: }
  748: 
  749: async function assertPublicServiceRenewAllowed(
  750:   service: {
  751:     id: number
  752:     hostId: number
  753:     packagePlanId: number | null
  754:     expiresAt: Date | null
  755:   },
  756:   months: number
  757: ): Promise<{ ok: true } | { ok: false; status: number; code: string; message: string; details?: Record<string, unknown> }> {
  758:   if (!service.packagePlanId) {
  759:     return { ok: false, status: 400, code: 'FREE_SERVICE', message: 'Free services do not need renewal' }
  760:   }
  761: 
  762:   const exchangeLock = await getExchangeOperationLock(service.id)
  763:   if (exchangeLock.locked) {
  764:     return {
  765:       ok: false,
  766:       status: 409,
  767:       code: exchangeLock.code || 'EXCHANGE_INSTANCE_LOCKED',
  768:       message: exchangeLock.message || 'Service is listed on the exchange or has an unsettled exchange order',
  769:       details: {
  770:         listingId: exchangeLock.listingId,
  771:         orderId: exchangeLock.orderId
  772:       }
  773:     }
  774:   }
  775: 
  776:   const host = await prisma.host.findUnique({
  777:     where: { id: service.hostId },
  778:     select: { user: { select: { role: true } } }
  779:   })
  780:   const isHostedInstance = host?.user.role === 'user'
  781:   if (!isHostedInstance) {
  782:     return { ok: true }
  783:   }
  784: 
  785:   if (months !== 1) {
  786:     return {
  787:       ok: false,
  788:       status: 400,
  789:       code: 'HOSTING_MONTHLY_ONLY',
  790:       message: 'Hosted user services can only be renewed monthly'
  791:     }
  792:   }
  793: 
  794:   if (service.expiresAt) {
  795:     const daysUntilExpire = Math.ceil((service.expiresAt.getTime() - Date.now()) / (1000 * 60 * 60 * 24))
  796:     if (daysUntilExpire > 7) {
  797:       return {
  798:         ok: false,
  799:         status: 400,
  800:         code: 'HOSTING_RENEW_TOO_EARLY',
  801:         message: 'Hosted user services can only be renewed within 7 days before expiry',
  802:         details: { daysUntilExpire }
  803:       }
  804:     }
  805:   }
  806: 
  807:   return { ok: true }
  808: }
