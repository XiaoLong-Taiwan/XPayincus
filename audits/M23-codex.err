 1902:   fastify.post<{ Params: PublicApiIdParams; Body: PublicApiServiceActionBody }>('/services/:id/actions', {
 1903:     config: { rateLimit: PUBLIC_API_RATE_LIMITS.serviceOperate }
 1904:   }, async (request, reply) => {
 1905:     const apiToken = await authenticatePublicApiRequest(request, reply, 'services:operate')
 1906:     if (!apiToken) return
 1907:     const id = parsePositiveId(request.params.id)
 1908:     if (!id) return reply.code(400).send({ error: 'Invalid service id', code: 'INVALID_SERVICE_ID' })
 1909: 
 1910:     const action = normalizePublicServiceOperation(request.body?.action)
 1911:     if (!action) {
 1912:       return reply.code(400).send({
 1913:         error: 'action must be one of start, stop, or restart',
 1914:         code: 'INVALID_SERVICE_ACTION'
 1915:       })
 1916:     }
 1917: 
 1918:     const service = await prisma.instance.findFirst({
 1919:       where: { id, userId: apiToken.userId },
 1920:       select: {
 1921:         id: true,
 1922:         hostId: true,
 1923:         userId: true,
 1924:         name: true,
 1925:         status: true,
 1926:         suspendReason: true
 1927:       }
 1928:     })
 1929:     if (!service) return reply.code(404).send({ error: 'Service not found', code: 'SERVICE_NOT_FOUND' })
 1930: 
 1931:     const allowed = await assertPublicServiceOperationAllowed(service, action)
 1932:     if (!allowed.ok) {
 1933:       return reply.code(allowed.status).send({
 1934:         error: allowed.message,
 1935:         code: allowed.code,
 1936:         ...(allowed.details ? { details: allowed.details } : {})
 1937:       })
 1938:     }
 1939: 
 1940:     try {
 1941:       const task = await createInstanceTask({
 1942:         instanceId: service.id,
 1943:         hostId: service.hostId,
 1944:         userId: apiToken.userId,
 1945:         taskType: action
 1946:       })
 1947: 
 1948:       emitServiceTaskPluginEvent({
 1949:         event: 'service.task.queued',
 1950:         instanceId: service.id,
 1951:         userId: apiToken.userId,
 1952:         hostId: service.hostId,
 1953:         instanceName: service.name,
 1954:         taskId: task.id,
 1955:         taskType: task.taskType,
 1956:         taskStatus: task.status,
 1957:         source: 'public_api.services.actions',
 1958:         actor: { id: apiToken.userId, role: apiToken.user.role, username: apiToken.user.username },
 1959:         dedupeKey: `service.task.queued:public-api:${task.id}`,
 1960:         metadata: { action, tokenSource: apiToken.source }
 1961:       })
 1962: 
 1963:       await createLog(
 1964:         apiToken.userId,
 1965:         LogModule.PLUGIN,
 1966:         'public_api.service_action_queued',
 1967:         `Public API ${apiToken.source} queued ${action} task #${task.id} for own service "${service.name}"`,
 1968:         LogResult.SUCCESS,
 1969:         { instanceId: service.id }
 1970:       )
 1971: 
 1972:       return reply.code(202).send({
 1973:         data: {
 1974:           serviceId: service.id,
 1975:           action,
 1976:           taskId: task.id,
 1977:           taskType: task.taskType,
 1978:           status: task.status
 1979:         }
 1980:       })
 1981:     } catch (error) {
 1982:       if (error instanceof InstanceTaskConflictError) {
 1983:         return reply.code(409).send({
 1984:           error: 'Service has an active operation task',
 1985:           code: 'SERVICE_TASK_IN_PROGRESS',
 1986:           ...(error.activeTask ? {
 1987:             details: {
 1988:               taskId: error.activeTask.id,
 1989:               taskType: error.activeTask.taskType,
 1990:               status: error.activeTask.status
 1991:             }
 1992:           } : {})
 1993:         })
 1994:       }
 1995:       throw error
 1996:     }
 1997:   })
