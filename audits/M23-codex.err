  402: function isPublicBalanceAdjustmentType(value: string): value is BalanceAdjustmentRequestType {
  403:   return PUBLIC_BALANCE_ADJUSTMENT_TYPES.has(value as BalanceAdjustmentRequestType)
  404: }
  405: 
  406: function isPublicBalanceAdjustmentStatus(value: string): value is BalanceAdjustmentRequestStatus {
  407:   return PUBLIC_BALANCE_ADJUSTMENT_STATUSES.has(value as BalanceAdjustmentRequestStatus)
  408: }
  409: 
  410: function normalizePublicBalanceAdjustmentType(value: unknown): BalanceAdjustmentRequestType {
  411:   return typeof value === 'string' && isPublicBalanceAdjustmentType(value)
  412:     ? value
  413:     : 'manual_adjust'
  414: }
  415: 
  416: function normalizePublicBalanceAdjustmentStatus(value: unknown): BalanceAdjustmentRequestStatus | undefined | null {
  417:   if (value === undefined || value === null || value === '') return undefined
  418:   if (typeof value !== 'string') return null
  419:   const status = value.trim()
  420:   return isPublicBalanceAdjustmentStatus(status) ? status : null
  421: }
  422: 
  423: function normalizePublicBalanceAdjustmentOrderNo(value: unknown): string | undefined | null {
  424:   if (value === undefined || value === null || value === '') return undefined
  425:   if (typeof value !== 'string') return null
  426:   const orderNo = value.trim()
  427:   return PUBLIC_BALANCE_ADJUSTMENT_ORDER_NO_PATTERN.test(orderNo) ? orderNo : null
