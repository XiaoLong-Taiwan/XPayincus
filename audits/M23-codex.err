  424: export async function exchangeOAuthAuthorizationCode(input: {
  425:   clientId: string
  426:   clientSecret: string
  427:   code: string
  428:   redirectUri: string
  429: }) {
  430:   const app = await prisma.oAuthClientApp.findUnique({ where: { clientId: input.clientId } })
  431:   if (!app || !app.enabled || !safeTimingEqual(app.clientSecretHash, hashOAuthSecret(input.clientSecret))) {
  432:     throw new Error('Invalid OAuth client credentials')
  433:   }
  434: 
  435:   const codeHash = hashOAuthSecret(input.code)
  436:   const accessTokenRaw = generateOAuthAccessToken()
  437:   const refreshTokenRaw = generateOAuthRefreshToken()
  438:   const accessTokenHash = hashOAuthSecret(accessTokenRaw)
  439:   const refreshTokenHash = hashOAuthSecret(refreshTokenRaw)
  440:   const accessTokenExpiresAt = new Date(Date.now() + OAUTH_ACCESS_TOKEN_TTL_SECONDS * 1000)
  441:   const refreshTokenExpiresAt = new Date(Date.now() + OAUTH_REFRESH_TOKEN_TTL_SECONDS * 1000)
  442: 
  443:   const result = await prisma.$transaction(async tx => {
  444:     const authorizationCode = await tx.oAuthAuthorizationCode.findUnique({ where: { codeHash } })
  445:     if (!authorizationCode || authorizationCode.appId !== app.id) throw new Error('Invalid authorization code')
  446:     if (authorizationCode.usedAt) throw new Error('Authorization code has already been used')
  447:     if (authorizationCode.expiresAt.getTime() <= Date.now()) throw new Error('Authorization code has expired')
  448:     if (authorizationCode.redirectUri !== input.redirectUri) throw new Error('redirect_uri does not match authorization request')
  449: 
  450:     await tx.oAuthAuthorizationCode.update({
  451:       where: { id: authorizationCode.id },
  452:       data: { usedAt: new Date() }
  453:     })
  454: 
  455:     const grant = await tx.oAuthGrant.findUnique({
  456:       where: { appId_userId: { appId: app.id, userId: authorizationCode.userId } }
  457:     })
  458:     if (!grant || grant.revokedAt) throw new Error('OAuth authorization has been revoked')
  459: 
  460:     const accessToken = await tx.oAuthAccessToken.create({
  461:       data: {
  462:         appId: app.id,
  463:         userId: authorizationCode.userId,
  464:         grantId: grant.id,
  465:         tokenPrefix: getOAuthAccessTokenPrefix(accessTokenRaw),
  466:         tokenHash: accessTokenHash,
  467:         scopes: serializeScopes(authorizationCode.scopes),
  468:         expiresAt: accessTokenExpiresAt
  469:       }
  470:     })
  471:     const refreshToken = await tx.oAuthRefreshToken.create({
  472:       data: {
  473:         appId: app.id,
  474:         userId: authorizationCode.userId,
  475:         grantId: grant.id,
  476:         tokenPrefix: getOAuthRefreshTokenPrefix(refreshTokenRaw),
  477:         tokenHash: refreshTokenHash,
  478:         scopes: serializeScopes(authorizationCode.scopes),
  479:         expiresAt: refreshTokenExpiresAt
  480:       }
  481:     })
  482: 
  483:     return { authorizationCode, accessToken, refreshToken }
  484:   })
  485: 
  486:   return {
  487:     accessToken: accessTokenRaw,
  488:     refreshToken: refreshTokenRaw,
  489:     tokenType: 'Bearer' as const,
  490:     expiresIn: OAUTH_ACCESS_TOKEN_TTL_SECONDS,
  491:     refreshExpiresIn: OAUTH_REFRESH_TOKEN_TTL_SECONDS,
  492:     scope: serializeScopes(result.accessToken.scopes).join(' '),
  493:     accessTokenRecord: result.accessToken
  494:   }
  495: }
