 2459:   fastify.patch<{ Params: PublicApiIdParams; Body: PublicApiTicketStatusBody }>('/tickets/:id/status', {
 2460:     config: { rateLimit: PUBLIC_API_RATE_LIMITS.ticketStatus }
 2461:   }, async (request, reply) => {
 2462:     const apiToken = await authenticatePublicApiRequest(request, reply, 'tickets:write')
 2463:     if (!apiToken) return
 2464:     const id = parsePositiveId(request.params.id)
 2465:     if (!id) return reply.code(400).send({ error: 'Invalid ticket id', code: 'INVALID_TICKET_ID' })
 2466:     const action = normalizePublicTicketStatusAction(request.body?.action)
 2467:     if (!action) {
 2468:       return reply.code(400).send({
 2469:         error: 'action must be one of close or reopen',
 2470:         code: 'INVALID_TICKET_STATUS_ACTION'
 2471:       })
 2472:     }
 2473: 
 2474:     const ticket = await prisma.ticket.findFirst({
 2475:       where: { id, userId: apiToken.userId },
 2476:       select: { id: true, userId: true, subject: true, status: true }
 2477:     })
 2478:     if (!ticket) return reply.code(404).send({ error: 'Ticket not found', code: 'TICKET_NOT_FOUND' })
 2479:     if (action === 'close' && ticket.status === 'closed') {
 2480:       return reply.code(409).send({ error: 'Ticket is already closed', code: 'TICKET_ALREADY_CLOSED' })
 2481:     }
 2482:     if (action === 'reopen' && ticket.status !== 'closed') {
 2483:       return reply.code(409).send({ error: 'Only closed tickets can be reopened', code: 'TICKET_NOT_CLOSED' })
 2484:     }
 2485: 
 2486:     const now = new Date()
 2487:     const nextStatus: TicketStatus = action === 'close' ? 'closed' : 'open'
 2488:     const update = await prisma.ticket.updateMany({
 2489:       where: {
 2490:         id: ticket.id,
 2491:         userId: apiToken.userId,
 2492:         ...(action === 'close' ? { status: { not: 'closed' as TicketStatus } } : { status: 'closed' as TicketStatus })
 2493:       },
 2494:       data: {
 2495:         status: nextStatus,
 2496:         resolvedAt: action === 'close' ? now : null,
 2497:         closedAt: action === 'close' ? now : null,
 2498:         updatedAt: now
 2499:       }
 2500:     })
 2501:     if (update.count === 0) {
 2502:       return reply.code(409).send({ error: 'Ticket status changed concurrently', code: 'TICKET_STATUS_CONFLICT' })
 2503:     }
 2504: 
 2505:     emitPluginEvent('ticket.status.changed', {
 2506:       dedupeKey: `ticket.status.changed:public-api:${ticket.id}:${nextStatus}:${now.getTime()}`,
 2507:       ticketId: ticket.id,
 2508:       userId: apiToken.userId,
 2509:       username: apiToken.user.username,
 2510:       subject: ticket.subject,
 2511:       previousStatus: ticket.status,
 2512:       status: nextStatus,
 2513:       source: 'public_api',
 2514:       changedAt: now.toISOString()
 2515:     }, { id: apiToken.userId, role: apiToken.user.role, username: apiToken.user.username }, { dedupeKey: `ticket.status.changed:public-api:${ticket.id}:${nextStatus}:${now.getTime()}` })
 2516: 
 2517:     await createLog(apiToken.userId, LogModule.PLUGIN, 'public_api.ticket_status_update', `Public API ${apiToken.source} changed own ticket #${ticket.id} status to ${nextStatus}`, LogResult.SUCCESS)
 2518: 
 2519:     return {
 2520:       data: {
 2521:         id: ticket.id,
 2522:         status: nextStatus,
 2523:         previousStatus: ticket.status,
 2524:         resolvedAt: action === 'close' ? now.toISOString() : null,
 2525:         closedAt: action === 'close' ? now.toISOString() : null,
 2526:         updatedAt: now.toISOString()
 2527:       }
 2528:     }
 2529:   })
 2530: 
 2531:   fastify.post<{ Params: PublicApiIdParams; Body: PublicApiTicketReplyBody }>('/tickets/:id/replies', {
 2532:     bodyLimit: TICKET_UPLOAD_BODY_LIMIT,
 2533:     config: { rateLimit: PUBLIC_API_RATE_LIMITS.ticketReply }
 2534:   }, async (request, reply) => {
 2535:     const apiToken = await authenticatePublicApiRequest(request, reply, 'tickets:write')
 2536:     if (!apiToken) return
 2537:     const id = parsePositiveId(request.params.id)
 2538:     if (!id) return reply.code(400).send({ error: 'Invalid ticket id', code: 'INVALID_TICKET_ID' })
 2539: 
 2540:     let uploadedAttachments: CreateTicketMessageAttachmentData[] = []
 2541: 
 2542:     try {
 2543:       const payload = await readTicketPayload(request)
 2544:       const content = normalizePublicTicketMessageContent(payload.fields.content)
 2545:       if (content.length > MAX_PUBLIC_TICKET_REPLY_LENGTH || (payload.images.length === 0 && content.length < 1)) {
 2546:         return reply.code(400).send({
 2547:           error: `content must be non-empty when no images are attached and no longer than ${MAX_PUBLIC_TICKET_REPLY_LENGTH} characters`,
 2548:           code: 'INVALID_TICKET_REPLY_CONTENT'
 2549:         })
 2550:       }
 2551: 
 2552:       const ticket = await prisma.ticket.findFirst({
 2553:         where: { id, userId: apiToken.userId },
 2554:         include: {
 2555:           user: { select: { id: true, username: true } },
 2556:           host: {
 2557:             select: {
 2558:               id: true,
 2559:               name: true,
 2560:               userId: true,
 2561:               user: { select: { role: true } }
 2562:             }
 2563:           }
 2564:         }
 2565:       })
 2566:       if (!ticket) return reply.code(404).send({ error: 'Ticket not found', code: 'TICKET_NOT_FOUND' })
 2567:       if (ticket.status === 'closed') return reply.code(409).send({ error: 'Cannot reply to a closed ticket', code: 'TICKET_CLOSED' })
 2568: 
 2569:       if (payload.images.length > 0) {
 2570:         uploadedAttachments = await uploadTicketImages(payload.images)
 2571:       }
 2572: 
 2573:       const message = await addTicketMessage(ticket.id, apiToken.userId, content, false, uploadedAttachments)
 2574:       const attachments = uploadedAttachments.length > 0
 2575:         ? await prisma.ticketMessageAttachment.findMany({
 2576:           where: { ticketId: ticket.id, messageId: message.id },
 2577:           orderBy: { id: 'asc' },
 2578:           select: {
 2579:             id: true,
 2580:             filename: true,
 2581:             originalName: true,
 2582:             mimeType: true,
 2583:             sizeBytes: true,
 2584:             thumbnailUrl: true,
 2585:             createdAt: true
 2586:           }
 2587:         })
 2588:         : []
 2589: 
 2590:       try {
 2591:         const hostedTicketHost = ticket.host?.user.role === 'user' ? ticket.host : null
 2592:         if (hostedTicketHost?.userId) {
 2593:           await sendNotification(hostedTicketHost.userId, 'ticket_replied', {
 2594:             subject: ticket.subject,
 2595:             hostName: ticket.host?.name || 'ç³»ç»Ÿ',
 2596:             replyFrom: apiToken.user.username
 2597:           })
 2598:         } else {
 2599:           const adminIds = await getAllAdminUserIds()
 2600:           for (const adminId of adminIds) {
 2601:             await sendNotification(adminId, 'ticket_replied', {
 2602:               subject: ticket.subject,
 2603:               hostName: ticket.host?.name || 'ç³»ç»Ÿ',
 2604:               replyFrom: apiToken.user.username
 2605:             })
 2606:           }
 2607:         }
 2608:       } catch (error) {
 2609:         console.error('[PublicAPI] Failed to send ticket reply notification:', error)
 2610:       }
 2611: 
 2612:       emitPluginEvent('ticket.replied', {
 2613:         dedupeKey: `ticket.replied:${ticket.id}:${message.id}`,
 2614:         ticketId: ticket.id,
 2615:         messageId: message.id,
 2616:         userId: apiToken.userId,
 2617:         username: apiToken.user.username,
 2618:         subject: ticket.subject,
 2619:         isFromOwner: false,
 2620:         status: 'in_progress',
 2621:         attachmentCount: uploadedAttachments.length,
 2622:         source: 'public_api',
 2623:         createdAt: message.createdAt
 2624:       }, { id: apiToken.userId, role: apiToken.user.role, username: apiToken.user.username }, { dedupeKey: `ticket.replied:${ticket.id}:${message.id}` })
 2625: 
