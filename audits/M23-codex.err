### server/src/routes/api-tokens.ts
    1: import type { FastifyInstance, FastifyRequest } from 'fastify'
    2: import { prisma } from '../db/prisma.js'
    3: import { createLog, LogModule, LogResult } from '../db/logs.js'
    4: import {
    5:   generatePublicApiToken,
    6:   getPublicApiTokenPrefix,
    7:   hashPublicApiToken,
    8:   normalizePublicApiScopes,
    9:   normalizePublicApiTokenName,
   10:   PUBLIC_API_SCOPES
   11: } from '../lib/public-api-auth.js'
   12: 
   13: interface CreateApiTokenBody {
   14:   name?: unknown
   15:   scopes?: unknown
   16:   expiresAt?: unknown
   17: }
   18: 
   19: interface TokenParams {
   20:   id: string
   21: }
   22: 
   23: function serializePublicApiToken(token: {
   24:   id: number
   25:   name: string
   26:   tokenPrefix: string
   27:   scopes: unknown
   28:   lastUsedAt: Date | null
   29:   revokedAt: Date | null
   30:   expiresAt: Date | null
   31:   createdAt: Date
   32:   updatedAt: Date
   33: }) {
   34:   return {
   35:     id: token.id,
   36:     name: token.name,
   37:     tokenPrefix: token.tokenPrefix,
   38:     scopes: Array.isArray(token.scopes) ? token.scopes : [],
   39:     lastUsedAt: token.lastUsedAt?.toISOString() ?? null,
   40:     revokedAt: token.revokedAt?.toISOString() ?? null,
   41:     expiresAt: token.expiresAt?.toISOString() ?? null,
   42:     createdAt: token.createdAt.toISOString(),
   43:     updatedAt: token.updatedAt.toISOString()
   44:   }
   45: }
   46: 
   47: function parseTokenId(value: string): number | null {
   48:   if (!/^[1-9]\d*$/.test(value)) return null
   49:   const parsed = Number(value)
   50:   return Number.isSafeInteger(parsed) ? parsed : null
   51: }
   52: 
   53: function normalizeExpiresAt(value: unknown): Date | null | 'invalid' {
   54:   if (value === undefined || value === null || value === '') return null
   55:   if (typeof value !== 'string') return 'invalid'
   56:   const date = new Date(value)
   57:   if (Number.isNaN(date.getTime()) || date.getTime() <= Date.now()) return 'invalid'
   58:   return date
   59: }
   60: 
   61: function getRequestUser(request: FastifyRequest): { id: number; username: string } {
   62:   return request.user as { id: number; username: string }
   63: }
   64: 
   65: export default async function apiTokenRoutes(fastify: FastifyInstance) {
   66:   fastify.get('/', {
   67:     onRequest: [fastify.authenticate]
   68:   }, async (request: FastifyRequest) => {
   69:     const user = getRequestUser(request)
   70:     const tokens = await prisma.publicApiToken.findMany({
   71:       where: { userId: user.id },
   72:       orderBy: { createdAt: 'desc' },
   73:       select: {
   74:         id: true,
   75:         name: true,
   76:         tokenPrefix: true,
   77:         scopes: true,
   78:         lastUsedAt: true,
   79:         revokedAt: true,
   80:         expiresAt: true,
   81:         createdAt: true,
   82:         updatedAt: true
   83:       }
   84:     })
   85: 
   86:     return {
   87:       scopes: PUBLIC_API_SCOPES,
   88:       tokens: tokens.map(serializePublicApiToken)
   89:     }
   90:   })
   91: 
   92:   fastify.post<{
   93:     Body: CreateApiTokenBody
   94:   }>('/', {
   95:     onRequest: [fastify.authenticate]
   96:   }, async (request, reply) => {
   97:     const user = getRequestUser(request)
   98:     const name = normalizePublicApiTokenName(request.body?.name)
   99:     const scopes = normalizePublicApiScopes(request.body?.scopes)
  100:     const expiresAt = normalizeExpiresAt(request.body?.expiresAt)
  101: 
  102:     if (!name) {
  103:       return reply.code(400).send({ error: 'Invalid token name', code: 'INVALID_TOKEN_NAME' })
  104:     }
  105:     if (!scopes) {
  106:       return reply.code(400).send({ error: 'Invalid API scopes', code: 'INVALID_API_SCOPES' })
  107:     }
  108:     if (expiresAt === 'invalid') {
  109:       return reply.code(400).send({ error: 'Invalid expiry time', code: 'INVALID_EXPIRES_AT' })
  110:     }
  111: 
  112:     const rawToken = generatePublicApiToken()
  113:     const tokenHash = hashPublicApiToken(rawToken)
  114:     const record = await prisma.publicApiToken.create({
  115:       data: {
  116:         userId: user.id,
  117:         name,
  118:         tokenPrefix: getPublicApiTokenPrefix(rawToken),
  119:         tokenHash,
  120:         scopes,
  121:         expiresAt
  122:       }
  123:     })
  124: 
  125:     await createLog(
  126:       user.id,
  127:       LogModule.SECURITY,
  128:       'public_api.token_create',
  129:       `Created public API token "${name}" with scopes: ${scopes.join(', ')}`,
  130:       LogResult.SUCCESS
  131:     )
  132: 
  133:     return reply.code(201).send({
  134:       token: rawToken,
  135:       apiToken: serializePublicApiToken(record)
  136:     })
  137:   })
  138: 
  139:   fastify.delete<{
  140:     Params: TokenParams
  141:   }>('/:id', {
  142:     onRequest: [fastify.authenticate]
  143:   }, async (request, reply) => {
  144:     const user = getRequestUser(request)
  145:     const tokenId = parseTokenId(request.params.id)
  146:     if (!tokenId) {
  147:       return reply.code(400).send({ error: 'Invalid token id', code: 'INVALID_TOKEN_ID' })
  148:     }
  149: 
  150:     const token = await prisma.publicApiToken.findFirst({
  151:       where: {
  152:         id: tokenId,
  153:         userId: user.id
  154:       }
  155:     })
  156: 
  157:     if (!token) {
  158:       return reply.code(404).send({ error: 'API token not found', code: 'API_TOKEN_NOT_FOUND' })
  159:     }
  160: 
  161:     if (!token.revokedAt) {
  162:       await prisma.publicApiToken.update({
  163:         where: { id: token.id },
  164:         data: { revokedAt: new Date() }
  165:       })
  166: 
  167:       await createLog(
  168:         user.id,
  169:         LogModule.SECURITY,
  170:         'public_api.token_revoke',
  171:         `Revoked public API token "${token.name}"`,
  172:         LogResult.SUCCESS
  173:       )
  174:     }
  175: 
  176:     return { message: 'API token revoked' }
  177:   })
  178: }
