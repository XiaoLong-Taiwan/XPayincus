  905:       snapshots: instance.snapshotLimit,
  906:       backups: instance.backupLimit,
  907:       sites: instance.siteLimit,
  908:       monthlyTrafficLimit: serializeBigInt(instance.monthlyTrafficLimit),
  909:       monthlyTrafficUsed: serializeBigInt(instance.monthlyTrafficUsed),
  910:       trafficStatus: instance.trafficStatus
  911:     },
  912:     billing: {
  913:       expiresAt: instance.expiresAt?.toISOString() ?? null,
  914:       suspendedAt: instance.suspendedAt?.toISOString() ?? null,
  915:       suspendReason: instance.suspendReason,
  916:       billingPrice: instance.billingPrice === null ? null : toMoney(instance.billingPrice),
  917:       billingCycle: instance.billingCycle,
  918:       autoRenew: instance.autoRenew,
  919:       plan: instance.packagePlan ? {
  920:         id: instance.packagePlan.id,
  921:         name: instance.packagePlan.name,
  922:         billingCycle: instance.packagePlan.billingCycle,
  923:         price: toMoney(instance.packagePlan.price),
  924:         package: instance.packagePlan.package
  925:       } : null
  926:     },
  927:     createdAt: instance.createdAt.toISOString(),
  928:     updatedAt: instance.updatedAt.toISOString()
  929:   }
  930: }
  931: 
  932: function buildPublicServiceIncluded(services: PublicServiceRecord[], includes: PublicApiServiceInclude[]) {
  933:   const included: {
  934:     products?: Array<{ id: number; name: string }>
  935:     plans?: Array<{ id: number; name: string; billingCycle: number | null; price: number; productId: number | null }>
  936:   } = {}
  937:   if (includes.includes('product')) {
  938:     const products = new Map<number, { id: number; name: string }>()
  939:     for (const service of services) {
  940:       const product = service.packagePlan?.package
  941:       if (product) products.set(product.id, { id: product.id, name: product.name })
  942:     }
  943:     included.products = Array.from(products.values())
  944:   }
  945:   if (includes.includes('plan')) {
  946:     const plans = new Map<number, { id: number; name: string; billingCycle: number | null; price: number; productId: number | null }>()
  947:     for (const service of services) {
  948:       const plan = service.packagePlan
  949:       if (plan) {
  950:         plans.set(plan.id, {
  951:           id: plan.id,
  952:           name: plan.name,
  953:           billingCycle: plan.billingCycle,
  954:           price: toMoney(plan.price),
  955:           productId: plan.package?.id ?? null
  956:         })
  957:       }
  958:     }
  959:     included.plans = Array.from(plans.values())
  960:   }
  961:   return included
  962: }
  963: 
  964: async function serializePublicServiceOperationTask(task: {
  965:   id: number
  966:   instanceId: number
  967:   taskType: string
  968:   status: string
  969:   progress: string | null
  970:   error: string | null
  971:   hostId: number
  972:   createdAt: Date
  973:   startedAt: Date | null
  974:   finishedAt: Date | null
  975: }) {
  976:   const queuePosition = task.status === 'PENDING' ? await getTaskQueuePosition(task.id, task.hostId) : 0
  977:   return {
  978:     id: task.id,
  979:     serviceId: task.instanceId,
  980:     taskType: task.taskType,
  981:     status: task.status,
  982:     progress: task.progress,
  983:     error: task.error,
  984:     queuePosition,
  985:     createdAt: task.createdAt.toISOString(),
  986:     startedAt: task.startedAt?.toISOString() ?? null,
  987:     finishedAt: task.finishedAt?.toISOString() ?? null
  988:   }
  989: }
