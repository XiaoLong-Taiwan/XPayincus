 1327:     const instanceIds = Array.from(new Set(logs.map(log => log.instanceId).filter((id): id is number => typeof id === 'number')))
 1328:     const instances = instanceIds.length
 1329:       ? await prisma.instance.findMany({
 1330:           where: { id: { in: instanceIds }, userId: apiToken.userId },
 1331:           select: { id: true, name: true }
