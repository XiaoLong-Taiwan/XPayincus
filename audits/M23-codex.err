  196: 
  197: export function listPublicApiScopeMetadata(scopes: readonly PublicApiScope[] = PUBLIC_API_SCOPES): PublicApiScopeMetadata[] {
  198:   return scopes.map(scope => PUBLIC_API_SCOPE_METADATA[scope])
  199: }
  200: 
  201: export interface AuthenticatedPublicApiToken {
  202:   id: number
  203:   source: 'api_token' | 'oauth_access_token'
  204:   userId: number
  205:   name: string
  206:   tokenPrefix: string
  207:   scopes: PublicApiScope[]
  208:   user: {
  209:     id: number
  210:     username: string
  211:     email: string | null
  212:     role: 'admin' | 'user'
  213:     status: string
  214:     avatarStyle: string
  215:     avatarBadgeId: string | null
  216:   }
  217: }
  218: 
  219: type PublicApiTokenWithUser = PublicApiToken & {
  220:   user: Pick<User, 'id' | 'username' | 'email' | 'role' | 'status' | 'avatarStyle' | 'avatarBadgeId'>
  221: }
  222: 
  223: type OAuthAccessTokenWithUserAndApp = NonNullable<Awaited<ReturnType<typeof prisma.oAuthAccessToken.findUnique>>> & {
  224:   user: Pick<User, 'id' | 'username' | 'email' | 'role' | 'status' | 'avatarStyle' | 'avatarBadgeId'>
  225:   app: { name: string; clientId: string; enabled: boolean }
  226: }
  227: 
  228: function safeTimingEqual(a: string, b: string): boolean {
  229:   const aBuffer = Buffer.from(a)
  230:   const bBuffer = Buffer.from(b)
  231:   if (aBuffer.length !== bBuffer.length) return false
  232:   return timingSafeEqual(aBuffer, bBuffer)
  233: }
  234: 
  235: export function generatePublicApiToken(): string {
  236:   return `${PUBLIC_API_TOKEN_PREFIX}${randomBytes(32).toString('base64url')}`
  237: }
  238: 
  239: export function hashPublicApiToken(token: string): string {
  240:   return createHash('sha256').update(token).digest('hex')
  241: }
  242: 
  243: export function getPublicApiTokenPrefix(token: string): string {
  244:   return token.slice(0, PUBLIC_API_TOKEN_PREFIX_LENGTH)
  245: }
  246: 
  247: export function normalizePublicApiTokenName(value: unknown): string | null {
  248:   if (typeof value !== 'string') return null
  249:   const trimmed = value.trim()
  250:   if (!trimmed || trimmed.length > PUBLIC_API_TOKEN_MAX_NAME_LENGTH) return null
  251:   return trimmed
  252: }
  253: 
  254: export function normalizePublicApiScopes(value: unknown): PublicApiScope[] | null {
  255:   if (!Array.isArray(value) || value.length === 0 || value.length > PUBLIC_API_TOKEN_MAX_SCOPES) {
  256:     return null
  257:   }
  258: 
  259:   const allowedScopes = new Set<string>(PUBLIC_API_SCOPES)
  260:   const scopes = Array.from(new Set(value.map(scope => typeof scope === 'string' ? scope.trim() : '')))
  261:     .filter((scope): scope is PublicApiScope => allowedScopes.has(scope))
  262: 
  263:   return scopes.length === value.length ? scopes : null
  264: }
  265: 
  266: export function readPublicApiBearerToken(request: FastifyRequest): string | null {
  267:   const auth = request.headers.authorization
  268:   if (!auth?.startsWith('Bearer ')) return null
  269: 
  270:   const token = auth.slice('Bearer '.length).trim()
  271:   const isPublicApiToken = token.startsWith(PUBLIC_API_TOKEN_PREFIX)
  272:   const isOAuthAccessToken = token.startsWith(OAUTH_ACCESS_TOKEN_PREFIX)
  273:   if ((!isPublicApiToken && !isOAuthAccessToken) || token.length < 32) {
  274:     return null
  275:   }
  276:   return token
  277: }
  278: 
  279: function serializeScopes(value: unknown): PublicApiScope[] {
  280:   const normalized = normalizePublicApiScopes(value)
  281:   return normalized ?? []
  282: }
  283: 
  284: function serializeAuthenticatedToken(token: PublicApiTokenWithUser): AuthenticatedPublicApiToken {
  285:   return {
  286:     id: token.id,
  287:     source: 'api_token',
  288:     userId: token.userId,
  289:     name: token.name,
  290:     tokenPrefix: token.tokenPrefix,
  291:     scopes: serializeScopes(token.scopes),
  292:     user: {
  293:       id: token.user.id,
  294:       username: token.user.username,
  295:       email: token.user.email,
  296:       role: token.user.role as 'admin' | 'user',
  297:       status: token.user.status,
  298:       avatarStyle: token.user.avatarStyle,
  299:       avatarBadgeId: token.user.avatarBadgeId
  300:     }
  301:   }
  302: }
  303: 
  304: function serializeAuthenticatedOAuthToken(token: OAuthAccessTokenWithUserAndApp): AuthenticatedPublicApiToken {
  305:   return {
  306:     id: token.id,
  307:     source: 'oauth_access_token',
  308:     userId: token.userId,
  309:     name: `OAuth app ${token.app.name}`,
  310:     tokenPrefix: token.tokenPrefix,
  311:     scopes: serializeScopes(token.scopes),
  312:     user: {
  313:       id: token.user.id,
  314:       username: token.user.username,
  315:       email: token.user.email,
  316:       role: token.user.role as 'admin' | 'user',
  317:       status: token.user.status,
  318:       avatarStyle: token.user.avatarStyle,
  319:       avatarBadgeId: token.user.avatarBadgeId
  320:     }
  321:   }
  322: }
  323: 
  324: export async function authenticatePublicApiRequest(
  325:   request: FastifyRequest,
  326:   reply: FastifyReply,
  327:   requiredScope: PublicApiScope
  328: ): Promise<AuthenticatedPublicApiToken | null> {
  329:   const rawToken = readPublicApiBearerToken(request)
  330:   if (!rawToken) {
  331:     reply.code(401).send({ error: 'Unauthorized', code: 'PUBLIC_API_TOKEN_REQUIRED' })
  332:     return null
  333:   }
  334: 
  335:   if (rawToken.startsWith(OAUTH_ACCESS_TOKEN_PREFIX)) {
  336:     const tokenHash = hashPublicApiToken(rawToken)
  337:     const tokenPrefix = getPublicApiTokenPrefix(rawToken)
  338:     const token = await prisma.oAuthAccessToken.findUnique({
  339:       where: { tokenHash },
  340:       include: {
  341:         app: { select: { name: true, clientId: true, enabled: true } },
  342:         user: {
  343:           select: {
  344:             id: true,
  345:             username: true,
  346:             email: true,
  347:             role: true,
  348:             status: true,
  349:             avatarStyle: true,
  350:             avatarBadgeId: true
  351:           }
  352:         }
  353:       }
  354:     })
  355: 
  356:     if (!token || !safeTimingEqual(token.tokenHash, tokenHash) || token.tokenPrefix !== tokenPrefix) {
  357:       reply.code(401).send({ error: 'Unauthorized', code: 'PUBLIC_API_TOKEN_INVALID' })
  358:       return null
  359:     }
  360: 
  361:     if (!token.app.enabled) {
  362:       reply.code(401).send({ error: 'OAuth app disabled', code: 'OAUTH_APP_DISABLED' })
  363:       return null
  364:     }
  365: 
