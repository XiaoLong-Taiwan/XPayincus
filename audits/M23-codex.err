 1300:     const type = normalizePublicBalanceLogType(request.query?.type)
 1301:     const lotteryGift = request.query?.lotteryGift
 1302:     const where: Prisma.BalanceLogWhereInput = {
 1303:       userId: apiToken.userId,
 1304:       ...(type ? { type } : {})
 1305:     }
 1306: 
 1307:     if (lotteryGift === 'exclude') {
 1308:       where.NOT = {
 1309:         type: 'gift',
 1310:         remark: { contains: 'æŠ½å¥–ä¸­å¥–' }
 1311:       }
 1312:     } else if (lotteryGift === 'only') {
 1313:       where.type = 'gift'
 1314:       where.remark = { contains: 'æŠ½å¥–ä¸­å¥–' }
 1315:     }
 1316: 
 1317:     const [total, logs] = await Promise.all([
 1318:       prisma.balanceLog.count({ where }),
