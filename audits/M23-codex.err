 1152: function getPublicPluginActions(manifest: PayIncusPluginManifest) {
 1153:   return (manifest.capabilities?.actions || [])
 1154:     .filter(action => isPublicPluginAction(action) && pluginManifestHasActionPermission(manifest, action))
 1155:     .map(serializePublicPluginAction)
 1156: }
