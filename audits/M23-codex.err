  810: function mapRechargeStatus(status: RechargeStatus): string {
  811:   if (status === 'completed') return 'completed'
  812:   if (status === 'refunded') return 'refunded'
  813:   if (status === 'failed') return 'failed'
  814:   if (status === 'cancelled') return 'cancelled'
  815:   return 'pending'
  816: }
