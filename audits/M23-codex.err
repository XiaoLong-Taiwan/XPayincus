 1582:   fastify.get<{ Querystring: PublicApiOrderListQuery }>('/orders', async (request, reply) => {
 1583:     const apiToken = await authenticatePublicApiRequest(request, reply, 'orders:read')
 1584:     if (!apiToken) return
 1585:     const pagination = parsePagination(request.query || {})
 1586:     const sort = parsePublicApiSort(request.query?.sort, PUBLIC_CREATED_AT_SORT_FIELDS, '-createdAt')
 1587:     if (!sort) return reply.code(400).send({ error: 'Invalid sort', code: 'INVALID_PUBLIC_API_SORT' })
 1588:     const status = normalizeOptionalEnum(request.query?.status, PUBLIC_ORDER_STATUSES)
 1589:     if (status === null) return reply.code(400).send({ error: 'Invalid order status', code: 'INVALID_ORDER_STATUS' })
 1590:     const orderStatusFilter = buildPublicOrderStatusFilter(status)
 1591:     const rechargeWhere: Prisma.RechargeRecordWhereInput = {
 1592:       userId: apiToken.userId,
 1593:       ...(orderStatusFilter.rechargeStatuses ? { status: { in: orderStatusFilter.rechargeStatuses } } : {})
 1594:     }
 1595:     const billingWhere: Prisma.InstanceBillingRecordWhereInput = {
 1596:       userId: apiToken.userId,
 1597:       ...(orderStatusFilter.billingTypes ? { type: { in: orderStatusFilter.billingTypes } } : {})
 1598:     }
 1599:     const sourceTake = Math.min(pagination.skip + pagination.take, 200)
 1600:     const [rechargeTotal, billingTotal, recharges, billings] = await Promise.all([
 1601:       orderStatusFilter.rechargeStatuses?.length === 0 ? 0 : prisma.rechargeRecord.count({ where: rechargeWhere }),
 1602:       orderStatusFilter.billingTypes?.length === 0 ? 0 : prisma.instanceBillingRecord.count({ where: billingWhere }),
 1603:       orderStatusFilter.rechargeStatuses?.length === 0 ? [] : prisma.rechargeRecord.findMany({
 1604:         where: rechargeWhere,
 1605:         orderBy: buildPublicSortOrder(sort) as Prisma.RechargeRecordOrderByWithRelationInput[],
 1606:         take: sourceTake
 1607:       }),
 1608:       orderStatusFilter.billingTypes?.length === 0 ? [] : prisma.instanceBillingRecord.findMany({
 1609:         where: billingWhere,
 1610:         orderBy: buildPublicSortOrder(sort) as Prisma.InstanceBillingRecordOrderByWithRelationInput[],
 1611:         take: sourceTake,
 1612:         include: {
 1613:           instance: {
 1614:             select: {
 1615:               id: true,
 1616:               name: true,
 1617:               status: true,
 1618:               packagePlan: {
 1619:                 select: {
 1620:                   id: true,
 1621:                   name: true,
 1622:                   package: { select: { id: true, name: true } }
 1623:                 }
 1624:               }
 1625:             }
 1626:           }
 1627:         }
 1628:       })
 1629:     ])
 1630: 
 1631:     const sortMultiplier = sort.direction === 'desc' ? -1 : 1
 1632:     const orders = [
 1633:       ...recharges.map(record => ({
 1634:         id: `recharge:${record.id}`,
 1635:         sourceType: 'recharge',
 1636:         sourceId: record.id,
 1637:         orderNo: record.orderNo,
 1638:         title: 'ä½™é¢å……å€¼',
 1639:         status: mapRechargeStatus(record.status),
 1640:         rawStatus: record.status,
 1641:         amount: toMoney(record.amount),
 1642:         actualAmount: record.actualAmount === null ? null : toMoney(record.actualAmount),
 1643:         fee: toMoney(record.fee),
 1644:         paymentMethod: record.paymentMethod,
 1645:         tradeNo: maskTradeNo(record.tradeNo),
 1646:         failReason: record.failReason,
 1647:         createdAt: record.createdAt.toISOString(),
 1648:         completedAt: record.completedAt?.toISOString() ?? null,
 1649:         expiredAt: record.expiredAt?.toISOString() ?? null
 1650:       })),
 1651:       ...billings.map(record => ({
 1652:         id: `instance_billing:${record.id}`,
 1653:         sourceType: 'instance_billing',
 1654:         sourceId: record.id,
 1655:         orderNo: `IB-${record.id}`,
 1656:         title: record.remark || 'å®žä¾‹è®¡è´¹',
 1657:         status: mapBillingStatus(record.type),
 1658:         rawStatus: record.type,
 1659:         amount: toMoney(record.amount),
 1660:         actualAmount: toMoney(record.amount),
 1661:         fee: 0,
 1662:         paymentMethod: 'balance',
 1663:         tradeNo: null,
 1664:         failReason: null,
 1665:         instance: record.instance ? {
 1666:           id: record.instance.id,
 1667:           name: record.instance.name,
 1668:           status: record.instance.status,
 1669:           plan: record.instance.packagePlan ? {
 1670:             id: record.instance.packagePlan.id,
 1671:             name: record.instance.packagePlan.name,
 1672:             package: record.instance.packagePlan.package
 1673:           } : null
 1674:         } : null,
 1675:         months: record.months,
 1676:         periodStart: record.periodStart.toISOString(),
 1677:         periodEnd: record.periodEnd.toISOString(),
 1678:         createdAt: record.createdAt.toISOString(),
 1679:         completedAt: record.createdAt.toISOString(),
 1680:         expiredAt: null
 1681:       }))
 1682:     ]
 1683:       .sort((a, b) => {
 1684:         const createdAtCompare = a.createdAt.localeCompare(b.createdAt) * sortMultiplier
 1685:         if (createdAtCompare !== 0) return createdAtCompare
 1686:         return a.id.localeCompare(b.id) * sortMultiplier
 1687:       })
 1688:       .slice(pagination.skip, pagination.skip + pagination.take)
 1689: 
 1690:     await createLog(apiToken.userId, LogModule.PLUGIN, 'public_api.orders_list', `Public API ${apiToken.source} listed own orders`, LogResult.SUCCESS)
 1691:     return {
 1692:       data: orders,
 1693:       meta: publicSortMeta({ page: pagination.page, pageSize: pagination.pageSize, total: rechargeTotal + billingTotal, sort })
 1694:     }
 1695:   })
