 1026: function isPublicPluginAction(action: PluginActionManifest): boolean {
 1027:   if (action.runtime !== 'webhook' || !action.url) return false
 1028:   return !(action.scopes || []).some(scope => scope.startsWith('service-extension:') || scope.startsWith('gateway-extension:'))
 1029: }
 1030: 
 1031: function pluginManifestHasActionPermission(manifest: PayIncusPluginManifest, action: PluginActionManifest): boolean {
 1032:   const permissions = new Set(manifest.permissions || [])
 1033:   return permissions.has('plugin-action:run') && (action.scopes || []).every(scope => permissions.has(scope))
 1034: }
 1035: 
 1036: function serializePublicPluginAction(action: PluginActionManifest) {
 1037:   return {
 1038:     name: action.name,
 1039:     method: action.method,
 1040:     path: action.path,
 1041:     runtime: action.runtime,
 1042:     scopes: action.scopes || [],
 1043:     idempotency: action.idempotency || 'none',
 1044:     rateLimit: action.rateLimit || 'normal',
 1045:     requestSchema: action.requestSchema || null,
 1046:     responseSchema: action.responseSchema || null
 1047:   }
 1048: }
