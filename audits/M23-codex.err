 1336:     await createLog(
 1337:       apiToken.userId,
 1338:       LogModule.PLUGIN,
 1339:       'public_api.balance_logs_list',
 1340:       `Public API ${apiToken.source} listed current user balance logs`,
 1341:       LogResult.SUCCESS
 1342:     )
 1343: 
 1344:     return {
 1345:       data: logs.map(log => {
 1346:         const instance = log.instanceId ? instanceMap.get(log.instanceId) ?? null : null
 1347:         return {
 1348:           id: log.id,
 1349:           type: log.type,
 1350:           amount: toMoney(log.amount),
 1351:           balanceBefore: toMoney(log.balanceBefore),
 1352:           balanceAfter: toMoney(log.balanceAfter),
 1353:           orderId: log.orderId,
 1354:           instance: instance ? { id: instance.id, name: instance.name } : null,
