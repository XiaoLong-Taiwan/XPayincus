 1017: async function loadEnabledPublicPluginManifest(pluginId: string): Promise<PayIncusPluginManifest | null> {
 1018:   const plugin = await prisma.plugin.findUnique({
 1019:     where: { pluginId },
 1020:     include: { versions: { orderBy: { installedAt: 'desc' }, take: 1 } }
 1021:   })
 1022:   if (!plugin || !plugin.enabled || plugin.status !== 'enabled') return null
 1023:   return plugin.versions[0]?.manifest as unknown as PayIncusPluginManifest | null
 1024: }
