 2257:     if (!apiToken) return
 2258: 
 2259:     let uploadedAttachments: CreateTicketMessageAttachmentData[] = []
 2260: 
 2261:     try {
 2262:       if (!await getSystemConfigBoolean('ticket_enabled', true)) {
 2263:         return reply.code(403).send({ error: 'Ticket creation is disabled', code: 'TICKET_CREATION_DISABLED' })
 2264:       }
 2265: 
 2266:       const payload = await readTicketPayload(request)
 2267:       const subject = normalizePublicTicketSubject(payload.fields.subject)
 2268:       const content = normalizePublicTicketMessageContent(payload.fields.content)
 2269:       if (!subject || content.length > MAX_PUBLIC_TICKET_REPLY_LENGTH || (payload.images.length === 0 && content.length < MIN_PUBLIC_TICKET_CREATE_CONTENT_LENGTH)) {
 2270:         return reply.code(400).send({
 2271:           error: `subject must be ${MIN_PUBLIC_TICKET_SUBJECT_LENGTH}-${MAX_PUBLIC_TICKET_SUBJECT_LENGTH} characters and content must be ${MIN_PUBLIC_TICKET_CREATE_CONTENT_LENGTH}-${MAX_PUBLIC_TICKET_REPLY_LENGTH} characters when no images are attached`,
 2272:           code: 'INVALID_TICKET_CREATE_PAYLOAD'
 2273:         })
 2274:       }
 2275: 
 2276:       const instanceId = parseOptionalPositiveId(payload.fields.instanceId)
 2277:       if (instanceId === null) {
 2278:         return reply.code(400).send({ error: 'Invalid instance id', code: 'INVALID_INSTANCE_ID' })
 2279:       }
 2280: 
 2281:       let hostId: number | null = null
 2282:       let host: { id: number; name: string; userId: number; user: { role: string } } | null = null
 2283:       let instance: { id: number; name: string; hostId: number } | null = null
 2284:       if (instanceId !== undefined) {
 2285:         instance = await prisma.instance.findFirst({
 2286:           where: { id: instanceId, userId: apiToken.userId },
 2287:           select: { id: true, name: true, hostId: true }
 2288:         })
 2289:         if (!instance) return reply.code(404).send({ error: 'Instance not found', code: 'INSTANCE_NOT_FOUND' })
 2290:         hostId = instance.hostId
 2291:         host = await prisma.host.findUnique({
 2292:           where: { id: hostId },
 2293:           select: {
 2294:             id: true,
 2295:             name: true,
 2296:             userId: true,
 2297:             user: { select: { role: true } }
 2298:           }
 2299:         })
 2300:         if (!host) return reply.code(404).send({ error: 'Host not found', code: 'HOST_NOT_FOUND' })
 2301:       }
 2302: 
 2303:       const category = normalizePublicTicketCategory(payload.fields.category)
 2304:       const priority = normalizePublicTicketPriority(payload.fields.priority)
 2305:       if (payload.images.length > 0) {
 2306:         uploadedAttachments = await uploadTicketImages(payload.images)
 2307:       }
 2308: 
 2309:       const result = await createTicket({
 2310:         userId: apiToken.userId,
 2311:         hostId,
 2312:         instanceId: instanceId ?? null,
 2313:         subject,
 2314:         category,
 2315:         priority,
 2316:         content,
 2317:         attachments: uploadedAttachments
 2318:       })
 2319: 
 2320:       const attachments = uploadedAttachments.length > 0
 2321:         ? await prisma.ticketMessageAttachment.findMany({
 2322:           where: { ticketId: result.ticketId, messageId: result.messageId },
 2323:           orderBy: { id: 'asc' },
 2324:           select: {
 2325:             id: true,
 2326:             filename: true,
 2327:             originalName: true,
 2328:             mimeType: true,
 2329:             sizeBytes: true,
 2330:             thumbnailUrl: true,
 2331:             createdAt: true
 2332:           }
 2333:         })
 2334:         : []
 2335: 
 2336:       try {
 2337:         if (host && host.user.role !== 'admin') {
 2338:           await sendNotification(host.userId, 'ticket_created', {
 2339:             username: apiToken.user.username,
 2340:             subject,
 2341:             hostName: host.name,
 2342:             instanceName: instance?.name || 'æ— '
 2343:           })
 2344:         } else {
 2345:           const adminIds = await getAllAdminUserIds()
 2346:           for (const adminId of adminIds) {
 2347:             await sendNotification(adminId, 'ticket_created', {
 2348:               username: apiToken.user.username,
 2349:               subject,
 2350:               hostName: host?.name || 'ç³»ç»Ÿ',
 2351:               instanceName: instance?.name || 'æ— '
 2352:             })
 2353:           }
 2354:         }
 2355:       } catch (error) {
 2356:         console.error('[PublicAPI] Failed to send ticket creation notification:', error)
 2357:       }
 2358: 
 2359:       emitPluginEvent('ticket.created', {
 2360:         dedupeKey: `ticket.created:${result.ticketId}:${result.messageId}`,
 2361:         ticketId: result.ticketId,
 2362:         messageId: result.messageId,
 2363:         userId: apiToken.userId,
 2364:         username: apiToken.user.username,
 2365:         subject,
 2366:         category,
 2367:         priority,
 2368:         instanceId: instanceId ?? null,
 2369:         hostId,
 2370:         attachmentCount: uploadedAttachments.length,
 2371:         source: 'public_api',
 2372:         createdAt: new Date().toISOString()
