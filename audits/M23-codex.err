  497: export async function exchangeOAuthRefreshToken(input: {
  498:   clientId: string
  499:   clientSecret: string
  500:   refreshToken: string
  501: }) {
  502:   const app = await prisma.oAuthClientApp.findUnique({ where: { clientId: input.clientId } })
  503:   if (!app || !app.enabled || !safeTimingEqual(app.clientSecretHash, hashOAuthSecret(input.clientSecret))) {
  504:     throw new Error('Invalid OAuth client credentials')
  505:   }
  506: 
  507:   const refreshTokenHash = hashOAuthSecret(input.refreshToken)
  508:   const accessTokenRaw = generateOAuthAccessToken()
  509:   const nextRefreshTokenRaw = generateOAuthRefreshToken()
  510:   const accessTokenHash = hashOAuthSecret(accessTokenRaw)
  511:   const nextRefreshTokenHash = hashOAuthSecret(nextRefreshTokenRaw)
  512:   const accessTokenExpiresAt = new Date(Date.now() + OAUTH_ACCESS_TOKEN_TTL_SECONDS * 1000)
  513:   const refreshTokenExpiresAt = new Date(Date.now() + OAUTH_REFRESH_TOKEN_TTL_SECONDS * 1000)
  514: 
  515:   const result = await prisma.$transaction(async tx => {
  516:     const refreshToken = await tx.oAuthRefreshToken.findUnique({
  517:       where: { tokenHash: refreshTokenHash },
  518:       include: {
  519:         user: { select: { status: true } },
  520:         grant: true
  521:       }
  522:     })
  523:     if (!refreshToken || refreshToken.appId !== app.id) throw new Error('Invalid refresh token')
  524:     if (refreshToken.revokedAt) throw new Error('Refresh token has been revoked')
  525:     if (refreshToken.expiresAt.getTime() <= Date.now()) throw new Error('Refresh token has expired')
  526:     if (refreshToken.user.status !== 'active') throw new Error('Account is not active')
  527:     if (!refreshToken.grant || refreshToken.grant.revokedAt) throw new Error('OAuth authorization has been revoked')
  528: 
  529:     await tx.oAuthRefreshToken.update({
  530:       where: { id: refreshToken.id },
  531:       data: {
  532:         revokedAt: new Date(),
  533:         lastUsedAt: new Date()
  534:       }
  535:     })
  536: 
  537:     const scopes = serializeScopes(refreshToken.scopes)
  538:     const accessToken = await tx.oAuthAccessToken.create({
  539:       data: {
  540:         appId: app.id,
  541:         userId: refreshToken.userId,
  542:         grantId: refreshToken.grantId,
  543:         tokenPrefix: getOAuthAccessTokenPrefix(accessTokenRaw),
  544:         tokenHash: accessTokenHash,
  545:         scopes,
  546:         expiresAt: accessTokenExpiresAt
  547:       }
  548:     })
  549:     const nextRefreshToken = await tx.oAuthRefreshToken.create({
  550:       data: {
  551:         appId: app.id,
  552:         userId: refreshToken.userId,
  553:         grantId: refreshToken.grantId,
  554:         tokenPrefix: getOAuthRefreshTokenPrefix(nextRefreshTokenRaw),
  555:         tokenHash: nextRefreshTokenHash,
  556:         scopes,
  557:         expiresAt: refreshTokenExpiresAt
  558:       }
  559:     })
  560:     return { accessToken, refreshToken: nextRefreshToken }
  561:   })
  562: 
  563:   return {
  564:     accessToken: accessTokenRaw,
  565:     refreshToken: nextRefreshTokenRaw,
  566:     tokenType: 'Bearer' as const,
  567:     expiresIn: OAUTH_ACCESS_TOKEN_TTL_SECONDS,
  568:     refreshExpiresIn: OAUTH_REFRESH_TOKEN_TTL_SECONDS,
  569:     scope: serializeScopes(result.accessToken.scopes).join(' '),
  570:     accessTokenRecord: result.accessToken
  571:   }
  572: }
