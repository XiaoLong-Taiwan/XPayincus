  531: function normalizePublicNotificationVariables(value: unknown): Record<string, string> | null {
  532:   if (value === undefined || value === null) return {}
  533:   if (!value || typeof value !== 'object' || Array.isArray(value)) return null
  534:   const entries = Object.entries(value as Record<string, unknown>)
  535:   if (entries.length > MAX_PUBLIC_NOTIFICATION_TEMPLATE_VARIABLES) return null
  536: 
  537:   const normalized: Record<string, string> = {}
  538:   for (const [key, rawValue] of entries) {
  539:     if (!/^[A-Za-z][A-Za-z0-9_]{0,39}$/.test(key)) return null
  540:     if (rawValue === null || rawValue === undefined) continue
  541:     if (!['string', 'number', 'boolean'].includes(typeof rawValue)) return null
  542:     const text = String(rawValue).trim()
  543:     if (!text || text.length > MAX_PUBLIC_NOTIFICATION_TEMPLATE_VARIABLE_LENGTH) return null
  544:     normalized[key] = text
  545:   }
  546:   return normalized
  547: }
