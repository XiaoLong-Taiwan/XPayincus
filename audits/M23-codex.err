 1050: async function resolvePublicPluginActionRateLimitPolicy(input: {
 1051:   pluginId: string
 1052:   actionName: string
 1053:   rateLimit?: 'normal' | 'strict'
 1054: }): Promise<{ rateLimit: 'normal' | 'strict'; max: number; windowMs: number }> {
 1055:   const rateLimit = input.rateLimit === 'strict' ? 'strict' : 'normal'
 1056:   const fallback = PUBLIC_PLUGIN_ACTION_DYNAMIC_RATE_LIMITS[rateLimit]
 1057:   const rows = await prisma.$queryRaw<PublicPluginActionRateLimitPolicyRow[]>`
 1058:     SELECT
 1059:       "max_requests" AS "maxRequests",
 1060:       "window_seconds" AS "windowSeconds"
 1061:     FROM "public_plugin_action_rate_limit_policies"
 1062:     WHERE "enabled" = true
 1063:       AND "rate_limit" = ${rateLimit}
 1064:       AND (
 1065:         ("plugin_id" = ${input.pluginId} AND "action_name" = ${input.actionName})
 1066:         OR ("plugin_id" = ${input.pluginId} AND "action_name" = ${PUBLIC_PLUGIN_ACTION_RATE_LIMIT_GLOBAL_SCOPE})
 1067:         OR ("plugin_id" = ${PUBLIC_PLUGIN_ACTION_RATE_LIMIT_GLOBAL_SCOPE} AND "action_name" = ${PUBLIC_PLUGIN_ACTION_RATE_LIMIT_GLOBAL_SCOPE})
 1068:       )
 1069:     ORDER BY
 1070:       CASE
 1071:         WHEN "plugin_id" = ${input.pluginId} AND "action_name" = ${input.actionName} THEN 1
 1072:         WHEN "plugin_id" = ${input.pluginId} AND "action_name" = ${PUBLIC_PLUGIN_ACTION_RATE_LIMIT_GLOBAL_SCOPE} THEN 2
 1073:         ELSE 3
 1074:       END ASC
 1075:     LIMIT 1
 1076:   `
 1077:   const policy = rows[0]
 1078:   if (!policy) return { rateLimit, ...fallback }
 1079: 
 1080:   return {
 1081:     rateLimit,
 1082:     max: Math.max(1, Math.min(10_000, policy.maxRequests)),
 1083:     windowMs: Math.max(10, Math.min(3600, policy.windowSeconds)) * 1000
 1084:   }
 1085: }
 1086: 
 1087: async function checkPublicPluginActionDynamicRateLimit(input: {
 1088:   tokenSource: string
 1089:   tokenId: number
 1090:   pluginId: string
 1091:   actionName: string
 1092:   rateLimit?: 'normal' | 'strict'
 1093: }): Promise<{ allowed: true } | { allowed: false; retryAfterSeconds: number; limit: number }> {
 1094:   const policy = await resolvePublicPluginActionRateLimitPolicy(input)
 1095:   const now = new Date()
 1096:   const resetAt = new Date(now.getTime() + policy.windowMs)
 1097:   const rows = await prisma.$queryRaw<Array<{ requestCount: number; resetAt: Date }>>`
 1098:     INSERT INTO "public_plugin_action_rate_limit_buckets" (
 1099:       "token_source",
 1100:       "token_id",
 1101:       "plugin_id",
 1102:       "action_name",
 1103:       "policy",
 1104:       "request_count",
 1105:       "reset_at",
 1106:       "created_at",
 1107:       "updated_at"
 1108:     )
 1109:     VALUES (
 1110:       ${input.tokenSource},
 1111:       ${input.tokenId},
 1112:       ${input.pluginId},
 1113:       ${input.actionName},
 1114:       ${policy.rateLimit},
 1115:       1,
 1116:       ${resetAt},
 1117:       ${now},
 1118:       ${now}
 1119:     )
 1120:     ON CONFLICT ("token_source", "token_id", "plugin_id", "action_name")
 1121:     DO UPDATE SET
 1122:       "policy" = ${policy.rateLimit},
 1123:       "request_count" = CASE
 1124:         WHEN "public_plugin_action_rate_limit_buckets"."reset_at" <= ${now} THEN 1
 1125:         ELSE "public_plugin_action_rate_limit_buckets"."request_count" + 1
 1126:       END,
 1127:       "reset_at" = CASE
 1128:         WHEN "public_plugin_action_rate_limit_buckets"."reset_at" <= ${now} THEN ${resetAt}
 1129:         ELSE "public_plugin_action_rate_limit_buckets"."reset_at"
 1130:       END,
 1131:       "updated_at" = ${now}
 1132:     RETURNING
 1133:       "request_count" AS "requestCount",
 1134:       "reset_at" AS "resetAt"
 1135:   `
 1136:   const bucket = rows[0]
 1137:   if (!bucket) {
 1138:     return { allowed: true }
 1139:   }
 1140: 
 1141:   if (bucket.requestCount > policy.max) {
 1142:     return {
 1143:       allowed: false,
 1144:       retryAfterSeconds: Math.max(1, Math.ceil((bucket.resetAt.getTime() - now.getTime()) / 1000)),
 1145:       limit: policy.max
 1146:     }
 1147:   }
 1148: 
 1149:   return { allowed: true }
 1150: }
