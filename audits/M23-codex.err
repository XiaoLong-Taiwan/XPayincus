 1965:         LogModule.PLUGIN,
 1966:         'public_api.service_action_queued',
 1967:         `Public API ${apiToken.source} queued ${action} task #${task.id} for own service "${service.name}"`,
 1968:         LogResult.SUCCESS,
 1969:         { instanceId: service.id }
 1970:       )
