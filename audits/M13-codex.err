 117:     if (latestSnapshot && elapsedSeconds > 0) {
 118:       const rxMbps = Number(rxIncrement) * 8 / elapsedSeconds / 1_000_000
 119:       const txMbps = Number(txIncrement) * 8 / elapsedSeconds / 1_000_000
 120:       const pps = Number(totalPacketDelta) / elapsedSeconds
 121: 
 122:       await tx.instanceResourceSample.create({
