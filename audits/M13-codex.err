 280:             periodStart: formatLocalDate(periodStart),
 281:             periodEnd: formatLocalDate(periodEnd),
 282:             data: history.map(record => ({
 283:                 date: formatLocalDate(record.date),
 284:                 rxTotal: serializeBigInt(record.rxTotal),
 285:                 txTotal: serializeBigInt(record.txTotal),
 286:                 rxFormatted: formatBytes(record.rxTotal),
 287:                 txFormatted: formatBytes(record.txTotal),
 288:                 total: serializeBigInt(record.rxTotal + record.txTotal),
 289:                 totalFormatted: formatBytes(record.rxTotal + record.txTotal)
 290:             }))
 291:         }
 292:     })
