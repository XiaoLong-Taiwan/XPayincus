  75: export function formatBytes(bytes: bigint): string {
  76:     const units = ['B', 'KB', 'MB', 'GB', 'TB']
  77:     let value = Number(bytes)
  78:     let unitIndex = 0
  79: 
  80:     while (value >= 1024 && unitIndex < units.length - 1) {
  81:         value /= 1024
  82:         unitIndex++
  83:     }
  84: 
  85:     return `${value.toFixed(2)} ${units[unitIndex]}`
  86: }
