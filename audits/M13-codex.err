  72:             certPath: host.certPath,
  73:             keyPath: host.keyPath
  74:         })
  75:         const duration = Date.now() - startTime
  76:         updateClientResponseTime(host.id, duration)
  77:         return client
  78:     } catch (error) {
  79:         console.error(`[Traffic] Failed to get client for host ${host.id}:`, error)
  80:         recordClientError(host.id)
  81:         return null
  82:     }
  83: }
