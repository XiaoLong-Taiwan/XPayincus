 435:     if (instancesToCheckForThrottle.size > 0) {
 436:         // è®¡ç®—æ¯ä¸ªå®žä¾‹å’Œç”¨æˆ·æ›´æ–°åŽçš„ç”¨é‡ï¼ˆåœ¨å†…å­˜ä¸­ï¼‰
 437:         const instanceUpdatedUsage = new Map<number, bigint>()
