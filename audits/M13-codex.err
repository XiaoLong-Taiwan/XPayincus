 177: /**
 178:  * æ£€æŸ¥å¹¶æ¢å¤å¸¦å®½
 179:  */
 180: async function checkAndRestore(
 181:     instance: RunningTrafficInstance,
 182:     client: IncusClient
 183: ): Promise<void> {
 184:     const userQuota = instance.user.quota
 185:     if (!userQuota) return
 186: 
 187:     const userEffectiveLimit = getEffectiveLimit(userQuota.monthlyTrafficLimit, userQuota.extraTrafficQuota)
 188:     const instanceLimit = instance.monthlyTrafficLimit
 189: 
 190:     const userUnderLimit = !isOverLimit(userQuota.monthlyTrafficUsed, userEffectiveLimit)
 191:     const instanceUnderLimit = !isOverLimit(instance.monthlyTrafficUsed, instanceLimit)
 192:     const desiredUserStatus = calculateUserTrafficStatus(userQuota.monthlyTrafficUsed, userEffectiveLimit)
 193: 
 194:     if (userUnderLimit && instanceUnderLimit) {
 195:         const remoteThrottled = await isThrottled(client, instance.incusId)
 196:         if (instance.trafficStatus !== 'LIMITED' && !remoteThrottled) {
 197:             if (userQuota.trafficStatus !== desiredUserStatus) {
 198:                 await trafficDb.updateUserTrafficStatus(instance.userId, desiredUserStatus)
 199:             }
 200:             return
 201:         }
 202: 
 203:         try {
 204:             const resolvedLimits = resolveTrafficBandwidthLimits(instance, {
 205:                 stripThrottleOverride: remoteThrottled || instance.trafficStatus === 'LIMITED'
 206:             })
 207: 
 208:             await restoreBandwidth(
 209:                 client,
 210:                 instance.incusId,
 211:                 resolvedLimits.incusIngress,
 212:                 resolvedLimits.incusEgress
 213:             )
 214:             await trafficDb.updateInstanceTrafficStatus(instance.id, 'NORMAL')
 215:             await trafficDb.updateInstanceBandwidthLimits(
 216:                 instance.id,
 217:                 resolvedLimits.dbIngress,
 218:                 resolvedLimits.dbEgress
 219:             )
 220: 
 221:             if (userQuota.trafficStatus !== desiredUserStatus) {
 222:                 await trafficDb.updateUserTrafficStatus(instance.userId, desiredUserStatus)
 223:             }
 224: 
 225:             console.log(`[Traffic] Restored bandwidth for instance ${instance.id}`)
 226:         } catch (error) {
 227:             console.error(`[Traffic] Failed to restore bandwidth for instance ${instance.id}:`, error)
 228:         }
 229:     }
 230: }
