 294:     /**
 295:      * æ›´æ–°å®žä¾‹æµé‡é™é¢ï¼ˆç®¡ç†å‘˜ï¼‰
 296:      */
 297:     fastify.put<{
 298:         Params: { instanceId: string }
 299:         Body: { monthlyLimit: unknown }
 300:     }>('/instances/:instanceId/traffic/limit', {
 301:         onRequest: [fastify.authenticateAdmin]
 302:     }, async (request: FastifyRequest<{
 303:         Params: { instanceId: string }
 304:         Body: { monthlyLimit: unknown }
 305:     }>, reply: FastifyReply) => {
 306:         const instanceId = parsePositiveId(request.params.instanceId)
 307:         if (instanceId === null) {
 308:             return reply.code(400).send({ error: 'Invalid instance ID' })
 309:         }
 310: 
 311:         const { monthlyLimit } = request.body
 312:         const limit = parseNullablePostgresBigIntInput(monthlyLimit)
 313:         if (limit === undefined) {
 314:             return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid monthly traffic limit'))
 315:         }
 316: 
 317:         await trafficDb.updateInstanceTrafficLimit(instanceId, limit)
 318:         const instance = await trafficDb.getInstanceTrafficInfo(instanceId)
 319:         if (instance) {
