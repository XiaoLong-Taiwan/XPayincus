  85: /**
  86:  * æ‰¹é‡æ›´æ–°æµé‡å¿«ç…§
  87:  * ä½¿ç”¨ PostgreSQL çš„ INSERT ... ON CONFLICT è¿›è¡Œé«˜æ•ˆçš„æ‰¹é‡æ›´æ–°
  88:  * æ”¯æŒå¤§è§„æ¨¡å®žä¾‹ï¼ˆ10000+ï¼‰ï¼Œä½¿ç”¨åˆ†ç‰‡å¤„ç†é¿å…äº‹åŠ¡è¿‡å¤§
  89:  */
  90: export async function bulkUpsertSnapshots(
  91:     snapshots: Array<{ instanceId: number; rxRaw: bigint; txRaw: bigint }>
  92: ) {
  93:     if (snapshots.length === 0) return
  94: 
  95:     // åˆ†æ‰¹å¤„ç†ï¼Œé¿å…å•æ¬¡äº‹åŠ¡è¿‡å¤§
  96:     for (let i = 0; i < snapshots.length; i += BATCH_SIZE) {
  97:         const batch = snapshots.slice(i, i + BATCH_SIZE)
  98:         
  99:         // ä½¿ç”¨ PostgreSQL çš„ INSERT ... ON CONFLICT (upsert) è¯­æ³•è¿›è¡Œæ‰¹é‡æ›´æ–°
 100:         // æž„å»º VALUES å­å¥ï¼ˆéªŒè¯å¹¶æ¸…ç†æ‰€æœ‰å€¼ï¼‰
 101:         const valuesClause = batch
 102:             .map(s => {
 103:                 const instanceId = sanitizeNumber(s.instanceId)
 104:                 const rxRaw = sanitizeNumber(s.rxRaw)
 105:                 const txRaw = sanitizeNumber(s.txRaw)
 106:                 return `(${instanceId}, ${rxRaw}, ${txRaw}, NOW())`
 107:             })
 108:             .join(', ')
 109:         
 110:         // ä½¿ç”¨åŽŸç”Ÿ SQL æ‰¹é‡ upsert
 111:         try {
 112:             await prisma.$executeRawUnsafe(`
 113:                 INSERT INTO traffic_snapshots (instance_id, rx_raw, tx_raw, updated_at)
 114:                 VALUES ${valuesClause}
 115:                 ON CONFLICT (instance_id)
 116:                 DO UPDATE SET
 117:                     rx_raw = EXCLUDED.rx_raw,
 118:                     tx_raw = EXCLUDED.tx_raw,
 119:                     updated_at = NOW()
 120:             `)
 121:         } catch (error) {
 122:             console.error(`[Traffic] Failed to bulk upsert snapshots (batch ${i}-${i + batch.length}):`, error)
 123:             throw error
 124:         }
 125:     }
 126: }
