 220: /**
 221:  * å‘é€ Telegram é€šçŸ¥
 222:  */
 223: async function sendTelegram(
 224:     config: { botToken: string; chatId: string },
 225:     title: string,
 226:     message: string
 227: ): Promise<{ success: boolean; error: string | null }> {
 228:     const { botToken, chatId } = config
 229: 
 230:     if (!botToken || !chatId) {
 231:         return { success: false, error: 'Missing botToken or chatId' }
 232:     }
 233: 
 234:     try {
 235:         const text = `*${escapeMarkdown(title)}*\n\n${escapeMarkdown(message)}`
 236: 
 237:         const response = await fetch(`https://api.telegram.org/bot${botToken}/sendMessage`, {
 238:             method: 'POST',
 239:             redirect: 'manual',
 240:             signal: AbortSignal.timeout(TRAFFIC_NOTIFICATION_FETCH_TIMEOUT_MS),
 241:             headers: { 'Content-Type': 'application/json' },
 242:             body: JSON.stringify({
 243:                 chat_id: chatId,
 244:                 text,
 245:                 parse_mode: 'MarkdownV2'
 246:             })
 247:         })
 248: 
 249:         const result = await response.json() as { ok: boolean; description?: string }
 250: 
 251:         if (!result.ok) {
 252:             return { success: false, error: result.description || 'Unknown error' }
 253:         }
 254: 
 255:         return { success: true, error: null }
 256:     } catch (err) {
 257:         const error = err instanceof Error ? err.message : String(err)
 258:         return { success: false, error }
 259:     }
 260: }
 261: 
 262: /**
 263:  * å‘é€ Discord é€šçŸ¥
 264:  */
 265: async function sendDiscord(
 266:     config: { webhookUrl: string },
 267:     title: string,
 268:     message: string
 269: ): Promise<{ success: boolean; error: string | null }> {
 270:     const { webhookUrl } = config
 271: 
 272:     if (!webhookUrl) {
 273:         return { success: false, error: 'Missing webhookUrl' }
 274:     }
 275: 
 276:     try {
 277:         const parsedUrl = await assertSafeWebhookUrl(webhookUrl)
 278:         const response = await fetch(parsedUrl.toString(), {
 279:             method: 'POST',
 280:             signal: AbortSignal.timeout(TRAFFIC_NOTIFICATION_FETCH_TIMEOUT_MS),
 281:             headers: { 'Content-Type': 'application/json' },
 282:             body: JSON.stringify({
 283:                 embeds: [{
 284:                     title,
 285:                     description: message,
 286:                     color: title.includes('é¢„è­¦') ? 0xffa500 : 0xff0000,
 287:                     timestamp: new Date().toISOString(),
 288:                     footer: {
 289:                         text: 'Incudal'
 290:                     }
 291:                 }]
 292:             }),
 293:             redirect: 'manual'
 294:         })
 295: 
 296:         if (!response.ok) {
 297:             return { success: false, error: await readSafeNotificationError(response) }
 298:         }
 299: 
 300:         return { success: true, error: null }
 301:     } catch (err) {
 302:         const error = err instanceof Error ? err.message : String(err)
 303:         return { success: false, error }
 304:     }
 305: }
