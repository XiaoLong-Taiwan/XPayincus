 420: /**
 421:  * éªŒè¯ IPv6 åœ°å€æ ¼å¼
 422:  */
 423: export function isValidIpv6(address: string): boolean {
 424:   // ç®€å•çš„ IPv6 æ ¼å¼éªŒè¯
 425:   const ipv6Regex = /^([0-9a-fA-F]{0,4}:){2,7}[0-9a-fA-F]{0,4}$/
 426:   const trimmed = address.trim().split('/')[0] // ç§»é™¤æŽ©ç 
 427:   return ipv6Regex.test(trimmed) || /^::1$/.test(trimmed) || /^::$/.test(trimmed)
 428: }
 429: 
 430: /**
 431:  * éªŒè¯ IPv6 ç½‘æ®µæ ¼å¼
 432:  */
 433: export function isValidIpv6Subnet(cidr: string): boolean {
 434:   const parts = cidr.split('/')
 435:   if (parts.length !== 2) return false
 436: 
 437:   const [addr, prefix] = parts
 438:   const prefixNum = parseInt(prefix, 10)
 439: 
 440:   if (isNaN(prefixNum) || prefixNum < 48 || prefixNum > 128) return false
 441: 
 442:   return isValidIpv6(addr)
 443: }

