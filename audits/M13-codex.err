  82: )
  83: assert.ok(
  84:   dbSource.includes('advisoryTransactionLockString(tx, IP_ADDRESS_ALLOCATION_LOCK_NAMESPACE, data.address)') &&
  85:     dbSource.includes('async function assertIpAddressAvailable(') &&
  86:     dbSource.includes("throw new Error(IP_ADDRESS_ALREADY_EXISTS_ERROR)") &&
  87:     dbSource.includes('export async function updateIpAddressAddress(') &&
  88:     dbSource.includes('data: { ipv6: data.address }'),
