  29: /**
  30:  * éªŒè¯å¹¶æ¸…ç† SQL å€¼ï¼ˆé˜²æ­¢ SQL æ³¨å…¥ï¼Œè™½ç„¶è¾“å…¥æ˜¯å—æŽ§çš„æ•°å­—ç±»åž‹ï¼‰
  31:  */
  32: function sanitizeNumber(value: number | bigint): string {
  33:     if (typeof value === 'bigint') {
  34:         // bigint å€¼ç¡®ä¿æ˜¯æœ‰æ•ˆæ•°å­—
  35:         if (value < 0n) {
  36:             throw new Error(`Invalid bigint value: ${value}`)
  37:         }
  38:         return value.toString()
  39:     }
  40:     // number å€¼éªŒè¯
  41:     if (!Number.isInteger(value) || value < 0 || !Number.isFinite(value)) {
  42:         throw new Error(`Invalid number value: ${value}`)
  43:     }
  44:     return value.toString()
  45: }
  46: 
  47: /**
  48:  * éªŒè¯å¹¶æ¸…ç†æ—¥æœŸå­—ç¬¦ä¸²
  49:  */
  50: function sanitizeDate(date: Date): string {
  51:     const dateStr = date.toISOString().split('T')[0] // YYYY-MM-DD
  52:     // éªŒè¯æ ¼å¼ï¼šYYYY-MM-DD
  53:     if (!/^\d{4}-\d{2}-\d{2}$/.test(dateStr)) {
  54:         throw new Error(`Invalid date format: ${dateStr}`)
  55:     }
  56:     return dateStr
  57: }
