 151:         select: {
 152:           monthlyTrafficUsed: true
 153:         }
 154:       })
 155:       currentUsage = updatedInstance.monthlyTrafficUsed
 156: 
 157:       await tx.userQuota.updateMany({
 158:         where: { userId },
 159:         data: {
 160:           monthlyTrafficUsed: { increment: totalDelta }
 161:         }
 162:       })
 163: 
 164:       await tx.dailyTraffic.upsert({
 165:         where: {
 166:           instanceId_date: {
 167:             instanceId,
 168:             date: normalizedDate
 169:           }
 170:         },
 171:         update: {
 172:           rxTotal: { increment: rxIncrement },
 173:           txTotal: { increment: txIncrement }
 174:         },
 175:         create: {
 176:           instanceId,
 177:           date: normalizedDate,
 178:           rxTotal: rxIncrement,
 179:           txTotal: txIncrement
 180:         }
 181:       })
 182:     }
 183: 
 184:     return {
 185:       totalDelta,
 186:       currentUsage,
 187:       skipped: false
 188:     }
 189:   }), {
 190:     expireMs: 30000,
 191:     waitTimeoutMs: 5000,
 192:     retryIntervalMs: 50
 193:   })
 194: 
 195:   if (!userLockResult.success || !userLockResult.result) {
 196:     throw new Error(userLockResult.error || 'ç”¨æˆ·æµé‡é‡ç½®é”èŽ·å–å¤±è´¥')
 197:   }
 198: 
 199:   return userLockResult.result
