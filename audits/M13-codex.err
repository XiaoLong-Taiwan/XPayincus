 876:  * å°†æ‰€æœ‰å®žä¾‹çš„æµé‡é™é¢æ›´æ–°ä¸ºå…¶æ‰€å±žå¥—é¤çš„æµé‡é™é¢
 877:  */
 878: export async function syncPackageTrafficLimitsToInstances(packageId?: number): Promise<{ count: number; instanceIds: number[] }> {
 879:     const instances = await prisma.instance.findMany({
 880:         where: {
 881:             status: { not: 'deleted' },
 882:             packageId: packageId ?? { not: null }
 883:         },
 884:         select: {
 885:             id: true,
 886:             hostId: true,
 887:             packageId: true,
 888:             monthlyTrafficUsed: true,
 889:             package: {
 890:                 select: {
 891:                     monthlyTrafficLimit: true
 892:                 }
 893:             },
 894:             packagePlan: {
 895:                 select: {
 896:                     trafficLimit: true
 897:                 }
 898:             }
 899:         }
 900:     })
 901: 
 902:     const packageIds = [...new Set(instances.map(instance => instance.packageId).filter((id): id is number => id !== null))]
 903:     if (packageIds.length === 0) {
 904:         return { count: 0, instanceIds: [] }
 905:     }
 906: 
 907:     const bindings = await prisma.packageHost.findMany({
 908:         where: {
 909:             packageId: { in: packageIds }
 910:         },
 911:         select: {
 912:             packageId: true,
 913:             hostId: true,
 914:             trafficMultiplier: true
 915:         }
 916:     })
 917:     const multiplierByPackageHost = new Map(bindings.map(binding => [
 918:         `${binding.packageId}:${binding.hostId}`,
 919:         binding.trafficMultiplier
 920:     ]))
 921: 
 922:     const updatedInstanceIds: number[] = []
 923:     await Promise.all(instances.map(instance => {
 924:         const baseTrafficLimit = instance.packagePlan?.trafficLimit ?? instance.package?.monthlyTrafficLimit ?? null
 925:         const monthlyTrafficLimit = applyTrafficMultiplier(
 926:             baseTrafficLimit,
 927:             multiplierByPackageHost.get(`${instance.packageId}:${instance.hostId}`) ?? 1
 928:         )
 929:         updatedInstanceIds.push(instance.id)
 930: 
 931:         return prisma.instance.update({
 932:             where: { id: instance.id },
 933:             data: {
 934:                 monthlyTrafficLimit,
 935:                 trafficStatus: calculateInstanceTrafficStatus(instance.monthlyTrafficUsed, monthlyTrafficLimit)
 936:             }
 937:         })
 938:     }))
 939: 
 940:     return { count: instances.length, instanceIds: updatedInstanceIds }
 941: }

