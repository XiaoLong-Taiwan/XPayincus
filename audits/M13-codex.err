 102:         currentUsage: instance.monthlyTrafficUsed
 103:     }, {
 104:         waitTimeoutMs: 200,
 105:         retryIntervalMs: 50,
 106:         expireMs: 30000
 107:     })
 108: 
 109:     if (!result.success) {
 110:         console.error(`[Traffic] Failed to collect traffic for instance ${instance.id}: ${result.error}`)
 111:         return null
 112:     }
 113: 
 114:     return {
 115:         instanceId: instance.id,
 116:         totalDelta: result.totalDelta
