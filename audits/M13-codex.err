  16: function sectionBetween(startMarker: string, endMarker: string): string {
  17:   const start = source.indexOf(startMarker)
  18:   assert.notEqual(start, -1, `missing start marker: ${startMarker}`)
  19:   const end = source.indexOf(endMarker, start + startMarker.length)
  20:   assert.notEqual(end, -1, `missing end marker: ${endMarker}`)
  21:   return source.slice(start, end)
  22: }
  23: 
  24: assert.ok(
