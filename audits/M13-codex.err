 232: async function reconcileTrafficState(instances: RunningTrafficInstance[]): Promise<void> {
 233:     if (instances.length === 0) {
 234:         return
 235:     }
 236: 
 237:     const instancesByHost = new Map<number, RunningTrafficInstance[]>()
 238:     for (const instance of instances) {
 239:         if (instance.host.status !== 'online') continue
 240: 
 241:         const hostInstances = instancesByHost.get(instance.host.id) || []
 242:         hostInstances.push(instance)
 243:         instancesByHost.set(instance.host.id, hostInstances)
 244:     }
 245: 
 246:     for (const [hostId, hostInstances] of instancesByHost) {
 247:         const host = hostInstances[0].host
 248:         const client = await getHostClient({
 249:             id: hostId,
 250:             url: host.url,
 251:             certPath: host.certPath,
 252:             keyPath: host.keyPath
 253:         })
 254: 
 255:         if (!client) continue
 256: 
 257:         const hostLimit = pLimit(CONCURRENCY_PER_HOST)
 258:         await Promise.all(
 259:             hostInstances.map(instance =>
 260:                 hostLimit(async () => {
 261:                     await checkAndThrottle(instance, client)
 262:                     await checkAndRestore(instance, client)
 263:                 })
 264:             )
 265:         )
 266:     }
 267: }
