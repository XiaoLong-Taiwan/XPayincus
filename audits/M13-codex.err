 130: /**
 131:  * æ›´æ–°æˆ–åˆ›å»ºæ¯æ—¥æµé‡è®°å½•
 132:  */
 133: export async function upsertDailyTraffic(
 134:     instanceId: number,
 135:     date: Date,
 136:     rxIncrement: bigint,
 137:     txIncrement: bigint
 138: ) {
 139:     // æ ‡å‡†åŒ–æ—¥æœŸä¸ºå½“å¤© 00:00:00
 140:     const normalizedDate = new Date(date.getFullYear(), date.getMonth(), date.getDate())
 141: 
 142:     const existing = await prisma.dailyTraffic.findUnique({
 143:         where: {
 144:             instanceId_date: { instanceId, date: normalizedDate }
 145:         }
 146:     })
 147: 
 148:     if (existing) {
 149:         return prisma.dailyTraffic.update({
 150:             where: { id: existing.id },
 151:             data: {
 152:                 rxTotal: existing.rxTotal + rxIncrement,
 153:                 txTotal: existing.txTotal + txIncrement
 154:             }
 155:         })
 156:     }
 157: 
 158:     return prisma.dailyTraffic.create({
 159:         data: {
 160:             instanceId,
 161:             date: normalizedDate,
 162:             rxTotal: rxIncrement,
 163:             txTotal: txIncrement
 164:         }
 165:     })
 166: }
 167: 
 168: /**
 169:  * æ‰¹é‡æ›´æ–°æˆ–åˆ›å»ºæ¯æ—¥æµé‡è®°å½•
 170:  * ä½¿ç”¨ PostgreSQL çš„ INSERT ... ON CONFLICT è¿›è¡Œé«˜æ•ˆçš„æ‰¹é‡æ›´æ–°
 171:  * æ”¯æŒå¤§è§„æ¨¡å®žä¾‹ï¼ˆ10000+ï¼‰ï¼Œä½¿ç”¨åˆ†ç‰‡å¤„ç†é¿å…äº‹åŠ¡è¿‡å¤§
 172:  */
 173: export async function bulkUpsertDailyTraffic(
 174:     updates: Array<{ instanceId: number; date: Date; rxIncrement: bigint; txIncrement: bigint }>
 175: ) {
 176:     if (updates.length === 0) return
 177: 
 178:     // æ ‡å‡†åŒ–æ—¥æœŸå¹¶åˆ†ç»„ï¼ˆæŒ‰ instanceId + dateï¼‰
 179:     const normalizedUpdates = updates.map(u => ({
 180:         instanceId: u.instanceId,
 181:         date: new Date(u.date.getFullYear(), u.date.getMonth(), u.date.getDate()),
 182:         rxIncrement: u.rxIncrement,
 183:         txIncrement: u.txIncrement
 184:     }))
 185: 
 186:     // åˆå¹¶åŒä¸€ä¸ªå®žä¾‹åŒä¸€å¤©çš„å¢žé‡
 187:     const dailyMap = new Map<string, { instanceId: number; date: Date; rxTotal: bigint; txTotal: bigint }>()
 188:     for (const u of normalizedUpdates) {
 189:         const key = `${u.instanceId}-${u.date.getTime()}`
 190:         const existing = dailyMap.get(key)
 191:         if (existing) {
 192:             existing.rxTotal += u.rxIncrement
 193:             existing.txTotal += u.txIncrement
 194:         } else {
 195:             dailyMap.set(key, {
 196:                 instanceId: u.instanceId,
 197:                 date: u.date,
 198:                 rxTotal: u.rxIncrement,
 199:                 txTotal: u.txIncrement
 200:             })
 201:         }
 202:     }
 203: 
 204:     const dailyArray = Array.from(dailyMap.values())
 205:     
 206:     // åˆ†æ‰¹å¤„ç†ï¼Œé¿å…å•æ¬¡äº‹åŠ¡è¿‡å¤§
 207:     for (let i = 0; i < dailyArray.length; i += BATCH_SIZE) {
 208:         const batch = dailyArray.slice(i, i + BATCH_SIZE)
 209:         
 210:         // ä½¿ç”¨ PostgreSQL çš„ INSERT ... ON CONFLICT (upsert) è¯­æ³•è¿›è¡Œæ‰¹é‡æ›´æ–°
 211:         // æž„å»º VALUES å­å¥ï¼ˆéªŒè¯å¹¶æ¸…ç†æ‰€æœ‰å€¼ï¼‰
 212:         const valuesClause = batch
 213:             .map(({ instanceId, date, rxTotal, txTotal }) => {
 214:                 const instanceIdStr = sanitizeNumber(instanceId)
 215:                 const dateStr = sanitizeDate(date)
 216:                 const rxTotalStr = sanitizeNumber(rxTotal)
 217:                 const txTotalStr = sanitizeNumber(txTotal)
 218:                 return `(${instanceIdStr}, '${dateStr}'::date, ${rxTotalStr}, ${txTotalStr})`
 219:             })
 220:             .join(', ')
 221:         
 222:         // ä½¿ç”¨åŽŸç”Ÿ SQL æ‰¹é‡ upsert
 223:         try {
 224:             await prisma.$executeRawUnsafe(`
 225:                 INSERT INTO daily_traffic (instance_id, date, rx_total, tx_total)
 226:                 VALUES ${valuesClause}
 227:                 ON CONFLICT (instance_id, date)
 228:                 DO UPDATE SET
 229:                     rx_total = daily_traffic.rx_total + EXCLUDED.rx_total,
 230:                     tx_total = daily_traffic.tx_total + EXCLUDED.tx_total
 231:             `)
 232:         } catch (error) {
 233:             console.error(`[Traffic] Failed to bulk upsert daily traffic (batch ${i}-${i + batch.length}):`, error)
 234:             throw error
 235:         }
 236:     }
 237: }
