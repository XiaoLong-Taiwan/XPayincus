 269: export async function reconcileTrafficStateForInstanceIds(instanceIds: number[]): Promise<void> {
 270:     const instances = await trafficDb.getRunningInstancesForTrafficByIds(instanceIds)
 271:     await reconcileTrafficState(instances)
 272: }
