 325: /**
 326:  * æ‰§è¡Œæµé‡é‡‡é›†ä»»åŠ¡ï¼ˆå®žé™…é€»è¾‘ï¼‰
 327:  * é«˜å¯ç”¨ä¼˜åŒ–ï¼šæŒ‰å®¿ä¸»æœºåˆ†æ‰¹å¤„ç†ï¼ŒæŽ§åˆ¶å¹¶å‘
 328:  */
 329: async function executeTrafficJob(startTime: number): Promise<void> {
 330:     const instances = await trafficDb.getRunningInstancesForTraffic()
 331:     console.log(`[Traffic] Found ${instances.length} running instances`)
 332: 
 333:     if (instances.length === 0) return
 334: 
 335:     // åˆ›å»ºå®žä¾‹æ˜ å°„è¡¨ï¼ˆç”¨äºŽåŽç»­æŸ¥æ‰¾ï¼‰
 336:     const instanceMap = new Map<number, typeof instances[0]>()
 337:     for (const instance of instances) {
 338:         instanceMap.set(instance.id, instance)
 339:     }
 340: 
 341:     // æŒ‰ä¸»æœºåˆ†ç»„
 342:     const instancesByHost = new Map<number, typeof instances>()
 343:     for (const instance of instances) {
 344:         if (instance.host.status !== 'online') continue
 345: 
 346:         const hostInstances = instancesByHost.get(instance.host.id) || []
 347:         hostInstances.push(instance)
 348:         instancesByHost.set(instance.host.id, hostInstances)
 349:     }
 350: 
 351:     // æ”¶é›†æµé‡æ•°æ®
 352:     const deltas: TrafficDelta[] = []
 353:     // æ€§èƒ½ç»Ÿè®¡
 354:     let successCount = 0
 355:     let errorCount = 0
 356: 
 357:     // å®šä¹‰å•ä¸ªå®¿ä¸»æœºçš„é‡‡é›†å‡½æ•°
 358:     async function collectHostTraffic(hostId: number, hostInstances: typeof instances): Promise<{
 359:         deltas: TrafficDelta[]
 360:         success: number
 361:         error: number
 362:     }> {
 363:         const host = hostInstances[0].host
 364:         const client = await getHostClient({
 365:             id: hostId,
 366:             url: host.url,
 367:             certPath: host.certPath,
 368:             keyPath: host.keyPath
 369:         })
 370: 
 371:         if (!client) {
 372:             return { deltas: [], success: 0, error: hostInstances.length }
 373:         }
 374: 
 375:         // æ¯å®¿ä¸»æœºä½¿ç”¨ç‹¬ç«‹çš„å¹¶å‘é™åˆ¶
 376:         const hostLimit = pLimit(CONCURRENCY_PER_HOST)
 377:         
 378:         // å¹¶å‘é‡‡é›†è¯¥ä¸»æœºä¸Šçš„æ‰€æœ‰å®žä¾‹
 379:         const results = await Promise.all(
 380:             hostInstances.map(instance =>
 381:                 hostLimit(() => collectInstanceTraffic(instance, client))
 382:             )
 383:         )
 384: 
 385:         const hostDeltas: TrafficDelta[] = []
 386:         let hostSuccess = 0
 387:         let hostError = 0
 388: 
 389:         for (const delta of results) {
 390:             if (delta) {
 391:                 hostDeltas.push(delta)
 392:                 hostSuccess++
 393:             } else {
 394:                 hostError++
 395:             }
 396:         }
 397: 
 398:         return { deltas: hostDeltas, success: hostSuccess, error: hostError }
 399:     }
