   4:   | 'nat_ipv6_nat'
   5:   | 'ipv6_only'
   6:   | 'ipv6_nat'
   7:   | 'public_ipv4'
   8:   | 'public_ipv4_ipv6'
   9: 
  10: export const ACTIVE_PACKAGE_NETWORK_MODES: NetworkMode[] = [
  11:   'nat',
  12:   'nat_ipv6',
  13:   'ipv6_only',
  14:   'public_ipv4',
  15:   'public_ipv4_ipv6'
  16: ]
  17: 
  18: export const LEGACY_IPV6_NAT_NETWORK_MODES = new Set<NetworkMode>([
  19:   'nat_ipv6_nat',
  20:   'ipv6_nat'
  21: ])
  22: 
  23: export function normalizeNetworkMode(value: string | null | undefined): NetworkMode {
  24:   switch (value) {
  25:     case 'nat_ipv6':
  26:     case 'nat_ipv6_nat':
  27:     case 'ipv6_only':
  28:     case 'ipv6_nat':
  29:     case 'public_ipv4':
  30:     case 'public_ipv4_ipv6':
  31:       return value
  32:     default:
  33:       return 'nat'
  34:   }
  35: }
  36: 
  37: export function networkModeNeedsNatIpv4(mode: string | null | undefined): boolean {
  38:   const normalized = normalizeNetworkMode(mode)
  39:   return normalized === 'nat' || normalized === 'nat_ipv6' || normalized === 'nat_ipv6_nat'
  40: }
  41: 
  42: export function networkModeNeedsPublicIpv4(mode: string | null | undefined): boolean {
  43:   const normalized = normalizeNetworkMode(mode)
  44:   return normalized === 'public_ipv4' || normalized === 'public_ipv4_ipv6'
  45: }
  46: 
  47: export function networkModeNeedsRoutedIpv6(mode: string | null | undefined): boolean {
  48:   const normalized = normalizeNetworkMode(mode)
  49:   return normalized === 'nat_ipv6' || normalized === 'ipv6_only' || normalized === 'public_ipv4_ipv6'
  50: }
  51: 
  52: export function networkModeAllowsPortMapping(mode: string | null | undefined): boolean {
  53:   return networkModeNeedsNatIpv4(mode)
  54: }
===== server/src/lib/traffic-multiplier.ts =====
   1: import type { Prisma } from '@prisma/client'
   2: 
   3: const MULTIPLIER_SCALE = 1000n
   4: 
   5: type DbClient = Prisma.TransactionClient | {
   6:   packageHost: {
   7:     findUnique(args: {
   8:       where: { packageId_hostId: { packageId: number; hostId: number } }
   9:       select: { trafficMultiplier: true }
  10:     }): Promise<{ trafficMultiplier: unknown } | null>
  11:   }
  12: }
  13: 
  14: export function normalizeTrafficMultiplier(value: unknown): number {
  15:   if (value === null || value === undefined || value === '') {
  16:     return 1
  17:   }
  18: 
  19:   const numeric = Number(value)
  20:   if (!Number.isFinite(numeric) || numeric < 0.001 || numeric > 100) {
  21:     throw new Error('Traffic multiplier must be at least 0.001 and no more than 100')
  22:   }
  23: 
  24:   return Math.round(numeric * 1000) / 1000
  25: }
  26: 
  27: export function applyTrafficMultiplier(limit: bigint | null, multiplier: unknown): bigint | null {
  28:   if (limit === null) {
  29:     return null
  30:   }
  31: 
  32:   const normalized = normalizeTrafficMultiplier(multiplier)
  33:   const scaled = BigInt(Math.round(normalized * Number(MULTIPLIER_SCALE)))
  34:   return (limit * scaled) / MULTIPLIER_SCALE
  35: }
  36: 
  37: export async function getPackageHostTrafficMultiplier(
  38:   client: DbClient,
  39:   packageId: number,
  40:   hostId: number
  41: ): Promise<number> {
  42:   const binding = await client.packageHost.findUnique({
  43:     where: {
  44:       packageId_hostId: {
  45:         packageId,
  46:         hostId
  47:       }
  48:     },
  49:     select: {
  50:       trafficMultiplier: true
  51:     }
  52:   })
  53: 
  54:   return normalizeTrafficMultiplier(binding?.trafficMultiplier)
  55: }
  56: 
  57: export async function resolveInstanceTrafficLimitForHost(
  58:   client: DbClient,
  59:   params: {
  60:     packageId: number | null | undefined
  61:     hostId: number
  62:     baseTrafficLimit: bigint | null
  63:   }
  64: ): Promise<bigint | null> {
  65:   if (!params.packageId) {
  66:     return params.baseTrafficLimit
  67:   }
  68: 
  69:   const multiplier = await getPackageHostTrafficMultiplier(client, params.packageId, params.hostId)
  70:   return applyTrafficMultiplier(params.baseTrafficLimit, multiplier)
  71: }
===== server/src/services/traffic-bandwidth.ts =====
   1: import { THROTTLE_BANDWIDTH } from '../lib/incus/incus-traffic.js'
   2: 
   3: const MB_IN_BYTES = 1024n * 1024n
   4: 
   5: interface TrafficBandwidthSource {
   6:   limitsIngress: string | null
   7:   limitsEgress: string | null
   8:   package?: {
   9:     limitsIngress: string | null
  10:     limitsEgress: string | null
  11:   } | null
  12:   packagePlan?: {
  13:     trafficLimitSpeed: string | null
  14:   } | null
  15: }
  16: 
  17: export interface ResolvedTrafficBandwidthLimits {
  18:   incusIngress: string | null
  19:   incusEgress: string | null
  20:   dbIngress: string | null
  21:   dbEgress: string | null
  22: }
  23: 
  24: export function normalizePlanTrafficLimitSpeed(trafficLimitSpeed: unknown): string | null | undefined {
  25:   if (trafficLimitSpeed === null || trafficLimitSpeed === undefined || trafficLimitSpeed === '') {
  26:     return null
  27:   }
  28: 
  29:   if (typeof trafficLimitSpeed !== 'string') {
  30:     return undefined
  31:   }
  32: 
  33:   const trimmed = trafficLimitSpeed.trim()
  34:   if (trimmed === '' || trimmed === '0') {
  35:     return null
  36:   }
  37: 
  38:   const unitMatch = trimmed.match(/^(\d+(?:\.\d+)?)\s*(Mbit|Gbit)$/i)
  39:   if (unitMatch) {
  40:     const numeric = Number(unitMatch[1])
  41:     if (!Number.isFinite(numeric) || numeric <= 0) {
  42:       return undefined
  43:     }
  44:     const multiplier = unitMatch[2].toLowerCase() === 'gbit' ? 1000 : 1
  45:     const mbps = Math.round(numeric * multiplier)
  46:     return mbps > 0 ? `${mbps}Mbit` : undefined
  47:   }
  48: 
  49:   if (/^\d+$/.test(trimmed)) {
  50:     const bytes = BigInt(trimmed)
  51:     const mbps = bytes / MB_IN_BYTES
  52:     return mbps > 0n ? `${mbps.toString()}Mbit` : null
  53:   }
  54: 
  55:   return undefined
  56: }
  57: 
  58: export function resolveTrafficBandwidthLimits(
  59:   instance: TrafficBandwidthSource,
  60:   options: { stripThrottleOverride?: boolean } = {}
  61: ): ResolvedTrafficBandwidthLimits {
  62:   const planLimit = normalizePlanTrafficLimitSpeed(instance.packagePlan?.trafficLimitSpeed)
  63:   if (planLimit) {
  64:     return {
  65:       incusIngress: planLimit,
  66:       incusEgress: planLimit,
  67:       dbIngress: planLimit,
  68:       dbEgress: planLimit
  69:     }
  70:   }
  71: 
  72:   const stripThrottleOverride = options.stripThrottleOverride === true
  73:   const configuredIngress = stripThrottleOverride && instance.limitsIngress === THROTTLE_BANDWIDTH
  74:     ? null
  75:     : instance.limitsIngress
  76:   const configuredEgress = stripThrottleOverride && instance.limitsEgress === THROTTLE_BANDWIDTH
  77:     ? null
  78:     : instance.limitsEgress
  79: 
  80:   return {
  81:     incusIngress: configuredIngress ?? instance.package?.limitsIngress ?? null,
  82:     incusEgress: configuredEgress ?? instance.package?.limitsEgress ?? null,
  83:     dbIngress: configuredIngress ?? null,
  84:     dbEgress: configuredEgress ?? null
  85:   }
  86: }
