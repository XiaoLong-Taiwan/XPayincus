 138:     }, async (request: FastifyRequest<{
 139:         Params: { userId: string }
 140:         Body: { monthlyLimit: unknown }
 141:     }>, reply: FastifyReply) => {
 142:         const userId = parsePositiveId(request.params.userId)
 143:         if (userId === null) {
