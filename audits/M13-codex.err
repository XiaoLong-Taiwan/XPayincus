  99:     instanceTaskWorkerSource.includes('ipAddresses:') &&
 100:     instanceTaskWorkerSource.includes("type: 'inet6'"),
 101:   'instance change-host worker must lock and recheck IPv6 uniqueness before direct ipAddress writes'
 102: )
 103: 
 104: const deleteIpSection = sectionBetween(
 105:   '     * åˆ é™¤å®žä¾‹çš„é¢å¤– IP',
