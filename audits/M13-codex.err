 413: /**
 414:  * åˆ¤æ–­ç½‘ç»œæ¨¡å¼æ˜¯å¦éœ€è¦ç‹¬ç«‹ IPv6 åœ°å€ï¼ˆRouted æ¨¡å¼ï¼‰
 415:  */
 416: export function hasIpv6Support(networkMode: NetworkMode): boolean {
 417:   return networkModeNeedsRoutedIpv6(networkMode)
 418: }
