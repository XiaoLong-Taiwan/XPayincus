  85: /**
  86:  * é‡‡é›†å•ä¸ªå®žä¾‹çš„æµé‡æ•°æ®
  87:  */
  88: async function collectInstanceTraffic(
  89:     instance: {
  90:         id: number
  91:         incusId: string
  92:         userId: number
  93:         monthlyTrafficUsed: bigint
  94:     },
  95:     client: IncusClient
  96: ): Promise<TrafficDelta | null> {
