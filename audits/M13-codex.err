 364: /**
 365:  * æ‰¹é‡å¢žåŠ å®žä¾‹æµé‡ç”¨é‡
 366:  * ä½¿ç”¨ PostgreSQL çš„ UPDATE ... FROM VALUES è¿›è¡Œé«˜æ•ˆçš„æ‰¹é‡æ›´æ–°
 367:  * æ”¯æŒå¤§è§„æ¨¡å®žä¾‹ï¼ˆ10000+ï¼‰ï¼Œä½¿ç”¨åˆ†ç‰‡å¤„ç†é¿å…äº‹åŠ¡è¿‡å¤§
 368:  */
 369: export async function bulkIncrementInstanceTrafficUsage(
 370:     updates: Array<{ instanceId: number; delta: bigint }>
 371: ) {
 372:     if (updates.length === 0) return
 373: 
 374:     // æŒ‰å®žä¾‹ ID åˆ†ç»„ï¼Œç´¯åŠ åŒä¸€ä¸ªå®žä¾‹çš„å¢žé‡ï¼ˆç†è®ºä¸Šä¸åº”è¯¥å‡ºçŽ°ï¼Œä½†ä¸ºäº†å®‰å…¨ï¼‰
 375:     const instanceDeltas = new Map<number, bigint>()
 376:     for (const { instanceId, delta } of updates) {
 377:         const current = instanceDeltas.get(instanceId) || 0n
 378:         instanceDeltas.set(instanceId, current + delta)
 379:     }
 380: 
 381:     // è½¬æ¢ä¸ºæ•°ç»„å¹¶æŒ‰åˆ†ç‰‡å¤§å°åˆ†æ‰¹å¤„ç†
 382:     const deltasArray = Array.from(instanceDeltas.entries())
 383:     
 384:     // åˆ†æ‰¹å¤„ç†ï¼Œé¿å…å•æ¬¡äº‹åŠ¡è¿‡å¤§
 385:     for (let i = 0; i < deltasArray.length; i += BATCH_SIZE) {
 386:         const batch = deltasArray.slice(i, i + BATCH_SIZE)
 387:         
 388:         // ä½¿ç”¨ PostgreSQL çš„ UPDATE ... FROM VALUES è¯­æ³•è¿›è¡Œæ‰¹é‡æ›´æ–°
 389:         // æž„å»º VALUES å­å¥ï¼ˆéªŒè¯å¹¶æ¸…ç†æ‰€æœ‰å€¼ï¼‰
 390:         const valuesClause = batch
 391:             .map(([instanceId, delta]) => {
 392:                 const instanceIdStr = sanitizeNumber(instanceId)
 393:                 const deltaStr = sanitizeNumber(delta)
 394:                 return `(${instanceIdStr}, ${deltaStr})`
 395:             })
 396:             .join(', ')
 397:         
 398:         // ä½¿ç”¨åŽŸç”Ÿ SQL æ‰¹é‡æ›´æ–°
 399:         try {
 400:             await prisma.$executeRawUnsafe(`
 401:                 UPDATE instances AS i
 402:                 SET monthly_traffic_used = i.monthly_traffic_used + v.delta::bigint
 403:                 FROM (VALUES ${valuesClause}) AS v(id, delta)
 404:                 WHERE i.id = v.id
 405:             `)
 406:         } catch (error) {
 407:             console.error(`[Traffic] Failed to bulk increment instance traffic usage (batch ${i}-${i + batch.length}):`, error)
 408:             throw error
 409:         }
 410:     }
 411: }
