 279: /**
 280:  * å¸¦è¶…æ—¶çš„ä»»åŠ¡æ‰§è¡Œï¼ˆå¸¦å®šæ—¶å™¨æ¸…ç†ï¼Œé˜²æ­¢å†…å­˜æ³„æ¼ï¼‰
 281:  */
 282: async function withTimeout<T>(
 283:     promise: Promise<T>,
 284:     timeoutMs: number,
 285:     timeoutMessage: string
 286: ): Promise<T> {
 287:     let timeoutId: ReturnType<typeof setTimeout> | null = null
 288:     
 289:     const timeoutPromise = new Promise<never>((_, reject) => {
 290:         timeoutId = setTimeout(() => reject(new Error(timeoutMessage)), timeoutMs)
 291:     })
 292: 
 293:     try {
 294:         return await Promise.race([promise, timeoutPromise])
 295:     } finally {
 296:         if (timeoutId) clearTimeout(timeoutId)
 297:     }
 298: }
 299: 
 300: /**
 301:  * ä¸»æµé‡é‡‡é›†ä»»åŠ¡
 302:  */
 303: export async function runTrafficJob(): Promise<void> {
 304:     console.log('[Traffic] Starting traffic collection job...')
 305:     const startTime = Date.now()
 306: 
 307:     try {
 308:         // ä½¿ç”¨è¶…æ—¶åŒ…è£…æ•´ä¸ªä»»åŠ¡
 309:         await withTimeout(
 310:             executeTrafficJob(startTime),
 311:             JOB_TIMEOUT_MS,
 312:             `[Traffic] Job timeout after ${JOB_TIMEOUT_MS}ms`
 313:         )
 314:     } catch (error) {
 315:         const duration = Date.now() - startTime
 316:         if (error instanceof Error && error.message.includes('timeout')) {
 317:             console.error(`[Traffic] Job timed out after ${duration}ms`)
 318:         } else {
 319:             console.error('[Traffic] Job failed:', error)
 320:         }
 321:         throw error
 322:     }
 323: }
