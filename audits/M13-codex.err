 274: export async function syncInstanceNetwork(
 275:   client: IncusClient,
 276:   instanceName: string,
 277:   ipv6Config: IPv6Config,
 278:   hostInterface: string,
 279:   restart: boolean = true
 280: ): Promise<void> {
 281:   // 1. èŽ·å–å½“å‰é…ç½®
 282:   const current = await getInstance(client, instanceName) as unknown as {
 283:     config: Record<string, string>
 284:     devices: Record<string, Record<string, string>>
 285:     profiles: string[]
 286:     description?: string
 287:   }
 288: 
 289:   // 2. èŽ·å–å½“å‰å®žä¾‹çš„ IPv4 åœ°å€
 290:   const currentIpv4 = current.devices?.eth0?.['ipv4.address'] || '10.10.1.1'
 291: 
 292:   // 3. æž„å»ºæ–°çš„ IPv6 åœ°å€åˆ—è¡¨
 293:   const allIps = [ipv6Config.primaryIp]
 294:   if (ipv6Config.extraIps && ipv6Config.extraIps.length > 0) {
 295:     allIps.push(...ipv6Config.extraIps)
 296:   }
 297: 
 298:   // 4. æ›´æ–° eth1 è®¾å¤‡é…ç½®
 299:   const devices = { ...current.devices }
 300: 
 301:   if (devices['eth1']) {
 302:     // æ›´æ–°çŽ°æœ‰ eth1
 303:     devices['eth1'] = {
 304:       ...devices['eth1'],
 305:       'ipv6.address': allIps.join(',')
 306:     }
 307: 
 308:     // æ›´æ–°ç½‘æ®µè·¯ç”±
 309:     if (ipv6Config.subnet) {
 310:       devices['eth1']['ipv6.routes'] = ipv6Config.subnet
 311:     } else {
 312:       delete devices['eth1']['ipv6.routes']
 313:     }
 314:   } else {
 315:     const generatedNicMacs = getVmNicMacsForInstanceName(instanceName)
 316:     // åˆ›å»ºæ–°çš„ eth1
 317:     devices['eth1'] = {
 318:       type: 'nic',
 319:       nictype: 'routed',
 320:       parent: hostInterface,
 321:       name: 'eth1',
 322:       hwaddr: generatedNicMacs.eth1,
 323:       'ipv6.address': allIps.join(',')
 324:       // æ³¨æ„: security.ipv6_filtering å’Œ security.mac_filtering åªæ”¯æŒ bridged æ¨¡å¼
 325:     }
 326: 
 327:     if (ipv6Config.subnet) {
 328:       devices['eth1']['ipv6.routes'] = ipv6Config.subnet
 329:     }
 330:   }
 331: 
 332:   // 5. æ›´æ–° cloud-init network-config
 333:   const config = { ...current.config }
 334:   const nicMacs = {
 335:     eth0: current.devices?.eth0?.hwaddr || getVmNicMacsForInstanceName(instanceName).eth0,
 336:     eth1: devices['eth1']?.hwaddr || current.devices?.eth1?.hwaddr || getVmNicMacsForInstanceName(instanceName).eth1
 337:   }
 338:   config['user.network-config'] = generateCloudInitNetworkConfig({
 339:     ipv4Address: currentIpv4,
 340:     ipv6List: allIps,
 341:     nicMacs
 342:   })
 343: 
 344:   // 6. å‘é€æ›´æ–°è¯·æ±‚ (PUT å…¨é‡æ›¿æ¢)
 345:   await client.request('PUT', `/1.0/instances/${instanceName}`, {
 346:     config,
 347:     devices,
 348:     profiles: current.profiles,
 349:     description: current.description || ''
 350:   })
 351: 
 352:   // 7. é‡å¯å®žä¾‹ä½¿é…ç½®ç”Ÿæ•ˆ
 353:   if (restart) {
 354:     try {
 355:       await restartInstance(client, instanceName, false)
 356:     } catch (err) {
 357:       console.warn(`[syncInstanceNetwork] é‡å¯å®žä¾‹ ${instanceName} å¤±è´¥:`, err)
 358:     }
 359:   }
 360: }
 361: 
 362: /**
