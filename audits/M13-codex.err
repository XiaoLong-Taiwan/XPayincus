 375:   }
 376: 
 377:   // èŽ·å–å½“å‰å®žä¾‹çš„ IPv4 åœ°å€
 378:   const currentIpv4 = current.devices?.eth0?.['ipv4.address'] || '10.10.1.1'
 379: 
 380:   // ç§»é™¤ eth1
 381:   const devices = { ...current.devices }
 382:   delete devices['eth1']
 383: 
 384:   // æ›´æ–° network-configï¼Œä¿ç•™ IPv4 é…ç½®ï¼Œç§»é™¤ IPv6
 385:   const config = { ...current.config }
 386:   const nicMacs = {
 387:     eth0: current.devices?.eth0?.hwaddr || getVmNicMacsForInstanceName(instanceName).eth0
 388:   }
 389:   config['user.network-config'] = generateCloudInitNetworkConfig({
 390:     ipv4Address: currentIpv4,
 391:     nicMacs
 392:     // ä¸ä¼  ipv6Listï¼Œä»…ç”Ÿæˆ eth0 é…ç½®
 393:   })
 394: 
 395:   await client.request('PUT', `/1.0/instances/${instanceName}`, {
 396:     config,
 397:     devices,
 398:     profiles: current.profiles,
 399:     description: current.description || ''
 400:   })
 401: 
 402:   if (restart) {
 403:     try {
 404:       await restartInstance(client, instanceName, false)
 405:     } catch (err) {
 406:       console.warn(`[removeInstanceIpv6] é‡å¯å®žä¾‹ ${instanceName} å¤±è´¥:`, err)
 407:     }
 408:   }
 409: }
