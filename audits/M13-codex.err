  22: import { parseNullablePostgresBigIntInput } from '../lib/bigint-input.js'
  23: import { getExchangeOperationLock } from '../services/exchange-operation-lock.js'
  24: 
  25: /**
  26:  * BigInt åºåˆ—åŒ–ä¸ºå­—ç¬¦ä¸²
  27:  */
  28: function serializeBigInt(value: bigint | null): string | null {
  29:     return value === null ? null : value.toString()
  30: }
  31: 
  32: function parsePositiveId(value: string): number | null {
  33:     if (!/^\d+$/.test(value)) {
  34:         return null
  35:     }
  36: 
  37:     const parsed = Number(value)
  38:     return Number.isSafeInteger(parsed) && parsed > 0 ? parsed : null
  39: }
  40: 
  41: function normalizeMoney(value: number): number {
  42:     return Number(value.toFixed(2))
  43: }
  44: 
  45: function resolveTrafficResetPriceCents(instance: {
  46:     package?: { trafficResetPrice: unknown } | null
  47:     packagePlan?: { trafficResetPrice: unknown } | null
  48: }): number {
  49:     const planPrice = instance.packagePlan?.trafficResetPrice
  50:     if (planPrice !== null && planPrice !== undefined) {
  51:         return Math.max(0, Math.round(Number(planPrice) || 0))
  52:     }
  53:     return Math.max(0, Math.round(Number(instance.package?.trafficResetPrice) || 0))
  54: }
  55: 
  56: /**
  57:  * è®¡ç®—ç™¾åˆ†æ¯”
  58:  * æ³¨æ„: å…ˆè½¬æ¢ä¸º Number å†è®¡ç®—,é¿å… BigInt æ•´æ•°é™¤æ³•ç²¾åº¦ä¸¢å¤±
  59:  * ä¾‹å¦‚: 160MB / 257GB ç”¨ BigInt æ•´æ•°é™¤æ³•ä¼šå¾—åˆ° 0,è€Œéž 0.061%
  60:  */
  61: function calculatePercentage(used: bigint, limit: bigint | null): number {
  62:     if (limit === null || limit === 0n) return 0
  63:     // å…ˆè½¬æ¢ä¸ºæµ®ç‚¹æ•°å†è®¡ç®—ç™¾åˆ†æ¯”,é¿å…æ•´æ•°é™¤æ³•å¯¼è‡´çš„ç²¾åº¦ä¸¢å¤±
  64:     const percentage = (Number(used) / Number(limit)) * 100
  65:     return Math.min(100, percentage)
  66: }
  67: 
  68: export default async function trafficRoutes(fastify: FastifyInstance): Promise<void> {
  69:     // ==================== ç”¨æˆ·æµé‡ API ====================
  70: 
  71:     /**
  72:      * èŽ·å–å½“å‰ç”¨æˆ·çš„æµé‡ç»Ÿè®¡
  73:      */
  74:     fastify.get('/me/traffic', {
  75:         onRequest: [fastify.authenticateUser]
  76:     }, async (request: FastifyRequest, reply: FastifyReply) => {
  77:         const userId = request.user.id
  78: 
  79:         const quota = await trafficDb.getUserTrafficQuota(userId)
  80:         if (!quota) {
  81:             return reply.code(404).send({ error: 'User quota not found' })
  82:         }
  83: 
  84:         const effectiveLimit = quota.monthlyTrafficLimit !== null
  85:             ? quota.monthlyTrafficLimit + quota.extraTrafficQuota
  86:             : null
  87: 
  88:         return {
  89:             monthlyUsed: serializeBigInt(quota.monthlyTrafficUsed),
  90:             monthlyUsedFormatted: formatBytes(quota.monthlyTrafficUsed),
  91:             monthlyLimit: serializeBigInt(effectiveLimit),
  92:             monthlyLimitFormatted: effectiveLimit ? formatBytes(effectiveLimit) : null,
  93:             extraQuota: serializeBigInt(quota.extraTrafficQuota),
  94:             trafficStatus: quota.trafficStatus,
  95:             percentage: calculatePercentage(quota.monthlyTrafficUsed, effectiveLimit)
  96:         }
  97:     })
  98: 
  99:     /**
 100:      * èŽ·å–æŒ‡å®šç”¨æˆ·çš„æµé‡ç»Ÿè®¡ï¼ˆç®¡ç†å‘˜ï¼‰
 101:      */
 102:     fastify.get<{ Params: { userId: string } }>('/users/:userId/traffic', {
 103:         onRequest: [fastify.authenticateAdmin]
 104:     }, async (request: FastifyRequest<{ Params: { userId: string } }>, reply: FastifyReply) => {
 105:         const userId = parsePositiveId(request.params.userId)
 106:         if (userId === null) {
 107:             return reply.code(400).send({ error: 'Invalid user ID' })
 108:         }
 109: 
 110:         const quota = await trafficDb.getUserTrafficQuota(userId)
 111:         if (!quota) {
 112:             return reply.code(404).send({ error: 'User quota not found' })
 113:         }
 114: 
 115:         const effectiveLimit = quota.monthlyTrafficLimit !== null
 116:             ? quota.monthlyTrafficLimit + quota.extraTrafficQuota
 117:             : null
 118: 
 119:         return {
 120:             monthlyUsed: serializeBigInt(quota.monthlyTrafficUsed),
 121:             monthlyUsedFormatted: formatBytes(quota.monthlyTrafficUsed),
 122:             monthlyLimit: serializeBigInt(effectiveLimit),
 123:             monthlyLimitFormatted: effectiveLimit ? formatBytes(effectiveLimit) : null,
 124:             extraQuota: serializeBigInt(quota.extraTrafficQuota),
 125:             trafficStatus: quota.trafficStatus,
