 200: 
 201:     // éšæœºé€‰æ‹©ä¸€ä¸ªå­ç½‘ç´¢å¼•
 202:     let subnetIndex: bigint
 203:     if (maxSubnets > BigInt(Number.MAX_SAFE_INTEGER)) {
 204:         const bytes = randomBytes(8)
 205:         subnetIndex = BigInt('0x' + bytes.toString('hex')) % maxSubnets
 206:     } else {
 207:         subnetIndex = BigInt(Math.floor(Math.random() * Number(maxSubnets)))
 208:     }
