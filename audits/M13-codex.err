 413: /**
 414:  * å¢žåŠ ç”¨æˆ·æµé‡ç”¨é‡
 415:  */
 416: export async function incrementUserTrafficUsage(userId: number, delta: bigint) {
 417:     return prisma.userQuota.update({
 418:         where: { userId },
 419:         data: {
 420:             monthlyTrafficUsed: { increment: delta }
 421:         }
 422:     })
 423: }
 424: 
 425: /**
 426:  * æ‰¹é‡å¢žåŠ ç”¨æˆ·æµé‡ç”¨é‡
 427:  * ä½¿ç”¨ PostgreSQL çš„ UPDATE ... FROM VALUES è¿›è¡Œé«˜æ•ˆçš„æ‰¹é‡æ›´æ–°
 428:  * æ”¯æŒå¤§è§„æ¨¡ç”¨æˆ·ï¼ˆ10000+ï¼‰ï¼Œä½¿ç”¨åˆ†ç‰‡å¤„ç†é¿å…äº‹åŠ¡è¿‡å¤§
 429:  */
 430: export async function bulkIncrementUserTrafficUsage(
 431:     updates: Array<{ userId: number; delta: bigint }>
 432: ) {
 433:     if (updates.length === 0) return
 434: 
 435:     // æŒ‰ç”¨æˆ· ID åˆ†ç»„ï¼Œç´¯åŠ åŒä¸€ä¸ªç”¨æˆ·çš„å¢žé‡
 436:     const userDeltas = new Map<number, bigint>()
 437:     for (const { userId, delta } of updates) {
 438:         const current = userDeltas.get(userId) || 0n
 439:         userDeltas.set(userId, current + delta)
 440:     }
 441: 
 442:     // è½¬æ¢ä¸ºæ•°ç»„å¹¶æŒ‰åˆ†ç‰‡å¤§å°åˆ†æ‰¹å¤„ç†
 443:     const deltasArray = Array.from(userDeltas.entries())
 444:     
 445:     // åˆ†æ‰¹å¤„ç†ï¼Œé¿å…å•æ¬¡äº‹åŠ¡è¿‡å¤§
 446:     for (let i = 0; i < deltasArray.length; i += BATCH_SIZE) {
 447:         const batch = deltasArray.slice(i, i + BATCH_SIZE)
 448:         
 449:         // ä½¿ç”¨ PostgreSQL çš„ UPDATE ... FROM VALUES è¯­æ³•è¿›è¡Œæ‰¹é‡æ›´æ–°
 450:         // æž„å»º VALUES å­å¥ï¼ˆéªŒè¯å¹¶æ¸…ç†æ‰€æœ‰å€¼ï¼‰
 451:         const valuesClause = batch
 452:             .map(([userId, delta]) => {
 453:                 const userIdStr = sanitizeNumber(userId)
 454:                 const deltaStr = sanitizeNumber(delta)
 455:                 return `(${userIdStr}, ${deltaStr})`
 456:             })
 457:             .join(', ')
 458:         
 459:         // ä½¿ç”¨åŽŸç”Ÿ SQL æ‰¹é‡æ›´æ–°
 460:         try {
 461:             await prisma.$executeRawUnsafe(`
 462:                 UPDATE user_quotas AS uq
 463:                 SET monthly_traffic_used = uq.monthly_traffic_used + v.delta::bigint
 464:                 FROM (VALUES ${valuesClause}) AS v(user_id, delta)
 465:                 WHERE uq.user_id = v.user_id
 466:             `)
 467:         } catch (error) {
 468:             console.error(`[Traffic] Failed to bulk increment user traffic usage (batch ${i}-${i + batch.length}):`, error)
 469:             throw error
 470:         }
 471:     }
 472: }
