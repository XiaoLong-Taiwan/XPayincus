 130:     /**
 131:      * æ›´æ–°ç”¨æˆ·æµé‡é™é¢ï¼ˆç®¡ç†å‘˜ï¼‰
 132:      */
 133:     fastify.put<{
 134:         Params: { userId: string }
 135:         Body: { monthlyLimit: unknown }
