  88: /**
  89:  * è§£æžå­—èŠ‚å­—ç¬¦ä¸²ä¸º BigInt
  90:  * æ”¯æŒæ ¼å¼: "100GB", "1.5TB", "500MB" ç­‰
  91:  */
  92: export function parseBytes(str: string): bigint {
  93:     const match = str.match(/^([\d.]+)\s*(B|KB|MB|GB|TB)$/i)
  94:     if (!match) {
  95:         throw new Error(`Invalid byte string: ${str}`)
  96:     }
  97: 
  98:     const value = parseFloat(match[1])
  99:     const unit = match[2].toUpperCase()
 100: 
 101:     const multipliers: Record<string, bigint> = {
 102:         'B': 1n,
 103:         'KB': 1024n,
 104:         'MB': 1024n * 1024n,
 105:         'GB': 1024n * 1024n * 1024n,
 106:         'TB': 1024n * 1024n * 1024n * 1024n
 107:     }
 108: 
 109:     return BigInt(Math.floor(value * Number(multipliers[unit])))
 110: }
