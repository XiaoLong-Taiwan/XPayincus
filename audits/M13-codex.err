 120: /**
 121:  * æ£€æŸ¥å¹¶æ‰§è¡Œé™é€Ÿ
 122:  */
 123: async function checkAndThrottle(
 124:     instance: RunningTrafficInstance,
 125:     client: IncusClient
 126: ): Promise<void> {
 127:     const userQuota = instance.user.quota
 128:     if (!userQuota) return
 129: 
 130:     const userEffectiveLimit = getEffectiveLimit(userQuota.monthlyTrafficLimit, userQuota.extraTrafficQuota)
 131:     const instanceLimit = instance.monthlyTrafficLimit
 132: 
 133:     // æ£€æŸ¥ç”¨æˆ·çº§åˆ«é™é¢
 134:     const userOverLimit = isOverLimit(userQuota.monthlyTrafficUsed, userEffectiveLimit)
 135:     // æ£€æŸ¥å®žä¾‹çº§åˆ«é™é¢
 136:     const instanceOverLimit = isOverLimit(instance.monthlyTrafficUsed, instanceLimit)
 137: 
 138:     if (userOverLimit || instanceOverLimit) {
 139:         const remoteThrottled = await isThrottled(client, instance.incusId)
 140: 
 141:         if (instance.trafficStatus !== 'LIMITED' || !remoteThrottled) {
 142:             try {
 143:                 await applyThrottle(client, instance.incusId)
 144:                 const shouldNotifyThrottled = await trafficDb.markInstanceTrafficLimitedIfNeeded(instance.id)
 145:                 if (userOverLimit && userQuota.trafficStatus !== 'LIMITED') {
 146:                     await trafficDb.updateUserTrafficStatus(instance.userId, 'LIMITED')
 147:                 }
 148: 
 149:                 if (shouldNotifyThrottled) {
 150:                     await sendTrafficThrottledNotification(instance.userId, instance.name, instance.host.name)
 151:                 }
 152: 
 153:                 console.log(`[Traffic] Throttled instance ${instance.id} (${instance.incusId})`)
 154:             } catch (error) {
 155:                 console.error(`[Traffic] Failed to throttle instance ${instance.id}:`, error)
 156:             }
 157:         } else if (userOverLimit && userQuota.trafficStatus !== 'LIMITED') {
 158:             await trafficDb.updateUserTrafficStatus(instance.userId, 'LIMITED')
 159:         }
 160:     } else {
 161:         // æ£€æŸ¥é¢„è­¦
 162:         const userWarning = isWarningThreshold(userQuota.monthlyTrafficUsed, userEffectiveLimit)
 163:         if (userWarning && !isWarningSentThisMonth(userQuota.trafficWarningSentAt)) {
 164:             const shouldNotifyWarning = await trafficDb.markUserTrafficWarningIfNeeded(instance.userId, new Date())
 165:             if (shouldNotifyWarning) {
 166:                 await sendTrafficWarningNotification(
 167:                     instance.userId,
 168:                     userQuota.monthlyTrafficUsed,
 169:                     userEffectiveLimit!
 170:                 )
 171:                 console.log(`[Traffic] Sent warning to user ${instance.userId}`)
 172:             }
 173:         }
 174:     }
 175: }
 176: 
 177: /**
 178:  * æ£€æŸ¥å¹¶æ¢å¤å¸¦å®½
 179:  */
 180: async function checkAndRestore(
 181:     instance: RunningTrafficInstance,
 182:     client: IncusClient
 183: ): Promise<void> {
 184:     const userQuota = instance.user.quota
 185:     if (!userQuota) return
 186: 
 187:     const userEffectiveLimit = getEffectiveLimit(userQuota.monthlyTrafficLimit, userQuota.extraTrafficQuota)
 188:     const instanceLimit = instance.monthlyTrafficLimit
 189: 
 190:     const userUnderLimit = !isOverLimit(userQuota.monthlyTrafficUsed, userEffectiveLimit)
 191:     const instanceUnderLimit = !isOverLimit(instance.monthlyTrafficUsed, instanceLimit)
 192:     const desiredUserStatus = calculateUserTrafficStatus(userQuota.monthlyTrafficUsed, userEffectiveLimit)
 193: 
 194:     if (userUnderLimit && instanceUnderLimit) {
 195:         const remoteThrottled = await isThrottled(client, instance.incusId)
 196:         if (instance.trafficStatus !== 'LIMITED' && !remoteThrottled) {
 197:             if (userQuota.trafficStatus !== desiredUserStatus) {
 198:                 await trafficDb.updateUserTrafficStatus(instance.userId, desiredUserStatus)
 199:             }
 200:             return
 201:         }
 202: 
 203:         try {
 204:             const resolvedLimits = resolveTrafficBandwidthLimits(instance, {
 205:                 stripThrottleOverride: remoteThrottled || instance.trafficStatus === 'LIMITED'
 206:             })
 207: 
 208:             await restoreBandwidth(
 209:                 client,
 210:                 instance.incusId,
 211:                 resolvedLimits.incusIngress,
 212:                 resolvedLimits.incusEgress
 213:             )
 214:             await trafficDb.updateInstanceTrafficStatus(instance.id, 'NORMAL')
 215:             await trafficDb.updateInstanceBandwidthLimits(
 216:                 instance.id,
 217:                 resolvedLimits.dbIngress,
 218:                 resolvedLimits.dbEgress
 219:             )
 220: 
 221:             if (userQuota.trafficStatus !== desiredUserStatus) {
 222:                 await trafficDb.updateUserTrafficStatus(instance.userId, desiredUserStatus)
 223:             }
 224: 
 225:             console.log(`[Traffic] Restored bandwidth for instance ${instance.id}`)
 226:         } catch (error) {
 227:             console.error(`[Traffic] Failed to restore bandwidth for instance ${instance.id}:`, error)
 228:         }
 229:     }
 230: }
