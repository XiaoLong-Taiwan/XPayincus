 120: /**
 121:  * æ£€æŸ¥å¹¶æ‰§è¡Œé™é€Ÿ
 122:  */
 123: async function checkAndThrottle(
 124:     instance: RunningTrafficInstance,
 125:     client: IncusClient
 126: ): Promise<void> {
 127:     const userQuota = instance.user.quota
 128:     if (!userQuota) return
 129: 
 130:     const userEffectiveLimit = getEffectiveLimit(userQuota.monthlyTrafficLimit, userQuota.extraTrafficQuota)
 131:     const instanceLimit = instance.monthlyTrafficLimit
 132: 
 133:     // æ£€æŸ¥ç”¨æˆ·çº§åˆ«é™é¢
 134:     const userOverLimit = isOverLimit(userQuota.monthlyTrafficUsed, userEffectiveLimit)
 135:     // æ£€æŸ¥å®žä¾‹çº§åˆ«é™é¢
 136:     const instanceOverLimit = isOverLimit(instance.monthlyTrafficUsed, instanceLimit)
 137: 
 138:     if (userOverLimit || instanceOverLimit) {
 139:         const remoteThrottled = await isThrottled(client, instance.incusId)
 140: 
 141:         if (instance.trafficStatus !== 'LIMITED' || !remoteThrottled) {
 142:             try {
 143:                 await applyThrottle(client, instance.incusId)
 144:                 const shouldNotifyThrottled = await trafficDb.markInstanceTrafficLimitedIfNeeded(instance.id)
 145:                 if (userOverLimit && userQuota.trafficStatus !== 'LIMITED') {
 146:                     await trafficDb.updateUserTrafficStatus(instance.userId, 'LIMITED')
 147:                 }
 148: 
 149:                 if (shouldNotifyThrottled) {
 150:                     await sendTrafficThrottledNotification(instance.userId, instance.name, instance.host.name)
 151:                 }
 152: 
 153:                 console.log(`[Traffic] Throttled instance ${instance.id} (${instance.incusId})`)
 154:             } catch (error) {
 155:                 console.error(`[Traffic] Failed to throttle instance ${instance.id}:`, error)
 156:             }
 157:         } else if (userOverLimit && userQuota.trafficStatus !== 'LIMITED') {
 158:             await trafficDb.updateUserTrafficStatus(instance.userId, 'LIMITED')
 159:         }
 160:     } else {
 161:         // æ£€æŸ¥é¢„è­¦
 162:         const userWarning = isWarningThreshold(userQuota.monthlyTrafficUsed, userEffectiveLimit)
 163:         if (userWarning && !isWarningSentThisMonth(userQuota.trafficWarningSentAt)) {
 164:             const shouldNotifyWarning = await trafficDb.markUserTrafficWarningIfNeeded(instance.userId, new Date())
 165:             if (shouldNotifyWarning) {
 166:                 await sendTrafficWarningNotification(
 167:                     instance.userId,
 168:                     userQuota.monthlyTrafficUsed,
 169:                     userEffectiveLimit!
 170:                 )
 171:                 console.log(`[Traffic] Sent warning to user ${instance.userId}`)
 172:             }
 173:         }
 174:     }
 175: }
