 314: export async function getHostTrafficSummary(hostId: number) {
 315:     // èšåˆèŠ‚ç‚¹ä¸‹æ‰€æœ‰æ´»è·ƒå®žä¾‹çš„æµé‡ä½¿ç”¨å’Œæµé‡é™åˆ¶
 316:     const result = await prisma.instance.aggregate({
