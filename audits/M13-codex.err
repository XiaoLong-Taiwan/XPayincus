 229:      */
 230:     fastify.get<{
 231:         Params: { instanceId: string }
 232:         Querystring: { days?: string }
 233:     }>('/instances/:instanceId/traffic/history', {
 234:         onRequest: [fastify.authenticate]
 235:     }, async (request: FastifyRequest<{
 236:         Params: { instanceId: string }
 237:         Querystring: { days?: string }
 238:     }>, reply: FastifyReply) => {
 239:         const instanceId = parsePositiveId(request.params.instanceId)
 240:         if (instanceId === null) {
