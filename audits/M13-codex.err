 281:  */
 282: async function withTimeout<T>(
 283:     promise: Promise<T>,
 284:     timeoutMs: number,
 285:     timeoutMessage: string
 286: ): Promise<T> {
 287:     let timeoutId: ReturnType<typeof setTimeout> | null = null
 288:     
 289:     const timeoutPromise = new Promise<never>((_, reject) => {
 290:         timeoutId = setTimeout(() => reject(new Error(timeoutMessage)), timeoutMs)
 291:     })
 292: 
 293:     try {
 294:         return await Promise.race([promise, timeoutPromise])
 295:     } finally {
 296:         if (timeoutId) clearTimeout(timeoutId)
 297:     }
 298: }
