 271: /**
 272:  * èŽ·å–èŠ‚ç‚¹çš„æ¯æ—¥æµé‡åŽ†å²ï¼ˆèšåˆè¯¥èŠ‚ç‚¹ä¸‹æ‰€æœ‰å®žä¾‹çš„æµé‡ï¼‰
 273:  * æ ¹æ®èŠ‚ç‚¹çš„ trafficResetDay è®¡ç®—å‘¨æœŸèµ·å§‹æ—¥æœŸ
 274:  * @param hostId èŠ‚ç‚¹ ID
 275:  * @param trafficResetDay æµé‡é‡ç½®æ—¥ï¼ˆé»˜è®¤ 1ï¼‰
 276:  */
 277: export async function getHostDailyTraffic(hostId: number, trafficResetDay: number = 1) {
 278:     // å¯¼å…¥å‘¨æœŸè®¡ç®—å‡½æ•°
 279:     const { getTrafficPeriod } = await import('../services/traffic-utils.js')
 280:     const { periodStart } = getTrafficPeriod(trafficResetDay)
 281: 
 282:     // ä½¿ç”¨åŽŸç”Ÿ SQL è¿›è¡ŒèšåˆæŸ¥è¯¢
 283:     // æŒ‰æ—¥æœŸåˆ†ç»„ï¼ŒèšåˆèŠ‚ç‚¹ä¸‹æ‰€æœ‰å½“å‰å­˜åœ¨çš„å®žä¾‹çš„æµé‡
 284:     // æ³¨æ„ï¼šSUM() è¿”å›ž numeric ç±»åž‹ï¼Œå¿…é¡»æ˜¾å¼è½¬æ¢ä¸º bigintï¼Œå¦åˆ™ Prisma è¿”å›ž Decimal å¯¹è±¡
 285:     const result = await prisma.$queryRaw<Array<{
 286:         date: Date
 287:         rx_total: bigint
 288:         tx_total: bigint
 289:     }>>`
 290:         SELECT 
 291:             dt.date,
 292:             COALESCE(SUM(dt.rx_total), 0)::bigint as rx_total,
 293:             COALESCE(SUM(dt.tx_total), 0)::bigint as tx_total
 294:         FROM daily_traffic dt
 295:         INNER JOIN instances i ON dt.instance_id = i.id
 296:         WHERE i.host_id = ${hostId}
 297:           AND i.status != 'deleted'
 298:           AND dt.date >= ${periodStart}
 299:         GROUP BY dt.date
 300:         ORDER BY dt.date ASC
 301:     `
 302: 
 303:     return result.map(row => ({
 304:         date: row.date,
 305:         rxTotal: row.rx_total,
 306:         txTotal: row.tx_total
 307:     }))
 308: }
