 202: /**
 203:  * åœ¨å®žä¾‹çº§é”å†…å®Œæˆä¸€æ¬¡å®Œæ•´çš„æµé‡é‡‡é›†ä¸ŽåŸºçº¿æäº¤ã€‚
 204:  * è¿™ä¼šä¸²è¡ŒåŒ–åŒä¸€å®žä¾‹ä¸Šçš„å³æ—¶é‡‡é›†ä¸Žå®šæ—¶é‡‡é›†ï¼Œé¿å…è¯»å–åŒä¸€æ—§åŸºçº¿å¯¼è‡´é‡å¤è®°è´¦ã€‚
 205:  */
 206: export async function collectTrafficForInstanceWithClient(
 207:   input: CollectTrafficWithClientInput,
 208:   lockOptions: LockOptions = {}
 209: ): Promise<CollectInstanceTrafficResult> {
 210:   const { instanceId, userId, incusId, client, currentUsage = 0n } = input
 211:   const lockKey = getTrafficLockKey(instanceId)
 212:   const effectiveLockOptions = { ...DEFAULT_TRAFFIC_LOCK_OPTIONS, ...lockOptions }
 213:   const lockResult = await acquireLock(lockKey, effectiveLockOptions)
 214: 
 215:   if (!lockResult.success || !lockResult.ownerId) {
 216:     return {
 217:       success: false,
 218:       skipped: false,
 219:       totalDelta: 0n,
 220:       currentUsage,
 221:       error: lockResult.error || 'æµé‡é‡‡é›†é”èŽ·å–å¤±è´¥'
 222:     }
 223:   }
 224: 
 225:   const renewIntervalMs = Math.max(1000, Math.floor((effectiveLockOptions.expireMs || DEFAULT_TRAFFIC_LOCK_OPTIONS.expireMs || 30000) / 3))
 226:   let renewTimer: ReturnType<typeof setInterval> | null = null
 227: 
 228:   try {
 229:     renewTimer = setInterval(() => {
 230:       extendLock(lockKey, lockResult.ownerId!, effectiveLockOptions.expireMs).catch((error) => {
 231:         console.warn(`[Traffic] Failed to extend lock ${lockKey}:`, error)
 232:       })
 233:     }, renewIntervalMs)
 234: 
 235:     const counters = await getTrafficCounters(client, incusId)
 236:     const result = await applyTrafficCounters(instanceId, userId, counters)
 237: 
 238:     return {
 239:       success: true,
 240:       skipped: result.skipped,
 241:       totalDelta: result.totalDelta,
 242:       currentUsage: result.currentUsage
 243:     }
 244:   } catch (error) {
 245:     return {
 246:       success: false,
 247:       skipped: false,
 248:       totalDelta: 0n,
 249:       currentUsage,
 250:       error: error instanceof Error ? error.message : String(error)
 251:     }
 252:   } finally {
 253:     if (renewTimer) clearInterval(renewTimer)
 254:     await releaseLock(lockKey, lockResult.ownerId)
 255:   }
 256: }
