  15: // é‡è¯•é…ç½®
  16: const MAX_RETRIES = 3
  17: const RETRY_DELAY_MS = 2000
  18: const TRAFFIC_NOTIFICATION_FETCH_TIMEOUT_MS = 15_000
  19: const TRAFFIC_NOTIFICATION_ERROR_PREVIEW_MAX_CHARS = 2_000
  20: 
  21: /**
  22:  * å»¶è¿Ÿå‡½æ•°
  23:  */
  24: function delay(ms: number): Promise<void> {
  25:     return new Promise(resolve => setTimeout(resolve, ms))
  26: }
  27: 
  28: /**
  29:  * åˆ¤æ–­æ˜¯å¦ä¸ºä¸å¯é‡è¯•çš„é”™è¯¯
  30:  */
  31: function isNonRetryableError(error: string | null): boolean {
  32:     if (!error) return false
  33: 
  34:     const nonRetryablePatterns = [
  35:         'Missing botToken',
  36:         'Missing chatId',
  37:         'Missing webhookUrl',
  38:         'chat not found',
  39:         'bot was blocked',
  40:         'CHAT_ID_INVALID',
  41:         'BOT_TOKEN_INVALID',
  42:         '401',
  43:         '403',
  44:         '404',
  45:     ]
  46: 
  47:     return nonRetryablePatterns.some(pattern =>
  48:         error.toLowerCase().includes(pattern.toLowerCase())
  49:     )
  50: }
  51: 
  52: async function readSafeNotificationError(response: Response): Promise<string> {
  53:     const text = await response.text()
  54:     const sanitized = sanitizeTokensInString(text)
  55:     const preview = sanitized.slice(0, TRAFFIC_NOTIFICATION_ERROR_PREVIEW_MAX_CHARS)
  56:     return preview || `HTTP ${response.status}`
  57: }
  58: 
  59: /**
  60:  * å¸¦é‡è¯•çš„å‘é€å‡½æ•°
  61:  */
  62: async function sendWithRetry(
  63:     sendFn: () => Promise<{ success: boolean; error: string | null }>,
  64:     channelType: string
  65: ): Promise<{ success: boolean; error: string | null }> {
  66:     let lastError: string | null = null
  67: 
  68:     for (let attempt = 1; attempt <= MAX_RETRIES; attempt++) {
  69:         try {
  70:             const result = await sendFn()
  71: 
  72:             if (result.success) {
  73:                 return result
  74:             }
  75: 
  76:             if (isNonRetryableError(result.error)) {
  77:                 return result
  78:             }
  79: 
  80:             lastError = result.error
  81:             console.warn(`[TrafficNotifier] ${channelType} attempt ${attempt}/${MAX_RETRIES} failed: ${result.error}`)
  82: 
  83:             if (attempt < MAX_RETRIES) {
  84:                 await delay(RETRY_DELAY_MS * attempt)
  85:             }
  86:         } catch (err) {
  87:             lastError = err instanceof Error ? err.message : String(err)
  88:             console.warn(`[TrafficNotifier] ${channelType} attempt ${attempt}/${MAX_RETRIES} error: ${lastError}`)
  89: 
  90:             if (attempt < MAX_RETRIES) {
  91:                 await delay(RETRY_DELAY_MS * attempt)
  92:             }
  93:         }
  94:     }
  95: 
  96:     return { success: false, error: `Failed after ${MAX_RETRIES} attempts: ${lastError}` }
  97: }
