  70: /**
  71:  * æ›´æ–°æˆ–åˆ›å»ºæµé‡å¿«ç…§
  72:  */
  73: export async function upsertTrafficSnapshot(
  74:     instanceId: number,
  75:     rxRaw: bigint,
  76:     txRaw: bigint
  77: ) {
  78:     return prisma.trafficSnapshot.upsert({
  79:         where: { instanceId },
  80:         update: { rxRaw, txRaw },
  81:         create: { instanceId, rxRaw, txRaw }
  82:     })
  83: }
