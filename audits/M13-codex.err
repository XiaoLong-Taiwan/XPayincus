 225:  * @deprecated ä½¿ç”¨ generateCloudInitNetworkConfig æ›¿ä»£
 226:  */
 227: export function generateCloudInitNetworkConfigLegacy(ipv6List: string[]): string {
 228:   if (!ipv6List || ipv6List.length === 0) {
 229:     // æ—  IPv6ï¼Œä»…é…ç½® eth0 DHCP
 230:     return `version: 2
 231: ethernets:
 232:   eth0:
 233:     dhcp4: true
 234: `
 235:   }
 236: 
 237:   // æ ¼å¼åŒ– IPv6 åœ°å€ (æ·»åŠ  /128 æŽ©ç )
 238:   const formattedAddresses = ipv6List
 239:     .filter(ip => ip && ip.trim())
 240:     .map(ip => {
 241:       const trimmed = ip.trim()
 242:       // å¦‚æžœå·²æœ‰æŽ©ç åˆ™ä¸æ·»åŠ 
 243:       return trimmed.includes('/') ? trimmed : `${trimmed}/128`
 244:     })
 245: 
 246:   const addressesYaml = formattedAddresses
 247:     .map(addr => `      - ${addr}`)
 248:     .join('\n')
 249: 
 250:   return `version: 2
 251: ethernets:
 252:   eth0:
 253:     dhcp4: true
 254:   eth1:
 255:     dhcp4: false
 256:     dhcp6: false
 257:     addresses:
 258: ${addressesYaml}
 259:     gateway6: fe80::1
 260: `
 261: }
