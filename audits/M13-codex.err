 248: 
 249:         // æƒé™æ£€æŸ¥ï¼šç®¡ç†å‘˜ã€å®žä¾‹æ‰€æœ‰è€…æˆ–å®¿ä¸»æœºæ‰€æœ‰è€…å¯ä»¥æŸ¥çœ‹
 250:         let host: Awaited<ReturnType<typeof db.getHostById>> = null
 251:         // 1. ç®¡ç†å‘˜æœ‰æƒé™
 252:         if (request.user.role === 'admin') {
 253:             // ç»§ç»­æ‰§è¡Œ
 254:         } else if (instance.userId === request.user.id) {
 255:             // 2. å®žä¾‹æ‰€æœ‰è€…æœ‰æƒé™
 256:         } else {
 257:             // 3. æ£€æŸ¥æ˜¯å¦æ˜¯å®¿ä¸»æœºæ‰€æœ‰è€…
 258:             if (instance.hostId) {
 259:                 host = await db.getHostById(instance.hostId)
 260:                 if (!host || host.user_id !== request.user.id) {
 261:                     return reply.code(403).send({ error: 'Access denied' })
 262:                 }
 263:             } else {
 264:                 return reply.code(403).send({ error: 'Access denied' })
 265:             }
 266:         }
 267: 
 268:         // èŽ·å–èŠ‚ç‚¹çš„æµé‡é‡ç½®æ—¥é…ç½®ï¼Œç”¨äºŽè®¡ç®—å‘¨æœŸ
 269:         if (!host && instance.hostId) {
 270:             host = await db.getHostById(instance.hostId)
 271:         }
 272:         const trafficResetDay = host?.traffic_reset_day ?? 1
 273:         const { periodStart, periodEnd } = getTrafficPeriod(trafficResetDay)
 274: 
 275:         // æŒ‰å‘¨æœŸèŽ·å–åŽ†å²æ•°æ®
