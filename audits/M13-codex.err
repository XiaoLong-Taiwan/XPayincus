 242: export async function getDailyTraffic(instanceId: number, days: number = 30) {
 243:     const startDate = new Date()
 244:     startDate.setDate(startDate.getDate() - days)
 245:     startDate.setHours(0, 0, 0, 0)
 246: 
 247:     return prisma.dailyTraffic.findMany({
