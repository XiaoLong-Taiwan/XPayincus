  45:   const normalizedDate = new Date(now.getFullYear(), now.getMonth(), now.getDate())
  46: 
  47:   const userLockResult = await withLock(getUserTrafficLockKey(userId), async () => prisma.$transaction(async (tx) => {
  48:     const instance = await tx.instance.findUnique({
  49:       where: { id: instanceId },
  50:       select: {
  51:         monthlyTrafficUsed: true,
  52:         status: true,
  53:         hostId: true
  54:       }
  55:     })
  56: 
  57:     if (!instance) {
  58:       throw new Error('å®žä¾‹ä¸å­˜åœ¨')
  59:     }
  60: 
  61:     if (instance.status !== 'running') {
  62:       return {
  63:         totalDelta: 0n,
  64:         currentUsage: instance.monthlyTrafficUsed,
  65:         skipped: true
  66:       }
  67:     }
  68: 
  69:     const latestSnapshot = await tx.trafficSnapshot.findUnique({
  70:       where: { instanceId }
  71:     })
  72: 
  73:     const rxIncrement = latestSnapshot
  74:       ? calculateIncrement(counters.rxBytes, latestSnapshot.rxRaw)
  75:       : 0n
  76:     const txIncrement = latestSnapshot
  77:       ? calculateIncrement(counters.txBytes, latestSnapshot.txRaw)
  78:       : 0n
  79:     const rxPacketIncrement = latestSnapshot
  80:       ? calculateIncrement(counters.rxPackets, latestSnapshot.rxPacketsRaw)
  81:       : 0n
  82:     const txPacketIncrement = latestSnapshot
  83:       ? calculateIncrement(counters.txPackets, latestSnapshot.txPacketsRaw)
  84:       : 0n
  85:     const totalDelta = rxIncrement + txIncrement
  86:     const totalPacketDelta = rxPacketIncrement + txPacketIncrement
  87: 
  88:     const elapsedSeconds = latestSnapshot
  89:       ? Math.max(1, (counters.sampledAt.getTime() - latestSnapshot.updatedAt.getTime()) / 1000)
  90:       : 0
  91:     const cpuUsageDelta = latestSnapshot?.cpuUsageRaw !== null && latestSnapshot?.cpuUsageRaw !== undefined && counters.cpuUsageRaw !== null
  92:       ? calculateIncrement(counters.cpuUsageRaw, latestSnapshot.cpuUsageRaw)
  93:       : 0n
  94:     const cpuPercent = elapsedSeconds > 0 && cpuUsageDelta > 0n
  95:       ? Math.min(1000, Number(cpuUsageDelta) / (elapsedSeconds * 1_000_000_000) * 100)
  96:       : null
  97: 
  98:     await tx.trafficSnapshot.upsert({
