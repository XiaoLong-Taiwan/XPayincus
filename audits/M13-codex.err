 312:     }
 313:   }
 314: 
 315:   if (!instance.host.certPath || !instance.host.keyPath) {
 316:     return {
 317:       success: false,
 318:       skipped: false,
 319:       totalDelta: 0n,
 320:       currentUsage: instance.monthlyTrafficUsed,
 321:       error: 'å®¿ä¸»æœºè¯ä¹¦æœªé…ç½®ï¼Œæ— æ³•ç«‹å³é‡‡é›†æµé‡'
 322:     }
