  44:   1,
  45:   'IPv6 subnet route parameters must use strict positive ID parsing'
  46: )
  47: 
  48: for (const forbiddenPattern of [
  49:   'parseInt(request.params.instanceId',
  50:   'parseInt(request.params.ipId',
  51:   'parseInt(request.params.subnetId',
  52:   'isNaN(instanceId)',
  53:   'isNaN(ipId)',
  54:   'isNaN(subnetId)'
  55: ] as const) {
  56:   assert.ok(
  57:     !source.includes(forbiddenPattern),
  58:     `IP address routes must not use loose path ID parsing: ${forbiddenPattern}`
  59:   )
  60: }
