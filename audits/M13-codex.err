 172: export function generateCloudInitNetworkConfig(options: CloudInitNetworkOptions): string {
 173:   const { ipv4Address, ipv6List } = options
 174:   const { gateway } = IPV4_CONFIG
 175: 
 176:   // eth0: é™æ€ IPv4 é…ç½®
 177:   let config = `version: 2
 178: ethernets:
 179:   eth0:
 180:     dhcp4: false
 181:     dhcp6: false
 182:     accept-ra: false
 183:     addresses:
 184:       - ${ipv4Address}/22
 185:     routes:
 186:       - to: 0.0.0.0/0
 187:         via: ${gateway}
 188:     nameservers:
 189:       addresses:
 190:         - 10.10.0.1
 191: `
 192: 
 193:   // eth1: é™æ€ IPv6 é…ç½® (å¦‚æžœæœ‰)
 194:   if (ipv6List && ipv6List.length > 0) {
 195:     // æ ¼å¼åŒ– IPv6 åœ°å€ (æ·»åŠ  /128 æŽ©ç )
 196:     const formattedAddresses = ipv6List
 197:       .filter(ip => ip && ip.trim())
 198:       .map(ip => {
 199:         const trimmed = ip.trim()
 200:         return trimmed.includes('/') ? trimmed : `${trimmed}/128`
 201:       })
 202: 
 203:     const addressesYaml = formattedAddresses
 204:       .map(addr => `      - ${addr}`)
 205:       .join('\n')
 206: 
 207:     config += `  eth1:
 208:     dhcp4: false
 209:     dhcp6: false
 210:     accept-ra: false
 211:     addresses:
 212: ${addressesYaml}
 213:     gateway6: fe80::1
 214:     nameservers:
 215:       addresses:
 216:         - 10.10.0.1
 217: `
 218:   }
 219: 
 220:   return config
 221: }
