   1: import { isIP } from 'net'
   2: 
   3: export type DnsRecordType = 'A' | 'AAAA' | 'CNAME'
   4: 
   5: export function normalizeNetworkHost(value: string): string {
   6:   const trimmed = value.trim()
   7: 
   8:   if (trimmed.startsWith('[') && trimmed.endsWith(']')) {
   9:     const inner = trimmed.slice(1, -1).trim()
  10:     if (inner.includes(':')) {
  11:       return inner
  12:     }
  13:   }
  14: 
  15:   return trimmed
  16: }
  17: 
  18: export function getAddressFamily(value: string): 0 | 4 | 6 {
  19:   return isIP(normalizeNetworkHost(value)) as 0 | 4 | 6
  20: }
  21: 
  22: export function isIpLiteral(value: string): boolean {
  23:   return getAddressFamily(value) !== 0
  24: }
  25: 
  26: export function formatHostForUrl(value: string): string {
  27:   const normalized = normalizeNetworkHost(value)
  28:   return getAddressFamily(normalized) === 6 ? `[${normalized}]` : normalized
  29: }
  30: 
  31: export function formatHostForListen(value: string): string {
  32:   return formatHostForUrl(value)
  33: }
  34: 
  35: export function extractHostAddressFromUrl(value: string | null | undefined): string | null {
  36:   if (!value) return null
  37:   try {
  38:     const url = new URL(value)
  39:     return normalizeNetworkHost(url.hostname)
  40:   } catch {
  41:     return null
  42:   }
  43: }
  44: 
  45: export function selectBindableIpv4ListenAddress(
  46:   explicitBindIpv4: string | null | undefined,
  47:   fallbackPublicIpv4: string | null | undefined,
  48:   _hostUrl: string | null | undefined,
  49:   hostIpAddress: string | null | undefined
  50: ): string {
  51:   const explicit = explicitBindIpv4 ? normalizeNetworkHost(explicitBindIpv4) : ''
  52:   if (getAddressFamily(explicit) === 4) {
  53:     return explicit
  54:   }
  55: 
  56:   const localCandidates = new Set<string>()
  57:   const normalizedHostIpAddress = hostIpAddress ? normalizeNetworkHost(hostIpAddress) : null
  58:   const fallback = fallbackPublicIpv4 ? normalizeNetworkHost(fallbackPublicIpv4) : ''
  59: 
  60:   if (getAddressFamily(fallback) !== 4) {
  61:     return '0.0.0.0'
  62:   }
  63: 
  64:   if (normalizedHostIpAddress && getAddressFamily(normalizedHostIpAddress) === 4) {
  65:     localCandidates.add(normalizedHostIpAddress)
  66:   }
  67: 
  68:   return localCandidates.has(fallback) ? fallback : '0.0.0.0'
  69: }
