   42: function clampInboxPagination(page: number | undefined, pageSize: number | undefined): {
   43:   page: number
   44:   pageSize: number
   45: } {
   46:   return {
   47:     page: Number.isInteger(page) && page !== undefined && page > 0 ? page : 1,
   48:     pageSize: Number.isInteger(pageSize) && pageSize !== undefined
   49:       ? Math.min(Math.max(pageSize, 1), 100)
   50:       : 20
   51:   }
   52: }
