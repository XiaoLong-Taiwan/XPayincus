  597:       }
  598:       break
  599:     case 'webhook':
  600:       if (masked.secret) {
  601:         masked.secret = '***å·²è®¾ç½®***'
  602:       }
  603:       break
  604:   }
  605: 
  606:   return masked
  607: }

