  241:   /**
  242:    * èŠ‚ç‚¹æ‰€æœ‰è€…é€šçŸ¥å®žä¾‹ç”¨æˆ·ï¼ˆç«™å†…ä¿¡ï¼Œå¯é€‰é™„å¸¦é‚®ä»¶ï¼‰
  243:    */
  244:   fastify.post<{
  245:     Params: { hostId: string }
  246:     Body: {
  247:       title: string
  248:       content: string
  249:       instanceIds?: number[]
  250:       sendEmail?: boolean
  251:     }
  252:   }>('/hosts/:hostId/notify', {
  253:     schema: {
  254:       body: {
  255:         type: 'object',
  256:         required: ['title', 'content'],
  257:         properties: {
  258:           title: { type: 'string', minLength: 1, maxLength: 200 },
  259:           content: { type: 'string', minLength: 1, maxLength: 5000 },
  260:           instanceIds: {
  261:             type: 'array',
  262:             items: { type: 'integer', minimum: 1 },
  263:             minItems: 1,
  264:             maxItems: 100
  265:           },
  266:           sendEmail: { type: 'boolean' }
  267:         }
  268:       }
  269:     }
  270:   }, async (request: FastifyRequest<{
  271:     Params: { hostId: string }
  272:     Body: {
  273:       title: string
  274:       content: string
  275:       instanceIds?: number[]
  276:       sendEmail?: boolean
  277:     }
  278:   }>, reply: FastifyReply) => {
  279:     const hostId = parsePositiveId(request.params.hostId)
  280:     const userId = request.user.id
  281:     const { instanceIds, sendEmail = false } = request.body
  282: 
  283:     if (hostId === null) {
  284:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
  285:     }
  286:     const normalizedInstanceIds = parsePositiveIdArray(instanceIds)
  287:     if (normalizedInstanceIds === null) {
  288:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
  289:     }
  290: 
  291:     // æ£€æŸ¥èŠ‚ç‚¹æ˜¯å¦å­˜åœ¨
  292:     const host = await db.getHostById(hostId)
  293:     if (!host) {
  294:       return reply.code(404).send(apiError(ErrorCode.HOST_NOT_FOUND))
  295:     }
  296: 
  297:     // æ£€æŸ¥æ˜¯å¦æ˜¯èŠ‚ç‚¹æ‰€æœ‰è€…æˆ–ç®¡ç†å‘˜
  298:     if (host.user_id !== userId && request.user.role !== 'admin') {
  299:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
  300:     }
  301: 
  302:     const messageInput = normalizeInboxMessageInput(request.body)
  303:     if ('error' in messageInput) {
  304:       return reply.code(400).send(messageInput.error)
  305:     }
  306: 
  307:     const trimmedTitle = messageInput.title
  308:     const trimmedContent = messageInput.content
  309: 
  310:     // èŽ·å–ç›®æ ‡ç”¨æˆ·ï¼ˆåŽ»é‡ï¼‰ï¼šå¦‚æžœæŒ‡å®šäº† instanceIds åˆ™åªé€šçŸ¥è¿™äº›å®žä¾‹çš„ç”¨æˆ·ï¼Œå¦åˆ™é€šçŸ¥å…¨éƒ¨
  311:     const recipients = await inboxDb.getUniqueRecipientsByHostId(hostId, normalizedInstanceIds)
  312:     const userIds = recipients.map(recipient => recipient.userId)
  313:     const emailRecipients = sendEmail
  314:       ? recipients.filter(recipient => typeof recipient.email === 'string' && recipient.email.trim().length > 0)
  315:       : []
  316: 
  317:     if (sendEmail && emailRecipients.length > 0) {
  318:       const smtpEnabled = await isSmtpEnabled()
  319:       if (!smtpEnabled) {
  320:         return reply.code(400).send({
  321:           error: 'SMTP_NOT_CONFIGURED',
  322:           message: 'SMTP is not configured'
  323:         })
  324:       }
  325:     }
  326: 
  327:     if (userIds.length === 0) {
  328:       return {
  329:         success: true,
  330:         count: 0,
  331:         ...(sendEmail ? {
  332:           email: {
  333:             requested: true,
  334:             mode: 'none',
  335:             sentCount: 0,
  336:             queuedCount: 0,
  337:             skippedCount: 0,
  338:             failedCount: 0
  339:           }
  340:         } : {})
  341:       }
  342:     }
  343: 
  344:     // æž„å»ºå¸¦èŠ‚ç‚¹ç½²åçš„æ¶ˆæ¯å†…å®¹
  345:     const messageContent = `${trimmedContent}\n\næ¥è‡ªèŠ‚ç‚¹ï¼š${host.name}`
  346: 
  347:     // æ‰¹é‡å‘é€
  348:     const count = await inboxDb.createBulkMessages({
  349:       userIds,
  350:       eventType: 'host_announcement',
  351:       title: trimmedTitle,
  352:       content: messageContent,
  353:       data: { hostId, hostName: host.name, senderId: userId }
  354:     })
  355: 
  356:     // ä¿å­˜å…¬å‘Šè®°å½•
  357:     await announcementsDb.createAnnouncement({
  358:       type: 'host_broadcast',
  359:       senderId: userId,
  360:       title: trimmedTitle,
  361:       content: trimmedContent,
  362:       recipientCount: count,
  363:       hostId,
  364:     })
  365: 
  366:     if (!sendEmail) {
  367:       return { success: true, count }
  368:     }
  369: 
  370:     const emailSummary = {
  371:       requested: true,
  372:       mode: 'none' as 'none' | 'direct' | 'queued',
  373:       sentCount: 0,
  374:       queuedCount: 0,
  375:       skippedCount: recipients.length - emailRecipients.length,
  376:       failedCount: 0
  377:     }
  378: 
  379:     if (recipients.length === 1 && emailRecipients.length === 1) {
  380:       const recipient = emailRecipients[0]
  381:       emailSummary.mode = 'direct'
  382: 
  383:       const directSendResult = await sendHostAnnouncementEmail(recipient.email!.trim(), {
  384:         username: recipient.username,
  385:         hostName: host.name,
  386:         title: trimmedTitle,
  387:         content: trimmedContent
  388:       })
  389: 
  390:       if (directSendResult.success) {
  391:         emailSummary.sentCount = 1
  392:       } else {
  393:         emailSummary.failedCount = 1
  394:         fastify.log.error(
  395:           `[Inbox] Failed to send direct host announcement email to user ${recipient.userId}: ${directSendResult.error}`
  396:         )
  397:       }
  398:     } else if (emailRecipients.length > 0) {
  399:       emailSummary.mode = 'queued'
  400: 
  401:       try {
  402:         emailSummary.queuedCount = await db.enqueueHostNotificationEmailTasks(
  403:           emailRecipients.map(recipient => ({
  404:             userId: recipient.userId,
  405:             hostId,
  406:             email: recipient.email!.trim(),
  407:             username: recipient.username,
  408:             hostName: host.name,
  409:             title: trimmedTitle,
  410:             content: trimmedContent
  411:           }))
  412:         )
  413:         emailSummary.failedCount = Math.max(0, emailRecipients.length - emailSummary.queuedCount)
  414:       } catch (error) {
  415:         emailSummary.failedCount = emailRecipients.length
  416:         fastify.log.error(`[Inbox] Failed to enqueue host announcement emails for host ${hostId}: ${error}`)
  417:       }
  418:     }
  419: 
  420:     return {
  421:       success: true,
  422:       count,
  423:       email: emailSummary
  424:     }
  425:   })
  426: 
