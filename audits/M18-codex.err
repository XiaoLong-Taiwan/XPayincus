  281: function normalizeWebhookBaseUrl(value: string): string | null {
  282:   const trimmed = value.trim()
  283:   if (!trimmed || trimmed.length > telegramWebhookBaseUrlMaxLength) {
  284:     return null
  285:   }
  286: 
  287:   try {
  288:     const url = new URL(trimmed)
  289:     if (url.protocol !== 'https:' && url.protocol !== 'http:') {
  290:       return null
  291:     }
  292:     if (process.env.NODE_ENV === 'production' && url.protocol !== 'https:') {
  293:       return null
  294:     }
  295:     return `${url.protocol}//${url.host}`
  296:   } catch {
  297:     return null
  298:   }
  299: }
