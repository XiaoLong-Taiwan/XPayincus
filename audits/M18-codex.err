   35: function isIpv4InCidr(ip: string, baseIp: string, prefixLength: number): boolean {
   36:   const ipInt = ipv4ToInt(ip)
   37:   const baseInt = ipv4ToInt(baseIp)
   38:   const mask = prefixLength === 0 ? 0 : (0xffffffff << (32 - prefixLength)) >>> 0
   39:   return (ipInt & mask) === (baseInt & mask)
