  942: function isNonRetryableError(error: string | null): boolean {
  943:   if (!error) return false
  944: 
  945:   const nonRetryablePatterns = [
  946:     'Missing botToken',
  947:     'Missing chatId',
  948:     'Missing webhookUrl',
  949:     'Missing webhook URL',
  950:     'Invalid Discord Webhook URL',
  951:     'not yet implemented',
  952:     'Unknown channel type',
  953:     'Unsupported channel type',
  954:     'chat not found',
  955:     'bot was blocked',
  956:     'CHAT_ID_INVALID',
  957:     'BOT_TOKEN_INVALID',
  958:     '401', // Unauthorized
  959:     '403', // Forbidden
  960:     '404', // Not Found
  961:   ]
  962: 
  963:   return nonRetryablePatterns.some(pattern =>
  964:     error.toLowerCase().includes(pattern.toLowerCase())
  965:   )
  966: }
  967: 
  968: async function readSafeNotificationError(response: Response): Promise<string> {
  969:   const text = await response.text()
  970:   const sanitized = sanitizeTokensInString(text)
  971:   const preview = sanitized.slice(0, NOTIFICATION_ERROR_PREVIEW_MAX_CHARS)
  972:   return preview || `HTTP ${response.status}`
  973: }
