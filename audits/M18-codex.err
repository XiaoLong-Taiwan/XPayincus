  160: 
  161:     await createLog(request.user.id, 'notification', 'admin.global_channel.create',
  162:       `Created global TG channel "${name}" (chatId: ${chatId})`, 'success')
  163: 
  164:     return reply.code(201).send({
  165:       message: 'Global notification channel created',
  166:       channel: { id: channel.id, name, type: 'telegram', enabled }
  167:     })
  168:   })
  169: 
  170:   // æ›´æ–°å…¨å±€é€šçŸ¥æ¸ é“
  171:   fastify.patch<{
  172:     Params: { id: string }
  173:     Body: { name?: string; botToken?: string; chatId?: string; enabled?: boolean }
  174:   }>('/:id', {
  175:     onRequest: [fastify.authenticateAdmin],
  176:     schema: {
  177:       body: {
  178:         type: 'object',
  179:         properties: {
  180:           name: { type: 'string', minLength: 1, maxLength: 50 },
  181:           botToken: { type: 'string', minLength: 1 },
  182:           chatId: { type: 'string', minLength: 1 },
  183:           enabled: { type: 'boolean' }
  184:         }
  185:       }
  186:     }
  187:   }, async (
  188:     request: FastifyRequest<{ Params: { id: string }; Body: { name?: string; botToken?: string; chatId?: string; enabled?: boolean } }>,
  189:     reply: FastifyReply
  190:   ) => {
  191:     const channelId = parsePositiveRouteId(request.params.id)
  192:     if (!channelId) return reply.code(400).send({ error: 'Invalid ID' })
  193: 
  194:     const existing = await prisma.notificationChannel.findFirst({
  195:       where: { id: channelId, isGlobal: true } as any
  196:     })
  197:     if (!existing) return reply.code(404).send({ error: 'Channel not found' })
  198: 
  199:     const { enabled } = request.body
  200:     const normalized = normalizeGlobalTelegramChannelInput(request.body)
  201:     if (!normalized.valid) {
  202:       return reply.code(400).send({ error: normalized.error })
  203:     }
  204:     const { name, botToken, chatId } = normalized.value
  205:     const existingConfig = typeof existing.config === 'string' ? JSON.parse(existing.config) : existing.config as Record<string, unknown>
  206: 
  207:     // Merge config
  208:     const newConfig = {
  209:       botToken: botToken || existingConfig.botToken,
  210:       chatId: chatId || existingConfig.chatId
  211:     }
  212: 
  213:     await prisma.notificationChannel.update({
  214:       where: { id: channelId },
  215:       data: {
  216:         ...(name !== undefined && { name }),
  217:         ...(enabled !== undefined && { enabled }),
  218:         ...(botToken || chatId ? { config: newConfig } : {})
  219:       }
  220:     })
  221: 
  222:     await createLog(request.user.id, 'notification', 'admin.global_channel.update',
  223:       `Updated global TG channel "${existing.name}"`, 'success')
  224: 
  225:     return { message: 'Channel updated' }
  226:   })
