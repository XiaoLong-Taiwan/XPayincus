   61: function normalizeNotificationChannelName(value: unknown): string {
   62:   if (typeof value !== 'string') {
   63:     throw { error: 'Invalid notification channel name' }
   64:   }
   65:   const name = value.trim()
   66:   if (!name || name.length > 50) {
   67:     throw { error: 'Notification channel name must be 1-50 characters' }
   68:   }
   69:   return name
   70: }
   71: 
   72: function normalizeNotificationChannelCreateInput(input: unknown): NotificationChannelCreateInput {
   73:   if (!isPlainRecord(input)) {
   74:     throw { error: 'Invalid request body' }
   75:   }
   76: 
   77:   if (typeof input.type !== 'string' || !USER_NOTIFICATION_CHANNEL_TYPES.has(input.type as UserNotificationChannelType)) {
   78:     throw { error: 'Invalid notification channel type' }
   79:   }
   80:   if (!isPlainRecord(input.config)) {
   81:     throw { error: 'Invalid notification channel config' }
   82:   }
   83:   if (input.enabled !== undefined && typeof input.enabled !== 'boolean') {
   84:     throw { error: 'Invalid enabled flag' }
   85:   }
   86: 
   87:   return {
   88:     type: input.type as UserNotificationChannelType,
   89:     name: normalizeNotificationChannelName(input.name),
   90:     config: { ...input.config },
   91:     enabled: input.enabled ?? true
   92:   }
   93: }
   94: 
   95: function normalizeNotificationChannelUpdateInput(input: unknown): NotificationChannelUpdateInput {
   96:   if (!isPlainRecord(input)) {
   97:     throw { error: 'Invalid request body' }
   98:   }
   99: 
  100:   const update: NotificationChannelUpdateInput = {}
  101:   if (input.name !== undefined) {
  102:     update.name = normalizeNotificationChannelName(input.name)
  103:   }
  104:   if (input.config !== undefined) {
  105:     if (!isPlainRecord(input.config)) {
