  155: export async function claimNextHostNotificationEmailTask(): Promise<HostNotificationEmailTask | null> {
  156:   return prisma.$transaction(async (tx) => {
  157:         const locked = await tryAdvisoryTransactionLock(
  158:           tx,
  159:           HOST_NOTIFICATION_EMAIL_LOCK_NAMESPACE,
  160:           HOST_NOTIFICATION_EMAIL_LOCK_KEY
  161:         )
  162: 
  163:         if (!locked) {
  164:           return null
  165:         }
  166: 
  167:         const now = new Date()
  168:         const recentThreshold = new Date(now.getTime() - HOST_NOTIFICATION_EMAIL_INTERVAL_MS)
  169: 
  170:         const throttledTask = await tx.hostNotificationEmailTask.findFirst({
  171:           where: {
  172:             OR: [
  173:               { status: 'PROCESSING' },
  174:               { startedAt: { gte: recentThreshold } }
  175:             ]
  176:           },
  177:           select: { id: true }
  178:         })
  179: 
  180:         if (throttledTask) {
  181:           return null
  182:         }
  183: 
  184:         const nextTask = await tx.hostNotificationEmailTask.findFirst({
  185:           where: {
  186:             status: 'PENDING',
  187:             scheduledFor: { lte: now }
  188:           },
  189:           orderBy: [
  190:             { scheduledFor: 'asc' },
  191:             { createdAt: 'asc' }
  192:           ]
  193:         })
  194: 
  195:         if (!nextTask) {
  196:           return null
  197:         }
  198: 
  199:         return tx.hostNotificationEmailTask.update({
  200:           where: { id: nextTask.id },
  201:           data: {
  202:             status: 'PROCESSING',
  203:             startedAt: now,
  204:             finishedAt: null,
  205:             lastError: null
  206:           }
  207:         })
  208:   })
  209: }
