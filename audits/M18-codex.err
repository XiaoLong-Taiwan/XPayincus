 1261: async function sendTelegram(
 1262:   config: TelegramConfig,
 1263:   title: string,
 1264:   message: string
 1265: ): Promise<NotificationResult> {
 1266:   const { botToken, chatId } = config
 1267: 
 1268:   if (!botToken || !chatId) {
 1269:     return { success: false, error: 'Missing botToken or chatId' }
 1270:   }
 1271: 
 1272:   try {
 1273:     const text = `*${escapeMarkdown(title)}*\n\n${escapeMarkdown(message)}`
 1274: 
 1275:     const response = await fetch(`https://api.telegram.org/bot${botToken}/sendMessage`, {
 1276:       method: 'POST',
 1277:       redirect: 'manual',
 1278:       signal: AbortSignal.timeout(NOTIFICATION_FETCH_TIMEOUT_MS),
 1279:       headers: { 'Content-Type': 'application/json' },
 1280:       body: JSON.stringify({
 1281:         chat_id: chatId,
 1282:         text,
 1283:         parse_mode: 'MarkdownV2'
 1284:       })
 1285:     })
 1286: 
 1287:     const result = await response.json() as { ok: boolean; description?: string }
 1288: 
 1289:     if (!result.ok) {
 1290:       return { success: false, error: result.description || 'Unknown Telegram error' }
 1291:     }
 1292: 
 1293:     return { success: true, error: null }
 1294:   } catch (err) {
 1295:     const error = err instanceof Error ? err.message : String(err)
 1296:     return { success: false, error }
 1297:   }
 1298: }
