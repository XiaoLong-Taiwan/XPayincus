   12: const telegramBotTokenPattern = /^[1-9]\d{5,19}:[A-Za-z0-9_-]{20,}$/
   13: const telegramChatIdPattern = /^-?\d{1,20}$|^@[A-Za-z0-9_]{5,32}$/
   14: const maskedTelegramBotTokenPattern = /^.{1,20}\.\.\..{1,20}$/
   15: const POSITIVE_ROUTE_ID_PATTERN = /^[1-9]\d*$/
   16: 
   17: function parsePositiveRouteId(value: string): number | null {
   18:   if (!POSITIVE_ROUTE_ID_PATTERN.test(value)) return null
   19:   const parsed = Number(value)
   20:   return Number.isSafeInteger(parsed) ? parsed : null
   21: }
   22: 
   23: function normalizeGlobalTelegramChannelInput(input: {
   24:   name?: string
   25:   botToken?: string
   26:   chatId?: string
   27: }): { valid: true; value: { name?: string; botToken?: string; chatId?: string } } | { valid: false; error: string } {
   28:   const value: { name?: string; botToken?: string; chatId?: string } = {}
   29: 
   30:   if (input.name !== undefined) {
   31:     const name = input.name.trim()
   32:     if (!name || name.length > 50) {
   33:       return { valid: false, error: 'Channel name must be 1-50 characters' }
   34:     }
   35:     value.name = name
   36:   }
   37: 
   38:   if (input.botToken !== undefined) {
   39:     const botToken = input.botToken.trim()
   40:     if (!botToken || maskedTelegramBotTokenPattern.test(botToken) || !telegramBotTokenPattern.test(botToken)) {
   41:       return { valid: false, error: 'Invalid Bot Token format' }
   42:     }
   43:     value.botToken = botToken
   44:   }
   45: 
   46:   if (input.chatId !== undefined) {
   47:     const chatId = input.chatId.trim()
   48:     if (!telegramChatIdPattern.test(chatId)) {
   49:       return { valid: false, error: 'Invalid Telegram Chat ID format' }
   50:     }
   51:     value.chatId = chatId
   52:   }
   53: 
   54:   return { valid: true, value }
   55: }
