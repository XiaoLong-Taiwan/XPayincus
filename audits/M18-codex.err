    1: /**
    2:  * å…¬å‘Š/é€šçŸ¥åŽ†å²è®°å½•è·¯ç”±
    3:  */
    4: 
    5: import type { FastifyInstance, FastifyRequest, FastifyReply } from 'fastify'
    6: import * as announcementsDb from '../db/announcements.js'
    7: import { apiError, ErrorCode } from '../lib/errors.js'
    8: import type { AnnouncementType } from '@prisma/client'
    9: 
   10: const POSITIVE_ROUTE_ID_PATTERN = /^[1-9]\d*$/
   11: const announcementTypes = new Set<AnnouncementType>([
   12:   'system_broadcast',
   13:   'host_broadcast',
   14:   'admin_message',
   15:   'host_message'
   16: ])
   17: 
   18: function parsePositiveInteger(value: string | undefined, fallback: number, max: number): number {
   19:   if (value === undefined) {
   20:     return fallback
   21:   }
   22: 
   23:   if (!POSITIVE_ROUTE_ID_PATTERN.test(value)) {
   24:     return fallback
   25:   }
   26: 
   27:   const parsed = Number(value)
   28:   if (!Number.isSafeInteger(parsed)) {
   29:     return fallback
   30:   }
   31: 
   32:   return Math.min(parsed, max)
   33: }
   34: 
   35: function parsePositiveRouteId(value: string): number | null {
   36:   if (!POSITIVE_ROUTE_ID_PATTERN.test(value)) {
   37:     return null
   38:   }
   39: 
   40:   const parsed = Number(value)
   41:   return Number.isSafeInteger(parsed) ? parsed : null
   42: }
   43: 
   44: function parseOptionalPositiveId(value: string | undefined): number | null | undefined {
   45:   if (value === undefined) {
   46:     return undefined
   47:   }
   48:   return parsePositiveRouteId(value)
   49: }
   50: 
   51: function parseAnnouncementType(value: string | undefined): AnnouncementType | null | undefined {
   52:   if (value === undefined) {
   53:     return undefined
   54:   }
   55:   return announcementTypes.has(value as AnnouncementType) ? value as AnnouncementType : null
   56: }
   57: 
   58: export default async function announcementsRoutes(fastify: FastifyInstance) {
   59:   // æ‰€æœ‰è·¯ç”±éƒ½éœ€è¦è®¤è¯
   60:   fastify.addHook('onRequest', fastify.authenticate)
   61: 
   62:   /**
   63:    * èŽ·å–å…¬å‘ŠåŽ†å²åˆ—è¡¨ï¼ˆç®¡ç†å‘˜ï¼‰
   64:    * GET /api/announcements
   65:    */
   66:   fastify.get<{
   67:     Querystring: {
   68:       page?: string
   69:       pageSize?: string
   70:       type?: string
   71:     }
   72:   }>('/', async (request: FastifyRequest<{
   73:     Querystring: {
   74:       page?: string
   75:       pageSize?: string
   76:       type?: string
   77:     }
   78:   }>, reply: FastifyReply) => {
   79:     // æ£€æŸ¥ç®¡ç†å‘˜æƒé™
   80:     if (request.user.role !== 'admin') {
   81:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
   82:     }
   83: 
   84:     const { type } = request.query
   85:     const parsedType = parseAnnouncementType(type)
   86:     if (parsedType === null) {
   87:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid announcement type'))
   88:     }
   89: 
   90:     const result = await announcementsDb.getAnnouncementList({
   91:       page: parsePositiveInteger(request.query.page, 1, 100000),
   92:       pageSize: parsePositiveInteger(request.query.pageSize, 20, 100),
