   58:   }
   59:   if (trimmedContent.length > 5000) {
   60:     return { error: { error: 'CONTENT_TOO_LONG', message: 'Content is too long' } }
   61:   }
   62: 
   63:   return { title: trimmedTitle, content: trimmedContent }
   64: }
