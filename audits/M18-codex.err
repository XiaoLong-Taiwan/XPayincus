   57: export async function createInboxMessage(data: CreateInboxMessageData): Promise<number> {
   58:   const message = await prisma.inboxMessage.create({
   59:     data: {
   60:       userId: data.userId,
   61:       eventType: data.eventType,
   62:       title: data.title,
   63:       content: data.content,
   64:       data: data.data as Prisma.InputJsonValue | undefined
   65:     },
   66:     select: { id: true }
   67:   })
   68:   return message.id
   69: }
   70: 
   71: /**
