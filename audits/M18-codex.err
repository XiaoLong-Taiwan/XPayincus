 1131: export async function sendHostManagedInstanceNotification(
 1132:   hostId: number,
 1133:   eventType: HostManagedInstanceEventType,
 1134:   data: {
 1135:     username: string
 1136:     instanceName: string
 1137:     amount?: number
 1138:     refundAmount?: number
 1139:     feeAmount?: number
 1140:   }
 1141: ): Promise<SendResult> {
 1142:   try {
 1143:     const host = await prisma.host.findUnique({
 1144:       where: { id: hostId },
 1145:       select: {
 1146:         userId: true,
 1147:         name: true,
 1148:         notifyPurchase: true,
 1149:         notifyRenew: true,
 1150:         notifyDestroy: true,
 1151:         user: {
 1152:           select: {
 1153:             role: true
 1154:           }
 1155:         }
 1156:       }
 1157:     })
 1158: 
 1159:     if (!host || host.user.role === 'admin') {
 1160:       return { sent: 0, failed: 0 }
 1161:     }
 1162: 
 1163:     const enabled = eventType === 'purchase'
 1164:       ? host.notifyPurchase
 1165:       : eventType === 'renew'
 1166:         ? host.notifyRenew
 1167:         : host.notifyDestroy
 1168: 
 1169:     if (!enabled) {
 1170:       return { sent: 0, failed: 0 }
 1171:     }
 1172: 
 1173:     const channels = (await db.getEnabledChannelsByUserId(host.userId))
 1174:       .filter(channel => ['telegram', 'discord', 'webhook'].includes(channel.type))
 1175: 
 1176:     if (channels.length === 0) {
 1177:       return { sent: 0, failed: 0 }
 1178:     }
 1179: 
 1180:     const payload = buildHostManagedInstanceNotification(eventType, {
 1181:       hostName: host.name,
 1182:       ...data
 1183:     })
 1184: 
 1185:     let sent = 0
 1186:     let failed = 0
 1187: 
 1188:     for (const channel of channels) {
 1189:       try {
 1190:         const config = typeof channel.config === 'string'
 1191:           ? JSON.parse(channel.config)
 1192:           : channel.config
 1193: 
 1194:         const logId = await db.createNotificationLog({
 1195:           channelId: channel.id,
 1196:           eventType: payload.webhookEvent,
 1197:           message: payload.message,
 1198:           status: 'pending'
 1199:         })
 1200: 
 1201:         let result: NotificationResult
 1202: 
 1203:         switch (channel.type) {
 1204:           case 'telegram':
 1205:             result = await sendWithRetry(
 1206:               () => sendTelegram(config as TelegramConfig, payload.title, payload.message),
 1207:               'Telegram'
 1208:             )
 1209:             break
 1210:           case 'discord':
 1211:             result = await sendWithRetry(
 1212:               () => sendDiscord(config as DiscordConfig, payload.title, payload.message),
 1213:               'Discord'
 1214:             )
 1215:             break
 1216:           case 'webhook':
 1217:             result = await sendWithRetry(
 1218:               () => sendWebhook(
 1219:                 config as WebhookConfig,
 1220:                 payload.webhookEvent,
 1221:                 payload.title,
 1222:                 payload.message,
 1223:                 {
 1224:                   hostId,
 1225:                   hostName: host.name,
 1226:                   eventType,
 1227:                   ...data
 1228:                 }
 1229:               ),
 1230:               'Webhook'
 1231:             )
 1232:             break
 1233:           default:
 1234:             result = { success: false, error: `Unsupported channel type: ${channel.type}` }
 1235:         }
 1236: 
 1237:         await db.updateNotificationLogStatus(logId, result.success ? 'sent' : 'failed', result.error)
 1238: 
 1239:         if (result.success) {
 1240:           sent++
 1241:         } else {
 1242:           failed++
 1243:         }
 1244:       } catch (err) {
 1245:         const error = err instanceof Error ? err.message : String(err)
 1246:         console.error(`[Notifier] Failed to send host managed instance notification to channel ${channel.id}:`, error)
 1247:         failed++
 1248:       }
 1249:     }
