  107:     }
  108:     update.config = { ...input.config }
  109:   }
  110:   if (input.enabled !== undefined) {
  111:     if (typeof input.enabled !== 'boolean') {
  112:       throw { error: 'Invalid enabled flag' }
  113:     }
  114:     update.enabled = input.enabled
  115:   }
  116: 
  117:   return update
  118: }
