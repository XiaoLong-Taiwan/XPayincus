   34: 
   35: const USER_NOTIFICATION_CHANNEL_TYPES = new Set<UserNotificationChannelType>(['telegram', 'discord', 'webhook', 'email'])
   36: 
   37: function isPlainRecord(value: unknown): value is Record<string, unknown> {
   38:   return typeof value === 'object' && value !== null && !Array.isArray(value)
   39: }
   40: 
   41: function parsePositiveRouteId(value: string): number | null {
   42:   if (!POSITIVE_ROUTE_ID_PATTERN.test(value)) {
   43:     return null
   44:   }
   45: 
   46:   const parsed = Number(value)
   47:   return Number.isSafeInteger(parsed) ? parsed : null
   48: }
   49: 
   50: function parsePositiveInteger(value: string | undefined, fallback: number): number {
   51:   const parsed = parseInt(value || '', 10)
   52:   return Number.isInteger(parsed) && parsed > 0 ? parsed : fallback
   53: }
   54: 
   55: function parseNotificationLogStatus(value: string | undefined): 'pending' | 'sent' | 'failed' | undefined {
   56:   return value && notificationLogStatuses.has(value)
   57:     ? value as 'pending' | 'sent' | 'failed'
   58:     : undefined
   59: }
