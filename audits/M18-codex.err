  225: export async function retryOrFailHostNotificationEmailTask(
  226:   taskId: number,
  227:   currentRetryCount: number,
  228:   errorMessage: string
  229: ): Promise<void> {
  230:   if (currentRetryCount >= HOST_NOTIFICATION_EMAIL_MAX_RETRIES) {
  231:     await prisma.hostNotificationEmailTask.updateMany({
  232:       where: {
  233:         id: taskId,
  234:         status: 'PROCESSING',
  235:         retryCount: currentRetryCount
  236:       },
  237:       data: {
  238:         status: 'FAILED',
  239:         lastError: errorMessage,
  240:         finishedAt: new Date()
  241:       }
  242:     })
  243:     return
  244:   }
  245: 
  246:   await prisma.hostNotificationEmailTask.updateMany({
  247:     where: {
  248:       id: taskId,
  249:       status: 'PROCESSING',
  250:       retryCount: currentRetryCount
  251:     },
  252:     data: {
  253:       status: 'PENDING',
  254:       retryCount: { increment: 1 },
  255:       lastError: errorMessage,
  256:       scheduledFor: new Date(Date.now() + HOST_NOTIFICATION_EMAIL_RETRY_DELAY_MS),
  257:       finishedAt: null
  258:     }
  259:   })
  260: }

