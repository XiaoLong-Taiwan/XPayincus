   78: export async function enqueueHostNotificationEmailTasks(
   79:   tasks: EnqueueHostNotificationEmailTaskInput[]
   80: ): Promise<number> {
   81:   if (tasks.length === 0) return 0
   82: 
   83:   for (let attempt = 0; attempt < ADVISORY_LOCK_RETRY_LIMIT; attempt++) {
   84:     const queuedCount = await prisma.$transaction(async (tx) => {
   85:         const locked = await tryAdvisoryTransactionLock(
   86:           tx,
   87:           HOST_NOTIFICATION_EMAIL_LOCK_NAMESPACE,
   88:           HOST_NOTIFICATION_EMAIL_LOCK_KEY
   89:         )
   90: 
   91:         if (!locked) return null
   92: 
   93:         const now = new Date()
   94:         const [latestQueuedTask, latestAttemptedTask] = await Promise.all([
   95:           tx.hostNotificationEmailTask.findFirst({
   96:             where: {
   97:               status: { in: ['PENDING', 'PROCESSING'] }
   98:             },
   99:             orderBy: [
  100:               { scheduledFor: 'desc' },
  101:               { id: 'desc' }
  102:             ],
  103:             select: { scheduledFor: true }
  104:           }),
  105:           tx.hostNotificationEmailTask.findFirst({
  106:             where: {
  107:               startedAt: { not: null }
  108:             },
  109:             orderBy: [
  110:               { startedAt: 'desc' },
  111:               { id: 'desc' }
  112:             ],
  113:             select: { startedAt: true }
  114:           })
  115:         ])
  116: 
  117:         let baseTime = now.getTime()
  118: 
  119:         if (latestQueuedTask?.scheduledFor) {
  120:           baseTime = Math.max(
  121:             baseTime,
  122:             latestQueuedTask.scheduledFor.getTime() + HOST_NOTIFICATION_EMAIL_INTERVAL_MS
  123:           )
  124:         }
  125: 
  126:         if (latestAttemptedTask?.startedAt) {
  127:           baseTime = Math.max(
  128:             baseTime,
  129:             latestAttemptedTask.startedAt.getTime() + HOST_NOTIFICATION_EMAIL_INTERVAL_MS
  130:           )
  131:         }
  132: 
  133:         const queuedTasks = tasks.map((task, index) => ({
  134:           ...task,
  135:           scheduledFor: new Date(baseTime + index * HOST_NOTIFICATION_EMAIL_INTERVAL_MS)
  136:         }))
  137: 
  138:         const result = await tx.hostNotificationEmailTask.createMany({
  139:           data: queuedTasks
  140:         })
  141: 
  142:         return result.count
  143:       })
  144: 
  145:     if (queuedCount !== null) {
  146:       return queuedCount
  147:     }
  148: 
  149:     await sleep(ADVISORY_LOCK_RETRY_DELAY_MS * (attempt + 1))
  150:   }
  151: 
  152:   throw new Error('Failed to acquire host notification email queue lock')
  153: }
