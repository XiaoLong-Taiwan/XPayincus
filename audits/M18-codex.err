  301: function buildWebhookUrl(_request: FastifyRequest, baseUrl?: string): string | null {
  302:   const explicitBaseUrl = typeof baseUrl === 'string' ? normalizeWebhookBaseUrl(baseUrl) : null
  303:   if (explicitBaseUrl) {
  304:     return `${explicitBaseUrl}/api/telegram/webhook`
  305:   }
  306: 
  307:   const configuredBaseUrl = (process.env.SITE_URL || process.env.FRONTEND_URL?.split(',')[0])?.trim()
  308:   if (configuredBaseUrl) {
  309:     const normalized = normalizeWebhookBaseUrl(configuredBaseUrl)
  310:     if (normalized) {
  311:       return `${normalized}/api/telegram/webhook`
  312:     }
  313:   }
  314: 
