    5: import type { FastifyInstance, FastifyRequest, FastifyReply } from 'fastify'
    6: import * as inboxDb from '../db/inbox.js'
    7: import * as db from '../db/index.js'
    8: import * as announcementsDb from '../db/announcements.js'
    9: import { apiError, ErrorCode } from '../lib/errors.js'
   10: import { isSmtpEnabled, sendHostAnnouncementEmail } from '../lib/mailer.js'
   11: import { redactDemoInboxMessage, shouldRedactDemoLoginRecords } from '../lib/demo-safety.js'
   12: 
   13: const POSITIVE_INTEGER_PATTERN = /^[1-9]\d*$/
   14: 
   15: function parsePositiveInteger(value: string | undefined, fallback: number): number {
   16:   if (!value || !POSITIVE_INTEGER_PATTERN.test(value)) return fallback
   17:   const parsed = Number(value)
   18:   return Number.isSafeInteger(parsed) ? parsed : fallback
   19: }
   20: 
   21: function parsePositiveId(value: string): number | null {
   22:   if (!POSITIVE_INTEGER_PATTERN.test(value)) return null
   23:   const parsed = Number(value)
   24:   return Number.isSafeInteger(parsed) ? parsed : null
   25: }
   26: 
   27: function parsePositiveIdArray(value: number[] | undefined): number[] | undefined | null {
   28:   if (value === undefined) return undefined
   29:   const ids: number[] = []
   30:   const seenIds = new Set<number>()
   31:   for (const item of value) {
   32:     if (!Number.isSafeInteger(item) || item <= 0) return null
   33:     if (!seenIds.has(item)) {
   34:       seenIds.add(item)
   35:       ids.push(item)
   36:     }
   37:   }
   38:   return ids
   39: }
   40: 
   41: function normalizeInboxMessageInput(body: unknown): { title: string; content: string } | { error: { error: string; message: string } } {
   42:   if (!body || typeof body !== 'object' || Array.isArray(body)) {
   43:     return { error: { error: 'TITLE_REQUIRED', message: 'Title is required' } }
   44:   }
   45: 
   46:   const { title, content } = body as { title?: unknown; content?: unknown }
   47:   if (typeof title !== 'string' || title.trim().length === 0) {
   48:     return { error: { error: 'TITLE_REQUIRED', message: 'Title is required' } }
   49:   }
   50:   if (typeof content !== 'string' || content.trim().length === 0) {
   51:     return { error: { error: 'CONTENT_REQUIRED', message: 'Content is required' } }
   52:   }
   53: 
   54:   const trimmedTitle = title.trim()
   55:   const trimmedContent = content.trim()
   56:   if (trimmedTitle.length > 200) {
   57:     return { error: { error: 'TITLE_TOO_LONG', message: 'Title is too long' } }
   58:   }
   59:   if (trimmedContent.length > 5000) {
   60:     return { error: { error: 'CONTENT_TOO_LONG', message: 'Content is too long' } }
   61:   }
   62: 
   63:   return { title: trimmedTitle, content: trimmedContent }
   64: }
   65: 
   66: export default async function inboxRoutes(fastify: FastifyInstance) {
   67: 
   68:   // æ‰€æœ‰è·¯ç”±éƒ½éœ€è¦è®¤è¯
   69:   fastify.addHook('onRequest', fastify.authenticate)
   70: 
   71:   /**
   72:    * èŽ·å–ç«™å†…ä¿¡åˆ—è¡¨
   73:    */
   74:   fastify.get<{
   75:     Querystring: {
   76:       page?: string
   77:       pageSize?: string
   78:       isRead?: string
   79:     }
   80:   }>('/', async (request: FastifyRequest<{
   81:     Querystring: {
   82:       page?: string
   83:       pageSize?: string
   84:       isRead?: string
   85:     }
   86:   }>) => {
   87:     const { isRead } = request.query
   88:     const userId = request.user.id
   89: 
   90:     // è§£æž isRead å‚æ•°
   91:     let isReadFilter: boolean | undefined
   92:     if (isRead === 'true') {
   93:       isReadFilter = true
   94:     } else if (isRead === 'false') {
   95:       isReadFilter = false
   96:     }
   97: 
   98:     const result = await inboxDb.getInboxMessages(userId, {
   99:       page: parsePositiveInteger(request.query.page, 1),
  100:       pageSize: Math.min(100, parsePositiveInteger(request.query.pageSize, 20)),
  101:       isRead: isReadFilter
  102:     })
  103: 
  104:     if (shouldRedactDemoLoginRecords(request, request.user)) {
  105:       return {
  106:         ...result,
  107:         messages: result.messages.map(redactDemoInboxMessage)
  108:       }
  109:     }
  110: 
  111:     return result
  112:   })
