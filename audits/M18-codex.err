  485: /**
  486:  * éªŒè¯é…ç½®
  487:  */
  488: function validateConfig(
  489:   type: 'telegram' | 'discord' | 'webhook' | 'email',
  490:   config: Record<string, unknown>
  491: ): { valid: boolean; error?: string } {
  492:   switch (type) {
  493:     case 'telegram':
  494:       if (typeof config.botToken !== 'string' || typeof config.chatId !== 'string') {
  495:         return { valid: false, error: 'Please provide Bot Token and Chat ID' }
  496:       }
  497:       {
  498:         const botToken = config.botToken.trim()
  499:         const chatId = config.chatId.trim()
  500:         if (!telegramBotTokenPattern.test(botToken)) {
  501:           return { valid: false, error: 'Invalid Telegram Bot Token' }
  502:         }
  503:         if (!telegramChatIdPattern.test(chatId)) {
  504:           return { valid: false, error: 'Invalid Telegram Chat ID' }
  505:         }
  506:         config.botToken = botToken
  507:         config.chatId = chatId
  508:       }
  509:       break
  510:     case 'discord':
  511:       if (!config.webhookUrl || typeof config.webhookUrl !== 'string') {
  512:         return { valid: false, error: 'Please provide Discord Webhook URL' }
  513:       }
  514:       if (!config.webhookUrl.startsWith('https://discord.com/api/webhooks/')) {
  515:         return { valid: false, error: 'Invalid Discord Webhook URL' }
  516:       }
  517:       break
  518:     case 'webhook':
  519:       if (!config.url || typeof config.url !== 'string') {
  520:         return { valid: false, error: 'Please provide Webhook URL' }
  521:       }
  522:       {
  523:         const webhookUrl = config.url.trim()
  524:         if (!webhookUrl.startsWith('http://') && !webhookUrl.startsWith('https://')) {
  525:           return { valid: false, error: 'Invalid Webhook URL' }
  526:         }
  527:         config.url = webhookUrl
  528:       }
  529:       if (config.secret !== undefined) {
  530:         if (typeof config.secret !== 'string' || config.secret.length > maxWebhookSecretLength) {
  531:           return { valid: false, error: 'Invalid Webhook secret' }
  532:         }
  533:         config.secret = config.secret.trim()
  534:       }
  535:       break
  536:     case 'email':
  537:       if (!config.email) {
  538:         return { valid: false, error: 'Please provide email address' }
  539:       }
  540:       break
  541:   }
  542: 
  543:   return { valid: true }
  544: }
  545: 
  546: /**
  547:  * èŽ·å–é…ç½®é¢„è§ˆï¼ˆéšè—æ•æ„Ÿä¿¡æ¯ï¼‰
  548:  */
  549: function getConfigPreview(type: string, configStr: string | Record<string, unknown>): string {
  550:   try {
  551:     const config = typeof configStr === 'string' ? JSON.parse(configStr) : configStr as Record<string, unknown>
  552: 
  553:     switch (type) {
  554:       case 'telegram':
  555:         return `Chat ID: ${config.chatId || 'Not set'}`
  556:       case 'discord':
  557:         return typeof config.webhookUrl === 'string' && config.webhookUrl
  558:           ? `Webhook: ...${config.webhookUrl.slice(-20)}`
  559:           : 'Not set'
  560:       case 'webhook':
  561:         if (typeof config.url === 'string' && config.url) {
  562:           try {
  563:             return `URL: ${new URL(config.url).hostname}`
  564:           } catch {
  565:             return 'URL: Invalid'
  566:           }
  567:         }
  568:         return 'Not set'
  569:       case 'email':
  570:         return typeof config.email === 'string' ? config.email : 'Not set'
  571:       default:
  572:         return 'Unknown type'
  573:     }
  574:   } catch {
  575:     return 'Config error'
  576:   }
  577: }
  578: 
  579: /**
  580:  * éšè—æ•æ„Ÿé…ç½®ä¿¡æ¯
  581:  */
  582: function maskSensitiveConfig(
  583:   type: string,
  584:   config: Record<string, unknown>
  585: ): Record<string, unknown> {
  586:   const masked = { ...config }
  587: 
  588:   switch (type) {
  589:     case 'telegram':
  590:       if (typeof masked.botToken === 'string' && masked.botToken) {
  591:         masked.botToken = masked.botToken.slice(0, 10) + '...' + masked.botToken.slice(-5)
  592:       }
  593:       break
  594:     case 'discord':
  595:       if (typeof masked.webhookUrl === 'string' && masked.webhookUrl) {
  596:         masked.webhookUrl = masked.webhookUrl.slice(0, 50) + '...'
  597:       }
  598:       break
  599:     case 'webhook':
  600:       if (masked.secret) {
  601:         masked.secret = '***å·²è®¾ç½®***'
  602:       }
  603:       break
  604:   }
  605: 
  606:   return masked
  607: }
