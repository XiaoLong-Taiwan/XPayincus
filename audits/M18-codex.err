   13: const POSITIVE_INTEGER_PATTERN = /^[1-9]\d*$/
   14: 
   15: function parsePositiveInteger(value: string | undefined, fallback: number): number {
   16:   if (!value || !POSITIVE_INTEGER_PATTERN.test(value)) return fallback
   17:   const parsed = Number(value)
   18:   return Number.isSafeInteger(parsed) ? parsed : fallback
   19: }
   20: 
   21: function parsePositiveId(value: string): number | null {
   22:   if (!POSITIVE_INTEGER_PATTERN.test(value)) return null
   23:   const parsed = Number(value)
   24:   return Number.isSafeInteger(parsed) ? parsed : null
   25: }
   26: 
   27: function parsePositiveIdArray(value: number[] | undefined): number[] | undefined | null {
   28:   if (value === undefined) return undefined
   29:   const ids: number[] = []
   30:   const seenIds = new Set<number>()
   31:   for (const item of value) {
   32:     if (!Number.isSafeInteger(item) || item <= 0) return null
   33:     if (!seenIds.has(item)) {
   34:       seenIds.add(item)
   35:       ids.push(item)
   36:     }
   37:   }
   38:   return ids
   39: }
