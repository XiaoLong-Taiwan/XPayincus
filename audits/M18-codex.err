   74: export async function getInboxMessages(
   75:   userId: number,
   76:   options: {
   77:     page?: number
   78:     pageSize?: number
   79:     isRead?: boolean
   80:   } = {}
   81: ): Promise<PaginatedInboxMessages> {
   82:   const { page, pageSize } = clampInboxPagination(options.page, options.pageSize)
   83:   const skip = (page - 1) * pageSize
   84: 
   85:   const where = {
   86:     userId,
   87:     ...(options.isRead !== undefined ? { isRead: options.isRead } : {})
   88:   }
   89: 
   90:   const [messages, total] = await Promise.all([
   91:     prisma.inboxMessage.findMany({
   92:       where,
   93:       orderBy: { createdAt: 'desc' },
   94:       skip,
   95:       take: pageSize
   96:     }),
   97:     prisma.inboxMessage.count({ where })
   98:   ])
   99: 
  100:   return {
  101:     messages: messages.map(msg => ({
  102:       id: msg.id,
  103:       userId: msg.userId,
  104:       eventType: msg.eventType,
  105:       title: msg.title,
  106:       content: msg.content,
  107:       isRead: msg.isRead,
  108:       data: msg.data as Record<string, unknown> | null,
  109:       createdAt: msg.createdAt.toISOString()
  110:     })),
  111:     total,
  112:     page,
  113:     pageSize,
  114:     totalPages: Math.ceil(total / pageSize)
  115:   }
  116: }
