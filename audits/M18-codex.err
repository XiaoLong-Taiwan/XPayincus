  250: async function callTelegramApi<T>(
  251:   botToken: string,
  252:   method: string,
  253:   payload?: Record<string, unknown>
  254: ): Promise<TelegramApiResponse<T>> {
  255:   const response = await fetch(`https://api.telegram.org/bot${botToken}/${method}`, {
  256:     method: payload ? 'POST' : 'GET',
  257:     redirect: 'manual',
  258:     signal: AbortSignal.timeout(telegramApiTimeoutMs),
  259:     headers: payload ? { 'Content-Type': 'application/json' } : undefined,
  260:     body: payload ? JSON.stringify(payload) : undefined
  261:   })
  262:   const data = await response.json().catch(() => null)
  263: 
  264:   if (!data || typeof data !== 'object') {
  265:     return {
  266:       ok: false,
  267:       description: `Telegram API returned HTTP ${response.status}`,
  268:       error_code: response.status
  269:     }
  270:   }
  271: 
  272:   return data as TelegramApiResponse<T>
  273: }
