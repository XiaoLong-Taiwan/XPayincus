  277: /**
  278:  * æŽ©ç  Bot Tokenï¼ˆä¿ç•™å‰åŽéƒ¨åˆ†ï¼‰
  279:  */
  280: function maskBotToken(config: Record<string, unknown>): Record<string, unknown> {
  281:   const masked = { ...config }
  282:   if (typeof masked.botToken === 'string' && masked.botToken) {
  283:     masked.botToken = masked.botToken.slice(0, 8) + '...' + masked.botToken.slice(-5)
  284:   }
  285:   return masked
  286: }
===== server/src/workers/hostNotificationEmailWorker.ts =====
    1: import {
    2:   claimNextHostNotificationEmailTask,
    3:   cleanupStaleHostNotificationEmailTasks,
    4:   cleanupTimeoutHostNotificationEmailTasks,
    5:   retryOrFailHostNotificationEmailTask,
    6:   markHostNotificationEmailTaskSent
    7: } from '../db/host-notification-email-tasks.js'
    8: import { sendHostAnnouncementEmail } from '../lib/mailer.js'
    9: import type { HostNotificationEmailTask } from '@prisma/client'
   10: import { createWorkerDbBackoff } from './db-failure-backoff.js'
   11: 
   12: const POLL_INTERVAL = 5000
   13: const TIMEOUT_CHECK_INTERVAL = 60 * 1000
   14: 
   15: let workerInterval: ReturnType<typeof setInterval> | null = null
   16: let timeoutCheckInterval: ReturnType<typeof setInterval> | null = null
   17: let isProcessing = false
   18: const dbBackoff = createWorkerDbBackoff('HostNotifyEmailWorker')
   19: 
   20: async function processQueue(): Promise<void> {
   21:   if (isProcessing) return
   22:   if (dbBackoff.shouldSkip()) return
   23:   isProcessing = true
   24:   let currentTask: HostNotificationEmailTask | null = null
   25: 
   26:   try {
   27:     currentTask = await claimNextHostNotificationEmailTask()
   28:     if (!currentTask) return
   29: 
   30:     console.log(`[HostNotifyEmailWorker] Sending queued email task ${currentTask.id} to ${currentTask.email}`)
   31: 
   32:     const result = await sendHostAnnouncementEmail(currentTask.email, {
   33:       username: currentTask.username,
   34:       hostName: currentTask.hostName,
   35:       title: currentTask.title,
   36:       content: currentTask.content
   37:     })
   38: 
   39:     if (result.success) {
   40:       await markHostNotificationEmailTaskSent(currentTask.id)
   41:       console.log(`[HostNotifyEmailWorker] Task ${currentTask.id} sent successfully`)
   42:       return
   43:     }
   44: 
   45:     const errorMessage = result.error || 'Unknown email error'
   46:     await retryOrFailHostNotificationEmailTask(currentTask.id, currentTask.retryCount, errorMessage)
   47:     console.error(`[HostNotifyEmailWorker] Task ${currentTask.id} failed: ${errorMessage}`)
   48:   } catch (error) {
   49:     const errorMessage = error instanceof Error ? error.message : String(error)
   50:     console.error('[HostNotifyEmailWorker] Queue processing error:', error)
   51:     dbBackoff.arm(error)
   52: 
   53:     if (currentTask) {
   54:       try {
   55:         await retryOrFailHostNotificationEmailTask(currentTask.id, currentTask.retryCount, errorMessage)
   56:       } catch (retryError) {
   57:         console.error(`[HostNotifyEmailWorker] Failed to recover task ${currentTask.id}:`, retryError)
   58:       }
   59:     }
   60:   } finally {
   61:     isProcessing = false
   62:   }
   63: }
   64: 
   65: export {
   66:   cleanupStaleHostNotificationEmailTasks,
   67:   cleanupTimeoutHostNotificationEmailTasks
   68: }
   69: 
   70: export function startHostNotificationEmailWorker(): void {
   71:   if (workerInterval) {
   72:     console.warn('[HostNotifyEmailWorker] Worker already running')
   73:     return
   74:   }
   75: 
   76:   console.log('[HostNotifyEmailWorker] Starting worker')
   77:   workerInterval = setInterval(() => {
   78:     processQueue().catch(err => {
   79:       console.error('[HostNotifyEmailWorker] Worker tick failed:', err)
   80:     })
   81:   }, POLL_INTERVAL)
   82:   timeoutCheckInterval = setInterval(() => {
   83:     if (dbBackoff.shouldSkip()) return
   84:     cleanupTimeoutHostNotificationEmailTasks().then(count => {
   85:       if (count > 0) {
   86:         console.warn(`[HostNotifyEmailWorker] Requeued ${count} timed-out task(s)`)
   87:       }
   88:     }).catch(err => {
   89:       console.error('[HostNotifyEmailWorker] Timeout cleanup failed:', err)
   90:       dbBackoff.arm(err)
   91:     })
   92:   }, TIMEOUT_CHECK_INTERVAL)
   93: 
   94:   processQueue().catch(err => {
   95:     console.error('[HostNotifyEmailWorker] Initial queue processing failed:', err)
   96:   })
   97: }
   98: 
   99: export function stopHostNotificationEmailWorker(): void {
  100:   if (!workerInterval) return
  101: 
  102:   clearInterval(workerInterval)
  103:   workerInterval = null
  104:   if (timeoutCheckInterval) {
  105:     clearInterval(timeoutCheckInterval)
  106:     timeoutCheckInterval = null
  107:   }
  108:   console.log('[HostNotifyEmailWorker] Worker stopped')
  109: }

