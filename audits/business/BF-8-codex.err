  451:   const existing = await prisma.flashSaleCampaign.findUnique({ where: { id }, include: { items: true } })
  452:   if (!existing) return null
  453: 
  454:   const nextStartAt = input.startAt ?? existing.startAt
  455:   const nextEndAt = input.endAt ?? existing.endAt
  456:   if (nextEndAt <= nextStartAt) {
  457:     throw new FlashSaleError('FLASH_SALE_INVALID_TIME', '结束时间必须晚于开始时间')
  458:   }
