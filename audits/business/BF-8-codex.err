   61: function serializePlan(plan: {
   62:   id: number
   63:   name: string
   64:   description: string | null
   65:   cpu: number
   66:   memory: number
   67:   disk: number
   68:   trafficLimit: bigint
   69:   trafficLimitSpeed: string
   70:   price: unknown
   71:   billingCycle: number
   72:   isActive: boolean
