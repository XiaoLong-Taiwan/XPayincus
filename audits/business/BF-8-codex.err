  322:     const id = parsePositiveId((request.params as { id: string }).id)
  323:     if (id === null) return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
  324: 
  325:     const result = await giftCardDb.disableGiftCard(id)
  326:     if (result.count === 0) return reply.code(404).send(apiError(ErrorCode.GIFT_CARD_NOT_FOUND))
  327:     return { success: true }
