  165:   }
  166: }
  167: 
  168: async function createCampaign(): Promise<void> {
  169:   const validItems = form.value.items.filter(item => item.packagePlanId)
  170:   if (!form.value.name.trim() || !form.value.startAt || !form.value.endAt || validItems.length === 0) {
  171:     toast.warning('请填写活动名称、时间和至少一个秒杀商品')
  172:     return
  173:   }
  174:   const invalidItem = validItems.some(item =>
  175:     item.flashPrice < 0 ||
  176:     item.totalStock < 1 ||
  177:     item.perUserLimit < 1
  178:   )
  179:   if (invalidItem) {
  180:     toast.warning('秒杀商品的价格、库存和限购配置无效')
  181:     return
  182:   }
  183:   const duplicatePlan = new Set(validItems.map(item => item.packagePlanId)).size !== validItems.length
  184:   if (duplicatePlan) {
  185:     toast.warning('同一活动中不能重复添加相同方案')
  186:     return
  187:   }
  188: 
  189:   saving.value = true
  190:   try {
  191:     const campaignMaxPerUser = Math.max(1, ...validItems.map(item => Number(item.perUserLimit || 1)))
  192:     const response = await api.flashSales.create({
  193:       name: form.value.name.trim(),
  194:       description: form.value.description.trim() || null,
  195:       status: form.value.status,
  196:       startAt: new Date(form.value.startAt).toISOString(),
  197:       endAt: new Date(form.value.endAt).toISOString(),
  198:       requireTurnstile: form.value.requireTurnstile,
  199:       minAccountAgeHours: Number(form.value.minAccountAgeHours || 0),
  200:       requireEmail: form.value.requireEmail,
  201:       blockRiskRestricted: form.value.blockRiskRestricted,
  202:       maxPerUser: campaignMaxPerUser,
  203:       notes: form.value.notes.trim() || null,
  204:       items: validItems.map((item, index) => ({
  205:         packagePlanId: item.packagePlanId!,
  206:         flashPrice: Math.round(Number(item.flashPrice) * 100),
  207:         totalStock: Number(item.totalStock),
  208:         perUserLimit: Number(item.perUserLimit),
  209:         allowCoupon: item.allowCoupon,
  210:         allowAff: item.allowAff,
  211:         sortOrder: index
  212:       }))
  213:     })
  214:     toast.success('秒杀活动已创建')
  215:     selectedCampaignId.value = response.campaign.id
  216:     resetForm()
  217:     await loadCampaigns()
  218:   } catch (err: any) {
  219:     toast.error(err?.message || '创建秒杀活动失败')
  220:   } finally {
  400: </script>
