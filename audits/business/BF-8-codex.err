  720: export async function claimFlashSalePurchaseInTransaction(tx: Prisma.TransactionClient, input: {
  721:   itemId: number
  722:   userId: number
  723:   packageId: number
  724:   planId: number
  725:   instanceId: number
  726:   amount: number
  727:   balanceLogId?: number | null
  728:   billingRecordId?: number | null
  729:   idempotencyKey: string
  730:   metadata?: Prisma.InputJsonValue
  731: }) {
  732:   await advisoryTransactionLock(tx, FLASH_SALE_ITEM_LOCK_NAMESPACE, input.itemId)
  733: 
  734:   const item = await tx.flashSaleItem.findUnique({
  735:     where: { id: input.itemId },
  736:     include: {
  737:       campaign: true,
  738:       packagePlan: true
  739:     }
  740:   })
  741:   if (!item) {
  742:     throw new FlashSaleError('FLASH_SALE_ITEM_NOT_FOUND', '秒杀商品不存在', 404)
  743:   }
  744:   const now = new Date()
  745:   if (item.packagePlanId !== input.planId || item.packagePlan.packageId !== input.packageId) {
  746:     throw new FlashSaleError('FLASH_SALE_PLAN_MISMATCH', '秒杀商品与当前套餐方案不匹配')
  747:   }
  748:   if (item.campaign.status !== 'active' || now < item.campaign.startAt || now > item.campaign.endAt) {
  749:     throw new FlashSaleError('FLASH_SALE_NOT_ACTIVE', '秒杀活动未开始或已结束')
  750:   }
  751:   if (remainingStock(item) <= 0) {
  752:     throw new FlashSaleError('FLASH_SALE_SOLD_OUT', '秒杀库存已抢完', 409)
  753:   }
  754: 
  755:   const perUserLimit = Math.max(1, Math.min(item.perUserLimit, item.campaign.maxPerUser || item.perUserLimit))
  756:   const purchasedCount = await tx.flashSaleReservation.count({
  757:     where: {
  758:       itemId: item.id,
  759:       userId: input.userId,
  760:       status: { in: ACTIVE_PURCHASE_STATUSES }
  761:     }
  762:   })
  763:   if (purchasedCount >= perUserLimit) {
  764:     throw new FlashSaleError('FLASH_SALE_USER_LIMIT_REACHED', `每个账号限购 ${perUserLimit} 台`, 409)
  765:   }
  766: 
  767:   const reservation = await tx.flashSaleReservation.create({
  768:     data: {
  769:       campaignId: item.campaignId,
  770:       itemId: item.id,
  771:       userId: input.userId,
  772:       instanceId: input.instanceId,
  773:       status: 'delivering',
  774:       amount: input.amount,
  775:       balanceLogId: input.balanceLogId ?? null,
  776:       billingRecordId: input.billingRecordId ?? null,
  777:       idempotencyKey: input.idempotencyKey,
  778:       metadata: input.metadata ?? {},
  779:       paidAt: now
  780:     }
  781:   })
  782: 
  783:   await tx.flashSaleItem.update({
  784:     where: { id: item.id },
  785:     data: {
  786:       soldCount: { increment: 1 }
  787:     }
  788:   })
  789: 
  790:   return reservation
  791: }
  792: 
  793: export async function markFlashSaleDelivered(instanceId: number): Promise<void> {
  794:   await prisma.$transaction(async (tx) => {
  795:     const reservation = await tx.flashSaleReservation.findFirst({
  796:       where: { instanceId, status: { in: ['paid', 'delivering'] } },
  797:       orderBy: { createdAt: 'desc' }
  798:     })
  799:     if (!reservation) return
  800:     await tx.flashSaleReservation.update({
  801:       where: { id: reservation.id },
  802:       data: {
  803:         status: 'delivered',
  804:         deliveredAt: new Date()
  805:       }
  806:     })
  807:     await tx.flashSaleItem.update({
  808:       where: { id: reservation.itemId },
  809:       data: {
  810:         deliveredCount: { increment: 1 }
  811:       }
  812:     })
  813:   })
  814: }
  815: 
  816: export async function markFlashSaleFailed(instanceId: number, reason: string, refunded: boolean): Promise<void> {
  817:   await prisma.$transaction(async (tx) => {
  818:     const reservation = await tx.flashSaleReservation.findFirst({
  819:       where: { instanceId, status: { in: ['paid', 'delivering'] } },
  820:       orderBy: { createdAt: 'desc' }
  821:     })
  822:     if (!reservation) return
  823: 
  824:     await tx.flashSaleReservation.update({
  825:       where: { id: reservation.id },
  826:       data: {
  827:         status: refunded ? 'refunded' : 'failed',
  828:         failureReason: reason.slice(0, 1000),
  829:         refundedAt: refunded ? new Date() : null
  830:       }
  831:     })
  832:     await tx.flashSaleItem.update({
  833:       where: { id: reservation.itemId },
  834:       data: {
  835:         failedCount: { increment: 1 },
  836:         soldCount: { decrement: 1 }
  837:       }
  838:     })
  839:   })
  840: }

