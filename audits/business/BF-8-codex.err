  344: export async function createFlashSaleCampaign(input: {
  345:   name: string
  346:   description?: string | null
  347:   status?: FlashSaleCampaignStatus
  348:   startAt: Date
  349:   endAt: Date
  350:   requireTurnstile?: boolean
  351:   minAccountAgeHours?: number
  352:   requireEmail?: boolean
  353:   blockRiskRestricted?: boolean
  354:   maxPerUser?: number
  355:   notes?: string | null
  356:   items: Array<{
  357:     packagePlanId: number
  358:     flashPrice: number
  359:     totalStock: number
  360:     perUserLimit?: number
  361:     allowCoupon?: boolean
  362:     allowAff?: boolean
  363:     sortOrder?: number
  364:   }>
  365:   actorUserId: number
  366: }) {
  367:   if (input.endAt <= input.startAt) {
  368:     throw new FlashSaleError('FLASH_SALE_INVALID_TIME', '结束时间必须晚于开始时间')
  369:   }
  370:   if (input.items.length === 0) {
  371:     throw new FlashSaleError('FLASH_SALE_ITEM_REQUIRED', '至少需要一个秒杀商品')
  372:   }
  373: 
  374:   const plans = await prisma.packagePlan.findMany({
  375:     where: { id: { in: input.items.map(item => item.packagePlanId) } },
  376:     select: { id: true, price: true }
  377:   })
  378:   const planById = new Map(plans.map(plan => [plan.id, plan]))
  379: 
  380:   const campaign = await prisma.$transaction(async (tx) => {
  381:     const created = await tx.flashSaleCampaign.create({
  382:       data: {
  383:         name: input.name,
  384:         description: input.description ?? null,
  385:         status: input.status ?? 'draft',
  386:         startAt: input.startAt,
  387:         endAt: input.endAt,
  388:         requireTurnstile: input.requireTurnstile ?? true,
  389:         minAccountAgeHours: input.minAccountAgeHours ?? 0,
  390:         requireEmail: input.requireEmail ?? false,
  391:         blockRiskRestricted: input.blockRiskRestricted ?? true,
  392:         maxPerUser: input.maxPerUser ?? 1,
  393:         notes: input.notes ?? null,
  394:         createdByUserId: input.actorUserId,
  395:         items: {
  396:           create: input.items.map((item) => {
  397:             const plan = planById.get(item.packagePlanId)
  398:             if (!plan) {
  399:               throw new FlashSaleError('FLASH_SALE_PLAN_NOT_FOUND', `方案 #${item.packagePlanId} 不存在`)
  400:             }
  401:             if (!Number.isFinite(item.flashPrice) || item.flashPrice < 0) {
  402:               throw new FlashSaleError('FLASH_SALE_INVALID_PRICE', '秒杀价无效')
  403:             }
  404:             if (!Number.isInteger(item.totalStock) || item.totalStock < 1) {
  405:               throw new FlashSaleError('FLASH_SALE_INVALID_STOCK', '库存必须大于 0')
  406:             }
  407:             return {
  408:               packagePlanId: item.packagePlanId,
  409:               flashPrice: item.flashPrice,
  410:               originalPriceSnapshot: plan.price,
  411:               totalStock: item.totalStock,
  412:               perUserLimit: item.perUserLimit ?? input.maxPerUser ?? 1,
  413:               allowCoupon: item.allowCoupon ?? false,
  414:               allowAff: item.allowAff ?? false,
  415:               sortOrder: item.sortOrder ?? 0
  416:             }
  417:           })
  418:         }
  419:       }
  420:     })
  421: 
  422:     await tx.flashSaleAuditLog.create({
  423:       data: {
  424:         campaignId: created.id,
  425:         actorUserId: input.actorUserId,
  426:         action: 'create',
  427:         afterData: input as unknown as Prisma.InputJsonValue
  428:       }
  429:     })
  430: 
  431:     return created
  432:   })
  433: 
  434:   return getAdminFlashSale(campaign.id)
  435: }
