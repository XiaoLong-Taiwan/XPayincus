   52: function normalizeStatusForTime(status: FlashSaleCampaignStatus, startAt: Date, endAt: Date, now = new Date()) {
   53:   if (status === 'cancelled' || status === 'ended' || status === 'paused' || status === 'draft') {
   54:     return status
   55:   }
   56:   if (now < startAt) return 'scheduled'
   57:   if (now > endAt) return 'ended'
   58:   return 'active'
   59: }
