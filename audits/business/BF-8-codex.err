  189: export function normalizeFlashSaleListParams(params: {
  190:   page?: unknown
  191:   pageSize?: unknown
  192:   status?: unknown
  193: }) {
  194:   const status = typeof params.status === 'string' && params.status ? params.status as FlashSaleCampaignStatus : undefined
  195:   return {
  196:     page: clampPage(params.page),
  197:     pageSize: clampPageSize(params.pageSize),
  198:     status
  199:   }
  200: }
