   85:     id: plan.id,
   86:     name: plan.name,
   87:     description: plan.description,
   88:     cpu: plan.cpu,
   89:     memory: plan.memory,
   90:     disk: plan.disk,
   91:     trafficLimit: plan.trafficLimit.toString(),
   92:     trafficLimitSpeed: plan.trafficLimitSpeed,
   93:     price: toNumber(plan.price),
   94:     billingCycle: plan.billingCycle,
   95:     isActive: plan.isActive,
   96:     isSoldOut: plan.isSoldOut,
   97:     package: {
   98:       id: plan.package.id,
   99:       name: plan.package.name,
  100:       networkMode: plan.package.networkMode,
  101:       instanceType: plan.package.instanceType,
  102:       sourceType: plan.package.user?.role === 'admin' ? 'official' : 'market',
  103:       monthlyTrafficLimit: plan.package.monthlyTrafficLimit?.toString() ?? null,
  104:       hostCount: plan.package.packageHosts?.length ?? 0
