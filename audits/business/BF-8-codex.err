 3711: // ==================== 签到系统模型 ====================
 3712: 
 3713: // 兑换码类型枚举
 3714: enum RedeemCodeType {
 3715:   c // CPU
 3716:   r // 内存 (RAM)
 3717:   d // 硬盘 (Disk)
 3718:   t // 流量 (Traffic)
 3719:   p // 积分 (Points)
 3720: }
 3721: 
 3722: // 签到记录表
 3723: model CheckinRecord {
 3724:   id         Int            @id @default(autoincrement())
 3725:   userId     Int            @map("user_id")          // 签到用户（兑换码所有者）
 3726:   redeemCode String         @unique @map("redeem_code") // 兑换码
 3727:   codeType   RedeemCodeType @map("code_type")        // 兑换码类型
 3728:   codeValue  Int            @map("code_value")       // 兑换码数值
 3729:   expiresAt  DateTime       @map("expires_at")       // 过期时间（3小时）
 3730:   usedAt     DateTime?      @map("used_at")          // 使用时间
 3731:   usedBy     Int?           @map("used_by")          // 使用者ID
 3732:   usedFor    Int?           @map("used_for")         // 使用的实例ID
 3733:   createdAt  DateTime       @default(now()) @map("created_at")
 3734: 
 3735:   user       User      @relation("CheckinRecords", fields: [userId], references: [id], onDelete: Cascade)
 3736:   usedByUser User?     @relation("RedeemRecords", fields: [usedBy], references: [id], onDelete: SetNull)
 3737:   instance   Instance? @relation(fields: [usedFor], references: [id], onDelete: SetNull)
 3738: 
 3739:   @@index([userId])
 3740:   @@index([usedBy])
 3741:   @@index([expiresAt])
 3742:   @@map("checkin_records")
 3743: }
 3744: 
 3745: // 用户签到统计表
 3746: model CheckinStats {
 3747:   id                   Int       @id @default(autoincrement())
 3748:   userId               Int       @unique @map("user_id")
 3749:   lastCheckinDate      DateTime? @map("last_checkin_date")       // 最后签到日期
 3750:   lastRedeemDate       DateTime? @map("last_redeem_date")        // 最后兑换日期（签到码专用）
 3751:   consecutiveOthersUse Int       @default(0) @map("consecutive_others_use") // 连续被他人使用天数
 3752:   selfOnlyMode         Boolean   @default(false) @map("self_only_mode")     // 是否只能自己使用
 3753: 
 3754:   user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 3755: 
 3756:   @@map("checkin_stats")
 3757: }
 3758: 
 3759: // 每日积分签到记录
 3760: model DailyCheckin {
 3761:   id        Int      @id @default(autoincrement())
 3762:   userId    Int      @map("user_id")
 3763:   dateKey   String   @map("date_key")
 3764:   points    Int
 3765:   streakDays Int     @default(1) @map("streak_days")
 3766:   ipAddress String?  @map("ip_address")
 3767:   userAgent String?  @map("user_agent") @db.Text
 3768:   createdAt DateTime @default(now()) @map("created_at")
 3769: 
 3770:   user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 3771: 
 3772:   @@unique([userId, dateKey])
 3773:   @@index([userId, createdAt(sort: Desc)])
 3774:   @@index([dateKey, createdAt(sort: Desc)])
 3775:   @@map("daily_checkins")
