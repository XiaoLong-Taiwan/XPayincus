  100: /**
  101:  * 批量创建一次性兑换码
  102:  */
  103: export async function createRedeemCodeBatch(data: {
  104:   hostId: number
  105:   createdById: number
  106:   codeType: RedeemCodeType
  107:   codeValue: number
  108:   count: number
  109:   expiresAt?: Date | null
  110:   remark?: string
  111:   targetUserId?: number | null
  112: }): Promise<{ codes: string[]; batchId: string }> {
  113:   const codes: string[] = []
  114:   const createData = []
  115:   // 生成批次ID，同批次的兑换码每用户只能使用一张
  116:   const batchId = crypto.randomBytes(8).toString('hex')
  117: 
  118:   for (let i = 0; i < data.count; i++) {
  119:     const code = generateSystemCode()
  120:     codes.push(code)
  121:     createData.push({
  122:       code,
  123:       hostId: data.hostId,
  124:       createdById: data.createdById,
  125:       codeType: data.codeType,
  126:       codeValue: data.codeValue,
  127:       maxUses: 1,
  128:       expiresAt: data.expiresAt,
  129:       remark: data.remark,
  130:       batchId,
  131:       targetUserId: data.targetUserId ?? null
  132:     })
  133:   }
  134: 
  135:   await prisma.redeemCode.createMany({ data: createData })
  136:   return { codes, batchId }
  137: }
