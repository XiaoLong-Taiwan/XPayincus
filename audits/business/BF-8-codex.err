  172: /**
  173:  * 检查用户今日是否已兑换（使用北京时间 0 点刷新）
  174:  */
  175: export async function hasRedeemedToday(userId: number): Promise<boolean> {
  176:   const stats = await prisma.checkinStats.findUnique({
  177:     where: { userId }
  178:   })
  179:   
  180:   if (!stats?.lastRedeemDate) return false
  181:   
  182:   const todayMidnight = getBeijingMidnight()
  183:   const lastRedeemMidnight = toBeijingMidnight(stats.lastRedeemDate)
  184:   
  185:   return lastRedeemMidnight.getTime() >= todayMidnight.getTime()
  186: }
