  292:           <p class="mt-1 text-sm text-themed-muted">{{ t('giftCards.activeTotal', { amount: formatMoney(totalActiveValue) }) }}</p>
  293:         </div>
  294:         <select v-model="statusFilter" class="input w-full md:w-44" @change="loadCards">
  295:           <option v-for="item in statusOptions" :key="item.value" :value="item.value">{{ item.label }}</option>
  296:         </select>
  297:       </div>
  298: 
  299:       <div class="mt-5 space-y-3 lg:hidden">
  300:         <div v-for="card in cards" :key="card.id" class="rounded-lg border border-themed bg-themed-surface p-4">
