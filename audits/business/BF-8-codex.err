  422: /**
  423:  * 使用兑换码
  424:  * @param usedFor 实例ID，null 表示存入资源池
  425:  */
  426: export async function useRedeemCode(
  427:   recordId: number,
  428:   usedBy: number,
  429:   usedFor: number | null
  430: ): Promise<void> {
  431:   const now = new Date()
  432:   
  433:   await prisma.$transaction([
  434:     // 标记兑换码已使用
  435:     prisma.checkinRecord.update({
  436:       where: { id: recordId },
  437:       data: {
  438:         usedAt: now,
  439:         usedBy,
  440:         usedFor: usedFor // null 表示存入资源池
  441:       }
  442:     }),
  443:     // 更新兑换者的最后兑换日期
  444:     prisma.checkinStats.upsert({
  445:       where: { userId: usedBy },
  446:       update: { lastRedeemDate: now },
  447:       create: {
  448:         userId: usedBy,
  449:         lastRedeemDate: now
  450:       }
  451:     })
  452:   ])
  453: }
