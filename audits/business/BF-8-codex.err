  293: export async function getAdminFlashSaleReservations(campaignId: number, params: { page?: unknown; pageSize?: unknown }) {
  294:   const page = clampPage(params.page)
  295:   const pageSize = clampPageSize(params.pageSize)
  296:   const where = { campaignId }
  297:   const [total, reservations] = await Promise.all([
  298:     prisma.flashSaleReservation.count({ where }),
  299:     prisma.flashSaleReservation.findMany({
  300:       where,
  301:       include: {
  302:         user: { select: { id: true, username: true, email: true, avatarStyle: true, avatarBadgeId: true } },
  303:         instance: { select: { id: true, name: true, status: true } },
  304:         item: {
  305:           include: {
  306:             packagePlan: {
  307:               include: { package: true }
  308:             }
  309:           }
  310:         }
  311:       },
  312:       orderBy: { createdAt: 'desc' },
  313:       skip: (page - 1) * pageSize,
  314:       take: pageSize
  315:     })
  316:   ])
  317: 
  318:   return {
  319:     reservations: reservations.map((reservation) => ({
  320:       id: reservation.id,
  321:       campaignId: reservation.campaignId,
  322:       itemId: reservation.itemId,
  323:       userId: reservation.userId,
  324:       user: reservation.user,
  325:       instanceId: reservation.instanceId,
  326:       instance: reservation.instance,
  327:       status: reservation.status,
  328:       amount: toNumber(reservation.amount),
  329:       failureReason: reservation.failureReason,
  330:       paidAt: toIso(reservation.paidAt),
  331:       deliveredAt: toIso(reservation.deliveredAt),
  332:       refundedAt: toIso(reservation.refundedAt),
  333:       createdAt: reservation.createdAt.toISOString(),
  334:       updatedAt: reservation.updatedAt.toISOString(),
  335:       packageName: reservation.item.packagePlan.package.name,
  336:       planName: reservation.item.packagePlan.name
  337:     })),
  338:     total,
  339:     page,
  340:     pageSize
  341:   }
  342: }
