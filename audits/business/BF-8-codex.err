  269: export async function getAdminFlashSale(id: number) {
  270:   const campaign = await prisma.flashSaleCampaign.findUnique({
  271:     where: { id },
  272:     include: {
  273:       items: {
  274:         include: {
  275:           packagePlan: {
  276:             include: {
  277:                 package: {
  278:                   include: {
  279:                     user: { select: { role: true } },
  280:                     packageHosts: { select: { hostId: true } }
  281:                   }
  282:                 }
  283:             }
  284:           }
  285:         },
  286:         orderBy: [{ sortOrder: 'asc' }, { id: 'asc' }]
  287:       }
  288:     }
  289:   })
  290:   return campaign ? serializeCampaign(campaign) : null
  291: }
