 succeeded in 662ms:
    1: /**
    2:  * 系统兑换码管理路由
    3:  * 宿主机所有者可以管理其节点的兑换码
    4:  */
    5: 
    6: import type { FastifyInstance } from 'fastify'
    7: import * as db from '../db/index.js'
    8: import { createLog } from '../db/logs.js'
    9: import { apiError, ErrorCode } from '../lib/errors.js'
   10: import type { RedeemCodeType } from '@prisma/client'
   11: 
   12: const REDEEM_CODE_TYPES: RedeemCodeType[] = ['c', 'r', 'd', 't']
   13: const MAX_REDEEM_CODE_BATCH_COUNT = 100
   14: const MAX_REDEEM_CODE_MAX_USES = 1000
   15: const MAX_REDEEM_CODE_REMARK_LENGTH = 200
   16: 
   17: // 资源类型名称映射
   18: const CODE_TYPE_NAMES: Record<string, string> = {
   19:   c: 'CPU',
   20:   r: 'Memory',
   21:   d: 'Disk',
   22:   t: 'Traffic'
   23: }
   24: 
   25: // 资源单位映射
   26: const CODE_TYPE_UNITS: Record<string, string> = {
   27:   c: '%',
   28:   r: 'MB',
   29:   d: 'MB',
   30:   t: 'GB'
   31: }
   32: 
   33: function parsePositiveId(value: string): number | null {
   34:   if (!/^\d+$/.test(value)) {
   35:     return null
   36:   }
   37: 
   38:   const parsed = Number(value)
   39:   return Number.isSafeInteger(parsed) && parsed > 0 ? parsed : null
   40: }
   41: 
   42: function normalizePositiveUniqueIds(values: unknown[]): number[] | null {
   43:   const ids = new Set<number>()
   44: 
   45:   for (const value of values) {
   46:     if (typeof value !== 'number' || !Number.isSafeInteger(value) || value <= 0 || ids.has(value)) {
   47:       return null
   48:     }
   49:     ids.add(value)
   50:   }
   51: 
   52:   return Array.from(ids)
   53: }
   54: 
   55: function isPlainRecord(value: unknown): value is Record<string, unknown> {
   56:   return typeof value === 'object' && value !== null && !Array.isArray(value)
   57: }
   58: 
   59: function requireRedeemCodeInteger(value: unknown, field: string, min: number, max: number): number {
   60:   if (typeof value !== 'number' || !Number.isSafeInteger(value)) {
   61:     throw apiError(ErrorCode.INVALID_PARAMS, `${field} must be an integer`)
   62:   }
   63:   if (value < min || value > max) {
   64:     throw apiError(ErrorCode.INVALID_PARAMS, `${field} must be between ${min} and ${max}`)
   65:   }
   66:   return value
   67: }
   68: 
   69: function normalizeRedeemCodeType(value: unknown): RedeemCodeType {
   70:   if (typeof value !== 'string' || !REDEEM_CODE_TYPES.includes(value as RedeemCodeType)) {
   71:     throw apiError(ErrorCode.INVALID_PARAMS, 'Invalid redeem code type')
   72:   }
   73:   return value as RedeemCodeType
   74: }
   75: 
   76: function normalizeOptionalRedeemCodeRemark(value: unknown): string | undefined {
   77:   if (value === undefined) return undefined
   78:   if (typeof value !== 'string') {
   79:     throw apiError(ErrorCode.INVALID_PARAMS, 'Invalid remark')
   80:   }
   81:   const trimmed = value.trim()
   82:   if (trimmed.length > MAX_REDEEM_CODE_REMARK_LENGTH || /[\u0000-\u001F\u007F]/.test(trimmed)) {
   83:     throw apiError(ErrorCode.INVALID_PARAMS, 'Invalid remark')
   84:   }
   85:   return trimmed || undefined
   86: }
   87: 
   88: function normalizeOptionalExpiryDate(value: string | null | undefined): Date | null | undefined {
   89:   if (value === undefined) {
   90:     return undefined
   91:   }
   92:   if (value === null || value.trim() === '') {
   93:     return null
   94:   }
   95: 
   96:   const date = new Date(value)
   97:   return Number.isNaN(date.getTime()) ? undefined : date
   98: }
   99: 
  100: function normalizeRedeemCodeCreateBody(input: unknown): {
  101:   codeType: RedeemCodeType
  102:   codeValue: number
  103:   maxUses?: number
  104:   expiresAt?: string | null
  105:   remark?: string
  106:   batchCount?: number
  107: } {
  108:   if (!isPlainRecord(input)) {
  109:     throw apiError(ErrorCode.INVALID_PARAMS, 'Invalid request body')
  110:   }
  111: 
  112:   const codeType = normalizeRedeemCodeType(input.codeType)
  113:   const codeValueRange = db.CODE_VALUE_RANGES[codeType]
  114:   const codeValue = requireRedeemCodeInteger(input.codeValue, 'codeValue', codeValueRange.min, codeValueRange.max)
  115:   const maxUses = input.maxUses === undefined
  116:     ? undefined
  117:     : requireRedeemCodeInteger(input.maxUses, 'maxUses', 1, MAX_REDEEM_CODE_MAX_USES)
  118:   const batchCount = input.batchCount === undefined
  119:     ? undefined
  120:     : requireRedeemCodeInteger(input.batchCount, 'batchCount', 1, MAX_REDEEM_CODE_BATCH_COUNT)
  121:   if (input.expiresAt !== undefined && input.expiresAt !== null && typeof input.expiresAt !== 'string') {
  122:     throw apiError(ErrorCode.INVALID_PARAMS, 'Invalid expiry date')
  123:   }
  124: 
  125:   return {
  126:     codeType,
  127:     codeValue,
  128:     maxUses,
  129:     expiresAt: input.expiresAt as string | null | undefined,
  130:     remark: normalizeOptionalRedeemCodeRemark(input.remark),
  131:     batchCount
  132:   }
  133: }
  134: 
  135: function normalizeRedeemCodeUpdateBody(input: unknown): {
  136:   enabled?: boolean
  137:   remark?: string
  138:   maxUses?: number
  139:   expiresAt?: string | null
  140: } {
  141:   if (!isPlainRecord(input)) {
  142:     throw apiError(ErrorCode.INVALID_PARAMS, 'Invalid request body')
  143:   }
  144: 
  145:   if (input.enabled !== undefined && typeof input.enabled !== 'boolean') {
  146:     throw apiError(ErrorCode.INVALID_PARAMS, 'enabled must be a boolean')
  147:   }
  148:   if (input.expiresAt !== undefined && input.expiresAt !== null && typeof input.expiresAt !== 'string') {
  149:     throw apiError(ErrorCode.INVALID_PARAMS, 'Invalid expiry date')
  150:   }
  151: 
  152:   return {
  153:     enabled: input.enabled as boolean | undefined,
  154:     remark: normalizeOptionalRedeemCodeRemark(input.remark),
  155:     maxUses: input.maxUses === undefined
  156:       ? undefined
  157:       : requireRedeemCodeInteger(input.maxUses, 'maxUses', 1, MAX_REDEEM_CODE_MAX_USES),
  158:     expiresAt: input.expiresAt as string | null | undefined
  159:   }
  160: }
  161: 
  162: function normalizeRedeemCodeBatchDeleteBody(input: unknown): number[] | null {
  163:   if (!isPlainRecord(input) || !Array.isArray(input.ids) || input.ids.length === 0 || input.ids.length > 100) {
  164:     return null
  165:   }
  166:   return normalizePositiveUniqueIds(input.ids)
  167: }
  168: 
  169: export default async function redeemCodesRoutes(fastify: FastifyInstance) {
  170:   // ==================== 获取宿主机的兑换码列表 ====================
  171:   fastify.get<{
  172:     Params: { hostId: string }
  173:     Querystring: { limit?: number; offset?: number; enabled?: string }
  174:   }>('/hosts/:hostId/redeem-codes', {
  175:     onRequest: [fastify.authenticate],
  176:     schema: {
  177:       params: {
  178:         type: 'object',
  179:         required: ['hostId'],
  180:         properties: {
  181:           hostId: { type: 'string', pattern: '^\\d+$' }
  182:         }
  183:       },
  184:       querystring: {
  185:         type: 'object',
  186:         properties: {
  187:           limit: { type: 'integer', minimum: 1, maximum: 100, default: 50 },
  188:           offset: { type: 'integer', minimum: 0, default: 0 },
  189:           enabled: { type: 'string', enum: ['true', 'false'] }
  190:         }
  191:       }
  192:     }
  193:   }, async (request, reply) => {
  194:     const { user } = request
  195:     const hostId = parsePositiveId(request.params.hostId)
  196:     const { limit = 50, offset = 0, enabled } = request.query
  197: 
  198:     if (hostId === null) {
  199:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid host ID'))
  200:     }
  201: 
  202:     // 检查宿主机是否存在且属于当前用户
  203:     const host = await db.getHostById(hostId)
  204:     if (!host) {
  205:       return reply.code(404).send(apiError(ErrorCode.HOST_NOT_FOUND))
  206:     }
  207:     if (host.user_id !== user.id && user.role !== 'admin') {
  208:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
  209:     }
  210: 
  211:     const result = await db.getRedeemCodesByHost(hostId, {
  212:       limit,
  213:       offset,
  214:       enabled: enabled !== undefined ? enabled === 'true' : undefined
  215:     })
  216: 
  217:     return result
  218:   })
  219: 
  220:   // ==================== 创建兑换码 ====================
  221:   fastify.post<{
  222:     Params: { hostId: string }
  223:     Body: {
  224:       codeType: RedeemCodeType
  225:       codeValue: number
  226:       maxUses?: number
  227:       expiresAt?: string | null
  228:       remark?: string
  229:       batchCount?: number
  230:     }
  231:   }>('/hosts/:hostId/redeem-codes', {
  232:     onRequest: [fastify.authenticate],
  233:     schema: {
  234:       params: {
  235:         type: 'object',
  236:         required: ['hostId'],
  237:         properties: {
  238:           hostId: { type: 'string', pattern: '^\\d+$' }
  239:         }
  240:       },
  241:       body: {
  242:         type: 'object',
  243:         required: ['codeType', 'codeValue'],
  244:         properties: {
  245:           codeType: { type: 'string', enum: ['c', 'r', 'd', 't'] },
  246:           codeValue: { type: 'integer', minimum: 1 },
  247:           maxUses: { type: 'integer', minimum: 1, maximum: 1000 },
  248:           expiresAt: { type: ['string', 'null'] },
  249:           remark: { type: 'string', maxLength: 200 },
  250:           batchCount: { type: 'integer', minimum: 1, maximum: 100 }
  251:         }
  252:       }
  253:     }
  254:   }, async (request, reply) => {
  255:     const { user } = request
  256:     const hostId = parsePositiveId(request.params.hostId)
  257:     let body: ReturnType<typeof normalizeRedeemCodeCreateBody>
  258:     try {
  259:       body = normalizeRedeemCodeCreateBody(request.body)
  260:     } catch (error) {
  261:       return reply.code(400).send(error)
  262:     }
  263:     const { codeType, codeValue, maxUses, expiresAt, remark, batchCount } = body
  264: 
  265:     if (hostId === null) {
  266:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid host ID'))
  267:     }
  268: 
  269:     // 检查宿主机是否存在且属于当前用户
  270:     const host = await db.getHostById(hostId)
  271:     if (!host) {
  272:       return reply.code(404).send(apiError(ErrorCode.HOST_NOT_FOUND))
  273:     }
  274:     if (host.user_id !== user.id && user.role !== 'admin') {
  275:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
  276:     }
  277: 
  278:     const normalizedExpiresAt = normalizeOptionalExpiryDate(expiresAt)
  279:     if (normalizedExpiresAt === undefined && expiresAt !== undefined) {
  280:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid expiry date'))
  281:     }
  282:     const expiresAtDate = normalizedExpiresAt ?? null
  283: 
  284:     try {
  285:       if (batchCount && batchCount > 1) {
  286:         // 批量创建一次性兑换码
  287:         const { codes, batchId } = await db.createRedeemCodeBatch({
  288:           hostId,
  289:           createdById: user.id,
  290:           codeType: codeType as RedeemCodeType,
  291:           codeValue,
  292:           count: batchCount,
  293:           expiresAt: expiresAtDate,
  294:           remark
  295:         })
  296: 
  297:         const typeName = CODE_TYPE_NAMES[codeType] || codeType
  298:         const unit = CODE_TYPE_UNITS[codeType] || ''
  299:         await createLog(
  300:           user.id,
  301:           'redeem_code',
  302:           'batch_create',
  303:           `Created ${batchCount} redeem codes for host "${host.name}" (ID: ${hostId}): ${typeName} +${codeValue}${unit}, batch: ${batchId}`,
  304:           'success'
  305:         )
  306: 
  307:         return {
  308:           message: 'Batch created successfully',
  309:           codes,
  310:           batchId,
  311:           count: batchCount
  312:         }
  313:       } else {
  314:         // 创建单个兑换码（可多次使用）
  315:         const code = await db.createRedeemCode({
  316:           hostId,
  317:           createdById: user.id,
  318:           codeType: codeType as RedeemCodeType,
  319:           codeValue,
  320:           maxUses: maxUses ?? 1,
  321:           expiresAt: expiresAtDate,
  322:           remark
  323:         })
  324: 
  325:         const typeName = CODE_TYPE_NAMES[codeType] || codeType
  326:         const unit = CODE_TYPE_UNITS[codeType] || ''
  327:         await createLog(
  328:           user.id,
  329:           'redeem_code',
  330:           'create',
  331:           `Created redeem code for host "${host.name}" (ID: ${hostId}): ${typeName} +${codeValue}${unit}, max uses: ${maxUses ?? 1}`,
  332:           'success'
  333:         )
  334: 
  335:         return {
  336:           message: 'Created successfully',
  337:           code: code.code,
  338:           id: code.id
  339:         }
  340:       }
  341:     } catch (error) {
  342:       const errorMessage = error instanceof Error ? error.message : String(error)
  343:       await createLog(
  344:         user.id,
  345:         'redeem_code',
  346:         'create.failed',
  347:         `Failed to create redeem code for host (ID: ${hostId}): ${errorMessage}`,
  348:         'failed'
  349:       )
  350:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, errorMessage))
  351:     }
  352:   })
  353: 
  354:   // ==================== 更新兑换码 ====================
  355:   fastify.patch<{
  356:     Params: { hostId: string; codeId: string }
  357:     Body: {
  358:       enabled?: boolean
  359:       remark?: string
  360:       maxUses?: number
  361:       expiresAt?: string | null
  362:     }
  363:   }>('/hosts/:hostId/redeem-codes/:codeId', {
  364:     onRequest: [fastify.authenticate],
  365:     schema: {
  366:       params: {
  367:         type: 'object',
  368:         required: ['hostId', 'codeId'],
  369:         properties: {
  370:           hostId: { type: 'string', pattern: '^\\d+$' },
  371:           codeId: { type: 'string', pattern: '^\\d+$' }
  372:         }
  373:       },
  374:       body: {
  375:         type: 'object',
  376:         properties: {
  377:           enabled: { type: 'boolean' },
  378:           remark: { type: 'string', maxLength: 200 },
  379:           maxUses: { type: 'integer', minimum: 1, maximum: 1000 },
  380:           expiresAt: { type: ['string', 'null'] }
  381:         }
  382:       }
  383:     }
  384:   }, async (request, reply) => {
  385:     const { user } = request
  386:     const hostId = parsePositiveId(request.params.hostId)
  387:     const codeId = parsePositiveId(request.params.codeId)
  388:     let body: ReturnType<typeof normalizeRedeemCodeUpdateBody>
  389:     try {
  390:       body = normalizeRedeemCodeUpdateBody(request.body)
  391:     } catch (error) {
  392:       return reply.code(400).send(error)
  393:     }
  394:     const { enabled, remark, maxUses, expiresAt } = body
  395: 
  396:     if (hostId === null || codeId === null) {
  397:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid host or redeem code ID'))
  398:     }
  399: 
  400:     // 检查宿主机是否存在且属于当前用户
  401:     const host = await db.getHostById(hostId)
  402:     if (!host) {
  403:       return reply.code(404).send(apiError(ErrorCode.HOST_NOT_FOUND))
  404:     }
  405:     if (host.user_id !== user.id && user.role !== 'admin') {
  406:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
  407:     }
  408: 
  409:     try {
  410:       const expiresAtDate = normalizeOptionalExpiryDate(expiresAt)
  411:       if (expiresAtDate === undefined && expiresAt !== undefined) {
  412:         return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid expiry date'))
  413:       }
  414: 
  415:       const updated = await db.updateRedeemCodeForHost(hostId, codeId, {
  416:         enabled,
  417:         remark,
  418:         maxUses,
  419:         expiresAt: expiresAtDate
  420:       })
  421:       if (!updated) {
  422:         return reply.code(404).send(apiError(ErrorCode.REDEEM_CODE_NOT_FOUND))
  423:       }
  424: 
  425:       return { message: 'Updated successfully' }
  426:     } catch (error) {
  427:       const errorMessage = error instanceof Error ? error.message : String(error)
  428:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, errorMessage))
  429:     }
  430:   })
  431: 
  432:   // ==================== 删除兑换码 ====================
  433:   fastify.delete<{
  434:     Params: { hostId: string; codeId: string }
  435:   }>('/hosts/:hostId/redeem-codes/:codeId', {
  436:     onRequest: [fastify.authenticate],
  437:     schema: {
  438:       params: {
  439:         type: 'object',
  440:         required: ['hostId', 'codeId'],
  441:         properties: {
  442:           hostId: { type: 'string', pattern: '^\\d+$' },
  443:           codeId: { type: 'string', pattern: '^\\d+$' }
  444:         }
  445:       }
  446:     }
  447:   }, async (request, reply) => {
  448:     const { user } = request
  449:     const hostId = parsePositiveId(request.params.hostId)
  450:     const codeId = parsePositiveId(request.params.codeId)
  451: 
  452:     if (hostId === null || codeId === null) {
  453:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid host or redeem code ID'))
  454:     }
  455: 
  456:     // 检查宿主机是否存在且属于当前用户
  457:     const host = await db.getHostById(hostId)
  458:     if (!host) {
  459:       return reply.code(404).send(apiError(ErrorCode.HOST_NOT_FOUND))
  460:     }
  461:     if (host.user_id !== user.id && user.role !== 'admin') {
  462:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
  463:     }
  464: 
  465:     try {
  466:       const deleted = await db.deleteRedeemCodeForHost(hostId, codeId)
  467:       if (!deleted) {
  468:         return reply.code(404).send(apiError(ErrorCode.REDEEM_CODE_NOT_FOUND))
  469:       }
  470:       return { message: 'Deleted successfully' }
  471:     } catch (error) {
  472:       const errorMessage = error instanceof Error ? error.message : String(error)
  473:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, errorMessage))
  474:     }
  475:   })
  476: 
  477:   // ==================== 批量删除兑换码 ====================
  478:   fastify.post<{
  479:     Params: { hostId: string }
  480:     Body: { ids: number[] }
  481:   }>('/hosts/:hostId/redeem-codes/batch-delete', {
  482:     onRequest: [fastify.authenticate],
  483:     schema: {
  484:       params: {
  485:         type: 'object',
  486:         required: ['hostId'],
  487:         properties: {
  488:           hostId: { type: 'string', pattern: '^\\d+$' }
  489:         }
  490:       },
  491:       body: {
  492:         type: 'object',
  493:         required: ['ids'],
  494:         properties: {
  495:           ids: { type: 'array', items: { type: 'integer', minimum: 1 }, minItems: 1, maxItems: 100 }
  496:         }
  497:       }
  498:     }
  499:   }, async (request, reply) => {
  500:     const { user } = request
  501:     const hostId = parsePositiveId(request.params.hostId)
  502: 
  503:     if (hostId === null) {
  504:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid host ID'))
  505:     }
  506: 
  507:     const normalizedIds = normalizeRedeemCodeBatchDeleteBody(request.body)
  508:     if (!normalizedIds) {
  509:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid redeem code IDs'))
  510:     }
  511: 
  512:     // 检查宿主机是否存在且属于当前用户
  513:     const host = await db.getHostById(hostId)
  514:     if (!host) {
  515:       return reply.code(404).send(apiError(ErrorCode.HOST_NOT_FOUND))
  516:     }
  517:     if (host.user_id !== user.id && user.role !== 'admin') {
  518:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
  519:     }
  520: 
  521:     try {
  522:       const deletedCount = await db.deleteRedeemCodeBatchForHost(hostId, normalizedIds)
  523:       if (deletedCount !== normalizedIds.length) {
  524:         return reply.code(404).send(apiError(ErrorCode.REDEEM_CODE_NOT_FOUND))
