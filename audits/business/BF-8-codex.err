  455: /**
  456:  * 更新兑换码所有者的分享状态
  457:  */
  458: export async function updateOwnerShareStatus(
  459:   ownerId: number,
  460:   usedBySelf: boolean
  461: ): Promise<void> {
  462:   const stats = await prisma.checkinStats.findUnique({
  463:     where: { userId: ownerId }
  464:   })
  465: 
  466:   if (usedBySelf) {
  467:     // 自己使用了兑换码，重置连续计数和限制模式
  468:     await prisma.checkinStats.upsert({
  469:       where: { userId: ownerId },
  470:       update: {
  471:         consecutiveOthersUse: 0,
  472:         selfOnlyMode: false
  473:       },
  474:       create: {
  475:         userId: ownerId,
  476:         consecutiveOthersUse: 0,
  477:         selfOnlyMode: false
  478:       }
  479:     })
  480:   } else {
  481:     // 他人使用了兑换码
  482:     const currentCount = stats?.consecutiveOthersUse ?? 0
  483:     const newCount = currentCount + 1
  484:     const selfOnlyMode = newCount >= 2
  485: 
  486:     await prisma.checkinStats.upsert({
  487:       where: { userId: ownerId },
  488:       update: {
  489:         consecutiveOthersUse: newCount,
  490:         selfOnlyMode
  491:       },
  492:       create: {
  493:         userId: ownerId,
  494:         consecutiveOthersUse: newCount,
  495:         selfOnlyMode
