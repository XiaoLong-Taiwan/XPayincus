   24: function toNumber(value: unknown): number {
   25:   if (value === null || value === undefined) return 0
   26:   return Number(value)
   27: }
   28: 
   29: function toIso(value: Date | null | undefined): string | null {
   30:   return value ? value.toISOString() : null
   31: }
   32: 
   33: function remainingStock(item: {
   34:   totalStock: number
   35:   soldCount: number
   36:   reservedCount: number
   37: }): number {
   38:   return Math.max(0, item.totalStock - item.soldCount - item.reservedCount)
   39: }
   40: 
   41: function clampPage(value: unknown, fallback = 1): number {
   42:   const parsed = Number(value)
   43:   return Number.isInteger(parsed) && parsed > 0 ? parsed : fallback
   44: }
   45: 
   46: function clampPageSize(value: unknown, fallback = 20): number {
   47:   const parsed = Number(value)
   48:   if (!Number.isInteger(parsed) || parsed <= 0) return fallback
   49:   return Math.min(parsed, ADMIN_LIST_PAGE_SIZE_MAX)
   50: }
