  197: /**
  198:  * 创建或更新用户签到统计
  199:  */
  200: export async function upsertCheckinStats(userId: number, data: {
  201:   lastCheckinDate?: Date
  202:   lastRedeemDate?: Date
  203:   consecutiveOthersUse?: number
  204:   selfOnlyMode?: boolean
  205: }) {
  206:   return prisma.checkinStats.upsert({
  207:     where: { userId },
  208:     update: data,
  209:     create: {
  210:       userId,
  211:       ...data
  212:     }
  213:   })
  214: }
