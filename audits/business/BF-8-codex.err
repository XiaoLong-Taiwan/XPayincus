    1: /**
    2:  * 签到系统数据库操作
    3:  * 使用 Prisma ORM
    4:  */
    5: 
    6: import { Prisma } from '@prisma/client'
    7: import { prisma } from './prisma.js'
    8: import type { RedeemCodeType } from '@prisma/client'
    9: import { getSystemConfigBoolean, getSystemConfigNumber, updateSystemConfigs } from './system-config.js'
   10: import {
   11:   USER_POINTS_LOCK_NAMESPACE,
   12:   USER_RESOURCE_POOL_LOCK_NAMESPACE,
   13:   advisoryTransactionLock
   14: } from './advisory-locks.js'
   15: 
   16: // 各类型可选数值
   17: const CODE_VALUES: Record<RedeemCodeType, number[]> = {
   18:   c: [1, 2, 3, 5],             // CPU: 1-5%
   19:   r: [2, 4, 6, 12],            // 内存: 2/4/6/12 MB
   20:   d: [16, 32, 64, 128],        // 硬盘: 16/32/64/128 MB
   21:   t: [1, 2, 3, 5],             // 流量: 1/2/3/5 GB
   22:   p: [100, 300, 500, 1000]     // 积分: 100/300/500/1000
   23: }
   24: 
   25: // 资源类型列表（积分通过固定奖励发放，不走随机）
   26: const CODE_TYPES: RedeemCodeType[] = ['c', 'r', 'd', 't']
   27: const CHECKIN_MIN_POINTS_DEFAULT = 1
   28: const CHECKIN_MAX_POINTS_DEFAULT = 500
   29: const CHECKIN_MAX_POINTS_LIMIT = 100_000
   30: 
   31: export interface DailyCheckinSettings {
   32:   enabled: boolean
   33:   minPoints: number
   34:   maxPoints: number
   35:   requireInstance: boolean
   36: }
   37: 
   38: export interface DailyCheckinMeta {
   39:   ipAddress?: string | null
   40:   userAgent?: string | null
   41: }
   42: 
   43: function clampCheckinPoints(value: number, fallback: number): number {
   44:   if (!Number.isSafeInteger(value)) return fallback
   45:   return Math.min(Math.max(value, 1), CHECKIN_MAX_POINTS_LIMIT)
   46: }
   47: 
   48: function normalizeCheckinSettings(settings: DailyCheckinSettings): DailyCheckinSettings {
   49:   const minPoints = clampCheckinPoints(settings.minPoints, CHECKIN_MIN_POINTS_DEFAULT)
   50:   const maxPoints = Math.max(
   51:     minPoints,
   52:     clampCheckinPoints(settings.maxPoints, CHECKIN_MAX_POINTS_DEFAULT)
   53:   )
   54: 
   55:   return {
   56:     enabled: settings.enabled,
   57:     minPoints,
   58:     maxPoints,
   59:     requireInstance: settings.requireInstance
   60:   }
   61: }
   62: 
   63: function randomizePoints(minPoints: number, maxPoints: number): number {
   64:   return Math.floor(Math.random() * (maxPoints - minPoints + 1)) + minPoints
   65: }
   66: 
   67: /**
   68:  * 随机选择资源类型和数值
   69:  */
   70: function randomizeReward(): { type: RedeemCodeType; value: number } {
   71:   const type = CODE_TYPES[Math.floor(Math.random() * CODE_TYPES.length)]
   72:   const values = CODE_VALUES[type]
   73:   const value = values[Math.floor(Math.random() * values.length)]
   74:   return { type, value }
   75: }
  150:  * 检查用户今日是否已签到（使用北京时间 0 点刷新）
