  202: export async function listPublicFlashSales() {
  203:   const now = new Date()
  204:   const campaigns = await prisma.flashSaleCampaign.findMany({
  205:     where: {
  206:       status: { in: ['scheduled', 'active', 'paused'] },
  207:       endAt: { gt: now }
  208:     },
  209:     include: {
  210:       items: {
  211:         include: {
  212:           packagePlan: {
  213:             include: {
  214:               package: {
  215:                 include: {
  216:                   user: { select: { role: true } },
  217:                   packageHosts: { select: { hostId: true } }
  218:                 }
  219:               }
  220:             }
  221:           }
  222:         },
  223:         orderBy: [{ sortOrder: 'asc' }, { id: 'asc' }]
  224:       }
  225:     },
  226:     orderBy: [{ startAt: 'asc' }, { id: 'asc' }]
  227:   })
  228: 
  229:   return { campaigns: campaigns.map(serializeCampaign) }
  230: }
