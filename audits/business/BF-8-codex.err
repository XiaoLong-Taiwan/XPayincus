  433: /**
  434:  * 更新指定宿主机下的兑换码。
  435:  */
  436: export async function updateRedeemCodeForHost(
  437:   hostId: number,
  438:   id: number,
  439:   data: {
  440:     enabled?: boolean
  441:     remark?: string
  442:     maxUses?: number
  443:     expiresAt?: Date | null
  444:   }
  445: ): Promise<boolean> {
  446:   const result = await prisma.redeemCode.updateMany({
  447:     where: { id, hostId },
  448:     data
  449:   })
  450: 
  451:   return result.count > 0
  452: }
  453: 
  454: /**
  455:  * 删除指定宿主机下的兑换码。
  456:  */
  457: export async function deleteRedeemCodeForHost(hostId: number, id: number): Promise<boolean> {
  458:   const result = await prisma.redeemCode.deleteMany({
  459:     where: { id, hostId }
  460:   })
