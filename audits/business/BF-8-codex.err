  223:         campaignId: reservation.campaignId,
  224:         campaignName: reservation.campaign.name,
  225:         itemId: reservation.itemId,
  226:         packageName: reservation.item.packagePlan.package.name,
  227:         planName: reservation.item.packagePlan.name,
