 5043: enum GiftCardStatus {
 5044:   active
 5045:   used
 5046:   disabled
 5047:   expired
 5048: }
 5049: 
 5050: model GiftCard {
 5051:   id           Int            @id @default(autoincrement())
 5052:   code         String         @unique                        // gc- 前缀 + 24 位 base64url 随机字符
 5053:   faceValue    Decimal        @map("face_value") @db.Decimal(10, 2)  // 面值（CNY）
 5054:   balanceValue Decimal        @map("balance_value") @db.Decimal(10, 2) // 充值到账金额
 5055:   status       GiftCardStatus @default(active)
 5056:   createdById  Int?           @map("created_by_id")    // 创建者（null=管理员控制台生成）
 5057:   ownerId      Int?           @map("owner_id")         // 持有者（用户用余额生成时有值）
 5058:   usedById     Int?           @map("used_by_id")       // 兑换使用者
 5059:   usedAt       DateTime?      @map("used_at")
 5060:   expiresAt    DateTime?      @map("expires_at")       // 过期时间，null=永不过期
 5061:   remark       String?
 5062:   batchId      String?        @map("batch_id")         // 批量生成批次
 5063:   createdAt    DateTime       @default(now()) @map("created_at")
 5064: 
 5065:   createdBy User?  @relation("GiftCardsCreated", fields: [createdById], references: [id])
 5066:   owner     User?  @relation("GiftCardsOwner", fields: [ownerId], references: [id])
 5067:   usedBy    User?  @relation("GiftCardsUsedBy", fields: [usedById], references: [id])
 5068: 
 5069:   @@index([status])
 5070:   @@index([batchId])
 5071:   @@index([createdById])
 5072:   @@index([ownerId])
 5073:   @@index([usedById])
 5074:   @@map("gift_cards")
 5075: }

