    5: 
    6: import { prisma } from './prisma.js'
    7: import type { RedeemCodeType } from '@prisma/client'
    8: import { Prisma } from '@prisma/client'
    9: import crypto from 'crypto'
   10: import { INSTANCE_OPERATION_LOCK_NAMESPACE, REDEEM_CODE_LOCK_NAMESPACE, advisoryTransactionLock, tryAdvisoryTransactionLock } from './advisory-locks.js'
   11: 
   12: // 系统兑换码前缀
   13: const SYSTEM_CODE_PREFIX = 'h'
   14: const REDEEM_CODE_LIST_MAX_LIMIT = 100
   15: 
   16: function clampRedeemCodeListBounds(limit: number | undefined, offset: number | undefined, defaultLimit: number): {
   17:   limit: number
   18:   offset: number
   19: } {
   20:   return {
   21:     limit: Number.isInteger(limit) && limit !== undefined
   22:       ? Math.min(Math.max(limit, 1), REDEEM_CODE_LIST_MAX_LIMIT)
   23:       : defaultLimit,
   24:     offset: Number.isInteger(offset) && offset !== undefined && offset >= 0 ? offset : 0
   25:   }
   26: }
   27: 
   28: // 签到系统使用的固定可选数值（不要修改）
   29: export const CODE_VALUES: Record<RedeemCodeType, number[]> = {
   30:   c: [1, 2, 3, 5],             // CPU: 1-5%
   31:   r: [2, 4, 6, 12],            // 内存: 2/4/6/12 MB
   32:   d: [16, 32, 64, 128],        // 硬盘: 16/32/64/128 MB
   33:   t: [1, 2, 3, 5],             // 流量: 1/2/3/5 GB
   34:   p: [100, 300, 500, 1000]     // 积分: 100/300/500/1000（仅签到使用）
   35: }
   36: 
   37: // 宿主机兑换码的资源范围限制（允许用户自定义任意值）
   38: export const CODE_VALUE_RANGES: Record<RedeemCodeType, { min: number; max: number; unit: string }> = {
   39:   c: { min: 1, max: 100, unit: '%' },        // CPU: 1-100%
   40:   r: { min: 1, max: 65536, unit: 'MB' },     // 内存: 1MB - 64GB
   41:   d: { min: 1, max: 1048576, unit: 'MB' },   // 硬盘: 1MB - 1TB
   42:   t: { min: 1, max: 10240, unit: 'GB' },     // 流量: 1GB - 10TB
   43:   p: { min: 1, max: 100000, unit: '' }       // 积分: 1-100000（保留，宿主机不使用）
   44: }
   45: 
   46: /**
   47:  * 验证兑换码数值是否在允许范围内（宿主机兑换码使用）
   48:  */
   49: export function isValidCodeValue(codeType: RedeemCodeType, value: number): boolean {
   50:   const range = CODE_VALUE_RANGES[codeType]
   51:   if (!range) return false
   52:   return Number.isInteger(value) && value >= range.min && value <= range.max
   53: }
   54: 
   55: /**
   56:  * 生成系统兑换码
   57:  */
   58: function generateSystemCode(): string {
   59:   const randomPart = crypto.randomBytes(12).toString('base64url').slice(0, 18)
   60:   return `${SYSTEM_CODE_PREFIX}-${randomPart}`
   61: }
   62: 
   63: /**
   64:  * 判断兑换码是否为系统码（非签到码）
   65:  */
   66: export function isSystemCode(code: string): boolean {
   67:   return code.startsWith(`${SYSTEM_CODE_PREFIX}-`)
   68: }
   69: 
   70: /**
   71:  * 创建系统兑换码
   72:  */
   73: export async function createRedeemCode(data: {
   74:   hostId: number
   75:   createdById: number
   76:   codeType: RedeemCodeType
   77:   codeValue: number
   78:   maxUses?: number
   79:   expiresAt?: Date | null
   80:   remark?: string
   81:   targetUserId?: number | null
   82: }) {
   83:   const code = generateSystemCode()
   84: 
   85:   return prisma.redeemCode.create({
   86:     data: {
   87:       code,
   88:       hostId: data.hostId,
   89:       createdById: data.createdById,
   90:       codeType: data.codeType,
   91:       codeValue: data.codeValue,
   92:       maxUses: data.maxUses ?? 1,
   93:       expiresAt: data.expiresAt,
   94:       remark: data.remark,
   95:       targetUserId: data.targetUserId ?? null
   96:     }
   97:   })
   98: }
