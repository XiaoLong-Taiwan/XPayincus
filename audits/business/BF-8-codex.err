  335:               <th class="py-3 pr-4">{{ t('giftCards.expiresAt') }}</th>
  336:               <th class="py-3 pr-4">{{ t('giftCards.action') }}</th>
  337:             </tr>
  338:           </thead>
  339:           <tbody>
