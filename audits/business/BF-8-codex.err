  258:             action="gift_card"
  259:             @verify="onTurnstileVerify"
  260:             @expire="onTurnstileExpire"
  261:             @error="onTurnstileError"
  262:           />
  263:         </div>
  264:       </section>
  265: 
  266:       <section class="card p-6">
  267:         <h2 class="text-base font-semibold text-themed">{{ t('giftCards.redeemTitle') }}</h2>
  268:         <div class="mt-4 flex flex-col gap-3 sm:flex-row">
  269:           <input v-model="redeemCode" class="input flex-1 font-mono" :placeholder="t('giftCards.redeemPlaceholder')" />
  270:           <button class="btn-primary" :disabled="redeeming || !redeemCode.trim()" @click="redeemGiftCard">
  271:             {{ redeeming ? t('giftCards.redeeming') : t('giftCards.redeem') }}
  272:           </button>
  273:         </div>
  274:       </section>
  275: 
  276:       <section class="card p-6">
  277:         <h2 class="text-base font-semibold text-themed">{{ t('giftCards.generateTitle') }}</h2>
  278:         <div class="mt-4 grid gap-3 sm:grid-cols-[160px_minmax(0,1fr)_auto]">
  279:           <input v-model.number="generateAmount" class="input" type="number" min="0.01" max="10000" step="0.01" :placeholder="t('giftCards.amountPlaceholder')" />
  280:           <input v-model="generateRemark" class="input" maxlength="200" :placeholder="t('giftCards.remarkPlaceholder')" />
  281:           <button class="btn-primary" :disabled="generating || !generateAmount" @click="generateGiftCard">
  282:             {{ generating ? t('giftCards.generating') : t('giftCards.generate') }}
  283:           </button>
  284:         </div>
  285:       </section>
  286:     </div>
  287: 
  288:     <section class="card p-6">
  289:       <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
