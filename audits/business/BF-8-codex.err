  610: export async function assertFlashSaleCheckoutEligibility(input: {
  611:   itemId: number
  612:   userId: number
  613:   packageId: number
  614:   planId: number
  615:   promoCode?: string | null
  616:   turnstileToken?: string | null
  617:   remoteIp?: string | null
  618: }) {
  619:   const item = await prisma.flashSaleItem.findUnique({
  620:     where: { id: input.itemId },
  621:     include: {
  622:       campaign: true,
  623:       packagePlan: {
  624:         include: {
  625:                 package: {
  626:                   include: {
  627:                     user: { select: { role: true } },
  628:                     packageHosts: { select: { hostId: true } }
  629:                   }
  630:                 }
  631:         }
  632:       }
  633:     }
  634:   })
  635: 
  636:   if (!item) {
  637:     throw new FlashSaleError('FLASH_SALE_ITEM_NOT_FOUND', '秒杀商品不存在', 404)
  638:   }
  639:   if (item.packagePlanId !== input.planId || item.packagePlan.packageId !== input.packageId) {
  640:     throw new FlashSaleError('FLASH_SALE_PLAN_MISMATCH', '秒杀商品与当前套餐方案不匹配')
  641:   }
  642: 
  643:   const now = new Date()
  644:   if (item.campaign.status !== 'active' || now < item.campaign.startAt || now > item.campaign.endAt) {
  645:     throw new FlashSaleError('FLASH_SALE_NOT_ACTIVE', '秒杀活动未开始或已结束')
  646:   }
  647:   if (remainingStock(item) <= 0) {
  648:     throw new FlashSaleError('FLASH_SALE_SOLD_OUT', '秒杀库存已抢完', 409)
  649:   }
  650:   if (input.promoCode && (!item.allowCoupon || !item.allowAff)) {
  651:     throw new FlashSaleError('FLASH_SALE_COUPON_DISABLED', '秒杀商品不支持叠加优惠码或 AFF')
  652:   }
  653: 
  654:   const user = await prisma.user.findUnique({
  655:     where: { id: input.userId },
  656:     select: { id: true, email: true, createdAt: true, status: true }
  657:   })
  658:   if (!user || user.status !== 'active') {
  659:     throw new FlashSaleError('FLASH_SALE_USER_INVALID', '账号状态不可参与秒杀', 403)
  660:   }
  661:   if (item.campaign.requireEmail && !user.email) {
  662:     throw new FlashSaleError('FLASH_SALE_EMAIL_REQUIRED', '参与秒杀需要先绑定邮箱', 403)
  663:   }
  664:   if (item.campaign.minAccountAgeHours > 0) {
  665:     const ageMs = now.getTime() - user.createdAt.getTime()
  666:     if (ageMs < item.campaign.minAccountAgeHours * 60 * 60 * 1000) {
  667:       throw new FlashSaleError('FLASH_SALE_ACCOUNT_TOO_NEW', `账号注册满 ${item.campaign.minAccountAgeHours} 小时后才能参与`, 403)
  668:     }
  669:   }
  670:   if (item.campaign.blockRiskRestricted) {
  671:     const restriction = await getActiveOrderRestriction(input.userId)
  672:     if (restriction) {
  673:       throw new FlashSaleError('FLASH_SALE_ORDER_RESTRICTED', restriction.reason || '账号下单受限，无法参与秒杀', 403)
  674:     }
  675:   }
  676: 
  677:   const perUserLimit = Math.max(1, Math.min(item.perUserLimit, item.campaign.maxPerUser || item.perUserLimit))
  678:   const purchasedCount = await prisma.flashSaleReservation.count({
  679:     where: {
  680:       itemId: item.id,
  681:       userId: input.userId,
  682:       status: { in: ACTIVE_PURCHASE_STATUSES }
  683:     }
  684:   })
  685:   if (purchasedCount >= perUserLimit) {
  686:     throw new FlashSaleError('FLASH_SALE_USER_LIMIT_REACHED', `每个账号限购 ${perUserLimit} 台`, 409)
  687:   }
  688: 
  689:   if (item.campaign.requireTurnstile) {
  690:     const config = await getTurnstileConfig()
  691:     if (config.enabled) {
  692:       if (!input.turnstileToken) {
  693:         throw new FlashSaleError('FLASH_SALE_TURNSTILE_REQUIRED', '请先完成人机验证', 403)
  694:       }
  695:       if (!config.secretKey) {
  696:         throw new FlashSaleError('FLASH_SALE_TURNSTILE_MISCONFIGURED', '人机验证未配置密钥', 503)
  697:       }
  698:       const result = await verifyTurnstileToken(input.turnstileToken, config.secretKey, input.remoteIp || undefined)
  699:       if (!result.success) {
  700:         throw new FlashSaleError('FLASH_SALE_TURNSTILE_FAILED', result.error || '人机验证失败', 403)
  701:       }
  702:     }
  703:   }
  704: 
  705:   return {
  706:     itemId: item.id,
  707:     campaignId: item.campaignId,
  708:     packagePlanId: item.packagePlanId,
  709:     flashPrice: toNumber(item.flashPrice),
  710:     originalPriceSnapshot: toNumber(item.originalPriceSnapshot),
  711:     allowAff: item.allowAff,
  712:     allowCoupon: item.allowCoupon,
  713:     campaignName: item.campaign.name,
  714:     planName: item.packagePlan.name,
  715:     packageName: item.packagePlan.package.name,
  716:     remainingStock: remainingStock(item)
  717:   }
  718: }
