 3778: // ==================== 系统兑换码模型 ====================
 3779: 
 3780: // 系统兑换码（宿主机所有者生成）
 3781: model RedeemCode {
 3782:   id          Int            @id @default(autoincrement())
 3783:   code        String         @unique                        // 兑换码，格式: h-{random18}
 3784:   hostId      Int            @map("host_id")                // 关联的宿主机
 3785:   createdById Int            @map("created_by_id")          // 创建者（宿主机所有者）
 3786:   codeType    RedeemCodeType @map("code_type")              // 资源类型
 3787:   codeValue   Int            @map("code_value")             // 资源数值
 3788:   maxUses     Int            @default(1) @map("max_uses")   // 最大使用次数
 3789:   usedCount   Int            @default(0) @map("used_count") // 已使用次数
 3790:   expiresAt   DateTime?      @map("expires_at")             // 过期时间，null=永不过期
 3791:   enabled     Boolean        @default(true)                 // 是否启用
 3792:   remark      String?                                       // 备注
 3793:   batchId     String?        @map("batch_id")               // 批次ID，同批次码每用户只能用一张
 3794:   targetUserId Int?           @map("target_user_id")         // 生命周期运营定向用户，null=所有用户
 3795:   createdAt   DateTime       @default(now()) @map("created_at")
 3796: 
 3797:   host        Host             @relation(fields: [hostId], references: [id], onDelete: Cascade)
 3798:   createdBy   User             @relation("RedeemCodesCreated", fields: [createdById], references: [id], onDelete: Cascade)
 3799:   usages      RedeemCodeUsage[]
 3800: 
 3801:   @@index([hostId])
 3802:   @@index([createdById])
 3803:   @@index([enabled])
 3804:   @@index([batchId])
 3805:   @@index([targetUserId])
 3806:   @@map("redeem_codes")
 3807: }
 3808: 
 3809: // 系统兑换码使用记录
 3810: model RedeemCodeUsage {
 3811:   id           Int      @id @default(autoincrement())
 3812:   redeemCodeId Int      @map("redeem_code_id")  // 兑换码 ID
 3813:   userId       Int      @map("user_id")         // 使用者
 3814:   instanceId   Int      @map("instance_id")     // 应用到的实例
 3815:   batchId      String?  @map("batch_id")        // 批次ID（冗余存储，用于唯一约束）
 3816:   usedAt       DateTime @default(now()) @map("used_at")
 3817: 
 3818:   redeemCode RedeemCode @relation(fields: [redeemCodeId], references: [id], onDelete: Cascade)
 3819:   user       User       @relation("RedeemCodeUsages", fields: [userId], references: [id], onDelete: Cascade)
 3820:   instance   Instance   @relation(fields: [instanceId], references: [id], onDelete: Cascade)
 3821: 
 3822:   @@unique([userId, batchId])  // 同批次每用户只能使用一次（NULL值不参与约束）
 3823:   @@index([redeemCodeId])
 3824:   @@index([userId])
 3825:   @@index([instanceId])
 3826:   @@map("redeem_code_usages")
 3827: }
