  152: export async function hasCheckedInToday(userId: number): Promise<boolean> {
  153:   const dateKey = getBeijingDateKey()
  154:   const daily = await prisma.dailyCheckin.findUnique({
  155:     where: { userId_dateKey: { userId, dateKey } },
  156:     select: { id: true }
  157:   })
  158:   if (daily) return true
  159: 
  160:   const stats = await prisma.checkinStats.findUnique({
  161:     where: { userId }
  162:   })
  163:   
  164:   if (!stats?.lastCheckinDate) return false
  165:   
  166:   const todayMidnight = getBeijingMidnight()
  167:   const lastCheckinMidnight = toBeijingMidnight(stats.lastCheckinDate)
  168:   
  169:   return lastCheckinMidnight.getTime() >= todayMidnight.getTime()
  170: }
