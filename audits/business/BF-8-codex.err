  485:     } catch (err) {
  486:       const msg = err instanceof Error ? err.message : String(err)
  487:       const mapped = mapGiftCardError(reply, msg)
  488:       if (mapped) return mapped
  489:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, msg))
  490:     }
  491:   })
  492: 
  493:   // 用户查看自己的兑换码
  494:   fastify.get('/user/mine', {
  495:     onRequest: [fastify.authenticate],
  496:     config: { rateLimit: { max: 60, timeWindow: '1 minute' } },
  497:     schema: {
  498:       querystring: {
  499:         type: 'object',
  500:         properties: {
  501:           page: { type: 'integer', minimum: 1, default: 1 },
  502:           pageSize: { type: 'integer', minimum: 1, maximum: 100, default: 20 },
  503:           status: { type: 'string', enum: ['active', 'used', 'disabled', 'expired'] }
  504:         }
  505:       }
  506:     }
  507:   }, async (request) => {
  508:     const { user } = request
  509:     const query = request.query as Record<string, unknown>
  510:     return giftCardDb.listGiftCardsByUser(user.id, {
  511:       page: parseClampedPositiveInteger(query.page, 1, 999999),
  512:       pageSize: parseClampedPositiveInteger(query.pageSize, 20, 100),
  513:       status: normalizeStatus(query.status)
  514:     })
  515:   })
  516: }

