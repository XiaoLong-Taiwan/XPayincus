  494:   fastify.get('/user/mine', {
  495:     onRequest: [fastify.authenticate],
  496:     config: { rateLimit: { max: 60, timeWindow: '1 minute' } },
  497:     schema: {
  498:       querystring: {
  499:         type: 'object',
  500:         properties: {
  501:           page: { type: 'integer', minimum: 1, default: 1 },
  502:           pageSize: { type: 'integer', minimum: 1, maximum: 100, default: 20 },
  503:           status: { type: 'string', enum: ['active', 'used', 'disabled', 'expired'] }
  504:         }
  505:       }
  506:     }
  507:   }, async (request) => {
  508:     const { user } = request
  509:     const query = request.query as Record<string, unknown>
  510:     return giftCardDb.listGiftCardsByUser(user.id, {
  511:       page: parseClampedPositiveInteger(query.page, 1, 999999),
  512:       pageSize: parseClampedPositiveInteger(query.pageSize, 20, 100),
  513:       status: normalizeStatus(query.status)
  514:     })
  515:   })
  516: }
    1: /**
    2:  * 礼品卡兑换码数据访问层
    3:  */
    4: 
    5: import crypto from 'crypto'
    6: import { Prisma, type GiftCardStatus } from '@prisma/client'
    7: import { prisma } from './prisma.js'
    8: import {
    9:   GIFT_CARD_LOCK_NAMESPACE,
   10:   USER_BALANCE_LOCK_NAMESPACE,
   11:   advisoryTransactionLock
   12: } from './advisory-locks.js'
   13: 
   14: const GIFT_CARD_RANDOM_LENGTH = 24
   15: const GIFT_CARD_CODE_PREFIX = 'gc-'
   16: const MAX_GIFT_CARD_BATCH_COUNT = 500
   17: const MAX_GIFT_CARD_REMARK_LENGTH = 200
   18: const MAX_GIFT_CARD_FACE_VALUE = 10000
   19: const MAX_GIFT_CARD_LIST_PAGE_SIZE = 100
   20: 
   21: export const GIFT_CARD_CONSTANTS = {
   22:   CODE_LENGTH: GIFT_CARD_RANDOM_LENGTH,
   23:   CODE_PREFIX: GIFT_CARD_CODE_PREFIX,
   24:   MAX_BATCH_COUNT: MAX_GIFT_CARD_BATCH_COUNT,
   25:   MAX_REMARK_LENGTH: MAX_GIFT_CARD_REMARK_LENGTH,
   26:   MAX_FACE_VALUE: MAX_GIFT_CARD_FACE_VALUE
   27: } as const
   28: 
   29: export interface GiftCardCreateInput {
   30:   faceValue: number
   31:   balanceValue: number
   32:   createdById?: number | null
   33:   ownerId?: number | null
   34:   expiresAt?: Date | null
   35:   remark?: string
   36:   batchId?: string
   37: }
   38: 
   39: export interface GiftCardAdminListOptions {
   40:   page?: number
   41:   pageSize?: number
   42:   status?: GiftCardStatus
   43:   batchId?: string
   44:   revealCode?: boolean
   45: }
   46: 
   47: export interface GiftCardUserListOptions {
   48:   page?: number
   49:   pageSize?: number
   50:   status?: GiftCardStatus
   51: }
   52: 
   53: export interface GiftCardBalanceResult {
   54:   balanceValue: number
   55:   balanceBefore: number
   56:   balanceAfter: number
   57: }
   58: 
   59: type GiftCardRedeemTransactionResult = GiftCardBalanceResult | { error: 'GIFT_CARD_EXPIRED' }
   60: 
   61: function generateGiftCardCode(): string {
   62:   const encoded = crypto.randomBytes(18).toString('base64url')
   63:   return GIFT_CARD_CODE_PREFIX + encoded.substring(0, GIFT_CARD_RANDOM_LENGTH)
   64: }
   65: 
   66: function generateBatchId(): string {
   67:   return crypto.randomBytes(8).toString('hex')
   68: }
   69: 
   70: function toMoney(value: unknown): number {
   71:   const numberValue = Number(value)
   72:   return Number.isFinite(numberValue) ? Number(numberValue.toFixed(2)) : 0
   73: }
   74: 
   75: function toDecimal(value: number): Prisma.Decimal {
   76:   return new Prisma.Decimal(value.toFixed(2))
   77: }
   78: 
   79: function clampPage(value: number | undefined): number {
   80:   return Number.isInteger(value) && value !== undefined && value > 0 ? value : 1
   81: }
   82: 
   83: function clampPageSize(value: number | undefined): number {
   84:   return Number.isInteger(value) && value !== undefined
   85:     ? Math.min(Math.max(value, 1), MAX_GIFT_CARD_LIST_PAGE_SIZE)
   86:     : 20
   87: }
   88: 
   89: function maskGiftCardCode(code: string): string {
   90:   if (code.length <= 12) return code
   91:   return `${code.slice(0, 7)}...${code.slice(-4)}`
   92: }
   93: 
   94: function isUniqueConstraintError(error: unknown): boolean {
   95:   return error instanceof Prisma.PrismaClientKnownRequestError && error.code === 'P2002'
   96: }
   97: 
   98: function serializeGiftCard<T extends { faceValue: unknown; balanceValue: unknown; code?: string }>(
   99:   record: T,
  100:   options: { revealCode?: boolean } = {}
  101: ): T & { faceValue: number; balanceValue: number; codeMasked?: string } {
  102:   const code = record.code
  103:   return {
  104:     ...record,
  105:     ...(code && !options.revealCode ? { code: maskGiftCardCode(code) } : {}),
  106:     ...(code ? { codeMasked: maskGiftCardCode(code) } : {}),
  107:     faceValue: toMoney(record.faceValue),
  108:     balanceValue: toMoney(record.balanceValue)
  109:   }
  110: }
  111: 
  112: async function createGiftCardInTransaction(
  113:   tx: Prisma.TransactionClient,
  114:   input: GiftCardCreateInput
  115: ) {
  116:   return tx.giftCard.create({
  117:     data: {
  118:       code: generateGiftCardCode(),
  119:       faceValue: toDecimal(input.faceValue),
  120:       balanceValue: toDecimal(input.balanceValue),
  121:       createdById: input.createdById ?? null,
  122:       ownerId: input.ownerId ?? null,
  123:       expiresAt: input.expiresAt ?? null,
  124:       remark: input.remark,
  125:       batchId: input.batchId
  126:     },
  127:     select: {
  128:       id: true,
  129:       code: true,
  130:       faceValue: true,
  131:       balanceValue: true,
  132:       status: true,
  133:       expiresAt: true,
  134:       batchId: true,
  135:       createdAt: true
  136:     }
  137:   })
  138: }
  139: 
  140: export async function createGiftCard(input: GiftCardCreateInput) {
  141:   for (let attempt = 0; attempt < 3; attempt++) {
  142:     try {
  143:       const card = await prisma.$transaction((tx) => createGiftCardInTransaction(tx, input))
  144:       return serializeGiftCard(card, { revealCode: true })
  145:     } catch (error) {
  146:       if (!isUniqueConstraintError(error) || attempt === 2) throw error
  147:     }
  148:   }
  149:   throw new Error('GIFT_CARD_CODE_COLLISION')
  150: }
  151: 
  152: export async function createGiftCardBatch(
  153:   count: number,
  154:   input: Omit<GiftCardCreateInput, 'batchId'>
  155: ) {
  156:   if (!Number.isSafeInteger(count) || count < 1 || count > MAX_GIFT_CARD_BATCH_COUNT) {
  157:     throw new Error('GIFT_CARD_BATCH_TOO_LARGE')
  158:   }
  159: 
  160:   for (let attempt = 0; attempt < 3; attempt++) {
  161:     try {
  162:       return await prisma.$transaction(async (tx) => {
  163:         const batchId = generateBatchId()
  164:         const cards = []
  165:         for (let i = 0; i < count; i++) {
  166:           cards.push(await createGiftCardInTransaction(tx, { ...input, batchId }))
  167:         }
  168:         return {
  169:           codes: cards.map(card => serializeGiftCard(card, { revealCode: true })),
  170:           batchId,
  171:           count: cards.length
  172:         }
  173:       })
  174:     } catch (error) {
  175:       if (!isUniqueConstraintError(error) || attempt === 2) throw error
  176:     }
  177:   }
  178:   throw new Error('GIFT_CARD_CODE_COLLISION')
  179: }
  180: 
  181: export async function generateGiftCardFromBalance(input: {
  182:   userId: number
  183:   faceValue: number
  184:   remark?: string
  185: }) {
  186:   for (let attempt = 0; attempt < 3; attempt++) {
  187:     try {
  188:       return await prisma.$transaction(async (tx) => {
  189:         await advisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, input.userId)
  190: 
  191:         const user = await tx.user.findUnique({
  192:           where: { id: input.userId },
  193:           select: { balance: true }
  194:         })
  195:         if (!user) throw new Error('USER_NOT_FOUND')
  196: 
  197:         const balanceBefore = toMoney(user.balance)
  198:         const amount = toMoney(input.faceValue)
  199:         const updateResult = await tx.user.updateMany({
  200:           where: { id: input.userId, balance: { gte: amount } },
  201:           data: { balance: { decrement: toDecimal(amount) } }
  202:         })
  203:         if (updateResult.count !== 1) {
  204:           throw new Error('GIFT_CARD_INSUFFICIENT_BALANCE')
  205:         }
  206: 
  207:         const updatedUser = await tx.user.findUnique({
  208:           where: { id: input.userId },
  209:           select: { balance: true }
  210:         })
  211:         if (!updatedUser) throw new Error('USER_NOT_FOUND')
  212: 
  213:         const balanceAfter = toMoney(updatedUser.balance)
  214:         const balanceLog = await tx.balanceLog.create({
  215:           data: {
  216:             // 礼品卡是保值凭证（可转赠/他账兑换），发行扣款不是真实服务消费，
  217:             // 必须用独立类型，避免被 getUsersTotalConsumeMap 计入可兑换积分的消费额而被刷分。
  218:             userId: input.userId,
  219:             type: 'gift_card_issue',
  220:             amount: toDecimal(-amount),
  221:             balanceBefore: toDecimal(balanceBefore),
  222:             balanceAfter: toDecimal(balanceAfter),
  223:             remark: input.remark || '生成礼品卡'
  224:           }
  225:         })
  226: 
  227:         const giftCard = await createGiftCardInTransaction(tx, {
  228:           faceValue: amount,
  229:           balanceValue: amount,
  230:           createdById: input.userId,
  231:           ownerId: input.userId,
  232:           remark: input.remark || '用户余额生成礼品卡'
  233:         })
  234: 
  235:         return {
  236:           giftCard: serializeGiftCard(giftCard, { revealCode: true }),
  237:           balanceLog,
  238:           balanceBefore,
  239:           balanceAfter
  240:         }
  241:       })
  242:     } catch (error) {
  243:       if (!isUniqueConstraintError(error) || attempt === 2) throw error
  244:     }
  245:   }
  246:   throw new Error('GIFT_CARD_CODE_COLLISION')
  247: }
  248: 
  249: export async function findGiftCardByCode(code: string) {
  250:   const card = await prisma.giftCard.findUnique({
  251:     where: { code },
  252:     select: {
  253:       id: true,
  254:       code: true,
  255:       faceValue: true,
  256:       balanceValue: true,
  257:       status: true,
  258:       createdById: true,
  259:       ownerId: true,
  260:       usedById: true,
  261:       usedAt: true,
  262:       expiresAt: true,
  263:       remark: true,
  264:       batchId: true,
  265:       createdAt: true,
  266:       createdBy: { select: { id: true, username: true } },
  267:       owner: { select: { id: true, username: true } },
  268:       usedBy: { select: { id: true, username: true } }
  269:     }
  270:   })
  271:   return card ? serializeGiftCard(card, { revealCode: true }) : null
  272: }
  273: 
  274: export async function findGiftCardById(id: number, options: { revealCode?: boolean } = {}) {
  275:   const card = await prisma.giftCard.findUnique({
  276:     where: { id },
  277:     select: {
  278:       id: true,
  279:       code: true,
  280:       faceValue: true,
  281:       balanceValue: true,
  282:       status: true,
  283:       createdById: true,
  284:       ownerId: true,
  285:       usedById: true,
  286:       usedAt: true,
  287:       expiresAt: true,
  288:       remark: true,
  289:       batchId: true,
  290:       createdAt: true
  291:     }
  292:   })
  293:   return card ? serializeGiftCard(card, options) : null
  294: }
  295: 
  296: export async function redeemGiftCard(code: string, userId: number): Promise<GiftCardBalanceResult> {
  297:   const result = await prisma.$transaction(async (tx): Promise<GiftCardRedeemTransactionResult> => {
  298:     const initialGiftCard = await tx.giftCard.findUnique({
  299:       where: { code },
  300:       select: { id: true }
  301:     })
  302:     if (!initialGiftCard) {
  303:       throw new Error('GIFT_CARD_NOT_FOUND')
  304:     }
  305: 
  306:     await advisoryTransactionLock(tx, GIFT_CARD_LOCK_NAMESPACE, initialGiftCard.id)
  307:     await advisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, userId)
  308: 
  309:     const giftCard = await tx.giftCard.findUnique({
  310:       where: { id: initialGiftCard.id },
  311:       select: {
  312:         id: true,
  313:         code: true,
  314:         status: true,
  315:         balanceValue: true,
  316:         expiresAt: true,
  317:         ownerId: true
  318:       }
  319:     })
  320: 
  321:     if (!giftCard) {
  322:       throw new Error('GIFT_CARD_NOT_FOUND')
  323:     }
  324:     if (giftCard.status !== 'active') {
  325:       throw new Error(giftCard.status === 'used' ? 'GIFT_CARD_USED' : 'GIFT_CARD_DISABLED')
  326:     }
  327:     if (giftCard.ownerId === userId) {
  328:       throw new Error('GIFT_CARD_SELF_REDEEM')
  329:     }
  330:     if (giftCard.expiresAt && giftCard.expiresAt < new Date()) {
  331:       const expired = await tx.giftCard.updateMany({
  332:         where: { id: giftCard.id, status: 'active' },
  333:         data: { status: 'expired' }
  334:       })
  335:       if (expired.count === 0) {
  336:         throw new Error('GIFT_CARD_USED')
  337:       }
  338:       return { error: 'GIFT_CARD_EXPIRED' }
  339:     }
  340: 
  341:     const user = await tx.user.findUnique({
  342:       where: { id: userId },
  343:       select: { balance: true }
  344:     })
  345:     if (!user) throw new Error('USER_NOT_FOUND')
  346: 
  347:     const amount = toMoney(giftCard.balanceValue)
  348:     const balanceBefore = toMoney(user.balance)
  349:     const updated = await tx.giftCard.updateMany({
  350:       where: { id: giftCard.id, status: 'active' },
  351:       data: { status: 'used', usedById: userId, usedAt: new Date() }
  352:     })
  353:     if (updated.count !== 1) {
  354:       throw new Error('GIFT_CARD_USED')
  355:     }
  356: 
  357:     const updatedUser = await tx.user.update({
  358:       where: { id: userId },
  359:       data: { balance: { increment: toDecimal(amount) } },
  360:       select: { balance: true }
  361:     })
  362:     const balanceAfter = toMoney(updatedUser.balance)
  363: 
  364:     await tx.balanceLog.create({
  365:       data: {
  366:         userId,
  367:         type: 'gift',
  368:         amount: toDecimal(amount),
  369:         balanceBefore: toDecimal(balanceBefore),
  370:         balanceAfter: toDecimal(balanceAfter),
  371:         remark: `礼品卡兑换：${maskGiftCardCode(giftCard.code)}`
  372:       }
  373:     })
  374: 
  375:     return { balanceValue: amount, balanceBefore, balanceAfter }
  376:   })
  377: 
  378:   if ('error' in result) {
  379:     throw new Error(result.error)
  380:   }
  381: 
  382:   return result
  383: }
  384: 
  385: export async function disableGiftCard(id: number) {
  386:   return prisma.giftCard.updateMany({
  387:     where: { id, status: 'active' },
  388:     data: { status: 'disabled' }
  389:   })
  390: }
  391: 
  392: export async function enableGiftCard(id: number) {
  393:   return prisma.giftCard.updateMany({
  394:     where: {
  395:       id,
  396:       status: 'disabled',
  397:       OR: [{ expiresAt: null }, { expiresAt: { gt: new Date() } }]
  398:     },
  399:     data: { status: 'active' }
  400:   })
  401: }
  402: 
  403: export async function deleteGiftCard(id: number) {
  404:   return prisma.giftCard.deleteMany({
  405:     where: { id, status: { in: ['active', 'disabled', 'expired'] } }
  406:   })
  407: }
  408: 
  409: export async function batchDisableGiftCards(ids: number[]) {
  410:   return prisma.giftCard.updateMany({
  411:     where: { id: { in: ids }, status: 'active' },
  412:     data: { status: 'disabled' }
  413:   })
  414: }
  415: 
  416: export async function batchDeleteGiftCards(ids: number[]) {
  417:   return prisma.giftCard.deleteMany({
  418:     where: { id: { in: ids }, status: { in: ['active', 'disabled', 'expired'] } }
  419:   })
  420: }
  421: 
  422: export async function listGiftCardsByAdmin(options: GiftCardAdminListOptions) {
  423:   const page = clampPage(options.page)
  424:   const pageSize = clampPageSize(options.pageSize)
  425:   const where: Prisma.GiftCardWhereInput = {
  426:     ...(options.status ? { status: options.status } : {}),
  427:     ...(options.batchId ? { batchId: options.batchId } : {})
  428:   }
  429: 
  430:   const [total, records] = await Promise.all([
  431:     prisma.giftCard.count({ where }),
  432:     prisma.giftCard.findMany({
  433:       where,
  434:       select: {
  435:         id: true,
  436:         code: true,
  437:         faceValue: true,
  438:         balanceValue: true,
  439:         status: true,
  440:         expiresAt: true,
  441:         remark: true,
  442:         batchId: true,
  443:         createdAt: true,
  444:         usedAt: true,
  445:         createdBy: { select: { id: true, username: true } },
  446:         owner: { select: { id: true, username: true } },
  447:         usedBy: { select: { id: true, username: true } }
  448:       },
  449:       orderBy: { createdAt: 'desc' },
  450:       skip: (page - 1) * pageSize,
  451:       take: pageSize
  452:     })
  453:   ])
  454: 
  455:   return {
  456:     records: records.map(record => serializeGiftCard(record, { revealCode: options.revealCode === true })),
  457:     total,
  458:     page,
  459:     pageSize
  460:   }
  461: }
  462: 
  463: export async function listGiftCardsByUser(userId: number, options: GiftCardUserListOptions) {
  464:   const page = clampPage(options.page)
  465:   const pageSize = clampPageSize(options.pageSize)
  466:   const where: Prisma.GiftCardWhereInput = {
  467:     OR: [{ ownerId: userId }, { createdById: userId }, { usedById: userId }],
  468:     ...(options.status ? { status: options.status } : {})
  469:   }
  470: 
  471:   const [total, records] = await Promise.all([
  472:     prisma.giftCard.count({ where }),
  473:     prisma.giftCard.findMany({
  474:       where,
  475:       select: {
  476:         id: true,
  477:         code: true,
  478:         faceValue: true,
  479:         balanceValue: true,
  480:         status: true,
  481:         expiresAt: true,
  482:         createdAt: true,
  483:         usedAt: true
  484:       },
  485:       orderBy: { createdAt: 'desc' },
  486:       skip: (page - 1) * pageSize,
  487:       take: pageSize
  488:     })
  489:   ])
  490: 
  491:   return {
  492:     records: records.map(record => serializeGiftCard(record, { revealCode: true })),
  493:     total,
  494:     page,
  495:     pageSize
  496:   }
  497: }
  498: 
  499: export async function getGiftCardStats() {
  500:   const [total, active, used, disabled, expired, outstandingValue, redeemedValue] = await Promise.all([
  501:     prisma.giftCard.count(),
  502:     prisma.giftCard.count({ where: { status: 'active' } }),
  503:     prisma.giftCard.count({ where: { status: 'used' } }),
  504:     prisma.giftCard.count({ where: { status: 'disabled' } }),
  505:     prisma.giftCard.count({ where: { status: 'expired' } }),
  506:     prisma.giftCard.aggregate({
  507:       _sum: { balanceValue: true },
  508:       where: { status: { in: ['active', 'disabled'] } }
  509:     }),
  510:     prisma.giftCard.aggregate({
  511:       _sum: { balanceValue: true },
  512:       where: { status: 'used' }
  513:     })
  514:   ])
  515: 
  516:   return {
  517:     total,
  518:     active,
  519:     used,
  520:     disabled,
  521:     expired,
  522:     outstandingValue: toMoney(outstandingValue._sum.balanceValue),
  523:     totalRedeemedValue: toMoney(redeemedValue._sum.balanceValue)
  524:   }
  525: }

