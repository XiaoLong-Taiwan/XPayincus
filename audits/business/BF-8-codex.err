  480: /**
  481:  * 获取指定宿主机下某个兑换码的使用记录。
  482:  */
  483: export async function getRedeemCodeUsagesForHost(
  484:   hostId: number,
  485:   redeemCodeId: number,
  486:   options: { limit?: number; offset?: number } = {}
  487: ) {
  488:   const { limit, offset } = clampRedeemCodeListBounds(options.limit, options.offset, 20)
  489:   const where = { redeemCodeId, redeemCode: { hostId } }
  490: 
  491:   const [usages, total] = await Promise.all([
  492:     prisma.redeemCodeUsage.findMany({
  493:       where,
  494:       orderBy: { usedAt: 'desc' },
  495:       take: limit,
  496:       skip: offset,
  497:       include: {
  498:         user: {
  499:           select: { id: true, username: true }
