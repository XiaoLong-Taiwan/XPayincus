  353:                 </div>
  354:               </td>
  355:             </tr>
  356:             <tr v-if="!loading && cards.length === 0">
  357:               <td colspan="5" class="py-8 text-center text-themed-muted">{{ t('giftCards.empty') }}</td>
  358:             </tr>
  359:           </tbody>
  360:         </table>
  361:       </div>
  362:     </section>
  363:   </div>
