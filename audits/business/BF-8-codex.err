  150: function serializeCampaign(campaign: {
  151:   id: number
  152:   name: string
  153:   description: string | null
  154:   status: FlashSaleCampaignStatus
  155:   startAt: Date
  156:   endAt: Date
  157:   requireTurnstile: boolean
  158:   minAccountAgeHours: number
  159:   requireEmail: boolean
  160:   blockRiskRestricted: boolean
  161:   maxPerUser: number
  162:   notes: string | null
  163:   createdByUserId: number
  164:   createdAt: Date
  165:   updatedAt: Date
  166:   items: Array<Parameters<typeof serializeItem>[0]>
  167: }) {
  168:   return {
  169:     id: campaign.id,
  170:     name: campaign.name,
  171:     description: campaign.description,
  172:     status: campaign.status,
  173:     effectiveStatus: normalizeStatusForTime(campaign.status, campaign.startAt, campaign.endAt),
  174:     startAt: campaign.startAt.toISOString(),
  175:     endAt: campaign.endAt.toISOString(),
  176:     requireTurnstile: campaign.requireTurnstile,
  177:     minAccountAgeHours: campaign.minAccountAgeHours,
  178:     requireEmail: campaign.requireEmail,
  179:     blockRiskRestricted: campaign.blockRiskRestricted,
  180:     maxPerUser: campaign.maxPerUser,
  181:     notes: campaign.notes,
  182:     createdByUserId: campaign.createdByUserId,
  183:     createdAt: campaign.createdAt.toISOString(),
  184:     updatedAt: campaign.updatedAt.toISOString(),
  185:     items: campaign.items.map(serializeItem)
  186:   }
  187: }
