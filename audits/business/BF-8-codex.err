  553: export async function updateFlashSaleItemConfig(itemId: number, input: {
  554:   flashPrice?: number
  555:   totalStock?: number
  556:   perUserLimit?: number
  557:   allowCoupon?: boolean
  558:   allowAff?: boolean
  559:   sortOrder?: number
  560:   actorUserId: number
  561:   reason?: string
  562: }) {
  563:   if (input.flashPrice !== undefined && (!Number.isInteger(input.flashPrice) || input.flashPrice < 0)) {
  564:     throw new FlashSaleError('FLASH_SALE_INVALID_PRICE', '秒杀价无效')
  565:   }
  566:   if (input.totalStock !== undefined && (!Number.isInteger(input.totalStock) || input.totalStock < 0)) {
  567:     throw new FlashSaleError('FLASH_SALE_INVALID_STOCK', '库存不能小于 0')
  568:   }
  569:   if (input.perUserLimit !== undefined && (!Number.isInteger(input.perUserLimit) || input.perUserLimit < 1)) {
  570:     throw new FlashSaleError('FLASH_SALE_INVALID_LIMIT', '每人限购必须大于 0')
  571:   }
  572:   if (input.sortOrder !== undefined && (!Number.isInteger(input.sortOrder) || input.sortOrder < 0)) {
  573:     throw new FlashSaleError('FLASH_SALE_INVALID_SORT', '排序值不能小于 0')
  574:   }
  575: 
  576:   const item = await prisma.flashSaleItem.findUnique({ where: { id: itemId } })
  577:   if (!item) return null
  578:   if (input.totalStock !== undefined && input.totalStock < item.soldCount + item.reservedCount) {
  579:     throw new FlashSaleError('FLASH_SALE_STOCK_BELOW_SOLD', '库存不能小于已售和锁定数量')
  580:   }
  581: 
  582:   const updated = await prisma.$transaction(async (tx) => {
  583:     const next = await tx.flashSaleItem.update({
  584:       where: { id: itemId },
  585:       data: {
  586:         flashPrice: input.flashPrice,
  587:         totalStock: input.totalStock,
  588:         perUserLimit: input.perUserLimit,
  589:         allowCoupon: input.allowCoupon,
  590:         allowAff: input.allowAff,
  591:         sortOrder: input.sortOrder
  592:       }
  593:     })
  594:     await tx.flashSaleAuditLog.create({
  595:       data: {
  596:         campaignId: item.campaignId,
  597:         itemId,
  598:         actorUserId: input.actorUserId,
  599:         action: 'update',
  600:         beforeData: item as unknown as Prisma.InputJsonValue,
  601:         afterData: next as unknown as Prisma.InputJsonValue,
  602:         reason: input.reason
  603:       }
  604:     })
  605:     return next
  606:   })
  607:   return updated
  608: }
