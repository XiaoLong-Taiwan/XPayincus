  464: 
  465: /**
  466:  * 批量删除指定宿主机下的兑换码。
  467:  */
  468: export async function deleteRedeemCodeBatchForHost(hostId: number, ids: number[]): Promise<number> {
  469:   if (ids.length === 0) {
  470:     return 0
  471:   }
  472: 
  473:   const result = await prisma.redeemCode.deleteMany({
