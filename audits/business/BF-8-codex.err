  200:       prisma.flashSaleReservation.count({ where }),
  201:       prisma.flashSaleReservation.findMany({
  202:         where,
  203:         include: {
  204:           campaign: { select: { id: true, name: true } },
  205:           item: {
  206:             include: {
  207:               packagePlan: {
  208:                 include: { package: true }
  209:               }
  210:             }
  211:           },
  212:           instance: { select: { id: true, name: true, status: true } }
  213:         },
  214:         orderBy: { createdAt: 'desc' },
  215:         skip: (page - 1) * pageSize,
  216:         take: pageSize
  217:       })
  218:     ])
  219: 
  220:     return {
