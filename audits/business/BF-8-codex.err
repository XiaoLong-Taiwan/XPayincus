  592: export async function issueLifecycleRedeemCode(data: {
  593:   userId: number
  594:   hostId: number
  595:   codeType: RedeemCodeType
  596:   codeValue: number
  597:   expiresInDays: number
  598:   remark?: string
  599:   actor: Actor
  600: }) {
  601:   const expiresAt = addDays(Math.min(Math.max(data.expiresInDays, 1), 365))
  602:   const code = await createRedeemCode({
  603:     hostId: data.hostId,
  604:     createdById: data.actor.id,
  605:     codeType: data.codeType,
  606:     codeValue: data.codeValue,
  607:     maxUses: 1,
  608:     expiresAt,
  609:     remark: data.remark ?? '生命周期运营定向发放',
  610:     targetUserId: data.userId
  611:   })
  612: 
  613:   await createInboxMessage({
  614:     userId: data.userId,
  615:     eventType: 'user_lifecycle_offer',
  616:     title: '您有一张可用资源兑换码',
  617:     content: `管理员为您发放了一张定向资源兑换码：${code.code}，请在有效期内使用。`,
  618:     data: { redeemCodeId: code.id, expiresAt: expiresAt.toISOString() }
  619:   })
  620: 
  621:   await recordLifecycleAction({
  622:     actionType: 'issue_redeem_code',
  623:     actor: data.actor,
  624:     targetUserId: data.userId,
  625:     payload: {
  626:       hostId: data.hostId,
  627:       codeType: data.codeType,
  628:       codeValue: data.codeValue,
  629:       expiresInDays: data.expiresInDays
  630:     },
  631:     result: { redeemCodeId: code.id, expiresAt: expiresAt.toISOString() },
  632:     message: `为用户 #${data.userId} 发放定向资源兑换码`
  633:   })
  634: 
  635:   return {
  640: }
  641: 
  642: export async function sendLifecycleReminder(data: {
  643:   userIds: number[]
  644:   title: string
  645:   content: string
  646:   actor: Actor
  647: }) {
  648:   const userIds = Array.from(new Set(data.userIds.filter(id => Number.isSafeInteger(id) && id > 0))).slice(0, 100)
  649:   const users = await prisma.user.findMany({ where: { id: { in: userIds }, role: 'user' }, select: { id: true } })
  650: 
  651:   for (const user of users) {
  652:     await createInboxMessage({
  653:       userId: user.id,
  654:       eventType: 'user_lifecycle_reminder',
  655:       title: data.title,
  656:       content: data.content,
  657:       data: { source: 'admin_user_lifecycle' }
  658:     })
  659:     await recordLifecycleAction({
  660:       actionType: 'send_reminder',
  661:       actor: data.actor,
  662:       targetUserId: user.id,
  663:       payload: { title: data.title },
  664:       message: `向用户 #${user.id} 发送生命周期提醒`
  665:     })
  666:   }
  667: 
  668:   return { sent: users.length }
  669: }
  670: 
  671: export async function sendLifecycleReminderToSegment(data: {
  672:   segmentKey: string
  673:   title: string
  674:   content: string
  675:   actor: Actor
  676: }) {
  677:   const members = await prisma.userLifecycleSegmentMember.findMany({
  678:     where: { segmentRule: { key: data.segmentKey } },
  679:     select: { userId: true },
  680:     take: 100
  681:   })
  682: 
  683:   return sendLifecycleReminder({
  684:     userIds: members.map(member => member.userId),
  685:     title: data.title,
  686:     content: data.content,
  687:     actor: data.actor
  688:   })
  689: }
  690: 
  691: export async function getUserLifecycleOffers(userId: number) {
  692:   const now = new Date()
  693:   const codes = await prisma.redeemCode.findMany({
  694:     where: {
  695:       targetUserId: userId,
  696:       enabled: true,
  697:       OR: [{ expiresAt: null }, { expiresAt: { gt: now } }]
  698:     },
  699:     select: {
  700:       id: true,
  701:       code: true,
  702:       codeType: true,
  703:       codeValue: true,
  704:       maxUses: true,
  705:       usedCount: true,
  706:       expiresAt: true,
  707:       remark: true,
  708:       host: { select: { id: true, name: true } },
  709:       usages: { where: { userId }, select: { id: true, usedAt: true }, take: 1 }
  710:     },

