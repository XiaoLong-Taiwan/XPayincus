  541: export async function addLifecycleTag(userId: number, tagKey: UserLifecycleTagKey, actor: Actor, note?: string) {
  542:   const tag = await prisma.userLifecycleTag.upsert({
  543:     where: { userId_tagKey: { userId, tagKey } },
  544:     create: {
  545:       userId,
  546:       tagKey,
  547:       active: true,
  548:       note: note ?? null,
  549:       assignedByUserId: actor.id,
  550:       assignedByUsername: actor.username
  551:     },
  552:     update: {
  553:       active: true,
  554:       note: note ?? null,
  555:       assignedByUserId: actor.id,
  556:       assignedByUsername: actor.username,
  557:       assignedAt: new Date(),
  558:       removedAt: null
  559:     }
  560:   })
  561: 
  562:   await recordLifecycleAction({
  563:     actionType: 'add_tag',
  564:     actor,
  565:     targetUserId: userId,
  566:     payload: { tagKey, note: note ?? null },
  567:     result: { tagId: tag.id },
  568:     message: `为用户 #${userId} 添加生命周期标签 ${tagKey}`
  569:   })
  570: 
  571:   return tag
  572: }
  573: 
  574: export async function removeLifecycleTag(userId: number, tagKey: UserLifecycleTagKey, actor: Actor) {
  575:   const tag = await prisma.userLifecycleTag.update({
  576:     where: { userId_tagKey: { userId, tagKey } },
  577:     data: { active: false, removedAt: new Date() }
  578:   })
  579: 
  580:   await recordLifecycleAction({
  581:     actionType: 'remove_tag',
  582:     actor,
  583:     targetUserId: userId,
  584:     payload: { tagKey },
  585:     result: { tagId: tag.id },
  586:     message: `移除用户 #${userId} 的生命周期标签 ${tagKey}`
  587:   })
  588: 
  589:   return tag
  590: }
