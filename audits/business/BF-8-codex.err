  232: export async function listAdminFlashSales(params: ReturnType<typeof normalizeFlashSaleListParams>) {
  233:   const where = params.status ? { status: params.status } : {}
  234:   const [total, campaigns] = await Promise.all([
  235:     prisma.flashSaleCampaign.count({ where }),
  236:     prisma.flashSaleCampaign.findMany({
  237:       where,
  238:       include: {
  239:         items: {
  240:           include: {
  241:             packagePlan: {
  242:               include: {
  243:                 package: {
  244:                   include: {
  245:                     user: { select: { role: true } },
  246:                     packageHosts: { select: { hostId: true } }
  247:                   }
  248:                 }
  249:               }
  250:             }
  251:           },
  252:           orderBy: [{ sortOrder: 'asc' }, { id: 'asc' }]
  253:         }
  254:       },
  255:       orderBy: [{ createdAt: 'desc' }],
  256:       skip: (params.page - 1) * params.pageSize,
  257:       take: params.pageSize
  258:     })
  259:   ])
  260: 
  261:   return {
  262:     campaigns: campaigns.map(serializeCampaign),
  263:     total,
  264:     page: params.page,
  265:     pageSize: params.pageSize
  266:   }
  267: }
