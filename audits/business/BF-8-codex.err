  112: // ==================== 费用计算函数 ====================
  113: 
  114: /**
  115:  * 计算开通费用
  116:  * 注意：数据库中 price 存储的是分（cents），需要除以100转成元
  117:  * 开通费已废弃，固定为0
  118:  */
  119: export function calculateCreateBilling(plan: PackagePlan): CreateBillingResult {
  120:   const price = Number(plan.price) / 100  // 分转元
  121:   const totalPrice = price  // 不再计算开通费
  122: 
  123:   // 计算到期时间（根据计费周期）
  124:   const expiresAt = addMonths(new Date(), plan.billingCycle)
  125: 
  126:   return {
  127:     plan,
  128:     price,
  129:     billingCycle: plan.billingCycle,
  130:     setupFee: 0,  // 开通费已废弃
  131:     totalPrice,
  132:     expiresAt
  133:   }
  134: }
  135: 
  136: /**
  137:  * 计算月价（将方案价格折算为月价）
  138:  */
  139: export function calculateMonthlyPrice(instance: { billingPrice: any; billingCycle: number | null }): number {
  140:   const price = Number(instance.billingPrice) || 0
  141:   const cycle = Math.max(instance.billingCycle || 1, 1) // 防止除零
  142:   return price / cycle
  143: }
  144: 
