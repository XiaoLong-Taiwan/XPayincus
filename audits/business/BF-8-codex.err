  305:             </div>
  306:             <span class="shrink-0 text-sm" :class="statusClass(card.status)">{{ statusLabel(card.status) }}</span>
  307:           </div>
  308:           <div class="mt-3 grid grid-cols-2 gap-3 text-sm">
  309:             <div>
  310:               <div class="text-xs text-themed-muted">{{ t('giftCards.amount') }}</div>
  311:               <div class="font-medium text-themed">{{ formatMoney(card.balanceValue) }}</div>
  312:             </div>
  313:             <div>
