119:
120:function extractUrlFromHtmlSnippet(html: string | null): string | null {
121:  if (!html) {
122:    return null
123:  }
124:
125:  const srcMatch = html.match(/src="([^"]+)"/i)
126:  if (srcMatch?.[1]) {
127:    return srcMatch[1]
128:  }
129:
130:  const markdownMatch = html.match(/\((https?:\/\/[^)]+)\)/i)
131:  if (markdownMatch?.[1]) {
132:    return markdownMatch[1]
133:  }
134:
135:  return null
136:}
137:
138:function joinUrl(baseUrl: string, pathname: string | null): string | null {
139:  const normalizedPath = asNullableString(pathname)?.replace(/^\/+/, '')
140:  if (!normalizedPath) {
141:    return null
142:  }
143:
144:  return `${normalizeBaseUrl(baseUrl)}/${normalizedPath}`
145:}
146:
147:function pickProviderFileId(...values: unknown[]): string | null {
148:  for (const value of values) {
149:    const picked = typeof value === 'number' && Number.isFinite(value)
150:      ? String(value)
151:      : asNullableString(value)
152:    if (picked) {
153:      return picked.replace(/^\/+/, '')
154:    }
155:  }
156:
157:  return null
158:}
