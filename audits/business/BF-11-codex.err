691:// Reply
692:async function handleReply() {
693:  if (!selectedTicket.value) return
694:  if (!replyContent.value.trim() && replyAttachments.value.length === 0) return
695:  
696:  replying.value = true
697:  try {
698:    const res = await api.tickets.reply(selectedTicket.value.id, replyContent.value.trim(), replyAttachments.value)
699:    messages.value.push(res.data)
700:    messagesTotal.value++
701:    await ensureMessageAttachmentUrls([res.data])
702:    replyContent.value = ''
703:    replyAttachments.value = []
704:    toast.success(t('tickets.replySuccess'))
705:    if (authStore.isAdmin) {
706:      await loadSupportContext()
707:    }
708:    // Scroll to bottom
709:    await nextTick()
710:    const container = document.getElementById('messages-container')
711:    if (container) container.scrollTop = container.scrollHeight
712:  } catch (error: any) {
713:    toast.error(error?.message || t('common.error'))
714:  } finally {
715:    replying.value = false
716:  }
717:}
