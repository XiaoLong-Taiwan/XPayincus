665:// Load more messages
666:async function loadMoreMessages() {
667:  if (!selectedTicket.value || messagesLoadingMore.value) return
668:  if (messagesPage.value >= messagesTotalPages.value) return
669:  
670:  messagesLoadingMore.value = true
671:  try {
672:    messagesPage.value++
673:    const res = await api.tickets.getMessages(selectedTicket.value.id, {
674:      page: messagesPage.value,
675:      pageSize: messagesPageSize.value
676:    })
677:    messages.value.push(...res.messages)
678:    await ensureMessageAttachmentUrls(res.messages)
679:  } catch (error: any) {
680:    toast.error(error?.message || t('common.error'))
681:    messagesPage.value--
682:  } finally {
683:    messagesLoadingMore.value = false
684:  }
685:}
