415:    ['contains_database_url', /\b(postgresql|mysql|redis):\/\//i],
416:    ['contains_server_path', /\/(?:opt|var|etc|root|home)\/[A-Za-z0-9._/-]+/],
417:    ['claims_refund_completed', /(?:å·²|å·²ç»|ä¸ºæ‚¨)(?:å®Œæˆ|å¤„ç†)?é€€æ¬¾/],
418:    ['claims_instance_operation_completed', /(?:å·²|å·²ç»|ä¸ºæ‚¨)(?:åˆ é™¤|é”€æ¯|é‡è£…|è¿ç§»|æ¢å¤)(?:æœºå™¨|å®žä¾‹|æ•°æ®)?/],
419:    ['mentions_internal_note', /å†…éƒ¨å¤‡æ³¨|ç®¡ç†å‘˜å¤‡æ³¨|åŽå°å¤‡æ³¨/],
420:    ['mentions_risk_rule_detail', /é£ŽæŽ§è§„åˆ™|ç»•è¿‡é™åˆ¶|åŽå°é…ç½®/]
421:  ]
422:
423:  for (const [reason, pattern] of checks) {
424:    if (pattern.test(draft)) {
