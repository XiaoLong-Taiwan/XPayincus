721:export async function getAiTicketAutomationStatus(): Promise<AiTicketAutomationStatus> {
722:  const config = await loadAiTicketAgentConfig()
723:  return {
724:    enabled: config.enabled,
725:    mode: config.mode,
726:    modelConfigured: Boolean(config.apiBaseUrl && config.apiKey),
727:    autoReplyCategories: config.autoReplyCategories,
728:    confidenceThreshold: config.confidenceThreshold,
729:    dailyAutoReplyLimit: config.dailyAutoReplyLimit,
730:    ticketAutoReplyLimit: config.ticketAutoReplyLimit,
731:    cooldownSeconds: config.cooldownSeconds,
732:    showAiIdentity: config.showAiIdentity
733:  }
734:}
