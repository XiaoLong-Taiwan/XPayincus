937:      subject: ticket.subject,
938:      category: ticket.category,
939:      priority: ticket.priority,
940:      status: ticket.status,
941:      createdAt: ticket.createdAt.toISOString(),
942:      updatedAt: ticket.updatedAt.toISOString(),
943:      linkedInstanceId: ticket.instanceId,
944:      recentMessages: ticket.messages
945:        .slice()
946:        .reverse()
