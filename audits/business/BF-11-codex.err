555:async function loadTickets(silent = false) {
556:  if (!silent) loading.value = true
557:  else refreshing.value = true
558:  
559:  try {
560:    const params: Record<string, unknown> = {
561:      page: page.value,
562:      pageSize: pageSize.value
563:    }
564:    
565:    // çŠ¶æ€ç­›é€‰ï¼š'active' ä¼ é€’ç»™åŽç«¯å¤„ç†ï¼Œ'all' ä¸ä¼  status
566:    if (statusFilter.value === 'active') {
567:      params.status = 'active'
568:    } else if (statusFilter.value !== 'all') {
569:      params.status = statusFilter.value
570:    }
571:    
572:    // æœç´¢
573:    if (searchQuery.value.trim()) {
574:      params.search = searchQuery.value.trim()
575:    }
576:    
577:    if (hostFilter.value) params.hostId = hostFilter.value
578:    if (activeTab.value === 'host' && authStore.isAdmin && hostTicketSourceFilter.value !== 'all') {
579:      params.sourceType = hostTicketSourceFilter.value
580:    }
581:    if (activeTab.value === 'host' && authStore.isAdmin && queueFilter.value !== 'all') {
582:      params.queue = queueFilter.value
583:    }
584:    
585:    let response
586:    if (activeTab.value === 'my') {
587:      response = await api.tickets.list(params as { status?: TicketStatus | 'active'; search?: string; page?: number; pageSize?: number })
588:    } else {
589:      response = await api.tickets.getMyHostTickets(params as { status?: TicketStatus | 'active'; hostId?: number; search?: string; page?: number; pageSize?: number })
590:    }
591:    
592:    tickets.value = response.tickets
593:    total.value = response.total
594:  } catch (error: any) {
595:    toast.error(error?.message || t('common.error'))
596:  } finally {
597:    loading.value = false
598:    refreshing.value = false
599:  }
600:}
