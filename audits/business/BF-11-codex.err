1043:export async function addTicketMessage(
1044:  ticketId: number,
1045:  senderId: number,
1046:  content: string,
1047:  isFromOwner: boolean,
1048:  attachments: CreateTicketMessageAttachmentData[] = []
1049:): Promise<TicketMessage> {
1050:  const message = await prisma.$transaction(async tx => {
1051:    const ticketUpdate = await tx.ticket.updateMany({
1052:      where: {
1053:        id: ticketId,
1054:        status: { not: 'closed' }
1055:      },
1056:      data: {
1057:        updatedAt: new Date(),
1058:        ...(!isFromOwner ? {
1059:          status: 'in_progress' as TicketStatus,
1060:          resolvedAt: null,
1061:          closedAt: null
1062:        } : {})
1063:      }
1064:    })
1065:
1066:    if (ticketUpdate.count === 0) {
1067:      throw new Error('Cannot reply to a closed ticket')
1068:    }
1069:
1070:    if (isFromOwner) {
1071:      await tx.ticket.updateMany({
1072:        where: {
1073:          id: ticketId,
1074:          firstRespondedAt: null
1075:        },
1076:        data: {
1077:          firstRespondedAt: new Date()
1078:        }
1079:      })
1080:    }
1081:
1082:    const createdMessage = await tx.ticketMessage.create({
1083:      data: {
1084:        ticketId,
1085:        senderId,
1086:        content,
1087:        isFromOwner
1088:      }
1089:    })
1090:
1091:    if (attachments.length > 0) {
1092:      await tx.ticketMessageAttachment.createMany({
1093:        data: attachments.map(attachment => ({
1094:          ticketId,
1095:          messageId: createdMessage.id,
1096:          uploaderId: senderId,
1097:          provider: attachment.provider,
1098:          providerVersion: attachment.providerVersion,
1099:          providerFileId: attachment.providerFileId ?? null,
1100:          filename: attachment.filename,
1101:          originalName: attachment.originalName,
1102:          mimeType: attachment.mimeType,
1103:          sizeBytes: attachment.sizeBytes,
1104:          width: attachment.width ?? null,
1105:          height: attachment.height ?? null,
1106:          url: attachment.url,
1107:          thumbnailUrl: attachment.thumbnailUrl ?? null
1108:        }))
1109:      })
1110:    }
1111:
1112:    return tx.ticketMessage.findUniqueOrThrow({
1113:      where: { id: createdMessage.id },
1114:      include: {
1115:        sender: {
1116:          select: {
1117:            id: true,
1118:            username: true,
1119:            avatarStyle: true,
1120:            avatarBadgeId: true
1121:          }
1122:        },
1123:        attachments: {
1124:          orderBy: { id: 'asc' }
1125:        }
1126:      }
1127:    })
1128:  })
1129:
1130:  return {
1131:    id: message.id,
1132:    ticketId: message.ticketId,
1133:    senderId: message.senderId,
1134:    content: message.content,
1135:    isFromOwner: message.isFromOwner,
1136:    createdAt: message.createdAt.toISOString(),
1137:    attachments: message.attachments.map(mapTicketMessageAttachment),
1138:    sender: message.sender
1139:  }
1140:}
