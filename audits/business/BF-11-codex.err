160:function parseProviderNumericId(providerFileId: string): number | null {
161:  if (!/^[1-9][0-9]*$/.test(providerFileId)) {
162:    return null
163:  }
164:
165:  const id = Number(providerFileId)
166:  return Number.isSafeInteger(id) ? id : null
167:}
168:
169:function extractLskyErrorMessage(payload: any, fallback: string): string {
170:  return pickString(
171:    payload?.message,
172:    payload?.msg,
173:    payload?.error?.message,
174:    payload?.error,
175:    payload?.errors?.[0]?.message
176:  ) || fallback
177:}
178:
179:function extractUploadDataCandidates(payload: any): any[] {
180:  const candidates = [
181:    payload?.data?.data,
182:    payload?.data?.photo,
183:    payload?.data?.image,
184:    payload?.data,
185:    payload?.result?.data,
186:    payload?.result?.photo,
187:    payload?.result,
188:    payload
189:  ]
190:
191:  return candidates.filter(candidate => candidate && typeof candidate === 'object')
192:}
