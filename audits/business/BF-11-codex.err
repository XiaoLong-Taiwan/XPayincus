11:const TICKET_STATUSES = new Set<TicketStatus>(['open', 'in_progress', 'resolved', 'closed'])
12:const TICKET_LINK_TYPES = new Set<TicketObjectLinkType>([
13:  'recharge_record',
14:  'order_operation_case',
15:  'instance',
16:  'host',
17:  'delivery_case',
18:  'sla_alert',
19:  'plugin_task'
