301:async function loadAiTicketAgentConfig(): Promise<AiTicketAgentConfig> {
302:  const rows = await prisma.pluginConfig.findMany({
303:    where: { pluginId: AI_TICKET_AGENT_PLUGIN_ID },
304:    select: {
305:      key: true,
306:      valueJson: true,
307:      valueEncrypted: true,
308:      isSecret: true
309:    }
310:  })
311:  const configs = new Map<string, unknown>()
312:
313:  for (const row of rows) {
314:    configs.set(row.key, row.isSecret ? parseSecretConfigValue(row.valueEncrypted) : row.valueJson)
315:  }
316:
317:  return {
318:    enabled: getConfigBoolean(configs, 'enabled', false),
319:    mode: normalizeAiMode(getConfigString(configs, 'mode', 'draft')),
320:    apiBaseUrl: getConfigString(configs, 'apiBaseUrl'),
321:    apiKey: getConfigString(configs, 'apiKey'),
322:    model: getConfigString(configs, 'model', DEFAULT_AI_MODEL),
323:    temperature: Math.min(Math.max(getConfigNumber(configs, 'temperature', 0.2), 0), 1),
324:    timeoutMs: Math.min(Math.max(getConfigNumber(configs, 'timeoutMs', DEFAULT_AI_TIMEOUT_MS), 1000), 120_000),
325:    autoReplyCategories: getConfigStringArray(configs, 'autoReplyCategories', DEFAULT_AI_AUTO_REPLY_CATEGORIES),
326:    confidenceThreshold: Math.min(Math.max(getConfigNumber(configs, 'confidenceThreshold', DEFAULT_CONFIDENCE_THRESHOLD), 0), 1),
327:    dailyAutoReplyLimit: Math.max(Math.floor(getConfigNumber(configs, 'dailyAutoReplyLimit', DEFAULT_DAILY_AUTO_REPLY_LIMIT)), 0),
328:    ticketAutoReplyLimit: Math.max(Math.floor(getConfigNumber(configs, 'ticketAutoReplyLimit', DEFAULT_TICKET_AUTO_REPLY_LIMIT)), 0),
329:    cooldownSeconds: Math.max(Math.floor(getConfigNumber(configs, 'cooldownSeconds', DEFAULT_REPLY_COOLDOWN_SECONDS)), 0),
330:    showAiIdentity: getConfigBoolean(configs, 'showAiIdentity', true),
331:    systemPrompt: getConfigString(configs, 'systemPrompt') || null
332:  }
333:}
