1150:   */
RANGE 1151-1450
1151:  fastify.patch<{
1152:    Params: { id: string }
1153:    Body: { status: TicketStatus }
1154:  }>('/:id/status', {
1155:    onRequest: [fastify.authenticate]
1156:  }, async (request: FastifyRequest<{
