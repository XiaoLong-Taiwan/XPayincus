859:async function submitCreate() {
860:  if (!configStore.ticketEnabled) return
861:  if (createForm.value.subject.trim().length < 2) {
862:    toast.error(t('tickets.subject') + ' ' + t('common.error'))
863:    return
864:  }
865:  if (createAttachments.value.length === 0 && createForm.value.content.trim().length < 10) {
866:    toast.error(t('tickets.contentTooShort'))
867:    return
868:  }
869:  
870:  creating.value = true
871:  try {
872:    const res = await api.tickets.create({
873:      instanceId: createForm.value.instanceId || undefined,
874:      subject: createForm.value.subject.trim(),
875:      category: createForm.value.category,
876:      priority: createForm.value.priority,
877:      content: createForm.value.content.trim(),
878:      attachments: createAttachments.value
879:    })
880:    toast.success(t('tickets.createSuccess'))
881:    activeTab.value = 'my'
882:    await Promise.all([loadTickets(), loadPendingCount()])
883:    await router.replace({
884:      path: ticketsPath(),
885:      query: buildTicketsQuery({ tab: 'my', ticketId: res.ticket.id })
886:    })
887:  } catch (error: any) {
888:    toast.error(error?.message || t('common.error'))
889:  } finally {
890:    creating.value = false
891:  }
892:}
