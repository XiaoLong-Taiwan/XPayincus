191:function revokeAttachmentUrls(): void {
192:  for (const url of Object.values(attachmentObjectUrls.value)) {
193:    URL.revokeObjectURL(url)
194:  }
195:  attachmentObjectUrls.value = {}
196:  attachmentLoadingIds.value = {}
197:}
198:
199:async function ensureAttachmentObjectUrl(attachment: TicketMessageAttachment): Promise<void> {
200:  if (attachmentObjectUrls.value[attachment.id] || attachmentLoadingIds.value[attachment.id]) {
201:    return
202:  }
203:
204:  attachmentLoadingIds.value = {
205:    ...attachmentLoadingIds.value,
206:    [attachment.id]: true
207:  }
208:
209:  try {
210:    const blob = await api.tickets.getAttachmentContent(attachment.id)
211:    attachmentObjectUrls.value = {
212:      ...attachmentObjectUrls.value,
213:      [attachment.id]: URL.createObjectURL(blob)
214:    }
215:  } catch (error) {
216:    console.error('Failed to load ticket attachment:', error)
217:  } finally {
218:    const nextLoadingIds = { ...attachmentLoadingIds.value }
219:    delete nextLoadingIds[attachment.id]
220:    attachmentLoadingIds.value = nextLoadingIds
RANGE 430-910
430:  } finally {
431:    supportContextLoading.value = false
432:  }
433:}
434:
435:async function generateAiDraft(): Promise<void> {
436:  if (!authStore.isAdmin || !selectedTicket.value) return
437:  aiDraftLoading.value = true
438:  try {
439:    const result = await requestAiDraft(selectedTicket.value.id)
440:    replyContent.value = result.draft
441:    toast.success(t('tickets.support.aiDraftReady'))
442:    await nextTick()
443:    const textarea = document.getElementById('ticket-reply-textarea')
444:    if (textarea instanceof HTMLTextAreaElement) {
445:      textarea.focus()
446:    }
447:  } catch (error: any) {
448:    const code = error?.code
449:    if (code === 'AI_TICKET_PLUGIN_DISABLED') {
450:      toast.error(t('tickets.support.aiPluginDisabled'))
451:    } else if (code === 'AI_TICKET_AGENT_MODEL_NOT_CONFIGURED') {
452:      toast.error(t('tickets.support.aiModelNotConfigured'))
453:    } else if (code === 'AI_TICKET_DRAFT_BLOCKED') {
454:      toast.error(t('tickets.support.aiDraftBlocked'))
455:    } else {
456:      toast.error(error?.message || t('common.error'))
457:    }
458:  } finally {
459:    aiDraftLoading.value = false
460:  }
461:}
462:
463:async function sendAiReply(): Promise<void> {
464:  if (!authStore.isAdmin || !selectedTicket.value || aiReplyLoading.value) return
465:  if (!window.confirm(t('tickets.support.aiReplyConfirm'))) return
466:
467:  aiReplyLoading.value = true
468:  try {
469:    const result = await requestAiReply(selectedTicket.value.id)
470:    messages.value.push(result.data)
471:    messagesTotal.value++
472:    await ensureMessageAttachmentUrls([result.data])
473:    replyContent.value = ''
474:    toast.success(t('tickets.support.aiReplySent'))
475:    await loadSupportContext()
476:    await nextTick()
477:    const container = document.getElementById('messages-container')
478:    if (container) container.scrollTop = container.scrollHeight
479:  } catch (error: any) {
480:    const code = error?.code
481:    if (code === 'AI_TICKET_PLUGIN_DISABLED' || code === 'AI_TICKET_PLUGIN_PERMISSION_MISSING') {
482:      toast.error(t('tickets.support.aiPluginDisabled'))
483:    } else if (code === 'AI_TICKET_AGENT_MODEL_NOT_CONFIGURED') {
484:      toast.error(t('tickets.support.aiModelNotConfigured'))
485:    } else if (code === 'AI_TICKET_AGENT_REPLY_MODE_DISABLED') {
486:      toast.error(t('tickets.support.aiReplyModeDisabled'))
487:    } else if (code === 'AI_TICKET_REPLY_HANDOFF_REQUIRED') {
488:      toast.error(t('tickets.support.aiReplyHandoffRequired'))
489:    } else if (code === 'AI_TICKET_REPLY_BLOCKED') {
490:      toast.error(t('tickets.support.aiReplyBlocked'))
491:    } else {
492:      toast.error(error?.message || t('common.error'))
493:    }
494:  } finally {
495:    aiReplyLoading.value = false
496:  }
497:}
