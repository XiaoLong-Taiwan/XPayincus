8:import { schedule } from 'node-cron'
9:import { prisma } from '../db/prisma.js'
10:import * as ticketDb from '../db/tickets.js'
11:import { createLog, LogModule, LogResult } from '../db/logs.js'
12:import { sendNotification } from '../lib/notifier.js'
13:import {
14:  AI_TICKET_REPLY_PERMISSION,
15:  auditAiTicketReply,
16:  generateAiTicketReply,
17:  getAiTicketAutomationStatus,
18:  getAiTicketPermission
19:} from './ai-ticket-context.js'
20:
21:const AUTO_REPLY_SCAN_BATCH_SIZE = 5
22:const AUTO_REPLY_CANDIDATE_LOOKAHEAD = 30
23:
24:let schedulerStarted = false
25:let running = false
26:const processingTicketIds = new Set<number>()
27:
28:async function getAiReplyActor(): Promise<{ id: number; username: string } | null> {
29:  return prisma.user.findFirst({
30:    where: {
31:      role: 'admin',
32:      status: 'active'
33:    },
34:    orderBy: { id: 'asc' },
35:    select: {
36:      id: true,
37:      username: true
38:    }
39:  })
40:}
41:
42:async function loadAutoReplyCandidates(allowedCategories: string[]): Promise<Array<{ id: number }>> {
43:  const tickets = await prisma.ticket.findMany({
44:    where: {
45:      status: { in: ['open', 'in_progress'] },
46:      category: { in: allowedCategories },
47:      priority: { not: 'urgent' },
48:      OR: [
49:        { hostId: null },
50:        { host: { user: { role: 'admin' } } }
51:      ]
52:    },
53:    orderBy: [
54:      { updatedAt: 'asc' },
55:      { id: 'asc' }
56:    ],
57:    take: AUTO_REPLY_CANDIDATE_LOOKAHEAD,
58:    select: {
59:      id: true,
60:      messages: {
61:        orderBy: { createdAt: 'desc' },
62:        take: 1,
63:        select: { isFromOwner: true }
64:      }
65:    }
66:  })
67:
68:  return tickets
69:    .filter(ticket => ticket.messages[0]?.isFromOwner === false)
70:    .slice(0, AUTO_REPLY_SCAN_BATCH_SIZE)
71:    .map(ticket => ({ id: ticket.id }))
72:}
73:
74:async function loadTicketForAutoReply(ticketId: number) {
75:  return prisma.ticket.findUnique({
76:    where: { id: ticketId },
77:    select: {
78:      id: true,
79:      userId: true,
80:      hostId: true,
81:      subject: true,
82:      status: true,
83:      host: {
84:        select: {
85:          user: { select: { role: true } },
86:          name: true
87:        }
88:      },
89:      messages: {
90:        orderBy: { createdAt: 'desc' },
91:        take: 1,
92:        select: { isFromOwner: true }
93:      }
94:    }
95:  })
96:}
97:
98:async function isStillAutoReplyEligible(ticketId: number): Promise<boolean> {
99:  const ticket = await loadTicketForAutoReply(ticketId)
100:  if (!ticket) return false
101:  if (ticket.status !== 'open' && ticket.status !== 'in_progress') return false
102:  if (ticket.hostId && ticket.host?.user.role !== 'admin') return false
103:  return ticket.messages[0]?.isFromOwner === false
104:}
105:
106:async function processAutoReplyTicket(ticketId: number, actor: { id: number; username: string }): Promise<'sent' | 'skipped' | 'blocked' | 'failed'> {
107:  if (processingTicketIds.has(ticketId)) return 'skipped'
108:  processingTicketIds.add(ticketId)
109:
110:  try {
111:    if (!await isStillAutoReplyEligible(ticketId)) {
112:      return 'skipped'
113:    }
114:
115:    const result = await generateAiTicketReply(ticketId)
116:    if (result.mode !== 'auto' || !result.canSend) {
117:      await auditAiTicketReply({
118:        actorUserId: actor.id,
119:        ticketId,
120:        result: 'blocked',
121:        reason: result.sendBlockedReasons.length > 0 ? result.sendBlockedReasons.join(',') : 'AI_TICKET_AUTO_REPLY_BLOCKED'
122:      })
123:      return 'blocked'
124:    }
125:    if (!result.safety.passed) {
126:      await auditAiTicketReply({
127:        actorUserId: actor.id,
128:        ticketId,
129:        result: 'blocked',
130:        reason: result.safety.blockedReasons.join(',')
131:      })
132:      return 'blocked'
133:    }
134:
135:    const ticket = await loadTicketForAutoReply(ticketId)
136:    if (!ticket || !await isStillAutoReplyEligible(ticketId)) {
137:      return 'skipped'
138:    }
139:
140:    await ticketDb.addTicketMessage(ticketId, actor.id, result.draft, true, [])
141:
142:    try {
143:      await sendNotification(ticket.userId, 'ticket_replied', {
144:        subject: ticket.subject,
145:        hostName: ticket.host?.name || 'ç³»ç»Ÿ',
146:        replyFrom: actor.username
147:      })
148:    } catch (err) {
149:      console.error(`[AiTicketAutoReply] é€šçŸ¥å¤±è´¥ (å·¥å• #${ticketId}):`, err)
150:    }
151:
152:    await auditAiTicketReply({
153:      actorUserId: actor.id,
154:      ticketId,
155:      result: 'success'
156:    })
157:
158:    return 'sent'
159:  } catch (error) {
160:    const message = error instanceof Error ? error.message : String(error)
161:    await auditAiTicketReply({
162:      actorUserId: actor.id,
163:      ticketId,
164:      result: 'failed',
165:      reason: message.startsWith('AI_TICKET_') ? message : 'AI_TICKET_AUTO_REPLY_FAILED'
166:    })
167:    return 'failed'
168:  } finally {
169:    processingTicketIds.delete(ticketId)
170:  }
171:}
172:
173:export async function runAiTicketAutoReplyJob(): Promise<{ scanned: number; sent: number; blocked: number; skipped: number; failed: number }> {
174:  const summary = { scanned: 0, sent: 0, blocked: 0, skipped: 0, failed: 0 }
175:
176:  if (running) {
177:    summary.skipped = 1
178:    return summary
179:  }
180:
181:  running = true
182:  try {
183:    const permission = await getAiTicketPermission(AI_TICKET_REPLY_PERMISSION)
184:    if (!permission.allowed) return summary
185:
186:    const status = await getAiTicketAutomationStatus()
187:    if (!status.enabled || status.mode !== 'auto') return summary
188:
189:    const actor = await getAiReplyActor()
190:    if (!actor) {
191:      await createLog(
192:        null,
193:        LogModule.PLUGIN,
194:        'ai_ticket.auto_reply',
195:        'AI ticket auto reply skipped: no active admin actor',
196:        LogResult.WARNING
197:      )
198:      return summary
199:    }
200:
201:    const candidates = await loadAutoReplyCandidates(status.autoReplyCategories)
202:    summary.scanned = candidates.length
203:
204:    for (const candidate of candidates) {
205:      const result = await processAutoReplyTicket(candidate.id, actor)
206:      summary[result] += 1
207:    }
208:
209:    if (summary.sent > 0 || summary.blocked > 0 || summary.failed > 0) {
210:      await createLog(
211:        actor.id,
212:        LogModule.PLUGIN,
213:        'ai_ticket.auto_reply',
214:        `AI ticket auto reply scanned=${summary.scanned} sent=${summary.sent} blocked=${summary.blocked} skipped=${summary.skipped} failed=${summary.failed}`,
215:        summary.failed > 0 ? LogResult.WARNING : LogResult.SUCCESS
216:      )
217:    }
218:
219:    return summary
220:  } catch (error) {
221:    console.error('[AiTicketAutoReply] è‡ªåŠ¨æŽ¥ç®¡ä»»åŠ¡å¤±è´¥:', error)
222:    summary.failed += 1
223:    return summary
224:  } finally {
225:    running = false
226:  }
227:}
228:
229:export function startAiTicketAutoReplyScheduler(): void {
230:  if (schedulerStarted) {
231:    return
232:  }
233:
234:  schedulerStarted = true
