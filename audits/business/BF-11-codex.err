201:async function fetchLskyDefaultStorageId(config: TicketImageLskyConfig): Promise<string> {
202:  const apiBase = resolveLskyApiBase(config.baseUrl, 'v2')
203:  const cacheKey = `${apiBase}:${config.token}`
204:  const cached = lskyStorageIdCache.get(cacheKey)
205:  if (cached && (Date.now() - cached.fetchedAt) < LSKY_STORAGE_CACHE_TTL_MS) {
206:    return cached.storageId
207:  }
208:
209:  const groupUrl = `${apiBase}/group`
210:  const response = await fetch(groupUrl, {
211:    method: 'GET',
212:    redirect: 'manual',
213:    signal: AbortSignal.timeout(LSKY_GROUP_TIMEOUT_MS),
214:    headers: buildLskyAuthHeaders(config.token)
215:  })
216:
217:  const responseText = await response.text()
218:  const payload: any = parseJsonResponse(responseText)
219:
220:  if (!response.ok || payload?.status === false) {
221:    throw new Error(extractLskyErrorMessage(payload, `Failed to fetch Lsky group info with status ${response.status}`))
222:  }
223:
224:  const storages = Array.isArray(payload?.data?.storages) ? payload.data.storages : []
225:  const firstStorage = storages.find((item: any) => item && (typeof item.id === 'number' || typeof item.id === 'string'))
226:  const storageId = firstStorage ? String(firstStorage.id) : ''
227:
228:  if (!storageId) {
229:    console.error('[Lsky] Unable to determine default storage_id from /group response', {
230:      groupUrl,
231:      status: response.status,
232:      bodyPreview: sanitizeResponsePreview(responseText)
233:    })
234:    throw new Error('Unable to determine Lsky storage_id automatically from /group')
235:  }
236:
237:  lskyStorageIdCache.set(cacheKey, {
238:    storageId,
239:    fetchedAt: Date.now()
240:  })
241:
242:  return storageId
243:}
