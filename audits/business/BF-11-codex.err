22:export type TicketSlaStatus = 'waiting_first_response' | 'waiting_user' | 'waiting_internal' | 'due_soon' | 'overdue' | 'met' | 'closed'
23:
24:function clampPagination(
25:  page: number | undefined,
26:  pageSize: number | undefined,
27:  fallbackPageSize: number,
28:  maxPageSize: number = 100
29:): { page: number; pageSize: number } {
30:  return {
31:    page: Number.isInteger(page) && page !== undefined && page > 0 ? page : 1,
32:    pageSize: Number.isInteger(pageSize) && pageSize !== undefined
33:      ? Math.min(Math.max(pageSize, 1), maxPageSize)
34:      : fallbackPageSize
35:  }
36:}
37:
38:function normalizeTicketStatus(status: TicketStatus | 'active' | undefined): TicketStatus | 'active' | undefined {
39:  if (status === 'active') return status
40:  return status && TICKET_STATUSES.has(status) ? status : undefined
41:}
42:
43:function normalizeSearchTerm(search: string | undefined): string {
44:  return search?.trim().slice(0, 128) ?? ''
45:}
46:
47:function getSearchId(searchTerm: string): number | null {
48:  const parsed = Number(searchTerm)
49:  return Number.isInteger(parsed) && parsed > 0 ? parsed : null
50:}
51:
52:function addMinutes(date: Date, minutes: number): Date {
53:  return new Date(date.getTime() + minutes * 60 * 1000)
54:}
55:
56:function getSlaMinutes(priority: TicketPriority): { firstResponse: number; resolution: number } {
57:  switch (priority) {
58:    case 'urgent':
59:      return { firstResponse: 30, resolution: 240 }
60:    case 'high':
61:      return { firstResponse: 120, resolution: 720 }
62:    case 'low':
63:      return { firstResponse: 1440, resolution: 5760 }
64:    case 'normal':
65:    default:
66:      return { firstResponse: 480, resolution: 2880 }
67:  }
68:}
69:
70:function computeSlaStatus(input: {
71:  status: TicketStatus
72:  firstResponseDueAt: Date | null
73:  resolutionDueAt: Date | null
74:  firstRespondedAt: Date | null
75:  resolvedAt: Date | null
76:  closedAt: Date | null
77:  lastMessage?: { isFromOwner: boolean } | null
78:}, now = new Date()): TicketSlaStatus {
79:  if (input.status === 'closed') return 'closed'
80:  if (input.resolvedAt || input.status === 'resolved') return 'met'
81:
82:  const hasFirstResponse = Boolean(input.firstRespondedAt)
83:  if (!hasFirstResponse && input.firstResponseDueAt && input.firstResponseDueAt.getTime() < now.getTime()) {
84:    return 'overdue'
85:  }
86:  if (input.resolutionDueAt && input.resolutionDueAt.getTime() < now.getTime()) {
87:    return 'overdue'
88:  }
89:
90:  const soonMs = 60 * 60 * 1000
91:  if ((!hasFirstResponse && input.firstResponseDueAt && input.firstResponseDueAt.getTime() - now.getTime() <= soonMs) ||
92:      (input.resolutionDueAt && input.resolutionDueAt.getTime() - now.getTime() <= soonMs)) {
93:    return 'due_soon'
94:  }
95:
96:  if (!hasFirstResponse) return 'waiting_first_response'
97:  if (input.lastMessage?.isFromOwner) return 'waiting_user'
98:  return 'waiting_internal'
99:}
100:
101:function toIso(value: Date | null | undefined): string | null {
102:  return value ? value.toISOString() : null
103:}
104:
105:export function normalizeTicketObjectLinkType(type: string | undefined): TicketObjectLinkType | null {
106:  if (!type || !TICKET_LINK_TYPES.has(type as TicketObjectLinkType)) return null
107:  return type as TicketObjectLinkType
108:}
