103:function parseJsonResponse(text: string): unknown {
104:  const normalizedText = text.replace(/^\uFEFF/, '')
105:  if (!normalizedText.trim()) {
106:    return null
107:  }
108:
109:  try {
110:    return JSON.parse(normalizedText)
111:  } catch {
112:    return null
113:  }
114:}
115:
116:function sanitizeResponsePreview(text: string): string {
