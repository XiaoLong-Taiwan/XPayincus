980:  /**
981:   * å›žå¤å·¥å•ï¼ˆç”¨æˆ·æˆ–ç®¡ç†å‘˜ï¼‰
982:   * POST /tickets/:id/messages
983:   */
984:  fastify.post<{
985:    Params: { id: string }
986:  }>('/:id/messages', {
987:    onRequest: [fastify.authenticate],
988:    bodyLimit: TICKET_UPLOAD_BODY_LIMIT
989:  }, async (request: FastifyRequest<{
990:    Params: { id: string }
991:  }>, reply: FastifyReply) => {
992:    const { user } = request
993:    const ticketId = parsePositiveId(request.params.id)
994:
995:    if (ticketId === null) {
996:      return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
997:    }
998:
999:    let uploadedAttachments: ticketDb.CreateTicketMessageAttachmentData[] = []
1000:
1001:    try {
1002:      const payload = await readTicketPayload(request)
1003:      const content = sanitizeContent(payload.fields.content)
1004:
1005:      // è¾“å…¥éªŒè¯
1006:      if (content.length > 5000) {
1007:        return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Content must be 0-5000 characters'))
1008:      }
1009:      if (payload.images.length === 0 && content.length < 1) {
1010:        return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Content must be 1-5000 characters when no images are attached'))
1011:      }
1012:
1013:      // æƒé™æ£€æŸ¥
1014:      const access = await ticketDb.canUserAccessTicket(user.id, ticketId, user.role)
1015:      if (!access.canAccess) {
1016:        return reply.code(404).send(apiError(ErrorCode.NOT_FOUND))
1017:      }
1018:
1019:      // èŽ·å–å·¥å•è¯¦æƒ…
1020:      const ticket = await ticketDb.getTicketById(ticketId)
1021:      if (!ticket) {
1022:        return reply.code(404).send(apiError(ErrorCode.NOT_FOUND))
1023:      }
1024:
1025:      // æ£€æŸ¥å·¥å•çŠ¶æ€
1026:      if (ticket.status === 'closed') {
1027:        return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Cannot reply to a closed ticket'))
1028:      }
1029:
1030:      if (payload.images.length > 0) {
1031:        uploadedAttachments = await uploadTicketImages(payload.images)
1032:      }
1033:
1034:      // æ·»åŠ æ¶ˆæ¯
1035:      const message = await ticketDb.addTicketMessage(
1036:        ticketId,
1037:        user.id,
1038:        content,
1039:        access.isOwner,
1040:        uploadedAttachments
1041:      )
1042:
1043:      // å‘é€é€šçŸ¥
1044:      // åˆ¤æ–­æ˜¯å¦æ˜¯æ‰˜ç®¡å®žä¾‹çš„å·¥å•ï¼ˆå®¿ä¸»æœºæœ‰æ‰€æœ‰è€…ä¸”ä¸æ˜¯ç®¡ç†å‘˜è´¦å·ï¼‰
1045:      const hostedTicketHost = await getTicketHostOwnership(ticket.host?.id)
1046:      const isHostedTicket = hostedTicketHost?.user.role === 'user'
1047:
1048:      try {
1049:        if (access.isOwner) {
1050:          // å®¿ä¸»æœºæ‰€æœ‰è€…æˆ–ç®¡ç†å‘˜å›žå¤ï¼Œé€šçŸ¥å·¥å•åˆ›å»ºç”¨æˆ·
1051:          await sendNotification(ticket.userId, 'ticket_replied', {
1052:            subject: ticket.subject,
1053:            hostName: ticket.host?.name || 'ç³»ç»Ÿ',
1054:            replyFrom: user.username
1055:          })
1056:        } else {
1057:          // ç”¨æˆ·å›žå¤å·¥å•
1058:          if (isHostedTicket) {
1059:            // æ‰˜ç®¡å®žä¾‹çš„å·¥å•ï¼šé€šçŸ¥å®¿ä¸»æœºæ‰€æœ‰è€…
1060:            await sendNotification(hostedTicketHost!.userId, 'ticket_replied', {
1061:              subject: ticket.subject,
1062:              hostName: ticket.host?.name || 'ç³»ç»Ÿ',
1063:              replyFrom: user.username
1064:            })
1065:          } else {
1066:            // å®˜æ–¹èŠ‚ç‚¹æˆ–æ— å®žä¾‹çš„å·¥å•ï¼šé€šçŸ¥æ‰€æœ‰ç®¡ç†å‘˜
1067:            const adminIds = await getAllAdminUserIds()
1068:            for (const adminId of adminIds) {
1069:              await sendNotification(adminId, 'ticket_replied', {
1070:                subject: ticket.subject,
1071:                hostName: ticket.host?.name || 'ç³»ç»Ÿ',
1072:                replyFrom: user.username
1073:              })
1074:            }
1075:          }
1076:        }
1077:      } catch (err) {
1078:        console.error('[Tickets] Failed to send notification:', err)
1079:      }
1080:
1081:      emitPluginEvent('ticket.replied', {
1082:        dedupeKey: `ticket.replied:${ticketId}:${message.id}`,
1083:        ticketId,
1084:        messageId: message.id,
1085:        userId: user.id,
1086:        username: user.username,
1087:        subject: ticket.subject,
1088:        isFromOwner: access.isOwner,
1089:        status: ticket.status,
1090:        attachmentCount: uploadedAttachments.length,
1091:        createdAt: message.createdAt
1092:      }, { id: user.id, role: user.role, username: user.username }, { dedupeKey: `ticket.replied:${ticketId}:${message.id}` })
1093:
1094:      return reply.code(201).send({
1095:        message: 'Message added successfully',
1096:        data: message
1097:      })
1098:    } catch (error: any) {
1099:      if (uploadedAttachments.length > 0) {
1100:        await cleanupUploadedTicketImages(uploadedAttachments)
1101:      }
1102:      if (!isHandledTicketPayloadError(error)) {
1103:        throw error
1104:      }
1105:      return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, error?.message || 'Invalid ticket reply payload'))
1106:    }
1107:  })
