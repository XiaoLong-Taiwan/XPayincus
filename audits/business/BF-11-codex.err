292:export async function createTicket(data: CreateTicketData): Promise<{ ticketId: number; messageId: number }> {
293:  const result = await prisma.$transaction(async (tx) => {
294:    const createdAt = new Date()
295:    const priority = data.priority || 'normal'
296:    const sla = getSlaMinutes(priority)
297:    // åˆ›å»ºå·¥å•
298:    const ticket = await tx.ticket.create({
299:      data: {
300:        userId: data.userId,
301:        hostId: data.hostId ?? null,  // å…è®¸ä¸º null
302:        instanceId: data.instanceId ?? null,
303:        subject: data.subject,
304:        category: data.category || 'general',
305:        priority,
306:        status: 'open',
307:        firstResponseDueAt: addMinutes(createdAt, sla.firstResponse),
308:        resolutionDueAt: addMinutes(createdAt, sla.resolution)
309:      }
310:    })
311:
312:    // åˆ›å»ºé¦–æ¡æ¶ˆæ¯
313:    const message = await tx.ticketMessage.create({
314:      data: {
315:        ticketId: ticket.id,
316:        senderId: data.userId,
317:        content: data.content,
318:        isFromOwner: false
319:      }
320:    })
321:
322:    if (data.attachments && data.attachments.length > 0) {
323:      await tx.ticketMessageAttachment.createMany({
324:        data: data.attachments.map(attachment => ({
325:          ticketId: ticket.id,
326:          messageId: message.id,
327:          uploaderId: data.userId,
328:          provider: attachment.provider,
329:          providerVersion: attachment.providerVersion,
330:          providerFileId: attachment.providerFileId ?? null,
331:          filename: attachment.filename,
332:          originalName: attachment.originalName,
333:          mimeType: attachment.mimeType,
334:          sizeBytes: attachment.sizeBytes,
335:          width: attachment.width ?? null,
336:          height: attachment.height ?? null,
337:          url: attachment.url,
338:          thumbnailUrl: attachment.thumbnailUrl ?? null
339:        }))
340:      })
341:    }
342:
343:    return { ticketId: ticket.id, messageId: message.id }
344:  })
345:
346:  return result
347:}
