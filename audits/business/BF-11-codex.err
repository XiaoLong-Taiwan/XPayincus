949:          content: cleanText(message.content, 2000),
950:          createdAt: message.createdAt.toISOString()
951:        }))
952:    },
953:    user: user ? {
954:      username: user.username,
955:      accountStatus: user.status,
956:      registeredAt: user.createdAt.toISOString(),
957:      balance: valueToString(user.balance),
958:      counts: user._count
959:    } : null,
960:    payments: payments.map(payment => ({
961:      id: payment.id,
962:      orderRef: maskIdentifier(payment.orderNo),
963:      amount: valueToString(payment.amount),
964:      actualAmount: nullableValueToString(payment.actualAmount),
965:      status: payment.status,
966:      paymentMethod: payment.paymentMethod,
967:      providerName: payment.provider.name,
968:      createdAt: payment.createdAt.toISOString(),
969:      completedAt: toIso(payment.completedAt)
970:    })),
971:    instances: instances
972:      .map(instance => {
973:        const latestTask = instance.instanceTasks[0] || null
974:        return {
975:          id: instance.id,
976:          name: instance.name,
977:          status: instance.status,
978:          packageName: instance.package?.name || null,
979:          planName: instance.packagePlan?.name || null,
980:          cpu: instance.cpu,
981:          memory: instance.memory,
982:          disk: instance.disk,
983:          publicIpv4: instance.ipv4,
984:          publicIpv6: instance.ipv6,
985:          expiresAt: toIso(instance.expiresAt),
986:          monthlyTrafficUsed: valueToString(instance.monthlyTrafficUsed),
987:          monthlyTrafficLimit: nullableValueToString(instance.monthlyTrafficLimit),
988:          trafficStatus: instance.trafficStatus,
989:          portCount: instance._count.portMappings,
990:          latestTask: latestTask ? {
991:            taskType: latestTask.taskType,
992:            status: latestTask.status,
993:            progress: latestTask.progress,
994:            createdAt: latestTask.createdAt.toISOString(),
995:            finishedAt: toIso(latestTask.finishedAt)
