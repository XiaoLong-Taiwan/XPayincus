270:export async function uploadTicketImageToLsky(
271:  input: LskyTicketImageUploadInput
272:): Promise<LskyTicketImageUploadResult> {
273:  const config = await getTicketImageLskyConfig()
274:  if (!config) {
275:    throw new Error('Lsky image bed is not configured')
276:  }
277:
278:  const resolvedTargetId = config.apiVersion === 'v2'
279:    ? (config.targetId || await fetchLskyDefaultStorageId(config))
280:    : config.targetId
281:
282:  const formData = new FormData()
283:  formData.append(
284:    'file',
285:    new Blob([input.buffer], { type: input.contentType }),
286:    input.filename
287:  )
288:
289:  if (resolvedTargetId) {
290:    if (config.apiVersion === 'v2') {
291:      formData.append('storage_id', resolvedTargetId)
292:    } else {
293:      formData.append('strategy_id', resolvedTargetId)
294:    }
295:  }
296:
297:  const uploadUrl = `${resolveLskyApiBase(config.baseUrl, config.apiVersion)}/upload`
298:
299:  const response = await fetch(uploadUrl, {
300:    method: 'POST',
301:    redirect: 'manual',
302:    signal: AbortSignal.timeout(LSKY_UPLOAD_TIMEOUT_MS),
303:    headers: buildLskyAuthHeaders(config.token),
304:    body: formData
305:  })
306:
307:  const responseText = await response.text()
308:  const payload: any = parseJsonResponse(responseText)
309:
310:  if (!payload) {
311:    console.error('[Lsky] Upload returned non-JSON response', {
312:      uploadUrl,
313:      status: response.status,
314:      contentType: response.headers.get('content-type'),
315:      bodyPreview: sanitizeResponsePreview(responseText)
316:    })
317:  }
318:
319:  if (!response.ok || payload?.status === false) {
320:    throw new Error(extractLskyErrorMessage(payload, `Lsky upload failed with status ${response.status}`))
321:  }
322:
323:  const dataCandidates = extractUploadDataCandidates(payload)
324:
325:  let resolvedData: any = null
326:  let url: string | null = null
327:  let thumbnailUrl: string | null = null
328:  for (const candidate of dataCandidates) {
329:    const links = candidate?.links ?? {}
330:    const candidateUrl = pickString(
331:      candidate?.url,
332:      candidate?.public_url,
333:      links?.url,
334:      links?.raw_url,
335:      extractUrlFromHtmlSnippet(asNullableString(links?.html)),
336:      extractUrlFromHtmlSnippet(asNullableString(links?.markdown)),
337:      joinUrl(config.baseUrl, pickString(candidate?.pathname, candidate?.path))
338:    )
339:
340:    if (candidateUrl) {
341:      resolvedData = candidate
342:      url = candidateUrl
343:      thumbnailUrl = pickString(
344:        candidate?.thumbnail_url,
345:        links?.thumbnail_url,
346:        candidateUrl
347:      )
348:      break
349:    }
350:  }
351:
352:  if (!url) {
353:    console.error('[Lsky] Upload succeeded but no image URL was returned', {
354:      uploadUrl,
355:      status: response.status,
356:      contentType: response.headers.get('content-type'),
357:      bodyPreview: sanitizeResponsePreview(responseText),
358:      responseKeys: payload && typeof payload === 'object' ? Object.keys(payload as Record<string, unknown>) : [],
359:      dataCandidateKeys: dataCandidates.map(candidate => Object.keys(candidate as Record<string, unknown>))
360:    })
361:    throw new Error('Lsky upload succeeded but no image URL was returned')
362:  }
363:
364:  const safeImageUrl = await assertSafeHttpUrl(url, 'Lsky image URL')
365:  const safeThumbnailUrl = thumbnailUrl
366:    ? (await assertSafeHttpUrl(thumbnailUrl, 'Lsky thumbnail URL')).toString()
367:    : null
368:
369:  const data = resolvedData ?? dataCandidates[0] ?? {}
370:  const mimeType = normalizeAllowedImageMimeType(pickString(data?.mimetype, data?.mime_type, input.contentType))
371:    ?? normalizeAllowedImageMimeType(input.contentType)
372:  if (!mimeType) {
373:    throw new Error('Lsky upload returned unsupported image MIME type')
374:  }
375:
376:  return {
377:    provider: 'lsky',
378:    providerVersion: config.apiVersion,
379:    providerFileId: config.apiVersion === 'v2'
380:      ? pickProviderFileId(data?.id, data?.key, data?.hash, data?.pathname, data?.path)
381:      : pickProviderFileId(data?.key, data?.id, data?.hash, data?.pathname, data?.path),
382:    filename: pickString(data?.name, data?.filename, input.filename) || input.filename,
383:    originalName: input.filename,
384:    mimeType,
385:    sizeBytes: pickNumber(data?.size, data?.file_size, input.sizeBytes) || input.sizeBytes,
386:    width: pickNumber(data?.width),
387:    height: pickNumber(data?.height),
388:    url: safeImageUrl.toString(),
389:    thumbnailUrl: safeThumbnailUrl
390:  }
391:}
392:
393:export async function deleteTicketImageFromLsky(providerVersion: string, providerFileId: string | null): Promise<boolean> {
394:  if (!providerFileId) {
395:    return false
396:  }
397:
398:  const config = await getTicketImageLskyConfig()
399:  if (!config) {
400:    return false
401:  }
402:
403:  const apiVersion = providerVersion === 'v2' ? 'v2' : 'v1'
404:  const apiBase = resolveLskyApiBase(config.baseUrl, apiVersion)
405:  const numericId = apiVersion === 'v2' ? parseProviderNumericId(providerFileId) : null
406:  if (apiVersion === 'v2' && numericId === null) {
407:    return false
408:  }
409:
410:  const deleteUrl = apiVersion === 'v2'
411:    ? `${apiBase}/user/photos`
412:    : `${apiBase}/images/${encodeURIComponent(providerFileId)}`
413:
414:  try {
415:    const response = await fetch(deleteUrl, {
416:      method: 'DELETE',
417:      redirect: 'manual',
418:      signal: AbortSignal.timeout(LSKY_DELETE_TIMEOUT_MS),
419:      headers: apiVersion === 'v2'
420:        ? { ...buildLskyAuthHeaders(config.token), 'Content-Type': 'application/json' }
421:        : buildLskyAuthHeaders(config.token),
422:      body: apiVersion === 'v2' ? JSON.stringify([numericId]) : undefined
423:    })
424:    const responseText = await response.text()
425:    const payload: any = parseJsonResponse(responseText)
426:
427:    if (!response.ok || payload?.status === false) {
428:      console.warn('[Lsky] Delete did not confirm success', {
429:        apiVersion,
430:        deleteUrl,
431:        status: response.status,
432:        contentType: response.headers.get('content-type'),
433:        providerFileIdLength: providerFileId.length,
434:        numericIdPresent: numericId !== null,
435:        bodyPreview: sanitizeResponsePreview(responseText)
436:      })
437:      return false
438:    }
439:
440:    return true
441:  } catch (error) {
442:    console.warn('[Lsky] Delete request failed', {
443:      apiVersion,
444:      deleteUrl,
445:      providerFileIdLength: providerFileId.length,
446:      numericIdPresent: numericId !== null,
447:      errorMessage: sanitizeTokensInString(error instanceof Error ? error.message : String(error))
448:    })
449:    return false
450:  }
451:}
