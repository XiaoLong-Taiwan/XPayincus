68:function handleFileChange(event: Event): void {
69:  const target = event.target as HTMLInputElement
70:  const selectedFiles = Array.from(target.files || [])
71:  if (selectedFiles.length === 0) {
72:    return
73:  }
74:
75:  const nextFiles = [...props.modelValue]
76:
77:  for (const file of selectedFiles) {
78:    if (nextFiles.length >= props.maxFiles) {
