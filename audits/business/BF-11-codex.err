1:import type { FastifyRequest } from 'fastify'
2:import type * as ticketDb from '../db/tickets.js'
3:import { deleteTicketImageFromLsky, uploadTicketImageToLsky } from './lsky.js'
4:
5:export const MAX_TICKET_IMAGES = 6
6:export const MAX_TICKET_IMAGE_SIZE = 50 * 1024 * 1024
7:export const TICKET_UPLOAD_BODY_LIMIT = (MAX_TICKET_IMAGES * MAX_TICKET_IMAGE_SIZE) + (4 * 1024 * 1024)
8:export const ALLOWED_IMAGE_MIME_TYPES = new Set([
9:  'image/jpeg',
10:  'image/png',
11:  'image/webp',
12:  'image/gif',
13:  'image/avif'
14:])
15:
16:export interface ParsedTicketPayload {
17:  fields: Record<string, string>
18:  images: Array<{
19:    buffer: Buffer
20:    filename: string
21:    contentType: string
22:    sizeBytes: number
23:  }>
24:}
25:
26:export function isMultipartRequest(request: FastifyRequest): boolean {
27:  return typeof (request as FastifyRequest & { isMultipart?: () => boolean }).isMultipart === 'function'
28:    && (request as FastifyRequest & { isMultipart: () => boolean }).isMultipart()
29:}
30:
31:export async function readTicketPayload(request: FastifyRequest): Promise<ParsedTicketPayload> {
32:  if (!isMultipartRequest(request)) {
33:    const body = (request.body ?? {}) as Record<string, unknown>
34:    const fields: Record<string, string> = {}
35:
36:    for (const [key, value] of Object.entries(body)) {
37:      if (value !== null && value !== undefined) {
38:        fields[key] = String(value)
39:      }
40:    }
41:
42:    return { fields, images: [] }
43:  }
44:
45:  const multipartRequest = request as FastifyRequest & {
46:    parts: () => AsyncIterable<any>
47:  }
48:  const fields: Record<string, string> = {}
49:  const images: ParsedTicketPayload['images'] = []
50:
51:  for await (const part of multipartRequest.parts()) {
52:    if (part.type === 'file') {
53:      if (part.fieldname !== 'images') {
54:        await part.toBuffer()
55:        continue
56:      }
57:
58:      if (!part.mimetype || !ALLOWED_IMAGE_MIME_TYPES.has(part.mimetype)) {
59:        throw new Error('Only JPG, PNG, WebP, GIF and AVIF images are supported')
60:      }
61:
62:      if (images.length >= MAX_TICKET_IMAGES) {
63:        throw new Error(`A ticket message can contain at most ${MAX_TICKET_IMAGES} images`)
64:      }
65:
66:      const buffer = await part.toBuffer()
67:      if (buffer.length === 0) {
68:        continue
69:      }
70:
71:      if (buffer.length > MAX_TICKET_IMAGE_SIZE) {
72:        throw new Error(`Each image must be no larger than ${MAX_TICKET_IMAGE_SIZE / (1024 * 1024)}MB`)
73:      }
74:
75:      images.push({
76:        buffer,
77:        filename: part.filename || `ticket-image-${Date.now()}`,
78:        contentType: part.mimetype,
79:        sizeBytes: buffer.length
80:      })
81:      continue
82:    }
83:
84:    fields[part.fieldname] = typeof part.value === 'string' ? part.value : String(part.value ?? '')
85:  }
86:
87:  return { fields, images }
88:}
89:
90:export async function uploadTicketImages(
91:  images: ParsedTicketPayload['images']
92:): Promise<ticketDb.CreateTicketMessageAttachmentData[]> {
93:  const uploaded: ticketDb.CreateTicketMessageAttachmentData[] = []
94:
95:  try {
96:    for (const image of images) {
97:      const result = await uploadTicketImageToLsky(image)
98:      uploaded.push({
99:        provider: result.provider,
100:        providerVersion: result.providerVersion,
101:        providerFileId: result.providerFileId,
102:        filename: result.filename,
103:        originalName: result.originalName,
104:        mimeType: result.mimeType,
105:        sizeBytes: result.sizeBytes,
106:        width: result.width,
107:        height: result.height,
108:        url: result.url,
109:        thumbnailUrl: result.thumbnailUrl
110:      })
111:    }
112:  } catch (error) {
113:    if (uploaded.length > 0) {
114:      await cleanupUploadedTicketImages(uploaded)
115:    }
116:    throw error
117:  }
118:
119:  return uploaded
120:}
121:
122:export async function cleanupUploadedTicketImages(
123:  attachments: Array<{ providerVersion: string; providerFileId?: string | null }>
124:): Promise<void> {
125:  await Promise.allSettled(
126:    attachments.map(attachment => deleteTicketImageFromLsky(attachment.providerVersion, attachment.providerFileId ?? null))
127:  )
128:}
129:
130:export function normalizeAllowedImageMimeType(value: string | null | undefined): string | null {
131:  const normalized = value?.split(';')[0]?.trim().toLowerCase()
132:  return normalized && ALLOWED_IMAGE_MIME_TYPES.has(normalized) ? normalized : null
133:}
134:
135:export function isHandledTicketPayloadError(error: unknown): error is Error {
136:  if (!(error instanceof Error)) {
137:    return false
138:  }
139:
140:  return [
141:    'Only JPG',
142:    'A ticket message can contain at most',
143:    'Each image must be no larger than',
144:    'Lsky',
145:    'image bed',
146:    'Cannot reply to a closed ticket',
147:    'must use http or https',
148:    'Private or',
149:    'Unable to resolve hostname',
150:    'Targets resolving'
151:  ].some(fragment => error.message.includes(fragment))
152:}

