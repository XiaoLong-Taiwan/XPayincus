2461:  }, async (request, reply) => {
2462:    const apiToken = await authenticatePublicApiRequest(request, reply, 'tickets:write')
2463:    if (!apiToken) return
2464:    const id = parsePositiveId(request.params.id)
2465:    if (!id) return reply.code(400).send({ error: 'Invalid ticket id', code: 'INVALID_TICKET_ID' })
2466:    const action = normalizePublicTicketStatusAction(request.body?.action)
2467:    if (!action) {
2468:      return reply.code(400).send({
2469:        error: 'action must be one of close or reopen',
2470:        code: 'INVALID_TICKET_STATUS_ACTION'
2471:      })
2472:    }
2473:
2474:    const ticket = await prisma.ticket.findFirst({
2475:      where: { id, userId: apiToken.userId },
2476:      select: { id: true, userId: true, subject: true, status: true }
2477:    })
2478:    if (!ticket) return reply.code(404).send({ error: 'Ticket not found', code: 'TICKET_NOT_FOUND' })
2479:    if (action === 'close' && ticket.status === 'closed') {
2480:      return reply.code(409).send({ error: 'Ticket is already closed', code: 'TICKET_ALREADY_CLOSED' })
2481:    }
2482:    if (action === 'reopen' && ticket.status !== 'closed') {
2483:      return reply.code(409).send({ error: 'Only closed tickets can be reopened', code: 'TICKET_NOT_CLOSED' })
2484:    }
2485:
2486:    const now = new Date()
2487:    const nextStatus: TicketStatus = action === 'close' ? 'closed' : 'open'
2488:    const update = await prisma.ticket.updateMany({
2489:      where: {
2490:        id: ticket.id,
2491:        userId: apiToken.userId,
2492:        ...(action === 'close' ? { status: { not: 'closed' as TicketStatus } } : { status: 'closed' as TicketStatus })
2493:      },
2494:      data: {
2495:        status: nextStatus,
2496:        resolvedAt: action === 'close' ? now : null,
2497:        closedAt: action === 'close' ? now : null,
2498:        updatedAt: now
2499:      }
2500:    })
2501:    if (update.count === 0) {
2502:      return reply.code(409).send({ error: 'Ticket status changed concurrently', code: 'TICKET_STATUS_CONFLICT' })
2503:    }
2504:
2505:    emitPluginEvent('ticket.status.changed', {
2506:      dedupeKey: `ticket.status.changed:public-api:${ticket.id}:${nextStatus}:${now.getTime()}`,
2507:      ticketId: ticket.id,
2508:      userId: apiToken.userId,
2509:      username: apiToken.user.username,
2510:      subject: ticket.subject,
2511:      previousStatus: ticket.status,
2512:      status: nextStatus,
2513:      source: 'public_api',
2514:      changedAt: now.toISOString()
2515:    }, { id: apiToken.userId, role: apiToken.user.role, username: apiToken.user.username }, { dedupeKey: `ticket.status.changed:public-api:${ticket.id}:${nextStatus}:${now.getTime()}` })
2516:
2517:    await createLog(apiToken.userId, LogModule.PLUGIN, 'public_api.ticket_status_update', `Public API ${apiToken.source} changed own ticket #${ticket.id} status to ${nextStatus}`, LogResult.SUCCESS)
2518:
2519:    return {
2520:      data: {
2521:        id: ticket.id,
2522:        status: nextStatus,
2523:        previousStatus: ticket.status,
2524:        resolvedAt: action === 'close' ? now.toISOString() : null,
2525:        closedAt: action === 'close' ? now.toISOString() : null,
2526:        updatedAt: now.toISOString()
2527:      }
2528:    }
2529:  })
