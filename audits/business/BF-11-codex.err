475:export async function getUserTickets(
476:  userId: number,
477:  options: {
478:    status?: TicketStatus | 'active'
479:    search?: string
480:    page?: number
481:    pageSize?: number
482:  } = {}
483:): Promise<{
484:  tickets: TicketWithDetailsExtended[]
485:  total: number
486:  page: number
487:  pageSize: number
488:  totalPages: number
489:}> {
490:  const { page, pageSize } = clampPagination(options.page, options.pageSize, 10)
491:  const status = normalizeTicketStatus(options.status)
492:  const searchTerm = normalizeSearchTerm(options.search)
493:  const skip = (page - 1) * pageSize
494:
495:  const where: any = { userId }
496:  
497:  // çŠ¶æ€ç­›é€‰ï¼šactive è¡¨ç¤ºæŽ’é™¤ closed
498:  if (status === 'active') {
499:    where.status = { not: 'closed' }
500:  } else if (status) {
501:    where.status = status
502:  }
503:
504:  // æœç´¢ï¼šæ”¯æŒä¸»é¢˜å’Œå·¥å•ID
505:  if (searchTerm) {
506:    const searchId = getSearchId(searchTerm)
507:    if (searchId !== null) {
508:      // å¦‚æžœæ˜¯æ•°å­—ï¼ŒåŒæ—¶æœç´¢ ID å’Œä¸»é¢˜
509:      where.OR = [
510:        { id: searchId },
511:        { subject: { contains: searchTerm, mode: 'insensitive' } }
512:      ]
513:    } else {
514:      where.subject = { contains: searchTerm, mode: 'insensitive' }
