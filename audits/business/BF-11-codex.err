507:async function syncViewFromRoute(): Promise<void> {
508:  const targetTab = normalizeTab(route.query.tab ?? getDefaultTab())
509:  if (activeTab.value !== targetTab) {
510:    activeTab.value = targetTab
511:    await loadTickets(true)
512:  }
513:
514:  const ticketIdParam = route.query.ticket
515:  const compose = route.query.compose === '1'
516:  const ticketId = typeof ticketIdParam === 'string' ? Number(ticketIdParam) : NaN
517:
518:  if (Number.isInteger(ticketId) && ticketId > 0) {
519:    if (viewMode.value !== 'detail' || selectedTicket.value?.id !== ticketId) {
520:      await openTicketDetail(ticketId)
521:    }
522:    return
523:  }
524:
525:  if (compose && !authStore.isAdmin) {
526:    if (viewMode.value !== 'create') {
527:      await openCreateView()
528:    }
529:    return
530:  }
531:
532:  if (viewMode.value !== 'list') {
533:    viewMode.value = 'list'
534:    resetDetailState()
535:  }
