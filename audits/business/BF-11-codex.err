682:export async function getAiTicketPermission(permission: AiTicketPermission): Promise<AiTicketContextPermissionResult> {
683:  const plugin = await prisma.plugin.findUnique({
684:    where: { pluginId: AI_TICKET_AGENT_PLUGIN_ID },
685:    select: {
686:      enabled: true,
687:      status: true,
688:      versions: {
689:        orderBy: { installedAt: 'desc' },
690:        take: 1,
691:        select: { manifest: true }
692:      }
693:    }
694:  })
695:
696:  if (!plugin || !plugin.enabled || plugin.status !== 'enabled') {
697:    return {
698:      allowed: false,
699:      code: 'AI_TICKET_PLUGIN_DISABLED',
700:      message: 'AI ticket agent plugin is not enabled'
701:    }
702:  }
703:
704:  const manifest = plugin.versions[0]?.manifest as { permissions?: unknown } | undefined
705:  const permissions = Array.isArray(manifest?.permissions) ? manifest.permissions : []
706:  if (!permissions.includes(permission)) {
707:    return {
708:      allowed: false,
709:      code: 'AI_TICKET_PLUGIN_PERMISSION_MISSING',
710:      message: `AI ticket agent plugin is missing ${permission} permission`
711:    }
712:  }
713:
714:  return { allowed: true }
715:}
716:
717:export async function getAiTicketContextPermission(): Promise<AiTicketContextPermissionResult> {
718:  return getAiTicketPermission(AI_TICKET_CONTEXT_PERMISSION)
719:}
