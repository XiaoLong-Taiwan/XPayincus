381:function parseAiDecisionJson(content: string): { reply: string; confidence: number; handoffRequired: boolean; handoffReason: string | null } | null {
382:  const trimmed = content.trim()
383:  const jsonText = trimmed.startsWith('{')
384:    ? trimmed
385:    : trimmed.match(/\{[\s\S]*\}/)?.[0]
386:  if (!jsonText) return null
387:
388:  try {
389:    const parsed = JSON.parse(jsonText) as {
390:      reply?: unknown
391:      confidence?: unknown
392:      handoffRequired?: unknown
393:      handoffReason?: unknown
394:    }
395:    const reply = typeof parsed.reply === 'string' ? parsed.reply.trim() : ''
396:    const confidence = typeof parsed.confidence === 'number' && Number.isFinite(parsed.confidence)
397:      ? Math.min(Math.max(parsed.confidence, 0), 1)
398:      : NaN
399:    const handoffRequired = typeof parsed.handoffRequired === 'boolean' ? parsed.handoffRequired : true
400:    const handoffReason = typeof parsed.handoffReason === 'string' && parsed.handoffReason.trim()
401:      ? parsed.handoffReason.trim().slice(0, 160)
402:      : null
403:
404:    if (!reply || Number.isNaN(confidence)) return null
405:    return { reply, confidence, handoffRequired, handoffReason }
406:  } catch {
407:    return null
408:  }
409:}
