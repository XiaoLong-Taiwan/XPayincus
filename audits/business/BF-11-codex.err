684:  /**
685:   * ç”± AI å·¥å•æ’ä»¶ç”Ÿæˆå¹¶å‘é€ä¸€æ¡å®¢æœå›žå¤ï¼ˆä»…ç®¡ç†å‘˜ + å·²å¯ç”¨ AI å·¥å•æ’ä»¶ + reply æƒé™ï¼‰
686:   * POST /tickets/:id/ai/reply
687:   */
688:  fastify.post<{
689:    Params: { id: string }
690:  }>('/:id/ai/reply', {
691:    onRequest: [fastify.authenticate, fastify.requireAdmin],
692:    schema: {
693:      params: {
694:        type: 'object',
695:        required: ['id'],
696:        properties: {
697:          id: { type: 'string', pattern: '^[1-9]\\d*$' }
698:        }
699:      }
700:    }
701:  }, async (request: FastifyRequest<{
702:    Params: { id: string }
703:  }>, reply: FastifyReply) => {
704:    const { user } = request
705:    const ticketId = parsePositiveId(request.params.id)
706:
707:    if (ticketId === null) {
708:      return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
709:    }
710:
711:    const permission = await getAiTicketPermission(AI_TICKET_REPLY_PERMISSION)
712:    if (!permission.allowed) {
713:      await auditAiTicketReply({
714:        actorUserId: user.id,
715:        ticketId,
716:        result: 'denied',
717:        reason: permission.code
718:      })
719:      return reply.code(403).send({
720:        error: permission.message || 'AI ticket reply is not available',
721:        code: permission.code || 'AI_TICKET_REPLY_DENIED'
722:      })
723:    }
724:
725:    const ticket = await ticketDb.getTicketById(ticketId)
726:    if (!ticket) {
727:      await auditAiTicketReply({
728:        actorUserId: user.id,
729:        ticketId,
730:        result: 'failed',
731:        reason: 'TICKET_NOT_FOUND'
732:      })
733:      return reply.code(404).send(apiError(ErrorCode.NOT_FOUND))
734:    }
735:    if (ticket.status === 'closed') {
736:      await auditAiTicketReply({
737:        actorUserId: user.id,
738:        ticketId,
739:        result: 'denied',
740:        reason: 'AI_TICKET_CLOSED'
741:      })
742:      return reply.code(400).send({
743:        error: 'Cannot reply to a closed ticket',
744:        code: 'AI_TICKET_CLOSED'
745:      })
746:    }
747:
748:    try {
749:      const result = await generateAiTicketReply(ticketId)
750:      if (!result.canSend) {
751:        const code = result.mode === 'draft'
752:          ? 'AI_TICKET_AGENT_REPLY_MODE_DISABLED'
753:          : 'AI_TICKET_REPLY_HANDOFF_REQUIRED'
754:        await auditAiTicketReply({
755:          actorUserId: user.id,
756:          ticketId,
757:          result: 'denied',
758:          reason: result.sendBlockedReasons.length > 0 ? result.sendBlockedReasons.join(',') : code
759:        })
760:        return reply.code(code === 'AI_TICKET_AGENT_REPLY_MODE_DISABLED' ? 409 : 422).send({
761:          error: code === 'AI_TICKET_AGENT_REPLY_MODE_DISABLED'
762:            ? 'AI ticket agent is in draft mode'
763:            : 'AI reply requires human handling',
764:          code,
765:          confidence: result.confidence,
766:          confidenceThreshold: result.confidenceThreshold,
767:          blockedReasons: result.sendBlockedReasons
768:        })
769:      }
770:      if (!result.safety.passed) {
771:        await auditAiTicketReply({
772:          actorUserId: user.id,
773:          ticketId,
774:          result: 'blocked',
775:          reason: result.safety.blockedReasons.join(',')
776:        })
777:        return reply.code(422).send({
778:          error: 'AI reply failed safety checks',
779:          code: 'AI_TICKET_REPLY_BLOCKED',
780:          safety: result.safety
781:        })
782:      }
783:
784:      const message = await ticketDb.addTicketMessage(ticketId, user.id, result.draft, true, [])
785:
786:      try {
787:        await sendNotification(ticket.userId, 'ticket_replied', {
788:          subject: ticket.subject,
789:          hostName: ticket.host?.name || 'ç³»ç»Ÿ',
790:          replyFrom: user.username
791:        })
792:      } catch (err) {
793:        console.error('[Tickets] Failed to send AI ticket reply notification:', err)
794:      }
795:
796:      await auditAiTicketReply({
797:        actorUserId: user.id,
798:        ticketId,
799:        result: 'success'
800:      })
801:
802:      return reply.code(201).send({
803:        message: 'AI reply sent successfully',
804:        data: message,
805:        model: result.model,
806:        safety: result.safety,
807:        confidence: result.confidence,
808:        confidenceThreshold: result.confidenceThreshold
809:      })
810:    } catch (error) {
811:      const message = error instanceof Error ? error.message : String(error)
812:      const knownStatus: Record<string, number> = {
813:        AI_TICKET_AGENT_DISABLED: 403,
814:        AI_TICKET_AGENT_MODEL_NOT_CONFIGURED: 400,
815:        AI_TICKET_MODEL_REQUEST_FAILED: 502,
816:        AI_TICKET_MODEL_EMPTY_RESPONSE: 502,
817:        AI_TICKET_MODEL_DECISION_INVALID: 502,
818:        TICKET_NOT_FOUND: 404
819:      }
820:      const statusCode = knownStatus[message] || 502
821:      await auditAiTicketReply({
822:        actorUserId: user.id,
823:        ticketId,
824:        result: 'failed',
825:        reason: message
826:      })
827:
828:      if (message === 'TICKET_NOT_FOUND') {
829:        return reply.code(404).send(apiError(ErrorCode.NOT_FOUND))
830:      }
831:
832:      return reply.code(statusCode).send({
833:        error: statusCode === 502 ? 'AI reply generation failed' : message,
834:        code: message.startsWith('AI_TICKET_') ? message : 'AI_TICKET_REPLY_FAILED'
835:      })
836:    }
837:  })
