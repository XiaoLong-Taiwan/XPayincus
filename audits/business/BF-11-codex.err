905:  if (days === 0) {
906:    return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
907:  } else if (days < 7) {
908:    return t('inbox.daysAgo', { n: days })
909:  } else {
910:    return date.toLocaleDateString()
