1145:export async function updateTicketStatus(
1146:  ticketId: number,
1147:  status: TicketStatus
1148:): Promise<void> {
1149:  const updateData: {
1150:    status: TicketStatus
1151:    resolvedAt?: Date | null
1152:    closedAt?: Date | null
1153:  } = { status }
1154:
1155:  if (status === 'resolved') {
1156:    updateData.resolvedAt = new Date()
1157:  } else if (status === 'closed') {
1158:    updateData.closedAt = new Date()
1159:  } else if (status === 'open' || status === 'in_progress') {
1160:    updateData.resolvedAt = null
1161:    updateData.closedAt = null
1162:  }
1163:
1164:  await prisma.ticket.update({
1165:    where: { id: ticketId },
1166:    data: updateData
1167:  })
1168:}
