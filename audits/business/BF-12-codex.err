  287: function getMarketFingerprint(entries: PluginMarketEntry[]): string {
  288:   const stablePayload = entries.map(entry => ({
  289:     id: entry.id,
  290:     latest: entry.latest,
  291:     reviewStatus: entry.reviewStatus,
  292:     trustLevel: entry.trustLevel,
  293:     repo: entry.repo,
  294:     downloadUrl: entry.downloadUrl,
  295:     sha256: entry.sha256,
  296:     compatibility: entry.compatibility,
  297:     permissions: entry.permissions,
  298:     pricing: entry.pricing
  299:   }))
  300:   return createHash('sha256').update(JSON.stringify(stablePayload)).digest('hex')
  301: }
