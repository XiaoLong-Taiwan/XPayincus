  406:     return await getPluginTask(task.id)
  407:   } catch (error) {
  408:     const message = error instanceof Error ? error.message : String(error)
  409:     await appendPluginTaskLog(logPath, `FAILED: ${message}`).catch(() => undefined)
  410:     await markPluginTaskFinished(task.id, 'failed', message)
