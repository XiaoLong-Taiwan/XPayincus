  127: function assertTrustedMarketUrl(input: string, purpose: 'index' | 'download', trustedHosts: Set<string>): URL {
  128:   const url = new URL(input)
  129:   if (url.protocol !== 'https:') throw new Error('Plugin market URL must use HTTPS')
  130:   const host = url.hostname.toLowerCase()
  131:   if (!trustedHosts.has(host)) {
  132:     throw new Error(`Plugin market URL host is not trusted; configure ${PLUGIN_MARKET_TRUSTED_HOSTS_ENV}`)
  133:   }
  134: 
  135:   if (host === 'github.com' && !url.pathname.includes('/releases/download/')) {
  136:     throw new Error('GitHub plugin URL must point to a release asset')
  137:   }
  138: 
  139:   if (host === 'raw.githubusercontent.com' && purpose === 'download') {
  140:     throw new Error('Raw GitHub URLs may only be used for plugin market indexes')
  141:   }
  142: 
  143:   if (host === 'objects.githubusercontent.com') return url
  144: 
  145:   if ((host === 'payincus.com' || host === 'xiaolong-taiwan.github.io') && purpose === 'index') {
