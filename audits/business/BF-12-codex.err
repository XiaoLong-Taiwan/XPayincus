  105: export async function getThemeMarketIndexUrl(): Promise<string | null> {
  106:   return pickString(await getConfiguredThemeMarketIndexUrl(), 500)
  107: }
  108: 
  109: function assertTrustedThemeMarketUrl(input: string, purpose: 'index' | 'download', trustedHosts: Set<string>): URL {
  110:   const url = new URL(input)
  111:   if (url.protocol !== 'https:') throw new Error('Theme market URL must use HTTPS')
  112:   const host = url.hostname.toLowerCase()
  113:   if (!trustedHosts.has(host)) {
  114:     throw new Error('Theme market URL host is not trusted')
  115:   }
  116: 
  117:   if (host === 'github.com' && !url.pathname.includes('/releases/download/')) {
  118:     throw new Error('GitHub theme URL must point to a release asset')
  119:   }
  120: 
  121:   if (host === 'raw.githubusercontent.com' && purpose === 'download') {
  122:     throw new Error('Raw GitHub URLs may only be used for theme market indexes')
  123:   }
  124: 
  125:   if (host === 'objects.githubusercontent.com') return url
  126: 
  127:   if ((host === 'payincus.com' || host === 'xiaolong-taiwan.github.io') && purpose === 'index') {
  128:     if (!url.pathname.endsWith('/theme-market/index.json')) {
  129:       throw new Error('Stable theme market index must use /theme-market/index.json')
  130:     }
  131:   }
  132: 
  133:   if ((host === 'payincus.com' || host === 'xiaolong-taiwan.github.io') && purpose === 'download') {
  134:     if (!url.pathname.startsWith('/theme-market/packages/') && !url.pathname.startsWith('/theme-market/manifests/')) {
  135:       throw new Error('Stable theme market assets must be under /theme-market/packages or /theme-market/manifests')
  136:     }
  137:   }
  138: 
  139:   return url
  140: }
  141: 
  142: function normalizeDeveloper(input: unknown, fallbackName: string): ThemeMarketDeveloper {
  143:   const record = isRecord(input) ? input : {}
  144:   return {
  145:     name: pickString(record.name, 120) || fallbackName,
  146:     homepage: pickString(record.homepage, 500) ?? undefined,
  147:     github: pickString(record.github, 500) ?? undefined,
  148:     verified: pickBoolean(record.verified),
  149:     contact: pickString(record.contact, 200) ?? undefined
  150:   }
  151: }
  152: 
  153: function normalizeCompatibility(input: unknown): ThemeMarketCompatibility {
  154:   const record = isRecord(input) ? input : {}
  155:   return {
  156:     minPayincus: pickString(record.minPayincus, 64) ?? undefined,
  157:     maxPayincus: pickString(record.maxPayincus, 64) ?? undefined
  158:   }
  159: }
  160: 
  161: function normalizeSecurity(input: unknown): ThemeMarketSecurity {
  162:   const record = isRecord(input) ? input : {}
  163:   const signature = isRecord(record.signature)
  164:     ? {
  165:         status: pickEnum(record.signature.status, ['unsigned', 'valid', 'missing', 'invalid'] as const, 'unsigned'),
  166:         algorithm: pickString(record.signature.algorithm, 60) ?? undefined,
  167:         keyId: pickString(record.signature.keyId, 120) ?? undefined
  168:       }
  169:     : { status: 'unsigned' as const }
  170:   return {
  171:     checksumPinned: pickBoolean(record.checksumPinned, true),
  172:     signature,
  173:     notes: pickStringArray(record.notes, 10, 240)
  174:   }
  175: }
  176: 
  177: function normalizeEntry(input: unknown, trustedHosts: Set<string>): ThemeMarketEntry | null {
  178:   if (!isRecord(input)) return null
  179:   const id = pickString(input.id, 120)
  180:   const name = pickString(input.name, 120)
  181:   const latest = pickString(input.latest, 64)
  182:   const manifestUrl = pickString(input.manifestUrl, 500)
  183:   const downloadUrl = pickString(input.downloadUrl, 500)
  184:   const sha256 = pickString(input.sha256, 64)
  185:   if (!id || !name || !latest || !manifestUrl || !downloadUrl || !sha256) return null
  186:   assertTrustedThemeMarketUrl(manifestUrl, 'download', trustedHosts)
  187:   assertTrustedThemeMarketUrl(downloadUrl, 'download', trustedHosts)
  188:   if (!/^[a-f0-9]{64}$/i.test(sha256)) return null
  189:   const reviewStatus = pickEnum(input.reviewStatus, ['pending', 'listed', 'delisted', 'rejected'] as const, 'pending')
  190:   const trustLevel = pickEnum(input.trustLevel, ['official', 'verified', 'third_party'] as const, 'third_party')
  191:   const author = pickString(input.author, 120) ?? undefined
  192:   return {
  193:     id,
  194:     name,
  195:     latest,
  196:     manifestUrl,
  197:     downloadUrl,
  198:     sha256: sha256.toLowerCase(),
  199:     description: pickString(input.description, 500) ?? undefined,
  200:     author,
  201:     previewImageUrl: pickString(input.previewImageUrl, 500) ?? undefined,
  202:     reviewStatus,
  203:     trustLevel,
  204:     developer: normalizeDeveloper(input.developer, author || name),
  205:     compatibility: normalizeCompatibility(input.compatibility),
  206:     security: normalizeSecurity(input.security),
  207:     tokens: pickStringArray(input.tokens, 80, 120),
  208:     layoutSlots: pickStringArray(input.layoutSlots, 80, 120),
  209:     rating: {
  210:       average: pickNumber(isRecord(input.rating) ? input.rating.average : undefined, 0, 0, 5),
  211:       count: Math.floor(pickNumber(isRecord(input.rating) ? input.rating.count : undefined, 0, 0, 1_000_000))
  212:     },
  213:     installCount: Math.floor(pickNumber(input.installCount, 0, 0, 1_000_000_000)),
  214:     releaseNotes: pickString(input.releaseNotes, 1000) ?? undefined,
  215:     rollbackNotes: pickString(input.rollbackNotes, 1000) ?? undefined
  216:   }
  217: }
  218: 
  219: function normalizeVersionParts(version: string | undefined): [number, number, number] | null {
  220:   if (!version) return null
  221:   const match = version.trim().match(/^v?(\d+)\.(\d+)\.(\d+)(?:[-+].*)?$/)
  222:   if (!match) return null
  223:   return [Number(match[1]), Number(match[2]), Number(match[3])]
  224: }
  225: 
  226: function compareVersions(left: string | undefined, right: string | undefined): number {
  227:   const a = normalizeVersionParts(left)
  228:   const b = normalizeVersionParts(right)
  229:   if (!a || !b) return 0
  230:   for (let index = 0; index < 3; index += 1) {
  231:     if (a[index] !== b[index]) return a[index] > b[index] ? 1 : -1
  232:   }
  233:   return 0
  234: }
  235: 
  236: function getThemeMarketFingerprint(entries: ThemeMarketEntry[]): string {
  237:   const stablePayload = entries.map(entry => ({
  238:     id: entry.id,
  239:     latest: entry.latest,
  240:     reviewStatus: entry.reviewStatus,
  241:     trustLevel: entry.trustLevel,
  242:     downloadUrl: entry.downloadUrl,
  243:     sha256: entry.sha256,
  244:     compatibility: entry.compatibility,
  245:     tokens: entry.tokens,
  246:     layoutSlots: entry.layoutSlots
  247:   }))
  248:   return createHash('sha256').update(JSON.stringify(stablePayload)).digest('hex')
  249: }
  250: 
  251: const THEME_MARKET_INSTALL_POLICY = ['stable theme index only', 'listed entries only', 'SHA256 required', 'theme package validation required']
  252: 
  253: export function buildUnavailableThemeMarketIndex(): ThemeMarketIndex {
  254:   return {
  255:     themes: [],
  256:     governance: {
  257:       totalEntries: 0,
  258:       visibleEntries: 0,
  259:       hiddenEntries: 0,
  260:       indexHost: null,
  261:       fingerprint: getThemeMarketFingerprint([]),
  262:       defaultReviewStatus: 'pending',
  263:       installPolicy: THEME_MARKET_INSTALL_POLICY,
  264:       unavailableReason: 'market_unavailable'
  265:     }
  266:   }
  267: }
  268: 
  269: export async function fetchThemeMarketIndex(url?: string | null): Promise<ThemeMarketIndex> {
  270:   const effectiveUrl = url ?? await getThemeMarketIndexUrl()
  271:   if (!effectiveUrl) {
  272:     return buildUnavailableThemeMarketIndex()
  273:   }
  274: 
  275:   const trustedHosts = await getThemeMarketTrustedHosts()
  276:   const parsed = assertTrustedThemeMarketUrl(effectiveUrl, 'index', trustedHosts)
  277:   const response = await fetch(parsed, {
  278:     headers: { 'user-agent': 'payincus-theme-center' }
  279:   })
  280:   if (!response.ok) {
  281:     throw new Error(`Failed to fetch theme market index: HTTP ${response.status}`)
  282:   }
  283:   const payload: unknown = await response.json()
  284:   const normalized = isRecord(payload) && Array.isArray(payload.themes)
  285:     ? payload.themes.map(entry => normalizeEntry(entry, trustedHosts)).filter((entry): entry is ThemeMarketEntry => !!entry)
  286:     : []
  287:   const themes = normalized.filter(entry => entry.reviewStatus === 'listed')
  288:   return {
  289:     themes,
  290:     governance: {
  291:       totalEntries: normalized.length,
  292:       visibleEntries: themes.length,
  293:       hiddenEntries: normalized.length - themes.length,
  294:       indexHost: parsed.hostname,
  295:       fingerprint: getThemeMarketFingerprint(normalized),
  296:       defaultReviewStatus: 'pending',
  297:       installPolicy: THEME_MARKET_INSTALL_POLICY
  298:     }
  299:   }
  300: }
  301: 
  302: export async function assertThemeMarketEntryInstallable(entry: ThemeMarketEntry): Promise<void> {
  303:   if (entry.reviewStatus !== 'listed') {
  304:     throw new Error('Theme market entry is not listed for installation')
  305:   }
  306:   if (!entry.security.checksumPinned) {
  307:     throw new Error('Theme market entry must pin a SHA256 checksum')
  308:   }
  309:   if (!/^[a-f0-9]{64}$/i.test(entry.sha256)) {
  310:     throw new Error('Theme market entry has an invalid SHA256 checksum')
  311:   }
  312:   const current = await getCurrentVersionMetadata()
  313:   const currentVersion = current.gitTag || current.version
  314:   if (entry.compatibility.minPayincus && compareVersions(currentVersion, entry.compatibility.minPayincus) < 0) {
  315:     throw new Error(`Theme requires PayIncus ${entry.compatibility.minPayincus} or later`)
  316:   }
  317:   if (entry.compatibility.maxPayincus && compareVersions(currentVersion, entry.compatibility.maxPayincus) > 0) {
  318:     throw new Error(`Theme supports PayIncus up to ${entry.compatibility.maxPayincus}`)
  319:   }
  320: }
  321: 
  322: export async function downloadMarketTheme(entry: ThemeMarketEntry): Promise<string> {
  323:   await assertThemeMarketEntryInstallable(entry)
  324:   assertTrustedThemeMarketUrl(entry.downloadUrl, 'download', await getThemeMarketTrustedHosts())
  325:   const response = await fetch(entry.downloadUrl, {
  326:     headers: { 'user-agent': 'payincus-theme-center' }
  327:   })
  328:   if (!response.ok) {
  329:     throw new Error(`Failed to download theme package: HTTP ${response.status}`)
  330:   }
  331:   const arrayBuffer = await response.arrayBuffer()
  332:   const buffer = Buffer.from(arrayBuffer)
  333:   const actualSha256 = createHash('sha256').update(buffer).digest('hex')
  334:   if (actualSha256 !== entry.sha256.toLowerCase()) {
  335:     throw new Error('Theme package SHA256 mismatch')
  336:   }
  337:   const dir = join(getThemeStagingDir(), 'downloads')
  338:   await mkdir(dir, { recursive: true })
  339:   const path = join(dir, `${entry.id}-${entry.latest}-${randomUUID()}.tar.gz`)
  340:   await writeFile(path, buffer, { mode: 0o600 })
  341:   return path
  342: }

