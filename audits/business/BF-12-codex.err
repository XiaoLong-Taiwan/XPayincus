  353: export async function assertMarketEntryInstallable(entry: PluginMarketEntry): Promise<void> {
  354:   if (entry.reviewStatus !== 'listed') {
  355:     throw new Error('Plugin market entry is not listed for installation')
  356:   }
  357:   if (!entry.security.checksumPinned) {
  358:     throw new Error('Plugin market entry must pin a SHA256 checksum')
  359:   }
  360:   if (!/^[a-f0-9]{64}$/i.test(entry.sha256)) {
  361:     throw new Error('Plugin market entry has an invalid SHA256 checksum')
  362:   }
  363:   const current = await getCurrentVersionMetadata()
  364:   const currentVersion = current.gitTag || current.version
  365:   if (entry.compatibility.minPayincus && compareVersions(currentVersion, entry.compatibility.minPayincus) < 0) {
  366:     throw new Error(`Plugin requires PayIncus ${entry.compatibility.minPayincus} or later`)
  367:   }
  368:   if (entry.compatibility.maxPayincus && compareVersions(currentVersion, entry.compatibility.maxPayincus) > 0) {
  369:     throw new Error(`Plugin supports PayIncus up to ${entry.compatibility.maxPayincus}`)
  370:   }
  371: }
