   74: async function downloadBoundedHttpsFile(url: string, label: string, maxBytes: number): Promise<Buffer> {
   75:   const safeUrl = await assertSafeHttpUrl(url, label)
   76:   if (safeUrl.protocol !== 'https:') {
   77:     throw new Error(`${label} must use HTTPS`)
   78:   }
   79: 
   80:   const response = await fetch(safeUrl, {
   81:     method: 'GET',
   82:     redirect: 'manual',
   83:     signal: AbortSignal.timeout(30_000),
   84:     headers: {
   85:       'accept': 'application/octet-stream',
   86:       'user-agent': 'PayIncus-Plugin-Submission-Scanner/1.0'
   87:     }
   88:   })
   89: 
   90:   if (!response.ok) {
   91:     throw new Error(`${label} download failed with HTTP ${response.status}`)
   92:   }
   93: 
   94:   const contentLength = Number(response.headers.get('content-length') || '0')
   95:   if (Number.isFinite(contentLength) && contentLength > maxBytes) {
   96:     throw new Error(`${label} exceeds ${Math.round(maxBytes / 1024 / 1024)}MB`)
   97:   }
   98: 
   99:   const chunks: Uint8Array[] = []
  100:   let total = 0
  101:   if (!response.body) throw new Error(`${label} response has no body`)
  102: 
  103:   const reader = response.body.getReader()
  104:   while (true) {
  105:     const { done, value } = await reader.read()
  106:     if (done) break
  107:     if (!value) continue
  108:     total += value.byteLength
  109:     if (total > maxBytes) {
  110:       throw new Error(`${label} exceeds ${Math.round(maxBytes / 1024 / 1024)}MB`)
  111:     }
  112:     chunks.push(value)
  113:   }
  114: 
  115:   return Buffer.concat(chunks)
  116: }
