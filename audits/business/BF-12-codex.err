  167:   fastify.get('/assets/:themeId/:version/*', async (request: FastifyRequest, reply: FastifyReply) => {
  168:     const params = request.params as { themeId?: string; version?: string; '*': string }
  169:     const themeId = params.themeId ? normalizeThemeId(params.themeId) : null
  170:     const version = params.version ? normalizeVersion(params.version) : null
  171:     const assetPath = params['*'] || ''
  172:     if (!themeId || !version || !assetPath || assetPath.startsWith('/') || assetPath.includes('..') || assetPath.includes('\\')) {
  173:       return reply.code(400).send({ error: 'Invalid theme asset path', code: 'INVALID_THEME_ASSET_PATH' })
  174:     }
  175:     const theme = await getThemePackageForAsset(themeId, version)
  176:     if (!theme) return reply.code(404).send({ error: 'Theme asset not found', code: 'THEME_ASSET_NOT_FOUND' })
  177: 
  178:     try {
  179:       const filePath = resolveThemeAsset(theme.installPath, assetPath)
  180:       const body = await readFile(filePath)
  181:       reply
  182:         .type(contentTypeForPath(assetPath))
  183:         .header('Cache-Control', theme.enabled ? 'public, max-age=300' : 'private, max-age=60')
  184:         .header('Referrer-Policy', 'same-origin')
  185:         .header('X-Content-Type-Options', 'nosniff')
  186:         .header('X-Robots-Tag', 'noindex')
  187:         // ä¸»é¢˜åŒ…å†…å¯èƒ½å¤¹å¸¦ SVG/HTML ç­‰å¯æ‰§è¡Œè„šæœ¬çš„æ–‡ä»¶ï¼›ä½œä¸ºé¡¶å±‚æ–‡æ¡£æ‰“å¼€æ—¶ç”¨ä¸¥æ ¼ CSP + sandbox
  188:         // é˜»æ–­å†…è”è„šæœ¬ï¼Œé˜²æ­¢å­˜å‚¨åž‹ XSSã€‚è¯¥å¤´å¯¹ä»¥ <link>/<img>/<font> åŠ è½½çš„å­èµ„æºæ— å‰¯ä½œç”¨ã€‚
  189:         .header('Content-Security-Policy', "default-src 'none'; style-src 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; sandbox")
  190:         .send(body)
  191:     } catch {
  192:       return reply.code(404).send({ error: 'Theme asset not found', code: 'THEME_ASSET_NOT_FOUND' })
  193:     }
  194:   })
  195: }

