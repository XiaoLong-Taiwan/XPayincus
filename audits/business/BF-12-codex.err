  574: export async function createPluginTask(input: {
  575:   pluginId?: string | null
  576:   action: PluginInstallTaskAction
  577:   sourceType: PluginSourceType
  578:   sourceUrl?: string | null
  579:   startedByUserId: number
  580: }) {
  581:   const logDir = getPluginLogDir()
  582:   await mkdir(logDir, { recursive: true })
  583:   return await prisma.pluginInstallTask.create({
  584:     data: {
  585:       pluginId: input.pluginId || null,
  586:       action: input.action,
  587:       sourceType: input.sourceType,
  588:       sourceUrl: input.sourceUrl || null,
  589:       startedByUserId: input.startedByUserId,
  590:       status: 'pending',
  591:       logPath: join(logDir, `plugin-task-pending-${Date.now()}.log`)
  592:     },
  593:     include: { startedBy: { select: { username: true } } }
  594:   })
  595: }
  596: 
  597: export async function markPluginTaskRunning(id: number, logPath: string) {
  598:   return await prisma.pluginInstallTask.update({
  599:     where: { id },
  600:     data: { status: 'running', startedAt: new Date(), logPath, errorMessage: null }
  601:   })
  602: }
  603: 
  604: export async function markPluginTaskFinished(id: number, status: 'success' | 'failed', errorMessage?: string | null) {
  605:   return await prisma.pluginInstallTask.update({
  606:     where: { id },
  607:     data: { status, errorMessage: errorMessage || null, finishedAt: new Date() }
  608:   })
  609: }
