   74: function isRecord(value: unknown): value is Record<string, unknown> {
   75:   return !!value && typeof value === 'object' && !Array.isArray(value)
   76: }
   77: 
   78: function pickString(value: unknown, maxLength: number): string | null {
   79:   if (typeof value !== 'string') return null
   80:   const trimmed = value.trim()
   81:   return trimmed && trimmed.length <= maxLength ? trimmed : null
   82: }
   83: 
   84: function pickBoolean(value: unknown, fallback = false): boolean {
   85:   return typeof value === 'boolean' ? value : fallback
   86: }
   87: 
   88: function pickNumber(value: unknown, fallback: number, min: number, max: number): number {
   89:   const number = typeof value === 'number' ? value : Number(value)
   90:   return Number.isFinite(number) && number >= min && number <= max ? number : fallback
   91: }
   92: 
   93: function pickEnum<T extends string>(value: unknown, allowed: readonly T[], fallback: T): T {
   94:   return typeof value === 'string' && allowed.includes(value as T) ? value as T : fallback
   95: }
   96: 
   97: function pickStringArray(value: unknown, maxItems: number, maxLength: number): string[] {
   98:   if (!Array.isArray(value)) return []
   99:   return value
  100:     .slice(0, maxItems)
  101:     .map(item => pickString(item, maxLength))
  102:     .filter((item): item is string => !!item)
  103: }
