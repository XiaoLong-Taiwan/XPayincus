   10: 
   11: function envFirst(keys: string | string[]): string {
   12:   const envKeys = Array.isArray(keys) ? keys : [keys]
   13:   for (const key of envKeys) {
   14:     const value = process.env[key]?.trim()
   15:     if (value) return value
   16:   }
   17:   return ''
   18: }
   19: 
   20: function splitCsv(value: string | null | undefined): string[] {
   21:   if (!value) return []
   22:   return value
   23:     .split(',')
   24:     .map(item => item.trim())
   25:     .filter(Boolean)
   26: }
   27: 
   28: export async function getRuntimeConfigString(
   29:   configKey: string,
   30:   envKeys: string | string[],
   31:   fallback = ''
   32: ): Promise<string> {
   33:   const dbValue = (await getSystemConfig(configKey))?.trim()
   34:   if (dbValue) return dbValue
   35:   return envFirst(envKeys) || fallback
   36: }
   37: 
   38: export async function getRuntimeConfigBoolean(
   39:   configKey: string,
   40:   envKey: string,
   41:   fallback = false
   42: ): Promise<boolean> {
   43:   const dbValue = await getSystemConfig(configKey)
   44:   if (dbValue === 'true' || dbValue === '1') return true
   45:   if (dbValue === 'false' || dbValue === '0') return false
   46:   const envValue = process.env[envKey]?.trim().toLowerCase()
   47:   if (envValue === 'true' || envValue === '1' || envValue === 'yes') return true
   48:   if (envValue === 'false' || envValue === '0' || envValue === 'no') return false
   49:   return fallback
   50: }
   51: 
   52: export async function getRuntimeConfigNumber(
   53:   configKey: string,
   54:   envKey: string,
   55:   fallback: number,
   56:   min: number,
   57:   max: number
   58: ): Promise<number> {
   59:   const dbValue = await getSystemConfigNumber(configKey, Number.NaN)
   60:   if (Number.isInteger(dbValue) && dbValue >= min && dbValue <= max) return dbValue
   61:   const envValue = Number(process.env[envKey])
   62:   if (Number.isInteger(envValue) && envValue >= min && envValue <= max) return envValue
   63:   return fallback
   64: }
   65: 
   66: export async function getCombinedAdminIdAllowlist(
   67:   configKey: string,
   68:   envKeys: string | string[]
   69: ): Promise<{ ids: Set<number>; configured: boolean }> {
   70:   const ids = new Set<number>()
   71:   const rawValues = [
   72:     await getSystemConfig(configKey),
   73:     envFirst(envKeys)
   74:   ].filter((value): value is string => typeof value === 'string' && value.trim().length > 0)
   75: 
   76:   for (const raw of rawValues) {
   77:     for (const part of splitCsv(raw)) {
   78:       const id = Number(part)
   79:       if (Number.isSafeInteger(id) && id > 0) ids.add(id)
   80:     }
   81:   }
   82: 
   83:   return { ids, configured: rawValues.length > 0 }
   84: }
