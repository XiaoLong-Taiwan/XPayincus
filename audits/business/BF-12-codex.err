 1032:   fastify.post<{ Params: PluginParams }>('/:pluginId/disable', {
 1033:     onRequest: [fastify.authenticateAdmin]
 1034:   }, async (request, reply) => {
 1035:     if (!(await requirePluginManager(request, reply))) return
 1036:     const pluginId = normalizePluginId(request.params.pluginId)
 1037:     if (!pluginId) return reply.code(400).send({ error: 'Invalid plugin id', code: 'INVALID_PLUGIN_ID' })
 1038:     const user = getRequestUser(request)
 1039:     const before = await getPlugin(pluginId)
 1040:     if (!before) return reply.code(404).send({ error: 'Plugin not found', code: 'PLUGIN_NOT_FOUND' })
 1041:     await dispatchPluginLifecycleEvent({
 1042:       event: 'plugin.disabled',
 1043:       pluginId,
 1044:       version: before.currentVersion,
 1045:       sourceType: before.sourceType,
  450:     data: {
  451:       status: input.status,
  452:       reviewNotes: input.reviewNotes || null,
  453:       reviewedByUserId: input.reviewedByUserId,
  454:       reviewedAt: new Date()
  455:     },
  456:     include: {
  457:       plugin: { select: { name: true, status: true, enabled: true, currentVersion: true } }
  458:     }
  459:   })
  460: }
  461: 
  462: export async function assertPluginCapabilitiesApprovedForEnable(pluginId: string): Promise<{
  463:   ok: true
  464: } | {
  465:   ok: false
  466:   reviews: SerializedPluginCapabilityReview[]
  467: }> {
  468:   const plugin = await prisma.plugin.findUnique({
  469:     where: { pluginId },
  470:     select: { currentVersion: true }
  471:   })
  472:   if (!plugin?.currentVersion) return { ok: true }
  473: 
  474:   const blocking = await prisma.pluginCapabilityReview.findMany({
  475:     where: {
  476:       pluginId,
  477:       manifestVersion: plugin.currentVersion,
  478:       riskLevel: { in: ['high', 'critical'] },
  479:       status: { not: 'approved' }
  480:     },
  481:     include: {
  482:       plugin: { select: { name: true, status: true, enabled: true, currentVersion: true } }
  483:     },
  484:     orderBy: [{ riskLevel: 'desc' }, { capabilityType: 'asc' }, { id: 'asc' }]
  485:   })
  486:   if (blocking.length === 0) return { ok: true }
  487:   return { ok: false, reviews: blocking.map(serializePluginCapabilityReview) }
  488: }
  489: 
  490: export function serializePluginTask(task: PluginInstallTask & { startedBy?: { username: string } | null }): SerializedPluginTask {
  491:   return {
  492:     id: task.id,
  493:     pluginId: task.pluginId,
