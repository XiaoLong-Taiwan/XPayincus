--- theme-templates/clean-theme/payincus.theme.json
   1: {
   2:   "id": "com.payincus.theme.clean",
   3:   "name": "PayIncus Clean Theme",
   4:   "version": "1.0.0",
   5:   "payincus": ">=0.6.0",
   6:   "description": "Official clean theme sample with design tokens, controlled config fields, CSS assets, and safe template fragments.",
   7:   "author": "PayIncus",
   8:   "homepage": "https://xiaolong-taiwan.github.io/XPayincus//plugins/templates",
   9:   "css": "dist/theme.css",
  10:   "tokens": {
  11:     "colorPrimary": "#0f766e",
  12:     "colorAccent": "#2563eb",
  13:     "colorSurface": "#ffffff",
  14:     "colorMuted": "#64748b",
  15:     "radius": "8px",
  16:     "shadow": "0 10px 30px rgba(15, 23, 42, 0.08)"
  17:   },
  18:   "layoutSlots": [
  19:     "public.home.hero",
  20:     "public.home.sections",
  21:     "public.market.banner",
  22:     "public.auth.aside",
  23:     "user.shell.brand",
  24:     "user.dashboard.banner",
  25:     "user.dashboard.cards",
  26:     "user.instance.detail.extra",
  27:     "user.wallet.banner",
  28:     "user.tickets.banner",
  29:     "user.extensions.banner",
  30:     "user.orders.banner",
  31:     "user.profile.banner",
  32:     "user.invites.banner",
  33:     "user.hosts.banner",
  34:     "user.host.create.banner",
  35:     "admin.shell.brand",
  36:     "admin.extensions.header",
  37:     "admin.extensions.market.banner",
  38:     "admin.extensions.theme.banner",
  39:     "admin.dashboard.banner",
  40:     "admin.dashboard.widgets",
  41:     "admin.billing.banner",
  42:     "admin.payment.providers.banner",
  43:     "admin.oauth.banner",
  44:     "shared.footer"
  45:   ],
  46:   "templates": [
  47:     {
  48:       "slot": "public.home.hero",
  49:       "title": "Clean homepage hero",
  50:       "entry": "templates/public/home-hero.html"
  51:     },
  52:     {
  53:       "slot": "public.home.sections",
  54:       "title": "Clean homepage sections",
  55:       "entry": "templates/public/home-sections.html"
  56:     },
  57:     {
  58:       "slot": "public.market.banner",
  59:       "title": "Clean market banner",
  60:       "entry": "templates/public/market-banner.html"
  61:     },
  62:     {
  63:       "slot": "public.auth.aside",
  64:       "title": "Clean authentication aside",
  65:       "entry": "templates/public/auth-aside.html"
  66:     },
  67:     {
  68:       "slot": "user.shell.brand",
  69:       "title": "Clean user shell brand",
  70:       "entry": "templates/user/shell-brand.html"
  71:     },
  72:     {
  73:       "slot": "user.dashboard.banner",
  74:       "title": "Clean user dashboard banner",
  75:       "entry": "templates/user/dashboard-banner.html"
  76:     },
  77:     {
  78:       "slot": "user.dashboard.cards",
  79:       "title": "Clean user dashboard cards",
  80:       "entry": "templates/user/dashboard-cards.html"
  81:     },
