  321: export async function fetchPluginMarketIndex(url?: string | null): Promise<PluginMarketIndex> {
  322:   const effectiveUrl = url ?? await getPluginMarketIndexUrl()
  323:   if (!effectiveUrl) {
  324:     return buildUnavailablePluginMarketIndex()
  325:   }
  326:   const trustedHosts = await getPluginMarketTrustedHosts()
  327:   const parsed = assertGitHubIndexUrl(effectiveUrl, trustedHosts)
  328:   const response = await fetch(parsed, {
  329:     headers: { 'user-agent': 'payincus-plugin-center' }
  330:   })
  331:   if (!response.ok) {
  332:     throw new Error(`Failed to fetch plugin market index: HTTP ${response.status}`)
  333:   }
  334:   const payload: unknown = await response.json()
  335:   const normalized = isRecord(payload) && Array.isArray(payload.plugins)
  336:     ? payload.plugins.map(entry => normalizeEntry(entry, trustedHosts)).filter((entry): entry is PluginMarketEntry => !!entry)
  337:     : []
  338:   const plugins = normalized.filter(entry => entry.reviewStatus === 'listed')
  339:   return {
  340:     plugins,
  341:     governance: {
  342:       totalEntries: normalized.length,
  343:       visibleEntries: plugins.length,
  344:       hiddenEntries: normalized.length - plugins.length,
  345:       indexHost: parsed.hostname,
  346:       fingerprint: getMarketFingerprint(normalized),
  347:       defaultReviewStatus: 'pending',
  348:       installPolicy: PLUGIN_MARKET_INSTALL_POLICY
  349:     }
  350:   }
  351: }
