   60: async function sha256File(path: string): Promise<string> {
   61:   const hash = createHash('sha256')
   62:   await new Promise<void>((resolve, reject) => {
   63:     const stream = createReadStream(path)
   64:     stream.on('data', chunk => hash.update(chunk))
   65:     stream.on('error', reject)
   66:     stream.on('end', () => resolve())
   67:   })
   68:   return hash.digest('hex')
   69: }
