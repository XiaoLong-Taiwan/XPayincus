  187: export async function scanPluginMarketSubmission(input: PluginSubmissionScanInput): Promise<PluginSubmissionScanResult> {
  188:   const findings: PluginSubmissionScanFinding[] = []
  189:   const maxBytes = getPluginPackageMaxBytes()
  190:   const scanRoot = join(getPluginStagingDir(), 'submission-scans')
  191:   await mkdir(scanRoot, { recursive: true })
  192:   const scanDir = join(scanRoot, `${input.id}-${Date.now()}-${randomUUID()}`)
  193:   await mkdir(scanDir, { recursive: true })
  194:   const packagePath = join(scanDir, 'plugin.tar.gz')
  195: 
  196:   let manifest: PayIncusPluginManifest | null = null
  197:   let packageSha256: string | null = null
  198: 
  199:   try {
  200:     const [manifestBuffer, packageBuffer] = await Promise.all([
  201:       downloadBoundedHttpsFile(input.manifestUrl, 'Manifest URL', 1024 * 1024),
  202:       downloadBoundedHttpsFile(input.packageUrl, 'Package URL', maxBytes)
  203:     ])
  204: 
  205:     manifest = parsePluginManifest(JSON.parse(manifestBuffer.toString('utf8')))
  206:     compareManifestToSubmission(manifest, input, findings)
  207: 
  208:     await writeFile(packagePath, packageBuffer, { mode: 0o600 })
  209:     packageSha256 = await sha256File(packagePath)
  210:     if (packageSha256 !== input.sha256.toLowerCase()) {
  211:       pushFinding(findings, 'error', 'sha256_mismatch', `Package SHA256 ${packageSha256} does not match submitted SHA256 ${input.sha256}`)
  212:     }
  213: 
  214:     const validated = await validateAndExtractPluginPackage(packagePath, input.id)
  215:     compareManifestToSubmission(validated.manifest, input, findings)
  216:     if (validated.sha256 !== packageSha256) {
  217:       pushFinding(findings, 'error', 'package_hash_inconsistent', 'Package hash changed during validation')
  218:     }
  219:     await rm(validated.stagingDir, { recursive: true, force: true }).catch(() => undefined)
  220: 
  221:     if (JSON.stringify(validated.manifest) !== JSON.stringify(manifest)) {
  222:       pushFinding(findings, 'warning', 'manifest_url_package_mismatch', 'Manifest URL content differs from package manifest')
  223:     }
  224: 
  225:     const riskLevel = assessRisk(validated.manifest, input.permissions, findings)
  226:     return {
  227:       status: scanStatusFromFindings(findings),
  228:       riskLevel,
  229:       manifest: {
  230:         id: validated.manifest.id,
  231:         name: validated.manifest.name,
  232:         version: validated.manifest.version,
  233:         permissions: validated.manifest.permissions || []
  234:       },
  235:       packageSha256,
  236:       findings,
  237:       scannedAt: new Date().toISOString()
  238:     }
  239:   } catch (error) {
  240:     const message = error instanceof Error ? error.message : String(error)
  241:     pushFinding(findings, 'error', 'scan_failed', message)
  242:     return {
  243:       status: 'failed',
  244:       riskLevel: 'high',
  245:       manifest: manifest ? {
  246:         id: manifest.id,
  247:         name: manifest.name,
  248:         version: manifest.version,
  249:         permissions: manifest.permissions || []
  250:       } : null,
  251:       packageSha256,
  252:       findings,
  253:       scannedAt: new Date().toISOString()
  254:     }
  255:   } finally {
  256:     await rm(scanDir, { recursive: true, force: true }).catch(() => undefined)
  257:   }
  258: }
