  131:   handler: string
  132:   total: number
  133:   success: number
  134:   failed: number
  135:   retryPending: number
  136:   deadLetter: number
  137:   deduped: number
  138:   dueRetry: number
  139:   lastEventAt: string | null
  140:   lastSuccessAt: string | null
  141:   lastFailureAt: string | null
  142:   lastError: string | null
  143:   recentWindowHours: number
  144:   recentTotal: number
  145:   recentSuccess: number
  146:   recentFailed: number
  147:   recentRetryPending: number
  148:   recentDeadLetter: number
  149:   recentDeduped: number
  150:   recentDueRetry: number
  151:   recentSuccessRate: number | null
  152:   alerts: DeveloperPluginEventHealthAlert[]
  153: }
  154: 
  155: function getRequestUser(request: FastifyRequest): { id: number; username: string; role: 'admin' | 'user' } {
  156:   return request.user as { id: number; username: string; role: 'admin' | 'user' }
  157: }
  158: 
  159: async function canManagePluginMarketSubmissions(user: { id: number; username: string; role: 'admin' | 'user' }): Promise<boolean> {
  160:   if (user.role !== 'admin') return false
  161:   const { ids: allowedIds } = await getCombinedAdminIdAllowlist(
  162:     'plugin_manager_allowed_admin_ids',
  163:     ['PLUGIN_MANAGER_ALLOWED_ADMIN_IDS', 'SYSTEM_UPDATE_ALLOWED_ADMIN_IDS']
  164:   )
  165:   if (allowedIds.size > 0) return allowedIds.has(user.id)
  166:   return user.username === 'admin'
  167: }
  168: 
  169: async function requirePluginMarketReviewer(request: FastifyRequest, reply: FastifyReply): Promise<boolean> {
  170:   const user = getRequestUser(request)
  171:   if (!(await canManagePluginMarketSubmissions(user))) {
  172:     await createLog(
  173:       user.id,
  174:       LogModule.PLUGIN,
  175:       'plugin.market_submission.review_denied',
  176:       `Denied plugin market submission review access for ${user.username}`,
  177:       LogResult.WARNING
  178:     )
  179:     reply.code(403).send({ error: 'Super administrator privileges required', code: 'SUPER_ADMIN_REQUIRED' })
  180:     return false
  181:   }
  182:   return true
  183: }
  184: 
  185: function normalizeText(value: unknown, maxLength: number): string | null {
  186:   if (typeof value !== 'string') return null
  187:   const trimmed = value.trim()
  188:   if (!trimmed || trimmed.length > maxLength) return null
  189:   return trimmed
  190: }
  191: 
  192: function normalizeOptionalText(value: unknown, maxLength: number): string | null {
  193:   if (value === undefined || value === null || value === '') return null
  194:   return normalizeText(value, maxLength)
  195: }
  196: 
  197: function normalizeHttpsUrl(value: unknown): string | null {
  198:   const text = normalizeText(value, 2048)
  199:   if (!text) return null
  200:   try {
  201:     const url = new URL(text)
  202:     if (url.protocol !== 'https:') return null
  203:     return url.toString()
  204:   } catch {
  205:     return null
  206:   }
  207: }
  208: 
  209: function normalizeOptionalHttpsUrl(value: unknown): string | null {
  210:   if (value === undefined || value === null || value === '') return null
  211:   return normalizeHttpsUrl(value)
  212: }
  213: 
  214: function normalizeJsonRecord(value: unknown): Record<string, unknown> {
  215:   return value && typeof value === 'object' && !Array.isArray(value)
  216:     ? value as Record<string, unknown>
  217:     : {}
  218: }
  219: 
  220: function normalizeSubmissionBody(body: SubmissionBody) {
  221:   const pluginId = normalizeText(body.pluginId, 120)
  222:   const version = normalizeText(body.version, 64)
  223:   const name = normalizeText(body.name, 120)
  224:   const repoUrl = normalizeHttpsUrl(body.repoUrl)
  225:   const releaseUrl = normalizeHttpsUrl(body.releaseUrl)
  226:   const manifestUrl = normalizeHttpsUrl(body.manifestUrl)
  227:   const packageUrl = normalizeHttpsUrl(body.packageUrl)
  228:   const sha256 = normalizeText(body.sha256, 64)?.toLowerCase() ?? null
  229:   const developerName = normalizeText(body.developerName, 120)
  230:   const contactEmail = normalizeText(body.contactEmail, 254)
  231:   const developerHomepage = normalizeOptionalHttpsUrl(body.developerHomepage)
  232:   const developerGithub = normalizeOptionalHttpsUrl(body.developerGithub)
  233:   const notes = normalizeOptionalText(body.notes, 5000)
  234: 
  235:   if (!pluginId || !PLUGIN_ID_PATTERN.test(pluginId)) throw new Error('Invalid plugin id')
  236:   if (!version || !VERSION_PATTERN.test(version)) throw new Error('Invalid plugin version')
  237:   if (!name) throw new Error('Invalid plugin name')
  238:   if (!repoUrl || !releaseUrl || !manifestUrl || !packageUrl) throw new Error('Submission URLs must be HTTPS')
  239:   if (!sha256 || !SHA256_PATTERN.test(sha256)) throw new Error('Invalid package SHA256')
  240:   if (!developerName) throw new Error('Invalid developer name')
  240:   if (!developerName) throw new Error('Invalid developer name')
  241:   if (!contactEmail || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(contactEmail)) throw new Error('Invalid contact email')
  242: 
  243:   return {
  244:     pluginId,
  245:     version,
  246:     name,
  247:     repoUrl,
  248:     releaseUrl,
  249:     manifestUrl,
  250:     packageUrl,
  251:     sha256,
  252:     developerName,
  253:     developerHomepage,
  254:     developerGithub,
  255:     contactEmail,
  256:     permissions: normalizeJsonRecord(body.permissions),
  257:     compatibility: normalizeJsonRecord(body.compatibility),
  258:     pricing: normalizeJsonRecord(body.pricing),
  259:     notes
  260:   }
  261: }
  262: 
  263: function parsePositiveId(value: string): number | null {
  264:   if (!/^[1-9]\d*$/.test(value)) return null
  265:   const parsed = Number(value)
  266:   return Number.isSafeInteger(parsed) ? parsed : null
  267: }
  268: 
  269: function parseLimit(value: string | undefined): number {
  270:   if (!value || !/^[1-9]\d*$/.test(value)) return 100
  271:   const parsed = Number(value)
  272:   return Number.isSafeInteger(parsed) ? Math.min(parsed, 200) : 100
  273: }
  274: 
  275: function normalizeReviewStatus(value: unknown): PluginMarketSubmissionReviewStatus | null {
  276:   return typeof value === 'string' && REVIEW_STATUSES.includes(value as PluginMarketSubmissionReviewStatus)
  277:     ? value as PluginMarketSubmissionReviewStatus
  278:     : null
  279: }
  280: 
  281: function getPluginSubmissionUploadDir(): string {
  282:   return join(getPluginDataDir(), 'submission-uploads', 'plugins')
  283: }
  284: 
  285: function getPluginSubmissionUploadTempDir(): string {
  286:   return join(getPluginStagingDir(), 'submission-uploads')
  287: }
  288: 
  289: function normalizeUploadFilename(value: string): string | null {
  290:   const trimmed = value.trim()
  291:   return /^[a-z][a-z0-9.-]{2,180}\.(?:tar\.gz|plugin\.json)$/.test(trimmed) ? trimmed : null
  292: }
  293: 
  294: async function publicBaseUrlFromRequest(request: FastifyRequest): Promise<string> {
  295:   return getPluginSubmissionPublicBaseUrl(`${request.protocol}://${request.hostname}`)
  296: }
  297: 
  298: async function buildPublicUploadUrl(request: FastifyRequest, filename: string): Promise<string> {
  299:   const publicBaseUrl = await publicBaseUrlFromRequest(request)
  300:   return `${publicBaseUrl}/api/plugin-market-submissions/uploads/plugins/${encodeURIComponent(filename)}`
  301: }
  302: 
  303: function submissionUploadTaskId(): number {
  304:   return Math.floor(Date.now() % 1_000_000_000) * 1000 + Math.floor(Math.random() * 1000)
  305: }
  306: 
  307: async function receiveUploadedPluginPackage(request: FastifyRequest): Promise<{ packagePath: string; sourceName: string }> {
  308:   const multipartRequest = request as FastifyRequest & {
  309:     parts: () => AsyncIterable<any>
  310:   }
  311:   const uploadTempDir = getPluginSubmissionUploadTempDir()
  312:   await mkdir(uploadTempDir, { recursive: true })
  313:   const maxBytes = getPluginPackageMaxBytes()
  314: 
  315:   for await (const part of multipartRequest.parts()) {
  316:     if (part.type !== 'file') continue
  317:     if (part.fieldname !== 'package') {
  318:       await part.toBuffer()
  319:       continue
  320:     }
  321:     const sourceName = String(part.filename || 'plugin.tar.gz')
  322:     if (!sourceName.endsWith('.tar.gz')) {
  323:       throw new Error('Plugin package must be a .tar.gz file')
  324:     }
  325:     const buffer = await part.toBuffer()
  326:     if (buffer.length === 0) throw new Error('Plugin package is empty')
  327:     if (buffer.length > maxBytes) throw new Error(`Plugin package exceeds ${Math.round(maxBytes / 1024 / 1024)}MB`)
  328:     const packagePath = join(uploadTempDir, `${Date.now()}-${randomUUID()}.tar.gz`)
  329:     await writeFile(packagePath, buffer, { mode: 0o600 })
  330:     return { packagePath, sourceName }
  331:   }
  332: 
  333:   throw new Error('Missing plugin package file')
  334: }
  335: 
  336: function normalizeRiskLevel(value: unknown): PluginMarketSubmissionRiskLevel | null {
  337:   return typeof value === 'string' && RISK_LEVELS.includes(value as PluginMarketSubmissionRiskLevel)
  338:     ? value as PluginMarketSubmissionRiskLevel
  339:     : null
  340: }
  341: 
  342: function calculateSuccessRate(success: number, total: number): number | null {
  343:   if (total <= 0) return null
  344:   return Math.round((success / total) * 1000) / 10
  345: }
  346: 
  347: function buildDeveloperEventTrend(logs: Array<{ result: string; createdAt: Date; lastAttemptAt: Date | null }>, now: Date, days: number): DeveloperPluginEventHealthTrendPoint[] {
  348:   const dayMs = 24 * 60 * 60 * 1000
  349:   const points = Array.from({ length: days }, (_, index) => {
  350:     const date = new Date(now.getTime() - (days - index - 1) * dayMs).toISOString().slice(0, 10)
  351:     return { date, total: 0, success: 0, failed: 0, retryPending: 0, deadLetter: 0, deduped: 0 }
  352:   })
  353:   const byDate = new Map(points.map(point => [point.date, point]))
  354:   for (const log of logs) {
  355:     const date = (log.lastAttemptAt || log.createdAt).toISOString().slice(0, 10)
  356:     const point = byDate.get(date)
  357:     if (!point) continue
  358:     point.total += 1
  359:     if (log.result === 'success') point.success += 1
  360:     if (log.result === 'failed') point.failed += 1
  361:     if (log.result === 'retry_pending') point.retryPending += 1
  362:     if (log.result === 'dead_letter') point.deadLetter += 1
  363:     if (log.result === 'duplicate_skipped') point.deduped += 1
  364:   }
  365:   return points
  366: }
  367: 
  368: function buildDeveloperEventAlerts(input: {
  369:   deadLetter: number
  370:   dueRetry: number
  371:   recentTotal: number
  372:   recentFailed: number
  373:   recentRetryPending: number
  374:   recentDeadLetter: number
  375:   recentSuccessRate: number | null
  376: }): DeveloperPluginEventHealthAlert[] {
  377:   const alerts: DeveloperPluginEventHealthAlert[] = []
  378:   if (input.deadLetter > 0) {
  379:     alerts.push({
  380:       level: 'critical',
  381:       code: 'dead_letter',
  382:       message: 'Event deliveries have reached dead letter state.',
  383:       count: input.deadLetter
  384:     })
  385:   }
  386:   if (input.dueRetry > 0) {
  387:     alerts.push({
  388:       level: 'critical',
  389:       code: 'due_retry',
  390:       message: 'Event deliveries are due for retry.',
  391:       count: input.dueRetry
  392:     })
  393:   }
  394:   if (input.recentDeadLetter > 0) {
  395:     alerts.push({
  396:       level: 'critical',
  397:       code: 'recent_dead_letter',
  398:       message: 'Dead letter events occurred in the recent window.',
  399:       count: input.recentDeadLetter
  400:     })
  401:   }
  402:   if (input.recentRetryPending > 0) {
  403:     alerts.push({
  404:       level: 'warning',
  405:       code: 'recent_retry_pending',
  406:       message: 'Recent event deliveries are waiting for retry.',
  407:       count: input.recentRetryPending
  408:     })
  409:   }
  410:   if (input.recentFailed > 0) {
  411:     alerts.push({
  412:       level: 'warning',
  413:       code: 'recent_failed',
  414:       message: 'Recent event deliveries failed before retry handling.',
  415:       count: input.recentFailed
  416:     })
  417:   }
  418:   if (input.recentTotal >= 10 && input.recentSuccessRate !== null && input.recentSuccessRate < 95) {
  419:     alerts.push({
  420:       level: 'warning',
  421:       code: 'recent_success_rate_low',
  422:       message: 'Recent event delivery success rate is below 95%.',
  423:       count: input.recentTotal
  424:     })
  425:   }
  426:   return alerts.slice(0, 8)
  427: }
  428: 
  429: async function buildDeveloperPluginEventHealth(userId: number): Promise<DeveloperPluginEventHealth[]> {
  430:   const submissions = await prisma.pluginMarketSubmission.findMany({
  640:   fastify.get<{
  641:     Params: UploadParams
  642:   }>('/uploads/plugins/:filename', async (request, reply) => {
  643:     const filename = normalizeUploadFilename(request.params.filename)
  644:     if (!filename) return reply.code(404).send({ error: 'Upload not found', code: 'PLUGIN_UPLOAD_NOT_FOUND' })
  645:     const uploadDir = getPluginSubmissionUploadDir()
  646:     const filePath = resolveInside(uploadDir, filename)
  647:     try {
  648:       await access(filePath)
  649:     } catch {
  650:       return reply.code(404).send({ error: 'Upload not found', code: 'PLUGIN_UPLOAD_NOT_FOUND' })
  651:     }
  652:     if (filename.endsWith('.tar.gz')) {
  653:       reply.header('Content-Type', 'application/gzip')
  654:       reply.header('Content-Disposition', `attachment; filename="${filename}"`)
  655:     } else {
  656:       reply.header('Content-Type', 'application/json; charset=utf-8')
  657:     }
  658:     reply.header('X-Content-Type-Options', 'nosniff')
  659:     return reply.send(createReadStream(filePath))
  660:   })
  661: 
  662:   fastify.post('/upload-package', {
  663:     onRequest: [fastify.authenticate]
  664:   }, async (request, reply) => {
  665:     const user = getRequestUser(request)
  666:     let packagePath: string | null = null
  667:     let stagingDir: string | null = null
  668:     try {
  669:       const upload = await receiveUploadedPluginPackage(request)
  670:       packagePath = upload.packagePath
  671:       const validated = await validateAndExtractPluginPackage(packagePath, submissionUploadTaskId())
  672:       stagingDir = validated.stagingDir
  673: 
  674:       const suffix = `${validated.sha256.slice(0, 12)}-${randomUUID().slice(0, 8)}`
  675:       const baseName = `${validated.manifest.id}-${validated.manifest.version}-${suffix}`
  676:       const packageFilename = `${baseName}.tar.gz`
  677:       const manifestFilename = `${baseName}.plugin.json`
  678:       const uploadDir = getPluginSubmissionUploadDir()
  679:       await mkdir(uploadDir, { recursive: true })
  680:       const finalPackagePath = resolveInside(uploadDir, packageFilename)
  681:       const finalManifestPath = resolveInside(uploadDir, manifestFilename)
  682:       await rename(packagePath, finalPackagePath)
  683:       packagePath = null
  684:       await writeFile(finalManifestPath, `${JSON.stringify(validated.manifest, null, 2)}\n`, { mode: 0o644 })
  685: 
  686:       await createLog(
  687:         user.id,
  688:         LogModule.PLUGIN,
  689:         'plugin.market_submission.upload_package',
  690:         `Uploaded plugin market package ${validated.manifest.id}@${validated.manifest.version} (${validated.sha256})`,
  691:         LogResult.SUCCESS
  692:       )
  693: 
  694:       return reply.code(201).send({
  695:         upload: {
  696:           pluginId: validated.manifest.id,
  697:           version: validated.manifest.version,
  698:           name: validated.manifest.name,
  699:           packageUrl: await buildPublicUploadUrl(request, packageFilename),
  700:           manifestUrl: await buildPublicUploadUrl(request, manifestFilename),
  701:           sha256: validated.sha256,
  702:           permissions: {
  703:             manifest: validated.manifest.permissions || [],
  704:             events: (validated.manifest.capabilities?.events || []).map(event => event.event),
  705:             actions: (validated.manifest.capabilities?.actions || []).map(action => action.name)
  706:           },
  707:           compatibility: { payincus: validated.manifest.payincus },
  708:           sourceName: upload.sourceName
  709:         }
  710:       })
  711:     } catch (error) {
  712:       const message = error instanceof Error ? error.message : String(error)
  713:       await createLog(
  714:         user.id,
  715:         LogModule.PLUGIN,
  716:         'plugin.market_submission.upload_failed',
  717:         `Plugin market package upload failed: ${message}`,
  718:         LogResult.WARNING
  719:       ).catch(() => undefined)
  720:       return reply.code(400).send({ error: message, code: 'PLUGIN_SUBMISSION_UPLOAD_INVALID' })
  721:     } finally {
  722:       if (packagePath) await rm(packagePath, { force: true }).catch(() => undefined)
  723:       if (stagingDir) await rm(stagingDir, { recursive: true, force: true }).catch(() => undefined)
  724:     }
  725:   })
  726: 
  727:   fastify.post<{
  728:     Body: SubmissionBody
  729:   }>('/', {
  730:     onRequest: [fastify.authenticate]
  731:   }, async (request, reply) => {
  732:     const user = getRequestUser(request)
  733: 
  734:     try {
  735:       const normalized = normalizeSubmissionBody(request.body || {})
  736:       const submission = await createPluginMarketSubmission({
  737:         ...normalized,
  738:         submittedByUserId: user.id
  739:       })
  740:       await createLog(
  741:         user.id,
  742:         LogModule.PLUGIN,
  743:         'plugin.market_submission.create',
  744:         `Submitted plugin market review ${normalized.pluginId}@${normalized.version}`,
  745:         LogResult.SUCCESS
  746:       )
  747:       return reply.code(201).send({ submission: serializePluginMarketSubmission(submission) })
  748:     } catch (error) {
  749:       if (error instanceof Prisma.PrismaClientKnownRequestError && error.code === 'P2002') {
  750:         return reply.code(409).send({ error: 'Plugin version is already submitted', code: 'PLUGIN_SUBMISSION_EXISTS' })
  751:       }
  752:       const message = error instanceof Error ? error.message : String(error)
  753:       return reply.code(400).send({ error: message, code: 'PLUGIN_SUBMISSION_INVALID' })
  754:     }
  755:   })
  756: 
  757:   fastify.get('/mine', {
  758:     onRequest: [fastify.authenticate]
  759:   }, async (request) => {
  760:     const user = getRequestUser(request)
  761:     const submissions = await listMyPluginMarketSubmissions(user.id)
  762:     return { submissions: submissions.map(serializePluginMarketSubmission) }
  763:   })
  764: 
  765:   fastify.get('/mine/event-health', {
  766:     onRequest: [fastify.authenticate]
  767:   }, async (request) => {
  768:     const user = getRequestUser(request)
  769:     return {
  770:       plugins: await buildDeveloperPluginEventHealth(user.id),
  771:       updatedAt: new Date().toISOString()
  772:     }
  773:   })
  774: 
  775:   fastify.get('/mine/event-alert-preferences', {
  776:     onRequest: [fastify.authenticate]
  777:   }, async (request) => {
  778:     const user = getRequestUser(request)
  779:     const pluginIds = await listSubmittedPluginIds(user.id)
  780:     return {
  781:       preferences: await listPluginEventAlertPreferences(user.id, pluginIds),
  782:       updatedAt: new Date().toISOString()
  783:     }
  784:   })
  785: 
  786:   fastify.patch<{
  787:     Params: PluginIdParams
  788:     Body: PluginEventAlertPreferenceInput
  789:   }>('/mine/event-alert-preferences/:pluginId', {
  790:     onRequest: [fastify.authenticate]
  791:   }, async (request, reply) => {
  792:     const user = getRequestUser(request)
  793:     const pluginId = normalizeText(request.params.pluginId, 120)
  794:     if (!pluginId || !PLUGIN_ID_PATTERN.test(pluginId)) {
  795:       return reply.code(400).send({ error: 'Invalid plugin id', code: 'INVALID_PLUGIN_ID' })
  796:     }
  797:     const submitted = await prisma.pluginMarketSubmission.findFirst({
  798:       where: { submittedByUserId: user.id, pluginId },
  799:       select: { id: true }
  800:     })
  801:     if (!submitted) {
  802:       return reply.code(404).send({ error: 'Plugin submission not found', code: 'PLUGIN_SUBMISSION_NOT_FOUND' })
  803:     }
  804:     const preference = await upsertPluginEventAlertPreference(user.id, pluginId, request.body || {})
  805:     await createLog(
  806:       user.id,
  807:       LogModule.PLUGIN,
  808:       'plugin.event.alert_preference_update',
  809:       `Updated plugin event alert preference for ${pluginId}`,
  810:       LogResult.SUCCESS
  811:     )
  812:     return { preference }
  813:   })
  814: 
  815:   fastify.get<{
  816:     Querystring: SubmissionQuery
  817:   }>('/admin', {
  818:     onRequest: [fastify.authenticateAdmin]
  819:   }, async (request, reply) => {
  820:     if (!(await requirePluginMarketReviewer(request, reply))) return
  821:     let reviewStatus: PluginMarketSubmissionReviewStatus | undefined
  822:     if (request.query.reviewStatus) {
  823:       const normalizedReviewStatus = normalizeReviewStatus(request.query.reviewStatus)
  824:       if (!normalizedReviewStatus) {
  825:         return reply.code(400).send({ error: 'Invalid review status', code: 'INVALID_REVIEW_STATUS' })
  826:       }
  827:       reviewStatus = normalizedReviewStatus
  828:     }
  829:     if (request.query.reviewStatus && !reviewStatus) {
  830:       return reply.code(400).send({ error: 'Invalid review status', code: 'INVALID_REVIEW_STATUS' })
  831:     }
  832:     const submissions = await listPluginMarketSubmissions({
  833:       reviewStatus,
  834:       limit: parseLimit(request.query.limit)
  835:     })
  836:     return { submissions: submissions.map(serializePluginMarketSubmission) }
  837:   })
  838: 
  839:   fastify.patch<{
  840:     Params: ReviewParams
  841:     Body: ReviewBody
  842:   }>('/admin/:id/review', {
  843:     onRequest: [fastify.authenticateAdmin]
  844:   }, async (request, reply) => {
  845:     if (!(await requirePluginMarketReviewer(request, reply))) return
  846:     const id = parsePositiveId(request.params.id)
  847:     if (!id) return reply.code(400).send({ error: 'Invalid submission id', code: 'INVALID_SUBMISSION_ID' })
  848: 
  849:     const reviewStatus = normalizeReviewStatus(request.body?.reviewStatus)
  850:     const riskLevel = normalizeRiskLevel(request.body?.riskLevel) ?? 'medium'
  851:     const reviewNotes = normalizeOptionalText(request.body?.reviewNotes, 5000)
  852:     if (!reviewStatus) {
  853:       return reply.code(400).send({ error: 'Invalid review status', code: 'INVALID_REVIEW_STATUS' })
  854:     }
  855: 
  856:     try {
  857:       const user = getRequestUser(request)
  858:       const submission = await reviewPluginMarketSubmission({
  859:         id,
  860:         reviewStatus,
  861:         riskLevel,
  862:         reviewNotes,
  863:         reviewedByUserId: user.id
  864:       })
  865:       await createLog(
  866:         user.id,
  867:         LogModule.PLUGIN,
  868:         'plugin.market_submission.review',
  869:         `Reviewed plugin market submission ${submission.pluginId}@${submission.version}: ${reviewStatus}/${riskLevel}`,
  870:         LogResult.SUCCESS
  871:       )
  872:       return { submission: serializePluginMarketSubmission(submission) }
