   99: async function readExistingMarketEntries(indexPath: string): Promise<ThemeMarketEntry[]> {
  100:   try {
  101:     const payload = JSON.parse(await readFile(indexPath, 'utf8')) as unknown
  102:     if (!isRecord(payload) || !Array.isArray(payload.themes)) return []
  103:     return payload.themes.filter((entry): entry is ThemeMarketEntry => isRecord(entry) && typeof entry.id === 'string')
  104:   } catch {
  105:     return []
  106:   }
  107: }
