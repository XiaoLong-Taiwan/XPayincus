   64: function submissionToMarketEntry(submission: Awaited<ReturnType<typeof prisma.themeMarketSubmission.findMany>>[number], publicBaseUrl: string): ThemeMarketEntry {
   65:   const manifestUrl = submission.manifestUrl || `${publicBaseUrl}/manifests/${submission.themeId}/${submission.version}.json`
   66:   return {
   67:     id: submission.themeId,
   68:     name: submission.name,
   69:     latest: submission.version,
   70:     manifestUrl,
   71:     downloadUrl: submission.packageUrl,
   72:     sha256: submission.sha256,
   73:     description: submission.notes || undefined,
   74:     author: submission.developerName,
   75:     reviewStatus: 'listed',
   76:     trustLevel: submission.developerGithub ? 'verified' : 'third_party',
   77:     developer: {
   78:       name: submission.developerName,
   79:       homepage: submission.developerHomepage || undefined,
   80:       github: submission.developerGithub || undefined,
   81:       verified: Boolean(submission.developerGithub),
   82:       contact: submission.contactEmail
   83:     },
   84:     compatibility: normalizeCompatibility(submission.compatibility),
   85:     security: {
   86:       checksumPinned: true,
   87:       signature: { status: 'unsigned' },
   88:       notes: getScanNotes(submission.scanResult, submission.riskLevel)
   89:     },
   90:     tokens: pickStringArray(submission.tokens),
   91:     layoutSlots: pickStringArray(submission.layoutSlots),
   92:     rating: { average: 0, count: 0 },
   93:     installCount: 0,
   94:     releaseNotes: submission.notes || undefined,
   95:     rollbackNotes: 'Disable the theme or roll back to the default theme from the extension center.'
   96:   }
   97: }
