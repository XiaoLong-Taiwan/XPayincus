   56: async function getThemeMarketPublicBaseUrl(): Promise<string> {
   57:   return (await getRuntimeConfigString(
   58:     'theme_market_public_base_url',
   59:     'THEME_MARKET_PUBLIC_BASE_URL',
   60:     'https://xiaolong-taiwan.github.io/XPayincus//theme-market'
   61:   )).replace(/\/+$/, '')
