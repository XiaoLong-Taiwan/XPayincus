   61: function isRecord(value: unknown): value is Record<string, unknown> {
   62:   return !!value && typeof value === 'object' && !Array.isArray(value)
   63: }
   64: 
   65: function pushFinding(
   66:   findings: PluginSubmissionScanFinding[],
   67:   severity: PluginSubmissionScanFinding['severity'],
   68:   code: string,
   69:   message: string
   70: ) {
   71:   findings.push({ severity, code, message })
   72: }
