  611: export async function appendPluginTaskLog(logPath: string, message: string) {
  612:   await mkdir(getPluginLogDir(), { recursive: true })
  613:   await appendFile(logPath, `${new Date().toISOString()} ${message}\n`, 'utf8')
  614: }
  615: 
  616: export async function installValidatedPlugin(input: {
  617:   taskId: number
  618:   stagingDir: string
  619:   manifest: PayIncusPluginManifest
  620:   packageSha256: string
  621:   sourceType: PluginSourceType
  622:   sourceRepo?: string | null
  623:   installedByUserId: number
  624:   logPath: string
  625: }) {
  626:   const installRoot = getPluginInstallDir()
  627:   await mkdir(installRoot, { recursive: true })
  628:   const pluginRoot = resolveInside(installRoot, input.manifest.id)
  629:   await mkdir(pluginRoot, { recursive: true })
  630:   const finalPath = resolveInside(pluginRoot, input.manifest.version)
  631:   await rm(finalPath, { recursive: true, force: true })
  632:   await rename(input.stagingDir, finalPath)
  633:   await appendPluginTaskLog(input.logPath, `Installed package files to ${finalPath}`)
  634: 
  635:   const plugin = await prisma.plugin.upsert({
  636:     where: { pluginId: input.manifest.id },
  637:     create: {
  638:       pluginId: input.manifest.id,
  639:       name: input.manifest.name,
  640:       status: 'installed',
  641:       enabled: false,
  642:       currentVersion: input.manifest.version,
  643:       sourceType: input.sourceType,
  644:       sourceRepo: input.sourceRepo || null,
  645:       installedByUserId: input.installedByUserId
  646:     },
  647:     update: {
  648:       name: input.manifest.name,
  649:       status: 'installed',
  650:       currentVersion: input.manifest.version,
  651:       sourceType: input.sourceType,
  652:       sourceRepo: input.sourceRepo || null
  653:     }
  654:   })
  655: 
  656:   await prisma.pluginVersion.upsert({
  657:     where: { pluginId_version: { pluginId: input.manifest.id, version: input.manifest.version } },
  658:     create: {
  659:       pluginId: input.manifest.id,
  660:       version: input.manifest.version,
  661:       manifest: input.manifest as any,
  662:       packageSha256: input.packageSha256,
  663:       installPath: finalPath
  664:     },
  665:     update: {
  666:       manifest: input.manifest as any,
  667:       packageSha256: input.packageSha256,
  668:       installPath: finalPath
  669:     }
  670:   })
  671: 
  672:   const capabilityReviewCount = await syncPluginCapabilityReviews(input.manifest)
  673:   await appendPluginTaskLog(input.logPath, `Synced ${capabilityReviewCount} capability review record(s)`)
  674: 
  675:   await prisma.pluginInstallTask.update({
  676:     where: { id: input.taskId },
  677:     data: { pluginId: input.manifest.id }
  678:   })
  679:   await createPluginEvent(input.manifest.id, input.installedByUserId, 'plugin.install', 'success', `Installed ${input.manifest.version}`)
  680:   return plugin
  681: }
