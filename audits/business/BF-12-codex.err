  12:         "title": "Admin Tool",
  13:         "entry": "dist/admin/index.html"
  14:       },
  15:       {
  16:         "slot": "admin.sidebar.extra",
  17:         "title": "Admin Tool Console",
  18:         "entry": "dist/admin/index.html"
  19:       },
  20:       {
  21:         "slot": "admin.dashboard.widgets",
  22:         "title": "Admin Tool Widget",
  23:         "entry": "dist/admin/index.html"
  24:       }
  25:     ],
  26:     "userPages": []
  27:   },
  28:   "permissions": ["plugin:config:read"],
  29:   "configSchema": {},
  30:   "templates": []
  31: }
--- plugin-templates/flash-sale-plugin/payincus.plugin.json
   1: {
   2:   "id": "com.example.flash-sale",
   3:   "name": "Flash Sale Example",
   4:   "version": "1.0.0",
   5:   "payincus": ">=0.6.0",
   6:   "description": "A complete extension example with an admin settings page, user campaign page, webhook actions, event subscriptions, and scoped storage.",
   7:   "author": "Example",
   8:   "homepage": "https://example.com/payincus-flash-sale",
   9:   "entrypoints": {
  10:     "adminPages": [
  11:       {
  12:         "slot": "admin.plugins.settings",
  13:         "title": "Flash Sale Settings",
  14:         "entry": "dist/admin/settings.html"
  15:       }
  16:     ],
  17:     "userPages": [
  18:       {
  19:         "slot": "user.sidebar.extra",
  20:         "title": "Flash Sale",
  21:         "path": "/plugins/flash-sale",
  22:         "entry": "dist/user/index.html",
  23:         "requiresAuth": true
  24:       }
  25:     ]
  26:   },
  27:   "permissions": [
  28:     "plugin-action:run",
  29:     "plugin-storage:read",
  30:     "plugin-storage:write",
  31:     "orders:create",
  32:     "products:read",
  33:     "services:read",
  34:     "notifications:send"
  35:   ],
  36:   "configSchema": {
  37:     "campaignEnabled": {
  38:       "type": "checkbox",
  39:       "label": "Enable campaign",
  40:       "description": "Controls whether the flash sale page should show the active campaign.",
  41:       "group": "Campaign",
  42:       "order": 10,
  43:       "required": false,
  44:       "default": false
  45:     },
  46:     "campaignId": {
  47:       "type": "text",
  48:       "label": "Campaign ID",
  49:       "description": "Stable ID used in webhook idempotency and extension storage keys.",
  50:       "placeholder": "summer-2026",
  51:       "group": "Campaign",
  52:       "order": 20,
  53:       "required": true
  54:     },
  55:     "productSku": {
  56:       "type": "text",
  57:       "label": "Product SKU",
  58:       "description": "Product or package identifier shown on the user page.",
  59:       "placeholder": "vps-basic",
  60:       "group": "Campaign",
  61:       "order": 30,
  62:       "required": true
  63:     },
  64:     "startsAt": {
  65:       "type": "text",
  66:       "label": "Start time",
  67:       "description": "ISO 8601 campaign start time.",
  68:       "placeholder": "2026-07-01T12:00:00+08:00",
  69:       "group": "Campaign",
  70:       "order": 40,
  71:       "required": true
  72:     },
  73:     "endsAt": {
  74:       "type": "text",
  75:       "label": "End time",
  76:       "description": "ISO 8601 campaign end time.",
  77:       "placeholder": "2026-07-01T12:10:00+08:00",
  78:       "group": "Campaign",
  79:       "order": 50,
  80:       "required": true
  81:     },
  82:     "stockLimit": {
  83:       "type": "number",
  84:       "label": "Stock limit",
  85:       "description": "Maximum number of reservations the extension service may accept.",
  86:       "group": "Inventory",
  87:       "order": 60,
  88:       "required": true,
  89:       "default": 100,
  90:       "min": 1,
  91:       "max": 100000,
  92:       "step": 1
  93:     },
  94:     "perUserLimit": {
  95:       "type": "number",
  96:       "label": "Per-user limit",
  97:       "description": "Maximum reservations per user in this campaign.",
  98:       "group": "Inventory",
  99:       "order": 70,
 100:       "required": true,
 101:       "default": 1,
 102:       "min": 1,
 103:       "max": 20,
 104:       "step": 1
 105:     },
 106:     "reserveWebhookSecret": {
 107:       "type": "password",
 108:       "label": "Reserve webhook secret",
 109:       "description": "Secret used by the external extension service. PayIncus stores it encrypted.",
 110:       "group": "Security",
 111:       "order": 80,
 112:       "required": false,
 113:       "secret": true
 114:     }
 115:   },
 116:   "capabilities": {
 117:     "actions": [
 118:       {
 119:         "name": "reserveStock",
 120:         "method": "POST",
 121:         "path": "/reserve-stock",
 122:         "runtime": "webhook",
 123:         "url": "https://extension.example.com/payincus/flash-sale/reserve-stock",
 124:         "scopes": ["orders:create", "plugin-storage:write", "notifications:send"],
 125:         "requestSchema": {
 126:           "type": "object",
 127:           "required": ["campaignId", "sku", "userId", "idempotencyKey"],
 128:           "properties": {
 129:             "campaignId": { "type": "string" },
 130:             "sku": { "type": "string" },
 131:             "userId": { "type": "number" },
 132:             "idempotencyKey": { "type": "string" }
 133:           }
 134:         },
 135:         "responseSchema": {
 136:           "type": "object",
 137:           "required": ["reserved", "reservationId"],
 138:           "properties": {
 139:             "reserved": { "type": "boolean" },
 140:             "reservationId": { "type": "string" },
 141:             "expiresAt": { "type": "string" }
 142:           }
 143:         },
 144:         "idempotency": "required",
 145:         "rateLimit": "strict"
 146:       },
 147:       {
 148:         "name": "confirmPaidReservation",
 149:         "method": "POST",
 150:         "path": "/confirm-paid-reservation",
 151:         "runtime": "webhook",
 152:         "url": "https://extension.example.com/payincus/flash-sale/confirm-paid-reservation",
 153:         "scopes": ["plugin-storage:write", "notifications:send"],
 154:         "idempotency": "required",
 155:         "rateLimit": "normal"
 156:       },
 157:       {
 158:         "name": "releaseReservation",
 159:         "method": "POST",
 160:         "path": "/release-reservation",
 161:         "runtime": "webhook",
 162:         "url": "https://extension.example.com/payincus/flash-sale/release-reservation",
 163:         "scopes": ["plugin-storage:write", "notifications:send"],
 164:         "idempotency": "required",
 165:         "rateLimit": "normal"
 166:       }
 167:     ],
 168:     "events": [
 169:       {
 170:         "event": "order.paid",
 171:         "handler": "confirmPaidReservation"
 172:       },
 173:       {
 174:         "event": "payment.failed",
 175:         "handler": "releaseReservation"
 176:       }
 177:     ],
 178:     "notificationTemplates": [
 179:       {
 180:         "id": "reservation_reminder",
 181:         "title": "ç§’æ€é¢„çº¦æé†’",
 182:         "message": "æ´»åŠ¨ã€Œ{{campaignName}}ã€å°†åœ¨ {{startsAt}} å¼€å§‹ï¼Œå•†å“ï¼š{{productName}}ã€‚",
 183:         "variables": ["campaignName", "startsAt", "productName"]
 184:       },
 185:       {
 186:         "id": "reservation_result",
 187:         "title": "ç§’æ€é¢„çº¦ç»“æžœ",
 188:         "message": "æ´»åŠ¨ã€Œ{{campaignName}}ã€é¢„çº¦ç»“æžœï¼š{{statusText}}ã€‚",
 189:         "variables": ["campaignName", "statusText"]
 190:       }
 191:     ],
 192:     "storage": {
 193:       "kind": "kv",
 194:       "maxKeys": 5000,
 195:       "scopes": ["global", "user", "service"],
 196:       "retention": "keep",
 197:       "tables": [
 198:         {
 199:           "name": "campaign_reservations",
 200:           "description": "Scoped reservation rows keyed by campaign and user id.",
 201:           "scopes": ["global", "user"],
 202:           "maxRows": 100000,
 203:           "migrations": [
 204:             {
 205:               "version": "1.0.0",
 206:               "name": "Create reservation row shape"
 207:             }
 208:           ]
 209:         }
 210:       ]
 211:     }
 212:   },
 213:   "templates": [
 214:     {
 215:       "name": "Default campaign config",
 216:       "path": "templates/default-config.json"
 217:     }
 218:   ]
 219: }
--- plugin-templates/user-sidebar-plugin/payincus.plugin.json
   1: {
   2:   "id": "com.example.user-sidebar",
