   44: const HIGH_RISK_PERMISSION_PATTERNS = [
   45:   /^admin:/,
   46:   /^payment:/,
   47:   /^balance:/,
   48:   /^orders:(create|write|refund|pay)/,
   49:   /^instances:(create|write|delete|rebuild)/,
   50:   /^users:(write|delete|ban)/
   51: ]
   52: 
   53: const WARNING_PERMISSION_PATTERNS = [
   54:   /^orders:/,
   55:   /^tickets:/,
   56:   /^notifications:/,
   57:   /^plugin-action:run$/,
   58:   /^plugin-storage:(read|write)$/
   59: ]
