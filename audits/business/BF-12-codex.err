    7: function normalizeThemeId(value: string): string | null {
    8:   const trimmed = value.trim()
    9:   return /^[a-z][a-z0-9]*(?:\.[a-z][a-z0-9-]*){2,}$/.test(trimmed) ? trimmed : null
   10: }
   11: 
   12: function normalizeVersion(value: string): string | null {
   13:   const trimmed = value.trim()
   14:   return /^\d+\.\d+\.\d+(?:[-+][0-9A-Za-z.-]+)?$/.test(trimmed) ? trimmed : null
   15: }
   16: 
   17: function normalizeThemeConfigKey(value: string): string | null {
   18:   const trimmed = value.trim()
   19:   return /^[A-Za-z][A-Za-z0-9_.-]{0,79}$/.test(trimmed) ? trimmed : null
   20: }
   21: 
   22: function normalizeThemeConfigFilename(value: string): string | null {
   23:   const trimmed = value.trim()
   24:   return /^[0-9]+-[0-9a-f-]{36}\.(?:png|jpg|webp)$/.test(trimmed) ? trimmed : null
   25: }
   26: 
   27: function contentTypeForPath(path: string): string {
   28:   const ext = extname(path).toLowerCase()
   29:   if (ext === '.css') return 'text/css; charset=utf-8'
   30:   if (ext === '.json') return 'application/json; charset=utf-8'
   31:   if (ext === '.svg') return 'image/svg+xml'
   32:   if (ext === '.png') return 'image/png'
   33:   if (ext === '.jpg' || ext === '.jpeg') return 'image/jpeg'
   34:   if (ext === '.webp') return 'image/webp'
   35:   if (ext === '.woff') return 'font/woff'
   36:   if (ext === '.woff2') return 'font/woff2'
   37:   return 'application/octet-stream'
   38: }
   39: 
   40: function escapeHtml(value: string): string {
   41:   return value
   42:     .replace(/&/g, '&amp;')
   43:     .replace(/</g, '&lt;')
   44:     .replace(/>/g, '&gt;')
   45:     .replace(/"/g, '&quot;')
   46:     .replace(/'/g, '&#39;')
   47: }
   48: 
