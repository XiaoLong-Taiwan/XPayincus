    1: import { readFile } from 'fs/promises'
    2: import { extname, join } from 'path'
    3: import type { FastifyInstance, FastifyReply, FastifyRequest } from 'fastify'
    4: import { getActiveThemePackage, getThemePackage, getThemePackageForAsset, serializeThemePackage } from '../db/themes.js'
    5: import { getThemeDataDir, resolveThemeAsset, type PayIncusThemeManifest } from '../lib/theme-package.js'
