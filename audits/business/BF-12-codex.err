  532: export async function listPlugins() {
  533:   return await prisma.plugin.findMany({
  534:     orderBy: [{ enabled: 'desc' }, { updatedAt: 'desc' }],
  535:     include: {
  536:       installedBy: { select: { username: true } },
  537:       enabledBy: { select: { username: true } },
  538:       versions: { orderBy: { installedAt: 'desc' }, take: 1 },
  539:       capabilityReviews: { orderBy: [{ updatedAt: 'desc' }, { id: 'desc' }], take: 20 }
  540:     }
  541:   })
  542: }
  543: 
  544: export async function getPlugin(pluginId: string) {
  545:   return await prisma.plugin.findUnique({
  546:     where: { pluginId },
  547:     include: {
  548:       installedBy: { select: { username: true } },
  549:       enabledBy: { select: { username: true } },
  550:       versions: { orderBy: { installedAt: 'desc' } },
  551:       configs: { orderBy: { key: 'asc' } },
  552:       tasks: { orderBy: { createdAt: 'desc' }, take: 10 },
  553:       eventLogs: { orderBy: { createdAt: 'desc' }, take: 20 },
  554:       capabilityReviews: { orderBy: [{ updatedAt: 'desc' }, { id: 'desc' }] }
  555:     }
  556:   })
  557: }
  558: 
  559: export async function listPluginTasks(limit = 30) {
  560:   return await prisma.pluginInstallTask.findMany({
  561:     orderBy: { createdAt: 'desc' },
  562:     take: limit,
  563:     include: { startedBy: { select: { username: true } } }
  564:   })
  565: }
  566: 
  567: export async function getPluginTask(id: number) {
  568:   return await prisma.pluginInstallTask.findUnique({
  569:     where: { id },
  570:     include: { startedBy: { select: { username: true } } }
  571:   })
  572: }
