   64: function submissionToMarketEntry(submission: Awaited<ReturnType<typeof prisma.themeMarketSubmission.findMany>>[number], publicBaseUrl: string): ThemeMarketEntry {
   65:   const manifestUrl = submission.manifestUrl || `${publicBaseUrl}/manifests/${submission.themeId}/${submission.version}.json`
   66:   return {
   67:     id: submission.themeId,
   68:     name: submission.name,
   69:     latest: submission.version,
   70:     manifestUrl,
   71:     downloadUrl: submission.packageUrl,
   72:     sha256: submission.sha256,
   73:     description: submission.notes || undefined,
   74:     author: submission.developerName,
   75:     reviewStatus: 'listed',
   76:     trustLevel: submission.developerGithub ? 'verified' : 'third_party',
   77:     developer: {
