   14: 
   15: function isRecord(value: unknown): value is Record<string, unknown> {
   16:   return !!value && typeof value === 'object' && !Array.isArray(value)
   17: }
   18: 
   19: function pickString(value: unknown, fallback = ''): string {
   20:   return typeof value === 'string' && value.trim() ? value.trim() : fallback
   21: }
   22: 
   23: function pickStringArray(value: unknown): string[] {
   24:   return Array.isArray(value)
   25:     ? value.filter((item): item is string => typeof item === 'string' && item.trim().length > 0).map(item => item.trim())
   26:     : []
   27: }
