  188: 
  189: function normalizeCompatibility(input: unknown): PluginMarketCompatibility {
  190:   const record = isRecord(input) ? input : {}
  191:   return {
  192:     minPayincus: pickString(record.minPayincus, 64) ?? undefined,
  193:     maxPayincus: pickString(record.maxPayincus, 64) ?? undefined
  194:   }
  195: }
  196: 
  197: function normalizeSecurity(input: unknown): PluginMarketSecurity {
  198:   const record = isRecord(input) ? input : {}
  199:   const signature = isRecord(record.signature)
  200:     ? {
  201:         status: pickEnum(record.signature.status, ['unsigned', 'valid', 'missing', 'invalid'] as const, 'unsigned'),
  202:         algorithm: pickString(record.signature.algorithm, 60) ?? undefined,
  203:         keyId: pickString(record.signature.keyId, 120) ?? undefined
  204:       }
  205:     : { status: 'unsigned' as const }
  206:   return {
  207:     checksumPinned: pickBoolean(record.checksumPinned, true),
  208:     signature,
  209:     notes: pickStringArray(record.notes, 10, 240)
  210:   }
  211: }
  212: 
  213: function normalizePricing(input: unknown): PluginMarketPricing {
  214:   const record = isRecord(input) ? input : {}
  215:   const type = pickEnum(record.type, ['free', 'paid'] as const, 'free')
  216:   return {
  217:     type,
  218:     price: pickString(record.price, 60) ?? undefined,
  219:     currency: pickString(record.currency, 12) ?? undefined,
  220:     revenueSharePercent: record.revenueSharePercent === null
  221:       ? null
  222:       : pickNumber(record.revenueSharePercent, 0, 0, 100)
  223:   }
  224: }
  225: 
  226: function normalizeEntry(input: unknown, trustedHosts: Set<string>): PluginMarketEntry | null {
  227:   if (!isRecord(input)) return null
  228:   const id = pickString(input.id, 120)
  229:   const name = pickString(input.name, 120)
  230:   const latest = pickString(input.latest, 64)
  231:   const repo = pickString(input.repo, 160)
  232:   const manifestUrl = pickString(input.manifestUrl, 500)
  233:   const downloadUrl = pickString(input.downloadUrl, 500)
  234:   const sha256 = pickString(input.sha256, 64)
  235:   if (!id || !name || !latest || !repo || !manifestUrl || !downloadUrl || !sha256) return null
  236:   assertTrustedMarketUrl(manifestUrl, 'download', trustedHosts)
  237:   assertTrustedMarketUrl(downloadUrl, 'download', trustedHosts)
  238:   if (!/^[a-f0-9]{64}$/i.test(sha256)) return null
  239:   const reviewStatus = pickEnum(input.reviewStatus, ['pending', 'listed', 'delisted', 'rejected'] as const, 'pending')
  240:   const trustLevel = pickEnum(input.trustLevel, ['official', 'verified', 'third_party'] as const, 'third_party')
  241:   const author = pickString(input.author, 120) ?? undefined
  242:   return {
  243:     id,
  244:     name,
  245:     latest,
  246:     repo,
  247:     manifestUrl,
  248:     downloadUrl,
  249:     sha256: sha256.toLowerCase(),
  250:     description: pickString(input.description, 500) ?? undefined,
  251:     author,
  252:     reviewStatus,
  253:     trustLevel,
  254:     developer: normalizeDeveloper(input.developer, author || name),
  255:     permissions: normalizePermissions(input.permissions),
  256:     compatibility: normalizeCompatibility(input.compatibility),
  257:     security: normalizeSecurity(input.security),
  258:     pricing: normalizePricing(input.pricing),
  259:     rating: {
  260:       average: pickNumber(isRecord(input.rating) ? input.rating.average : undefined, 0, 0, 5),
  261:       count: Math.floor(pickNumber(isRecord(input.rating) ? input.rating.count : undefined, 0, 0, 1_000_000))
  262:     },
  263:     installCount: Math.floor(pickNumber(input.installCount, 0, 0, 1_000_000_000)),
  264:     releaseNotes: pickString(input.releaseNotes, 1000) ?? undefined,
  265:     upgradeNotes: pickString(input.upgradeNotes, 1000) ?? undefined,
  266:     rollbackNotes: pickString(input.rollbackNotes, 1000) ?? undefined
  267:   }
  268: }
  269: 
  270: function normalizeVersionParts(version: string | undefined): [number, number, number] | null {
  271:   if (!version) return null
  272:   const match = version.trim().match(/^v?(\d+)\.(\d+)\.(\d+)(?:[-+].*)?$/)
  273:   if (!match) return null
  274:   return [Number(match[1]), Number(match[2]), Number(match[3])]
  275: }
  276: 
  277: function compareVersions(left: string | undefined, right: string | undefined): number {
  278:   const a = normalizeVersionParts(left)
  279:   const b = normalizeVersionParts(right)
  280:   if (!a || !b) return 0
  281:   for (let index = 0; index < 3; index += 1) {
  282:     if (a[index] !== b[index]) return a[index] > b[index] ? 1 : -1
  283:   }
  284:   return 0
  285: }
  286: 
  287: function getMarketFingerprint(entries: PluginMarketEntry[]): string {
  288:   const stablePayload = entries.map(entry => ({
  289:     id: entry.id,
  290:     latest: entry.latest,
  291:     reviewStatus: entry.reviewStatus,
  292:     trustLevel: entry.trustLevel,
  293:     repo: entry.repo,
  294:     downloadUrl: entry.downloadUrl,
  295:     sha256: entry.sha256,
  296:     compatibility: entry.compatibility,
  297:     permissions: entry.permissions,
  298:     pricing: entry.pricing
  299:   }))
  300:   return createHash('sha256').update(JSON.stringify(stablePayload)).digest('hex')
  301: }
  302: 
  303: const PLUGIN_MARKET_INSTALL_POLICY = ['GitHub index only', 'listed entries only', 'GitHub release artifact only', 'SHA256 required']
  304: 
  305: export function buildUnavailablePluginMarketIndex(): PluginMarketIndex {
  306:   return {
  307:     plugins: [],
  308:     governance: {
  309:       totalEntries: 0,
  310:       visibleEntries: 0,
  311:       hiddenEntries: 0,
  312:       indexHost: null,
  313:       fingerprint: getMarketFingerprint([]),
  314:       defaultReviewStatus: 'pending',
  315:       installPolicy: PLUGIN_MARKET_INSTALL_POLICY,
  316:       unavailableReason: 'market_unavailable'
  317:     }
  318:   }
  319: }
  320: 
  321: export async function fetchPluginMarketIndex(url?: string | null): Promise<PluginMarketIndex> {
  322:   const effectiveUrl = url ?? await getPluginMarketIndexUrl()
  323:   if (!effectiveUrl) {
  324:     return buildUnavailablePluginMarketIndex()
  325:   }
  326:   const trustedHosts = await getPluginMarketTrustedHosts()
  327:   const parsed = assertGitHubIndexUrl(effectiveUrl, trustedHosts)
  328:   const response = await fetch(parsed, {
  329:     headers: { 'user-agent': 'payincus-plugin-center' }
  330:   })
  331:   if (!response.ok) {
  332:     throw new Error(`Failed to fetch plugin market index: HTTP ${response.status}`)
  333:   }
  334:   const payload: unknown = await response.json()
  335:   const normalized = isRecord(payload) && Array.isArray(payload.plugins)
  336:     ? payload.plugins.map(entry => normalizeEntry(entry, trustedHosts)).filter((entry): entry is PluginMarketEntry => !!entry)
  337:     : []
  338:   const plugins = normalized.filter(entry => entry.reviewStatus === 'listed')
  339:   return {
  340:     plugins,
  341:     governance: {
  342:       totalEntries: normalized.length,
  343:       visibleEntries: plugins.length,
  344:       hiddenEntries: normalized.length - plugins.length,
  345:       indexHost: parsed.hostname,
  346:       fingerprint: getMarketFingerprint(normalized),
  347:       defaultReviewStatus: 'pending',
  348:       installPolicy: PLUGIN_MARKET_INSTALL_POLICY
  349:     }
  350:   }
  351: }
  352: 
  353: export async function assertMarketEntryInstallable(entry: PluginMarketEntry): Promise<void> {
  354:   if (entry.reviewStatus !== 'listed') {
  355:     throw new Error('Plugin market entry is not listed for installation')
  356:   }
  357:   if (!entry.security.checksumPinned) {
  358:     throw new Error('Plugin market entry must pin a SHA256 checksum')
  359:   }
  360:   if (!/^[a-f0-9]{64}$/i.test(entry.sha256)) {
  361:     throw new Error('Plugin market entry has an invalid SHA256 checksum')
  362:   }
  363:   const current = await getCurrentVersionMetadata()
  364:   const currentVersion = current.gitTag || current.version
  365:   if (entry.compatibility.minPayincus && compareVersions(currentVersion, entry.compatibility.minPayincus) < 0) {
  366:     throw new Error(`Plugin requires PayIncus ${entry.compatibility.minPayincus} or later`)
  367:   }
  368:   if (entry.compatibility.maxPayincus && compareVersions(currentVersion, entry.compatibility.maxPayincus) > 0) {
  369:     throw new Error(`Plugin supports PayIncus up to ${entry.compatibility.maxPayincus}`)
  370:   }
  371: }
  372: 
  373: export async function downloadMarketPlugin(entry: PluginMarketEntry): Promise<string> {
  374:   await assertMarketEntryInstallable(entry)
  375:   await assertGitHubReleaseUrl(entry.downloadUrl)
  376:   const response = await fetch(entry.downloadUrl, {
  377:     headers: { 'user-agent': 'payincus-plugin-center' }
  378:   })
  379:   if (!response.ok) {
  380:     throw new Error(`Failed to download plugin package: HTTP ${response.status}`)
  381:   }
  382:   const arrayBuffer = await response.arrayBuffer()
  383:   const buffer = Buffer.from(arrayBuffer)
  384:   const actualSha256 = createHash('sha256').update(buffer).digest('hex')
  385:   if (actualSha256 !== entry.sha256.toLowerCase()) {
  386:     throw new Error('Plugin package SHA256 mismatch')
  387:   }
  388:   const dir = join(getPluginStagingDir(), 'downloads')
  389:   await mkdir(dir, { recursive: true })
  390:   const path = join(dir, `${entry.id}-${entry.latest}-${randomUUID()}.tar.gz`)
  391:   await writeFile(path, buffer, { mode: 0o600 })
  392:   return path
  393: }

