   15: function isRecord(value: unknown): value is Record<string, unknown> {
   16:   return !!value && typeof value === 'object' && !Array.isArray(value)
   17: }
   18: 
   19: function pickString(value: unknown, fallback = ''): string {
   20:   return typeof value === 'string' && value.trim() ? value.trim() : fallback
   21: }
   22: 
   23: function pickStringArray(value: unknown): string[] {
   24:   return Array.isArray(value)
   25:     ? value.filter((item): item is string => typeof item === 'string' && item.trim().length > 0).map(item => item.trim())
   26:     : []
   27: }
   28: 
   29: function normalizeCompatibility(value: unknown): ThemeMarketEntry['compatibility'] {
   30:   const record = isRecord(value) ? value : {}
   31:   return {
   32:     minPayincus: pickString(record.minPayincus) || undefined,
   33:     maxPayincus: pickString(record.maxPayincus) || undefined
   34:   }
   35: }
   36: 
   37: function getScanNotes(scanResult: unknown, riskLevel: string): string[] {
   38:   const notes = [`Theme submission scan risk level: ${riskLevel}`]
   39:   if (!isRecord(scanResult)) return notes
   40:   const status = pickString(scanResult.status)
   41:   if (status) notes.push(`Theme submission scan status: ${status}`)
   42:   const findings = Array.isArray(scanResult.findings) ? scanResult.findings : []
   43:   for (const finding of findings.slice(0, 5)) {
   44:     if (!isRecord(finding)) continue
   45:     const code = pickString(finding.code)
   46:     const message = pickString(finding.message)
   47:     if (code || message) notes.push(`${code || 'finding'}: ${message}`)
   48:   }
   49:   return notes
   50: }
