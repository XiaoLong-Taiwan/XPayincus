   79:       homepage: submission.developerHomepage || undefined,
   80:       github: submission.developerGithub || undefined,
   81:       verified: Boolean(submission.developerGithub),
   82:       contact: submission.contactEmail
   83:     },
   84:     compatibility: normalizeCompatibility(submission.compatibility),
   85:     security: {
   86:       checksumPinned: true,
   87:       signature: { status: 'unsigned' },
   88:       notes: getScanNotes(submission.scanResult, submission.riskLevel)
