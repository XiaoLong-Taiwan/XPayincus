  178: 
  179: function normalizePermissions(input: unknown): PluginMarketPermissions {
  180:   const record = isRecord(input) ? input : {}
  181:   return {
  182:     adminPages: pickStringArray(record.adminPages, 30, 160),
  183:     userPages: pickStringArray(record.userPages, 30, 160),
  184:     api: pickStringArray(record.api, 80, 160),
  185:     storage: pickStringArray(record.storage, 30, 160)
