   92:     rating: { average: 0, count: 0 },
   93:     installCount: 0,
   94:     releaseNotes: submission.notes || undefined,
   95:     rollbackNotes: 'Disable the theme or roll back to the default theme from the extension center.'
   96:   }
   97: }
