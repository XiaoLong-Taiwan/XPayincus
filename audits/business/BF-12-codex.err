  111:   fastify.get('/:themeId/config-files/:key/:filename', async (request: FastifyRequest, reply: FastifyReply) => {
  112:     const params = request.params as { themeId?: string; key?: string; filename?: string }
  113:     const themeId = params.themeId ? normalizeThemeId(params.themeId) : null
  114:     const key = params.key ? normalizeThemeConfigKey(params.key) : null
  115:     const filename = params.filename ? normalizeThemeConfigFilename(params.filename) : null
  116:     if (!themeId || !key || !filename) {
  117:       return reply.code(400).send({ error: 'Invalid theme config file path', code: 'INVALID_THEME_CONFIG_FILE_PATH' })
  118:     }
  119:     const theme = await getActiveThemePackage()
  120:     if (!theme || theme.themeId !== themeId || !theme.enabled) {
  121:       return reply.code(404).send({ error: 'Theme config file not found', code: 'THEME_CONFIG_FILE_NOT_FOUND' })
  122:     }
  123:     const manifest = theme.manifest as unknown as PayIncusThemeManifest
  124:     const configValues = theme.configValues as Record<string, unknown>
  125:     const field = manifest.configSchema?.[key]
  126:     if (!field || field.type !== 'file') {
  127:       return reply.code(404).send({ error: 'Theme config file not found', code: 'THEME_CONFIG_FILE_NOT_FOUND' })
  128:     }
  129:     const expectedValue = `/api/themes/${encodeURIComponent(themeId)}/config-files/${encodeURIComponent(key)}/${encodeURIComponent(filename)}`
  130:     if (configValues[key] !== expectedValue) {
  131:       return reply.code(404).send({ error: 'Theme config file not found', code: 'THEME_CONFIG_FILE_NOT_FOUND' })
  132:     }
  133:     try {
  134:       const filePath = resolveThemeAsset(getThemeDataDir(), join('config-files', themeId, key, filename))
  135:       const body = await readFile(filePath)
  136:       reply
  137:         .type(contentTypeForPath(filename))
  138:         .header('Cache-Control', 'public, max-age=300')
  139:         .header('Referrer-Policy', 'same-origin')
  140:         .header('X-Content-Type-Options', 'nosniff')
  141:         .header('X-Robots-Tag', 'noindex')
  142:         .send(body)
  143:     } catch {
  144:       return reply.code(404).send({ error: 'Theme config file not found', code: 'THEME_CONFIG_FILE_NOT_FOUND' })
  145:     }
  146:   })
  147: 
  148:   fastify.get<{ Params: { themeId: string } }>('/preview/:themeId', async (request, reply) => {
  149:     const themeId = normalizeThemeId(request.params.themeId)
  150:     if (!themeId) return reply.code(400).send({ error: 'Invalid theme id', code: 'INVALID_THEME_ID' })
  151:     const theme = await getThemePackage(themeId)
  152:     if (!theme) return reply.code(404).send({ error: 'Theme not found', code: 'THEME_NOT_FOUND' })
  153:     const serialized = serializeThemePackage(theme)
  154:     reply
  155:       .type('text/html; charset=utf-8')
  156:       .header('Cache-Control', 'private, no-store')
  157:       .header('X-Robots-Tag', 'noindex')
  158:       .send(previewHtml({
  159:         name: serialized.name,
  160:         themeId: serialized.themeId,
  161:         version: serialized.version,
