  611:     const baseWhere = {
  612:       action: 'plugin.event.dispatch',
  613:       ...(pluginId ? { pluginId } : {}),
  614:       ...(eventName ? { eventName } : {}),
  615:       ...(handler ? { handler: { contains: handler } } : {})
