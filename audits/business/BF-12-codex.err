  628:       prisma.pluginEventLog.count({ where: baseWhere }),
  629:       prisma.pluginEventLog.count({ where: { ...baseWhere, result: 'success' } }),
  630:       prisma.pluginEventLog.count({ where: { ...baseWhere, result: 'failed' } }),
  631:       prisma.pluginEventLog.count({ where: { ...baseWhere, result: 'retry_pending' } }),
