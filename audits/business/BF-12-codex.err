   99: async function readExistingMarketEntries(indexPath: string): Promise<ThemeMarketEntry[]> {
  100:   try {
  101:     const payload = JSON.parse(await readFile(indexPath, 'utf8')) as unknown
  102:     if (!isRecord(payload) || !Array.isArray(payload.themes)) return []
  103:     return payload.themes.filter((entry): entry is ThemeMarketEntry => isRecord(entry) && typeof entry.id === 'string')
  104:   } catch {
  105:     return []
  106:   }
  107: }
  108: 
  109: export async function publishThemeMarketIndex(): Promise<ThemeMarketPublishResult> {
  110:   const publishDir = getThemeMarketPublishDir()
  111:   const indexPath = join(publishDir, 'index.json')
  112:   const [existingEntries, listedSubmissions, publicBaseUrl] = await Promise.all([
  113:     readExistingMarketEntries(indexPath),
  114:     prisma.themeMarketSubmission.findMany({
  115:       where: {
  116:         reviewStatus: 'listed',
  117:         scanStatus: { in: ['passed', 'warning'] }
  118:       },
  119:       orderBy: [{ themeId: 'asc' }, { version: 'desc' }]
  120:     }),
  121:     getThemeMarketPublicBaseUrl()
  122:   ])
  123: 
  124:   const entriesById = new Map<string, ThemeMarketEntry>()
  125:   for (const entry of existingEntries) {
  126:     entriesById.set(entry.id, entry)
  127:   }
  128:   for (const submission of listedSubmissions) {
  129:     entriesById.set(submission.themeId, submissionToMarketEntry(submission, publicBaseUrl))
  130:   }
  131: 
  132:   const updatedAt = new Date().toISOString()
  133:   const themes = Array.from(entriesById.values()).sort((left, right) => left.id.localeCompare(right.id))
  134:   const fingerprint = createHash('sha256').update(JSON.stringify(themes.map(entry => ({
  135:     id: entry.id,
  136:     latest: entry.latest,
  137:     reviewStatus: entry.reviewStatus,
  138:     downloadUrl: entry.downloadUrl,
  139:     sha256: entry.sha256,
  140:     compatibility: entry.compatibility,
  141:     tokens: entry.tokens,
  142:     layoutSlots: entry.layoutSlots
  143:   })))).digest('hex')
  144: 
  145:   const index: ThemeMarketIndex & { version: number; updatedAt: string } = {
  146:     version: 1,
  147:     updatedAt,
  148:     themes,
  149:     governance: {
  150:       totalEntries: entriesById.size,
  151:       visibleEntries: entriesById.size,
  152:       hiddenEntries: 0,
  153:       indexHost: null,
  154:       fingerprint,
  155:       defaultReviewStatus: 'pending',
  156:       installPolicy: ['listed entries only', 'SHA256 required', 'theme submission scan required before publishing']
  157:     }
  158:   }
  159: 
  160:   await mkdir(dirname(indexPath), { recursive: true })
  161:   await writeFile(indexPath, `${JSON.stringify(index, null, 2)}\n`, 'utf8')
  162:   return {
  163:     indexPath,
  164:     publishedEntries: listedSubmissions.length,
  165:     totalEntries: index.themes.length,
  166:     updatedAt
  167:   }
  168: }

