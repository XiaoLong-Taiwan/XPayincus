  118: function compareManifestToSubmission(
  119:   manifest: PayIncusPluginManifest,
  120:   input: PluginSubmissionScanInput,
  121:   findings: PluginSubmissionScanFinding[]
  122: ) {
  123:   if (manifest.id !== input.pluginId) {
  124:     pushFinding(findings, 'error', 'manifest_id_mismatch', `Manifest id ${manifest.id} does not match submitted id ${input.pluginId}`)
  125:   }
  126:   if (manifest.version !== input.version) {
  127:     pushFinding(findings, 'error', 'manifest_version_mismatch', `Manifest version ${manifest.version} does not match submitted version ${input.version}`)
  128:   }
  129:   if (manifest.name !== input.name) {
  130:     pushFinding(findings, 'warning', 'manifest_name_mismatch', `Manifest name ${manifest.name} differs from submitted name ${input.name}`)
  131:   }
  132: }
  133: 
  134: function collectDeclaredPermissions(manifest: PayIncusPluginManifest, submittedPermissions: unknown): string[] {
  135:   const permissions = new Set<string>(manifest.permissions || [])
  136:   if (isRecord(submittedPermissions)) {
  137:     for (const value of Object.values(submittedPermissions)) {
  138:       if (Array.isArray(value)) {
  139:         for (const item of value) {
  140:           if (typeof item === 'string' && item.trim()) permissions.add(item.trim())
  141:         }
  142:       }
  143:     }
  144:   }
  145:   return Array.from(permissions).sort()
  146: }
  147: 
  148: function assessRisk(
  149:   manifest: PayIncusPluginManifest,
  150:   submittedPermissions: unknown,
  151:   findings: PluginSubmissionScanFinding[]
  152: ): PluginMarketSubmissionRiskLevel {
  153:   const permissions = collectDeclaredPermissions(manifest, submittedPermissions)
  154:   let risk: PluginMarketSubmissionRiskLevel = 'low'
  155: 
  156:   for (const permission of permissions) {
  157:     if (HIGH_RISK_PERMISSION_PATTERNS.some(pattern => pattern.test(permission))) {
  158:       risk = 'high'
  159:       pushFinding(findings, 'warning', 'high_risk_permission', `High-risk permission declared: ${permission}`)
  160:     } else if (WARNING_PERMISSION_PATTERNS.some(pattern => pattern.test(permission)) && risk === 'low') {
  161:       risk = 'medium'
  162:     }
  163:   }
  164: 
  165:   if ((manifest.capabilities?.actions || []).length > 0) {
  166:     risk = risk === 'low' ? 'medium' : risk
  167:     pushFinding(findings, 'info', 'webhook_actions_declared', 'Manifest declares webhook actions')
  168:   }
  169:   if ((manifest.capabilities?.events || []).length > 0) {
  170:     risk = risk === 'low' ? 'medium' : risk
  171:     pushFinding(findings, 'info', 'event_subscriptions_declared', 'Manifest declares event subscriptions')
  172:   }
  173:   if (manifest.capabilities?.storage) {
  174:     risk = risk === 'low' ? 'medium' : risk
  175:     pushFinding(findings, 'info', 'storage_declared', 'Manifest declares extension storage')
  176:   }
  177: 
  178:   return risk
  179: }
  180: 
  181: function scanStatusFromFindings(findings: PluginSubmissionScanFinding[]): PluginSubmissionScanStatus {
  182:   if (findings.some(finding => finding.severity === 'error')) return 'failed'
  183:   if (findings.some(finding => finding.severity === 'warning')) return 'warning'
  184:   return 'passed'
  185: }
