   2:   "id": "com.example.coupon",
   3:   "name": "Coupon Example",
   4:   "version": "1.0.0",
   5:   "payincus": ">=0.0.12",
   6:   "description": "A mixed plugin with admin settings and a user-facing coupon page.",
   7:   "author": "Example",
   8:   "entrypoints": {
   9:     "adminPages": [
  10:       {
  11:         "slot": "admin.plugins.settings",
  12:         "title": "Coupon Settings",
  13:         "entry": "dist/admin/settings.html"
  14:       }
  15:     ],
  16:     "userPages": [
  17:       {
  18:         "slot": "user.sidebar.extra",
  19:         "title": "My Coupons",
  20:         "path": "/plugins/coupons",
  21:         "entry": "dist/user/coupons.html",
  22:         "requiresAuth": true
  23:       },
  24:       {
  25:         "slot": "user.dashboard.cards",
  26:         "title": "Coupon Summary",
  27:         "path": "/plugins/coupons",
  28:         "entry": "dist/user/coupons.html",
  29:         "requiresAuth": true
  30:       }
  31:     ]
  32:   },
  33:   "permissions": ["plugin:config:read", "plugin:config:write", "billing:discount:apply"],
  34:   "configSchema": {
  35:     "enabled": {
  36:       "type": "checkbox",
  37:       "label": "Enable coupons",
  38:       "group": "Coupon",
  39:       "order": 10,
  40:       "required": false,
  41:       "default": false
  42:     },
  43:     "maxDiscount": {
  44:       "type": "number",
  45:       "label": "Maximum discount",
  46:       "group": "Coupon",
  47:       "order": 20,
  48:       "required": true,
  49:       "default": 20,
  50:       "min": 1,
  51:       "max": 100,
  52:       "step": 1
  53:     }
  54:   },
  55:   "templates": [
  56:     {
  57:       "name": "Default coupon config",
  58:       "path": "templates/default-config.json"
  59:     }
  60:   ]
  61: }
