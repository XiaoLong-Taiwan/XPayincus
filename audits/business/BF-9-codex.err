 740:   // ç®¡ç†å‘˜é€€è®¢ï¼ˆåˆ é™¤è®¢é˜…ï¼‰
 741:   fastify.post<{
 742:     Params: { id: string }
 743:     Body: {
 744:       refundType: 'none' | 'full' | 'remaining'
 745:       reason?: string
 746:     }
 747:   }>('/admin/subscriptions/:id/cancel', {
 748:     onRequest: [fastify.authenticate, fastify.requireAdmin]
 749:   }, async (request, reply) => {
 750:     const subscriptionId = parsePositiveRouteId(request.params.id)
 751:     const { refundType, reason } = normalizeMailSubscriptionCancelInput(request.body)
 752: 
 753:     // èŽ·å–è®¢é˜…è¯¦æƒ…ï¼ˆåŒ…å«åŸŸåå’Œ sourceï¼‰
 754:     const subscription = await prisma.mailSubscription.findUnique({
 755:       where: { id: subscriptionId },
 756:       include: {
 757:         user: { select: { id: true, username: true, balance: true } },
 758:         plan: true,
 759:         source: true,
 760:         domains: true
 761:       }
 762:     })
 763: 
 764:     if (!subscription) {
 765:       return reply.code(404).send(apiError(ErrorCode.NOT_FOUND, 'è®¢é˜…ä¸å­˜åœ¨'))
 766:     }
 767: 
 768:     const source = await db.getMailSourceById(subscription.sourceId)
 769:     if (!source) {
 770:       return reply.code(404).send(apiError(ErrorCode.NOT_FOUND, 'é‚®ç®±æºä¸å­˜åœ¨'))
 771:     }
 772: 
 773:     // è®¡ç®—é€€æ¬¾é‡‘é¢
 774:     let refundAmount = 0
 775:     const planPrice = Number(subscription.plan.price)
 776: 
 777:     if (refundType === 'full') {
 778:       refundAmount = planPrice
 779:     } else if (refundType === 'remaining') {
 780:       const now = new Date()
 781:       const expiresAt = new Date(subscription.expiresAt)
 782:       if (expiresAt > now) {
 783:         const totalMs = subscription.plan.billingCycle === 'monthly'
 784:           ? 30 * 24 * 60 * 60 * 1000
 785:           : 365 * 24 * 60 * 60 * 1000
 786:         const remainingMs = expiresAt.getTime() - now.getTime()
 787:         const ratio = Math.min(remainingMs / totalMs, 1)
 788:         refundAmount = Number((planPrice * ratio).toFixed(2))
 789:       }
 790:       // å·²è¿‡æœŸåˆ™å‰©ä½™ä»·å€¼ä¸º 0
 791:     }
 792: 
 793:     // åˆ é™¤ CraneMail åŸŸåã€‚è¿œç«¯åˆ é™¤å¤±è´¥æ—¶ä¸èƒ½åˆ é™¤æœ¬åœ°è®¢é˜…ï¼Œå¦åˆ™ä¼šéšè—æ®‹ç•™èµ„æºã€‚
 794:     for (const domain of subscription.domains) {
 795:       try {
 796:         await craneMailService.deleteDomain(source, domain.domain)
 797:       } catch (err: any) {
 798:         console.error(`[AdminMailCancel] Failed to delete domain ${domain.domain} from CraneMail:`, err.message)
 799:         return reply.code(502).send(apiError(ErrorCode.UPSTREAM_ERROR, `åˆ é™¤è¿œç«¯åŸŸå ${domain.domain} å¤±è´¥: ${err.message}`))
 800:       }
 801:     }
 802: 
 803:     // DB äº‹åŠ¡ï¼šé€€æ¬¾ + åˆ é™¤è®¢é˜…
 804:     await prisma.$transaction(async (tx) => {
 805:       if (refundAmount > 0) {
 806:         const balanceLocked = await tryAdvisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, subscription.user.id)
 807:         if (!balanceLocked) {
 808:           throw apiError(ErrorCode.OPERATION_NOT_ALLOWED, 'ç”¨æˆ·ä½™é¢æ­£åœ¨å¤„ç†ï¼Œè¯·ç¨åŽé‡è¯•')
 809:         }
 810: 
 811:         const currentUser = await tx.user.findUnique({
 812:           where: { id: subscription.user.id },
 813:           select: { balance: true }
 814:         })
 815:         const oldBalance = Number(currentUser?.balance || 0)
 816: 
 817:         const updatedUser = await tx.user.update({
 818:           where: { id: subscription.user.id },
 819:           data: { balance: { increment: refundAmount } },
 820:           select: { balance: true }
 821:         })
 822:         const newBalance = Number(updatedUser.balance)
 823: 
 824:         await tx.balanceLog.create({
 825:           data: {
 826:             userId: subscription.user.id,
 827:             type: 'refund',
 828:             amount: refundAmount,
 829:             balanceBefore: oldBalance,
 830:             balanceAfter: newBalance,
 831:             remark: `ç®¡ç†å‘˜é€€è®¢é‚®ç®± - ${subscription.plan.name}ï¼ˆ${refundType === 'full' ? 'å…¨é¢é€€æ¬¾' : 'å‰©ä½™ä»·å€¼é€€æ¬¾'}ï¼‰åŽŸå› ï¼š${reason}`
 832:           }
 833:         })
 834:       }
 835: 
 836:       // åˆ é™¤è®¢é˜…ï¼ˆcascade åˆ é™¤åŸŸåã€è´¦æˆ·ã€AFF ç»‘å®šï¼‰
 837:       await tx.mailSubscription.delete({
 838:         where: { id: subscriptionId }
 839:       })
 840:     })
 841: 
 842:     await createLog(
 843:       request.user.id,
 844:       'mail',
 845:       'admin_cancel_mail_subscription',
 846:       `Admin cancelled mail subscription #${subscriptionId} for user ${subscription.user.username} (refund: ${refundType}, amount: ${refundAmount})`,
 847:       'success'
 848:     )
 849: 
 850:     return {
 851:       success: true,
 852:       refundAmount,
 853:       refundType
 854:     }
 855:   })
