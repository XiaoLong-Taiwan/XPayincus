 743:  */
 744: export async function getExpiringSubscriptions(daysAhead: number): Promise<MailSubscription[]> {
 745:   const deadline = new Date()
 746:   deadline.setDate(deadline.getDate() + daysAhead)
 747:   
 748:   return prisma.mailSubscription.findMany({
 749:     where: {
 750:       status: 'active',
 751:       autoRenew: true,
 752:       expiresAt: { lte: deadline }
 753:     }
 754:   })
 755: }

