 225: /**
 226:  * èŽ·å–åŸŸä¸‹æ‰€æœ‰è´¦æˆ·
 227:  */
 228: export async function listAccounts(
 229:   source: MailSource,
 230:   domain: string,
 231:   adminUsername: string,
 232:   adminPassword: string
 233: ): Promise<Array<{
 234:   username: string
 235:   email: string
