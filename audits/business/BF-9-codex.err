 334: export async function getUserMailSubscription(userId: number): Promise<(MailSubscription & {
 335:   source: MailSource
 336:   plan: MailPlan
 337:   domains: MailDomain[]
 338: }) | null> {
 339:   const subscription = await prisma.mailSubscription.findFirst({
 340:     where: { userId, status: 'active' },
 341:     include: {
 342:       source: true,
 343:       plan: true,
 344:       domains: {
 345:         include: { accounts: true }
 346:       }
 347:     }
 348:   })
 349:   return subscription ? withDecryptedSource(subscription) : null
