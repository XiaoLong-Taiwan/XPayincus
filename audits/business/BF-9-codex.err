 215:       displayName: result.userData.displayName || result.userData.userName,
 216:       diskLimitMb: result.userData.maxMailboxSize || 0,
 217:       diskUsedMb: result.userData.mailboxSizeUsed || 0,
 218:       isEnabled: result.userData.isEnabled !== false
 219:     }
 220:   } catch {
 221:     return null
 222:   }
