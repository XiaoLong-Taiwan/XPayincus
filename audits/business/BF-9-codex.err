 735:     domainCount: domains.length,
 736:     accountCount: domains.reduce((sum, d) => sum + d._count.accounts, 0),
 737:     diskUsedMb: domains.reduce((sum, d) => sum + d.diskUsedMb, 0)
 738:   }
 739: }
