 250:     diskLimitMb: user.maxMailboxSize || 0,
 251:     diskUsedMb: user.mailboxSizeUsed || 0
 252:   }))
 253: }
###FILE:server/src/services/mail-expiry-scheduler.ts
   1: /**
   2:  * é‚®ç®±è®¢é˜…è¿‡æœŸæ£€æŸ¥å®šæ—¶ä»»åŠ¡
   3:  * æ£€æŸ¥å¹¶å¤„ç†å·²è¿‡æœŸçš„é‚®ç®±è®¢é˜…
   4:  */
   5: 
   6: import { prisma } from '../db/prisma.js'
   7: 
   8: let schedulerInterval: NodeJS.Timeout | null = null
   9: 
  10: /**
  11:  * æ£€æŸ¥å¹¶æ›´æ–°è¿‡æœŸçš„é‚®ç®±è®¢é˜…
  12:  */
  13: export async function checkMailSubscriptionExpiry(): Promise<void> {
  14:   const now = new Date()
  15:   
  16:   try {
  17:     // æŸ¥æ‰¾æ‰€æœ‰å·²è¿‡æœŸä½†çŠ¶æ€ä»ä¸º active çš„è®¢é˜…
  18:     const expiredSubscriptions = await prisma.mailSubscription.findMany({
  19:       where: {
  20:         status: 'active',
  21:         expiresAt: { lt: now }
  22:       },
  23:       select: {
  24:         id: true,
  25:         userId: true,
  26:         expiresAt: true,
  27:         user: { select: { username: true } }
  28:       }
  29:     })
  30: 
  31:     if (expiredSubscriptions.length === 0) {
  32:       return
  33:     }
  34: 
  35:     console.log(`[Mail] Found ${expiredSubscriptions.length} expired mail subscription candidate(s)`)
  36: 
  37:     // æ‰¹é‡æ›´æ–°çŠ¶æ€ä¸º expiredã€‚ç»­è´¹å¯èƒ½åœ¨ findMany åŽå‘ç”Ÿï¼Œæ‰€ä»¥æ›´æ–°æ—¶å¿…é¡»é‡æŸ¥ expiresAtã€‚
  38:     const result = await prisma.mailSubscription.updateMany({
  39:       where: {
  40:         id: { in: expiredSubscriptions.map(s => s.id) },
  41:         status: 'active',
  42:         expiresAt: { lt: now }
  43:       },
  44:       data: { status: 'expired' }
  45:     })
  46: 
  47:     console.log(`[Mail] Updated ${result.count} mail subscriptions to expired status`)
  48:   } catch (error) {
  49:     console.error('[Mail] Error checking mail subscription expiry:', error)
  50:     throw error
  51:   }
  52: }
  53: 
  54: /**
  55:  * å¯åŠ¨é‚®ç®±è®¢é˜…è¿‡æœŸæ£€æŸ¥å®šæ—¶ä»»åŠ¡
  56:  * æ¯å°æ—¶æ‰§è¡Œä¸€æ¬¡
  57:  */
  58: export function startMailExpiryScheduler(): NodeJS.Timeout {
  59:   if (schedulerInterval) {
  60:     return schedulerInterval
  61:   }
  62: 
  63:   const INTERVAL = 60 * 60 * 1000 // 1 å°æ—¶
  64: 
  65:   console.log('[Mail] Starting mail subscription expiry scheduler')
  66: 
  67:   // å¯åŠ¨æ—¶ç«‹å³æ‰§è¡Œä¸€æ¬¡
  68:   checkMailSubscriptionExpiry().catch(err => {
  69:     console.error('[Mail] Initial mail expiry check failed:', err)
  70:   })
  71: 
  72:   // è®¾ç½®å®šæ—¶æ‰§è¡Œ
  73:   schedulerInterval = setInterval(() => {
  74:     checkMailSubscriptionExpiry().catch(err => {
  75:       console.error('[Mail] Scheduled mail expiry check failed:', err)
  76:     })
  77:   }, INTERVAL)
  78: 
  79:   return schedulerInterval
  80: }
###FILE:server/src/db/mail.ts
   1: /**
   2:  * åŸŸåé‚®ç®±æ¨¡å—æ•°æ®åº“æ“ä½œ
   3:  * åŒ…å«é‚®ç®±æºã€å¥—é¤æ–¹æ¡ˆã€è®¢é˜…ã€åŸŸåã€è´¦æˆ·çš„ CRUD æ“ä½œ
   4:  */
   5: 
   6: import { prisma } from './prisma.js'
   7: import type { MailSource, MailPlan, MailSubscription, MailDomain, MailAccount, MailBillingCycle, MailDomainStatus, MailSubscriptionStatus, Prisma } from '@prisma/client'
   8: import { decryptSensitiveData, encryptSensitiveData, isEncrypted } from '../lib/security.js'
   9: 
  10: export const MASKED_MAIL_SOURCE_API_KEY_VALUE = '__SECRET_SET__'
  11: 
  12: const MAIL_LIST_SEARCH_MAX_LENGTH = 128
  13: const MAIL_LIST_MAX_PAGE_SIZE = 100
  14: const MAIL_SUBSCRIPTION_STATUSES = new Set<MailSubscriptionStatus>(['active', 'expired', 'suspended'])
  15: const MAIL_DOMAIN_STATUSES = new Set<MailDomainStatus>(['pending', 'verified', 'suspended'])
  16: 
  17: function clampMailListPagination(page: number | undefined, pageSize: number | undefined): {
  18:   page: number
  19:   pageSize: number
  20: } {
  21:   return {
  22:     page: Number.isInteger(page) && page !== undefined && page > 0 ? page : 1,
  23:     pageSize: Number.isInteger(pageSize) && pageSize !== undefined
  24:       ? Math.min(Math.max(pageSize, 1), MAIL_LIST_MAX_PAGE_SIZE)
  25:       : 20
  26:   }
  27: }
  28: 
  29: function normalizeMailListSearch(search: string | undefined): string | undefined {
  30:   const trimmed = search?.trim()
  31:   return trimmed ? trimmed.slice(0, MAIL_LIST_SEARCH_MAX_LENGTH) : undefined
  32: }
  33: 
  34: function parseMailSearchUserId(searchTerm: string | undefined): number | undefined {
  35:   if (!searchTerm || !/^\d+$/.test(searchTerm)) {
  36:     return undefined
  37:   }
  38: 
  39:   const id = Number(searchTerm)
  40:   return Number.isSafeInteger(id) && id > 0 ? id : undefined
  41: }
  42: 
  43: function normalizePositiveMailSourceId(sourceId: number | undefined): number | undefined {
  44:   return Number.isSafeInteger(sourceId) && sourceId !== undefined && sourceId > 0
  45:     ? sourceId
  46:     : undefined
  47: }
  48: 
  49: function normalizeMailSubscriptionStatus(status: MailSubscriptionStatus | string | undefined): MailSubscriptionStatus | undefined {
  50:   return MAIL_SUBSCRIPTION_STATUSES.has(status as MailSubscriptionStatus)
  51:     ? status as MailSubscriptionStatus
  52:     : undefined
  53: }
  54: 
  55: function normalizeMailDomainStatus(status: MailDomainStatus | string | undefined): MailDomainStatus | undefined {
  56:   return MAIL_DOMAIN_STATUSES.has(status as MailDomainStatus)
  57:     ? status as MailDomainStatus
  58:     : undefined
  59: }
  60: 
  61: function decryptMailSecret(value: string): string {
  62:   if (!value) return value
  63:   return isEncrypted(value) ? (decryptSensitiveData(value) || value) : value
  64: }
  65: 
  66: function encryptMailSecret(value: string): string {
  67:   return isEncrypted(value) ? value : encryptSensitiveData(value)
  68: }
  69: 
  70: function decryptMailSource<T extends MailSource>(source: T): T {
  71:   return { ...source, apiKey: decryptMailSecret(source.apiKey) }
  72: }
  73: 
  74: function decryptMailDomainAdminPassword<T extends { adminPassword: string | null }>(domain: T): T {
  75:   return {
  76:     ...domain,
  77:     adminPassword: domain.adminPassword ? decryptMailSecret(domain.adminPassword) : domain.adminPassword
  78:   }
  79: }
  80: 
  81: function withDecryptedSource<T extends { source: MailSource }>(record: T): T {
  82:   return { ...record, source: decryptMailSource(record.source) }
  83: }
  84: 
  85: function withDecryptedDomainSource<T extends { source: MailSource; adminPassword: string | null }>(record: T): T {
  86:   return withDecryptedSource(decryptMailDomainAdminPassword(record))
  87: }
  88: 
  89: export function sanitizeMailSourceForResponse<T extends MailSource>(
  90:   source: T
  91: ): Omit<T, 'apiKey'> & { apiKey: string; apiKeyConfigured: boolean } {
  92:   return {
  93:     ...source,
  94:     apiKey: '',
  95:     apiKeyConfigured: Boolean(source.apiKey)
  96:   }
  97: }
  98: 
  99: export function sanitizeMailPlanForResponse<T extends { source: MailSource }>(
 100:   plan: T
 101: ): Omit<T, 'source'> & { source: ReturnType<typeof sanitizeMailSourceForResponse> } {
 102:   return {
 103:     ...plan,
 104:     source: sanitizeMailSourceForResponse(plan.source)
 105:   }
 106: }
 107: 
 108: export function sanitizeMailSubscriptionForResponse<T extends { source: MailSource }>(
 109:   subscription: T
 110: ): Omit<T, 'source'> & { source: ReturnType<typeof sanitizeMailSourceForResponse> } {
 111:   return {
 112:     ...subscription,
 113:     source: sanitizeMailSourceForResponse(subscription.source)
 114:   }
 115: }
 116: 
 117: export function sanitizeMailDomainForResponse<T extends { source: MailSource; adminPassword: string | null }>(
 118:   domain: T
 119: ): Omit<T, 'source' | 'adminPassword'> & {
 120:   source: ReturnType<typeof sanitizeMailSourceForResponse>
 121:   adminPassword: string
 122:   adminPasswordConfigured: boolean
 123: } {
 124:   return {
 125:     ...domain,
 126:     source: sanitizeMailSourceForResponse(domain.source),
 127:     adminPassword: '',
 128:     adminPasswordConfigured: Boolean(domain.adminPassword)
 129:   }
 130: }
 131: 
 132: export function mergeMailSourceApiKeyForUpdate(nextApiKey: string | null | undefined): string | undefined {
 133:   if (
 134:     nextApiKey === undefined ||
 135:     nextApiKey === null ||
 136:     nextApiKey === '' ||
 137:     nextApiKey === MASKED_MAIL_SOURCE_API_KEY_VALUE ||
 138:     nextApiKey.startsWith('***')
 139:   ) {
 140:     return undefined
 141:   }
 142:   return nextApiKey
 143: }
