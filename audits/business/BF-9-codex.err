 334: function normalizeMailSubscriptionCancelInput(input: unknown): MailSubscriptionCancelInput {
 335:   if (!isPlainRecord(input)) {
 336:     throw apiError(ErrorCode.VALIDATION_ERROR, 'è¯·æ±‚å‚æ•°æ— æ•ˆ')
 337:   }
 338: 
 339:   const refundType = input.refundType
 340:   if (refundType !== 'none' && refundType !== 'full' && refundType !== 'remaining') {
 341:     throw apiError(ErrorCode.VALIDATION_ERROR, 'è¯·é€‰æ‹©é€€æ¬¾æ–¹å¼')
 342:   }
 343: 
 344:   if (input.reason !== undefined && typeof input.reason !== 'string') {
 345:     throw apiError(ErrorCode.VALIDATION_ERROR, 'é€€æ¬¾åŽŸå› æ— æ•ˆ')
 346:   }
 347: 
 348:   const reason = input.reason?.trim()
 349:   if (reason !== undefined && reason.length > MAIL_CANCEL_REASON_MAX_LENGTH) {
 350:     throw apiError(ErrorCode.VALIDATION_ERROR, `é€€æ¬¾åŽŸå› ä¸èƒ½è¶…è¿‡ ${MAIL_CANCEL_REASON_MAX_LENGTH} ä¸ªå­—ç¬¦`)
 351:   }
 352: 
 353:   if (refundType !== 'none' && !reason) {
 354:     throw apiError(ErrorCode.VALIDATION_ERROR, 'é€€æ¬¾æ—¶å¿…é¡»å¡«å†™åŽŸå› ')
 355:   }
 356: 
 357:   return {
 358:     refundType,
 359:     ...(reason ? { reason } : {})
 360:   }
 361: }
