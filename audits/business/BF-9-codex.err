 613:   }
 614:   
 615:   // æœç´¢æ¡ä»¶ï¼šåŸŸåã€ç”¨æˆ·åã€é‚®ç®±ã€ç”¨æˆ·ID
 616:   if (searchTerm) {
 617:     where.OR = [
 618:       { domain: { contains: searchTerm, mode: 'insensitive' } },
 619:       { subscription: { user: { username: { contains: searchTerm, mode: 'insensitive' } } } },
 620:       { subscription: { user: { email: { contains: searchTerm, mode: 'insensitive' } } } },
 621:       ...(searchUserId ? [{ subscription: { userId: searchUserId } }] : [])
 622:     ]
 623:   }
 624:   
 625:   const [domains, total] = await Promise.all([
 626:     prisma.mailDomain.findMany({
 627:       where,
 628:       include: {
 629:         subscription: {
 630:           include: { user: { select: { id: true, username: true, email: true, avatarStyle: true, avatarBadgeId: true } } }
 631:         },
 632:         source: true,
 633:         _count: { select: { accounts: true } }
 634:       },
 635:       orderBy: { createdAt: 'desc' },
 636:       skip: (page - 1) * pageSize,
 637:       take: pageSize
 638:     }),
 639:     prisma.mailDomain.count({ where })
 640:   ])
 641:   
 642:   return { domains: domains.map(withDecryptedDomainSource), total }
 643: }
