 590: export async function getAllMailDomains(options?: {
 591:   sourceId?: number
 592:   status?: MailDomainStatus | string
 593:   search?: string
 594:   page?: number
 595:   pageSize?: number
 596: }): Promise<{
 597:   domains: (MailDomain & {
