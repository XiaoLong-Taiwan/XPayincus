 101: ): Promise<{ username?: string; password?: string; server?: string }> {
 102:   const result = await callApi(source, 'domain/create', {
 103:     domain,
 104:     disklimit: diskLimitGb.toString(),
 105:     userlimit: '0', // æ— é™ç”¨æˆ·
 106:     useraliaslimit: '0',
 107:     domainaliaslimit: '0',
 108:     maxusers: '0', // å¤‡ç”¨å‚æ•°å
 109:     maxuseraliases: '0', // å¤‡ç”¨å‚æ•°å
 110:     spamexperts: 'true',
 111:     spamexperts_adminaccess: 'all', // å¿…éœ€å‚æ•°ï¼Œæœ‰æ•ˆå€¼: 'primary' | 'all'
 112:     filestorage: 'true',
 113:     office: 'true'
 114:   })
 115: 
 116:   // API è¿”å›žæ ¼å¼: {status: true, username: "postmaster@domain.com", password: "xxx", server: "xxx"}
 117:   return {
 118:     username: result?.username,
 119:     password: result?.password,
 120:     server: result?.server
 121:   }
 122: }
 123: 
 124: /**
 125:  * èŽ·å–åŸŸåä¿¡æ¯ï¼ˆåŒ…å«éªŒè¯çŠ¶æ€ï¼‰
 126:  */
 127: export async function getDomainInfo(source: MailSource, domain: string): Promise<{
 128:   verified: boolean
 129:   txtRecord?: string
 130:   dnsRecords?: Array<{ type: string; record: string; value: string; prio?: number }>
 131:   mxRecords?: string[]
 132:   spfRecord?: string
 133:   dkimRecord?: string
 134:   cnameRecords?: Array<{ record: string; value: string }>
 135:   diskUsedMb?: number
 136: }> {
 137:   const result = await callApi(source, 'domain/info', { domain })
 138: 
 139:   // è§£æžéªŒè¯çŠ¶æ€ - status å¯èƒ½æ˜¯æ•°å­— 0/1 æˆ–å¸ƒå°”å€¼
 140:   const verifiedStatus = result?.verified?.status
 141:   const verified = verifiedStatus === true || verifiedStatus === 'true' || verifiedStatus === 1 || verifiedStatus === '1'
 142:   
 143:   // DNS è®°å½•æ˜¯æ•°ç»„æ ¼å¼ [{type, record, value, prio?}]
 144:   const dnsArray: Array<{ type: string; record: string; value: string; prio?: number }> = result?.dns || []
 145:   
 146:   // æ·»åŠ  workspace-verification TXT è®°å½•ï¼ˆä»Ž verified.txt è§£æžï¼‰
 147:   if (result?.verified?.txt) {
 148:     dnsArray.unshift({
 149:       type: 'TXT',
 150:       record: 'workspace-verification',
 151:       value: result.verified.txt
 152:     })
 153:   }
 154:   
 155:   // æ·»åŠ  DMARC TXT è®°å½•ï¼ˆå›ºå®šå€¼ï¼‰
 156:   dnsArray.push({
 157:     type: 'TXT',
 158:     record: '_dmarc',
 159:     value: 'v=DMARC1; p=none; sp=none'
 160:   })
 161:   
 162:   // æ·»åŠ  DKIM TXT è®°å½•ï¼ˆä»Ž dkim å­—æ®µè§£æžï¼Œä»…åœ¨éªŒè¯æˆåŠŸåŽæ˜¾ç¤ºï¼‰
 163:   if (verified && result?.dkim?.selector && result?.dkim?.key) {
 164:     dnsArray.push({
 165:       type: 'TXT',
 166:       record: result.dkim.selector,
 167:       value: `v=DKIM1; k=rsa; p=${result.dkim.key}`
 168:     })
 169:   }
 170:   
 171:   // æå–å„ç±»åž‹ DNS è®°å½•
 172:   const mxRecords = dnsArray
 173:     .filter(r => r.type === 'MX')
 174:     .map(r => r.prio ? `${r.prio} ${r.value}` : r.value)
 175:   
 176:   const spfRecord = dnsArray.find(r => r.type === 'TXT' && r.value?.includes('spf'))?.value
 177:   const dkimRecord = dnsArray.find(r => r.type === 'TXT' && r.record?.includes('dkim'))?.value
 178:   
 179:   const cnameRecords = dnsArray
 180:     .filter(r => r.type === 'CNAME')
 181:     .map(r => ({ record: r.record, value: r.value }))
 182:   
 183:   return {
 184:     verified,
 185:     txtRecord: result?.verified?.txt,
 186:     dnsRecords: dnsArray,
 187:     mxRecords,
 188:     spfRecord,
 189:     dkimRecord,
 190:     cnameRecords,
 191:     diskUsedMb: result?.diskusage ? parseInt(result.diskusage) : 0
 192:   }
 193: }
