  82: 
  83: async function loadData() {
  84:   loading.value = true
  85:   try {
  86:     const [subRes, srcRes] = await Promise.all([
  87:       api.mail.getSubscription(),
  88:       api.mail.getSources()
  89:     ])
  90:     subscription.value = subRes.subscription
  91:     sources.value = srcRes.sources
  92:     
  93:     // é»˜è®¤é€‰æ‹©ç¬¬ä¸€ä¸ªæºå’Œæ–¹æ¡ˆ
  94:     if (sources.value.length > 0 && !selectedSourceId.value) {
  95:       selectedSourceId.value = sources.value[0].id
  96:       if (sources.value[0].plans.length > 0) {
  97:         selectedPlanId.value = sources.value[0].plans[0].id
  98:       }
  99:     }
 100:     
 101:     // å¦‚æžœæ²¡æœ‰è®¢é˜…ï¼Œè‡ªåŠ¨åˆ‡æ¢åˆ°è´­ä¹° TAB
 102:     if (!subscription.value) {
 103:       activeTab.value = 'buy'
 104:     }
 105:   } catch (err: any) {
 106:     toast.error(translateError(err))
 107:   } finally {
 108:     loading.value = false
 109:   }
 110: }
 111: 
 112: function selectSource(id: number) {
 113:   selectedSourceId.value = id
 114:   const source = sources.value.find(s => s.id === id)
 115:   if (source?.plans.length > 0) {
 116:     selectedPlanId.value = source.plans[0].id
 117:   } else {
 118:     selectedPlanId.value = null
 119:   }
 120: }
 121: 
 122: function selectPlan(id: number) {
 123:   selectedPlanId.value = id
 124:   // é‡ç½®ä¼˜æƒ ç çŠ¶æ€
 125:   resetAffCode()
 126: }
 127: 
 128: function resetAffCode() {
 129:   affCode.value = ''
 130:   affCodeValid.value = null
 131:   affCodeDiscount.value = 0
 132:   affCodeCommissionRate.value = 0
 133:   affCodeError.value = ''
 134: }
 135: 
 136: async function verifyAffCode() {
 137:   if (!affCode.value.trim()) {
 138:     resetAffCode()
 139:     return
 140:   }
 141:   
 142:   affCodeVerifying.value = true
 143:   affCodeError.value = ''
 144:   
 145:   try {
 146:     const res = await api.mail.validateAffCode(affCode.value.trim())
 147:     if (res.valid) {
 148:       affCodeValid.value = true
 149:       affCodeDiscount.value = res.discountRate || 0
 150:       affCodeCommissionRate.value = res.commissionRate || 0
 151:     } else {
 152:       affCodeValid.value = false
 153:       affCodeError.value = res.error || t('aff.promoCodeInvalid')
 154:     }
 155:   } catch (err: any) {
 156:     affCodeValid.value = false
 157:     affCodeError.value = err.message || t('aff.promoCodeInvalid')
 158:   } finally {
 159:     affCodeVerifying.value = false
 160:   }
 161: }
 162: 
 163: async function purchaseSubscription() {
 164:   if (!selectedPlanId.value) {
 165:     toast.error(t('mail.selectPlanFirst'))
 166:     return
 167:   }
 168:   
 169:   buyLoading.value = true
 170:   try {
 171:     await api.mail.purchaseSubscription(
 172:       selectedPlanId.value,
 173:       affCodeValid.value ? affCode.value.trim() : undefined
 174:     )
 175:     toast.success(t('mail.purchaseSuccess'))
 176:     resetAffCode()
 177:     await loadData()
 178:     activeTab.value = 'my'
 179:   } catch (err: any) {
 180:     toast.error(translateError(err))
 181:   } finally {
 182:     buyLoading.value = false
 183:   }
 184: }
 185: 
 186: // æ·»åŠ åŸŸå
 187: function openAddDomainModal() {
 188:   newDomain.value = ''
 189:   showAddDomainModal.value = true
 190: }
 191: 
 192: async function addDomain() {
 193:   if (!newDomain.value.trim()) {
 194:     toast.error(t('mail.domainRequired'))
 195:     return
 196:   }
 197:   
 198:   addDomainLoading.value = true
 199:   try {
 200:     await api.mail.addDomain(newDomain.value.trim())
 201:     toast.success(t('mail.domainAdded'))
 202:     showAddDomainModal.value = false
 203:     await loadData()
 204:   } catch (err: any) {
 205:     toast.error(translateError(err))
 206:   } finally {
 207:     addDomainLoading.value = false
 208:   }
 209: }
 210: 
 211: function goToDomain(id: number) {
 212:   router.push(mailDomainPath(id))
 213: }
 214: 
 215: // ç»­è´¹ç›¸å…³
 216: function openRenewModal() {
 217:   // æ ¹æ®è®¡è´¹å‘¨æœŸè®¾ç½®é»˜è®¤å€¼
 218:   if (subscription.value?.plan?.billingCycle === 'yearly') {
 219:     renewMonths.value = 12
 220:   } else {
 221:     renewMonths.value = 1
 222:   }
 223:   showRenewModal.value = true
 224: }
 225: 
 226: const renewMonthlyPrice = computed(() => {
 227:   if (!subscription.value?.plan) return 0
 228:   const plan = subscription.value.plan
 229:   return plan.billingCycle === 'monthly' 
 230:     ? Number(plan.price) 
 231:     : Number(plan.price) / 12
 232: })
 233: 
 234: const renewOriginalPrice = computed(() => {
 235:   return Math.round(renewMonthlyPrice.value * renewMonths.value * 100) / 100
 236: })
 237: 
 238: const renewDiscountRate = computed(() => {
 239:   return subscription.value?.affBinding?.affCode?.discountRate || 0
 240: })
 241: 
 242: const renewDiscountAmount = computed(() => {
 243:   return Math.round(renewOriginalPrice.value * renewDiscountRate.value * 100) / 100
 244: })
 245: 
 246: const renewFinalPrice = computed(() => {
 247:   return renewOriginalPrice.value - renewDiscountAmount.value
 248: })
 249: 
 250: async function renewSubscription() {
 251:   renewLoading.value = true
 252:   try {
 253:     await api.mail.renewSubscription(renewMonths.value)
 254:     toast.success(t('mail.renewSuccess'))
 255:     showRenewModal.value = false
 256:     await loadData()
 257:   } catch (err: any) {
 258:     toast.error(translateError(err))
 259:   } finally {
 260:     renewLoading.value = false
 261:   }
 262: }
 263: 
 264: function getStatusBadge(status: string) {
 265:   switch (status) {
 266:     case 'verified': return 'badge-success'
 267:     case 'pending': return 'badge-warning'
 268:     case 'suspended': return 'badge-error'
 269:     default: return 'badge-ghost'
 270:   }
 271: }
 272: 
 273: function formatDate(dateStr: string) {
 274:   return new Date(dateStr).toLocaleDateString()
 275: }
 276: 
 277: function formatPrice(price: number | string | null | undefined) {
 278:   if (configStore.freeSiteMode) return freeSiteCopy.mailPrice
 279:   const num = Number(price) || 0
 280:   return `Â¥${num.toFixed(2)}`
 281: }
 282: 
 283: function getBillingCycleLabel(cycle: string | null | undefined) {
 284:   if (configStore.freeSiteMode) return freeSiteCopy.mailBillingCycle
 285:   return cycle === 'monthly' ? t('mail.monthly') : t('mail.yearly')
 286: }
 287: 
 288: function getBillingCycleSuffix(cycle: string | null | undefined) {
 289:   if (configStore.freeSiteMode) return ''
 290:   return `/${cycle === 'monthly' ? t('mail.month') : t('mail.year')}`
