  50: 
  51:   const responseText = await readLimitedTextResponse(response, 'CraneMail API response', CRANEMAIL_MAX_RESPONSE_BYTES)
  52:   console.log(`[CraneMail] Response status: ${response.status}`)
  53: 
  54:   if (!response.ok) {
