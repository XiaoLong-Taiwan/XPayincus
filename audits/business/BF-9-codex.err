 721:  */
 722: export async function getSubscriptionUsageStats(subscriptionId: number): Promise<{
 723:   domainCount: number
 724:   accountCount: number
 725:   diskUsedMb: number
 726: }> {
 727:   const domains = await prisma.mailDomain.findMany({
 728:     where: { subscriptionId },
