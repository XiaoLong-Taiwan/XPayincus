 237:   diskLimitMb: number
 238:   diskUsedMb: number
 239: }>> {
 240:   const result = await callApi(source, domain, adminUsername, adminPassword, 'GET', `/settings/domain/users/list?domain=${domain}`, undefined)
 241: 
 242:   if (!result.users || !Array.isArray(result.users)) {
 243:     return []
 244:   }
 245: 
 246:   return result.users.map((user: any) => ({
