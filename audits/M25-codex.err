   66:     verifySplitHost.includes(".*default-src 'self'.*frame-ancestors 'none'") &&
   67:     verifySplitHost.includes('assert_header "$tmp_dir/frontend.headers" "x-content-type-options" "nosniff"') &&
   68:     verifySplitHost.includes('assert_header "$tmp_dir/frontend.headers" "x-frame-options" "DENY"') &&
   69:     verifySplitHost.includes('assert_header "$tmp_dir/frontend.headers" "referrer-policy" "strict-origin-when-cross-origin"'),
   70:   'split host verifier must check security headers on the static frontend index response'
   71: )
   72: 
   73: console.log('security header checks passed')

