   33:     appSource.includes("noSniff: true") &&
   34:     appSource.includes("referrerPolicy: { policy: 'strict-origin-when-cross-origin' }") &&
   35:     appSource.includes('hsts: false'),
   36:   'backend Helmet security header decisions must stay explicit'
   37: )
   38: 
   39: for (const [name, source] of [
