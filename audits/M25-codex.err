  375: export function analyzeAuditData(input: {
  376:   processes: AuditProcess[]
  377:   connections: AuditConnection[]
  378:   startupItems: AuditStartupItem[]
  379:   rules?: AuditRuleDefinition[]
  380:   ignores?: AuditIgnoreDefinition[]
  381: }): { findings: AuditFinding[]; summary: AuditSummary } {
  382:   const findings: AuditFinding[] = []
  383:   const now = new Date()
  384:   const rules = (input.rules?.length ? input.rules : BUILTIN_AUDIT_RULES).filter(rule => rule.enabled)
  385:   const ignores = input.ignores || []
  386: 
  387:   input.processes.forEach((process, index) => {
  388:     const text = `${process.command} ${process.args}`
  389:     for (const rule of rules.filter(rule => rule.targetTypes.includes('process'))) {
  390:       const matchedText = findMatch(rule, text)
  391:       if (!matchedText) continue
  392:       process.findings.push(rule.name)
  393:       findings.push(buildRuleFinding({
  394:         id: buildFindingId('process', index, rule.id),
  395:         rule,
  396:         targetType: 'process',
  397:         pid: process.pid,
  398:         subject: `PID ${process.pid} (${process.command})`,
  399:         matchedText,
  400:         evidence: process.raw
  401:       }))
  402:     }
  403:   })
  404: 
  405:   input.startupItems.forEach((item, index) => {
  406:     for (const rule of rules.filter(rule => rule.targetTypes.includes('startup'))) {
  407:       const matchedText = findMatch(rule, item.command)
  408:       if (!matchedText) continue
  409:       item.findings.push(rule.name)
  410:       findings.push(buildRuleFinding({
  411:         id: buildFindingId('startup', index, rule.id),
  412:         rule,
  413:         targetType: 'startup',
  414:         subject: `æ¥æº ${item.source}`,
  415:         matchedText,
  416:         evidence: item.raw
  417:       }))
  418:     }
  419:   })
  420: 
  421:   input.connections.forEach((connection, index) => {
  422:     for (const rule of rules.filter(rule => rule.targetTypes.includes('network'))) {
  423:       const matchedText = findMatch(rule, connection.raw)
  424:       if (!matchedText) continue
  425:       findings.push(buildRuleFinding({
  426:         id: buildFindingId('network', index, rule.id),
  427:         rule,
  428:         targetType: 'network',
  429:         pid: connection.pid || undefined,
  430:         subject: `${connection.protocol} ${connection.local} -> ${connection.peer}`,
  431:         matchedText,
  432:         evidence: connection.raw
  433:       }))
  434:     }
  435:   })
  436: 
  437:   const udpConnections = input.connections.filter(row => /^udp/i.test(row.protocol)).length
  438:   if (udpConnections >= 100) {
  439:     findings.push({
  440:       id: 'network-high-udp-connection-count',
  441:       severity: 'medium',
  442:       category: 'network-anomaly',
  443:       title: 'UDP è¿žæŽ¥æ•°é‡åé«˜',
  444:       detail: `æœ¬æ¬¡æ‰«æä»Ž ss/netstat è¿”å›ž ${udpConnections} æ¡ UDP è¿žæŽ¥è®°å½•ï¼Œè¯·ç»“åˆä¸šåŠ¡ç”¨é€”åˆ¤æ–­æ˜¯å¦å¼‚å¸¸ã€‚`,
  445:       targetType: 'network',
  446:       evidence: input.connections.filter(row => /^udp/i.test(row.protocol)).slice(0, 5).map(row => row.raw).join('\n')
  447:     })
  448:   }
  449: 
  450:   const highCpuProcesses = input.processes.filter(process => (process.cpuPercent ?? 0) >= 80)
  451:   for (const process of highCpuProcesses.slice(0, 5)) {
  452:     findings.push({
  453:       id: `process-${process.pid}-high-cpu`,
  454:       severity: 'low',
  455:       category: 'resource-anomaly',
  456:       title: 'CPU å ç”¨åé«˜çš„è¿›ç¨‹',
  457:       detail: `PID ${process.pid} å½“å‰ CPU å ç”¨ä¸º ${process.cpuPercent}%ã€‚`,
  458:       targetType: 'process',
  459:       pid: process.pid,
  460:       evidence: process.raw.slice(0, 500)
  461:     })
  462:   }
  463: 
  464:   const listeningCount = input.connections.filter(row => row.state.toUpperCase() === 'LISTEN').length
  465:   const annotatedFindings = findings.map(finding => applyIgnore(finding, ignores, now))
  466:   const activeFindings = annotatedFindings.filter(finding => !finding.ignored)
  467: 
  468:   return {
  469:     findings: annotatedFindings.sort((a, b) => Number(a.ignored) - Number(b.ignored) || severityRank(b.severity) - severityRank(a.severity)),
  470:     summary: {
  471:       riskLevel: maxSeverity(activeFindings),
  472:       processCount: input.processes.length,
  473:       connectionCount: input.connections.length,
  474:       listeningCount,
  475:       startupItemCount: input.startupItems.length,
  476:       findingCount: activeFindings.length
  477:     }
  478:   }
  479: }
