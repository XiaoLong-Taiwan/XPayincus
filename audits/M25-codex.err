  200:   const rows: AuditProcess[] = []
  201:   for (const rawLine of output.split(/\r?\n/)) {
  202:     const raw = rawLine.trim()
  203:     if (!raw) continue
  204:     const match = raw.match(/^(\d+)\s+(\d+)\s+(\S+)\s+(\S+)\s+([\d.]+)\s+([\d.]+)\s+(\S+)\s+(\S+)(?:\s+(.*))?$/)
  205:     if (!match) continue
  206: 
  207:     const pid = Number(match[1])
  208:     if (!Number.isInteger(pid)) continue
  209:     const args = normalizeCommandText(match[9] || match[8] || '')
  210:     rows.push({
  211:       pid,
  212:       ppid: parseNumber(match[2]),
  213:       user: match[3],
  214:       stat: match[4],
  215:       cpuPercent: parseNumber(match[5]),
  216:       memoryPercent: parseNumber(match[6]),
  217:       elapsed: match[7],
  218:       command: match[8],
  219:       args,
  220:       raw,
  221:       findings: []
  222:     })
  223:     if (rows.length >= limit) break
  224:   }
  225:   return rows
  226: }
  227: 
  228: function parsePidFromProcessColumn(value: string): number | null {
  229:   const match = value.match(/\bpid=(\d+)/)
  230:   if (!match) return null
  231:   const pid = Number(match[1])
  232:   return Number.isInteger(pid) ? pid : null
  233: }
  234: 
  235: export function parseConnections(output: string, limit = 300): AuditConnection[] {
  236:   const rows: AuditConnection[] = []
  237:   for (const rawLine of output.split(/\r?\n/)) {
  238:     const raw = rawLine.trim()
  239:     if (!raw) continue
  240:     const fields = raw.split(/\s+/)
  241:     if (fields.length < 5) continue
  242: 
  243:     const processText = fields.length > 6 ? fields.slice(6).join(' ') : null
  244:     rows.push({
  245:       protocol: fields[0] || '',
  246:       state: fields[1] || '',
  247:       local: fields[4] || '',
  248:       peer: fields[5] || '',
  249:       process: processText,
  250:       pid: processText ? parsePidFromProcessColumn(processText) : null,
  251:       raw
  252:     })
  253:     if (rows.length >= limit) break
  254:   }
  255:   return rows
  256: }
  257: 
  258: export function parseStartupItems(output: string, limit = 200): AuditStartupItem[] {
  259:   const rows: AuditStartupItem[] = []
  260:   let source = 'startup'
  261:   for (const rawLine of output.split(/\r?\n/)) {
  262:     const raw = rawLine.trim()
  263:     if (!raw) continue
  264:     const sourceMatch = raw.match(/^\[(.+)\]$/)
  265:     if (sourceMatch) {
  266:       source = sourceMatch[1]
  267:       continue
  268:     }
  269:     rows.push({
  270:       source,
  271:       command: normalizeCommandText(raw),
  272:       raw,
  273:       findings: []
  274:     })
  275:     if (rows.length >= limit) break
  276:   }
  277:   return rows
  278: }
  279: 
  280: function severityRank(severity: AuditSeverity): number {
  281:   return { info: 0, low: 1, medium: 2, high: 3 }[severity]
  282: }
  283: 
  284: function maxSeverity(items: AuditFinding[]): AuditSeverity {
  285:   return items.reduce<AuditSeverity>((current, item) =>
  286:     severityRank(item.severity) > severityRank(current) ? item.severity : current,
  287:     items.length > 0 ? 'low' : 'info'
  288:   )
  289: }
  290: 
  291: function buildFindingId(prefix: string, index: number, ruleId: string): string {
  292:   return `${prefix}-${index}-${ruleId}`
  293: }
  294: 
  295: function findMatch(rule: AuditRuleDefinition, text: string): string | null {
  296:   if (!rule.enabled) return null
  297:   const patternText = rule.patternText.trim()
  298:   if (!patternText) return null
  299: 
  300:   if (rule.matchType === 'regex') {
  301:     try {
  302:       const regex = new RegExp(patternText, rule.caseSensitive ? '' : 'i')
  303:       const match = text.match(regex)
  304:       return match?.[0] || null
  305:     } catch {
  306:       return null
  307:     }
  308:   }
  309: 
  310:   const haystack = rule.caseSensitive ? text : text.toLowerCase()
  311:   const needle = rule.caseSensitive ? patternText : patternText.toLowerCase()
  312:   if (rule.matchType === 'exact') {
  313:     return haystack.trim() === needle.trim() ? patternText : null
  314:   }
  315:   return haystack.includes(needle) ? patternText : null
  316: }
  317: 
  318: function isIgnoreActive(ignore: AuditIgnoreDefinition, now: Date): boolean {
  319:   if (!ignore.expiresAt) return true
  320:   const expiresAt = ignore.expiresAt instanceof Date ? ignore.expiresAt : new Date(ignore.expiresAt)
  321:   return Number.isNaN(expiresAt.getTime()) || expiresAt > now
  322: }
  323: 
  324: function applyIgnore(finding: AuditFinding, ignores: AuditIgnoreDefinition[], now: Date): AuditFinding {
  325:   for (const ignore of ignores) {
  326:     if (!isIgnoreActive(ignore, now)) continue
  327:     if (ignore.ruleId && ignore.ruleId !== finding.ruleId) continue
  328:     if (ignore.targetType && ignore.targetType !== finding.targetType) continue
  329:     if (ignore.matchText) {
  330:       const needle = ignore.matchText.toLowerCase()
  331:       const text = `${finding.title} ${finding.detail} ${finding.evidence}`.toLowerCase()
  332:       if (!text.includes(needle)) continue
  333:     }
  334:     return {
  335:       ...finding,
  336:       ignored: true,
  337:       ignoreReason: ignore.reason || null
  338:     }
  339:   }
  340:   return finding
  341: }
