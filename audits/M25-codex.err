  364:     targetType: params.targetType,
  365:     ruleId: params.rule.id,
  366:     ruleName: params.rule.name,
  367:     ruleSource: params.rule.source,
  368:     matchedText: params.matchedText,
  369:     recommendation: params.rule.recommendation || null,
  370:     pid: params.pid,
