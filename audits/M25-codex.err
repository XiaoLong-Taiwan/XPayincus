  425: export async function getLogsForAuditExport(options: {
  426:   module?: string
  427:   startDate?: string
  428:   endDate?: string
  429:   search?: string
  430:   instanceId?: number
  431:   instanceName?: string
  432:   limit?: number
  433: } = {}): Promise<AuditLogRow[]> {
  434:   const safeLimit = Number.isInteger(options.limit) ? Math.min(Math.max(options.limit ?? 500, 1), 1000) : 500
  435:   const where = buildLogWhere(options)
  436: 
  437:   const logs = await prisma.log.findMany({
  438:     where,
  439:     include: {
  440:       user: {
  441:         select: {
  442:           username: true
  443:         }
  444:       }
  445:     },
  446:     orderBy: {
  447:       createdAt: 'desc'
  448:     },
  449:     take: safeLimit
  450:   })
  451: 
  452:   return logs.map(mapLogWithRisk)
  453: }
