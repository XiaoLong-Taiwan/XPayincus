  135: const INSTANCE_NAME_PATTERN = /instance\s+"([^"]+)"/gi
  136: const INSTANCE_ID_PATTERNS = [
  137:   /instance\s*#(\d+)/gi,
  138:   /instance:\s*[^()]*\(#(\d+)\)/gi,
  139:   /new instance ID:\s*(\d+)/gi
  140: ]
  141: 
  142: function extractLogInstanceIds(content: string): number[] {
  143:   const ids = new Set<number>()
  144: 
  145:   for (const pattern of INSTANCE_ID_PATTERNS) {
  146:     pattern.lastIndex = 0
  147:     for (const match of content.matchAll(pattern)) {
  148:       const id = Number(match[1])
  149:       if (Number.isSafeInteger(id) && id > 0) {
  150:         ids.add(id)
  151:       }
  152:     }
  153:   }
  154: 
  155:   return Array.from(ids)
  156: }
  157: 
  158: async function inferLogInstanceId(userId: number | null, content: string): Promise<number | null> {
  159:   const instanceIds = extractLogInstanceIds(content)
  160:   if (instanceIds.length === 1) {
  161:     const instance = await prisma.instance.findUnique({
  162:       where: { id: instanceIds[0] },
  163:       select: { id: true, userId: true }
  164:     })
  165: 
  166:     if (instance && (userId === null || instance.userId === userId)) {
  167:       return instance.id
  168:     }
  169:   }
  170: 
  171:   const names = Array.from(content.matchAll(INSTANCE_NAME_PATTERN))
  172:     .map(match => match[1]?.trim())
  173:     .filter((name): name is string => Boolean(name))
  174: 
  175:   const uniqueNames = Array.from(new Set(names))
  176:   if (uniqueNames.length !== 1) return null
  177: 
  178:   const matches = await prisma.instance.findMany({
  179:     where: {
  180:       name: uniqueNames[0],
  181:       ...(userId !== null ? { userId } : {})
  182:     },
  183:     select: { id: true },
  184:     take: 2
  185:   })
  186: 
  187:   return matches.length === 1 ? matches[0].id : null
  188: }
