  190: // ==================== åŸºç¡€æ—¥å¿—å‡½æ•° ====================
  191: 
  192: /**
  193:  * åˆ›å»ºæ—¥å¿—è®°å½•ï¼ˆåŸºç¡€å‡½æ•°ï¼‰
  194:  */
  195: export async function createLog(
  196:   userId: number | null,
  197:   module: string,
  198:   action: string,
  199:   content: string,
  200:   result: string,
  201:   options: CreateLogOptions = {}
  202: ): Promise<void> {
  203:   try {
  204:     const instanceId = options.instanceId !== undefined
  205:       ? options.instanceId
  206:       : await inferLogInstanceId(userId, content)
  207:     const normalizedContent = normalizeLogContentForStorage(content)
  208: 
  209:     await prisma.log.create({
  210:       data: {
  211:         userId: userId ?? null,
  212:         instanceId: instanceId ?? null,
  213:         module,
  214:         action,
  215:         content: normalizedContent,
  216:         result
  217:       }
  218:     })
  219:   } catch (error) {
  220:     // æ—¥å¿—è®°å½•å¤±è´¥ä¸åº”è¯¥å½±å“ä¸»ä¸šåŠ¡æµç¨‹ï¼Œåªæ‰“å°é”™è¯¯
  221:     console.error('æ—¥å¿—è®°å½•å¤±è´¥:', error)
  222:   }
  223: }
  224: 
  225: // ==================== ä¾¿æ·æ—¥å¿—å‡½æ•° ====================
  226: 
  227: /**
  228:  * è®°å½•æˆåŠŸæ“ä½œæ—¥å¿—
  229:  */
  230: export async function logSuccess(
  231:   userId: number | null,
  232:   module: string,
  233:   action: string,
  234:   content: string,
  235:   options?: CreateLogOptions
  236: ): Promise<void> {
  237:   await createLog(userId, module, action, content, LogResult.SUCCESS, options)
  238: }
  239: 
  240: /**
