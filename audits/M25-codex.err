  455: /**
  456:  * èŽ·å–æ—¥å¿—æ¨¡å—åˆ—è¡¨
  457:  */
  458: export async function getLogModules(): Promise<string[]> {
  459:   const modules = await prisma.log.findMany({
  460:     select: {
  461:       module: true
  462:     },
  463:     distinct: ['module'],
  464:     orderBy: {
  465:       module: 'asc'
  466:     }
  467:   })
  468: 
  469:   return modules.map(m => m.module)
  470: }
  471: 
  472: /**
  473:  * æ¸…ç†æ—§çš„æ“ä½œæ—¥å¿—ï¼ˆä¿ç•™æœ€è¿‘ N å¤©ï¼‰
  474:  * é»˜è®¤ä¿ç•™ 90 å¤©ç”¨äºŽå®¡è®¡
  475:  */
  476: export async function cleanOldLogs(days: number = 90): Promise<number> {
  477:   const cutoffDate = new Date()
  478:   cutoffDate.setDate(cutoffDate.getDate() - days)
  479: 
  480:   const result = await prisma.log.deleteMany({
  481:     where: {
  482:       createdAt: { lt: cutoffDate }
  483:     }
  484:   })
  485: 
  486:   return result.count
  487: }

