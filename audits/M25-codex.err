  266: function combineWhereWithAnd(where: Prisma.LogWhereInput, condition: Prisma.LogWhereInput): void {
  267:   const existingAnd = Array.isArray(where.AND) ? where.AND : []
  268:   const base: Prisma.LogWhereInput = { ...where }
  269:   delete base.AND
  270: 
  271:   const nextAnd: Prisma.LogWhereInput[] = []
  272:   if (Object.keys(base).length > 0) nextAnd.push(base)
  273:   nextAnd.push(...existingAnd, condition)
  274: 
  275:   const mutableWhere = where as Record<string, unknown>
  276:   for (const key of Object.keys(mutableWhere)) {
  277:     delete mutableWhere[key]
  278:   }
  279: 
  280:   if (nextAnd.length === 1) {
  281:     Object.assign(where, nextAnd[0])
  282:   } else {
  283:     where.AND = nextAnd
  284:   }
  285: }
  286: 
  287: function buildLogWhere(options: {
  288:   module?: string
  289:   userId?: number
  290:   startDate?: string
  291:   endDate?: string
  292:   search?: string
  293:   instanceId?: number
  294:   instanceName?: string
  295: }): Prisma.LogWhereInput {
  296:   const safeModule = normalizeLogFilterValue(options.module, LOG_MODULE_FILTER_MAX_LENGTH)
  297:   const safeSearch = normalizeLogFilterValue(options.search, LOG_SEARCH_FILTER_MAX_LENGTH)
  298:   const safeInstanceName = normalizeLogFilterValue(options.instanceName, LOG_INSTANCE_NAME_FILTER_MAX_LENGTH)
  299:   const safeStartDate = parseValidDateFilter(options.startDate)
  300:   const safeEndDate = parseValidDateFilter(options.endDate)
  301: 
  302:   const where: Prisma.LogWhereInput = {}
  303: 
  304:   if (safeModule) {
  305:     where.module = safeModule
  306:   }
  307: 
  308:   if (options.userId !== undefined) {
  309:     where.userId = options.userId
  310:   }
  311: 
  312:   if (safeStartDate || safeEndDate) {
  313:     where.createdAt = {
  314:       ...(safeStartDate ? { gte: safeStartDate } : {}),
  315:       ...(safeEndDate ? { lte: safeEndDate } : {})
  316:     }
  317:   }
  318: 
  319:   if (safeSearch) {
  320:     where.OR = [
  321:       { content: { contains: safeSearch, mode: 'insensitive' } },
  322:       { action: { contains: safeSearch, mode: 'insensitive' } },
  323:       { user: { username: { contains: safeSearch, mode: 'insensitive' } } }
  324:     ]
  325:   }
  326: 
  327:   if (options.instanceId !== undefined) {
  328:     combineWhereWithAnd(where, { instanceId: options.instanceId })
  329:   } else if (safeInstanceName) {
  330:     combineWhereWithAnd(where, { content: { contains: `instance "${safeInstanceName}"`, mode: 'insensitive' } })
  331:   }
  332: 
  333:   return where
  334: }
  335: 
  336: function mapLogWithRisk(log: Prisma.LogGetPayload<{ include: { user: { select: { username: true } } } }>): AuditLogRow {
  337:   const risk = classifyLogRisk({
  338:     module: log.module,
  339:     action: log.action,
  340:     content: log.content
  341:   })
  342: 
  343:   return {
  344:     id: log.id,
  345:     user_id: log.userId,
  346:     instance_id: log.instanceId,
  347:     username: redactAuditText(log.user?.username || '') || null,
  348:     module: log.module,
  349:     action: log.action,
  350:     content: redactAuditText(log.content),
  351:     result: log.result,
  352:     created_at: log.createdAt.toISOString(),
  353:     risk_level: risk.riskLevel,
  354:     risk_title: risk.riskTitle,
  355:     approval_required: risk.approvalRequired,
  356:     verification_required: risk.verificationRequired,
  357:     batch_sensitive: risk.batchSensitive
  358:   }
  359: }
  360: 
  361: /**
  362:  * åˆ†é¡µèŽ·å–æ—¥å¿—
  363:  */
  364: export async function getLogsPaginated(options: {
  365:   page?: number
  366:   pageSize?: number
  367:   module?: string
  368:   userId?: number
  369:   startDate?: string
  370:   endDate?: string
  371:   search?: string
  372:   instanceId?: number
  373:   instanceName?: string
  374: } = {}): Promise<{
  375:   items: Log[]
  376:   total: number
  377:   page: number
  378:   pageSize: number
  379:   totalPages: number
  380: }> {
  381:   const {
  382:     page = 1,
  383:     pageSize = 20,
  384:     module,
  385:     userId,
  386:     startDate,
  387:     endDate,
  388:     search,
  389:     instanceId,
  390:     instanceName
  391:   } = options
  392:   const safePage = Number.isInteger(page) && page > 0 ? page : 1
  393:   const safePageSize = Number.isInteger(pageSize) ? Math.min(Math.max(pageSize, 1), 100) : 20
  394:   const where = buildLogWhere({ module, userId, startDate, endDate, search, instanceId, instanceName })
  395: 
  396:   // èŽ·å–æ€»æ•°
  397:   const total = await prisma.log.count({ where })
  398: 
  399:   // èŽ·å–æ•°æ®ï¼ˆåŒ…å«ç”¨æˆ·åï¼‰
  400:   const logs = await prisma.log.findMany({
  401:     where,
  402:     include: {
  403:       user: {
  404:         select: {
  405:           username: true
  406:         }
  407:       }
  408:     },
  409:     orderBy: {
  410:       createdAt: 'desc'
  411:     },
  412:     skip: (safePage - 1) * safePageSize,
  413:     take: safePageSize
  414:   })
  415: 
  416:   return {
  417:     items: logs.map(mapLogWithRisk),
  418:     total,
  419:     page: safePage,
  420:     pageSize: safePageSize,
  421:     totalPages: Math.ceil(total / safePageSize)
  422:   }
  423: }
