===== test-mail-source-secret-handling.ts =====
   1: import assert from 'node:assert/strict'
   2: import { readFileSync } from 'node:fs'
   3: import { dirname, resolve } from 'node:path'
   4: import { fileURLToPath } from 'node:url'
   5: 
   6: const __filename = fileURLToPath(import.meta.url)
   7: const __dirname = dirname(__filename)
   8: 
   9: process.env.DATABASE_URL ||= 'postgresql://test:test@127.0.0.1:5432/payincus_test'
  10: 
  11: const {
  12:   MASKED_MAIL_SOURCE_API_KEY_VALUE,
  13:   mergeMailSourceApiKeyForUpdate,
  14:   sanitizeMailDomainForResponse,
  15:   sanitizeMailPlanForResponse,
  16:   sanitizeMailSourceForResponse,
  17:   sanitizeMailSubscriptionForResponse
  18: } = await import('../src/db/mail.js')
  19: const { decryptSensitiveData, encryptSensitiveData, isEncrypted } = await import('../src/lib/security.js')
  20: 
  21: const source = {
  22:   id: 1,
  23:   name: 'US Mail',
  24:   code: 'us',
  25:   apiUrl: 'https://api.example.com',
  26:   apiKey: 'mail-source-api-key',
  27:   smarterMailUrl: 'https://mail.example.com',
  28:   enabled: true,
  29:   sortOrder: 0,
  30:   createdAt: new Date(),
  31:   updatedAt: new Date()
  32: }
  33: 
  34: const sanitized = sanitizeMailSourceForResponse(source)
  35: assert.equal(sanitized.apiKey, '', 'mail source API key must not be returned to browser')
  36: assert.equal(sanitized.apiKeyConfigured, true, 'mail source response must expose configured flag')
  37: assert.equal(sanitized.apiUrl, source.apiUrl, 'non-secret mail source fields must remain visible')
  38: 
  39: const sanitizedPlan = sanitizeMailPlanForResponse({ id: 1, source })
  40: assert.equal(sanitizedPlan.source.apiKey, '', 'admin mail plan responses must redact nested source API keys')
  41: assert.equal(sanitizedPlan.source.apiKeyConfigured, true, 'admin mail plan responses must expose nested source configured flag')
  42: 
  43: const sanitizedSubscription = sanitizeMailSubscriptionForResponse({ id: 1, source })
  44: assert.equal(sanitizedSubscription.source.apiKey, '', 'admin mail subscription responses must redact nested source API keys')
  45: 
  46: const sanitizedDomain = sanitizeMailDomainForResponse({ id: 1, source, adminPassword: 'mail-admin-password' })
  47: assert.equal(sanitizedDomain.source.apiKey, '', 'admin mail domain responses must redact nested source API keys')
  48: assert.equal(sanitizedDomain.adminPassword, '', 'admin mail domain responses must not return admin passwords')
  49: assert.equal(sanitizedDomain.adminPasswordConfigured, true, 'admin mail domain responses must expose password configured flag')
  50: 
  51: assert.equal(mergeMailSourceApiKeyForUpdate(undefined), undefined, 'omitted API key must preserve existing secret')
  52: assert.equal(mergeMailSourceApiKeyForUpdate(null), undefined, 'null API key must preserve existing secret')
  53: assert.equal(mergeMailSourceApiKeyForUpdate(''), undefined, 'blank API key must preserve existing secret')
  54: assert.equal(mergeMailSourceApiKeyForUpdate('***1234'), undefined, 'legacy masked API key must preserve existing secret')
  55: assert.equal(mergeMailSourceApiKeyForUpdate(MASKED_MAIL_SOURCE_API_KEY_VALUE), undefined, 'placeholder API key must preserve existing secret')
  56: assert.equal(mergeMailSourceApiKeyForUpdate('new-api-key'), 'new-api-key', 'new API key must replace existing secret')
  57: 
  58: const encrypted = encryptSensitiveData(source.apiKey)
  59: assert.equal(isEncrypted(encrypted), true, 'mail source API key must use encrypted-at-rest format')
  60: assert.equal(decryptSensitiveData(encrypted), source.apiKey, 'encrypted mail source API key must decrypt')
  61: assert.equal(decryptSensitiveData(source.apiKey), source.apiKey, 'legacy plaintext mail source API key must remain readable')
  62: 
  63: const dbSource = readFileSync(resolve(__dirname, '../src/db/mail.ts'), 'utf8')
  64: assert.ok(
  65:   dbSource.includes('apiKey: encryptMailSecret(data.apiKey)'),
  66:   'mail source create must encrypt API keys before persistence'
  67: )
  68: assert.ok(
  69:   dbSource.includes('apiKey: encryptMailSecret(data.apiKey)'),
  70:   'mail source update must encrypt new API keys before persistence'
  71: )
  72: assert.ok(
  73:   dbSource.includes('adminPassword: data.adminPassword ? encryptMailSecret(data.adminPassword) : data.adminPassword'),
  74:   'mail domain admin passwords must be encrypted before persistence'
  75: )
  76: assert.ok(
  77:   dbSource.includes('decryptMailSource(source)'),
  78:   'mail source reads must decrypt API keys for server-side delivery calls'
  79: )
  80: assert.ok(
  81:   dbSource.includes('withDecryptedDomainSource(domain)'),
  82:   'mail domain reads must decrypt source/API credentials for delivery calls'
  83: )
  84: 
  85: const routeSource = readFileSync(resolve(__dirname, '../src/routes/mail.ts'), 'utf8')
  86: assert.ok(
  87:   routeSource.includes('sanitizeMailSourceForResponse'),
  88:   'mail admin source responses must be sanitized'
  89: )
  90: assert.ok(
  91:   routeSource.includes('plans: plans.map(db.sanitizeMailPlanForResponse)') &&
  92:     routeSource.includes('subscriptions: result.subscriptions.map(db.sanitizeMailSubscriptionForResponse)') &&
  93:     routeSource.includes('domains: result.domains.map(db.sanitizeMailDomainForResponse)'),
  94:   'mail admin plan, subscription, and domain list responses must sanitize nested source secrets and domain passwords'
  95: )
  96: assert.ok(
  97:   routeSource.includes('mergeMailSourceApiKeyForUpdate(sourceInput.apiKey)'),
  98:   'mail admin source update must preserve existing API keys for blank masked inputs'
  99: )
 100: assert.ok(
 101:   !routeSource.includes('adminPassword: domain.adminPassword,'),
 102:   'mail user domain detail must not passively return domain admin passwords'
 103: )
 104: assert.ok(
 105:   routeSource.includes("'/domains/:id/admin-password'") &&
 106:     routeSource.includes('onRequest: [fastify.authenticate]') &&
 107:     routeSource.includes('domain.subscription.userId !== request.user.id') &&
 108:     routeSource.includes('adminPassword: domain.adminPassword ?? null'),
 109:   'mail domain admin password must require an explicit authenticated owner-only password endpoint'
 110: )
 111: assert.ok(
 112:   !routeSource.includes("apiKey: '***' + source.apiKey.slice(-4)"),
 113:   'mail admin source list must not build API key masks from raw secrets'
 114: )
 115: 
 116: const clientSource = readFileSync(resolve(__dirname, '../../client/src/views/admin/AdminMailView.vue'), 'utf8')
 117: assert.ok(
 118:   clientSource.includes('apiKey: \'\','),
 119:   'mail admin source edit form must not prefill masked API keys'
 120: )
 121: assert.ok(
 122:   !clientSource.includes('apiKey: source.apiKey ||'),
 123:   'mail admin source edit form must not copy returned API key masks into the form'
 124: )
 125: assert.ok(
 126:   clientSource.includes('delete (payload as Partial<typeof sourceForm.value>).apiKey'),
 127:   'mail admin source update must omit blank API keys'
 128: )
 129: 
 130: console.log('mail source secret handling tests passed')
 131: process.exit(0)
