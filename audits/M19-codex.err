  12: function section(source: string, startMarker: string, endMarker: string): string {
  13:   const start = source.indexOf(startMarker)
  14:   assert.notEqual(start, -1, `missing start marker: ${startMarker}`)
  15:   const end = source.indexOf(endMarker, start + startMarker.length)
  16:   assert.notEqual(end, -1, `missing end marker: ${endMarker}`)
  17:   return source.slice(start, end)
  18: }
