  115:  * é€’å½’å¤„ç†åµŒå¥—å¯¹è±¡
  116:  */
  117: export function sanitizeObject<T>(obj: T, depth = 0): T {
  118:     // é˜²æ­¢æ— é™é€’å½’
  119:     if (depth > 10) return obj
  120: 
  121:     if (obj === null || obj === undefined) {
  122:         return obj
  123:     }
  124: 
  125:     // å¤„ç†å­—ç¬¦ä¸²
  126:     if (typeof obj === 'string') {
  127:         return sanitizeTokensInString(obj) as unknown as T
  128:     }
  129: 
  130:     // å¤„ç†æ•°ç»„
  131:     if (Array.isArray(obj)) {
  132:         return obj.map(item => sanitizeObject(item, depth + 1)) as unknown as T
  133:     }
  134: 
  135:     // å¤„ç†å¯¹è±¡
  136:     if (typeof obj === 'object') {
  137:         const result: Record<string, unknown> = {}
  138:         for (const [key, value] of Object.entries(obj)) {
  139:             if (isSensitiveField(key)) {
  140:                 result[key] = REDACTED
  141:             } else if (typeof value === 'string') {
  142:                 result[key] = sanitizeTokensInString(value)
  143:             } else if (typeof value === 'object' && value !== null) {
  144:                 result[key] = sanitizeObject(value, depth + 1)
  145:             } else {
  146:                 result[key] = value
  147:             }
  148:         }
  149:         return result as T
  150:     }
  151: 
  152:     return obj
  153: }
