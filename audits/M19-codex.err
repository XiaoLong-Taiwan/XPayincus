  43:   'Number(request.params.accountId)'
  44: ] as const) {
  45:   assert.ok(
  46:     !routeSource.includes(forbiddenPattern),
  47:     `mail routes must not use loose path ID parsing: ${forbiddenPattern}`
  48:   )
  49: }
