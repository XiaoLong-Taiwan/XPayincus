===== server/src/services/smartermail.ts =====
    1: /**
    2:  * SmarterMail API é›†æˆæœåŠ¡
    3:  * è´Ÿè´£é‚®ç®±è´¦æˆ·çš„åˆ›å»ºã€åˆ é™¤ã€æ›´æ–°å’Œå¯†ç é‡ç½®
    4:  */
    5: 
    6: import type { MailSource } from '@prisma/client'
    7: import { assertSafeHttpUrl } from '../lib/outbound-security.js'
    8: import { readLimitedTextResponse } from '../lib/http-response.js'
    9: import { sanitizeTokensInString } from '../lib/log-sanitizer.js'
   10: 
   11: const SMARTERMAIL_API_TIMEOUT_MS = 30_000
   12: const SMARTERMAIL_MAX_RESPONSE_BYTES = 1024 * 1024
   13: 
   14: async function getSmarterMailBaseUrl(source: MailSource): Promise<string> {
   15:   const safeBaseUrl = await assertSafeHttpUrl(source.smarterMailUrl, 'SmarterMail URL')
   16:   return safeBaseUrl.toString().replace(/\/+$/, '')
   17: }
   18: 
   19: /**
   20:  * èŽ·å– SmarterMail API Token
   21:  * ä½¿ç”¨åŸŸç®¡ç†å‘˜è´¦å·è®¤è¯
   22:  */
   23: async function getAuthToken(
   24:   domain: string,
   25:   adminUsername: string,
   26:   adminPassword: string,
   27:   baseUrl: string
   28: ): Promise<string> {
   29:   const email = `${adminUsername}@${domain}`
   30:   
   31:   const response = await fetch(`${baseUrl}/api/v1/auth/authenticate-user`, {
   32:     method: 'POST',
   33:     signal: AbortSignal.timeout(SMARTERMAIL_API_TIMEOUT_MS),
   34:     headers: {
   35:       'Content-Type': 'application/json'
   36:     },
   37:     body: JSON.stringify({
   38:       username: email,
   39:       password: adminPassword
   40:     }),
   41:     redirect: 'manual'
   42:   })
   43: 
   44:   if (!response.ok) {
   45:     throw new Error(`SmarterMail auth error: ${response.status} ${response.statusText}`)
   46:   }
   47: 
   48:   const result = await response.json() as { accessToken?: string; message?: string }
   49:   
   50:   if (!result.accessToken) {
   51:     throw new Error(sanitizeTokensInString(result.message || 'Failed to get SmarterMail token'))
   52:   }
   53: 
   54:   return result.accessToken
   55: }
   56: 
   57: /**
   58:  * è°ƒç”¨ SmarterMail API
   59:  */
   60: async function callApi(
   61:   source: MailSource,
   62:   domain: string,
   63:   adminUsername: string,
   64:   adminPassword: string,
   65:   method: 'GET' | 'POST' | 'PUT' | 'DELETE',
   66:   endpoint: string,
   67:   data?: any
   68: ): Promise<any> {
   69:   const baseUrl = await getSmarterMailBaseUrl(source)
   70:   const token = await getAuthToken(domain, adminUsername, adminPassword, baseUrl)
   71:   
   72:   const response = await fetch(`${baseUrl}/api/v1${endpoint}`, {
   73:     method,
   74:     signal: AbortSignal.timeout(SMARTERMAIL_API_TIMEOUT_MS),
   75:     headers: {
   76:       'Content-Type': 'application/json',
   77:       'Authorization': `Bearer ${token}`
   78:     },
   79:     body: data ? JSON.stringify(data) : undefined,
   80:     redirect: 'manual'
   81:   })
   82: 
   83:   if (!response.ok) {
   84:     const error = sanitizeTokensInString(
   85:       await readLimitedTextResponse(response, 'SmarterMail API error response', SMARTERMAIL_MAX_RESPONSE_BYTES)
   86:     )
   87:     throw new Error(`SmarterMail API error: ${response.status} - ${error}`)
   88:   }
   89: 
   90:   // æŸäº› API å¯èƒ½è¿”å›žç©ºå“åº”
   91:   const text = await readLimitedTextResponse(response, 'SmarterMail API response', SMARTERMAIL_MAX_RESPONSE_BYTES)
   92:   if (!text) return {}
   93:   
   94:   return JSON.parse(text)
   95: }
   96: 
   97: /**
   98:  * åˆ›å»ºé‚®ç®±è´¦æˆ·
   99:  */
  100: export async function createAccount(
  101:   source: MailSource,
  102:   domain: string,
  103:   adminUsername: string,
  104:   adminPassword: string,
  105:   account: {
  106:     username: string
  107:     password: string
  108:     displayName: string
  109:     diskLimitMb: number
  110:   }
  111: ): Promise<void> {
  112:   await callApi(source, domain, adminUsername, adminPassword, 'POST', '/settings/domain/users/user-put', {
  113:     userData: {
  114:       userName: account.username,
  115:       password: account.password,
  116:       displayName: account.displayName,
  117:       maxMailboxSize: account.diskLimitMb,
  118:       domain: domain,
  119:       isEnabled: true
  120:     }
  121:   })
  122: }
  123: 
  124: /**
