  58:     normalizerSection.includes("const sortOrder = requireSafeInteger(input.sortOrder, 'æŽ’åºå€¼')"),
  59:   'mail source enabled and sortOrder fields must be type-checked before persistence'
  60: )
  61: 
  62: const createSourceSection = section(
  63:   source,
  64:   '// åˆ›å»ºé‚®ç®±æº',
  65:   '// æ›´æ–°é‚®ç®±æº'
