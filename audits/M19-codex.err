  34: const localFailureResponseIndex = createAccountSection.indexOf("'é‚®ç®±è´¦æˆ·åˆ›å»ºå¤±è´¥ï¼Œå·²å›žæ»šè¿œç«¯è´¦å·ï¼Œè¯·é‡è¯•'")
  35: const compensationFailureResponseIndex = createAccountSection.indexOf('è¿œç«¯è¡¥å¿åˆ é™¤å¤±è´¥')
  36: const successLogIndex = createAccountSection.indexOf("'create_mail_account'")
  37: 
