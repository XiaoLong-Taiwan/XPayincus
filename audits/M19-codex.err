    1: import { lookup as dnsLookup } from 'dns/promises'
    2: import { lookup as dnsLookupCb } from 'dns'
    3: import { isIP, type LookupFunction } from 'net'
    4: import { Agent } from 'undici'
    5: 
    6: export class OutboundTargetValidationError extends Error {
    7:   constructor(message: string) {
    8:     super(message)
    9:     this.name = 'OutboundTargetValidationError'
   10:   }
   11: }
   12: 
   13: type SupportedProtocol = 'http' | 'https' | 'ftp' | 'sftp'
   14: 
   15: function buildUrl(input: string, defaultProtocol: SupportedProtocol): URL {
   16:   const trimmed = input.trim()
   17:   if (!trimmed) {
   18:     throw new OutboundTargetValidationError('Target cannot be empty')
   19:   }
   20: 
   21:   try {
   22:     if (trimmed.includes('://')) {
   23:       return new URL(trimmed)
   24:     }
   25:     return new URL(`${defaultProtocol}://${trimmed}`)
   26:   } catch {
   27:     throw new OutboundTargetValidationError('Target format is invalid')
   28:   }
   29: }
   30: 
   31: function ipv4ToInt(ip: string): number {
   32:   return ip.split('.').reduce((acc, item) => (acc << 8) + Number(item), 0) >>> 0
   33: }
   34: 
   35: function isIpv4InCidr(ip: string, baseIp: string, prefixLength: number): boolean {
   36:   const ipInt = ipv4ToInt(ip)
   37:   const baseInt = ipv4ToInt(baseIp)
   38:   const mask = prefixLength === 0 ? 0 : (0xffffffff << (32 - prefixLength)) >>> 0
   39:   return (ipInt & mask) === (baseInt & mask)
   40: }
   41: 
   42: function normalizeIpv6(ip: string): string {
   43:   return ip.toLowerCase().replace(/^\[|\]$/g, '')
   44: }
   45: 
   46: function isIpv6PrivateOrReserved(ip: string): boolean {
   47:   const normalized = normalizeIpv6(ip)
   48: 
   49:   if (
   50:     normalized === '::' ||
   51:     normalized === '::1' ||
   52:     normalized.startsWith('fc') ||
   53:     normalized.startsWith('fd') ||
   54:     /^fe[89ab]/i.test(normalized) ||
   55:     normalized.startsWith('ff') ||
   56:     normalized.startsWith('2001:db8')
   57:   ) {
   58:     return true
   59:   }
   60: 
   61:   const mappedIpv4Match = normalized.match(/^::ffff:(\d+\.\d+\.\d+\.\d+)$/i)
   62:   if (mappedIpv4Match) {
   63:     return isIpPrivateOrReserved(mappedIpv4Match[1])
   64:   }
   65: 
   66:   return false
   67: }
   68: 
   69: export function isIpPrivateOrReserved(ip: string): boolean {
   70:   const family = isIP(ip)
   71:   if (family === 4) {
   72:     const ranges: Array<[string, number]> = [
   73:       ['0.0.0.0', 8],
   74:       ['10.0.0.0', 8],
   75:       ['100.64.0.0', 10],
   76:       ['127.0.0.0', 8],
   77:       ['169.254.0.0', 16],
   78:       ['172.16.0.0', 12],
   79:       ['192.0.0.0', 24],
   80:       ['192.0.2.0', 24],
   81:       ['192.168.0.0', 16],
   82:       ['198.18.0.0', 15],
   83:       ['198.51.100.0', 24],
   84:       ['203.0.113.0', 24],
   85:       ['224.0.0.0', 4],
   86:       ['240.0.0.0', 4]
   87:     ]
   88: 
   89:     return ranges.some(([baseIp, prefixLength]) => isIpv4InCidr(ip, baseIp, prefixLength))
   90:   }
   91: 
   92:   if (family === 6) {
   93:     return isIpv6PrivateOrReserved(ip)
   94:   }
   95: 
   96:   return true
   97: }
   98: 
   99: async function assertPublicHostname(hostname: string): Promise<void> {
  100:   const normalizedHost = hostname.trim().toLowerCase().replace(/\.$/, '')
  101:   if (!normalizedHost) {
  102:     throw new OutboundTargetValidationError('Hostname cannot be empty')
  103:   }
  104: 
  105:   if (
  106:     normalizedHost === 'localhost' ||
  107:     normalizedHost.endsWith('.localhost') ||
  108:     normalizedHost.endsWith('.local') ||
  109:     normalizedHost.endsWith('.internal')
  110:   ) {
  111:     throw new OutboundTargetValidationError('Private or local targets are not allowed')
  112:   }
  113: 
  114:   const family = isIP(normalizedHost)
  115:   if (family !== 0) {
  116:     if (isIpPrivateOrReserved(normalizedHost)) {
  117:       throw new OutboundTargetValidationError('Private or reserved IP targets are not allowed')
  118:     }
  119:     return
  120:   }
  121: 
  122:   if (!normalizedHost.includes('.')) {
  123:     throw new OutboundTargetValidationError('Private or local hostnames are not allowed')
  124:   }
  125: 
  126:   let records: Array<{ address: string }>
  127:   try {
  128:     records = await dnsLookup(normalizedHost, { all: true, verbatim: true })
  129:   } catch (error: any) {
  130:     const code = error?.code ? String(error.code) : 'UNKNOWN'
  131:     throw new OutboundTargetValidationError(`Unable to resolve hostname (${code})`)
  132:   }
  133: 
  134:   if (records.length === 0) {
  135:     throw new OutboundTargetValidationError('Unable to resolve hostname')
  136:   }
  137: 
  138:   for (const record of records) {
  139:     if (isIpPrivateOrReserved(record.address)) {
  140:       throw new OutboundTargetValidationError('Targets resolving to private or reserved IPs are not allowed')
  141:     }
  142:   }
  143: }
