  450: /**
  451:  * ç»­è´¹è®¢é˜…
  452:  */
  453: export async function renewMailSubscription(id: number, months: number): Promise<MailSubscription> {
  454:   if (!Number.isSafeInteger(months) || months < 1 || months > 12) {
  455:     throw new Error('Invalid mail renewal months')
  456:   }
  457: 
  458:   const subscription = await prisma.mailSubscription.findUnique({ where: { id } })
  459:   if (!subscription) throw new Error('Subscription not found')
  460:   
  461:   const currentExpiry = subscription.expiresAt > new Date() ? subscription.expiresAt : new Date()
  462:   const newExpiry = new Date(currentExpiry)
  463:   newExpiry.setMonth(newExpiry.getMonth() + months)
  464:   
  465:   return prisma.mailSubscription.update({
  466:     where: { id },
  467:     data: { expiresAt: newExpiry, status: 'active' }
  468:   })
  469: }
