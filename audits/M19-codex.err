  189: /**
  190:  * èŽ·å–é‚®ç®±è´¦æˆ·ä¿¡æ¯
  191:  */
  192: export async function getAccountInfo(
  193:   source: MailSource,
  194:   domain: string,
  195:   adminUsername: string,
  196:   adminPassword: string,
  197:   username: string
  198: ): Promise<{
  199:   email: string
  200:   displayName: string
  201:   diskLimitMb: number
  202:   diskUsedMb: number
  203:   isEnabled: boolean
  204: } | null> {
  205:   try {
  206:     const result = await callApi(source, domain, adminUsername, adminPassword, 'POST', '/settings/domain/users/user-get', {
  207:       userName: username,
  208:       domain: domain
  209:     })
  210: 
  211:     if (!result.userData) return null
  212: 
  213:     return {
  214:       email: `${result.userData.userName}@${domain}`,
  215:       displayName: result.userData.displayName || result.userData.userName,
  216:       diskLimitMb: result.userData.maxMailboxSize || 0,
  217:       diskUsedMb: result.userData.mailboxSizeUsed || 0,
  218:       isEnabled: result.userData.isEnabled !== false
  219:     }
  220:   } catch {
  221:     return null
  222:   }
  223: }
  224: 
  225: /**
  226:  * èŽ·å–åŸŸä¸‹æ‰€æœ‰è´¦æˆ·
  227:  */
  228: export async function listAccounts(
  229:   source: MailSource,
  230:   domain: string,
  231:   adminUsername: string,
  232:   adminPassword: string
  233: ): Promise<Array<{
  234:   username: string
  235:   email: string
  236:   displayName: string
  237:   diskLimitMb: number
  238:   diskUsedMb: number
  239: }>> {
  240:   const result = await callApi(source, domain, adminUsername, adminPassword, 'GET', `/settings/domain/users/list?domain=${domain}`, undefined)
  241: 
  242:   if (!result.users || !Array.isArray(result.users)) {
  243:     return []
  244:   }
  245: 
  246:   return result.users.map((user: any) => ({
  247:     username: user.userName,
  248:     email: `${user.userName}@${domain}`,
  249:     displayName: user.displayName || user.userName,
  250:     diskLimitMb: user.maxMailboxSize || 0,
  251:     diskUsedMb: user.mailboxSizeUsed || 0
  252:   }))
  253: }
===== server/src/services/mail-expiry-scheduler.ts =====
    1: /**
    2:  * é‚®ç®±è®¢é˜…è¿‡æœŸæ£€æŸ¥å®šæ—¶ä»»åŠ¡
    3:  * æ£€æŸ¥å¹¶å¤„ç†å·²è¿‡æœŸçš„é‚®ç®±è®¢é˜…
    4:  */
    5: 
    6: import { prisma } from '../db/prisma.js'
    7: 
    8: let schedulerInterval: NodeJS.Timeout | null = null
    9: 
   10: /**
   11:  * æ£€æŸ¥å¹¶æ›´æ–°è¿‡æœŸçš„é‚®ç®±è®¢é˜…
   12:  */
   13: export async function checkMailSubscriptionExpiry(): Promise<void> {
   14:   const now = new Date()
   15:   
   16:   try {
   17:     // æŸ¥æ‰¾æ‰€æœ‰å·²è¿‡æœŸä½†çŠ¶æ€ä»ä¸º active çš„è®¢é˜…
   18:     const expiredSubscriptions = await prisma.mailSubscription.findMany({
   19:       where: {
   20:         status: 'active',
   21:         expiresAt: { lt: now }
   22:       },
   23:       select: {
   24:         id: true,
   25:         userId: true,
   26:         expiresAt: true,
   27:         user: { select: { username: true } }
   28:       }
   29:     })
   30: 
   31:     if (expiredSubscriptions.length === 0) {
   32:       return
   33:     }
   34: 
   35:     console.log(`[Mail] Found ${expiredSubscriptions.length} expired mail subscription candidate(s)`)
   36: 
   37:     // æ‰¹é‡æ›´æ–°çŠ¶æ€ä¸º expiredã€‚ç»­è´¹å¯èƒ½åœ¨ findMany åŽå‘ç”Ÿï¼Œæ‰€ä»¥æ›´æ–°æ—¶å¿…é¡»é‡æŸ¥ expiresAtã€‚
   38:     const result = await prisma.mailSubscription.updateMany({
   39:       where: {
   40:         id: { in: expiredSubscriptions.map(s => s.id) },
   41:         status: 'active',
   42:         expiresAt: { lt: now }
   43:       },
   44:       data: { status: 'expired' }
   45:     })
   46: 
   47:     console.log(`[Mail] Updated ${result.count} mail subscriptions to expired status`)
   48:   } catch (error) {
   49:     console.error('[Mail] Error checking mail subscription expiry:', error)
   50:     throw error
   51:   }
   52: }
   53: 
   54: /**
   55:  * å¯åŠ¨é‚®ç®±è®¢é˜…è¿‡æœŸæ£€æŸ¥å®šæ—¶ä»»åŠ¡
   56:  * æ¯å°æ—¶æ‰§è¡Œä¸€æ¬¡
   57:  */
   58: export function startMailExpiryScheduler(): NodeJS.Timeout {
   59:   if (schedulerInterval) {
   60:     return schedulerInterval
   61:   }
   62: 
   63:   const INTERVAL = 60 * 60 * 1000 // 1 å°æ—¶
   64: 
   65:   console.log('[Mail] Starting mail subscription expiry scheduler')
   66: 
   67:   // å¯åŠ¨æ—¶ç«‹å³æ‰§è¡Œä¸€æ¬¡
   68:   checkMailSubscriptionExpiry().catch(err => {
   69:     console.error('[Mail] Initial mail expiry check failed:', err)
   70:   })
   71: 
   72:   // è®¾ç½®å®šæ—¶æ‰§è¡Œ
   73:   schedulerInterval = setInterval(() => {
   74:     checkMailSubscriptionExpiry().catch(err => {
   75:       console.error('[Mail] Scheduled mail expiry check failed:', err)
   76:     })
   77:   }, INTERVAL)
   78: 
   79:   return schedulerInterval
   80: }

