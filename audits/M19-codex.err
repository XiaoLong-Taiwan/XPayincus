  350:     throw apiError(ErrorCode.VALIDATION_ERROR, `é€€æ¬¾åŽŸå› ä¸èƒ½è¶…è¿‡ ${MAIL_CANCEL_REASON_MAX_LENGTH} ä¸ªå­—ç¬¦`)
  351:   }
  352: 
  353:   if (refundType !== 'none' && !reason) {
  354:     throw apiError(ErrorCode.VALIDATION_ERROR, 'é€€æ¬¾æ—¶å¿…é¡»å¡«å†™åŽŸå› ')
  355:   }
  356: 
  357:   return {
  358:     refundType,
  359:     ...(reason ? { reason } : {})
  360:   }
  361: }
  362: 
  363: function parseOptionalPositiveQueryInteger(value: string | undefined, max = Number.MAX_SAFE_INTEGER): number | undefined {
  364:   if (!value) {
  365:     return undefined
  366:   }
  367: 
  368:   if (!POSITIVE_ROUTE_ID_RE.test(value)) {
  369:     return undefined
  370:   }
  371: 
  372:   const parsed = Number(value)
  373:   return Number.isSafeInteger(parsed) && parsed > 0 && parsed <= max ? parsed : undefined
  374: }
  375: 
  376: function parsePositiveQueryInteger(value: string | undefined, fallback: number, max = Number.MAX_SAFE_INTEGER): number {
  377:   return parseOptionalPositiveQueryInteger(value, max) ?? fallback
  378: }
  379: 
  380: function parsePositiveRouteId(value: unknown): number {
  381:   if (typeof value === 'number') {
  382:     if (Number.isSafeInteger(value) && value > 0) return value
  383:     throw apiError(ErrorCode.INVALID_PARAMS, 'ID æ— æ•ˆ')
  384:   }
  385: 
  386:   if (typeof value !== 'string' || !POSITIVE_ROUTE_ID_RE.test(value)) {
  387:     throw apiError(ErrorCode.INVALID_PARAMS, 'ID æ— æ•ˆ')
  388:   }
  389: 
  390:   const parsed = Number(value)
  391:   if (!Number.isSafeInteger(parsed)) {
  392:     throw apiError(ErrorCode.INVALID_PARAMS, 'ID æ— æ•ˆ')
  393:   }
  394: 
  395:   return parsed
  396: }
  397: 
  398: async function validateMailSourceOutboundUrls(input: {
  399:   apiUrl?: string
  400:   smarterMailUrl?: string
  401: }): Promise<{ apiUrl?: string; smarterMailUrl?: string }> {
  402:   try {
  403:     return {
  404:       ...(input.apiUrl !== undefined
  405:         ? { apiUrl: normalizeBaseUrl(await assertSafeHttpUrl(input.apiUrl, 'CraneMail API URL')) }
  406:         : {}),
  407:       ...(input.smarterMailUrl !== undefined
  408:         ? { smarterMailUrl: normalizeBaseUrl(await assertSafeHttpUrl(input.smarterMailUrl, 'SmarterMail URL')) }
  409:         : {})
  410:     }
  411:   } catch (error) {
  412:     const message = error instanceof Error ? error.message : 'é‚®ç®±æºåœ°å€æ— æ•ˆ'
  413:     throw apiError(ErrorCode.VALIDATION_ERROR, message)
  414:   }
  415: }
