  334: export async function getUserMailSubscription(userId: number): Promise<(MailSubscription & {
  335:   source: MailSource
  336:   plan: MailPlan
  337:   domains: MailDomain[]
  338: }) | null> {
  339:   const subscription = await prisma.mailSubscription.findFirst({
  340:     where: { userId, status: 'active' },
  341:     include: {
  342:       source: true,
  343:       plan: true,
  344:       domains: {
  345:         include: { accounts: true }
  346:       }
  347:     }
  348:   })
  349:   return subscription ? withDecryptedSource(subscription) : null
  350: }
  351: 
  352: /**
  353:  * èŽ·å–æ‰€æœ‰è®¢é˜…ï¼ˆç®¡ç†å‘˜ç”¨ï¼‰
  354:  */
  355: export async function getAllMailSubscriptions(options?: {
  356:   sourceId?: number
  357:   status?: MailSubscriptionStatus | string
  358:   search?: string
  359:   page?: number
  360:   pageSize?: number
  361: }): Promise<{
  362:   subscriptions: (MailSubscription & { user: { id: number; username: string; email: string | null; avatarStyle: string | null; avatarBadgeId: string | null }; source: MailSource; plan: MailPlan })[]
  363:   total: number
  364: }> {
  365:   const { page, pageSize } = clampMailListPagination(options?.page, options?.pageSize)
  366:   const sourceId = normalizePositiveMailSourceId(options?.sourceId)
  367:   const status = normalizeMailSubscriptionStatus(options?.status)
  368:   const searchTerm = normalizeMailListSearch(options?.search)
  369:   const searchUserId = parseMailSearchUserId(searchTerm)
  370:   
  371:   const where: any = {
  372:     ...(sourceId ? { sourceId } : {}),
  373:     ...(status ? { status } : {})
  374:   }
  375:   
  376:   // æœç´¢æ¡ä»¶ï¼šç”¨æˆ·åã€é‚®ç®±ã€ç”¨æˆ·ID
  377:   if (searchTerm) {
  378:     where.OR = [
  379:       { user: { username: { contains: searchTerm, mode: 'insensitive' } } },
  380:       { user: { email: { contains: searchTerm, mode: 'insensitive' } } },
  381:       ...(searchUserId ? [{ userId: searchUserId }] : [])
  382:     ]
  383:   }
  384:   
  385:   const [subscriptions, total] = await Promise.all([
  386:     prisma.mailSubscription.findMany({
  387:       where,
  388:       include: {
  389:         user: { select: { id: true, username: true, email: true, avatarStyle: true, avatarBadgeId: true } },
  390:         source: true,
  391:         plan: true
  392:       },
  393:       orderBy: { createdAt: 'desc' },
  394:       skip: (page - 1) * pageSize,
  395:       take: pageSize
  396:     }),
  397:     prisma.mailSubscription.count({ where })
  398:   ])
  399:   
  400:   return { subscriptions: subscriptions.map(withDecryptedSource), total }
  401: }
