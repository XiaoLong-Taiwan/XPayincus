  151: // DNS è®°å½•æ ¼å¼åŒ–å‡½æ•°
  152: function formatHostRecord(record: string): string {
  153:   // å¦‚æžœæ˜¯ @ï¼Œç›´æŽ¥è¿”å›ž
  154:   if (record === '@') return '@'
  155:   // ç§»é™¤æœ«å°¾çš„ç‚¹
  156:   return record.replace(/\.$/, '')
  157: }
  158: 
  159: function formatRecordValue(record: { type: string; value: string; prio?: number }): string {
  160:   // MX è®°å½•æ˜¾ç¤ºä¼˜å…ˆçº§
  161:   if (record.type === 'MX' && record.prio !== undefined) {
  162:     return `${record.prio} ${record.value}`
  163:   }
  164:   return record.value
  165: }
  166: 
  167: function getDnsRecordDescription(record: { type: string; value: string; record?: string }): string {
  168:   switch (record.type) {
  169:     case 'MX': return t('mail.dnsHint.mx')
  170:     case 'CNAME': return t('mail.dnsHint.cname')
  171:     case 'TXT':
  172:       if (record.value?.toLowerCase().includes('spf')) return t('mail.dnsHint.spf')
  173:       if (record.value?.toLowerCase().includes('dkim')) return t('mail.dnsHint.dkim')
  174:       if (record.record === '_dmarc') return t('mail.dnsHint.dmarc')
  175:       return t('mail.dnsHint.txt')
  176:     default: return ''
  177:   }
  178: }
  179: 
  180: function getStatusBadge(status: string) {
  181:   switch (status) {
  182:     case 'verified': return 'badge-success'
  183:     case 'pending': return 'badge-warning'
  184:     case 'suspended': return 'badge-error'
  185:     default: return 'badge-ghost'
  186:   }
  187: }
  188: 
  189: function formatDate(dateStr: string) {
  190:   return new Date(dateStr).toLocaleDateString()
  191: }
