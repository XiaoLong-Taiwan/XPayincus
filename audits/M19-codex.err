  477:   const domains = await prisma.mailDomain.findMany({
  478:     where: { subscriptionId },
  479:     include: { accounts: true },
  480:     orderBy: { createdAt: 'desc' }
  481:   })
  482:   return domains.map(decryptMailDomainAdminPassword)
  483: }
