 295: // æ‰§è¡Œç­¾åˆ°
 296: async function doCheckin() {
 297:   if (
 298:     checkinStatus.value?.hasCheckedIn ||
 299:     checkinStatus.value?.enabled === false ||
 300:     (checkinStatus.value?.requireInstance && !checkinStatus.value?.hasInstances)
 301:   ) return
 302:   try {
 303:     checkinLoading.value = true
 304:     checkinPhase.value = 'shaking'
 305:     await new Promise(resolve => setTimeout(resolve, 1200))
 306:     checkinPhase.value = 'opening'
 307:     await new Promise(resolve => setTimeout(resolve, 600))
 308:     const result = await api.checkin.checkin()
 309:     checkinPhase.value = 'revealing'
 310:     const rewardPoints = result.points ?? result.bonusPoints ?? result.codeValue
 311:     checkinResult.value = { type: 'p', value: rewardPoints, bonusPoints: rewardPoints }
 312:     generateConfetti()
 313:     await new Promise(resolve => setTimeout(resolve, 100))
 314:     await nextTick()
 315:     checkinPhase.value = 'done'
 316:     // åˆ·æ–°æ•°æ®
 317:     await Promise.all([loadCheckinStatus(), loadResourcePool(), loadPoints()])
 318:     toast.success(t('checkin.checkinSuccess'))
 319:     // 3ç§’åŽè‡ªåŠ¨å›žåˆ° idle çŠ¶æ€
 320:     setTimeout(() => {
 321:       resetCheckinAnimation()
 322:     }, 3000)
 323:   } catch (err: any) {
 324:     toast.error(translateError(err))
 325:     checkinPhase.value = 'idle'
 326:   } finally {
 327:     checkinLoading.value = false
 328:   }
 329: }
