 380: export async function getPointsLogs(
 381:   userId: number,
 382:   options: { page?: number; pageSize?: number; type?: PointsLogType } = {}
 383: ) {
 384:   const { page, pageSize } = clampPagination(options.page, options.pageSize)
 385:   const type = normalizePointsLogType(options.type)
 386:   const skip = (page - 1) * pageSize
 387: 
 388:   const where: Prisma.PointsLogWhereInput = { userId }
 389:   if (type) {
 390:     where.type = type
 391:   }
 392: 
 393:   const [logs, total] = await Promise.all([
 394:     prisma.pointsLog.findMany({
 395:       where,
 396:       orderBy: { createdAt: 'desc' },
 397:       take: pageSize,
 398:       skip
 399:     }),
 400:     prisma.pointsLog.count({ where })
 401:   ])
 402: 
 403:   return { logs, total, page, pageSize }
 404: }
 405: 
 406: /**
 407:  * èŽ·å–æ‰€æœ‰ç”¨æˆ·ç§¯åˆ†åˆ—è¡¨ï¼ˆç®¡ç†ç«¯ï¼‰
 408:  */
 409: export async function getAllUserPoints(options: {
 410:   page?: number
 411:   pageSize?: number
 412:   search?: string
 413:   orderBy?: 'points' | 'totalEarned' | 'totalSpent' | string
 414:   order?: 'asc' | 'desc' | string
 415: } = {}) {
 416:   const { page, pageSize } = clampPagination(options.page, options.pageSize)
 417:   const { search } = options
 418:   const orderBy = normalizeUserPointsOrderBy(options.orderBy)
 419:   const order = normalizeSortOrder(options.order)
 420:   const skip = (page - 1) * pageSize
 421: 
 422:   const where: Prisma.UserPointsWhereInput = {}
 423:   if (search) {
 424:     const keyword = search.trim().slice(0, 128)
 425:     where.user = {
 426:       username: { contains: keyword, mode: 'insensitive' }
 427:     }
 428:   }
 429: 
 430:   const [records, total] = await Promise.all([
 431:     prisma.userPoints.findMany({
 432:       where,
 433:       include: {
 434:         user: {
 435:           select: { id: true, username: true, avatarStyle: true }
 436:         }
 437:       },
 438:       orderBy: { [orderBy]: order },
 439:       take: pageSize,
 440:       skip
 441:     }),
 442:     prisma.userPoints.count({ where })
 443:   ])
 444: 
 445:   return { records, total, page, pageSize }
 446: }
