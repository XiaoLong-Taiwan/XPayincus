 122: function toNumber(value: unknown): number {
 123:   if (value === null || value === undefined) return 0
 124:   if (typeof value === 'number') return Number.isFinite(value) ? value : 0
 125:   if (typeof value === 'bigint') return Number(value)
 126:   return Number.parseFloat(String(value)) || 0
 127: }
 128: 
 129: function nullableMoney(value: unknown): number | null {
 130:   if (value === null || value === undefined || value === '') return null
 131:   const parsed = Number(value)
 132:   if (!Number.isFinite(parsed) || parsed < 0 || parsed > MAX_MONEY_THRESHOLD) {
 133:     throw new Error(`Money threshold must be between 0 and ${MAX_MONEY_THRESHOLD}`)
 134:   }
 135:   return Math.round(parsed * 100) / 100
 136: }
 137: 
 138: function nullableCount(value: unknown): number | null {
 139:   if (value === null || value === undefined || value === '') return null
 140:   const parsed = Number(value)
 141:   if (!Number.isFinite(parsed) || parsed < 0 || parsed > MAX_INSTANCE_THRESHOLD) {
 142:     throw new Error(`Instance threshold must be between 0 and ${MAX_INSTANCE_THRESHOLD}`)
 143:   }
 144:   if (!Number.isInteger(parsed)) {
 145:     throw new Error('Instance threshold must be an integer')
 146:   }
 147:   return parsed
 148: }
 149: 
 150: function hasThreshold(value: number | null): boolean {
 151:   return value !== null && value > 0
 152: }
 153: 
 154: function roundAmount(value: number): number {
 155:   return Math.round(value * 100) / 100
 156: }
 157: 
 158: function toProgressPercent(current: number, target: number): number {
 159:   if (!Number.isFinite(current) || !Number.isFinite(target) || target <= 0) return 0
 160:   return Math.max(0, Math.min(100, Math.round((current / target) * 100)))
 161: }
