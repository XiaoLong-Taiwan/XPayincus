 705: export async function calculateUserVipLevel(userId: number): Promise<{ level: number; stats: UserVipStats }> {
 706:   const [rules, stats, userMetric] = await Promise.all([
 707:     getVipRules('user'),
 708:     getUserVipStats(userId),
