 588: export async function applyBadgeToAvatar(userId: number, ownershipId: number) {
 589:   return runBadgeTransaction(async (tx) => {
 590:     const [user, ownership, badgeMap] = await Promise.all([
 591:       tx.user.findUnique({
 592:         where: { id: userId },
 593:         select: { avatarBadgeId: true }
 594:       }),
 595:       tx.userBadgeOwnership.findFirst({
 596:         where: { id: ownershipId, userId },
 597:         include: {
 598:           appliedInstance: {
 599:             select: { id: true, name: true }
 600:           }
 601:         }
 602:       }),
 603:       getBadgeCatalogMap(tx)
 604:     ])
 605: 
 606:     if (!ownership) {
 607:       throw new Error('BADGE_OWNERSHIP_NOT_FOUND')
 608:     }
 609: 
 610:     if (ownership.applicationTarget === 'avatar' && user?.avatarBadgeId === ownership.badgeId) {
 611:       return mapBadgeOwnership(ownership, badgeMap)
 612:     }
 613: 
 614:     if (ownership.applicationTarget === 'instance' && ownership.appliedInstanceId) {
