 728: export async function getVipOverview(userId: number): Promise<VipOverview> {
 729:   const [userRules, hostingRules, userStats, hostingStats, userVipMetric] = await Promise.all([
 730:     getVipRules('user'),
 731:     getVipRules('hosting'),
 732:     getUserVipStats(userId),
 733:     getHostingVipStats(userId),
 734:     getUserVipMetric()
 735:   ])
 736: 
 737:   const userVipLevel = calculateUserVipLevelByMetric(userRules, userStats, userVipMetric)
 738:   const hostingVipLevel = calculateVipLevel('hosting', hostingRules, hostingStats)
 739: 
 740:   return {
 741:     userVipLevel,
 742:     hostingVipLevel,
 743:     userVipBadgeStyle: getVipBadgeStyleForLevel(userRules, 'user', userVipLevel),
 744:     hostingVipBadgeStyle: getVipBadgeStyleForLevel(hostingRules, 'hosting', hostingVipLevel),
 745:     userVipMetric,
 746:     userStats,
 747:     hostingStats,
 748:     userVipProgress: calculateVipProgress('user', userRules, userVipLevel, userStats, userVipMetric),
 749:     hostingVipProgress: calculateVipProgress('hosting', hostingRules, hostingVipLevel, hostingStats)
 750:   }
 751: }
 752: 
 753: export function buildHostingVipSql(rules: NormalizedVipRule[]): Prisma.Sql {
 754:   const orderedRules = rules
 755:     .filter(rule => rule.enabled && hasActiveCondition('hosting', rule))
 756:     .sort((a, b) => b.level - a.level)
 757: 
 758:   if (orderedRules.length === 0) {
 759:     return Prisma.sql`"id" * 0`
 760:   }
 761: 
 762:   const cases = orderedRules.map((rule) => {
 763:     const conditions: Prisma.Sql[] = []
 764:     if (hasThreshold(rule.minHostingIncome)) {
 765:       conditions.push(Prisma.sql`"totalHostingIncome" >= ${rule.minHostingIncome}`)
 766:     }
 767:     if (hasThreshold(rule.minHostingInstances)) {
 768:       conditions.push(Prisma.sql`"instanceCount" >= ${rule.minHostingInstances}`)
 769:     }
 770: 
 771:     const conditionSql = rule.conditionMode === 'all'
 772:       ? Prisma.join(conditions, ' AND ')
 773:       : Prisma.join(conditions, ' OR ')
 774: 
 775:     return Prisma.sql`WHEN ${conditionSql} THEN ${rule.level}`
 776:   })
 777: 
 778:   return Prisma.sql`CASE ${Prisma.join(cases, ' ')} ELSE 0 END`
 779: }

