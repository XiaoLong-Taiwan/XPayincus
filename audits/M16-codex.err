  31: async function withSystemRedeemLocks<T>(
  32:   redeemCodeId: number,
  33:   userId: number,
  34:   batchId: string | null,
  35:   fn: () => Promise<T>
  36: ): Promise<T> {
  37:   const lockKeys = [
  38:     `redeem-code:${redeemCodeId}`,
  39:     ...(batchId ? [`redeem-batch:${batchId}:user:${userId}`] : [])
  40:   ]
  41:   const acquired: Array<{ lockKey: string; ownerId: string }> = []
  42: 
  43:   try {
  44:     for (const lockKey of lockKeys) {
  45:       const lock = await acquireLock(lockKey, {
  46:         expireMs: 120_000,
  47:         waitTimeoutMs: 10_000,
  48:         retryIntervalMs: 100
  49:       })
  50:       if (!lock.success || !lock.ownerId) {
  51:         throw new Error('REDEEM_CODE_BUSY')
  52:       }
  53:       acquired.push({ lockKey, ownerId: lock.ownerId })
  54:     }
  55: 
  56:     return await fn()
  57:   } finally {
  58:     for (const lock of acquired.reverse()) {
  59:       await releaseLock(lock.lockKey, lock.ownerId)
  60:     }
  61:   }
  62: }
