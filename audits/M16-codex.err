 495:           const isRetryable = err.code === 'P2034' ||
 496:             err.message?.includes('deadlock') ||
 497:             err.message?.includes('write conflict') ||
 498:             err.message?.includes('could not serialize')
 499:           
 500:           if (isRetryable && attempt < maxRetries) {
 501:             const baseDelay = Math.floor(Math.random() * 250) + 50
 502:             const delay = baseDelay * attempt
 503:             await new Promise(resolve => setTimeout(resolve, delay))
 504:             continue
 505:           }
 506:           // éžå¯é‡è¯•é”™è¯¯ï¼Œè¿”å›žå·²æœ‰ç»“æžœ
 507:           return {
 508:             success: results.length > 0,
