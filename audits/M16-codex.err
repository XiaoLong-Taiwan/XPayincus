 411:       let newRemainQuantity = prize.remainQuantity
 412:       if (prize.replenishAmount && prize.replenishAmount > 0) {
 413:         newRemainQuantity = (prize.remainQuantity || 0) + prize.replenishAmount
 414:       }
 415:       
 416:       const prizeData = {
 417:         name: prize.name.trim(),
 418:         type: prize.type,
 419:         value: prize.value || 0,
 420:         probability: prize.probability,
 421:         totalQuantity: prize.totalQuantity || undefined,
 422:         remainQuantity: newRemainQuantity,
 423:         displayOrder: i,
 424:         instanceDesc: prize.type === 'instance' ? prize.instanceDesc : undefined
 425:       }
 426:       
 427:       if (prize.id && existingIds.includes(prize.id)) {
 428:         // æ›´æ–°çŽ°æœ‰å¥–å“
 429:         await api.entertainment.adminUpdatePrize(prize.id, prizeData)
 430:       } else {
 431:         // åˆ›å»ºæ–°å¥–å“
 432:         await api.entertainment.adminCreatePrize(lotteryId, prizeData)
 433:       }
 434:     }
 435:     
 436:     toast.success(t('entertainment.admin.savePrizesSuccess'))
 437:     showPrizesModal.value = false
 438:     loadLotteries()
 439:   } catch (err: any) {
 440:     toast.error(t('entertainment.admin.savePrizesFailed') + ': ' + err.message)
 441:   } finally {
 442:     savingPrizes.value = false
 443:   }
 444: }
