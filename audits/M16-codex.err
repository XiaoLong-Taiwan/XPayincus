 286: export async function performDailyPointsCheckin(
 287:   userId: number,
 288:   meta: DailyCheckinMeta = {}
 289: ): Promise<{
 290:   id: number
 291:   dateKey: string
 292:   points: number
 293:   streakDays: number
 294:   currentPoints: number
 295: }> {
 296:   const settings = await getDailyCheckinSettings()
 297:   if (!settings.enabled) {
 298:     throw new Error('CHECKIN_DISABLED')
 299:   }
 300: 
 301:   const [user, hasInstances] = await Promise.all([
 302:     prisma.user.findUnique({ where: { id: userId }, select: { status: true } }),
 303:     settings.requireInstance ? userHasInstances(userId) : Promise.resolve(true)
 304:   ])
 305: 
 306:   if (!user || user.status !== 'active') {
 307:     throw new Error('CHECKIN_USER_BLOCKED')
 308:   }
 309:   if (settings.requireInstance && !hasInstances) {
 310:     throw new Error('CHECKIN_NO_INSTANCE')
 311:   }
 312: 
 313:   const now = new Date()
 314:   const dateKey = getBeijingDateKey(now)
 315:   const yesterdayKey = getYesterdayDateKey(dateKey)
 316:   const points = randomizePoints(settings.minPoints, settings.maxPoints)
 317: 
 318:   try {
 319:     return await prisma.$transaction(async (tx) => {
 320:       await advisoryTransactionLock(tx, USER_POINTS_LOCK_NAMESPACE, userId)
 321: 
 322:       const existing = await tx.dailyCheckin.findUnique({
 323:         where: { userId_dateKey: { userId, dateKey } },
 324:         select: { id: true }
 325:       })
 326:       if (existing) {
 327:         throw new Error('CHECKIN_ALREADY_TODAY')
 328:       }
 329: 
 330:       const lastRecord = await tx.dailyCheckin.findFirst({
 331:         where: { userId },
 332:         orderBy: { createdAt: 'desc' },
 333:         select: { dateKey: true, streakDays: true }
 334:       })
 335:       const streakDays = lastRecord?.dateKey === yesterdayKey
 336:         ? lastRecord.streakDays + 1
 337:         : 1
 338: 
 339:       const userPoints = await tx.userPoints.upsert({
 340:         where: { userId },
 341:         update: {},
 342:         create: { userId }
 343:       })
 344:       const currentPoints = userPoints.points + points
 345:       if (currentPoints > 2_147_483_647) {
 346:         throw new Error('CHECKIN_POINTS_LIMIT_EXCEEDED')
 347:       }
 348: 
 349:       const record = await tx.dailyCheckin.create({
 350:         data: {
 351:           userId,
 352:           dateKey,
 353:           points,
 354:           streakDays,
 355:           ipAddress: meta.ipAddress?.slice(0, 255) || null,
 356:           userAgent: meta.userAgent?.slice(0, 500) || null
 357:         }
 358:       })
 359: 
 360:       const updatedPoints = await tx.userPoints.update({
 361:         where: { userId },
 362:         data: {
 363:           points: { increment: points },
 364:           totalEarned: { increment: points }
 365:         }
 366:       })
 367: 
 368:       await tx.pointsLog.create({
 369:         data: {
 370:           userId,
 371:           type: 'checkin',
 372:           amount: points,
 373:           pointsBefore: userPoints.points,
 374:           pointsAfter: updatedPoints.points,
 375:           relatedId: record.id,
 376:           remark: `æ¯æ—¥ç­¾åˆ°å¥–åŠ± ${points} ç§¯åˆ†`
 377:         }
 378:       })
 379: 
 380:       await tx.checkinStats.upsert({
 381:         where: { userId },
 382:         update: { lastCheckinDate: now },
 383:         create: {
 384:           userId,
 385:           lastCheckinDate: now
 386:         }
 387:       })
 388: 
 389:       return {
 390:         id: record.id,
