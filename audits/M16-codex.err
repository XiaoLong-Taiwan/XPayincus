 389: async function getCurrentUserVip(userId: number, client: DbClient = prisma): Promise<{
 390:   level: number
 391:   metric: UserVipMetric
 392:   stats: UserVipStats
 393:   badgeStyle: VipBadgeStyle | null
 394: }> {
 395:   const metric = await getUserVipMetric()
 396:   const [rules, stats] = await Promise.all([
 397:     getVipRules('user', client),
 398:     getUserVipStats(userId, client)
 399:   ])
 400:   const level = calculateUserVipLevelByMetric(rules, stats, metric)
 401:   return {
 402:     level,
 403:     metric,
 404:     stats,
 405:     badgeStyle: getVipBadgeStyleForLevel(rules, 'user', level)
 406:   }
 407: }
