 496: export async function performRandomBadgeMultiDraw(userId: number, drawCount = 10) {
 497:   if (drawCount <= 0) {
 498:     return {
 499:       success: false as const,
 500:       points: 0,
 501:       ownerships: [] as BadgeOwnershipView[]
 502:     }
 503:   }
 504: 
 505:   const totalCost = BADGE_RANDOM_DRAW_COST * drawCount
 506: 
 507:   const result = await runBadgeTransaction(async (tx) => {
 508:     const spendResult = await spendBadgePoints(
 509:       tx,
 510:       userId,
 511:       totalCost,
 512:       'badge_draw_spend',
 513:       `å¾½ç« åè¿žæŠ½å–ï¼š${drawCount} æ¬¡`
 514:     )
 515: 
 516:     if (!spendResult.success) {
 517:       return {
 518:         success: false as const,
 519:         points: spendResult.points,
 520:         ownerships: [] as BadgeOwnershipView[]
 521:       }
 522:     }
 523: 
 524:     const ownerships: BadgeOwnershipView[] = []
 525:     for (let index = 0; index < drawCount; index += 1) {
 526:       const selected = await selectRandomBadgeOrThrow(tx)
 527:       ownerships.push(await createBadgeOwnership(tx, userId, selected.id, 'draw', selected))
 528:     }
 529: 
 530:     return {
 531:       success: true as const,
 532:       points: spendResult.points,
 533:       ownerships
 534:     }
 535:   })
 536: 
 537:   if (!result.success) {
 538:     return result
 539:   }
 540: 
 541:   return {
 542:     success: true as const,
 543:     points: result.points,
 544:     ownerships: result.ownerships
 545:   }
 546: }
