 124: function toNumber(value: unknown): number {
 125:   if (value === null || value === undefined) return 0
 126:   const numberValue = Number(value)
 127:   return Number.isFinite(numberValue) ? numberValue : 0
 128: }
 129: 
 130: function roundMoney(value: number): number {
 131:   return Math.round(value * 100) / 100
 132: }
 133: 
 134: function getRecord(value: unknown): Record<string, unknown> {
 135:   return value && typeof value === 'object' && !Array.isArray(value)
 136:     ? value as Record<string, unknown>
 137:     : {}
 138: }
 139: 
 140: function requireSafeInteger(value: unknown, field: string): number {
 141:   if (typeof value !== 'number' || !Number.isSafeInteger(value)) {
 142:     throw new VipBenefitError('INVALID_NUMBER', `${field} must be a safe integer`)
 143:   }
 144:   return value
 145: }
 146: 
 147: function requireFiniteNumber(value: unknown, field: string): number {
 148:   if (typeof value !== 'number' || !Number.isFinite(value)) {
 149:     throw new VipBenefitError('INVALID_NUMBER', `${field} must be a finite number`)
 150:   }
 151:   return value
 152: }
 153: 
 154: function normalizeLevel(value: unknown): number {
 155:   const level = requireSafeInteger(value, 'VIP level')
 156:   if (level < 1 || level > MAX_VIP_LEVEL) {
 157:     throw new VipBenefitError('INVALID_LEVEL', `VIP level must be between 1 and ${MAX_VIP_LEVEL}`)
 158:   }
 159:   return level
 160: }
 161: 
 162: function normalizeRewardType(value: unknown): VipBenefitRewardTypeValue {
 163:   if (typeof value === 'string' && REWARD_TYPES.has(value as VipBenefitRewardTypeValue)) {
 164:     return value as VipBenefitRewardTypeValue
 165:   }
 166:   throw new VipBenefitError('INVALID_REWARD_TYPE', 'Invalid VIP benefit reward type')
 167: }
 168: 
 169: function normalizeTitle(value: unknown): string {
 170:   if (typeof value !== 'string') {
 171:     throw new VipBenefitError('INVALID_TITLE', 'Reward title is required')
 172:   }
 173:   const title = value.trim()
 174:   if (!title) {
 175:     throw new VipBenefitError('INVALID_TITLE', 'Reward title is required')
 176:   }
 177:   if (title.length > MAX_TITLE_LENGTH) {
 178:     throw new VipBenefitError('INVALID_TITLE', `Reward title cannot exceed ${MAX_TITLE_LENGTH} characters`)
 179:   }
 180:   return title
 181: }
 182: 
 183: function normalizeDescription(value: unknown): string | null {
 184:   if (value === null || value === undefined) return null
 185:   if (typeof value !== 'string') return null
 186:   const description = value.trim()
 187:   if (!description) return null
 188:   return description.slice(0, MAX_DESCRIPTION_LENGTH)
 189: }
 190: 
 191: function normalizePositiveInteger(value: unknown, field: string, max: number): number {
 192:   const parsed = requireSafeInteger(value, field)
 193:   if (parsed <= 0 || parsed > max) {
 194:     throw new VipBenefitError('INVALID_NUMBER', `${field} must be an integer between 1 and ${max}`)
 195:   }
 196:   return parsed
 197: }
 198: 
 199: function normalizeOptionalPositiveInteger(value: unknown, fallback: number, field: string, max: number): number {
 200:   if (value === null || value === undefined || value === '') return fallback
 201:   return normalizePositiveInteger(value, field, max)
 202: }
 203: 
 204: function normalizeMoney(value: unknown, field: string): number {
 205:   const parsed = requireFiniteNumber(value, field)
 206:   if (parsed <= 0 || parsed > MAX_MONEY_AMOUNT) {
 207:     throw new VipBenefitError('INVALID_AMOUNT', `${field} must be between 0.01 and ${MAX_MONEY_AMOUNT}`)
 208:   }
 209:   return roundMoney(parsed)
 210: }
 211: 
 212: function normalizeSortOrder(value: unknown): number {
 213:   if (value === null || value === undefined || value === '') return 0
 214:   const parsed = requireSafeInteger(value, 'Sort order')
 215:   if (parsed < 0 || parsed > MAX_SORT_ORDER) {
