 359:   if (applyForm.value.amount <= 0) { toast.warning(t('checkin.enterAmount')); return }
 360:   const maxAmount = resourcePool.value[applyForm.value.resourceType === 'c' ? 'cpu' : applyForm.value.resourceType === 'r' ? 'memory' : applyForm.value.resourceType === 'd' ? 'disk' : 'traffic']
 361:   if (applyForm.value.amount > maxAmount) { toast.warning(t('checkin.insufficientPool')); return }
 362:   try {
 363:     applyLoading.value = true
 364:     const result = await api.resourcePool.apply({
 365:       instanceId: applyForm.value.instanceId,
 366:       resourceType: applyForm.value.resourceType,
 367:       amount: applyForm.value.amount
 368:     })
 369:     toast.success(t('checkin.applySuccess', { type: getResourceTypeName(applyForm.value.resourceType), value: applyForm.value.amount, unit: getResourceUnit(applyForm.value.resourceType), instance: result.instanceName }))
 370:     applyForm.value.amount = 1
 371:     await loadResourcePool()
 372:   } catch (err: any) {
 373:     toast.error(translateError(err))
 374:   } finally {
 375:     applyLoading.value = false
 376:   }
