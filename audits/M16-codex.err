  11: const POSITIVE_ROUTE_ID_PATTERN = /^[1-9]\d*$/
  12: const POINTS_LOG_TYPES = new Set<PointsLogType>([
  13:   'convert',
  14:   'lottery_win',
  15:   'lottery_spend',
  16:   'admin_adjust',
  17:   'checkin',
  18:   'badge_draw_spend',
  19:   'badge_select_spend',
