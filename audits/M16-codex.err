 581: export async function claimVipBenefitReward(userId: number, rewardId: number): Promise<{
 582:   claim: VipBenefitClaimView
 583:   overview: VipBenefitOverview
 584: }> {
 585:   if (!Number.isSafeInteger(rewardId) || rewardId <= 0) {
 586:     throw new VipBenefitError('INVALID_REWARD_ID', 'Invalid VIP benefit reward ID')
 587:   }
 588: 
 589:   let createdClaim: VipBenefitClaim | null = null
 590:   try {
 591:     createdClaim = await prisma.$transaction(async (tx) => {
 592:       await advisoryTransactionLock(tx, USER_VIP_BENEFIT_CLAIM_LOCK_NAMESPACE, userId)
 593: 
 594:       const vip = await getCurrentUserVip(userId, tx)
 595:       const reward = await tx.vipBenefitReward.findFirst({
 596:         where: {
 597:           id: rewardId,
 598:           enabled: true
 599:         }
 600:       })
 601: 
 602:       if (!reward) {
 603:         throw new VipBenefitError('REWARD_NOT_FOUND', 'VIP benefit reward not found', 404)
 604:       }
 605:       if (reward.level > vip.level) {
 606:         throw new VipBenefitError('VIP_LEVEL_REQUIRED', `VIP${reward.level} is required to claim this reward`, 403)
 607:       }
 608: 
 609:       const lowerRewards = await tx.vipBenefitReward.findMany({
 610:         where: {
 611:           enabled: true,
 612:           level: {
 613:             lt: reward.level,
 614:             lte: vip.level
 615:           }
 616:         },
 617:         orderBy: [
 618:           { level: 'asc' },
 619:           { sortOrder: 'asc' },
 620:           { id: 'asc' }
 621:         ]
 622:       })
 623: 
 624:       const rewardIdsToCheck = [...lowerRewards.map(item => item.id), reward.id]
 625:       const relevantClaims = await tx.vipBenefitClaim.findMany({
 626:         where: {
 627:           userId,
 628:           rewardId: { in: rewardIdsToCheck }
 629:         },
 630:         select: {
 631:           rewardId: true
 632:         }
 633:       })
 634:       const claimCounts = new Map<number, number>()
 635:       for (const claim of relevantClaims) {
 636:         claimCounts.set(claim.rewardId, (claimCounts.get(claim.rewardId) || 0) + 1)
 637:       }
 638: 
 639:       const blockingReward = lowerRewards.find(item => (claimCounts.get(item.id) || 0) < item.claimLimit)
 640:       if (blockingReward) {
 641:         throw new VipBenefitError(
 642:           'LOWER_LEVEL_REWARD_REQUIRED',
 643:           `Please claim all VIP${blockingReward.level} rewards first`,
 644:           409
 645:         )
 646:       }
 647: 
 648:       const existingCount = claimCounts.get(reward.id) || 0
 649:       if (existingCount >= reward.claimLimit) {
 650:         throw new VipBenefitError('CLAIM_LIMIT_REACHED', 'This VIP benefit reward has already been fully claimed', 409)
 651:       }
 652: 
 653:       const type = reward.type as VipBenefitRewardTypeValue
 654:       const config = normalizeStoredRewardConfig(type, reward.config)
 655:       const claim = await tx.vipBenefitClaim.create({
 656:         data: {
 657:           userId,
 658:           rewardId: reward.id,
 659:           level: reward.level,
 660:           status: getDeliveryStatus(type),
 661:           claimNo: existingCount + 1,
 662:           snapshot: buildClaimSnapshot(reward, config),
 663:           deliveredAt: type === 'instance' ? null : new Date()
 664:         }
 665:       })
 666: 
 667:       if (type === 'balance') {
 668:         const amount = normalizeMoney(config.amount, 'Balance reward amount')
 669:         const balanceLocked = await tryAdvisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, userId)
 670:         if (!balanceLocked) {
 671:           throw new VipBenefitError('BALANCE_CONFLICT', 'Balance is being processed, please try again later', 409)
 672:         }
 673: 
 674:         const user = await tx.user.findUnique({
 675:           where: { id: userId },
 676:           select: { balance: true }
 677:         })
 678:         if (!user) {
 679:           throw new VipBenefitError('USER_NOT_FOUND', 'User not found', 404)
 680:         }
 681:         const balanceBefore = toNumber(user.balance)
 682:         const updatedUser = await tx.user.update({
 683:           where: { id: userId },
 684:           data: { balance: { increment: amount } },
 685:           select: { balance: true }
 686:         })
 687:         const balanceAfter = toNumber(updatedUser.balance)
 688:         await tx.balanceLog.create({
 689:           data: {
 690:             userId,
 691:             type: 'gift',
 692:             amount,
 693:             balanceBefore,
 694:             balanceAfter,
 695:             remark: `VIP benefit: ${reward.title}`
 696:           }
 697:         })
 698:       } else if (type === 'points') {
 699:         const amount = normalizePositiveInteger(config.amount, 'Points reward amount', MAX_POINTS_AMOUNT)
 700:         await advisoryTransactionLock(tx, USER_POINTS_LOCK_NAMESPACE, userId)
 701: 
 702:         const userPoints = await tx.userPoints.upsert({
 703:           where: { userId },
 704:           update: {},
 705:           create: { userId }
 706:         })
 707:         const updatedPoints = await tx.userPoints.update({
 708:           where: { userId },
 709:           data: {
 710:             points: { increment: amount },
 711:             totalEarned: { increment: amount }
 712:           }
 713:         })
 714:         await tx.pointsLog.create({
 715:           data: {
 716:             userId,
 717:             type: 'vip_benefit',
 718:             amount,
 719:             pointsBefore: userPoints.points,
 720:             pointsAfter: updatedPoints.points,
 721:             relatedId: claim.id,
 722:             remark: `VIP benefit: ${reward.title}`
 723:           }
 724:         })
 725:       }
 726: 
 727:       return claim
 728:     })
 729:   } catch (error: any) {
 730:     if (error?.code === 'P2002') {
 731:       throw new VipBenefitError('CLAIM_CONFLICT', 'This VIP benefit reward was already claimed, please refresh and try again', 409)
 732:     }
 733:     throw error
 734:   }
 735: 
 736:   return {
 737:     claim: claimToView(createdClaim),
 738:     overview: await getVipBenefitOverview(userId)
 739:   }
 740: }
 741: 
 742: export async function claimAllAvailableVipBenefitRewards(userId: number): Promise<{
 743:   claims: VipBenefitClaimView[]
 744:   overview: VipBenefitOverview
 745: }> {
 746:   const claims: VipBenefitClaimView[] = []
 747:   let overview = await getVipBenefitOverview(userId)
 748: 
 749:   for (let attempt = 0; attempt < MAX_BULK_CLAIMS; attempt++) {
 750:     const nextReward = overview.rewards
 751:       .filter(reward => reward.state === 'claimable')
 752:       .sort((a, b) => a.level - b.level || a.sortOrder - b.sortOrder || a.id - b.id)[0]
 753: 
 754:     if (!nextReward) {
 755:       return { claims, overview }
 756:     }
 757: 
 758:     const result = await claimVipBenefitReward(userId, nextReward.id)
 759:     claims.push(result.claim)
 760:     overview = result.overview
 761:   }
 762: 
 763:   throw new VipBenefitError('BULK_CLAIM_LIMIT_EXCEEDED', 'Too many VIP benefit rewards to claim at once', 409)
 764: }

