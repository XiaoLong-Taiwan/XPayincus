 666: async function multiDraw() {
 667:   if (!selectedLottery.value) {
 668:     toast.warning(t('entertainment.selectLottery'))
 669:     return
 670:   }
 671:   const totalCost = selectedLottery.value.costPoints * 10
 672:   if (points.value.points < totalCost) {
 673:     toast.warning(t('entertainment.notEnoughPointsForMulti', { required: totalCost, current: points.value.points }))
 674:     return
 675:   }
 676:   if (isMultiDrawing.value || isSpinning.value) return
 677: 
 678:   isMultiDrawing.value = true
 679:   multiDrawResults.value = []
 680:   multiDrawError.value = ''
 681: 
 682:   try {
 683:     const res = await api.entertainment.drawMulti(selectedLottery.value.id)
 684:     multiDrawResults.value = res.records || []
 685:     multiDrawBadgeRewards.value = multiDrawResults.value
 686:       .map(result => result.badgeOwnership)
 687:       .filter((ownership): ownership is BadgeOwnership => !!ownership)
 688:     if (res.stopReason) {
 689:       multiDrawError.value = res.stopReason
 690:     }
 691:     
 692:     // å¦‚æžœæ²¡æœ‰ä»»ä½•ç»“æžœï¼Œç›´æŽ¥æ˜¾ç¤ºé”™è¯¯ toast
 693:     if (multiDrawResults.value.length === 0) {
 694:       toast.error(res.stopReason || t('entertainment.multiDrawFailed'))
 695:     } else if (multiDrawBadgeRewards.value.length > 0) {
 696:       showMultiDrawBadgeModal.value = true
 697:     } else {
 698:       showMultiDrawModal.value = true
 699:     }
 700:     
 701:     loadPoints() // åˆ·æ–°ç§¯åˆ†
 702:     loadLotteries() // åˆ·æ–°å¥–å“åº“å­˜
 703:   } catch (err: any) {
 704:     toast.error(t('entertainment.multiDrawFailed') + ': ' + err.message)
 705:   } finally {
 706:     isMultiDrawing.value = false
 707:   }
 708: }
 709: 
