 586: export async function replaceVipRules(type: VipRuleType, inputs: VipRuleInput[], userMetric?: UserVipMetric): Promise<NormalizedVipRule[]> {
 587:   if (inputs.length > MAX_VIP_LEVEL) {
 588:     throw new Error(`At most ${MAX_VIP_LEVEL} VIP rules can be saved`)
 589:   }
 590: 
 591:   const byLevel = new Map<number, NormalizedVipRule>()
 592:   const metricToSave = type === 'user' ? userMetric : undefined
 593:   const effectiveUserMetric = type === 'user' ? (metricToSave || await getUserVipMetric()) : 'totalRecharge'
 594:   for (const input of inputs) {
 595:     const rule = sanitizeVipRuleInput(type, input, effectiveUserMetric)
 596:     byLevel.set(rule.level, rule)
 597:   }
 598: 
 599:   const normalizedRules = Array.from(byLevel.values()).sort((a, b) => a.level - b.level)
 600:   await validateBenefitInstanceRefs(collectBenefitInstanceRefs(normalizedRules))
 601: 
 602:   await prisma.$transaction(async (tx) => {
 603:     if (metricToSave) {
 604:       await tx.systemConfig.upsert({
 605:         where: { key: USER_VIP_METRIC_CONFIG_KEY },
 606:         create: {
 607:           key: USER_VIP_METRIC_CONFIG_KEY,
 608:           value: metricToSave,
 609:           type: 'string',
 610:           label: 'ç”¨æˆ· VIP ç»Ÿè®¡å£å¾„',
 611:           description: 'ç”¨æˆ· VIP ç­‰çº§å…¨å±€è®¡ç®—å£å¾„ï¼štotalRecharge=ç´¯è®¡å……å€¼ï¼ŒtotalConsume=ç´¯è®¡æ¶ˆè´¹'
 612:         },
 613:         update: { value: metricToSave }
 614:       })
 615:     }
 616: 
 617:     if (normalizedRules.length === 0) {
 618:       await tx.vipLevelRule.deleteMany({ where: { type } })
 619:       return
 620:     }
 621: 
 622:     await tx.vipLevelRule.deleteMany({
 623:       where: {
 624:         type,
 625:         level: { notIn: normalizedRules.map(rule => rule.level) }
 626:       }
 627:     })
 628: 
 629:     for (const rule of normalizedRules) {
 630:       await tx.vipLevelRule.upsert({
 631:         where: {
 632:           type_level: {
 633:             type,
 634:             level: rule.level
 635:           }
 636:         },
 637:         create: {
 638:           type,
 639:           level: rule.level,
 640:           enabled: rule.enabled,
 641:           conditionMode: rule.conditionMode,
 642:           minRecharge: rule.minRecharge,
 643:           minConsume: rule.minConsume,
 644:           minHostingIncome: rule.minHostingIncome,
 645:           minHostingInstances: rule.minHostingInstances,
 646:           benefits: rule.benefits as Prisma.InputJsonObject
 647:         },
 648:         update: {
 649:           enabled: rule.enabled,
 650:           conditionMode: rule.conditionMode,
 651:           minRecharge: rule.minRecharge,
 652:           minConsume: rule.minConsume,
 653:           minHostingIncome: rule.minHostingIncome,
 654:           minHostingInstances: rule.minHostingInstances,
 655:           benefits: rule.benefits as Prisma.InputJsonObject
 656:         }
 657:       })
 658:     }
 659:   })
 660: 
 661:   if (metricToSave) {
 662:     invalidateCachedConfig(USER_VIP_METRIC_CONFIG_KEY)
 663:   }
 664: 
 665:   return getVipRules(type)
 666: }
