 184:   invalidateCachedConfig(USER_VIP_METRIC_CONFIG_KEY)
 185:   return metric
 186: }
 187: 
 188: function normalizeBenefits(value: unknown): Record<string, unknown> {
 189:   if (value && typeof value === 'object' && !Array.isArray(value)) {
 190:     return value as Record<string, unknown>
 191:   }
 192:   return {}
 193: }
 194: 
 195: function getRecord(value: unknown): Record<string, unknown> {
 196:   return value && typeof value === 'object' && !Array.isArray(value) ? value as Record<string, unknown> : {}
 197: }
 198: 
 199: export function getDefaultVipBadgeStyle(level: number): VipBadgeStyle {
 200:   const styles: VipBadgeStyle[] = [
 201:     { backgroundColor: '#FEF3C7', textColor: '#92400E' },
 202:     { backgroundColor: '#D1FAE5', textColor: '#047857' },
 203:     { backgroundColor: '#DBEAFE', textColor: '#1D4ED8' },
 204:     { backgroundColor: '#EDE9FE', textColor: '#6D28D9' },
 205:     { backgroundColor: '#FFEDD5', textColor: '#C2410C' },
 206:     { backgroundColor: '#FCE7F3', textColor: '#BE185D' },
 207:     { backgroundColor: '#FFE4E6', textColor: '#BE123C' },
 208:     { backgroundColor: '#CFFAFE', textColor: '#0E7490' },
 209:     { backgroundColor: '#FAE8FF', textColor: '#A21CAF' },
 210:     { backgroundColor: '#FEF9C3', textColor: '#A16207' }
 211:   ]
 212:   return styles[(Math.max(1, Math.floor(level)) - 1) % styles.length]
 213: }
 214: 
 215: function normalizeHexColor(value: unknown, fallback: string): string {
 216:   return typeof value === 'string' && HEX_COLOR_RE.test(value) ? value : fallback
 217: }
 218: 
 219: function normalizeBenefitMoney(value: unknown): number {
 220:   const parsed = Number(value)
 221:   if (!Number.isFinite(parsed) || parsed <= 0) return 0
 222:   return Math.min(MAX_MONEY_THRESHOLD, Math.round(parsed * 100) / 100)
 223: }
 224: 
 225: function normalizeBenefitInteger(value: unknown, max: number): number {
 226:   const parsed = Number(value)
 227:   if (!Number.isFinite(parsed) || parsed <= 0) return 0
 228:   return Math.min(max, Math.floor(parsed))
 229: }
 230: 
 231: function normalizeBenefitId(value: unknown): number | null {
 232:   const parsed = Number(value)
 233:   return Number.isInteger(parsed) && parsed > 0 ? parsed : null
 234: }
 235: 
 236: function normalizeBenefitLabel(value: unknown): string | null {
 237:   if (typeof value !== 'string') return null
 238:   const trimmed = value.trim()
 239:   return trimmed ? trimmed.slice(0, 100) : null
 240: }
 241: 
 242: function normalizeBenefitHallConfig(value: unknown, strict = false): VipBenefitHallConfig {
 243:   const raw = getRecord(value)
 244:   const balance = getRecord(raw.balance)
 245:   const points = getRecord(raw.points)
 246:   const instance = getRecord(raw.instance)
 247: 
 248:   const balanceAmount = normalizeBenefitMoney(balance.amount)
 249:   const pointsAmount = normalizeBenefitInteger(points.amount, MAX_BENEFIT_POINTS)
 250:   const packageId = normalizeBenefitId(instance.packageId)
 251:   const planId = normalizeBenefitId(instance.planId)
 252:   const days = normalizeBenefitInteger(instance.days, MAX_BENEFIT_INSTANCE_DAYS) || 30
 253:   const quantity = normalizeBenefitInteger(instance.quantity, MAX_BENEFIT_INSTANCE_QUANTITY) || 1
 254: 
 255:   const balanceEnabled = balance.enabled === true
 256:   const pointsEnabled = points.enabled === true
 257:   const instanceEnabled = instance.enabled === true
 258: 
 259:   if (strict) {
 260:     if (balanceEnabled && balanceAmount <= 0) {
--- server/src/services/vip-levels.ts 261-520 ---
 261:       throw new Error('VIP benefit balance amount must be greater than 0')
 262:     }
 263:     if (pointsEnabled && pointsAmount <= 0) {
 264:       throw new Error('VIP benefit points amount must be a positive integer')
 265:     }
 266:     if (instanceEnabled && (!packageId || !planId)) {
 267:       throw new Error('VIP benefit instance requires a package and plan')
 268:     }
 269:     if (instanceEnabled && normalizeBenefitInteger(instance.days, MAX_BENEFIT_INSTANCE_DAYS) <= 0) {
 270:       throw new Error('VIP benefit instance days must be a positive integer')
 271:     }
 272:     if (instanceEnabled && normalizeBenefitInteger(instance.quantity, MAX_BENEFIT_INSTANCE_QUANTITY) <= 0) {
 273:       throw new Error('VIP benefit instance quantity must be a positive integer')
 274:     }
 275:   }
 276: 
 277:   return {
 278:     balance: {
 279:       enabled: balanceEnabled && balanceAmount > 0,
 280:       amount: balanceAmount
 281:     },
 282:     points: {
 283:       enabled: pointsEnabled && pointsAmount > 0,
 284:       amount: pointsAmount
 285:     },
 286:     instance: {
 287:       enabled: instanceEnabled && !!packageId && !!planId,
 288:       packageId,
 289:       packageName: normalizeBenefitLabel(instance.packageName),
 290:       planId,
 291:       planName: normalizeBenefitLabel(instance.planName),
 292:       days,
 293:       quantity
 294:     }
 295:   }
 296: }
 297: 
 298: function collectBenefitInstanceRefs(rules: NormalizedVipRule[]): VipBenefitInstanceRef[] {
 299:   const refs: VipBenefitInstanceRef[] = []
 300:   for (const rule of rules) {
 301:     const benefitHall = normalizeBenefitHallConfig((rule.benefits as Record<string, unknown>).benefitHall)
 302:     if (benefitHall.instance.enabled && benefitHall.instance.packageId && benefitHall.instance.planId) {
 303:       refs.push({
 304:         level: rule.level,
 305:         packageId: benefitHall.instance.packageId,
 306:         planId: benefitHall.instance.planId
 307:       })
 308:     }
 309:   }
 310:   return refs
 311: }
 312: 
 313: async function validateBenefitInstanceRefs(refs: VipBenefitInstanceRef[]): Promise<void> {
 314:   if (refs.length === 0) return
 315: 
 316:   const packageIds = Array.from(new Set(refs.map(ref => ref.packageId)))
 317:   const planIds = Array.from(new Set(refs.map(ref => ref.planId)))
 318: 
 319:   const [packages, plans] = await Promise.all([
 320:     prisma.package.findMany({
 321:       where: {
 322:         id: { in: packageIds },
 323:         active: true
 324:       },
 325:       select: { id: true }
 326:     }),
 327:     prisma.packagePlan.findMany({
 328:       where: {
 329:         id: { in: planIds },
 330:         isActive: true
 331:       },
 332:       select: {
 333:         id: true,
 334:         packageId: true
 335:       }
 336:     })
 337:   ])
 338: 
 339:   const existingPackageIds = new Set(packages.map(pkg => pkg.id))
 340:   const activePlanPackageMap = new Map(plans.map(plan => [plan.id, plan.packageId]))
 341: 
 342:   for (const ref of refs) {
 343:     if (!existingPackageIds.has(ref.packageId)) {
 344:       throw new Error(`VIP${ref.level} benefit package does not exist or is disabled`)
 345:     }
 346:     if (activePlanPackageMap.get(ref.planId) !== ref.packageId) {
 347:       throw new Error(`VIP${ref.level} benefit plan does not exist, is disabled, or does not belong to the selected package`)
 348:     }
 349:   }
 350: }
 351: 
 352: export function normalizeVipBadgeStyle(level: number, value: unknown): VipBadgeStyle {
 353:   const fallback = getDefaultVipBadgeStyle(level)
 354:   if (!value || typeof value !== 'object' || Array.isArray(value)) {
 355:     return fallback
 356:   }
 357: 
 358:   const style = value as Record<string, unknown>
 359:   return {
 360:     backgroundColor: normalizeHexColor(style.backgroundColor, fallback.backgroundColor),
 361:     textColor: normalizeHexColor(style.textColor, fallback.textColor)
 362:   }
 363: }
 364: 
 365: function sanitizeBenefits(level: number, benefits: unknown, strict = false): Record<string, unknown> {
 366:   const normalized = normalizeBenefits(benefits)
 367:   return {
 368:     ...normalized,
 369:     badgeStyle: normalizeVipBadgeStyle(level, normalized.badgeStyle),
 370:     benefitHall: normalizeBenefitHallConfig(normalized.benefitHall, strict)
 371:   }
 372: }
 373: 
 374: export function getVipBadgeStyleForLevel(rules: NormalizedVipRule[], type: VipRuleType, level: number): VipBadgeStyle | null {
 375:   if (!level) return null
 376:   const rule = rules.find(item => item.type === type && item.level === level)
 377:   return rule?.badgeStyle || getDefaultVipBadgeStyle(level)
 378: }
 379: 
 380: export function normalizeVipRule(rule: VipLevelRule): NormalizedVipRule {
 381:   const benefits = sanitizeBenefits(rule.level, rule.benefits)
 382:   return {
 383:     id: rule.id,
 384:     type: rule.type,
 385:     level: rule.level,
 386:     enabled: rule.enabled,
 387:     conditionMode: rule.conditionMode,
 388:     minRecharge: rule.minRecharge === null ? null : toNumber(rule.minRecharge),
 389:     minConsume: rule.minConsume === null ? null : toNumber(rule.minConsume),
 390:     minHostingIncome: rule.minHostingIncome === null ? null : toNumber(rule.minHostingIncome),
 391:     minHostingInstances: rule.minHostingInstances,
 392:     benefits,
 393:     badgeStyle: normalizeVipBadgeStyle(rule.level, benefits.badgeStyle)
 394:   }
 395: }
 396: 
 397: export function sanitizeVipRuleInput(type: VipRuleType, input: VipRuleInput, userMetric: UserVipMetric = 'totalRecharge'): NormalizedVipRule {
 398:   const level = Number(input.level)
 399:   if (!Number.isInteger(level) || level < 1 || level > MAX_VIP_LEVEL) {
 400:     throw new Error(`VIP level must be between 1 and ${MAX_VIP_LEVEL}`)
 401:   }
 402: 
 403:   const conditionMode = input.conditionMode === 'all' ? 'all' : 'any'
 404:   const enabled = input.enabled !== false
 405:   const normalized: NormalizedVipRule = {
 406:     type,
 407:     level,
 408:     enabled,
 409:     conditionMode: type === 'user' ? 'any' : conditionMode,
 410:     minRecharge: type === 'user' && userMetric === 'totalRecharge' ? nullableMoney(input.minRecharge) : null,
 411:     minConsume: type === 'user' && userMetric === 'totalConsume' ? nullableMoney(input.minConsume) : null,
 412:     minHostingIncome: type === 'hosting' ? nullableMoney(input.minHostingIncome) : null,
 413:     minHostingInstances: type === 'hosting' ? nullableCount(input.minHostingInstances) : null,
 414:     benefits: sanitizeBenefits(level, input.benefits, true),
 415:     badgeStyle: getDefaultVipBadgeStyle(level)
 416:   }
 417:   normalized.badgeStyle = normalizeVipBadgeStyle(level, normalized.benefits.badgeStyle)
 418: 
 419:   if (enabled && !hasActiveCondition(type, normalized)) {
 420:     throw new Error(`VIP${level} requires at least one condition`)
 421:   }
 422: 
 423:   return normalized
 424: }
 425: 
 426: export function hasActiveCondition(type: VipRuleType, rule: Pick<NormalizedVipRule, 'minRecharge' | 'minConsume' | 'minHostingIncome' | 'minHostingInstances'>): boolean {
 427:   if (type === 'user') {
 428:     return hasThreshold(rule.minRecharge) || hasThreshold(rule.minConsume)
 429:   }
 430:   return hasThreshold(rule.minHostingIncome) || hasThreshold(rule.minHostingInstances)
 431: }
 432: 
 433: function getRuleChecks(type: VipRuleType, rule: NormalizedVipRule, stats: UserVipStats | HostingVipStats): boolean[] {
 434:   if (type === 'user') {
 435:     const userStats = stats as UserVipStats
 436:     return [
 437:       hasThreshold(rule.minRecharge) ? userStats.totalRecharge >= rule.minRecharge! : null,
 438:       hasThreshold(rule.minConsume) ? userStats.totalConsume >= rule.minConsume! : null
 439:     ].filter((value): value is boolean => value !== null)
 440:   }
 441: 
 442:   const hostingStats = stats as HostingVipStats
 443:   return [
 444:     hasThreshold(rule.minHostingIncome) ? hostingStats.totalHostingIncome >= rule.minHostingIncome! : null,
 445:     hasThreshold(rule.minHostingInstances) ? hostingStats.instanceCount >= rule.minHostingInstances! : null
 446:   ].filter((value): value is boolean => value !== null)
 447: }
 448: 
 449: function getUserRuleChecks(rule: NormalizedVipRule, stats: UserVipStats, userMetric: UserVipMetric): boolean[] {
 450:   return [
 451:     userMetric === 'totalRecharge' && hasThreshold(rule.minRecharge) ? stats.totalRecharge >= rule.minRecharge! : null,
 452:     userMetric === 'totalConsume' && hasThreshold(rule.minConsume) ? stats.totalConsume >= rule.minConsume! : null
 453:   ].filter((value): value is boolean => value !== null)
 454: }
 455: 
 456: function hasUserMetricCondition(rule: NormalizedVipRule, userMetric: UserVipMetric): boolean {
 457:   return userMetric === 'totalRecharge' ? hasThreshold(rule.minRecharge) : hasThreshold(rule.minConsume)
 458: }
 459: 
 460: export function isVipRuleMatched(type: VipRuleType, rule: NormalizedVipRule, stats: UserVipStats | HostingVipStats): boolean {
 461:   if (!rule.enabled || !hasActiveCondition(type, rule)) return false
 462:   const checks = getRuleChecks(type, rule, stats)
 463:   if (checks.length === 0) return false
 464:   return rule.conditionMode === 'all'
 465:     ? checks.every(Boolean)
 466:     : checks.some(Boolean)
 467: }
 468: 
 469: export function isUserVipRuleMatched(rule: NormalizedVipRule, stats: UserVipStats, userMetric: UserVipMetric): boolean {
 470:   if (!rule.enabled || rule.type !== 'user' || !hasUserMetricCondition(rule, userMetric)) return false
 471:   const checks = getUserRuleChecks(rule, stats, userMetric)
 472:   return checks.length > 0 && checks.some(Boolean)
 473: }
 474: 
 475: export function calculateVipLevel(type: VipRuleType, rules: NormalizedVipRule[], stats: UserVipStats | HostingVipStats): number {
 476:   const matchedRules = rules
 477:     .filter(rule => rule.type === type && isVipRuleMatched(type, rule, stats))
 478:     .sort((a, b) => b.level - a.level)
 479: 
 480:   return matchedRules[0]?.level || 0
 481: }
 482: 
 483: export function calculateUserVipLevelByMetric(rules: NormalizedVipRule[], stats: UserVipStats, userMetric: UserVipMetric): number {
 484:   const matchedRules = rules
 485:     .filter(rule => isUserVipRuleMatched(rule, stats, userMetric))
 486:     .sort((a, b) => b.level - a.level)
 487: 
 488:   return matchedRules[0]?.level || 0
 489: }
 490: 
 491: function buildVipProgressCondition(metric: VipProgressMetric, current: number, target: number): VipProgressCondition {
 492:   const normalizedCurrent = roundAmount(Math.max(current, 0))
 493:   const normalizedTarget = roundAmount(Math.max(target, 0))
 494:   return {
 495:     metric,
 496:     current: normalizedCurrent,
 497:     target: normalizedTarget,
 498:     remaining: roundAmount(Math.max(normalizedTarget - normalizedCurrent, 0)),
 499:     matched: normalizedCurrent >= normalizedTarget,
 500:     progress: toProgressPercent(normalizedCurrent, normalizedTarget)
 501:   }
 502: }
 503: 
 504: function getVipProgressConditions(
 505:   type: VipRuleType,
 506:   rule: NormalizedVipRule,
 507:   stats: UserVipStats | HostingVipStats,
 508:   userMetric: UserVipMetric = 'totalRecharge'
 509: ): VipProgressCondition[] {
 510:   if (type === 'user') {
 511:     const userStats = stats as UserVipStats
 512:     return [
 513:       userMetric === 'totalRecharge' && hasThreshold(rule.minRecharge)
 514:         ? buildVipProgressCondition('totalRecharge', userStats.totalRecharge, rule.minRecharge!)
 515:         : null,
 516:       userMetric === 'totalConsume' && hasThreshold(rule.minConsume)
 517:         ? buildVipProgressCondition('totalConsume', userStats.totalConsume, rule.minConsume!)
 518:         : null
 519:     ].filter((condition): condition is VipProgressCondition => condition !== null)
 520:   }
--- server/src/services/vip-levels.ts 521-779 ---
 521: 
 522:   const hostingStats = stats as HostingVipStats
 523:   return [
 524:     hasThreshold(rule.minHostingIncome)
 525:       ? buildVipProgressCondition('totalHostingIncome', hostingStats.totalHostingIncome, rule.minHostingIncome!)
 526:       : null,
 527:     hasThreshold(rule.minHostingInstances)
 528:       ? buildVipProgressCondition('instanceCount', hostingStats.instanceCount, rule.minHostingInstances!)
 529:       : null
 530:   ].filter((condition): condition is VipProgressCondition => condition !== null)
 531: }
 532: 
 533: export function calculateVipProgress(
 534:   type: VipRuleType,
 535:   rules: NormalizedVipRule[],
 536:   currentLevel: number,
 537:   stats: UserVipStats | HostingVipStats,
 538:   userMetric: UserVipMetric = 'totalRecharge'
 539: ): VipLevelProgress {
 540:   const nextRule = rules
 541:     .filter(rule => {
 542:       if (rule.type !== type || !rule.enabled || rule.level <= currentLevel) return false
 543:       return type === 'user' ? hasUserMetricCondition(rule, userMetric) : hasActiveCondition(type, rule)
 544:     })
 545:     .sort((a, b) => a.level - b.level)[0]
 546: 
 547:   if (!nextRule) {
 548:     return {
 549:       currentLevel,
 550:       nextLevel: null,
 551:       conditionMode: null,
 552:       userMetric: type === 'user' ? userMetric : null,
 553:       progress: currentLevel > 0 ? 100 : 0,
 554:       isMaxLevel: currentLevel > 0,
 555:       conditions: []
 556:     }
 557:   }
 558: 
 559:   const conditions = getVipProgressConditions(type, nextRule, stats, userMetric)
 560:   const conditionProgressValues = conditions.map(condition => condition.progress)
 561:   const progress = conditionProgressValues.length === 0
 562:     ? 0
 563:     : nextRule.conditionMode === 'all'
 564:       ? Math.min(...conditionProgressValues)
 565:       : Math.max(...conditionProgressValues)
 566: 
 567:   return {
 568:     currentLevel,
 569:     nextLevel: nextRule.level,
 570:     conditionMode: nextRule.conditionMode,
 571:     userMetric: type === 'user' ? userMetric : null,
 572:     progress,
 573:     isMaxLevel: false,
 574:     conditions
 575:   }
 576: }
