  10: const POSITIVE_ROUTE_ID_PATTERN = /^[1-9]\d*$/
  11: const LOTTERY_PRIZE_TYPES = new Set<LotteryPrizeType>([
  12:   'nothing',
  13:   'points',
  14:   'balance',
  15:   'badge',
  16:   'instance',
  17:   'cpu',
  18:   'memory',
  19:   'disk',
  20:   'traffic'
  21: ])
  22: const LOTTERY_RECORD_STATUSES = new Set<LotteryRecordStatus>(['pending', 'delivered', 'claimed'])
  23: const NOTIFICATION_TYPES = new Set(['telegram', 'discord', 'webhook'])
  24: const USER_POINTS_ORDER_BY_FIELDS = new Set(['points', 'totalEarned', 'totalSpent'])
  25: const SORT_ORDERS = new Set(['asc', 'desc'])
  26: const MAX_POINTS_ADJUST_AMOUNT = 1_000_000
  27: 
  28: function parsePositiveRouteId(value: string): number | null {
  29:   if (!POSITIVE_ROUTE_ID_PATTERN.test(value)) {
  30:     return null
  31:   }
  32: 
  33:   const parsed = Number(value)
  34:   return Number.isSafeInteger(parsed) ? parsed : null
  35: }
  36: 
  37: function parsePositiveIntegerQuery(value: string | undefined, fallback: number, max: number): number {
  38:   if (!value || !POSITIVE_ROUTE_ID_PATTERN.test(value)) {
  39:     return fallback
  40:   }
  41: 
  42:   const parsed = Number(value)
  43:   if (!Number.isSafeInteger(parsed)) {
  44:     return fallback
  45:   }
  46: 
  47:   return Math.min(parsed, max)
  48: }
  49: 
  50: function parseOptionalPositiveId(value: string | undefined): number | undefined | null {
  51:   if (!value) return undefined
  52:   return parsePositiveRouteId(value)
  53: }
  54: 
  55: function parseOptionalPositiveBodyId(value: unknown): number | undefined | null {
  56:   if (value === undefined || value === null) return undefined
  57:   return typeof value === 'number' && Number.isSafeInteger(value) && value > 0 ? value : null
  58: }
  59: 
  60: function parseOptionalNonNegativeIntegerBody(value: unknown): number | undefined | null {
  61:   if (value === undefined || value === null) return undefined
  62:   return typeof value === 'number' && Number.isSafeInteger(value) && value >= 0 ? value : null
  63: }
  64: 
  65: function parseIntegerBody(value: unknown): number | null {
  66:   return typeof value === 'number' && Number.isSafeInteger(value) ? value : null
  67: }
  68: 
  69: function parseOptionalIntegerBody(value: unknown, fallback: number): number {
  70:   if (value === undefined || value === null) return fallback
  71:   return typeof value === 'number' && Number.isSafeInteger(value) ? value : fallback
  72: }
  73: 
  74: function parseOptionalFiniteNumber(value: unknown): number | undefined | null {
  75:   if (value === undefined || value === null) return undefined
  76:   return typeof value === 'number' && Number.isFinite(value) ? value : null
  77: }
  78: 
  79: function parseLotteryPrizeType(value: unknown): LotteryPrizeType | null {
