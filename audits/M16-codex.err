  23: const LOTTERY_PRIZE_TYPES = new Set<LotteryPrizeType>([
  24:   'nothing',
  25:   'points',
  26:   'balance',
  27:   'badge',
  28:   'instance',
  29:   'cpu',
  30:   'memory',
  31:   'disk',
  32:   'traffic'
  33: ])
  34: 
  35: function parsePositiveRouteId(value: string): number | null {
  36:   if (!POSITIVE_ROUTE_ID_PATTERN.test(value)) {
  37:     return null
  38:   }
  39: 
  40:   const parsed = Number(value)
  41:   return Number.isSafeInteger(parsed) ? parsed : null
  42: }
  43: 
  44: function parsePositiveIntegerQuery(value: string | undefined, fallback: number, max: number): number {
  45:   if (!value || !POSITIVE_ROUTE_ID_PATTERN.test(value)) {
  46:     return fallback
  47:   }
  48: 
  49:   const parsed = Number(value)
  50:   if (!Number.isSafeInteger(parsed)) {
  51:     return fallback
  52:   }
  53: 
  54:   return Math.min(parsed, max)
  55: }
  56: 
  57: function parsePositiveBodyId(value: unknown): number | null {
  58:   return typeof value === 'number' && Number.isSafeInteger(value) && value > 0
  59:     ? value
  60:     : null
  61: }
  62: 
  63: function parsePointsLogType(value: string | undefined): PointsLogType | undefined | null {
  64:   if (!value) return undefined
  65:   return POINTS_LOG_TYPES.has(value as PointsLogType) ? value as PointsLogType : null
  66: }
  67: 
  68: function parseLotteryPrizeType(value: string | undefined): LotteryPrizeType | undefined | null {
  69:   if (!value) return undefined
  70:   return LOTTERY_PRIZE_TYPES.has(value as LotteryPrizeType) ? value as LotteryPrizeType : null
  71: }
