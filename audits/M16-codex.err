 379: // ä¿å­˜å¥–å“
 380: async function savePrizes() {
 381:   // éªŒè¯
 382:   for (const prize of prizes.value) {
 383:     if (!prize.name.trim()) {
 384:       toast.warning(t('entertainment.admin.enterPrizeName'))
 385:       return
 386:     }
 387:     if (prize.probability <= 0) {
 388:       toast.warning(t('entertainment.admin.invalidProbability'))
 389:       return
 390:     }
 391:   }
 392: 
 393:   savingPrizes.value = true
 394:   try {
 395:     const lotteryId = editingPrizes.value.id
 396:     const existingPrizes = editingPrizes.value.prizes || []
 397:     const existingIds = existingPrizes.map((p: any) => p.id)
 398:     const newPrizeIds = prizes.value.filter(p => p.id).map(p => p.id)
 399:     
 400:     // åˆ é™¤ä¸åœ¨æ–°åˆ—è¡¨ä¸­çš„å¥–å“
 401:     for (const existingId of existingIds) {
 402:       if (!newPrizeIds.includes(existingId)) {
 403:         await api.entertainment.adminDeletePrize(existingId)
 404:       }
 405:     }
 406:     
 407:     // æ›´æ–°æˆ–åˆ›å»ºå¥–å“
 408:     for (let i = 0; i < prizes.value.length; i++) {
 409:       const prize = prizes.value[i]
