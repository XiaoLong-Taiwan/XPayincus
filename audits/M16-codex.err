 491:   // æ‰¾åˆ°"è°¢è°¢å‚ä¸Ž"å¥–å“ï¼ˆä½œä¸ºå…œåº•ï¼‰
 492:   const nothingPrize = prizes.find(p => p.type === 'nothing')
 493:   
 494:   // æ£€æŸ¥æ˜¯å¦æœ‰ä»»ä½•å¯ç”¨å¥–å“
 495:   const hasAvailable = prizes.some(p =>
 496:     p.remainQuantity === null || p.remainQuantity > 0
 497:   )
