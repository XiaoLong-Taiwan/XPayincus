 268:         }
 269:         if (currentInstance.status !== 'running' && currentInstance.status !== 'stopped') {
 270:           throw new Error('INSTANCE_STATUS_INVALID')
 271:         }
 272:         if (currentInstance.host_id !== currentCodeRecord.hostId) {
 273:           throw new Error('REDEEM_CODE_HOST_MISMATCH')
 274:         }
 275: 
 276:         codeType = currentCodeRecord.codeType
 277:         codeValue = currentCodeRecord.codeValue
 278:         actualAdded = codeValue
 279:         if (!['c', 'r', 'd', 't'].includes(codeType)) {
 280:           throw new Error('REDEEM_CODE_INVALID_FORMAT')
 281:         }
 282: 
 283:         let patchedRollback: (() => Promise<void>) | null = null
 284: 
 285:         try {
 286:           if (codeType === 'c') {
 287:             const newCpu = currentInstance.cpu + codeValue
 288:             const host = await db.getHostById(currentInstance.host_id)
 289:             if (!host) {
 290:               throw new Error('HOST_NOT_FOUND')
 291:             }
 292:             const client = await getIncusClient(host)
 293:             await patchInstanceResources(client, currentInstance.incus_id, { cpu: newCpu })
 294:             patchedRollback = async () => {
 295:               await patchInstanceResources(client, currentInstance.incus_id, { cpu: currentInstance.cpu })
 296:             }
 297:             await db.applySystemRedeemCodeToInstance({
 298:               redeemCodeId: currentCodeRecord.id,
 299:               userId: user.id,
 300:               instanceId,
 301:               hostId: currentInstance.host_id,
 302:               batchId: currentCodeRecord.batchId,
 303:               instanceResources: { cpu: newCpu },
 304:               hostResourceDelta: { cpuUsed: actualAdded }
 305:             })
 306:           } else if (codeType === 'r') {
 307:             const newMemory = currentInstance.memory + codeValue
 308:             const host = await db.getHostById(currentInstance.host_id)
 309:             if (!host) {
 310:               throw new Error('HOST_NOT_FOUND')
 311:             }
 312:             const client = await getIncusClient(host)
 313:             await patchInstanceResources(client, currentInstance.incus_id, { memory: newMemory })
 314:             patchedRollback = async () => {
 315:               await patchInstanceResources(client, currentInstance.incus_id, { memory: currentInstance.memory })
 316:             }
 317:             await db.applySystemRedeemCodeToInstance({
 318:               redeemCodeId: currentCodeRecord.id,
 319:               userId: user.id,
 320:               instanceId,
 321:               hostId: currentInstance.host_id,
 322:               batchId: currentCodeRecord.batchId,
 323:               instanceResources: { memory: newMemory },
 324:               hostResourceDelta: { memoryUsed: actualAdded }
 325:             })
 326:           } else if (codeType === 'd') {
 327:             const newDisk = currentInstance.disk + codeValue
 328:             const host = await db.getHostById(currentInstance.host_id)
 329:             if (!host) {
 330:               throw new Error('HOST_NOT_FOUND')
 331:             }
 332:             const client = await getIncusClient(host)
 333:             await patchInstanceResources(client, currentInstance.incus_id, { disk: newDisk })
 334:             patchedRollback = async () => {
 335:               await patchInstanceResources(client, currentInstance.incus_id, { disk: currentInstance.disk })
 336:             }
 337:             await db.applySystemRedeemCodeToInstance({
 338:               redeemCodeId: currentCodeRecord.id,
 339:               userId: user.id,
 340:               instanceId,
 341:               hostId: currentInstance.host_id,
 342:               batchId: currentCodeRecord.batchId,
 343:               instanceResources: { disk: newDisk },
 344:               hostResourceDelta: { diskUsed: actualAdded }
 345:             })
 346:           } else if (codeType === 't') {
 347:             const trafficBytes = BigInt(codeValue) * BigInt(1024 * 1024 * 1024)
 348:             await db.applySystemRedeemCodeToInstance({
 349:               redeemCodeId: currentCodeRecord.id,
 350:               userId: user.id,
 351:               instanceId,
 352:               hostId: currentInstance.host_id,
 353:               batchId: currentCodeRecord.batchId,
 354:               monthlyTrafficDelta: trafficBytes
 355:             })
 356:           }
 357:         } catch (error) {
 358:           if (patchedRollback) {
 359:             try {
 360:               await patchedRollback()
 361:             } catch (rollbackError) {
 362:               request.log.error({ err: rollbackError, instanceId }, 'Failed to roll back Incus resource patch after redeem DB failure')
 363:             }
 364:           }
 365:           throw error
 366:         }
 367: 
 368:         const typeName = CODE_TYPE_NAMES[codeType]?.en || codeType
 369:         const unit = CODE_TYPE_UNITS[codeType] || ''
 370:         await createLog(
 371:           user.id,
 372:           'checkin',
 373:           'redeem.success',
 374:           `Redeemed system code ${trimmedCode} for instance "${currentInstance.name}": ${typeName} +${actualAdded}${unit}`,
 375:           'success',
 376:           { instanceId }
 377:         )
 378: 
 379:         // è®°å½•åˆ°èµ„æºæ± æ—¥å¿—ï¼ˆä¸åŠ èµ„æºæ± ï¼Œå› ä¸ºèµ„æºç›´æŽ¥åº”ç”¨åˆ°å®žä¾‹ï¼‰
 380:         if (codeType !== 'p') {
 381:           await db.logSystemRedeemToInstance(
 382:             user.id,
 383:             codeType as any,
 384:             actualAdded,
 385:             instanceId,
 386:             `ç³»ç»Ÿå…‘æ¢ç  ${trimmedCode} åº”ç”¨åˆ° ${currentInstance.name}`
 387:           )
 388:         }
 389: 
 390:         return {
 391:           message: 'Redeem successful',
 392:           codeType,
 393:           codeValue,
 394:           actualAdded,
 395:           instanceId,
 396:           instanceName: currentInstance.name,
 397:           isSystemCode: true,
 398:           toResourcePool: false
 399:         }
 400:       })
 401: 
 402:       return response
 403:     } catch (error) {
 404:       const errorMessage = error instanceof Error ? error.message : String(error)
 405:       if (errorMessage === 'REDEEM_CODE_NOT_FOUND') {
 406:         return reply.code(404).send(apiError(ErrorCode.REDEEM_CODE_NOT_FOUND))
 407:       }
 408:       if (errorMessage === 'REDEEM_CODE_DISABLED') {
 409:         return reply.code(400).send(apiError(ErrorCode.REDEEM_CODE_DISABLED))
 410:       }
 411:       if (errorMessage === 'REDEEM_CODE_EXPIRED') {
 412:         return reply.code(400).send(apiError(ErrorCode.REDEEM_CODE_EXPIRED))
 413:       }
 414:       if (errorMessage === 'REDEEM_CODE_INVALID_FORMAT') {
 415:         return reply.code(400).send(apiError(ErrorCode.REDEEM_CODE_INVALID_FORMAT))
 416:       }
 417:       if (errorMessage === 'REDEEM_CODE_EXHAUSTED') {
 418:         return reply.code(400).send(apiError(ErrorCode.REDEEM_CODE_EXHAUSTED))
 419:       }
 420:       if (errorMessage === 'REDEEM_CODE_ALREADY_USED_BY_USER') {
 421:         return reply.code(400).send(apiError(ErrorCode.REDEEM_CODE_ALREADY_USED_BY_USER))
 422:       }
 423:       if (errorMessage === 'REDEEM_CODE_BATCH_LIMIT') {
 424:         return reply.code(400).send(apiError(ErrorCode.REDEEM_CODE_BATCH_LIMIT))
 425:       }
 426:       if (errorMessage === 'REDEEM_CODE_BUSY') {
 427:         return reply.code(409).send({
 428:           error: 'REDEEM_CODE_BUSY',
 429:           message: 'Redeem code is busy, please retry'
 430:         })
 431:       }
 432:       if (errorMessage === 'INSTANCE_NOT_FOUND') {
 433:         return reply.code(404).send(apiError(ErrorCode.INSTANCE_NOT_FOUND))
 434:       }
 435:       if (errorMessage === 'FORBIDDEN') {
 436:         return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 437:       }
 438:       if (errorMessage === 'REDEEM_CODE_TARGET_USER_MISMATCH') {
 439:         return reply.code(403).send(apiError(ErrorCode.FORBIDDEN, 'This redeem code is assigned to another user'))
 440:       }
 441:       if (errorMessage === 'INSTANCE_STATUS_INVALID') {
 442:         return reply.code(400).send(apiError(ErrorCode.INSTANCE_STATUS_INVALID))
 443:       }
 444:       if (errorMessage === 'REDEEM_CODE_HOST_MISMATCH') {
 445:         return reply.code(400).send(apiError(ErrorCode.REDEEM_CODE_HOST_MISMATCH))
 446:       }
 447:       if (errorMessage === 'HOST_NOT_FOUND') {
 448:         return reply.code(404).send(apiError(ErrorCode.HOST_NOT_FOUND))
 449:       }
 450:       await createLog(user.id, 'checkin', 'redeem.failed', `Failed to redeem code ${trimmedCode}: ${errorMessage}`, 'failed', { instanceId })
 451:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, errorMessage))
 452:     }
 453:   })
 454: 
 455:   // ==================== èŽ·å–ç”¨æˆ·å¯ç”¨å®žä¾‹åˆ—è¡¨ ====================
 456:   fastify.get('/instances', {
 457:     onRequest: [fastify.authenticateUser]
 458:   }, async (request: FastifyRequest, _reply: FastifyReply) => {
 459:     const { user } = request
 460:     const instances = await db.getUserInstancesForRedeem(user.id)
 461:     return { instances }
 462:   })
 463: 
 464:   // ==================== èŽ·å–ç­¾åˆ°è®°å½• ====================
 465:   fastify.get<{
 466:     Querystring: {
 467:       limit?: number
 468:       offset?: number
 469:     }
 470:   }>('/records', {
 471:     onRequest: [fastify.authenticateUser],
 472:     schema: {
 473:       querystring: {
 474:         type: 'object',
 475:         properties: {
 476:           limit: { type: 'integer', minimum: 1, maximum: 100, default: 20 },
 477:           offset: { type: 'integer', minimum: 0, default: 0 }
 478:         }
 479:       }
 480:     }
 481:   }, async (request: FastifyRequest<{ Querystring: { limit?: number; offset?: number } }>, _reply: FastifyReply) => {
 482:     const { user } = request
 483:     const { limit = 20, offset = 0 } = request.query
 484:     const result = await db.getCheckinRecords(user.id, limit, offset)
 485:     return result
 486:   })
 487: 
 488:   // ==================== èŽ·å–å…‘æ¢è®°å½• ====================
 489:   fastify.get<{
 490:     Querystring: {
 491:       limit?: number
 492:       offset?: number
 493:     }
 494:   }>('/redeems', {
 495:     onRequest: [fastify.authenticateUser],
 496:     schema: {
 497:       querystring: {
 498:         type: 'object',
 499:         properties: {
 500:           limit: { type: 'integer', minimum: 1, maximum: 100, default: 20 },
 501:           offset: { type: 'integer', minimum: 0, default: 0 }
 502:         }
 503:       }
 504:     }
 505:   }, async (request: FastifyRequest<{ Querystring: { limit?: number; offset?: number } }>, _reply: FastifyReply) => {
 506:     const { user } = request
 507:     const { limit = 20, offset = 0 } = request.query
 508:     const result = await db.getRedeemRecords(user.id, limit, offset)
 509:     return result
 510:   })
 511: }
--- server/src/routes/vip-levels.ts ---
   1: import type { FastifyInstance, FastifyReply } from 'fastify'
   2: import type { UserVipMetric, VipRuleType, VipRuleInput } from '../services/vip-levels.js'
   3: import {
   4:   MAX_VIP_LEVEL,
   5:   getVipOverview,
   6:   getUserVipMetric,
   7:   getVipRules,
   8:   replaceVipRules
   9: } from '../services/vip-levels.js'
  10: 
  11: function parseRuleType(value: string | undefined): VipRuleType | null {
  12:   return value === 'user' || value === 'hosting' ? value : null
  13: }
  14: 
  15: function sendInvalidType(reply: FastifyReply) {
  16:   return reply.status(400).send({ error: 'Invalid VIP rule type' })
  17: }
  18: 
  19: function parseUserVipMetric(value: unknown): UserVipMetric | null {
  20:   return value === 'totalRecharge' || value === 'totalConsume' ? value : null
  21: }
  22: 
  23: export default async function vipLevelRoutes(app: FastifyInstance): Promise<void> {
  24:   app.get('/api/vip-levels/me', {
  25:     onRequest: [app.authenticate],
  26:     config: { rateLimit: { max: 60, timeWindow: '1 minute' } }
  27:   }, async (request) => {
  28:     return getVipOverview(request.user.id)
  29:   })
  30: 
  31:   app.get<{
  32:     Params: { type: string }
  33:   }>('/api/admin/vip-levels/:type', {
  34:     onRequest: [app.authenticate, app.requireAdmin],
  35:     config: { rateLimit: { max: 30, timeWindow: '1 minute' } }
  36:   }, async (request, reply) => {
  37:     const type = parseRuleType(request.params.type)
  38:     if (!type) return sendInvalidType(reply)
  39: 
  40:     return {
  41:       type,
  42:       maxLevel: MAX_VIP_LEVEL,
  43:       userMetric: type === 'user' ? await getUserVipMetric() : undefined,
  44:       rules: await getVipRules(type)
  45:     }
  46:   })
  47: 
  48:   app.put<{
  49:     Params: { type: string }
  50:     Body: { rules?: VipRuleInput[], userMetric?: UserVipMetric }
  51:   }>('/api/admin/vip-levels/:type', {
  52:     onRequest: [app.authenticate, app.requireAdmin],
  53:     config: { rateLimit: { max: 20, timeWindow: '1 minute' } }
  54:   }, async (request, reply) => {
  55:     const type = parseRuleType(request.params.type)
  56:     if (!type) return sendInvalidType(reply)
  57: 
  58:     const rules = Array.isArray(request.body?.rules) ? request.body.rules : []
  59:     let userMetric: UserVipMetric | undefined
  60:     if (type === 'user') {
  61:       const parsedUserMetric = parseUserVipMetric(request.body?.userMetric)
  62:       if (!parsedUserMetric) {
  63:         return reply.status(400).send({ error: 'Invalid user VIP metric' })
  64:       }
  65:       userMetric = parsedUserMetric
  66:     }
  67: 
  68:     try {
  69:       const savedRules = await replaceVipRules(type, rules, userMetric)
  70:       return {
  71:         type,
  72:         maxLevel: MAX_VIP_LEVEL,
  73:         userMetric,
  74:         rules: savedRules
  75:       }
  76:     } catch (error: any) {
  77:       request.log.warn({ error }, 'VIP level rule validation failed')
  78:       return reply.status(400).send({ error: error?.message || 'Invalid VIP level rules' })
  79:     }
  80:   })
  81: }
--- server/src/routes/vip-benefits.ts ---
   1: import type { FastifyInstance, FastifyReply } from 'fastify'
   2: import { VipBenefitError } from '../services/vip-benefits.js'
   3: import {
   4:   claimAllAvailableVipBenefitRewards,
   5:   claimVipBenefitReward,
   6:   createVipBenefitReward,
   7:   deleteVipBenefitReward,
   8:   getVipBenefitOverview,
   9:   listAdminVipBenefitRewards,
  10:   updateVipBenefitReward,
  11:   type VipBenefitRewardInput
  12: } from '../services/vip-benefits.js'
  13: 
  14: const POSITIVE_ROUTE_ID_PATTERN = /^[1-9]\d*$/
  15: 
  16: function parsePositiveRouteId(value: string): number | null {
  17:   if (!POSITIVE_ROUTE_ID_PATTERN.test(value)) return null
  18:   const parsed = Number(value)
  19:   return Number.isSafeInteger(parsed) ? parsed : null
  20: }
  21: 
  22: function sendVipBenefitError(reply: FastifyReply, error: unknown) {
  23:   if (error instanceof VipBenefitError) {
  24:     return reply.status(error.statusCode).send({
  25:       error: error.message,
  26:       code: error.code
  27:     })
  28:   }
  29:   throw error
  30: }
  31: 
  32: export default async function vipBenefitRoutes(app: FastifyInstance): Promise<void> {
  33:   app.get('/api/vip-benefits/me', {
  34:     onRequest: [app.authenticate],
  35:     config: { rateLimit: { max: 60, timeWindow: '1 minute' } }
  36:   }, async (request) => {
  37:     return getVipBenefitOverview(request.user.id)
  38:   })
  39: 
  40:   app.post<{
  41:     Params: { rewardId: string }
  42:   }>('/api/vip-benefits/:rewardId/claim', {
  43:     onRequest: [app.authenticate],
  44:     config: { rateLimit: { max: 100, timeWindow: '3 minutes' } }
  45:   }, async (request, reply) => {
  46:     const rewardId = parsePositiveRouteId(request.params.rewardId)
  47:     if (!rewardId) {
  48:       return reply.status(400).send({ error: 'Invalid VIP benefit reward ID', code: 'INVALID_REWARD_ID' })
  49:     }
  50: 
  51:     try {
  52:       return await claimVipBenefitReward(request.user.id, rewardId)
  53:     } catch (error) {
  54:       return sendVipBenefitError(reply, error)
  55:     }
  56:   })
  57: 
  58:   app.post('/api/vip-benefits/claim-all', {
  59:     onRequest: [app.authenticate],
  60:     config: { rateLimit: { max: 30, timeWindow: '3 minutes' } }
  61:   }, async (request, reply) => {
  62:     try {
  63:       return await claimAllAvailableVipBenefitRewards(request.user.id)
  64:     } catch (error) {
  65:       return sendVipBenefitError(reply, error)
  66:     }
  67:   })
  68: 
  69:   app.get('/api/admin/vip-benefits/rewards', {
  70:     onRequest: [app.authenticate, app.requireAdmin],
  71:     config: { rateLimit: { max: 30, timeWindow: '1 minute' } }
  72:   }, async () => {
  73:     return { rewards: await listAdminVipBenefitRewards() }
  74:   })
  75: 
  76:   app.post<{
  77:     Body: VipBenefitRewardInput
  78:   }>('/api/admin/vip-benefits/rewards', {
  79:     onRequest: [app.authenticate, app.requireAdmin],
  80:     config: { rateLimit: { max: 20, timeWindow: '1 minute' } }
  81:   }, async (request, reply) => {
  82:     try {
  83:       return { reward: await createVipBenefitReward(request.body || {}) }
  84:     } catch (error) {
  85:       return sendVipBenefitError(reply, error)
  86:     }
  87:   })
  88: 
  89:   app.put<{
  90:     Params: { id: string }
  91:     Body: VipBenefitRewardInput
  92:   }>('/api/admin/vip-benefits/rewards/:id', {
  93:     onRequest: [app.authenticate, app.requireAdmin],
  94:     config: { rateLimit: { max: 20, timeWindow: '1 minute' } }
  95:   }, async (request, reply) => {
  96:     const id = parsePositiveRouteId(request.params.id)
  97:     if (!id) {
  98:       return reply.status(400).send({ error: 'Invalid VIP benefit reward ID', code: 'INVALID_REWARD_ID' })
  99:     }
 100: 
 101:     try {
 102:       return { reward: await updateVipBenefitReward(id, request.body || {}) }
 103:     } catch (error) {
 104:       return sendVipBenefitError(reply, error)
 105:     }
 106:   })
 107: 
 108:   app.delete<{
 109:     Params: { id: string }
 110:   }>('/api/admin/vip-benefits/rewards/:id', {
 111:     onRequest: [app.authenticate, app.requireAdmin],
 112:     config: { rateLimit: { max: 10, timeWindow: '1 minute' } }
 113:   }, async (request, reply) => {
 114:     const id = parsePositiveRouteId(request.params.id)
 115:     if (!id) {
 116:       return reply.status(400).send({ error: 'Invalid VIP benefit reward ID', code: 'INVALID_REWARD_ID' })
 117:     }
 118: 
 119:     try {
 120:       await deleteVipBenefitReward(id)
 121:       return { success: true }
 122:     } catch (error) {
 123:       return sendVipBenefitError(reply, error)
 124:     }
 125:   })
 126: }
--- server/src/lib/lottery-notifier.ts ---
   1: /**
   2:  * æŠ½å¥–ä¸­å¥–é€šçŸ¥æ¨¡å—
   3:  * å‘ç®¡ç†å‘˜é…ç½®çš„é€šçŸ¥æ¸ é“å‘é€ä¸­å¥–é€šçŸ¥
   4:  */
   5: import * as db from '../db/index.js'
   6: import { assertSafeWebhookUrl } from './outbound-security.js'
   7: import { sanitizeTokensInString } from './log-sanitizer.js'
   8: 
   9: const LOTTERY_NOTIFICATION_FETCH_TIMEOUT_MS = 15_000
  10: const LOTTERY_NOTIFICATION_ERROR_PREVIEW_MAX_CHARS = 2_000
  11: 
  12: // ==================== é€šçŸ¥å†…å®¹æ¨¡æ¿ ====================
  13: 
  14: const LOTTERY_ADMIN_NOTIFICATIONS = {
  15:   balance_win: {
  16:     title: 'ðŸ’° ä½™é¢ä¸­å¥–é€šçŸ¥',
  17:     message: (data: {
  18:       username: string
  19:       lotteryName: string
  20:       prizeName: string
  21:       amount: number // åˆ†
  22:     }) => `ç”¨æˆ· ${data.username} åœ¨ã€Œ${data.lotteryName}ã€æŠ½ä¸­äº†ã€Œ${data.prizeName}ã€\n` +
  23:       `å¥–åŠ±é‡‘é¢ï¼šÂ¥${(data.amount / 100).toFixed(2)}\n` +
  24:       `å·²è‡ªåŠ¨å‘æ”¾åˆ°ç”¨æˆ·ä½™é¢`
  25:   },
  26: 
  27:   instance_win: {
  28:     title: 'ðŸŽ å®žä¾‹ä¸­å¥–é€šçŸ¥',
  29:     message: (data: {
  30:       username: string
  31:       lotteryName: string
  32:       prizeName: string
  33:       instanceDesc?: string
  34:     }) => `ç”¨æˆ· ${data.username} åœ¨ã€Œ${data.lotteryName}ã€æŠ½ä¸­äº†ã€Œ${data.prizeName}ã€\n` +
  35:       (data.instanceDesc ? `å¥–åŠ±å†…å®¹ï¼š${data.instanceDesc}\n` : '') +
  36:       `è¯·ç­‰å¾…ç”¨æˆ·æäº¤å·¥å•åŽæ‰‹åŠ¨å‘æ”¾`
  37:   }
  38: }
  39: 
  40: // ==================== é€šçŸ¥å‘é€å‡½æ•° ====================
  41: 
  42: interface LotteryWinNotification {
  43:   lotteryId: number
  44:   recordId: number
  45:   prizeType: 'balance' | 'instance'
  46:   username: string
  47:   lotteryName: string
  48:   prizeName: string
  49:   amount?: number       // ä½™é¢å¥–åŠ±é‡‘é¢ï¼ˆåˆ†ï¼‰
  50:   instanceDesc?: string // å®žä¾‹æè¿°
  51: }
  52: 
  53: async function readSafeNotificationError(response: Response): Promise<string> {
  54:   const text = await response.text()
  55:   const sanitized = sanitizeTokensInString(text)
  56:   const preview = sanitized.slice(0, LOTTERY_NOTIFICATION_ERROR_PREVIEW_MAX_CHARS)
  57:   return preview || `HTTP ${response.status}`
  58: }
  59: 
  60: /**
  61:  * å‘é€æŠ½å¥–ä¸­å¥–é€šçŸ¥åˆ°ç®¡ç†å‘˜é…ç½®çš„æ¸ é“
  62:  */
  63: export async function sendLotteryWinNotification(data: LotteryWinNotification): Promise<void> {
  64:   try {
  65:     // 1. èŽ·å–è¯¥æŠ½å¥–çš„é€šçŸ¥é…ç½®
  66:     const notifyConfig = await db.getLotteryNotificationConfig(data.lotteryId)
  67: 
  68:     if (!notifyConfig || !notifyConfig.enabled) {
  69:       console.log(`[LotteryNotifier] Lottery ${data.lotteryId} notification disabled or not configured`)
  70:       return
  71:     }
  72: 
  73:     // 2. æ£€æŸ¥æ˜¯å¦éœ€è¦é€šçŸ¥è¯¥ç±»åž‹
  74:     if (data.prizeType === 'balance' && !notifyConfig.notifyBalance) {
  75:       console.log(`[LotteryNotifier] Balance notification disabled for lottery ${data.lotteryId}`)
  76:       return
  77:     }
  78:     if (data.prizeType === 'instance' && !notifyConfig.notifyInstance) {
  79:       console.log(`[LotteryNotifier] Instance notification disabled for lottery ${data.lotteryId}`)
  80:       return
  81:     }
  82: 
  83:     // 3. æž„å»ºé€šçŸ¥å†…å®¹
  84:     let title: string
  85:     let message: string
  86: 
  87:     if (data.prizeType === 'balance') {
  88:       title = LOTTERY_ADMIN_NOTIFICATIONS.balance_win.title
  89:       message = LOTTERY_ADMIN_NOTIFICATIONS.balance_win.message({
  90:         username: data.username,
  91:         lotteryName: data.lotteryName,
  92:         prizeName: data.prizeName,
  93:         amount: data.amount || 0
  94:       })
  95:     } else {
  96:       title = LOTTERY_ADMIN_NOTIFICATIONS.instance_win.title
  97:       message = LOTTERY_ADMIN_NOTIFICATIONS.instance_win.message({
  98:         username: data.username,
  99:         lotteryName: data.lotteryName,
 100:         prizeName: data.prizeName,
 101:         instanceDesc: data.instanceDesc
 102:       })
 103:     }
 104: 
 105:     // 4. æ ¹æ®é…ç½®çš„æ¸ é“å‘é€
 106:     const config = notifyConfig.config as Record<string, string>
 107: 
 108:     switch (notifyConfig.type) {
 109:       case 'telegram':
 110:         await sendTelegram(config.botToken, config.chatId, title, message)
 111:         break
 112:       case 'discord':
 113:         await sendDiscord(config.webhookUrl, title, message)
 114:         break
 115:       case 'webhook':
 116:         await sendWebhook(config.url, config.secret, {
 117:           event: `lottery_win_${data.prizeType}`,
 118:           title,
 119:           message,
 120:           data
 121:         })
 122:         break
 123:       default:
 124:         console.warn(`[LotteryNotifier] Unknown channel type: ${notifyConfig.type}`)
 125:     }
 126: 
 127:     // 5. æ ‡è®°é€šçŸ¥å·²å‘é€
 128:     await db.markRecordNotificationSent(data.recordId)
 129: 
 130:     console.log(`[LotteryNotifier] Sent ${data.prizeType} win notification for lottery ${data.lotteryId}, user ${data.username}`)
 131:   } catch (err) {
 132:     console.error(`[LotteryNotifier] Failed to send notification:`, err)
 133:   }
 134: }
