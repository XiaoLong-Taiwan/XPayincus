 378: 
 379: // ä¿å­˜å¥–å“
 380: async function savePrizes() {
 381:   // éªŒè¯
 382:   for (const prize of prizes.value) {
 383:     if (!prize.name.trim()) {
 384:       toast.warning(t('entertainment.admin.enterPrizeName'))
 385:       return
 386:     }
 387:     if (prize.probability <= 0) {
 388:       toast.warning(t('entertainment.admin.invalidProbability'))
 389:       return
 390:     }
 391:   }
 392: 
 393:   savingPrizes.value = true
 394:   try {
 395:     const lotteryId = editingPrizes.value.id
 396:     const existingPrizes = editingPrizes.value.prizes || []
 397:     const existingIds = existingPrizes.map((p: any) => p.id)
 398:     const newPrizeIds = prizes.value.filter(p => p.id).map(p => p.id)
 399:     
 400:     // åˆ é™¤ä¸åœ¨æ–°åˆ—è¡¨ä¸­çš„å¥–å“
 401:     for (const existingId of existingIds) {
 402:       if (!newPrizeIds.includes(existingId)) {
 403:         await api.entertainment.adminDeletePrize(existingId)
 404:       }
 405:     }
 406:     
 407:     // æ›´æ–°æˆ–åˆ›å»ºå¥–å“
 408:     for (let i = 0; i < prizes.value.length; i++) {
 409:       const prize = prizes.value[i]
 410:       // è®¡ç®—æ–°çš„å‰©ä½™æ•°é‡ï¼ˆå¦‚æžœæœ‰è¡¥å……ï¼‰
 411:       let newRemainQuantity = prize.remainQuantity
 412:       if (prize.replenishAmount && prize.replenishAmount > 0) {
 413:         newRemainQuantity = (prize.remainQuantity || 0) + prize.replenishAmount
 414:       }
 415:       
 416:       const prizeData = {
 417:         name: prize.name.trim(),
 418:         type: prize.type,
 419:         value: prize.value || 0,
 420:         probability: prize.probability,
 421:         totalQuantity: prize.totalQuantity || undefined,
 422:         remainQuantity: newRemainQuantity,
 423:         displayOrder: i,
 424:         instanceDesc: prize.type === 'instance' ? prize.instanceDesc : undefined
 425:       }
 426:       
 427:       if (prize.id && existingIds.includes(prize.id)) {
 428:         // æ›´æ–°çŽ°æœ‰å¥–å“
 429:         await api.entertainment.adminUpdatePrize(prize.id, prizeData)
 430:       } else {
 431:         // åˆ›å»ºæ–°å¥–å“
 432:         await api.entertainment.adminCreatePrize(lotteryId, prizeData)
 433:       }
 434:     }
 435:     
 436:     toast.success(t('entertainment.admin.savePrizesSuccess'))
 437:     showPrizesModal.value = false
 438:     loadLotteries()
 439:   } catch (err: any) {
 440:     toast.error(t('entertainment.admin.savePrizesFailed') + ': ' + err.message)
 441:   } finally {
 442:     savingPrizes.value = false
 443:   }
 444: }
