 685: export async function getHostingVipStats(userId: number, client: DbClient = prisma): Promise<HostingVipStats> {
 686:   const [incomeResult, instanceCount] = await Promise.all([
 687:     client.hostingBalanceLog.aggregate({
 688:       where: { userId, type: 'income' },
 689:       _sum: { amount: true }
 690:     }),
 691:     client.instance.count({
 692:       where: {
 693:         host: { userId },
 694:         status: { not: 'deleted' }
 695:       }
 696:     })
 697:   ])
 698: 
 699:   return {
 700:     totalHostingIncome: toNumber(incomeResult._sum.amount),
 701:     instanceCount
 702:   }
 703: }
