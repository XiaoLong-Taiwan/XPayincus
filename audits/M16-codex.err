  28: const LOTTERY_RECORD_STATUSES = new Set<LotteryRecordStatus>(['pending', 'delivered', 'claimed'])
  29: 
  30: function clampPagination(
  31:   page: number | undefined,
  32:   pageSize: number | undefined,
  33:   fallbackPageSize: number = 20,
  34:   maxPageSize: number = 100
  35: ): { page: number; pageSize: number } {
  36:   return {
  37:     page: Number.isInteger(page) && page !== undefined && page > 0 ? page : 1,
  38:     pageSize: Number.isInteger(pageSize) && pageSize !== undefined
  39:       ? Math.min(Math.max(pageSize, 1), maxPageSize)
  40:       : fallbackPageSize
  41:   }
  42: }
  43: 
  44: function normalizeLotteryPrizeType(type: LotteryPrizeType | undefined): LotteryPrizeType | undefined {
  45:   return type && LOTTERY_PRIZE_TYPES.has(type) ? type : undefined
  46: }
  47: 
  48: function normalizeLotteryRecordStatus(status: LotteryRecordStatus | undefined): LotteryRecordStatus | undefined {
  49:   return status && LOTTERY_RECORD_STATUSES.has(status) ? status : undefined
  50: }
