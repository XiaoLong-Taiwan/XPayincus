 339: async function redeemCode() {
 340:   const code = redeemCodeInput.value.trim()
 341:   if (!code) { toast.warning(t('checkin.enterCode')); return }
 342:   if (!redeemSelectedInstance.value) { toast.warning(t('checkin.selectInstance')); return }
 343:   try {
 344:     redeemLoading.value = true
 345:     const result = await api.checkin.redeem(code, redeemSelectedInstance.value)
 346:     toast.success(t('checkin.redeemToInstanceSuccess', { type: getResourceTypeName(result.codeType), value: result.actualAdded, unit: getResourceUnit(result.codeType), instance: result.instanceName }))
 347:     redeemCodeInput.value = ''
 348:     await loadResourcePool()
 349:   } catch (err: any) {
 350:     toast.error(translateError(err))
 351:   } finally {
 352:     redeemLoading.value = false
 353:   }
 354: }
