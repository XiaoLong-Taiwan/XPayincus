   1: /**
   2:  * ç§¯åˆ†ç³»ç»Ÿæ•°æ®åº“æ“ä½œ
   3:  */
   4: import { prisma } from './prisma.js'
   5: import { Prisma } from '@prisma/client'
   6: import type { PointsLogType } from '@prisma/client'
   7: import { getUserTotalConsume } from './balance.js'
   8: import { USER_POINTS_LOCK_NAMESPACE, advisoryTransactionLock } from './advisory-locks.js'
   9: 
  10: // ==================== ç”¨æˆ·ç§¯åˆ† ====================
  11: 
  12: type UserPointsClient = typeof prisma | Prisma.TransactionClient
  13: const POINTS_LOG_TYPES = new Set<PointsLogType>([
  14:   'convert',
  15:   'lottery_win',
  16:   'lottery_spend',
  17:   'admin_adjust',
  18:   'checkin',
  19:   'badge_draw_spend',
  20:   'badge_select_spend',
  21:   'invite_generate',
  22:   'vip_benefit'
  23: ])
  24: const USER_POINTS_ORDER_BY_FIELDS = new Set(['points', 'totalEarned', 'totalSpent'])
  25: const SORT_ORDERS = new Set(['asc', 'desc'])
  26: const MAX_POINTS_MUTATION_AMOUNT = 1_000_000_000
  27: const MAX_POINTS_BALANCE = 2_147_483_647
  28: 
  29: function isSafePointsAmount(value: number): boolean {
  30:   return Number.isSafeInteger(value) && value > 0 && value <= MAX_POINTS_MUTATION_AMOUNT
  31: }
  32: 
  33: function isSafePointsAdjustment(value: number): boolean {
  34:   return Number.isSafeInteger(value) && value !== 0 && Math.abs(value) <= MAX_POINTS_MUTATION_AMOUNT
  35: }
  36: 
  37: function isSafePointsBalance(value: number): boolean {
  38:   return Number.isSafeInteger(value) && value >= 0 && value <= MAX_POINTS_BALANCE
  39: }
  40: 
  41: function assertSafePointsBalance(value: number): void {
  42:   if (!isSafePointsBalance(value)) {
  43:     throw new Error('ç§¯åˆ†ä½™é¢è¶…å‡ºç³»ç»Ÿå…è®¸èŒƒå›´')
  44:   }
  45: }
  46: 
  47: function assertSafePointsCounter(value: number): void {
  48:   if (!Number.isSafeInteger(value) || value < 0 || value > MAX_POINTS_BALANCE) {
  49:     throw new Error('ç§¯åˆ†ç»Ÿè®¡è¶…å‡ºç³»ç»Ÿå…è®¸èŒƒå›´')
  50:   }
  51: }
  52: 
  53: function clampPagination(
  54:   page: number | undefined,
  55:   pageSize: number | undefined,
  56:   fallbackPageSize: number = 20,
  57:   maxPageSize: number = 100
  58: ): { page: number; pageSize: number } {
  59:   return {
  60:     page: Number.isInteger(page) && page !== undefined && page > 0 ? page : 1,
  61:     pageSize: Number.isInteger(pageSize) && pageSize !== undefined
  62:       ? Math.min(Math.max(pageSize, 1), maxPageSize)
  63:       : fallbackPageSize
  64:   }
  65: }
  66: 
  67: function normalizePointsLogType(type: PointsLogType | undefined): PointsLogType | undefined {
  68:   return type && POINTS_LOG_TYPES.has(type) ? type : undefined
  69: }
  70: 
  71: function normalizeUserPointsOrderBy(orderBy: string | undefined): 'points' | 'totalEarned' | 'totalSpent' {
  72:   return orderBy && USER_POINTS_ORDER_BY_FIELDS.has(orderBy) ? orderBy as 'points' | 'totalEarned' | 'totalSpent' : 'points'
  73: }
  74: 
  75: function normalizeSortOrder(order: string | undefined): 'asc' | 'desc' {
  76:   return order && SORT_ORDERS.has(order) ? order as 'asc' | 'desc' : 'desc'
  77: }
  78: 
  79: async function ensureUserPoints(client: UserPointsClient, userId: number) {
  80:   const existing = await client.userPoints.findUnique({
  81:     where: { userId }
  82:   })
  83:   if (existing) return existing
  84: 
  85:   await client.$executeRaw(Prisma.sql`
  86:     INSERT INTO "user_points" ("user_id", "updated_at")
  87:     VALUES (${userId}, NOW())
  88:     ON CONFLICT ("user_id") DO NOTHING
  89:   `)
  90: 
  91:   const userPoints = await client.userPoints.findUnique({
  92:     where: { userId }
  93:   })
  94:   if (!userPoints) {
  95:     throw new Error('USER_POINTS_CREATE_FAILED')
  96:   }
  97: 
  98:   return userPoints
  99: }
 100: 
 101: /**
 102:  * èŽ·å–ç”¨æˆ·ç§¯åˆ†ä¿¡æ¯
 103:  */
 104: export async function getUserPoints(userId: number) {
 105:   return ensureUserPoints(prisma, userId)
 106: }
 107: 
 108: /**
 109:  * èŽ·å–ç”¨æˆ·å¯å…‘æ¢çš„æ¶ˆè´¹é‡‘é¢
 110:  */
 111: export async function getConvertibleConsume(userId: number): Promise<{
 112:   totalConsume: number
 113:   convertedConsume: number
 114:   convertibleAmount: number
 115:   convertiblePoints: number
 116: }> {
 117:   // èŽ·å–ç”¨æˆ·ç§¯åˆ†è®°å½•
 118:   const userPoints = await getUserPoints(userId)
 119: 
 120:   // èŽ·å–ç”¨æˆ·å®žé™…æ€»æ¶ˆè´¹é¢ï¼Œå…¼å®¹åŽ†å² consume æ—¥å¿— amount æ­£è´Ÿå·ä¸ä¸€è‡´
 121:   const totalConsume = await getUserTotalConsume(userId)
 122: 
 123:   // è®¡ç®—å¯å…‘æ¢é‡‘é¢
 124:   const convertedConsume = parseFloat(String(userPoints.convertedConsume))
 125:   const convertibleAmount = Math.max(0, totalConsume - convertedConsume)
 126:   const convertiblePoints = Math.floor(convertibleAmount * 100) // 1å…ƒ = 100ç§¯åˆ†
 127: 
 128:   return {
 129:     totalConsume,
 130:     convertedConsume,
 131:     convertibleAmount,
 132:     convertiblePoints
 133:   }
 134: }
 135: 
 136: /**
 137:  * å…‘æ¢ç§¯åˆ†
 138:  */
 139: export async function convertPointsFromConsumption(userId: number): Promise<{
 140:   success: boolean
 141:   converted: number
 142:   newPoints: number
 143:   consumeConverted: number
 144:   message?: string
 145: }> {
 146:   return prisma.$transaction(async (tx) => {
 147:     await advisoryTransactionLock(tx, USER_POINTS_LOCK_NAMESPACE, userId)
 148: 
 149:     const userPoints = await ensureUserPoints(tx, userId)
 150: 
 151:     // 2. èŽ·å–ç”¨æˆ·å½“å‰å®žé™…æ€»æ¶ˆè´¹é¢ï¼Œå…¼å®¹åŽ†å² consume æ—¥å¿— amount æ­£è´Ÿå·ä¸ä¸€è‡´
 152:     const totalConsume = await getUserTotalConsume(userId, tx)
 153: 
 154:     // 3. è®¡ç®—å¯å…‘æ¢çš„æ–°ç§¯åˆ†
 155:     const alreadyConverted = parseFloat(String(userPoints.convertedConsume))
 156:     const newConvertableConsume = totalConsume - alreadyConverted
 157: 
 158:     if (newConvertableConsume <= 0) {
 159:       return {
 160:         success: false,
 161:         converted: 0,
 162:         newPoints: userPoints.points,
 163:         consumeConverted: 0,
 164:         message: 'æš‚æ— å¯å…‘æ¢çš„æ¶ˆè´¹é¢'
 165:       }
 166:     }
 167: 
 168:     // 4. è®¡ç®—æ–°ç§¯åˆ†ï¼ˆ1å…ƒ = 100ç§¯åˆ†ï¼‰
 169:     const newPoints = Math.floor(newConvertableConsume * 100)
 170:     if (!isSafePointsAmount(newPoints)) {
 171:       return {
 172:         success: false,
 173:         converted: 0,
 174:         newPoints: userPoints.points,
 175:         consumeConverted: 0,
 176:         message: 'å¯å…‘æ¢ç§¯åˆ†æ•°é‡è¶…å‡ºç³»ç»Ÿå…è®¸èŒƒå›´'
 177:       }
 178:     }
 179:     assertSafePointsBalance(userPoints.points + newPoints)
 180:     assertSafePointsCounter(userPoints.totalEarned + newPoints)
 181: 
 182:     // 5. æ›´æ–°ç”¨æˆ·ç§¯åˆ†
 183:     const updatedPoints = await tx.userPoints.update({
 184:       where: { userId },
 185:       data: {
 186:         points: { increment: newPoints },
 187:         totalEarned: { increment: newPoints },
 188:         convertedConsume: totalConsume,
 189:         lastConvertedAt: new Date()
 190:       }
 191:     })
 192: 
 193:     // 6. è®°å½•ç§¯åˆ†å˜åŠ¨æ—¥å¿—
 194:     await tx.pointsLog.create({
 195:       data: {
 196:         userId,
 197:         type: 'convert',
 198:         amount: newPoints,
 199:         pointsBefore: userPoints.points,
 200:         pointsAfter: updatedPoints.points,
 201:         remark: `æ¶ˆè´¹å…‘æ¢ï¼šÂ¥${newConvertableConsume.toFixed(2)} â†’ ${newPoints}ç§¯åˆ†`
 202:       }
 203:     })
 204: 
 205:     return {
 206:       success: true,
 207:       converted: newPoints,
 208:       newPoints: updatedPoints.points,
 209:       consumeConverted: newConvertableConsume
 210:     }
 211:   })
 212: }
 213: 
 214: /**
 215:  * æ‰£é™¤ç”¨æˆ·ç§¯åˆ†ï¼ˆç”¨äºŽæŠ½å¥–ï¼‰
 216:  */
 217: export async function deductPoints(
 218:   userId: number,
 219:   amount: number,
 220:   relatedId?: number,
 221:   remark?: string
 222: ): Promise<{ success: boolean; newPoints: number; message?: string }> {
 223:   if (!isSafePointsAmount(amount)) {
 224:     return { success: false, newPoints: 0, message: 'ç§¯åˆ†æ‰£é™¤æ•°é‡æ— æ•ˆ' }
 225:   }
 226: 
 227:   return prisma.$transaction(async (tx) => {
 228:     await advisoryTransactionLock(tx, USER_POINTS_LOCK_NAMESPACE, userId)
 229: 
 230:     const userPoints = await tx.userPoints.findUnique({ where: { userId } })
 231:     if (!userPoints) {
 232:       return { success: false, newPoints: 0, message: 'ç§¯åˆ†è´¦æˆ·ä¸å­˜åœ¨' }
 233:     }
 234: 
 235:     if (userPoints.points < amount) {
 236:       return { success: false, newPoints: userPoints.points, message: 'ç§¯åˆ†ä¸è¶³' }
 237:     }
 238:     if (userPoints.totalSpent + amount > MAX_POINTS_BALANCE) {
 239:       return { success: false, newPoints: userPoints.points, message: 'ç§¯åˆ†ç»Ÿè®¡è¶…å‡ºç³»ç»Ÿå…è®¸èŒƒå›´' }
 240:     }
 241: 
 242:     const updatedPoints = await tx.userPoints.update({
 243:       where: { userId },
 244:       data: {
 245:         points: { decrement: amount },
 246:         totalSpent: { increment: amount }
 247:       }
 248:     })
 249: 
 250:     await tx.pointsLog.create({
 251:       data: {
 252:         userId,
 253:         type: 'lottery_spend',
 254:         amount: -amount,
 255:         pointsBefore: userPoints.points,
 256:         pointsAfter: updatedPoints.points,
 257:         relatedId,
 258:         remark: remark || `æŠ½å¥–æ¶ˆè€— ${amount} ç§¯åˆ†`
 259:       }
 260:     })
 261: 
 262:     return { success: true, newPoints: updatedPoints.points }
 263:   })
 264: }
