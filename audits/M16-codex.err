 565: function buildClaimSnapshot(reward: VipBenefitReward, config: VipBenefitRewardConfig): Prisma.InputJsonObject {
 566:   return {
 567:     rewardId: reward.id,
 568:     level: reward.level,
 569:     type: reward.type,
 570:     title: reward.title,
 571:     description: reward.description,
 572:     claimLimit: reward.claimLimit,
 573:     config: config as Prisma.InputJsonObject
 574:   }
 575: }
