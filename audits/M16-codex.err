 459: export async function getVipBenefitOverview(userId: number): Promise<VipBenefitOverview> {
 460:   const [vip, rewards, claims] = await Promise.all([
 461:     getCurrentUserVip(userId),
 462:     prisma.vipBenefitReward.findMany({
 463:       where: { enabled: true },
 464:       orderBy: [
 465:         { level: 'asc' },
 466:         { sortOrder: 'asc' },
 467:         { id: 'asc' }
 468:       ]
 469:     }),
 470:     prisma.vipBenefitClaim.findMany({
 471:       where: { userId },
 472:       orderBy: [
 473:         { level: 'asc' },
 474:         { rewardId: 'asc' },
 475:         { claimNo: 'asc' }
 476:       ]
 477:     })
 478:   ])
 479: 
 480:   const claimsByReward = new Map<number, VipBenefitClaim[]>()
 481:   for (const claim of claims) {
 482:     const list = claimsByReward.get(claim.rewardId) || []
 483:     list.push(claim)
 484:     claimsByReward.set(claim.rewardId, list)
 485:   }
 486: 
 487:   const outstandingLevels = new Set<number>()
 488:   const baseViews = rewards.map((reward) => {
 489:     const rewardClaims = claimsByReward.get(reward.id) || []
 490:     const claimedCount = rewardClaims.length
 491:     const remainingClaims = Math.max(0, reward.claimLimit - claimedCount)
 492:     if (reward.level <= vip.level && remainingClaims > 0) {
 493:       outstandingLevels.add(reward.level)
 494:     }
 495:     return {
 496:       reward,
 497:       claimedCount,
 498:       remainingClaims,
 499:       claims: rewardClaims
 500:     }
 501:   })
 502: 
 503:   const rewardViews: VipBenefitRewardView[] = baseViews.map((item) => {
 504:     const type = item.reward.type as VipBenefitRewardTypeValue
 505:     const lowerOutstanding = Array.from(outstandingLevels)
 506:       .filter(level => level < item.reward.level)
 507:       .sort((a, b) => a - b)[0] ?? null
 508:     const state: VipBenefitRewardState = item.remainingClaims <= 0
 509:       ? 'claimed'
 510:       : item.reward.level > vip.level
 511:         ? 'locked'
 512:         : lowerOutstanding
 513:           ? 'blocked'
 514:           : 'claimable'
 515: 
 516:     return {
 517:       id: item.reward.id,
 518:       level: item.reward.level,
 519:       type,
 520:       title: item.reward.title,
--- server/src/services/vip-benefits.ts 521-764 ---
 521:       description: item.reward.description,
 522:       claimLimit: item.reward.claimLimit,
 523:       sortOrder: item.reward.sortOrder,
 524:       enabled: item.reward.enabled,
 525:       config: normalizeStoredRewardConfig(type, item.reward.config),
 526:       createdAt: item.reward.createdAt.toISOString(),
 527:       updatedAt: item.reward.updatedAt.toISOString(),
 528:       claimedCount: item.claimedCount,
 529:       remainingClaims: item.remainingClaims,
 530:       state,
 531:       blockedByLevel: state === 'blocked' ? lowerOutstanding : null,
 532:       claims: item.claims.map(claimToView)
 533:     }
 534:   })
 535: 
 536:   const entitlement: VipBenefitAmountSummary = { balanceAmount: 0, pointsAmount: 0, instanceQuantity: 0 }
 537:   const remaining: VipBenefitAmountSummary = { balanceAmount: 0, pointsAmount: 0, instanceQuantity: 0 }
 538:   for (const reward of rewardViews) {
 539:     if (reward.level <= vip.level) {
 540:       addRewardAmount(entitlement, reward, reward.claimLimit)
 541:       addRewardAmount(remaining, reward, reward.remainingClaims)
 542:     }
 543:   }
 544: 
 545:   return {
 546:     currentLevel: vip.level,
 547:     userVipMetric: vip.metric,
 548:     userStats: vip.stats,
 549:     userVipBadgeStyle: vip.badgeStyle,
 550:     rewards: rewardViews,
 551:     summary: {
 552:       totalRewards: rewardViews.length,
 553:       unlockedRewards: rewardViews.filter(reward => reward.level <= vip.level).length,
 554:       claimableRewards: rewardViews.filter(reward => reward.state === 'claimable').length,
 555:       claimedRewards: rewardViews.filter(reward => reward.state === 'claimed').length,
 556:       lockedRewards: rewardViews.filter(reward => reward.state === 'locked').length,
 557:       blockedRewards: rewardViews.filter(reward => reward.state === 'blocked').length,
 558:       pendingRewards: claims.filter(claim => claim.status === 'pending').length,
 559:       entitlement,
 560:       remaining
 561:     }
 562:   }
 563: }
