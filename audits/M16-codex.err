 258:     planName: normalizeLabel(config.planName),
 259:     days: Math.max(1, Math.min(MAX_INSTANCE_DAYS, Math.floor(toNumber(config.days) || 30))),
 260:     quantity: Math.max(1, Math.min(MAX_INSTANCE_QUANTITY, Math.floor(toNumber(config.quantity) || 1)))
