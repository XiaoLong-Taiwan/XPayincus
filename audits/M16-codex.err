 413:   const lotteryId = Number.isInteger(options.lotteryId) && options.lotteryId !== undefined && options.lotteryId > 0
 414:     ? options.lotteryId
 415:     : undefined
 416:   const prizeType = normalizeLotteryPrizeType(options.prizeType)
 417:   const status = normalizeLotteryRecordStatus(options.status)
 418:   const search = typeof options.search === 'string' ? options.search.trim().slice(0, 128) : undefined
 419:   const skip = (page - 1) * pageSize
 420: 
 421:   const where: Prisma.LotteryRecordWhereInput = {}
 422:   if (lotteryId) where.lotteryId = lotteryId
 423:   if (prizeType) where.prizeType = prizeType
 424:   if (status) where.status = status
 425:   if (search) {
 426:     where.user = {
 427:       username: { contains: search, mode: 'insensitive' }
 428:     }
 429:   }
