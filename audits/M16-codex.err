 119: export async function getDailyCheckinSettings(): Promise<DailyCheckinSettings> {
 120:   const [enabled, minPoints, maxPoints, requireInstance] = await Promise.all([
 121:     getSystemConfigBoolean('checkin_enabled', true),
 122:     getSystemConfigNumber('checkin_min_points', CHECKIN_MIN_POINTS_DEFAULT),
 123:     getSystemConfigNumber('checkin_max_points', CHECKIN_MAX_POINTS_DEFAULT),
 124:     getSystemConfigBoolean('checkin_require_instance', false)
 125:   ])
 126: 
 127:   return normalizeCheckinSettings({ enabled, minPoints, maxPoints, requireInstance })
 128: }
