 137: 
 138: /**
 139:  * è½¬ä¹‰ Markdown ç‰¹æ®Šå­—ç¬¦
 140:  */
 141: function escapeMarkdown(text: string): string {
 142:   return text.replace(/[_*[\]()~`>#+=|{}.!-]/g, '\\$&')
 143: }
 144: 
 145: /**
 146:  * å‘é€ Telegram é€šçŸ¥
 147:  */
 148: async function sendTelegram(
 149:   botToken: string,
 150:   chatId: string,
 151:   title: string,
 152:   message: string
 153: ): Promise<void> {
 154:   if (!botToken || !chatId) {
 155:     throw new Error('Missing botToken or chatId')
 156:   }
 157: 
 158:   const text = `*${escapeMarkdown(title)}*\n\n${escapeMarkdown(message)}`
 159: 
 160:   const response = await fetch(`https://api.telegram.org/bot${botToken}/sendMessage`, {
 161:     method: 'POST',
 162:     redirect: 'manual',
 163:     signal: AbortSignal.timeout(LOTTERY_NOTIFICATION_FETCH_TIMEOUT_MS),
 164:     headers: { 'Content-Type': 'application/json' },
 165:     body: JSON.stringify({
 166:       chat_id: chatId,
 167:       text,
 168:       parse_mode: 'MarkdownV2'
 169:     })
 170:   })
 171: 
 172:   const result = await response.json() as { ok: boolean; description?: string }
 173: 
 174:   if (!result.ok) {
 175:     throw new Error(result.description || 'Unknown Telegram error')
 176:   }
 177: }
 178: 
 179: /**
 180:  * å‘é€ Discord é€šçŸ¥
 181:  */
 182: async function sendDiscord(
 183:   webhookUrl: string,
 184:   title: string,
 185:   message: string
 186: ): Promise<void> {
 187:   if (!webhookUrl) {
 188:     throw new Error('Missing webhookUrl')
 189:   }
 190: 
 191:   // æ ¹æ®æ ‡é¢˜é€‰æ‹©é¢œè‰²
 192:   let color = 0x00ff00 // é»˜è®¤ç»¿è‰²
 193:   if (title.includes('ä½™é¢')) {
 194:     color = 0xffd700 // é‡‘è‰²
 195:   } else if (title.includes('å®žä¾‹')) {
 196:     color = 0x9b59b6 // ç´«è‰²
 197:   }
 198: 
 199:   const parsedUrl = await assertSafeWebhookUrl(webhookUrl)
 200:   const response = await fetch(parsedUrl.toString(), {
 201:     method: 'POST',
 202:     signal: AbortSignal.timeout(LOTTERY_NOTIFICATION_FETCH_TIMEOUT_MS),
 203:     headers: { 'Content-Type': 'application/json' },
 204:     body: JSON.stringify({
 205:       embeds: [{
 206:         title,
 207:         description: message,
 208:         color,
 209:         timestamp: new Date().toISOString(),
 210:         footer: {
 211:           text: 'Incudal æŠ½å¥–ç³»ç»Ÿ'
 212:         }
 213:       }]
 214:     }),
 215:     redirect: 'manual'
 216:   })
 217: 
 218:   if (!response.ok) {
 219:     throw new Error(await readSafeNotificationError(response))
 220:   }
 221: }
 222: 
 223: /**
 224:  * å‘é€ Webhook é€šçŸ¥
 225:  */
 226: async function sendWebhook(
 227:   url: string,
 228:   secret: string | undefined,
 229:   payload: Record<string, unknown>
 230: ): Promise<void> {
 231:   if (!url) {
 232:     throw new Error('Missing webhook URL')
 233:   }
 234: 
 235:   const headers: Record<string, string> = {
 236:     'Content-Type': 'application/json'
 237:   }
 238: 
 239:   // å¦‚æžœæœ‰ secretï¼Œæ·»åŠ ç­¾å
 240:   if (secret) {
 241:     const crypto = await import('crypto')
 242:     const signature = crypto.createHmac('sha256', secret)
 243:       .update(JSON.stringify(payload))
 244:       .digest('hex')
 245:     headers['X-Signature'] = signature
 246:   }
 247: 
 248:   const parsedUrl = await assertSafeWebhookUrl(url)
 249:   const response = await fetch(parsedUrl.toString(), {
 250:     method: 'POST',
 251:     signal: AbortSignal.timeout(LOTTERY_NOTIFICATION_FETCH_TIMEOUT_MS),
 252:     headers,
 253:     body: JSON.stringify({
 254:       ...payload,
 255:       timestamp: new Date().toISOString()
 256:     }),
 257:     redirect: 'manual'
 258:   })
 259: 
 260:   if (!response.ok) {
 261:     throw new Error(`HTTP ${response.status}`)
 262:   }
 263: }

