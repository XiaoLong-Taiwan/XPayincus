 555:     })
 556: 
 557:     if (!lottery) {
 558:       return { success: false, message: 'æŠ½å¥–æ´»åŠ¨ä¸å­˜åœ¨' }
 559:     }
 560: 
 561:     if (!lottery.isActive) {
 562:       return { success: false, message: 'æŠ½å¥–æ´»åŠ¨å·²å…³é—­' }
 563:     }
 564: 
 565:     const now = new Date()
 566:     if (lottery.startAt && lottery.startAt > now) {
 567:       return { success: false, message: 'æŠ½å¥–æ´»åŠ¨å°šæœªå¼€å§‹' }
 568:     }
 569:     if (lottery.endAt && lottery.endAt < now) {
 570:       return { success: false, message: 'æŠ½å¥–æ´»åŠ¨å·²ç»“æŸ' }
 571:     }
 572: 
 573:     if (lottery.prizes.length === 0) {
 574:       return { success: false, message: 'å¥–æ± ä¸ºç©º' }
 575:     }
 576: 
 577:     // 2. æ£€æŸ¥ç”¨æˆ·ç§¯åˆ†ï¼ˆä½¿ç”¨ upsert é¿å…å¹¶å‘æ—¶çš„å”¯ä¸€çº¦æŸå†²çªï¼‰
 578:     const userPoints = await tx.userPoints.upsert({
 579:       where: { userId },
 580:       update: {},
 581:       create: { userId }
 582:     })
 583: 
 584:     if (userPoints.points < lottery.costPoints) {
 585:       return { success: false, message: 'ç§¯åˆ†ä¸è¶³' }
 586:     }
 587: 
 588:     // 3. æ‰£é™¤ç§¯åˆ†
 589:     await tx.userPoints.update({
 590:       where: { userId },
 591:       data: {
 592:         points: { decrement: lottery.costPoints },
 593:         totalSpent: { increment: lottery.costPoints }
 594:       }
 595:     })
 596: 
 597:     // 4. éšæœºæŠ½å–å¥–å“
 598:     const selectedPrize = weightedRandomSelect(lottery.prizes.map(p => ({
 599:       id: p.id,
 600:       type: p.type,
 601:       probability: p.probability,
 602:       remainQuantity: p.remainQuantity
 603:     })))
 604: 
