 130: export async function updateDailyCheckinSettings(input: Partial<DailyCheckinSettings>): Promise<DailyCheckinSettings> {
 131:   const current = await getDailyCheckinSettings()
 132:   const next = normalizeCheckinSettings({
 133:     enabled: typeof input.enabled === 'boolean' ? input.enabled : current.enabled,
 134:     minPoints: typeof input.minPoints === 'number' ? Math.trunc(input.minPoints) : current.minPoints,
 135:     maxPoints: typeof input.maxPoints === 'number' ? Math.trunc(input.maxPoints) : current.maxPoints,
 136:     requireInstance: typeof input.requireInstance === 'boolean' ? input.requireInstance : current.requireInstance
 137:   })
 138: 
 139:   await updateSystemConfigs([
 140:     { key: 'checkin_enabled', value: String(next.enabled) },
 141:     { key: 'checkin_min_points', value: String(next.minPoints) },
 142:     { key: 'checkin_max_points', value: String(next.maxPoints) },
 143:     { key: 'checkin_require_instance', value: String(next.requireInstance) }
 144:   ])
 145: 
 146:   return next
 147: }
