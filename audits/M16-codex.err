 404: export async function getAllLotteryRecords(options: {
 405:   page?: number
 406:   pageSize?: number
 407:   lotteryId?: number
 408:   prizeType?: LotteryPrizeType
 409:   status?: LotteryRecordStatus
 410:   search?: string
 411: } = {}) {
