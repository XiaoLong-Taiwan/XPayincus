 264: async function validateInstanceConfig(config: VipBenefitRewardConfig, client: DbClient = prisma): Promise<VipBenefitRewardConfig> {
 265:   const packageId = config.packageId
 266:   const planId = config.planId
 267:   if (!packageId || !planId) {
 268:     throw new VipBenefitError('INVALID_INSTANCE_REWARD', 'Instance reward requires a package and plan')
 269:   }
 270: 
 271:   const [pkg, plan] = await Promise.all([
 272:     client.package.findFirst({
 273:       where: {
 274:         id: packageId,
 275:         active: true
 276:       },
 277:       select: {
 278:         id: true,
 279:         name: true
 280:       }
 281:     }),
 282:     client.packagePlan.findFirst({
 283:       where: {
 284:         id: planId,
 285:         packageId,
 286:         isActive: true
 287:       },
 288:       select: {
 289:         id: true,
 290:         name: true
 291:       }
 292:     })
 293:   ])
 294: 
 295:   if (!pkg) {
 296:     throw new VipBenefitError('INVALID_INSTANCE_REWARD', 'Selected package does not exist or is disabled')
 297:   }
 298:   if (!plan) {
 299:     throw new VipBenefitError('INVALID_INSTANCE_REWARD', 'Selected plan does not exist, is disabled, or does not belong to the package')
 300:   }
 301: 
 302:   return {
 303:     ...config,
 304:     packageId,
 305:     packageName: config.packageName || pkg.name,
 306:     planId,
 307:     planName: config.planName || plan.name
 308:   }
 309: }
