 460: export async function performRandomBadgeDraw(userId: number) {
 461:   const result = await runBadgeTransaction(async (tx) => {
 462:     const selected = await selectRandomBadgeOrThrow(tx)
 463:     const spendResult = await spendBadgePoints(
 464:       tx,
 465:       userId,
 466:       BADGE_RANDOM_DRAW_COST,
 467:       'badge_draw_spend',
 468:       `å¾½ç« éšæœºæŠ½å–ï¼š${selected.fullLabel}`
 469:     )
 470: 
 471:     if (!spendResult.success) {
 472:       return {
 473:         success: false as const,
 474:         points: spendResult.points
 475:       }
 476:     }
 477: 
 478:     return {
 479:       success: true as const,
 480:       points: spendResult.points,
 481:       ownership: await createBadgeOwnership(tx, userId, selected.id, 'draw', selected)
 482:     }
 483:   })
 484: 
 485:   if (!result.success) {
 486:     return result
 487:   }
 488: 
 489:   return {
 490:     success: true as const,
 491:     points: result.points,
 492:     ownership: result.ownership
 493:   }
 494: }
