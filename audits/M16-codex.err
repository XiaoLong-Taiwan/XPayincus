 361:     title: reward.title,
 362:     description: reward.description,
 363:     claimLimit: reward.claimLimit,
 364:     sortOrder: reward.sortOrder,
 365:     enabled: reward.enabled,
 366:     config: normalizeStoredRewardConfig(reward.type as VipBenefitRewardTypeValue, reward.config),
 367:     createdAt: reward.createdAt.toISOString(),
 368:     updatedAt: reward.updatedAt.toISOString(),
 369:     claimedCount: 0,
 370:     remainingClaims: reward.claimLimit,
 371:     state: 'locked',
 372:     blockedByLevel: null,
 373:     claims: []
 374:   }
 375: }
 376: 
 377: function addRewardAmount(summary: VipBenefitAmountSummary, reward: VipBenefitRewardView, multiplier: number): void {
 378:   if (multiplier <= 0) return
 379:   const amount = toNumber(reward.config.amount)
 380:   if (reward.type === 'balance') {
 381:     summary.balanceAmount = roundMoney(summary.balanceAmount + amount * multiplier)
 382:   } else if (reward.type === 'points') {
 383:     summary.pointsAmount += Math.floor(amount) * multiplier
 384:   } else if (reward.type === 'instance') {
 385:     summary.instanceQuantity += Math.max(1, Math.floor(toNumber(reward.config.quantity) || 1)) * multiplier
 386:   }
 387: }
