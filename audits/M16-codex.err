 219: export async function performCheckin(userId: number): Promise<{
 220:   codeType: RedeemCodeType
 221:   codeValue: number
 222: }> {
 223:   const { type, value } = randomizeReward()
 224:   const now = new Date()
 225: 
 226:   // èµ„æºç±»åž‹åˆ°å­—æ®µçš„æ˜ å°„
 227:   const fieldMap: Record<string, 'cpu' | 'memory' | 'disk' | 'traffic'> = {
 228:     c: 'cpu', r: 'memory', d: 'disk', t: 'traffic'
 229:   }
 230:   const field = fieldMap[type]
 231: 
 232:   await prisma.$transaction(async (tx) => {
 233:     await advisoryTransactionLock(tx, USER_RESOURCE_POOL_LOCK_NAMESPACE, userId)
 234: 
 235:     const currentStats = await tx.checkinStats.findUnique({
 236:       where: { userId },
 237:       select: { lastCheckinDate: true }
 238:     })
 239:     if (currentStats?.lastCheckinDate) {
 240:       const todayMidnight = getBeijingMidnight()
 241:       const lastCheckinMidnight = toBeijingMidnight(currentStats.lastCheckinDate)
 242:       if (lastCheckinMidnight.getTime() >= todayMidnight.getTime()) {
 243:         throw new Error('CHECKIN_ALREADY_TODAY')
 244:       }
 245:     }
 246: 
 247:     // æ›´æ–°èµ„æºæ± 
 248:     await tx.userResourcePool.upsert({
 249:       where: { userId },
 250:       update: {
 251:         [field]: field === 'traffic'
 252:           ? { increment: BigInt(value) }
 253:           : { increment: value }
 254:       },
 255:       create: {
 256:         userId,
 257:         [field]: field === 'traffic' ? BigInt(value) : value
 258:       }
 259:     })
 260: 
 261:     // è®°å½•èµ„æºæ± æ—¥å¿—
 262:     await tx.resourcePoolLog.create({
 263:       data: {
 264:         userId,
 265:         action: 'checkin',
 266:         resourceType: type,
 267:         amount: value,
 268:         remark: 'ç­¾åˆ°èŽ·å¾—'
 269:       }
 270:     })
 271: 
 272:     // æ›´æ–°ç­¾åˆ°ç»Ÿè®¡
 273:     await tx.checkinStats.upsert({
 274:       where: { userId },
 275:       update: { lastCheckinDate: now },
 276:       create: {
 277:         userId,
 278:         lastCheckinDate: now
 279:       }
 280:     })
 281:   })
 282: 
 283:   return { codeType: type, codeValue: value }
 284: }
