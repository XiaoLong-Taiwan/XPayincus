 578: export async function getVipRules(type: VipRuleType, client: DbClient = prisma): Promise<NormalizedVipRule[]> {
 579:   const rules = await client.vipLevelRule.findMany({
 580:     where: { type },
 581:     orderBy: { level: 'asc' }
 582:   })
 583:   return rules.map(normalizeVipRule)
 584: }
