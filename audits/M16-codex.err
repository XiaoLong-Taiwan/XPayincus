 543: // æŠ½å¥–
 544: async function spin() {
 545:   if (!selectedLottery.value) {
 546:     toast.warning(t('entertainment.selectLottery'))
 547:     return
 548:   }
 549:   if (points.value.points < selectedLottery.value.costPoints) {
 550:     toast.warning(t('entertainment.notEnoughPoints'))
 551:     return
 552:   }
 553:   if (isSpinning.value) return
 554: 
 555:   isSpinning.value = true
 556:   spinResult.value = null
 557:   startBulbBlink() // å¼€å§‹ç¯æ³¡é—ªçƒ
 558:   
 559:   // å¼€å§‹æ—‹è½¬åŠ¨ç”»
 560:   const prizes = selectedLottery.value.prizes || []
 561:   const prizeCount = prizes.length || 8
 562:   const baseRotation = wheelRotation.value
 563:   
 564:   try {
 565:     const res = await api.entertainment.draw(selectedLottery.value.id)
 566:     spinResult.value = {
 567:       prizeType: res.record.prizeType,
 568:       prizeName: res.record.prizeName,
 569:       prizeValue: res.record.prizeValue,
 570:       prizeId: res.record.prizeId,
 571:       badgeOwnership: res.record.badgeOwnership
 572:     }
 573:     
 574:     // æ ¹æ®åŽç«¯è¿”å›žçš„ prizeId æ‰¾åˆ°ä¸­å¥–å¥–å“åœ¨è½¬ç›˜ä¸­çš„ç´¢å¼•
 575:     // ä½¿ç”¨ == è€Œä¸æ˜¯ === æ¥æ¯”è¾ƒï¼Œé¿å…ç±»åž‹ä¸ä¸€è‡´é—®é¢˜ï¼ˆnumber vs stringï¼‰
 576:     const prizeId = res.record.prizeId
 577:     const prizeIndex = prizes.findIndex((p: any) => p.id == prizeId)
 578:     const actualIndex = prizeIndex >= 0 ? prizeIndex : 0
 579:     
 580:     console.log('[Lottery] Prize result:', {
 581:       prizeId,
 582:       prizeIdType: typeof prizeId,
 583:       prizeName: res.record.prizeName,
 584:       prizeIndex,
 585:       actualIndex,
 586:       prizeCount,
 587:       prizes: prizes.map((p: any, i: number) => ({ 
 588:         index: i, 
 589:         id: p.id, 
 590:         idType: typeof p.id,
 591:         name: p.name,
 592:         displayOrder: p.displayOrder
 593:       }))
 594:     })
 595:     
 596:     // å¦‚æžœ findIndex è¿”å›ž -1ï¼Œè¯´æ˜Žæ•°æ®ä¸ä¸€è‡´ï¼Œæ‰“å°è­¦å‘Š
 597:     if (prizeIndex === -1) {
 598:       console.error('[Lottery] WARNING: prizeId not found in prizes array!', {
 599:         searchingFor: prizeId,
 600:         availableIds: prizes.map((p: any) => p.id)
 601:       })
 602:     }
 603:     
 604:     const segmentAngle = 360 / prizeCount
 605:     // è®¡ç®—ç›®æ ‡è§’åº¦ï¼šè®©è¯¥æ‰‡åŒºä¸­å¿ƒå¯¹å‡†é¡¶éƒ¨æŒ‡é’ˆ
 606:     // æ‰‡åŒº N çš„ä¸­å¿ƒåœ¨ (N + 0.5) * segmentAngle åº¦ä½ç½®
 607:     // è¦è®©å®ƒå¯¹å‡†é¡¶éƒ¨æŒ‡é’ˆï¼ˆ0åº¦ï¼‰ï¼Œéœ€è¦é¡ºæ—¶é’ˆæ—‹è½¬åˆ° (prizeCount - N - 0.5) * segmentAngle çš„ç»å¯¹è§’åº¦
 608:     const randomOffset = (Math.random() - 0.5) * segmentAngle * 0.4 // åœ¨æ‰‡åŒºä¸­å¿ƒé™„è¿‘éšæœºåç§»ï¼Œé¿å…åœåœ¨è¾¹ç•Œ
 609:     const stopAngle = (prizeCount - actualIndex - 0.5) * segmentAngle + randomOffset
 610:     
 611:     // å…³é”®ä¿®å¤ï¼šstopAngle æ˜¯ç»å¯¹è§’åº¦ï¼ˆ0-360Â°ï¼‰ï¼Œä¸èƒ½ç®€å•ç´¯åŠ 
 612:     // éœ€è¦è®¡ç®—ä¸€ä¸ªè‡³å°‘å¤šè½¬ 3 åœˆä¸”æœ€ç»ˆåœåœ¨ stopAngle ä½ç½®çš„ç›®æ ‡è§’åº¦
 613:     const minTarget = baseRotation + 1080  // è‡³å°‘æ¯”å½“å‰å¤šè½¬ 3 åœˆ
 614:     const targetAngle = Math.ceil(minTarget / 360) * 360 + stopAngle
 615:     
 616:     console.log('[Lottery] Angle calculation:', {
 617:       segmentAngle,
 618:       stopAngle,
 619:       targetAngle,
 620:       randomOffset
 621:     })
 622:     
 623:     wheelRotation.value = targetAngle
 624:     
 625:     // ç­‰å¾…åŠ¨ç”»å®ŒæˆåŽæ˜¾ç¤ºç»“æžœ
 626:     setTimeout(() => {
 627:       if (res.record.badgeOwnership) {
 628:         openLotteryBadgeRewardModal(res.record.badgeOwnership, res.currentPoints)
 629:       } else {
 630:         showResultModal.value = true
 631:       }
 632:       loadPoints() // åˆ·æ–°ç§¯åˆ†
 633:       loadLotteries() // åˆ·æ–°å¥–å“åº“å­˜
 634:     }, 2000)
 635:   } catch (err: any) {
 636:     toast.error(t('entertainment.spinFailed') + ': ' + err.message)
 637:     stopBulbBlink()
 638:   } finally {
 639:     setTimeout(() => {
 640:       isSpinning.value = false
 641:       stopBulbBlink() // åœæ­¢ç¯æ³¡é—ªçƒ
 642:     }, 2000)
 643:   }
 644: }
