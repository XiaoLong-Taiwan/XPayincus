 668: export async function getUserVipStats(userId: number, client: DbClient = prisma): Promise<UserVipStats> {
 669:   const [consumeMap, rechargeResult] = await Promise.all([
 670:     getUsersTotalConsumeMap([userId], client),
 671:     client.$queryRaw<Array<{ value: unknown }>>(Prisma.sql`
 672:       SELECT COALESCE(SUM(COALESCE(actual_amount, amount)), 0)::numeric AS value
 673:       FROM recharge_records
 674:       WHERE user_id = ${userId}
 675:         AND status = 'completed'
 676:     `)
 677:   ])
 678: 
 679:   return {
 680:     totalConsume: consumeMap.get(userId) || 0,
 681:     totalRecharge: toNumber(rechargeResult[0]?.value)
 682:   }
 683: }
