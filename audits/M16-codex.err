 311: async function normalizeRewardData(
 312:   input: VipBenefitRewardInput,
 313:   base?: VipBenefitReward
 314: ): Promise<{
 315:   level: number
 316:   type: VipBenefitRewardTypeValue
 317:   title: string
 318:   description: string | null
 319:   claimLimit: number
 320:   sortOrder: number
 321:   enabled: boolean
 322:   config: VipBenefitRewardConfig
 323: }> {
 324:   const type = normalizeRewardType(input.type ?? base?.type)
 325:   const rawConfig = input.config !== undefined ? input.config : base?.config
 326:   let config = normalizeRewardConfig(type, rawConfig)
 327:   if (type === 'instance') {
 328:     config = await validateInstanceConfig(config)
 329:   }
 330: 
 331:   return {
 332:     level: normalizeLevel(input.level ?? base?.level),
 333:     type,
 334:     title: normalizeTitle(input.title ?? base?.title),
 335:     description: normalizeDescription(input.description ?? base?.description),
 336:     claimLimit: normalizeOptionalPositiveInteger(input.claimLimit ?? base?.claimLimit, 1, 'Claim limit', MAX_CLAIM_LIMIT),
 337:     sortOrder: normalizeSortOrder(input.sortOrder ?? base?.sortOrder ?? 0),
 338:     enabled: input.enabled === undefined ? (base?.enabled ?? true) : input.enabled === true,
 339:     config
 340:   }
 341: }
