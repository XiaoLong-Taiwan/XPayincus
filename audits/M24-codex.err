  108: async function getIntegrationHealthHistory() {
  109:   const since = new Date(Date.now() - healthHistoryWindowDays * 24 * 60 * 60 * 1000)
  110:   const [windowRecords, recentFailures] = await Promise.all([
  111:     prisma.integrationHealthCheck.findMany({
  112:       where: { checkedAt: { gte: since } },
  113:       orderBy: { checkedAt: 'desc' },
  114:       take: 500
  115:     }),
  116:     prisma.integrationHealthCheck.findMany({
  117:       where: {
  118:         status: { in: ['warning', 'error'] }
  119:       },
  120:       orderBy: { checkedAt: 'desc' },
  121:       take: 10
  122:     })
  123:   ])
  124: 
  125:   const grouped = new Map<string, typeof windowRecords>()
  126:   for (const record of windowRecords) {
  127:     grouped.set(record.key, [...(grouped.get(record.key) || []), record])
  128:   }
  129: 
  130:   const summaries: IntegrationHealthSummary[] = Array.from(grouped.entries()).map(([key, records]) => {
  131:     const last = records[0]
  132:     const ok = records.filter(record => record.status === 'ok').length
  133:     const warning = records.filter(record => record.status === 'warning').length
  134:     const error = records.filter(record => record.status === 'error').length
  135:     const skipped = records.filter(record => record.status === 'skipped').length
  136:     const actionableTotal = Math.max(0, records.length - skipped)
  137:     const successRate = actionableTotal > 0 ? Math.round((ok / actionableTotal) * 1000) / 10 : 0
  138: 
  139:     return {
  140:       key,
  141:       title: last.title,
  142:       total: records.length,
  143:       ok,
  144:       warning,
  145:       error,
  146:       skipped,
  147:       successRate,
  148:       lastStatus: normalizeHealthStatus(last.status),
  149:       lastMessage: last.message,
  150:       lastCheckedAt: last.checkedAt.toISOString()
  151:     }
  152:   })
  153: 
  154:   summaries.sort((left, right) => right.lastCheckedAt.localeCompare(left.lastCheckedAt))
  155: 
  156:   return {
  157:     windowDays: healthHistoryWindowDays,
  158:     summaries,
  159:     recentFailures: recentFailures.map(serializeHealthRecord)
  160:   }
  161: }
