   99: async function assertPublicHostname(hostname: string): Promise<void> {
  100:   const normalizedHost = hostname.trim().toLowerCase().replace(/\.$/, '')
  101:   if (!normalizedHost) {
  102:     throw new OutboundTargetValidationError('Hostname cannot be empty')
  103:   }
  104: 
  105:   if (
  106:     normalizedHost === 'localhost' ||
  107:     normalizedHost.endsWith('.localhost') ||
  108:     normalizedHost.endsWith('.local') ||
  109:     normalizedHost.endsWith('.internal')
  110:   ) {
  111:     throw new OutboundTargetValidationError('Private or local targets are not allowed')
  112:   }
  113: 
  114:   const family = isIP(normalizedHost)
  115:   if (family !== 0) {
  116:     if (isIpPrivateOrReserved(normalizedHost)) {
  117:       throw new OutboundTargetValidationError('Private or reserved IP targets are not allowed')
  118:     }
  119:     return
  120:   }
  121: 
  122:   if (!normalizedHost.includes('.')) {
  123:     throw new OutboundTargetValidationError('Private or local hostnames are not allowed')
  124:   }
  125: 
  126:   let records: Array<{ address: string }>
  127:   try {
  128:     records = await dnsLookup(normalizedHost, { all: true, verbatim: true })
  129:   } catch (error: any) {
  130:     const code = error?.code ? String(error.code) : 'UNKNOWN'
  131:     throw new OutboundTargetValidationError(`Unable to resolve hostname (${code})`)
  132:   }
  133: 
  134:   if (records.length === 0) {
  135:     throw new OutboundTargetValidationError('Unable to resolve hostname')
  136:   }
  137: 
  138:   for (const record of records) {
  139:     if (isIpPrivateOrReserved(record.address)) {
  140:       throw new OutboundTargetValidationError('Targets resolving to private or reserved IPs are not allowed')
  141:     }
  142:   }
  143: }
  144: 
  145: export async function assertSafeWebhookUrl(url: string): Promise<URL> {
  146:   return assertSafeHttpUrl(url, 'Webhook URL')
  147: }
  148: 
  149: export async function assertSafeHttpUrl(url: string, label = 'URL'): Promise<URL> {
  150:   const parsed = buildUrl(url, 'https')
  151:   if (parsed.protocol !== 'http:' && parsed.protocol !== 'https:') {
  152:     throw new OutboundTargetValidationError(`${label} must use http or https`)
  153:   }
  154: 
  155:   await assertPublicHostname(parsed.hostname)
  156:   return parsed
  157: }
  158: 
  159: /**
  160:  * 连接期再校验的 DNS lookup：即使域名在“校验通过”与“真正发起连接”之间发生 DNS rebinding
  161:  * （解析到内网/保留地址），也会在建立连接时被拒绝，从而消除 assertPublicHostname 之后的 TOCTOU 窗口。
  162:  * 仅影响地址解析，不改变 TLS SNI（仍使用原始主机名），因此不破坏 HTTPS 证书校验。
  163:  */
  164: const revalidatingLookup: LookupFunction = (hostname, options, callback) => {
  165:   dnsLookupCb(hostname, { ...(options as object), all: true, verbatim: true }, (err, addresses) => {
  166:     const cb = callback as (err: NodeJS.ErrnoException | null, address?: string, family?: number) => void
  167:     if (err) {
  168:       cb(err)
  169:       return
  170:     }
  171:     const list = Array.isArray(addresses) ? addresses : []
  172:     if (list.length === 0) {
  173:       cb(new OutboundTargetValidationError('Unable to resolve hostname') as NodeJS.ErrnoException)
  174:       return
  175:     }
  176:     for (const record of list) {
  177:       if (isIpPrivateOrReserved(record.address)) {
  178:         cb(new OutboundTargetValidationError('Target resolved to a private or reserved IP') as NodeJS.ErrnoException)
  179:         return
  180:       }
  181:     }
  182:     const first = list[0]
  183:     cb(null, first.address, first.family)
  184:   })
  185: }
  186: 
  187: /**
  188:  * 用于所有“已通过 assertSafe*Url 校验的外发请求”的 undici dispatcher。
  189:  * 在 fetch(..., { dispatcher: safeOutboundDispatcher }) 中传入即可获得连接期防 rebinding 保护。
  190:  */
  191: export const safeOutboundDispatcher = new Agent({ connect: { lookup: revalidatingLookup } })
  192: 
  193: export async function assertSafeStorageTarget(
  194:   type: 'WEBDAV' | 'FTP' | 'SFTP' | 'S3',
  195:   host: string
  196: ): Promise<void> {
  197:   const defaultProtocol: Record<'WEBDAV' | 'FTP' | 'SFTP' | 'S3', SupportedProtocol> = {
  198:     WEBDAV: 'https',
  199:     FTP: 'ftp',
  200:     SFTP: 'sftp',
  201:     S3: 'https'
  202:   }
  203: 
  204:   const parsed = buildUrl(host, defaultProtocol[type])
  205:   await assertPublicHostname(parsed.hostname)
  206: }

