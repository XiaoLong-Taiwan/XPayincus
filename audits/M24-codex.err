   51: const telegramApiTimeoutMs = 15_000
   52: const integrationProbeTimeoutMs = 15_000
   53: const healthHistoryWindowDays = 7
   54: const supportedRechargeProviderTypes = new Set(['yipay', 'heleket', 'antom', 'manual', 'plugin_gateway'])
   55: const hostAgentOfflineThresholdMs = 2 * 60 * 1000
   56: 
   57: function nowIso(): string {
   58:   return new Date().toISOString()
   59: }
   60: 
   61: function durationSince(startedAt: number): number {
   62:   return Math.max(0, Date.now() - startedAt)
   63: }
   64: 
   65: function normalizeHealthStatus(value: string): IntegrationHealthStatus {
   66:   return value === 'ok' || value === 'warning' || value === 'error' || value === 'skipped'
   67:     ? value
   68:     : 'error'
   69: }
   70: 
   71: function serializeHealthRecord(record: {
   72:   id: number
   73:   key: string
   74:   title: string
   75:   status: string
   76:   message: string
   77:   detail: string | null
   78:   durationMs: number
