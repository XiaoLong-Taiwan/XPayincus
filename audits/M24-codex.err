  510:   })
  511: 
  512:   fastify.post('/health', {
  513:     onRequest: [fastify.authenticateAdmin]
  514:   }, async (request) => {
  515:     const items = await Promise.all([
  516:       probe('smtp', 'SMTP 邮件', checkSmtp),
  517:       probe('lsky', 'Lsky 工单附件', checkLsky),
  518:       probe('telegram', 'Telegram Bot', checkTelegram),
  519:       probe('payment-providers', '充值支付渠道', checkPaymentProviders),
  520:       probe('notification-channels', '全局通知渠道', checkNotificationChannels),
  521:       probe('remote-storage', '远程存储', checkRemoteStorage),
  522:       probe('host-agent', 'Agent / Incus 节点', checkHostAgent),
  523:       probe('ota-release', 'OTA 更新源', checkOtaRelease),
  524:       probe('plugin-market', '扩展市场源', checkPluginMarket),
  525:       probe('theme-market', '主题市场源', checkThemeMarket)
  526:     ])
  527: 
  528:     await createLog(
  529:       request.user.id,
  530:       'system',
  531:       'integrations.health_check',
  532:       `Checked integration health: ${items.map(item => `${item.key}=${item.status}`).join(', ')}`,
  533:       items.some(item => item.status === 'error') ? 'warning' : 'success'
  534:     )
  535: 
  536:     await recordIntegrationHealthItems(items, request.user.id)
  537:     const history = await getIntegrationHealthHistory()
  538: 
  539:     return {
  540:       checkedAt: nowIso(),
  541:       items,
  542:       history
  543:     }
  544:   })
  545: }

