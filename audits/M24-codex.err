  353: async function collectDetections(): Promise<AlertDetection[]> {
  354:   const now = new Date()
  355:   const since = new Date(now.getTime() - RECENT_LOOKBACK_HOURS * 60 * 60 * 1000)
  356:   const staleBefore = new Date(now.getTime() - AGENT_STALE_MINUTES * 60 * 1000)
  357: 
  358:   const [
  359:     offlineHosts,
  360:     offlineAgents,
  361:     staleAgents,
  362:     failedTasks,
  363:     failedRecharges,
  364:     failedNotifications,
  365:     failedEmailTasks,
  366:     failedUpdates
  367:   ] = await Promise.all([
  368:     prisma.host.findMany({
  369:       where: { status: { not: 'online' } },
  370:       select: { id: true, name: true, status: true, location: true, countryCode: true }
  371:     }),
  372:     prisma.hostAgent.findMany({
  373:       where: { enabled: true, status: { not: 'online' } },
  374:       select: { id: true, hostId: true, status: true, version: true, lastSeenAt: true, host: { select: { name: true } } }
  375:     }),
  376:     prisma.hostAgent.findMany({
  377:       where: {
  378:         enabled: true,
  379:         OR: [{ lastSeenAt: null }, { lastSeenAt: { lt: staleBefore } }]
  380:       },
  381:       select: { id: true, hostId: true, status: true, version: true, lastSeenAt: true, host: { select: { name: true } } }
  382:     }),
  383:     prisma.instanceTask.findMany({
  384:       where: {
  385:         status: 'FAILED',
  386:         OR: [{ finishedAt: { gte: since } }, { createdAt: { gte: since } }]
  387:       },
  388:       orderBy: [{ finishedAt: 'desc' }, { createdAt: 'desc' }],
  389:       take: 50,
  390:       select: {
  391:         id: true,
  392:         taskType: true,
  393:         error: true,
  394:         instanceId: true,
  395:         hostId: true,
  396:         userId: true,
  397:         finishedAt: true,
  398:         createdAt: true,
  399:         instance: { select: { name: true } }
  400:       }
  401:     }),
  402:     prisma.rechargeRecord.findMany({
  403:       where: { status: 'failed', updatedAt: { gte: since } },
  404:       orderBy: { updatedAt: 'desc' },
  405:       take: 50,
  406:       select: { id: true, orderNo: true, failReason: true, amount: true, updatedAt: true }
  407:     }),
  408:     prisma.notificationLog.findMany({
  409:       where: { status: 'failed', createdAt: { gte: since } },
  410:       orderBy: { createdAt: 'desc' },
  411:       take: 50,
  412:       select: {
  413:         id: true,
  414:         channelId: true,
  415:         eventType: true,
  416:         error: true,
  417:         createdAt: true,
  418:         channel: { select: { type: true, name: true } }
  419:       }
  420:     }),
  421:     prisma.hostNotificationEmailTask.findMany({
  422:       where: { status: 'FAILED', createdAt: { gte: since } },
  423:       orderBy: { createdAt: 'desc' },
  424:       take: 50,
  425:       select: { id: true, hostId: true, hostName: true, lastError: true, createdAt: true }
  426:     }),
  427:     prisma.systemUpdateTask.findMany({
  428:       where: { status: 'failed', updatedAt: { gte: since } },
  429:       orderBy: { updatedAt: 'desc' },
  430:       take: 20,
  431:       select: { id: true, targetVersion: true, fromVersion: true, errorMessage: true, updatedAt: true }
  432:     })
  433:   ])
  434: 
  435:   const detections: AlertDetection[] = []
  436: 
  437:   for (const host of offlineHosts) {
  438:     detections.push({
  439:       ruleCode: 'host.offline',
  440:       module: 'host',
  441:       severity: 'critical',
  442:       objectType: 'host',
  443:       objectId: host.id,
  444:       objectLabel: host.name,
  445:       fingerprint: `host:${host.id}`,
  446:       title: `节点离线：${host.name}`,
  447:       message: `节点状态为 ${host.status}，请检查 Incus API、网络和 Agent。`,
  448:       detail: { hostId: host.id, status: host.status, location: host.location, countryCode: host.countryCode }
  449:     })
  450:   }
  451: 
  452:   for (const agent of offlineAgents) {
  453:     detections.push({
  454:       ruleCode: 'agent.offline',
  455:       module: 'agent',
  456:       severity: 'warning',
  457:       objectType: 'agent',
  458:       objectId: agent.id,
  459:       objectLabel: agent.host?.name || `Host #${agent.hostId}`,
  460:       fingerprint: `agent:${agent.id}:offline`,
  461:       title: `Agent 离线：${agent.host?.name || agent.hostId}`,
  462:       message: `Agent 状态为 ${agent.status}，请检查安装、服务和网络。`,
  463:       detail: { hostId: agent.hostId, status: agent.status, version: agent.version, lastSeenAt: agent.lastSeenAt?.toISOString() ?? null }
  464:     })
  465:   }
  466: 
  467:   for (const agent of staleAgents) {
  468:     detections.push({
  469:       ruleCode: 'agent.heartbeat_stale',
  470:       module: 'agent',
  471:       severity: 'warning',
  472:       objectType: 'agent',
  473:       objectId: agent.id,
  474:       objectLabel: agent.host?.name || `Host #${agent.hostId}`,
  475:       fingerprint: `agent:${agent.id}:heartbeat`,
