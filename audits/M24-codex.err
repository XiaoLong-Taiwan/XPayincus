    5: import { FastifyInstance } from 'fastify'
    6: import { Prisma } from '@prisma/client'
    7: import { prisma } from '../db/prisma.js'
    8: import { BUSINESS_TIMEZONE, getDateStringInTimezone, getMonthStringInTimezone } from '../lib/timezone.js'
    9: 
   10: const BUSINESS_TZ_OFFSET_MINUTES = 8 * 60
   11: const DAY_MS = 24 * 60 * 60 * 1000
   12: const DAILY_DAYS = 30
   13: const MONTHLY_MONTHS = 12
   14: const AGENT_STALE_MINUTES = 30
   15: const TASK_LOOKBACK_DAYS = 1
   16: const RISK_LOOKBACK_DAYS = 7
   17: 
   18: interface BucketRow {
   19:   bucket: string
   20:   value: unknown
   21: }
   22: 
   23: interface ScalarRow {
   24:   value: unknown
   25: }
   26: 
   27: interface SeriesPoint {
   28:   label: string
   29:   value: number
   30: }
   31: 
   32: type OperationRiskSeverity = 'info' | 'warning' | 'critical'
   33: 
   34: interface OperationRisk {
   35:   key: string
   36:   severity: OperationRiskSeverity
   37:   count: number
   38: }
   39: 
   40: function toNumber(value: unknown): number {
   41:   if (value === null || value === undefined) return 0
   42:   if (typeof value === 'number') return value
   43:   if (typeof value === 'bigint') return Number(value)
   44:   return Number.parseFloat(String(value)) || 0
   45: }
   46: 
   47: function roundMoney(value: number): number {
   48:   return Number(value.toFixed(2))
   49: }
   50: 
   51: function parseYearMonth(label: string): { year: number; month: number } {
   52:   const [year, month] = label.split('-').map(Number)
   53:   return { year, month }
   54: }
   55: 
   56: function getBusinessDayStartUtc(date: Date = new Date()): Date {
   57:   const label = getDateStringInTimezone(date, BUSINESS_TIMEZONE)
   58:   const [year, month, day] = label.split('-').map(Number)
   59:   const start = new Date(Date.UTC(year, month - 1, day, 0, 0, 0, 0))
   60:   start.setMinutes(start.getMinutes() - BUSINESS_TZ_OFFSET_MINUTES)
   61:   return start
   62: }
   63: 
   64: function getBusinessMonthStartUtc(year: number, month: number): Date {
   65:   const start = new Date(Date.UTC(year, month - 1, 1, 0, 0, 0, 0))
   66:   start.setMinutes(start.getMinutes() - BUSINESS_TZ_OFFSET_MINUTES)
   67:   return start
   68: }
   69: 
   70: function formatBusinessDateFromStart(startUtc: Date): string {
   71:   return new Date(startUtc.getTime() + BUSINESS_TZ_OFFSET_MINUTES * 60 * 1000)
   72:     .toISOString()
   73:     .slice(0, 10)
   74: }
   75: 
   76: function formatBusinessMonthFromStart(startUtc: Date): string {
   77:   return new Date(startUtc.getTime() + BUSINESS_TZ_OFFSET_MINUTES * 60 * 1000)
   78:     .toISOString()
   79:     .slice(0, 7)
   80: }
   81: 
   82: function getDailyWindow(days: number): { start: Date; end: Date; labels: string[] } {
   83:   const todayStart = getBusinessDayStartUtc()
   84:   const start = new Date(todayStart.getTime() - (days - 1) * DAY_MS)
   85:   const end = new Date(todayStart.getTime() + DAY_MS)
   86:   const labels = Array.from({ length: days }, (_, index) =>
   87:     formatBusinessDateFromStart(new Date(start.getTime() + index * DAY_MS))
   88:   )
   89: 
   90:   return { start, end, labels }
   91: }
   92: 
   93: function getBusinessDayRange(offsetDays = 0): { start: Date; end: Date } {
   94:   const todayStart = getBusinessDayStartUtc()
   95:   const start = new Date(todayStart.getTime() + offsetDays * DAY_MS)
   96:   const end = new Date(start.getTime() + DAY_MS)
   97:   return { start, end }
   98: }
   99: 
  100: function getBusinessRollingRange(days: number): { start: Date; end: Date } {
  101:   const todayStart = getBusinessDayStartUtc()
  102:   return {
  103:     start: new Date(todayStart.getTime() - (days - 1) * DAY_MS),
  104:     end: new Date(todayStart.getTime() + DAY_MS)
  105:   }
  106: }
  107: 
  108: function getMonthlyWindow(months: number): { start: Date; end: Date; labels: string[] } {
  109:   const currentMonth = getMonthStringInTimezone(new Date(), BUSINESS_TIMEZONE)
  110:   const { year, month } = parseYearMonth(currentMonth)
  111:   const start = getBusinessMonthStartUtc(year, month - months + 1)
  112:   const end = getBusinessMonthStartUtc(year, month + 1)
  113:   const labels = Array.from({ length: months }, (_, index) =>
  114:     formatBusinessMonthFromStart(getBusinessMonthStartUtc(year, month - months + 1 + index))
  115:   )
  116: 
  117:   return { start, end, labels }
  118: }
  119: 
  120: function fillSeries(rows: BucketRow[], labels: string[], money = false): SeriesPoint[] {
  121:   const rowMap = new Map(rows.map(row => [row.bucket, toNumber(row.value)]))
  122:   return labels.map(label => {
  123:     const value = rowMap.get(label) || 0
  124:     return {
  125:       label,
  126:       value: money ? roundMoney(value) : value
  127:     }
  128:   })
  129: }
  130: 
  131: function scalarValue(rows: ScalarRow[], money = false): number {
  132:   const value = toNumber(rows[0]?.value)
  133:   return money ? roundMoney(value) : value
  134: }
  135: 
  136: function addRisk(risks: OperationRisk[], condition: boolean, key: string, severity: OperationRiskSeverity, count = 0): void {
  137:   if (condition) {
  138:     risks.push({ key, severity, count })
  139:   }
  140: }
