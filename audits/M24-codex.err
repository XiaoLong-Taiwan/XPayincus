  522:       probe('host-agent', 'Agent / Incus 节点', checkHostAgent),
  523:       probe('ota-release', 'OTA 更新源', checkOtaRelease),
  524:       probe('plugin-market', '扩展市场源', checkPluginMarket),
  525:       probe('theme-market', '主题市场源', checkThemeMarket)
  526:     ])
  527: 
  528:     await createLog(
  529:       request.user.id,
  530:       'system',
