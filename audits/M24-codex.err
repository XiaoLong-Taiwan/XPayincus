  775:     })
  776:     await addAlertAction(event.id, 'silence', actor, note, { minutes, silencedUntil: silencedUntil.toISOString() })
  777:     await createLog(actor.id, 'sla_alert', 'sla_alert.silence', `静默 SLA 告警 #${event.id} ${minutes} 分钟：${event.title}`, 'success')
  778:     return { alert: serializeAlert(event) }
  779:   })
  780: 
  781:   fastify.patch<{ Params: { code: string }; Body: RuleUpdateBody }>('/rules/:code', {
  782:     onRequest: [fastify.authenticateAdmin]
  783:   }, async (request, reply) => {
  784:     const code = request.params.code?.trim()
  785:     if (!code || code.length > 80) return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
  786:     const data: Prisma.SlaAlertRuleUpdateInput = {}
  787:     if (typeof request.body?.enabled === 'boolean') data.enabled = request.body.enabled
  788:     if (request.body?.severity !== undefined) {
  789:       const severity = normalizeSeverity(request.body.severity)
  790:       if (!severity) return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
  791:       data.severity = severity
  792:     }
  793:     if (request.body?.thresholdMinutes !== undefined) {
  794:       const value = request.body.thresholdMinutes === null ? null : Number(request.body.thresholdMinutes)
  795:       if (value !== null && (!Number.isSafeInteger(value) || value < 0 || value > 30 * 24 * 60)) {
  796:         return reply.code(400).send({ error: '阈值分钟必须是 0 到 43200 之间的整数或为空' })
  797:       }
  798:       data.thresholdMinutes = value
  799:     }
  800:     if (request.body?.thresholdCount !== undefined) {
  801:       const value = request.body.thresholdCount === null ? null : Number(request.body.thresholdCount)
  802:       if (value !== null && (!Number.isSafeInteger(value) || value < 0 || value > 1_000_000)) {
  803:         return reply.code(400).send({ error: '阈值次数必须是 0 到 1000000 之间的整数或为空' })
  804:       }
  805:       data.thresholdCount = value
  806:     }
  807:     if (request.body?.dedupeMinutes !== undefined) {
  808:       const dedupe = Number(request.body.dedupeMinutes)
  809:       if (!Number.isSafeInteger(dedupe) || dedupe < 5 || dedupe > 24 * 60) {
  810:         return reply.code(400).send({ error: '合并窗口必须在 5 分钟到 24 小时之间' })
  811:       }
  812:       data.dedupeMinutes = dedupe
  813:     }
  814:     if (request.body?.silenceMinutes !== undefined) {
  815:       const minutes = request.body.silenceMinutes === null ? null : Number(request.body.silenceMinutes)
  816:       if (minutes === null) {
  817:         data.silenceUntil = null
  818:       } else {
  819:         if (!Number.isSafeInteger(minutes) || minutes < 5 || minutes > 7 * 24 * 60) {
  820:           return reply.code(400).send({ error: '规则静默时间必须在 5 分钟到 7 天之间' })
  821:         }
  822:         data.silenceUntil = new Date(Date.now() + minutes * 60 * 1000)
  823:       }
  824:     }
  825: 
  826:     const rule = await prisma.slaAlertRule.update({ where: { code }, data })
  827:     const actor = request.user!
  828:     await createLog(actor.id, 'sla_alert', 'sla_alert.rule_update', `更新 SLA 告警规则 ${rule.code}`, 'success')
  829:     return { rule: serializeRule(rule) }
  830:   })
  831: }

