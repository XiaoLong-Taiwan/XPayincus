   20: 
   21: assert.ok(
   22:   routeSource.includes("items: { type: 'integer', minimum: 1 }") &&
   23:     routeSource.includes('uniqueItems: true'),
   24:   'batch config schema must reject non-positive and duplicate instance IDs before handler logic'
   25: )
   26: 
