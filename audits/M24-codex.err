  213: async function probe(
  214:   key: string,
  215:   title: string,
  216:   run: () => Promise<Omit<IntegrationHealthItem, 'key' | 'title' | 'checkedAt' | 'durationMs'>>
  217: ): Promise<IntegrationHealthItem> {
  218:   const startedAt = Date.now()
  219:   try {
  220:     const result = await run()
  221:     return {
  222:       key,
  223:       title,
  224:       ...result,
  225:       checkedAt: nowIso(),
  226:       durationMs: durationSince(startedAt)
  227:     }
  228:   } catch (error: any) {
  229:     return {
  230:       key,
  231:       title,
  232:       status: 'error',
  233:       message: error?.message || String(error),
  234:       checkedAt: nowIso(),
  235:       durationMs: durationSince(startedAt)
  236:     }
  237:   }
  238: }
