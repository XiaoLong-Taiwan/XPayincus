  298: async function upsertDetection(detection: AlertDetection, ruleMap: Map<string, any>) {
  299:   const rule = ruleMap.get(detection.ruleCode)
  300:   if (!rule || !rule.enabled) return { created: false, merged: false, skipped: true }
  301:   const now = new Date()
  302:   if (rule.silenceUntil && rule.silenceUntil > now) return { created: false, merged: false, skipped: true }
  303: 
  304:   const existing = await prisma.slaAlertEvent.findUnique({
  305:     where: {
  306:       ruleCode_fingerprint: {
  307:         ruleCode: detection.ruleCode,
  308:         fingerprint: detection.fingerprint
  309:       }
  310:     }
  311:   })
  312: 
  313:   const data = {
  314:     module: detection.module,
  315:     severity: detection.severity,
  316:     objectType: detection.objectType,
  317:     objectId: detection.objectId ?? null,
  318:     objectLabel: detection.objectLabel ?? null,
  319:     title: sanitizeTokensInString(detection.title),
  320:     message: sanitizeTokensInString(detection.message),
  321:     detail: detection.detail ?? Prisma.JsonNull,
  322:     lastTriggeredAt: now
  323:   }
  324: 
  325:   if (!existing) {
  326:     const created = await prisma.slaAlertEvent.create({
  327:       data: {
  328:         ruleCode: detection.ruleCode,
  329:         fingerprint: detection.fingerprint,
  330:         status: 'open',
  331:         ...data
  332:       }
  333:     })
  334:     await addAlertAction(created.id, 'detected', null, null, { ruleCode: detection.ruleCode })
  335:     return { created: true, merged: false, skipped: false }
  336:   }
  337: 
  338:   if (existing.status === 'ignored') return { created: false, merged: false, skipped: true }
  339: 
  340:   const updated = await prisma.slaAlertEvent.update({
  341:     where: { id: existing.id },
  342:     data: {
  343:       ...data,
  344:       status: existing.status === 'recovered' ? 'open' : existing.status,
  345:       recoveredAt: existing.status === 'recovered' ? null : existing.recoveredAt,
  346:       triggerCount: { increment: 1 }
  347:     }
  348:   })
  349:   await addAlertAction(updated.id, 'merged', null, null, { ruleCode: detection.ruleCode, triggerCount: updated.triggerCount })
  350:   return { created: false, merged: true, skipped: false }
  351: }
