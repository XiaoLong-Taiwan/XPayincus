  643: /**
  644:  * 判断是否有需要同步到 Incus 的高级配置
  645:  */
  646: function hasAdvancedIncusConfig(config: BatchConfigBody['config']): boolean {
  647:   const advancedFields = [
  648:     'nested', 'privileged',
  649:     'limitsRead', 'limitsWrite', 'limitsReadIops', 'limitsWriteIops',
  650:     'limitsIngress', 'limitsEgress', 'limitsProcesses', 'limitsCpuPriority',
  651:     'bootAutostart', 'bootAutostartPriority', 'bootAutostartDelay', 'bootHostShutdownTimeout'
  652:   ]
  653:   return advancedFields.some(field => config[field as keyof typeof config] !== undefined)
  654: }
  655: 
  656: /**
  657:  * 判断是否有需要存储到数据库的高级配置
  658:  */
  659: function hasDbAdvancedConfig(config: BatchConfigBody['config']): boolean {
  660:   const dbFields = [
  661:     'limitsRead', 'limitsWrite', 'limitsReadIops', 'limitsWriteIops',
  662:     'limitsIngress', 'limitsEgress', 'limitsProcesses', 'limitsCpuPriority',
  663:     'bootAutostart', 'bootAutostartPriority', 'bootAutostartDelay', 'bootHostShutdownTimeout'
  664:   ]
  665:   return dbFields.some(field => config[field as keyof typeof config] !== undefined)
  666: }
  667: 
  668: function resolveStorageOverrides(config: BatchConfigBody['config']): ResolvedStorageOverrides {
  669:   const overrides: ResolvedStorageOverrides = {}
  670: 
  671:   if (config.limitsRead !== undefined) {
  672:     overrides.limitsRead = config.limitsRead
  673:     overrides.limitsReadIops = null
  674:   } else if (config.limitsReadIops !== undefined) {
  675:     overrides.limitsRead = null
  676:     overrides.limitsReadIops = config.limitsReadIops
  677:   }
  678: 
  679:   if (config.limitsWrite !== undefined) {
  680:     overrides.limitsWrite = config.limitsWrite
  681:     overrides.limitsWriteIops = null
  682:   } else if (config.limitsWriteIops !== undefined) {
  683:     overrides.limitsWrite = null
  684:     overrides.limitsWriteIops = config.limitsWriteIops
  685:   }
  686: 
  687:   return overrides
  688: }

