    7: const BYTES_PER_TB = 1024 ** 4
    8: const MAX_COST = 100000000
    9: const LOW_CAPACITY_WARNING_RATIO = 0.75
   10: const LOW_CAPACITY_CRITICAL_RATIO = 0.9
   11: const MIN_PLAN_SLOTS = 0
   12: 
   13: type AlertSeverity = 'warning' | 'critical'
   14: 
   15: interface HostCapacitySnapshot {
   16:   cpuTotal: number
   17:   cpuUsed: number
   18:   cpuAvailable: number
   19:   cpuUsageRatio: number
   20:   memoryTotal: number
   21:   memoryUsed: number
   22:   memoryAvailable: number
   23:   memoryUsageRatio: number
   24:   diskTotal: number
   25:   diskUsed: number
   26:   diskAvailable: number
   27:   diskUsageRatio: number
   28:   natPortTotal: number
   29:   natPortUsed: number
   30:   natPortAvailable: number
   31:   natPortUsageRatio: number
   32:   instanceCount: number
   33:   trafficUsedBytes: string
   34: }
   35: 
   36: interface CapacityAlert {
   37:   key: string
   38:   severity: AlertSeverity
   39:   objectType: 'host' | 'package_plan'
   40:   objectId: number
   41:   title: string
   42:   message: string
   43: }
   44: 
   45: const CAPACITY_SLA_RULE_CODE = 'capacity.host_pressure'
   46: 
   47: function toNumber(value: unknown): number {
   48:   if (value === null || value === undefined) return 0
   49:   if (typeof value === 'number') return Number.isFinite(value) ? value : 0
   50:   if (typeof value === 'bigint') return Number(value)
   51:   if (value instanceof Prisma.Decimal) return value.toNumber()
   52:   return Number.parseFloat(String(value)) || 0
   53: }
   54: 
   55: function toMoney(value: unknown): number {
   56:   return Math.round(toNumber(value) * 100) / 100
   57: }
   58: 
   59: function usageRatio(used: number, total: number): number {
   60:   if (total <= 0) return used > 0 ? 1 : 0
   61:   return Math.min(Math.max(used / total, 0), 1)
   62: }
   63: 
   64: function positiveAvailable(total: number, used: number): number {
   65:   return Math.max(total - used, 0)
   66: }
   67: 
   68: function getNatPortTotal(host: { natPortStart: number | null; natPortEnd: number | null }): number {
   69:   if (!host.natPortStart || !host.natPortEnd || host.natPortEnd < host.natPortStart) return 0
   70:   return host.natPortEnd - host.natPortStart + 1
   71: }
   72: 
   73: function getDiskTotalMb(host: { storageSize: number }): number {
   74:   return Math.max((host.storageSize || 0) * 1024, 0)
   75: }
   76: 
   77: function getTodayDateOnly(): Date {
   78:   const now = new Date()
   79:   return new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate()))
   80: }
   81: 
   82: function normalizeCostInput(value: unknown, field: string): number {
   83:   const parsed = typeof value === 'string' ? Number(value.trim()) : Number(value)
   84:   if (!Number.isFinite(parsed) || parsed < 0 || parsed > MAX_COST) {
   85:     throw apiError(ErrorCode.INVALID_PARAMS, `${field} 必须是 0-${MAX_COST} 之间的数字`)
   86:   }
   87:   return Math.round(parsed * 100) / 100
   88: }
   89: 
   90: function normalizeNotes(value: unknown): string | null | undefined {
   91:   if (value === undefined) return undefined
   92:   if (value === null) return null
   93:   if (typeof value !== 'string') {
   94:     throw apiError(ErrorCode.INVALID_PARAMS, '成本备注无效')
   95:   }
   96:   const trimmed = value.trim()
   97:   if (trimmed.length > 500) {
   98:     throw apiError(ErrorCode.INVALID_PARAMS, '成本备注不能超过 500 个字符')
   99:   }
  100:   return trimmed || null
  101: }
