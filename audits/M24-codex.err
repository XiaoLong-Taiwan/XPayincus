  325: async function checkPaymentProviders() {
  326:   const providers = await getActivePaymentProviders()
  327:   if (providers.length === 0) {
  328:     return { status: 'warning' as const, message: '未启用任何充值支付渠道' }
  329:   }
  330: 
  331:   const unsupported = providers.filter(provider => !supportedRechargeProviderTypes.has(String(provider.type)))
  332:   if (unsupported.length > 0) {
  333:     return {
  334:       status: 'warning' as const,
  335:       message: `存在 ${unsupported.length} 个尚未接入充值下单流程的启用支付渠道`,
  336:       detail: unsupported.map(provider => `${provider.name}(${provider.type})`).join(', ')
  337:     }
  338:   }
  339: 
  340:   const manualWithoutInstructions = providers.filter(provider => {
  341:     if (provider.type !== 'manual') return false
  342:     const config = asRecord(provider.config)
  343:     return !trimString(config.instructions)
  344:   })
  345:   if (manualWithoutInstructions.length > 0) {
  346:     return {
  347:       status: 'error' as const,
  348:       message: '人工充值渠道已启用但未填写收款说明',
  349:       detail: manualWithoutInstructions.map(provider => provider.name).join(', ')
  350:     }
  351:   }
  352: 
  353:   const counts = providers.reduce<Record<string, number>>((acc, provider) => {
  354:     const type = String(provider.type)
  355:     acc[type] = (acc[type] || 0) + 1
  356:     return acc
  357:   }, {})
  358: 
  359:   return {
  360:     status: 'ok' as const,
  361:     message: `已启用 ${providers.length} 个可用于充值的支付渠道`,
  362:     detail: Object.entries(counts).map(([type, count]) => `${type} x${count}`).join(', ')
  363:   }
  364: }
