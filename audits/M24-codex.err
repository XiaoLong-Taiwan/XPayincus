  471:       status: 'warning' as const,
  472:       message: result.repositoryError || '当前部署目录无法读取 Git release tag',
  473:       detail: result.current.version
  474:     }
  475:   }
  476: 
  477:   const latestVersion = result.latest?.version || '未读取到 release tag'
  478:   return {
  479:     status: result.updateAvailable ? 'warning' as const : 'ok' as const,
  480:     message: result.updateAvailable
  481:       ? `检测到 ${result.updates.length} 个可用 OTA 更新`
  482:       : 'OTA 更新源可访问，当前已是最新 release tag',
  483:     detail: `当前 ${result.current.version} / 最新 ${latestVersion}`
  484:   }
  485: }
