  389: 
  390:     const hasSwapConfig = config.swapEnabled !== undefined || config.swapSize !== undefined
  391:     const instanceKind = instance.package?.instanceType === 'vm' ? 'vm' : 'container'
  392:     const currentSwapSize = resolveEffectiveSwapSize(instance.swapSize, instance.packagePlan?.swapSize)
  393:     const nextSwapEnabled = config.swapEnabled ?? instance.swapEnabled
  394:     const nextSwapSize = config.swapSize !== undefined
  395:       ? Math.max(0, config.swapSize ?? 0)
  396:       : currentSwapSize
  397:     const storageOverrides = resolveStorageOverrides(config)
  398: 
  399:     if (hasSwapConfig && instanceKind === 'vm') {
  400:       throw new Error('虚拟机不支持批量 SWAP 配置')
  401:     }
  402: 
  403:     if (nextSwapEnabled && nextSwapSize <= 0) {
  404:       throw new Error('启用 SWAP 前需要设置大于 0 的 SWAP 大小')
  405:     }
  406: 
  407:     // 1. 更新资源配置（CPU、内存、磁盘）到 Incus
  408:     if (client && (config.cpu !== undefined || config.memory !== undefined || config.disk !== undefined)) {
  409:       await patchInstanceResources(client, instance.incusId, {
