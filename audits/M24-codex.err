  151:             await createIncusSnapshot(client, instance.incusId, snapshotName)
  152: 
  153:             // 在数据库中记录
  154:             await db.createSnapshot({
  155:                 instanceId: instance.id,
  156:                 incusName: snapshotName,
  157:                 name: snapshotName,
  158:                 description: '自动快照',
  159:                 stateful: false
  160:             })
  161: 
  162:             // 更新策略最后运行时间
  163:             await db.updateSnapshotPolicyLastRun(instance.id)
  164: 
  165:             // 发送通知（区分是否轮换）
  166:             if (deletedSnapshotName) {
  167:                 await sendNotification(instance.userId, 'auto_snapshot_rotated', {
  168:                     instanceName: instance.name,
  169:                     snapshotName,
  170:                     deletedName: deletedSnapshotName,
  171:                     quotaLimit: snapshotLimit,
  172:                     hostName: instance.host.name
  173:                 })
  174:             } else {
  175:                 await sendNotification(instance.userId, 'auto_snapshot', {
  176:                     instanceName: instance.name,
  177:                     snapshotName,
  178:                     hostName: instance.host.name
  179:                 })
  180:             }
  181: 
  182:             // 记录日志
  183:             await createLog(
  184:                 instance.userId,
  185:                 'snapshot',
  186:                 'snapshot.auto_create',
  187:                 `Auto snapshot "${snapshotName}" created for instance "${instance.name}"${deletedSnapshotName ? ` (deleted old: ${deletedSnapshotName})` : ''}`,
  188:                 'success',
  189:                 { instanceId: instance.id }
  190:             )
  191: 
  192:             console.log(`[AutoPolicy] Auto snapshot created for instance ${instance.id}: ${snapshotName}`)
  193:             return // 成功，退出重试循环
  194: 
  195:         } catch (error) {
  196:             lastError = error instanceof Error ? error : new Error(String(error))
  197:             console.error(`[AutoPolicy] Auto snapshot failed for instance ${instance.id} (attempt ${attempt}):`, lastError.message)
  198: 
  199:             if (attempt < MAX_RETRIES) {
  200:                 await delay(RETRY_DELAY * attempt) // 递增延迟
  201:             }
  202:         }
  203:     }
  204: 
  205:     // 所有重试都失败
  206:     console.error(`[AutoPolicy] Auto snapshot failed after ${MAX_RETRIES} attempts for instance ${instance.id}`)
  207:     
  208:     // 即使失败也更新下次运行时间，避免无限重试
  209:     await db.updateSnapshotPolicyLastRun(instance.id)
  210:     
  211:     // 发送失败通知
  212:     await sendNotification(instance.userId, 'snapshot_failed', {
  213:         instanceName: instance.name,
  214:         error: lastError?.message || 'Unknown error',
  215:         hostName: instance.host.name
  216:     })
  217:     
  218:     await createLog(
  219:         instance.userId,
  220:         'snapshot',
  221:         'snapshot.auto_create',
  222:         `Auto snapshot failed for instance "${instance.name}": ${lastError?.message}`,
  223:         'failed',
  224:         { instanceId: instance.id }
  225:     )
  226: }
  227: 
  228: async function executeLockedAutoSnapshot(candidate: { instanceId: number }): Promise<void> {
  229:     const lockKey = getAutoSnapshotPolicyLockKey(candidate.instanceId)
  230:     const lockResult = await acquireLock(lockKey, {
  231:         expireMs: AUTO_POLICY_LOCK_EXPIRE_MS,
  232:         waitTimeoutMs: AUTO_POLICY_LOCK_WAIT_MS,
  233:         retryIntervalMs: 50
  234:     })
  235: 
  236:     if (!lockResult.success || !lockResult.ownerId) {
  237:         console.log(`[AutoPolicy] Skip auto snapshot for instance ${candidate.instanceId}: lock already held`)
  238:         return
  239:     }
  240: 
  241:     try {
  242:         const now = new Date()
  243:         const policy = await prisma.snapshotPolicy.findUnique({
  244:             where: { instanceId: candidate.instanceId },
  245:             include: {
  246:                 instance: {
  247:                     include: {
  248:                         host: true
  249:                     }
  250:                 }
  251:             }
  252:         })
  253: 
  254:         if (!policy?.enabled || (policy.nextRunAt !== null && policy.nextRunAt > now)) {
  255:             console.log(`[AutoPolicy] Skip auto snapshot for instance ${candidate.instanceId}: policy no longer due`)
  256:             return
  257:         }
  258: 
  259:         if (
  260:             !policy.instance ||
  261:             !['running', 'stopped'].includes(policy.instance.status) ||
  262:             policy.instance.host.status !== 'online'
  263:         ) {
  264:             console.log(`[AutoPolicy] Skip auto snapshot for instance ${candidate.instanceId}: instance or host no longer eligible`)
  265:             return
  266:         }
  267: 
  268:         const exchangeLock = await getExchangeOperationLock(candidate.instanceId)
  269:         if (exchangeLock.locked) {
  270:             console.log(`[AutoPolicy] Skip auto snapshot for instance ${candidate.instanceId}: exchange locked (${exchangeLock.code})`)
  271:             return
  272:         }
  273: 
  274:         await executeAutoSnapshot({
  275:             instanceId: policy.instanceId,
  276:             instance: {
  277:                 id: policy.instance.id,
  278:                 incusId: policy.instance.incusId,
  279:                 name: policy.instance.name,
  280:                 userId: policy.instance.userId,
  281:                 snapshotLimit: policy.instance.snapshotLimit,
  282:                 host: {
  283:                     url: policy.instance.host.url,
  284:                     name: policy.instance.host.name,
  285:                     certPath: policy.instance.host.certPath,
  286:                     keyPath: policy.instance.host.keyPath
  287:                 }
  288:             }
  289:         })
  290:     } finally {
  291:         await releaseLock(lockKey, lockResult.ownerId)
  292:     }
  293: }
  294: 
  295: /**
  296:  * 运行自动快照任务
  297:  */
  298: export async function runAutoSnapshotJob(): Promise<void> {
  299:     console.log('[AutoPolicy] Starting auto snapshot job...')
  300:     const startTime = Date.now()
  301: 
  302:     try {
  303:         const now = new Date()
  304: 
  305:         // 获取待执行的快照策略
  306:         const policies = await prisma.snapshotPolicy.findMany({
  307:             where: {
  308:                 enabled: true,
  309:                 OR: [
  310:                     { nextRunAt: null },
  311:                     { nextRunAt: { lte: now } }
  312:                 ]
  313:             },
  314:             include: {
  315:                 instance: {
  316:                     include: {
  317:                         host: true
  318:                     }
  319:                 }
  320:             }
  321:         })
  322: 
  323:         // 过滤掉已删除的实例，允许 running 和 stopped 状态
  324:         const validPolicies = policies.filter(p =>
  325:             p.instance &&
  326:             ['running', 'stopped'].includes(p.instance.status) &&
  327:             p.instance.host.status === 'online'
  328:         )
  329: 
  330:         console.log(`[AutoPolicy] Found ${validPolicies.length} snapshot policies to execute`)
  331: 
  332:         // 并发执行（允许 running 和 stopped 状态）
  333:         await Promise.all(
  334:             validPolicies.map(policy =>
  335:                 limit(() => executeLockedAutoSnapshot(policy))
  336:             )
  337:         )
  338: 
  339:         const duration = Date.now() - startTime
  340:         console.log(`[AutoPolicy] Auto snapshot job completed in ${duration}ms`)
  341:     } catch (error) {
  342:         console.error('[AutoPolicy] Auto snapshot job failed:', error)
  343:     }
  344: }
  345: 
  346: /**
  347:  * 启动自动策略调度器
  348:  */
  349: export function startAutoPolicyScheduler(): void {
  350:     if (schedulerStarted) {
  351:         return
  352:     }
  353: 
  354:     schedulerStarted = true
  355: 
  356:     // 每 5 分钟检查一次快照策略（支持10分钟频率）
  357:     schedule('*/5 * * * *', () => {
  358:         runAutoSnapshotJob().catch(console.error)
  359:     })
  360: 
  361:     console.log('[AutoPolicy] Scheduler started')
  362:     console.log('[AutoPolicy] - Auto snapshot: every 5 minutes')
  363: }

