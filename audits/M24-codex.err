  200: async function syncHostCapacityAlertsToSla(alerts: CapacityAlert[]): Promise<void> {
  201:   const hostAlerts = alerts.filter(alert => alert.objectType === 'host')
  202:   if (hostAlerts.length === 0) return
  203: 
  204:   const rule = await prisma.slaAlertRule.upsert({
  205:     where: { code: CAPACITY_SLA_RULE_CODE },
  206:     update: {},
  207:     create: {
  208:       code: CAPACITY_SLA_RULE_CODE,
  209:       module: 'capacity',
  210:       title: 'Host 容量压力',
  211:       description: 'Host CPU、内存、磁盘或 NAT 端口水位过高时触发。',
  212:       severity: 'warning',
  213:       dedupeMinutes: 30
  214:     }
  215:   })
  216: 
  217:   if (!rule.enabled) return
  218:   const now = new Date()
  219:   if (rule.silenceUntil && rule.silenceUntil > now) return
  220: 
  221:   await Promise.all(hostAlerts.map(async alert => {
  222:     const existing = await prisma.slaAlertEvent.findUnique({
  223:       where: {
  224:         ruleCode_fingerprint: {
  225:           ruleCode: CAPACITY_SLA_RULE_CODE,
  226:           fingerprint: alert.key
  227:         }
  228:       }
  229:     })
  230: 
  231:     const data = {
  232:       module: 'capacity',
  233:       severity: alert.severity,
  234:       objectType: 'host' as const,
  235:       objectId: alert.objectId,
  236:       objectLabel: alert.title.replace(/ (CPU|内存|磁盘|NAT 端口) 余量不足$/, ''),
  237:       title: alert.title,
  238:       message: alert.message,
  239:       detail: {
  240:         source: 'capacity-cost-overview',
  241:         capacityAlertKey: alert.key
  242:       },
  243:       lastTriggeredAt: now
  244:     }
  245: 
  246:     if (!existing) {
  247:       const created = await prisma.slaAlertEvent.create({
  248:         data: {
  249:           ruleCode: CAPACITY_SLA_RULE_CODE,
  250:           fingerprint: alert.key,
  251:           status: 'open',
  252:           ...data
  253:         }
  254:       })
  255:       await prisma.slaAlertAction.create({
  256:         data: {
  257:           eventId: created.id,
  258:           actionType: 'detected',
  259:           detail: { ruleCode: CAPACITY_SLA_RULE_CODE, source: 'capacity-cost-overview' }
  260:         }
  261:       })
  262:       return
  263:     }
  264: 
  265:     if (existing.status === 'ignored') return
  266:     const updated = await prisma.slaAlertEvent.update({
  267:       where: { id: existing.id },
  268:       data: {
  269:         ...data,
  270:         status: existing.status === 'recovered' ? 'open' : existing.status,
  271:         recoveredAt: existing.status === 'recovered' ? null : existing.recoveredAt,
  272:         triggerCount: { increment: 1 }
  273:       }
  274:     })
  275:     await prisma.slaAlertAction.create({
  276:       data: {
  277:         eventId: updated.id,
  278:         actionType: 'merged',
  279:         detail: { ruleCode: CAPACITY_SLA_RULE_CODE, source: 'capacity-cost-overview', triggerCount: updated.triggerCount }
  280:       }
  281:     })
  282:   }))
  283: }
