   93: async function recordIntegrationHealthItems(items: IntegrationHealthItem[], checkedByUserId: number): Promise<void> {
   94:   await prisma.integrationHealthCheck.createMany({
   95:     data: items.map(item => ({
   96:       key: item.key,
   97:       title: item.title,
   98:       status: item.status,
   99:       message: item.message,
  100:       detail: item.detail || null,
  101:       durationMs: item.durationMs,
  102:       checkedAt: new Date(item.checkedAt),
  103:       checkedByUserId
  104:     }))
  105:   })
  106: }
  107: 
  108: async function getIntegrationHealthHistory() {
  109:   const since = new Date(Date.now() - healthHistoryWindowDays * 24 * 60 * 60 * 1000)
  110:   const [windowRecords, recentFailures] = await Promise.all([
  111:     prisma.integrationHealthCheck.findMany({
  112:       where: { checkedAt: { gte: since } },
  113:       orderBy: { checkedAt: 'desc' },
  114:       take: 500
  115:     }),
  116:     prisma.integrationHealthCheck.findMany({
  117:       where: {
  118:         status: { in: ['warning', 'error'] }
  119:       },
  120:       orderBy: { checkedAt: 'desc' },
  121:       take: 10
  122:     })
  123:   ])
  124: 
  125:   const grouped = new Map<string, typeof windowRecords>()
  126:   for (const record of windowRecords) {
  127:     grouped.set(record.key, [...(grouped.get(record.key) || []), record])
  128:   }
  129: 
  130:   const summaries: IntegrationHealthSummary[] = Array.from(grouped.entries()).map(([key, records]) => {
  131:     const last = records[0]
  132:     const ok = records.filter(record => record.status === 'ok').length
  133:     const warning = records.filter(record => record.status === 'warning').length
  134:     const error = records.filter(record => record.status === 'error').length
  135:     const skipped = records.filter(record => record.status === 'skipped').length
  136:     const actionableTotal = Math.max(0, records.length - skipped)
  137:     const successRate = actionableTotal > 0 ? Math.round((ok / actionableTotal) * 1000) / 10 : 0
  138: 
  139:     return {
  140:       key,
  141:       title: last.title,
  142:       total: records.length,
  143:       ok,
  144:       warning,
  145:       error,
  146:       skipped,
  147:       successRate,
  148:       lastStatus: normalizeHealthStatus(last.status),
  149:       lastMessage: last.message,
  150:       lastCheckedAt: last.checkedAt.toISOString()
  151:     }
  152:   })
  153: 
  154:   summaries.sort((left, right) => right.lastCheckedAt.localeCompare(left.lastCheckedAt))
  155: 
  156:   return {
  157:     windowDays: healthHistoryWindowDays,
  158:     summaries,
  159:     recentFailures: recentFailures.map(serializeHealthRecord)
  160:   }
  161: }
  162: 
  163: function hostnameOf(value: string | null | undefined): string {
  164:   if (!value) return '-'
  165:   try {
  166:     return new URL(value).hostname
  167:   } catch {
  168:     return '-'
  169:   }
  170: }
  171: 
  172: function lskyApiBase(baseUrl: string, apiVersion: 'v1' | 'v2'): string {
  173:   const normalized = baseUrl.trim().replace(/\/+$/, '')
  174:   const apiPrefix = apiVersion === 'v2' ? '/api/v2' : '/api/v1'
  175:   return normalized.toLowerCase().endsWith(apiPrefix) ? normalized : `${normalized}${apiPrefix}`
  176: }
  177: 
  178: function asRecord(value: unknown): Record<string, unknown> {
  179:   return value && typeof value === 'object' && !Array.isArray(value)
  180:     ? value as Record<string, unknown>
  181:     : {}
  182: }
  183: 
  184: function trimString(value: unknown): string {
  185:   return typeof value === 'string' ? value.trim() : ''
  186: }
  187: 
  188: function formatAge(value: Date | null | undefined): string {
  189:   if (!value) return '从未上报'
  190:   const ageSeconds = Math.max(0, Math.floor((Date.now() - value.getTime()) / 1000))
  191:   if (ageSeconds < 60) return `${ageSeconds} 秒前`
  192:   const ageMinutes = Math.floor(ageSeconds / 60)
  193:   if (ageMinutes < 60) return `${ageMinutes} 分钟前`
  194:   const ageHours = Math.floor(ageMinutes / 60)
  195:   if (ageHours < 24) return `${ageHours} 小时前`
  196:   return `${Math.floor(ageHours / 24)} 天前`
  197: }
  198: 
  199: async function withProbeTimeout<T>(promise: Promise<T>, label: string, ms = integrationProbeTimeoutMs): Promise<T> {
  200:   let timer: NodeJS.Timeout | undefined
  201:   try {
  202:     return await Promise.race([
  203:       promise,
  204:       new Promise<T>((_, reject) => {
  205:         timer = setTimeout(() => reject(new Error(`${label} 超时（${Math.round(ms / 1000)} 秒）`)), ms)
  206:       })
  207:     ])
  208:   } finally {
  209:     if (timer) clearTimeout(timer)
  210:   }
  211: }
  212: 
  213: async function probe(
  214:   key: string,
  215:   title: string,
  216:   run: () => Promise<Omit<IntegrationHealthItem, 'key' | 'title' | 'checkedAt' | 'durationMs'>>
  217: ): Promise<IntegrationHealthItem> {
  218:   const startedAt = Date.now()
  219:   try {
  220:     const result = await run()
  221:     return {
  222:       key,
  223:       title,
  224:       ...result,
  225:       checkedAt: nowIso(),
  226:       durationMs: durationSince(startedAt)
  227:     }
  228:   } catch (error: any) {
  229:     return {
  230:       key,
  231:       title,
  232:       status: 'error',
  233:       message: error?.message || String(error),
  234:       checkedAt: nowIso(),
  235:       durationMs: durationSince(startedAt)
  236:     }
  237:   }
  238: }
