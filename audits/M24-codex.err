    1: /**
    2:  * 系统健康监控服务
    3:  * 
    4:  * 高可用特性：
    5:  * - 定期输出系统健康状态
    6:  * - 监控各调度器运行情况
    7:  * - Webhook 告警异常情况
    8:  */
    9: 
   10: import { schedule } from 'node-cron'
   11: import { getDbPoolStats, prisma } from '../db/prisma.js'
   12: import { getPoolStatus } from '../lib/incus/incus-pool.js'
   13: import { assertSafeWebhookUrl } from '../lib/outbound-security.js'
   14: 
   15: // 系统启动时间
   16: const systemStartTime = Date.now()
   17: 
   18: // 告警配置
   19: const ALERT_WEBHOOK_URL = process.env.ALERT_WEBHOOK_URL || ''
   20: const ALERT_COOLDOWN_MS = 10 * 60 * 1000  // 10分钟告警冷却
   21: const ALERT_TIMEOUT_MS = 10 * 1000  // 10秒请求超时
   22: let lastAlertTime = 0
   23: let schedulerStarted = false
   24: 
   25: // 监控指标
   26: interface SystemMetrics {
   27:   uptime: number
   28:   instanceCount: number
   29:   hostCount: number
   30:   onlineHostCount: number
   31:   pendingTasks: number
   32:   processingTasks: number
   33:   pendingRestoreTasks: number
   34:   processingRestoreTasks: number
   35:   pendingUploadTasks: number
   36:   processingUploadTasks: number
   37:   incusConnectionPoolSize: number
   38:   dbPoolTotalCount: number
   39:   dbPoolIdleCount: number
   40:   dbPoolWaitingCount: number
   41:   avgResponseTime: number
   42:   errorHosts: number
   43:   memoryUsageMB: number
   44: }
   45: 
   46: /**
   47:  * 收集系统指标
   48:  */
   49: async function collectMetrics(): Promise<SystemMetrics> {
   50:   const [
   51:     instanceCount,
   52:     hostStats,
   53:     pendingTasks,
   54:     processingTasks,
   55:     pendingRestoreTasks,
   56:     processingRestoreTasks,
   57:     pendingUploadTasks,
   58:     processingUploadTasks
   59:   ] = await Promise.all([
   60:     prisma.instance.count({ where: { status: { not: 'deleted' } } }),
   61:     prisma.host.groupBy({
   62:       by: ['status'],
   63:       _count: { id: true }
   64:     }),
   65:     prisma.instanceTask.count({ where: { status: 'PENDING' } }),
   66:     prisma.instanceTask.count({ where: { status: 'PROCESSING' } }),
   67:     prisma.restoreTask.count({ where: { status: 'PENDING' } }),
   68:     prisma.restoreTask.count({ where: { status: 'PROCESSING' } }),
   69:     prisma.backupUploadTask.count({ where: { status: 'PENDING' } }),
   70:     prisma.backupUploadTask.count({ where: { status: 'PROCESSING' } })
   71:   ])
   72:   
   73:   // 计算宿主机统计
   74:   const hostCount = hostStats.reduce((sum, h) => sum + h._count.id, 0)
   75:   const onlineHostCount = hostStats.find(h => h.status === 'online')?._count.id || 0
   76:   
   77:   // 获取连接池状态
   78:   const poolStatus = getPoolStatus()
   79:   let totalResponseTime = 0
   80:   let responseTimeCount = 0
   81:   let errorHosts = 0
   82:   
   83:   for (const [_, status] of poolStatus) {
   84:     if (status.lastResponseTime > 0) {
   85:       totalResponseTime += status.lastResponseTime
   86:       responseTimeCount++
   87:     }
   88:     if (status.errorCount >= 3) {
   89:       errorHosts++
   90:     }
   91:   }
   92:   
   93:   const avgResponseTime = responseTimeCount > 0 
   94:     ? Math.round(totalResponseTime / responseTimeCount) 
   95:     : 0
   96: 
   97:   const dbPoolStats = getDbPoolStats()
   98:   
   99:   // 获取内存使用情况
  100:   const memoryUsage = process.memoryUsage()
  101:   const memoryUsageMB = Math.round(memoryUsage.heapUsed / 1024 / 1024)
  102:   
  103:   return {
  104:     uptime: Math.round((Date.now() - systemStartTime) / 1000 / 60), // 分钟
  105:     instanceCount,
  106:     hostCount,
  107:     onlineHostCount,
  108:     pendingTasks,
  109:     processingTasks,
  110:     pendingRestoreTasks,
  111:     processingRestoreTasks,
  112:     pendingUploadTasks,
  113:     processingUploadTasks,
  114:     incusConnectionPoolSize: poolStatus.size,
  115:     dbPoolTotalCount: dbPoolStats.totalCount,
  116:     dbPoolIdleCount: dbPoolStats.idleCount,
  117:     dbPoolWaitingCount: dbPoolStats.waitingCount,
  118:     avgResponseTime,
  119:     errorHosts,
  120:     memoryUsageMB
  121:   }
  122: }
  123: 
  124: /**
  125:  * 发送告警到 Webhook
  126:  */
  127: async function sendAlert(alerts: string[]): Promise<void> {
  128:   if (!ALERT_WEBHOOK_URL) return
  129:   
  130:   // 告警冷却检查
  131:   const now = Date.now()
  132:   if (now - lastAlertTime < ALERT_COOLDOWN_MS) {
  133:     console.log('[Monitor] Alert cooldown, skipping webhook')
  134:     return
  135:   }
  136:   
  137:   try {
  138:     const payload = {
  139:       type: 'system_alert',
  140:       timestamp: new Date().toISOString(),
  141:       alerts,
  142:       source: 'incudal-monitor'
  143:     }
  144:     
  145:     // 设置请求超时
  146:     const controller = new AbortController()
  147:     const timeoutId = setTimeout(() => controller.abort(), ALERT_TIMEOUT_MS)
  148:     
  149:     try {
  150:       const webhookUrl = await assertSafeWebhookUrl(ALERT_WEBHOOK_URL)
  151:       const response = await fetch(webhookUrl.toString(), {
  152:         method: 'POST',
  153:         headers: {
  154:           'Content-Type': 'application/json'
  155:         },
  156:         body: JSON.stringify(payload),
  157:         signal: controller.signal,
  158:         redirect: 'manual'
  159:       })
  160:       
  161:       if (response.ok) {
  162:         lastAlertTime = now
  163:         console.log('[Monitor] Alert sent successfully')
  164:       } else {
  165:         console.error(`[Monitor] Alert webhook failed: ${response.status}`)
  166:       }
  167:     } finally {
  168:       clearTimeout(timeoutId)
  169:     }
  170:   } catch (error) {
  171:     if (error instanceof Error && error.name === 'AbortError') {
  172:       console.error('[Monitor] Alert webhook timeout')
  173:     } else {
  174:       console.error('[Monitor] Failed to send alert:', error)
  175:     }
  176:   }
  177: }
  178: 
  179: /**
  180:  * 输出健康报告
  181:  */
  182: async function reportHealth(): Promise<void> {
  183:   try {
  184:     const metrics = await collectMetrics()
  185:     
  186:     // 构建健康状态
  187:     const status = []
  188:     if (metrics.errorHosts > 0) {
  189:       status.push(`⚠️ ${metrics.errorHosts} hosts with errors`)
  190:     }
  191:     if (metrics.processingTasks > 10) {
  192:       status.push(`⚠️ High task load: ${metrics.processingTasks} processing`)
  193:     }
  194:     if (metrics.avgResponseTime > 1000) {
  195:       status.push(`⚠️ Slow response: ${metrics.avgResponseTime}ms avg`)
  196:     }
  197:     if (metrics.memoryUsageMB > 512) {
  198:       status.push(`⚠️ High memory: ${metrics.memoryUsageMB}MB`)
  199:     }
  200:     
  201:     const healthStatus = status.length > 0 ? status.join(', ') : '✓ All systems healthy'
  202:     
  203:     // 如果有异常且配置了 Webhook，发送告警
  204:     if (status.length > 0 && ALERT_WEBHOOK_URL) {
  205:       await sendAlert(status)
  206:     }
  207:     
  208:     // 计算总任务数
  209:     const totalPending = metrics.pendingTasks + metrics.pendingRestoreTasks + metrics.pendingUploadTasks
  210:     const totalProcessing = metrics.processingTasks + metrics.processingRestoreTasks + metrics.processingUploadTasks
  211:     
  212:     console.log(`[Monitor] Health Report:
  213:   Uptime: ${metrics.uptime} min | Memory: ${metrics.memoryUsageMB}MB
  214:   Instances: ${metrics.instanceCount}
  215:   Hosts: ${metrics.onlineHostCount}/${metrics.hostCount} online
  216:   Tasks: ${totalPending} pending, ${totalProcessing} processing
  217:     - Instance: ${metrics.pendingTasks}/${metrics.processingTasks}
  218:     - Restore: ${metrics.pendingRestoreTasks}/${metrics.processingRestoreTasks}
  219:     - Upload: ${metrics.pendingUploadTasks}/${metrics.processingUploadTasks}
  220:   DB Pool: total=${metrics.dbPoolTotalCount}, idle=${metrics.dbPoolIdleCount}, waiting=${metrics.dbPoolWaitingCount}
  221:   Incus Pool: ${metrics.incusConnectionPoolSize} connections, ${metrics.avgResponseTime}ms avg
  222:   Status: ${healthStatus}`)
  223:   } catch (error) {
  224:     console.error('[Monitor] Failed to collect metrics:', error)
  225:   }
  226: }
  227: 
  228: /**
  229:  * 启动系统监控
  230:  */
  231: export function startSystemMonitor(): void {
  232:   if (schedulerStarted) {
  233:     return
  234:   }
  235: 
  236:   schedulerStarted = true
  237: 
  238:   // 启动时输出一次
  239:   setTimeout(() => {
  240:     reportHealth().catch(console.error)
  241:   }, 5000) // 延迟5秒，等系统初始化完成
  242:   
  243:   // 每10分钟输出健康报告
  244:   schedule('*/10 * * * *', () => {
  245:     reportHealth().catch(console.error)
  246:   })
  247:   
  248:   console.log('[Monitor] System monitor started')
  249: }
  250: 
  251: /**
  252:  * 获取系统指标（API 用）
  253:  */
  254: export async function getSystemMetrics(): Promise<SystemMetrics> {
  255:   return collectMetrics()
  256: }

