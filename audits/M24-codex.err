  354: /**
  355:  * 更新单个实例配置
  356:  */
  357: async function updateSingleInstance(
  358:   instance: {
  359:     id: number
  360:     incusId: string
  361:     name: string
  362:     cpu: number
  363:     memory: number
  364:     disk: number
  365:     hostId: number
  366:     swapEnabled: boolean
  367:     swapSize: number | null
  368:     package: {
  369:       instanceType: string
