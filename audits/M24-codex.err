  533:       items.some(item => item.status === 'error') ? 'warning' : 'success'
  534:     )
  535: 
  536:     await recordIntegrationHealthItems(items, request.user.id)
  537:     const history = await getIntegrationHealthHistory()
  538: 
  539:     return {
  540:       checkedAt: nowIso(),
  541:       items,
  542:       history
  543:     }
  544:   })
  545: }

