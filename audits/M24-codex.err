  111: 
  112: export default async function batchConfigRoutes(fastify: FastifyInstance) {
  113:   /**
  114:    * 批量修改实例配置
  115:    * POST /api/hosts/:id/instances/batch-config
  116:    */
  117:   fastify.post<{
  118:     Params: { id: string }
  119:     Body: BatchConfigBody
  120:   }>('/:id/instances/batch-config', {
  121:     onRequest: [fastify.authenticate],
  122:     schema: {
  123:       body: {
  124:         type: 'object',
  125:         required: ['instanceIds', 'config'],
  126:         properties: {
  127:           instanceIds: {
  128:             type: 'array',
  129:             items: { type: 'integer', minimum: 1 },
  130:             minItems: 1,
  131:             maxItems: 1000,
  132:             uniqueItems: true
  133:           },
  134:           config: {
  135:             type: 'object',
  136:             properties: {
  137:               // 资源配置
  138:               cpu: { type: 'integer', minimum: 1 },
  139:               memory: { type: 'integer', minimum: 1 },
  140:               disk: { type: 'number', minimum: 1 },
  141:               monthlyTrafficLimit: { type: ['string', 'null'] },
  142:               swapEnabled: { type: 'boolean' },
  143:               swapSize: { type: ['integer', 'null'], minimum: 0, maximum: 1048576 },
  144:               // 配额限制
  145:               portLimit: { type: ['integer', 'null'], minimum: 1, maximum: 1000 },
  146:               snapshotLimit: { type: ['integer', 'null'], minimum: 0, maximum: 1000 },
  147:               backupLimit: { type: ['integer', 'null'], minimum: 0, maximum: 1000 },
  148:               siteLimit: { type: ['integer', 'null'], minimum: 0, maximum: 1000 },
  149:               // 容器权限
  150:               nested: { type: 'boolean' },
  151:               privileged: { type: 'boolean' },
  152:               // 高级配置
  153:               limitsRead: { type: ['string', 'null'] },
  154:               limitsWrite: { type: ['string', 'null'] },
  155:               limitsReadIops: { type: ['integer', 'null'], minimum: 0 },
  156:               limitsWriteIops: { type: ['integer', 'null'], minimum: 0 },
  157:               limitsIngress: { type: ['string', 'null'] },
  158:               limitsEgress: { type: ['string', 'null'] },
  159:               limitsProcesses: { type: ['integer', 'null'], minimum: 0 },
  160:               limitsCpuPriority: { type: ['integer', 'null'], minimum: 0, maximum: 10 },
  161:               bootAutostart: { type: ['boolean', 'null'] },
  162:               bootAutostartPriority: { type: ['integer', 'null'], minimum: 0, maximum: 100 },
  163:               bootAutostartDelay: { type: ['integer', 'null'], minimum: 5, maximum: 600 },
  164:               bootHostShutdownTimeout: { type: ['integer', 'null'], minimum: 30, maximum: 600 }
  165:             }
  166:           }
  167:         }
  168:       }
  169:     }
  170:   }, async (request: FastifyRequest<{
  171:     Params: { id: string }
  172:     Body: BatchConfigBody
  173:   }>, reply: FastifyReply) => {
  174:     const { user } = request
  175:     const { id } = request.params
  176:     const { instanceIds, config } = request.body
  177:     const hostId = parsePositiveRouteId(id)
  178: 
  179:     if (!hostId) {
  180:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
  181:     }
  182: 
  183:     const normalizedInstanceIds = normalizeBatchInstanceIds(instanceIds)
  184:     if (!normalizedInstanceIds) {
  185:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid instance IDs'))
  186:     }
  187: 
  188:     // 验证宿主机存在且属于当前用户
