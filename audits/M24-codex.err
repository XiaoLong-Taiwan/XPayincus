  238: async function upsertDefaultRule(rule: AlertSeed) {
  239:   try {
  240:     await prisma.slaAlertRule.upsert({
  241:       where: { code: rule.code },
  242:       update: {},
  243:       create: {
  244:         code: rule.code,
  245:         module: rule.module,
  246:         title: rule.title,
  247:         description: rule.description,
  248:         severity: rule.severity,
  249:         thresholdMinutes: rule.thresholdMinutes ?? null,
  250:         thresholdCount: rule.thresholdCount ?? null,
  251:         dedupeMinutes: rule.dedupeMinutes ?? 30
  252:       }
  253:     })
  254:   } catch (error) {
  255:     if (error instanceof Prisma.PrismaClientKnownRequestError && error.code === 'P2002') {
  256:       return
  257:     }
  258:     throw error
  259:   }
  260: }
  261: 
  262: async function seedDefaultRules() {
  263:   if (defaultRulesSeeded) return
  264: 
  265:   if (!defaultRulesSeedPromise) {
  266:     defaultRulesSeedPromise = (async () => {
  267:       for (const rule of DEFAULT_RULES) {
  268:         await upsertDefaultRule(rule)
  269:       }
  270:       defaultRulesSeeded = true
  271:     })().finally(() => {
  272:       defaultRulesSeedPromise = null
  273:     })
  274:   }
  275: 
