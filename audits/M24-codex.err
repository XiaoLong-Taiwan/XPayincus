  103: function buildHostCapacity(host: {
  104:   cpuAllowanceMax: number
  105:   cpuUsed: number
  106:   memoryMax: number
  107:   memoryUsed: number
  108:   storageSize: number
  109:   diskUsed: number
  110:   natPortStart: number | null
  111:   natPortEnd: number | null
  112:   natPortsUsedCount: number
  113:   instances: Array<{ monthlyTrafficUsed: bigint }>
  114: }): HostCapacitySnapshot {
  115:   const cpuTotal = Math.max(host.cpuAllowanceMax || 0, 0)
  116:   const cpuUsed = Math.max(host.cpuUsed || 0, 0)
  117:   const memoryTotal = Math.max(host.memoryMax || 0, 0)
  118:   const memoryUsed = Math.max(host.memoryUsed || 0, 0)
  119:   const diskTotal = getDiskTotalMb(host)
  120:   const diskUsed = Math.max(host.diskUsed || 0, 0)
  121:   const natPortTotal = getNatPortTotal(host)
  122:   const natPortUsed = Math.max(host.natPortsUsedCount || 0, 0)
  123:   const trafficUsed = host.instances.reduce((sum, instance) => sum + (instance.monthlyTrafficUsed || 0n), 0n)
  124: 
  125:   return {
  126:     cpuTotal,
  127:     cpuUsed,
  128:     cpuAvailable: positiveAvailable(cpuTotal, cpuUsed),
  129:     cpuUsageRatio: usageRatio(cpuUsed, cpuTotal),
  130:     memoryTotal,
  131:     memoryUsed,
  132:     memoryAvailable: positiveAvailable(memoryTotal, memoryUsed),
  133:     memoryUsageRatio: usageRatio(memoryUsed, memoryTotal),
  134:     diskTotal,
  135:     diskUsed,
  136:     diskAvailable: positiveAvailable(diskTotal, diskUsed),
  137:     diskUsageRatio: usageRatio(diskUsed, diskTotal),
  138:     natPortTotal,
  139:     natPortUsed,
  140:     natPortAvailable: positiveAvailable(natPortTotal, natPortUsed),
  141:     natPortUsageRatio: usageRatio(natPortUsed, natPortTotal),
  142:     instanceCount: host.instances.length,
  143:     trafficUsedBytes: trafficUsed.toString()
  144:   }
  145: }
  146: 
  147: function estimatePlanSlots(plan: { cpu: number; memory: number; disk: number; portLimit: number }, capacity: HostCapacitySnapshot): number {
  148:   const slots = [
  149:     plan.cpu > 0 ? Math.floor(capacity.cpuAvailable / plan.cpu) : Number.POSITIVE_INFINITY,
  150:     plan.memory > 0 ? Math.floor(capacity.memoryAvailable / plan.memory) : Number.POSITIVE_INFINITY,
  151:     plan.disk > 0 ? Math.floor(capacity.diskAvailable / plan.disk) : Number.POSITIVE_INFINITY,
  152:     plan.portLimit > 0 && capacity.natPortTotal > 0 ? Math.floor(capacity.natPortAvailable / plan.portLimit) : Number.POSITIVE_INFINITY
  153:   ]
  154:   const finiteSlots = slots.filter(Number.isFinite)
  155:   if (finiteSlots.length === 0) return MIN_PLAN_SLOTS
  156:   return Math.max(Math.min(...finiteSlots), MIN_PLAN_SLOTS)
  157: }
  158: 
  159: function estimatePlanMonthlyCost(
  160:   plan: { cpu: number; memory: number; disk: number; trafficLimit: bigint },
  161:   host: {
  162:     cpuAllowanceMax: number
  163:     memoryMax: number
  164:     storageSize: number
  165:     costProfile: { monthlyCost: Prisma.Decimal; ipv4MonthlyCost: Prisma.Decimal; trafficTbCost: Prisma.Decimal } | null
  166:   }
  167: ): number {
  168:   const profile = host.costProfile
  169:   if (!profile) return 0
  170: 
  171:   const monthlyCost = toMoney(profile.monthlyCost)
  172:   const cpuShare = host.cpuAllowanceMax > 0 ? plan.cpu / host.cpuAllowanceMax : 0
  173:   const memoryShare = host.memoryMax > 0 ? plan.memory / host.memoryMax : 0
  174:   const diskShare = getDiskTotalMb(host) > 0 ? plan.disk / getDiskTotalMb(host) : 0
  175:   const weightedShare = (cpuShare + memoryShare + diskShare) / 3
  176:   const resourceCost = monthlyCost * Math.max(weightedShare, 0)
  177:   const trafficCost = Number(plan.trafficLimit || 0n) > 0
  178:     ? (Number(plan.trafficLimit) / BYTES_PER_TB) * toMoney(profile.trafficTbCost)
  179:     : 0
  180: 
  181:   return toMoney(resourceCost + trafficCost + toMoney(profile.ipv4MonthlyCost))
  182: }
  183: 
  184: function pushUsageAlert(
  185:   alerts: CapacityAlert[],
  186:   key: string,
  187:   ratio: number,
  188:   objectType: 'host' | 'package_plan',
  189:   objectId: number,
  190:   title: string,
  191:   message: string
  192: ): void {
  193:   if (ratio >= LOW_CAPACITY_CRITICAL_RATIO) {
  194:     alerts.push({ key, severity: 'critical', objectType, objectId, title, message })
  195:   } else if (ratio >= LOW_CAPACITY_WARNING_RATIO) {
  196:     alerts.push({ key, severity: 'warning', objectType, objectId, title, message })
  197:   }
  198: }
