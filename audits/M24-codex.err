  289: async function checkTelegram() {
  290:   const enabled = await getSystemConfigBoolean('telegram_bot_enabled', false)
  291:   const botToken = await getSystemConfig('telegram_bot_token')
  292:   if (!enabled || !botToken) {
  293:     return { status: 'skipped' as const, message: 'Telegram Bot 未启用或 token 未配置' }
  294:   }
  295: 
  296:   const response = await fetch(`https://api.telegram.org/bot${botToken}/getWebhookInfo`, {
  297:     method: 'GET',
  298:     redirect: 'manual',
  299:     signal: AbortSignal.timeout(telegramApiTimeoutMs)
  300:   })
  301:   const payload: any = await response.json().catch(() => null)
  302:   if (!response.ok || !payload?.ok) {
  303:     return {
  304:       status: 'error' as const,
  305:       message: payload?.description || `Telegram getWebhookInfo failed: HTTP ${response.status}`
  306:     }
  307:   }
  308: 
  309:   const info = payload.result || {}
  310:   if (info.last_error_message) {
  311:     return {
  312:       status: 'warning' as const,
  313:       message: info.last_error_message,
  314:       detail: info.url ? `Webhook 已配置，待处理 ${info.pending_update_count ?? 0}` : 'Webhook 未配置'
  315:     }
  316:   }
  317: 
  318:   return {
  319:     status: info.url ? 'ok' as const : 'warning' as const,
  320:     message: info.url ? 'Telegram Webhook 正常' : 'Telegram Bot 可访问但 Webhook 未配置',
  321:     detail: info.url ? `待处理 ${info.pending_update_count ?? 0}` : undefined
  322:   }
  323: }
