  199: async function withProbeTimeout<T>(promise: Promise<T>, label: string, ms = integrationProbeTimeoutMs): Promise<T> {
  200:   let timer: NodeJS.Timeout | undefined
  201:   try {
  202:     return await Promise.race([
  203:       promise,
  204:       new Promise<T>((_, reject) => {
  205:         timer = setTimeout(() => reject(new Error(`${label} 超时（${Math.round(ms / 1000)} 秒）`)), ms)
  206:       })
  207:     ])
  208:   } finally {
  209:     if (timer) clearTimeout(timer)
  210:   }
  211: }
