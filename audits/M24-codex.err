  285: export default async function adminCapacityCostRoutes(app: FastifyInstance): Promise<void> {
  286:   app.get('/overview', {
  287:     onRequest: [app.authenticate, app.requireAdmin],
  288:     config: { rateLimit: { max: 30, timeWindow: '1 minute' } }
  289:   }, async () => {
  290:     const today = getTodayDateOnly()
  291:     const hosts = await prisma.host.findMany({
  292:       orderBy: { id: 'asc' },
  293:       include: {
  294:         costProfile: true,
  295:         instances: {
  296:           where: { status: { not: 'deleted' } },
  297:           select: { id: true, packagePlanId: true, monthlyTrafficUsed: true }
  298:         },
  299:         packageHosts: {
  300:           include: {
  301:             package: {
  302:               include: {
  303:                 plans: {
  304:                   where: { isActive: true },
  305:                   orderBy: { sortOrder: 'asc' },
  306:                   include: {
  307:                     _count: {
  308:                       select: {
  309:                         instances: { where: { status: { not: 'deleted' } } }
  310:                       }
  311:                     }
  312:                   }
  313:                 }
  314:               }
  315:             }
  316:           }
  317:         }
  318:       }
  319:     })
  320: 
  321:     const hostViews = hosts.map(host => {
  322:       const capacity = buildHostCapacity(host)
  323:       return {
  324:         id: host.id,
  325:         name: host.name,
  326:         location: host.location,
  327:         countryCode: host.countryCode,
  328:         status: host.status,
  329:         instanceType: host.instanceType,
  330:         capacity,
  331:         costProfile: host.costProfile
  332:           ? {
  333:               monthlyCost: toMoney(host.costProfile.monthlyCost),
  334:               ipv4MonthlyCost: toMoney(host.costProfile.ipv4MonthlyCost),
  335:               trafficTbCost: toMoney(host.costProfile.trafficTbCost),
  336:               currency: host.costProfile.currency,
  337:               notes: host.costProfile.notes,
  338:               updatedAt: host.costProfile.updatedAt
  339:             }
  340:           : {
  341:               monthlyCost: 0,
  342:               ipv4MonthlyCost: 0,
  343:               trafficTbCost: 0,
  344:               currency: 'CNY',
  345:               notes: null,
  346:               updatedAt: null
  347:             }
  348:       }
  349:     })
  350: 
  351:     await Promise.all(hostViews.map(host =>
  352:       prisma.capacitySnapshot.upsert({
  353:         where: {
  354:           hostId_capturedDate: {
  355:             hostId: host.id,
  356:             capturedDate: today
  357:           }
  358:         },
  359:         create: {
  360:           hostId: host.id,
  361:           capturedDate: today,
  362:           cpuTotal: host.capacity.cpuTotal,
  363:           cpuUsed: host.capacity.cpuUsed,
  364:           memoryTotal: host.capacity.memoryTotal,
  365:           memoryUsed: host.capacity.memoryUsed,
  366:           diskTotal: host.capacity.diskTotal,
  367:           diskUsed: host.capacity.diskUsed,
  368:           natPortTotal: host.capacity.natPortTotal,
  369:           natPortUsed: host.capacity.natPortUsed,
  370:           instanceCount: host.capacity.instanceCount,
  371:           trafficUsedBytes: BigInt(host.capacity.trafficUsedBytes)
  372:         },
  373:         update: {
  374:           cpuTotal: host.capacity.cpuTotal,
