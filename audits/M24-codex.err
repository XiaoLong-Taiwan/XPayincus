   84: function resetCostForms(data: CapacityCostOverview): void {
   85:   for (const host of data.hosts) {
   86:     costForms[host.id] = {
   87:       monthlyCost: host.costProfile.monthlyCost,
   88:       ipv4MonthlyCost: host.costProfile.ipv4MonthlyCost,
   89:       trafficTbCost: host.costProfile.trafficTbCost,
   90:       notes: host.costProfile.notes || ''
   91:     }
   92:   }
   93: }
   94: 
   95: async function loadOverview(): Promise<void> {
   96:   loading.value = true
   97:   try {
   98:     const data = await api.admin.getCapacityCostOverview()
   99:     overview.value = data
  100:     resetCostForms(data)
  101:   } catch (error: any) {
  102:     toast.error(`加载容量与成本失败：${error?.message || '未知错误'}`)
  103:   } finally {
  104:     loading.value = false
  105:   }
  106: }
  107: 
  108: async function saveCostProfile(host: HostRow): Promise<void> {
  109:   const form = costForms[host.id]
  110:   if (!form) return
  111:   savingHostId.value = host.id
  112:   try {
  113:     await api.admin.updateHostCostProfile(host.id, {
  114:       monthlyCost: form.monthlyCost,
  115:       ipv4MonthlyCost: form.ipv4MonthlyCost,
  116:       trafficTbCost: form.trafficTbCost,
  117:       notes: form.notes || null
  118:     })
  119:     toast.success('成本配置已保存')
  120:     await loadOverview()
  121:   } catch (error: any) {
  122:     toast.error(`保存成本配置失败：${error?.message || '未知错误'}`)
  123:   } finally {
  124:     savingHostId.value = null
  125:   }
  126: }
