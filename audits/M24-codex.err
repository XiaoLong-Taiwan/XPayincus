   29:     routeSource.includes('const normalizedInstanceIds = normalizeBatchInstanceIds(instanceIds)') &&
   30:     routeSource.includes("return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid instance IDs'))"),
   31:   'batch config route must validate host and instance IDs before host lookup or mutation'
   32: )
   33: 
   34: assert.ok(
