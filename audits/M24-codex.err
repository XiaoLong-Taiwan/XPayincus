   19: // 每宿主机并发限制
   20: const BATCH_CONFIG_CONCURRENCY = 10
   21: const POSITIVE_ROUTE_ID_PATTERN = /^[1-9]\d*$/
   22: 
   23: // 可重试的错误类型
   24: const RETRYABLE_ERRORS = [
   25:   'ETIMEDOUT',
   26:   'ECONNREFUSED',
   27:   'ECONNRESET',
   28:   'context deadline exceeded',
   29:   'timeout'
   30: ]
   31: 
   32: function isRetryableError(error: string): boolean {
   33:   return RETRYABLE_ERRORS.some(e => error.toLowerCase().includes(e.toLowerCase()))
   34: }
   35: 
   36: function parsePositiveRouteId(value: string): number | null {
   37:   if (!POSITIVE_ROUTE_ID_PATTERN.test(value)) {
   38:     return null
   39:   }
   40: 
   41:   const parsed = Number(value)
   42:   return Number.isSafeInteger(parsed) ? parsed : null
   43: }
   44: 
   45: function normalizeBatchInstanceIds(instanceIds: number[]): number[] | null {
   46:   if (!Array.isArray(instanceIds) || instanceIds.length === 0) {
   47:     return null
   48:   }
   49: 
   50:   const uniqueIds = new Set<number>()
   51:   for (const instanceId of instanceIds) {
   52:     if (!Number.isSafeInteger(instanceId) || instanceId <= 0 || uniqueIds.has(instanceId)) {
   53:       return null
   54:     }
   55:     uniqueIds.add(instanceId)
   56:   }
   57: 
   58:   return [...uniqueIds]
   59: }
