   36:     routeSource.includes('if (instances.length !== normalizedInstanceIds.length)') &&
   37:     routeSource.includes("return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Some instances are not available on this host'))"),
   38:   'batch config route must require every requested instance to be available on the target host'
   39: )
   40: 
   41: for (const forbiddenPattern of [
   42:   'const hostId = Number(id)',
   43:   'isNaN(hostId)',
   44:   'id: { in: instanceIds }',
   45:   "if (instances.length === 0) {\n      return reply.code(400).send({ error: '没有找到可修改的实例' })"
   46: ]) {
   47:   assert.ok(
   48:     !routeSource.includes(forbiddenPattern),
   49:     `batch config route must not keep loose or partial batch behavior: ${forbiddenPattern}`
   50:   )
   51: }
   52: 
   53: console.log('batch config route guard tests passed')

