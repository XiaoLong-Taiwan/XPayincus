  260:   const endpoint = config.apiVersion === 'v2' ? `${apiBase}/group` : `${apiBase}/profile`
  261:   // 管理员配置的 baseUrl 可能指向内网，探测前做 SSRF 校验，并用连接期再校验的 dispatcher 防 DNS rebinding
  262:   await assertSafeHttpUrl(endpoint, 'Lsky endpoint')
  263:   const response = await fetch(endpoint, {
  264:     method: 'GET',
  265:     redirect: 'manual',
  266:     dispatcher: safeOutboundDispatcher,
  267:     signal: AbortSignal.timeout(15_000),
  268:     headers: {
  269:       Accept: 'application/json',
  270:       Authorization: `Bearer ${config.token}`
  271:     }
  272:   } as RequestInit)
  273: 
  274:   if (!response.ok) {
  275:     return {
  276:       status: 'error' as const,
  277:       message: `Lsky 只读探测失败：HTTP ${response.status}`,
  278:       detail: `${config.apiVersion} / ${hostnameOf(config.baseUrl)}`
  279:     }
  280:   }
  281: 
  282:   return {
  283:     status: 'ok' as const,
  284:     message: 'Lsky API 可访问',
  285:     detail: `${config.apiVersion} / ${hostnameOf(config.baseUrl)}`
  286:   }
  287: }
