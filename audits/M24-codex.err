  560: 
  561:     const body = request.body || {}
  562:     const notes = normalizeNotes(body.notes)
  563:     const data: {
  564:       monthlyCost?: number
  565:       ipv4MonthlyCost?: number
  566:       trafficTbCost?: number
  567:       notes?: string | null
  568:       updatedByUserId: number
  569:     } = {
  570:       updatedByUserId: request.user.id
  571:     }
  572: 
  573:     if (body.monthlyCost !== undefined) data.monthlyCost = normalizeCostInput(body.monthlyCost, '宿主机月成本')
  574:     if (body.ipv4MonthlyCost !== undefined) data.ipv4MonthlyCost = normalizeCostInput(body.ipv4MonthlyCost, 'IPv4 月成本')
  575:     if (body.trafficTbCost !== undefined) data.trafficTbCost = normalizeCostInput(body.trafficTbCost, '每 TB 流量成本')
  576:     if (notes !== undefined) data.notes = notes
  577: 
  578:     const profile = await prisma.hostCostProfile.upsert({
  579:       where: { hostId },
  580:       create: {
  581:         hostId,
  582:         monthlyCost: data.monthlyCost ?? 0,
  583:         ipv4MonthlyCost: data.ipv4MonthlyCost ?? 0,
  584:         trafficTbCost: data.trafficTbCost ?? 0,
  585:         notes: data.notes ?? null,
  586:         updatedByUserId: data.updatedByUserId
  587:       },
  588:       update: data
  589:     })
  590: 
  591:     await createLog(
  592:       request.user.id,
  593:       'capacity',
  594:       'capacity.cost_profile.update',
  595:       `Updated capacity cost profile for host "${host.name}"`,
  596:       'success'
  597:     )
  598: 
  599:     return {
  600:       hostId,
  601:       monthlyCost: toMoney(profile.monthlyCost),
  602:       ipv4MonthlyCost: toMoney(profile.ipv4MonthlyCost),
  603:       trafficTbCost: toMoney(profile.trafficTbCost),
  604:       currency: profile.currency,
  605:       notes: profile.notes,
  606:       updatedAt: profile.updatedAt
  607:     }
  608:   })
  609: }

