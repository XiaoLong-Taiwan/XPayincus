   17: function skipWhitespace(source: string, index: number): number {
   18:   while (index < source.length && /\s/.test(source[index])) index += 1
   19:   return index
   20: }
   21: 
   22: function skipGenericBlock(source: string, index: number): number {
   23:   index = skipWhitespace(source, index)
   24:   if (source[index] !== '<') return index
   25: 
   26:   let depth = 0
   27:   let quote: string | null = null
   28:   for (let i = index; i < source.length; i += 1) {
   29:     const char = source[i]
   30:     const previous = source[i - 1]
   31: 
   32:     if (quote) {
   33:       if (char === quote && previous !== '\\') quote = null
   34:       continue
   35:     }
   36: 
   37:     if (char === '"' || char === "'" || char === '`') {
   38:       quote = char
   39:       continue
   40:     }
   41: 
   42:     if (char === '<') depth += 1
   43:     if (char === '>') {
   44:       depth -= 1
   45:       if (depth === 0) return i + 1
   46:     }
   47:   }
   48: 
   49:   return index
   50: }
   51: 
   52: function findMatching(source: string, index: number, open: string, close: string): number {
   53:   let depth = 0
   54:   let quote: string | null = null
   55: 
   56:   for (let i = index; i < source.length; i += 1) {
   57:     const char = source[i]
   58:     const previous = source[i - 1]
   59: 
   60:     if (quote) {
   61:       if (char === quote && previous !== '\\') quote = null
   62:       continue
   63:     }
   64: 
   65:     if (char === '"' || char === "'" || char === '`') {
   66:       quote = char
   67:       continue
   68:     }
   69: 
   70:     if (char === open) depth += 1
   71:     if (char === close) {
   72:       depth -= 1
   73:       if (depth === 0) return i
   74:     }
   75:   }
   76: 
   77:   return -1
   78: }
   79: 
   80: function splitTopLevelArgs(source: string): string[] {
   81:   const args: string[] = []
   82:   let start = 0
   83:   let parenDepth = 0
   84:   let braceDepth = 0
   85:   let bracketDepth = 0
   86:   let angleDepth = 0
   87:   let quote: string | null = null
   88: 
   89:   for (let i = 0; i < source.length; i += 1) {
   90:     const char = source[i]
   91:     const previous = source[i - 1]
   92: 
   93:     if (quote) {
   94:       if (char === quote && previous !== '\\') quote = null
   95:       continue
   96:     }
   97: 
   98:     if (char === '"' || char === "'" || char === '`') {
   99:       quote = char
  100:       continue
  101:     }
  102: 
  103:     if (char === '(') parenDepth += 1
  104:     else if (char === ')') parenDepth -= 1
  105:     else if (char === '{') braceDepth += 1
  106:     else if (char === '}') braceDepth -= 1
  107:     else if (char === '[') bracketDepth += 1
  108:     else if (char === ']') bracketDepth -= 1
  109:     else if (char === '<') angleDepth += 1
  110:     else if (char === '>') angleDepth = Math.max(0, angleDepth - 1)
  111:     else if (char === ',' && parenDepth === 0 && braceDepth === 0 && bracketDepth === 0 && angleDepth === 0) {
  112:       args.push(source.slice(start, i))
  113:       start = i + 1
  114:     }
  115:   }
  116: 
  117:   args.push(source.slice(start))
  118:   return args
  119: }
  120: 
  121: function readStringLiteral(rawValue: string | undefined): string | null {
  122:   const source = rawValue?.trim()
  123:   if (!source) return null
  124: 
  125:   const quote = source[0]
  126:   if (quote !== '"' && quote !== "'" && quote !== '`') return null
  127: 
  128:   let value = ''
  129:   for (let i = 1; i < source.length; i += 1) {
  130:     if (source[i] === quote && source[i - 1] !== '\\') return value
  131:     value += source[i]
  132:   }
  133: 
  134:   return null
  135: }
  136: 
  137: function matchRouteReceiver(source: string, index: number, method: string): number {
  138:   for (const receiver of ['fastify', 'app']) {
  139:     const prefix = `${receiver}.${method}`
  140:     if (source.slice(index, index + prefix.length) === prefix) {
  141:       return prefix.length
  142:     }
  143:   }
  144:   return 0
  145: }
  146: 
  147: function collectRoutes(): RouteInfo[] {
  148:   const files = readdirSync(routesDir)
  149:     .filter(file => file.endsWith('.ts'))
  150:     .sort()
  151:   const routes: RouteInfo[] = []
  152: 
  153:   for (const file of files) {
  154:     const source = readFileSync(join(routesDir, file), 'utf8')
  155:     const fileHasAuthenticateHook = /addHook\(\s*['"]onRequest['"]\s*,\s*(fastify|app)\.authenticate\b/.test(source)
  156: 
  157:     for (let index = 0; index < source.length; index += 1) {
  158:       for (const method of routeMethods) {
  159:         const receiverLength = matchRouteReceiver(source, index, method)
  160:         if (receiverLength === 0) continue
  161: 
  162:         let cursor = skipGenericBlock(source, index + receiverLength)
  163:         cursor = skipWhitespace(source, cursor)
  164:         if (source[cursor] !== '(') continue
  165: 
  166:         const callEnd = findMatching(source, cursor, '(', ')')
  167:         if (callEnd < 0) continue
  168: 
  169:         const args = splitTopLevelArgs(source.slice(cursor + 1, callEnd))
  170:         const routePath = readStringLiteral(args[0])
  171:         if (!routePath) {
  172:           index = callEnd
  173:           break
  174:         }
  175: 
  176:         routes.push({
  177:           file,
  178:           line: source.slice(0, index).split('\n').length,
  179:           method: method.toUpperCase(),
  180:           path: routePath,
  181:           options: args[1] ?? '',
  182:           handler: args.slice(1).join('\n'),
  183:           fileHasAuthenticateHook
  184:         })
  185: 
  186:         index = callEnd
  187:         break
  188:       }
  189:     }
  190:   }
  191: 
  192:   return routes
  193: }
