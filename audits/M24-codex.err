  195: function hasAdminGuard(route: RouteInfo): boolean {
  196:   if (/authenticateAdmin|requireAdmin/.test(route.options)) {
  197:     return true
  198:   }
  199: 
  200:   return hasRouteProtection(route) && hasInlineAdminOnlyCheck(route)
  201: }
