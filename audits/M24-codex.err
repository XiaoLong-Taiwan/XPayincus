  215:         id: { in: normalizedInstanceIds },
  216:         hostId: hostId,
  217:         status: { notIn: ['deleted', 'creating'] }
  218:       },
  219:       include: {
  220:         package: {
  221:           select: {
  222:             instanceType: true
  223:           }
  224:         },
  225:         packagePlan: {
  226:           select: {
  227:             swapSize: true
  228:           }
  229:         }
  230:       }
  231:     })
  232: 
  233:     if (instances.length !== normalizedInstanceIds.length) {
  234:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Some instances are not available on this host'))
  235:     }
  236: 
  237:     // 判断是否需要连接 Incus
  238:     const needsIncus = hasIncusConfig(config)
  239:     let client = null
  240: 
  241:     if (needsIncus) {
  242:       try {
  243:         client = await getIncusClient(host)
  244:       } catch (err) {
  245:         const errorMessage = err instanceof Error ? err.message : String(err)
  246:         return reply.code(503).send({ error: `无法连接到宿主机: ${errorMessage}` })
  247:       }
  248:     }
  249: 
  250:     // 使用并发控制处理实例
  251:     const limit = pLimit(BATCH_CONFIG_CONCURRENCY)
  252:     const results: ResultItem[] = []
  253:     
  254:     // 跟踪资源变化量（用于批量完成后统一更新）
  255:     let totalCpuDelta = 0
  256:     let totalMemoryDelta = 0
  257:     let totalDiskDelta = 0
  258: 
  259:     await Promise.all(
  260:       instances.map(instance =>
  261:         limit(async () => {
  262:           const result = await updateSingleInstance(
  263:             instance,
  264:             config,
  265:             parsedMonthlyTrafficLimit,
  266:             client
  267:           )
  268:           results.push(result)
  269:           
  270:           // 累计资源变化量
  271:           if (result.success) {
  272:             if (config.cpu !== undefined) totalCpuDelta += config.cpu - instance.cpu
  273:             if (config.memory !== undefined) totalMemoryDelta += config.memory - instance.memory
  274:             if (config.disk !== undefined) totalDiskDelta += Math.round(config.disk) - instance.disk
  275:           }
  276: 
  277:           // 如果是可重试错误，自动重试一次
  278:           if (!result.success && result.error && isRetryableError(result.error)) {
  279:             console.log(`[BatchConfig] Retrying instance ${instance.name} due to: ${result.error}`)
  280:             const retryResult = await updateSingleInstance(
  281:               instance,
  282:               config,
  283:               parsedMonthlyTrafficLimit,
  284:               client
  285:             )
  286:             // 更新结果
  287:             const idx = results.findIndex(r => r.instanceId === instance.id)
  288:             if (idx >= 0) {
  289:               // 如果重试成功，累计资源变化量
  290:               if (!results[idx].success && retryResult.success) {
  291:                 if (config.cpu !== undefined) totalCpuDelta += config.cpu - instance.cpu
  292:                 if (config.memory !== undefined) totalMemoryDelta += config.memory - instance.memory
  293:                 if (config.disk !== undefined) totalDiskDelta += Math.round(config.disk) - instance.disk
  294:               }
  295:               results[idx] = retryResult
  296:             }
  297:           }
  298:         })
  299:       )
  300:     )
  301:     
  302:     // 批量完成后，统一更新宿主机资源使用量（避免并发问题）
  303:     if (totalCpuDelta !== 0 || totalMemoryDelta !== 0 || totalDiskDelta !== 0) {
  304:       await db.updateHostResources(hostId, {
  305:         cpuUsed: host.cpu_used + totalCpuDelta,
  306:         memoryUsed: host.memory_used + totalMemoryDelta,
  307:         diskUsed: host.disk_used + totalDiskDelta
  308:       })
  309:     }
  310: 
  311:     const successCount = results.filter(r => r.success).length
  312:     const failedCount = results.filter(r => !r.success).length
  313:     const failedItems = results.filter(r => !r.success)
  314: 
  315:     // 记录操作日志
  316:     await createLog(
  317:       user.id,
  318:       'instance',
  319:       'instance.batch_config',
  320:       `Batch updated ${successCount} instances config on host "${host.name}", failed: ${failedCount}`,
  321:       failedCount > 0 ? 'partial' : 'success'
  322:     )
  323: 
  324:     return {
  325:       success: failedCount === 0,
  326:       totalCount: instances.length,
  327:       successCount,
  328:       failedCount,
  329:       failedItems,
  330:       // 用于重试
  331:       retryPayload: failedCount > 0 ? {
  332:         instanceIds: failedItems.map(i => i.instanceId),
  333:         config
  334:       } : undefined
  335:     }
  336:   })
  337: }
  338: 
  339: /**
  340:  * 判断配置是否需要同步到 Incus
  341:  */
  342: function hasIncusConfig(config: BatchConfigBody['config']): boolean {
  343:   const incusFields = [
  344:     'cpu', 'memory', 'disk',
  345:     'swapEnabled', 'swapSize',
  346:     'nested', 'privileged',
  347:     'limitsRead', 'limitsWrite', 'limitsReadIops', 'limitsWriteIops',
  348:     'limitsIngress', 'limitsEgress', 'limitsProcesses', 'limitsCpuPriority',
  349:     'bootAutostart', 'bootAutostartPriority', 'bootAutostartDelay', 'bootHostShutdownTimeout'
  350:   ]
  351:   return incusFields.some(field => config[field as keyof typeof config] !== undefined)
  352: }
  353: 
  354: /**
  355:  * 更新单个实例配置
  356:  */
  357: async function updateSingleInstance(
  358:   instance: {
  359:     id: number
  360:     incusId: string
  361:     name: string
  362:     cpu: number
  363:     memory: number
  364:     disk: number
  365:     hostId: number
  366:     swapEnabled: boolean
  367:     swapSize: number | null
  368:     package: {
  369:       instanceType: string
  370:     } | null
  371:     packagePlan: {
  372:       swapSize: number
  373:     } | null
  374:   },
  375:   config: BatchConfigBody['config'],
  376:   parsedMonthlyTrafficLimit: bigint | null | undefined,
  377:   client: Awaited<ReturnType<typeof getIncusClient>> | null
  378: ): Promise<ResultItem> {
  379:   try {
  380:     const exchangeLock = await getExchangeOperationLock(instance.id)
  381:     if (exchangeLock.locked) {
  382:       throw new Error(exchangeLock.message || '实例已上架交易所或处于交易锁定中，不能批量修改配置')
  383:     }
  384: 
  385:     const activeTask = await getActiveTaskForInstance(instance.id)
  386:     if (activeTask) {
  387:       throw new Error(`实例存在进行中的任务: ${activeTask.taskType}`)
  388:     }
  389: 
  390:     const hasSwapConfig = config.swapEnabled !== undefined || config.swapSize !== undefined
  391:     const instanceKind = instance.package?.instanceType === 'vm' ? 'vm' : 'container'
  392:     const currentSwapSize = resolveEffectiveSwapSize(instance.swapSize, instance.packagePlan?.swapSize)
  393:     const nextSwapEnabled = config.swapEnabled ?? instance.swapEnabled
  394:     const nextSwapSize = config.swapSize !== undefined
  395:       ? Math.max(0, config.swapSize ?? 0)
  396:       : currentSwapSize
  397:     const storageOverrides = resolveStorageOverrides(config)
  398: 
  399:     if (hasSwapConfig && instanceKind === 'vm') {
  400:       throw new Error('虚拟机不支持批量 SWAP 配置')
  401:     }
  402: 
  403:     if (nextSwapEnabled && nextSwapSize <= 0) {
  404:       throw new Error('启用 SWAP 前需要设置大于 0 的 SWAP 大小')
  405:     }
  406: 
  407:     // 1. 更新资源配置（CPU、内存、磁盘）到 Incus
  408:     if (client && (config.cpu !== undefined || config.memory !== undefined || config.disk !== undefined)) {
  409:       await patchInstanceResources(client, instance.incusId, {
  410:         cpu: config.cpu,
  411:         memory: config.memory,
  412:         disk: config.disk !== undefined ? Math.round(config.disk) : undefined
  413:       })
  414:     }
  415: 
  416:     // 2. 更新高级配置到 Incus
  417:     if (client && (hasAdvancedIncusConfig(config) || hasSwapConfig)) {
  418:       const incusConfig: Record<string, string | null> = {}
  419:       const needsDeviceConfig =
  420:         config.limitsRead !== undefined || config.limitsReadIops !== undefined ||
  421:         config.limitsWrite !== undefined || config.limitsWriteIops !== undefined ||
  422:         config.limitsIngress !== undefined || config.limitsEgress !== undefined
  423:       let incusDevices: Record<string, Record<string, string>> | null = null
  424: 
  425:       if (hasSwapConfig) {
  426:         incusConfig['limits.memory.swap'] = resolveIncusSwapValue(nextSwapEnabled, nextSwapSize)
  427:       }
  428: 
  429:       // 容器权限
  430:       if (config.nested !== undefined) {
  431:         incusConfig['security.nesting'] = config.nested ? 'true' : 'false'
  432:       }
  433:       if (config.privileged !== undefined) {
  434:         incusConfig['security.privileged'] = config.privileged ? 'true' : 'false'
  435:       }
  436: 
  437:       // 进程限制
  438:       if (config.limitsProcesses !== undefined && config.limitsProcesses !== null) {
  439:         incusConfig['limits.processes'] = String(config.limitsProcesses)
  440:       } else if (config.limitsProcesses !== undefined) {
  441:         incusConfig['limits.processes'] = null
  442:       }
  443: 
  444:       // CPU 优先级直接使用 Incus 原生 0-10 语义
  445:       if (config.limitsCpuPriority !== undefined && config.limitsCpuPriority !== null) {
  446:         incusConfig['limits.cpu.priority'] = String(config.limitsCpuPriority)
  447:       } else if (config.limitsCpuPriority !== undefined) {
  448:         incusConfig['limits.cpu.priority'] = null
  449:       }
  450: 
  451:       // 启动设置
  452:       if (config.bootAutostart !== undefined && config.bootAutostart !== null) {
  453:         incusConfig['boot.autostart'] = config.bootAutostart ? 'true' : 'false'
  454:       } else if (config.bootAutostart !== undefined) {
  455:         incusConfig['boot.autostart'] = null
  456:       }
  457:       if (config.bootAutostartPriority !== undefined && config.bootAutostartPriority !== null) {
  458:         incusConfig['boot.autostart.priority'] = String(config.bootAutostartPriority)
  459:       } else if (config.bootAutostartPriority !== undefined) {
  460:         incusConfig['boot.autostart.priority'] = null
  461:       }
  462:       if (config.bootAutostartDelay !== undefined && config.bootAutostartDelay !== null) {
  463:         incusConfig['boot.autostart.delay'] = String(config.bootAutostartDelay)
  464:       } else if (config.bootAutostartDelay !== undefined) {
  465:         incusConfig['boot.autostart.delay'] = null
  466:       }
  467:       if (config.bootHostShutdownTimeout !== undefined && config.bootHostShutdownTimeout !== null) {
  468:         incusConfig['boot.host_shutdown_timeout'] = String(config.bootHostShutdownTimeout)
  469:       } else if (config.bootHostShutdownTimeout !== undefined) {
  470:         incusConfig['boot.host_shutdown_timeout'] = null
  471:       }
  472: 
  473:       if (needsDeviceConfig) {
  474:         // 复制完整的设备列表，然后修改需要修改的设备
  475:         const currentInstance = await getInstance(client, instance.incusId) as {
  476:           devices?: Record<string, Record<string, string>>
  477:         }
  478:         incusDevices = currentInstance.devices ? JSON.parse(JSON.stringify(currentInstance.devices)) : {}
  479:       }
  480: 
  481:       // 存储 I/O 限制 (应用到 root 设备)
  482:       if (config.limitsRead !== undefined || config.limitsReadIops !== undefined ||
  483:         config.limitsWrite !== undefined || config.limitsWriteIops !== undefined) {
  484:         if (!incusDevices) {
  485:           incusDevices = {}
  486:         }
  487:         if (!incusDevices['root']) {
  488:           incusDevices['root'] = { path: '/', pool: 'default', type: 'disk' }
  489:         }
  490: 
  491:         if (config.limitsRead !== undefined) {
  492:           if (config.limitsRead !== null) {
  493:             incusDevices['root']['limits.read'] = config.limitsRead
  494:           } else {
  495:             delete incusDevices['root']['limits.read']
  496:           }
  497:         } else if (config.limitsReadIops !== undefined) {
  498:           if (config.limitsReadIops !== null) {
  499:             incusDevices['root']['limits.read'] = `${config.limitsReadIops}iops`
  500:           } else {
  501:             delete incusDevices['root']['limits.read']
  502:           }
  503:         }
  504: 
  505:         if (config.limitsWrite !== undefined) {
  506:           if (config.limitsWrite !== null) {
  507:             incusDevices['root']['limits.write'] = config.limitsWrite
  508:           } else {
  509:             delete incusDevices['root']['limits.write']
  510:           }
  511:         } else if (config.limitsWriteIops !== undefined) {
  512:           if (config.limitsWriteIops !== null) {
  513:             incusDevices['root']['limits.write'] = `${config.limitsWriteIops}iops`
  514:           } else {
  515:             delete incusDevices['root']['limits.write']
  516:           }
  517:         }
  518:       }
  519: 
  520:       // 网络限制 (应用到 eth0 设备)
  521:       if (config.limitsIngress !== undefined || config.limitsEgress !== undefined) {
  522:         // 确保 eth0 设备存在
  523:         if (!incusDevices) {
  524:           incusDevices = {}
  525:         }
  526:         if (!incusDevices['eth0']) {
  527:           incusDevices['eth0'] = {
  528:             type: 'nic',
  529:             name: 'eth0',
  530:             network: 'incusbr0'
  531:           }
  532:         }
  533: 
  534:         if (config.limitsIngress !== undefined) {
  535:           if (config.limitsIngress !== null) {
  536:             incusDevices['eth0']['limits.ingress'] = config.limitsIngress
  537:           } else {
  538:             delete incusDevices['eth0']['limits.ingress']
  539:           }
  540:         }
  541: 
  542:         if (config.limitsEgress !== undefined) {
  543:           if (config.limitsEgress !== null) {
  544:             incusDevices['eth0']['limits.egress'] = config.limitsEgress
  545:           } else {
  546:             delete incusDevices['eth0']['limits.egress']
  547:           }
  548:         }
  549:       }
  550: 
  551:       // 应用更新到 Incus
  552:       const updates: Record<string, unknown> = {}
  553:       if (Object.keys(incusConfig).length > 0) {
  554:         updates.config = incusConfig
  555:       }
  556:       if (incusDevices && Object.keys(incusDevices).length > 0) {
  557:         updates.devices = incusDevices
  558:       }
  559: 
  560:       if (Object.keys(updates).length > 0) {
  561:         await updateInstance(client, instance.incusId, updates)
  562:       }
  563:     }
  564: 
  565:     // 3. 更新数据库中的资源配置
  566:     if (config.cpu !== undefined || config.memory !== undefined || config.disk !== undefined || config.monthlyTrafficLimit !== undefined) {
  567:       await db.updateInstanceResources(instance.id, {
  568:         cpu: config.cpu,
  569:         memory: config.memory,
  570:         disk: config.disk !== undefined ? Math.round(config.disk) : undefined,
  571:         monthlyTrafficLimit: parsedMonthlyTrafficLimit
  572:       })
  573:       // 注意：宿主机资源使用量在批量处理完成后统一更新，避免并发问题
  574:     }
  575: 
  576:     // 4. 更新数据库中的配额限制
  577:     if (config.portLimit !== undefined || config.snapshotLimit !== undefined ||
  578:         config.backupLimit !== undefined || config.siteLimit !== undefined) {
  579:       await db.updateInstanceQuota(instance.id, {
  580:         portLimit: config.portLimit,
  581:         snapshotLimit: config.snapshotLimit,
  582:         backupLimit: config.backupLimit,
  583:         siteLimit: config.siteLimit
  584:       })
  585:     }
  586: 
  587:     // 5. 更新数据库中的 SWAP 配置
  588:     if (hasSwapConfig) {
  589:       const swapUpdate: {
  590:         swapEnabled?: boolean
  591:         swapSize?: number | null
  592:       } = {}
  593: 
  594:       if (config.swapEnabled !== undefined) {
  595:         swapUpdate.swapEnabled = config.swapEnabled
  596:       }
  597:       if (config.swapSize !== undefined) {
  598:         swapUpdate.swapSize = config.swapSize
  599:       } else if (config.swapEnabled === true) {
  600:         swapUpdate.swapSize = nextSwapSize
  601:       }
  602: 
  603:       await db.updateInstanceSwap(instance.id, swapUpdate)
  604:     }
  605: 
  606:     // 6. 更新数据库中的高级配置
  607:     if (hasDbAdvancedConfig(config)) {
  608:       await db.updateInstanceConfig(instance.id, {
  609:         limitsRead: storageOverrides.limitsRead,
  610:         limitsWrite: storageOverrides.limitsWrite,
  611:         limitsReadIops: storageOverrides.limitsReadIops,
  612:         limitsWriteIops: storageOverrides.limitsWriteIops,
  613:         limitsIngress: config.limitsIngress,
  614:         limitsEgress: config.limitsEgress,
  615:         limitsProcesses: config.limitsProcesses,
  616:         limitsCpuPriority: config.limitsCpuPriority,
  617:         bootAutostart: config.bootAutostart,
  618:         bootAutostartPriority: config.bootAutostartPriority,
  619:         bootAutostartDelay: config.bootAutostartDelay,
  620:         bootHostShutdownTimeout: config.bootHostShutdownTimeout
  621:       })
  622:     }
  623: 
  624:     return {
  625:       instanceId: instance.id,
  626:       incusId: instance.incusId,
  627:       name: instance.name,
  628:       success: true
  629:     }
  630:   } catch (err) {
  631:     const errorMessage = err instanceof Error ? err.message : String(err)
  632:     console.error(`[BatchConfig] Failed to update instance ${instance.name}:`, errorMessage)
  633:     return {
  634:       instanceId: instance.id,
  635:       incusId: instance.incusId,
  636:       name: instance.name,
  637:       success: false,
  638:       error: errorMessage
  639:     }
  640:   }
  641: }
  642: 
  643: /**
  644:  * 判断是否有需要同步到 Incus 的高级配置
  645:  */
  646: function hasAdvancedIncusConfig(config: BatchConfigBody['config']): boolean {
  647:   const advancedFields = [
  648:     'nested', 'privileged',
  649:     'limitsRead', 'limitsWrite', 'limitsReadIops', 'limitsWriteIops',
  650:     'limitsIngress', 'limitsEgress', 'limitsProcesses', 'limitsCpuPriority',
  651:     'bootAutostart', 'bootAutostartPriority', 'bootAutostartDelay', 'bootHostShutdownTimeout'
  652:   ]
  653:   return advancedFields.some(field => config[field as keyof typeof config] !== undefined)
  654: }
  655: 
  656: /**
  657:  * 判断是否有需要存储到数据库的高级配置
  658:  */
  659: function hasDbAdvancedConfig(config: BatchConfigBody['config']): boolean {
  660:   const dbFields = [
  661:     'limitsRead', 'limitsWrite', 'limitsReadIops', 'limitsWriteIops',
  662:     'limitsIngress', 'limitsEgress', 'limitsProcesses', 'limitsCpuPriority',
  663:     'bootAutostart', 'bootAutostartPriority', 'bootAutostartDelay', 'bootHostShutdownTimeout'
  664:   ]
  665:   return dbFields.some(field => config[field as keyof typeof config] !== undefined)
  666: }
  667: 
  668: function resolveStorageOverrides(config: BatchConfigBody['config']): ResolvedStorageOverrides {
  669:   const overrides: ResolvedStorageOverrides = {}
  670: 
  671:   if (config.limitsRead !== undefined) {
  672:     overrides.limitsRead = config.limitsRead
  673:     overrides.limitsReadIops = null
  674:   } else if (config.limitsReadIops !== undefined) {
  675:     overrides.limitsRead = null
  676:     overrides.limitsReadIops = config.limitsReadIops
  677:   }
  678: 
  679:   if (config.limitsWrite !== undefined) {
  680:     overrides.limitsWrite = config.limitsWrite
  681:     overrides.limitsWriteIops = null
  682:   } else if (config.limitsWriteIops !== undefined) {
  683:     overrides.limitsWrite = null
  684:     overrides.limitsWriteIops = config.limitsWriteIops
  685:   }
  686: 
  687:   return overrides
  688: }

