  409: async function checkHostAgent() {
  410:   const hosts = await prisma.host.findMany({
  411:     select: {
  412:       id: true,
  413:       name: true,
  414:       status: true,
  415:       isInstalled: true,
  416:       agent: {
  417:         select: {
  418:           enabled: true,
  419:           status: true,
  420:           version: true,
  421:           lastSeenAt: true
  422:         }
  423:       }
  424:     },
  425:     orderBy: { id: 'asc' }
  426:   })
  427:   const installedHosts = hosts.filter(host => host.isInstalled)
  428:   if (hosts.length === 0) {
  429:     return { status: 'skipped' as const, message: '暂无节点' }
  430:   }
  431:   if (installedHosts.length === 0) {
  432:     return { status: 'warning' as const, message: '暂无已安装节点' }
  433:   }
  434: 
  435:   const missingAgent = installedHosts.filter(host => !host.agent)
  436:   const enabledAgents = installedHosts.filter(host => host.agent?.enabled)
  437:   const now = Date.now()
  438:   const offlineAgents = enabledAgents.filter(host => {
  439:     const agent = host.agent
  440:     if (!agent) return true
  441:     if (agent.status !== 'online') return true
  442:     if (!agent.lastSeenAt) return true
  443:     return now - agent.lastSeenAt.getTime() > hostAgentOfflineThresholdMs
  444:   })
  445: 
  446:   if (missingAgent.length > 0 || offlineAgents.length > 0) {
  447:     return {
  448:       status: 'warning' as const,
  449:       message: `Agent 需要复核：缺失 ${missingAgent.length} 台，离线/过期 ${offlineAgents.length} 台`,
  450:       detail: [...missingAgent, ...offlineAgents]
  451:         .slice(0, 5)
  452:         .map(host => `${host.name}(${host.agent?.status || 'missing'} / ${formatAge(host.agent?.lastSeenAt)})`)
  453:         .join(', ')
  454:     }
  455:   }
  456: 
  457:   return {
  458:     status: 'ok' as const,
  459:     message: `Agent 心跳正常：${enabledAgents.length}/${installedHosts.length} 台已安装节点在线`,
  460:     detail: enabledAgents
  461:       .slice(0, 5)
  462:       .map(host => `${host.name} ${host.agent?.version || 'unknown'} / ${formatAge(host.agent?.lastSeenAt)}`)
  463:       .join(', ')
  464:   }
  465: }
