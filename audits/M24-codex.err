  145: function parsePositiveInteger(value: string | undefined, fallback: number): number {
  146:   if (!value || !POSITIVE_ROUTE_ID_PATTERN.test(value)) return fallback
  147:   const parsed = Number(value)
  148:   return Number.isSafeInteger(parsed) ? parsed : fallback
  149: }
  150: 
  151: function normalizePageSize(value: string | undefined): number {
  152:   return Math.min(parsePositiveInteger(value, DEFAULT_PAGE_SIZE), MAX_PAGE_SIZE)
  153: }
  154: 
  155: function normalizeSearch(value: string | undefined): string | undefined {
  156:   const search = value?.trim()
  157:   return search ? search.slice(0, SEARCH_MAX_LENGTH) : undefined
  158: }
  159: 
  160: function normalizeNote(value: unknown): string | null {
  161:   if (value === undefined || value === null) return null
  162:   if (typeof value !== 'string') throw new Error('备注必须是字符串')
  163:   const note = sanitizeTokensInString(value.trim())
  164:   if (note.length > NOTE_MAX_LENGTH) throw new Error(`备注不能超过 ${NOTE_MAX_LENGTH} 字符`)
  165:   return note || null
  166: }
  167: 
  168: function normalizeStatus(value: string | undefined): SlaAlertStatus | undefined {
  169:   if (!value || value === 'all') return undefined
  170:   return ALERT_STATUSES.has(value as SlaAlertStatus) ? value as SlaAlertStatus : undefined
  171: }
  172: 
  173: function normalizeSeverity(value: string | undefined): SlaAlertSeverity | undefined {
  174:   if (!value || value === 'all') return undefined
  175:   return ALERT_SEVERITIES.has(value as SlaAlertSeverity) ? value as SlaAlertSeverity : undefined
  176: }
