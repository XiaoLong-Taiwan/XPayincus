  279: async function addAlertAction(
  280:   eventId: number,
  281:   actionType: SlaAlertActionType,
  282:   actor: { id?: number | null; username?: string | null } | null,
  283:   note?: string | null,
  284:   detail?: Prisma.InputJsonValue
  285: ) {
