  567: function getAlertWhere(query: AlertQuery): Prisma.SlaAlertEventWhereInput {
  568:   const status = normalizeStatus(query.status)
  569:   const severity = normalizeSeverity(query.severity)
  570:   const module = query.module?.trim()
  571:   const search = normalizeSearch(query.search)
  572:   const where: Prisma.SlaAlertEventWhereInput = {}
  573: 
  574:   if (status) where.status = status
  575:   if (severity) where.severity = severity
  576:   if (module && module !== 'all') where.module = module.slice(0, 50)
  577:   if (search) {
  578:     const numericId = POSITIVE_ROUTE_ID_PATTERN.test(search) ? Number(search) : null
  579:     where.OR = [
  580:       ...(numericId && Number.isSafeInteger(numericId) ? [{ id: numericId }, { objectId: numericId }] : []),
  581:       { title: { contains: search, mode: 'insensitive' } },
  582:       { message: { contains: search, mode: 'insensitive' } },
  583:       { objectLabel: { contains: search, mode: 'insensitive' } },
  584:       { ruleCode: { contains: search, mode: 'insensitive' } }
  585:     ]
  586:   }
  587: 
  588:   return where
  589: }
