  140:                         await prisma.snapshot.delete({ where: { id: snapshotToDelete.id } })
  141:                         deletedSnapshotName = snapshotToDelete.name
  142:                         console.log(`[AutoPolicy] Deleted old snapshot to make room: ${snapshotToDelete.name}`)
  143:                     } catch (delErr) {
