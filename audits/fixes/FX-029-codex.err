 480:  * 概率值按实际设定值计算，不足100%的部分自动归入"谢谢参与"
 481:  * 
 482:  * 关键设计：遍历所有奖品计算概率区间，而不是只遍历available
 483:  * 这样即使某奖品库存耗尽，其概率区间也被保留，命中该区间时回退到nothing
 484:  */
 485: export function weightedRandomSelect(prizes: Array<{
 486:   id: number
 487:   type: LotteryPrizeType
 488:   probability: number | Prisma.Decimal
 489:   remainQuantity: number | null
 490: }>) {
 491:   // 找到"谢谢参与"奖品（作为兜底）
 492:   const nothingPrize = prizes.find(p => p.type === 'nothing')
 493:   
 494:   // 检查是否有任何可用奖品
 495:   const hasAvailable = prizes.some(p =>
 496:     p.remainQuantity === null || p.remainQuantity > 0
 497:   )
 498:   if (!hasAvailable) {
 499:     throw new Error('NO_AVAILABLE_PRIZES')
 500:   }
 501: 
 502:   // 使用绝对概率（基于100%）
 503:   const random = Math.random() * 100
 504:   let cumulative = 0
 505: 
 506:   // 遍历所有奖品（包括已抽完的），保持概率区间不变
 507:   for (const prize of prizes) {
 508:     cumulative += Number(prize.probability)
 509:     if (random < cumulative) {
 510:       // 检查该奖品是否有库存
 511:       if (prize.remainQuantity === null || prize.remainQuantity > 0) {
 512:         return prize
 513:       }
 514:       // 库存已空，回退到"谢谢参与"
 515:       if (nothingPrize) return nothingPrize
 516:       // 如果没有nothing奖品，继续检查下一个
 517:     }
 518:   }

