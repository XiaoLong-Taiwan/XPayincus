 399:       type: LotteryPrizeType
 400:       value?: number
 401:       probability: number
 402:       totalQuantity?: number
 403:       displayOrder?: number
 404:       instanceDesc?: string
 405:     }
 406:   }>('/lotteries/:id/prizes', {
 407:     onRequest: [fastify.authenticate, fastify.requireAdmin]
 408:   }, async (request: FastifyRequest<{
 409:     Params: { id: string }
 410:     Body: {
 411:       name: string
 412:       type: LotteryPrizeType
 413:       value?: number
 414:       probability: number
 415:       totalQuantity?: number
 416:       displayOrder?: number
 417:       instanceDesc?: string
 418:     }
 419:   }>, reply: FastifyReply) => {
 420:     const lotteryId = parsePositiveRouteId(request.params.id)
 421: 
 422:     if (!lotteryId) {
 423:       return reply.code(400).send({ error: 'INVALID_ID', message: 'Invalid lottery ID' })
 424:     }
 425: 
 426:     const lottery = await db.getLotteryById(lotteryId)
 427:     if (!lottery) {
 428:       return reply.code(404).send({ error: 'NOT_FOUND', message: 'Lottery not found' })
 429:     }
 430: 
 431:     const { name, type, value, probability, totalQuantity, displayOrder, instanceDesc } = request.body
 432:     const prizeType = parseLotteryPrizeType(type)
 433:     const parsedProbability = parseOptionalFiniteNumber(probability)
 434:     const parsedValue = value === undefined ? undefined : parseIntegerBody(value)
 435:     const parsedTotalQuantity = totalQuantity === undefined ? undefined : parseOptionalPositiveBodyId(totalQuantity)
 436:     const parsedDisplayOrder = parseOptionalIntegerBody(displayOrder, 0)
 437: 
 438:     if (!name || typeof name !== 'string') {
 439:       return reply.code(400).send({ error: 'NAME_REQUIRED', message: 'Prize name is required' })
 440:     }
 441: 
 442:     if (!prizeType) {
 443:       return reply.code(400).send({ error: 'INVALID_PRIZE_TYPE', message: 'Invalid prize type' })
 444:     }
 445: 
 446:     if (parsedProbability === null || parsedProbability === undefined || parsedProbability < 0 || parsedProbability > 100) {
 447:       return reply.code(400).send({ error: 'INVALID_PROBABILITY', message: 'Probability must be between 0 and 100' })
 448:     }
 449: 
 450:     // 只有 balance 和 instance 类型可以设置总数量，points 和 nothing 类型不能设置数量
 451:     if ((prizeType === 'points' || prizeType === 'nothing') && parsedTotalQuantity !== undefined && parsedTotalQuantity !== null) {
 452:       return reply.code(400).send({ 
 453:         error: 'INVALID_QUANTITY', 
 454:         message: 'Points and nothing prizes cannot have quantity limits' 
 455:       })
 456:     }
 457: 
 458:     if (parsedTotalQuantity === null) {
 459:       return reply.code(400).send({ error: 'INVALID_QUANTITY', message: 'Quantity must be a positive integer' })
 460:     }
 461: 
 462:     if (prizeType !== 'badge' && prizeType !== 'nothing' && prizeType !== 'instance' && (parsedValue === null || parsedValue === undefined || parsedValue < 0)) {
 463:       return reply.code(400).send({ error: 'INVALID_VALUE', message: 'Prize value must be a non-negative integer' })
 464:     }
 465: 
 466:     const prize = await db.createPrize({
 467:       lotteryId,
 468:       name: name.trim(),
 469:       type: prizeType,
 470:       value: prizeType === 'badge' || prizeType === 'nothing' || prizeType === 'instance' ? 0 : parsedValue ?? 0,
 471:       probability: parsedProbability,
 472:       totalQuantity: parsedTotalQuantity,
 473:       displayOrder: parsedDisplayOrder,
 474:       instanceDesc: instanceDesc?.trim()
 475:     })
 476: 
 477:     await createLog(
 478:       request.user.id,
 479:       'admin',
 480:       'lottery.prize.create',
 481:       `Added prize "${prize.name}" to lottery "${lottery.name}"`,
 482:       'success'
 483:     )
 484: 
 485:     return { success: true, prize: { id: prize.id, name: prize.name } }
 486:   })
