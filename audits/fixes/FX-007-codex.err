   38: function parsePositiveId(value: string): number | null {
   39:   const id = Number(value)
   40:   return Number.isSafeInteger(id) && id > 0 ? id : null
   41: }
   42: 
   43: async function canManageSystemUpdates(user: { id: number; username: string; role: 'admin' | 'user' }): Promise<boolean> {
   44:   if (user.role !== 'admin') return false
   45:   const { ids: allowedIds } = await getCombinedAdminIdAllowlist(
   46:     'system_update_allowed_admin_ids',
   47:     'SYSTEM_UPDATE_ALLOWED_ADMIN_IDS'
   48:   )
   49:   if (allowedIds.size > 0) {
   50:     return allowedIds.has(user.id)
   51:   }
   52:   return user.username === 'admin'
   53: }
