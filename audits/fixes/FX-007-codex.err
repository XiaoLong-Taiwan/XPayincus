   52: function getEmailDomainForAudit(email: string): string {
   53:     const domain = email.split('@').pop()?.trim().toLowerCase() || 'unknown'
   54:     return domain.replace(/[^a-z0-9.-]/g, '').slice(0, 120) || 'unknown'
   55: }
   56: 
   57: function isHttpImageUrl(value: string): boolean {
   58:     try {
   59:         const imageUrl = new URL(value)
   60:         return ['http:', 'https:'].includes(imageUrl.protocol)
   61:     } catch {
   62:         return false
   63:     }
   64: }
   65: 
   66: function parsePositiveConfigInteger(value: string, max = Number.MAX_SAFE_INTEGER): number | null {
   67:     const trimmed = value.trim()
   68:     if (!positiveIntegerConfigPattern.test(trimmed)) return null
   69:     const parsed = Number(trimmed)
   70:     return Number.isSafeInteger(parsed) && parsed <= max ? parsed : null
   71: }
   72: 
   73: function parseNonNegativeConfigInteger(value: string, max = Number.MAX_SAFE_INTEGER): number | null {
   74:     const trimmed = value.trim()
   75:     if (!nonNegativeIntegerConfigPattern.test(trimmed)) return null
   76:     const parsed = Number(trimmed)
   77:     return Number.isSafeInteger(parsed) && parsed <= max ? parsed : null
   78: }
   79: 
   80: function parseDecimalMoneyConfig(value: string, max: number): number | null {
   81:     const trimmed = value.trim()
   82:     if (!decimalMoneyPattern.test(trimmed)) return null
   83:     const parsed = Number(trimmed)
   84:     return Number.isFinite(parsed) && parsed >= 0 && parsed <= max ? parsed : null
   85: }
   86: 
   87: function normalizeAdminIdCsv(value: string): string | null {
   88:     const trimmed = value.trim()
   89:     if (!trimmed) return ''
   90:     if (!adminIdCsvPattern.test(trimmed)) return null
   91:     const ids = Array.from(new Set(trimmed.split(',').map(item => Number(item.trim()))))
   92:     if (ids.some(id => !Number.isSafeInteger(id) || id <= 0)) return null
   93:     return ids.join(',')
   94: }
   95: 
   96: function normalizeTrustedHostsCsv(value: string): string | null {
   97:     const trimmed = value.trim()
   98:     if (!trimmed) return ''
   99:     const hosts = Array.from(new Set(
  100:         trimmed
  101:             .split(',')
  102:             .map(item => item.trim().toLowerCase())
  103:             .filter(Boolean)
  104:     ))
  105:     if (hosts.length > 50) return null
  106:     if (hosts.some(host => host.length > 253 || !trustedHostPattern.test(host))) return null
  107:     return hosts.join(',')
  108: }
