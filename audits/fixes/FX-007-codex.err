  110: async function normalizeOptionalSafeHttpsUrl(value: string, label: string, maxLength = 1000): Promise<string | null> {
  111:     const trimmed = value.trim()
  112:     if (!trimmed) return ''
  113:     if (trimmed.length > maxLength) return null
  114:     try {
