   59: function spawnUpdater(scriptName: string, args: string[], logPath: string): void {
   60:   const root = getProjectRoot()
   61:   const scriptPath = process.env.NODE_ENV === 'production'
   62:     ? `server/dist/scripts/${scriptName.replace(/\.ts$/, '.js')}`
   63:     : `server/src/scripts/${scriptName}`
   64:   const nodeArgs = scriptPath.endsWith('.ts')
   65:     ? ['--import', 'tsx', scriptPath, ...args]
   66:     : [scriptPath, ...args]
   67:   const child = spawn(process.execPath, nodeArgs, {
   68:     cwd: root,
   69:     detached: true,
   70:     stdio: ['ignore', 'ignore', 'ignore'],
   71:     env: {
   72:       ...process.env,
   73:       INCUDAL_APP_DIR: root,
   74:       SYSTEM_UPDATE_LOG_PATH: logPath,
   75:       SYSTEM_UPDATE_LOG_DIR: getLogDir(root)
   76:     }
   77:   })
   78:   child.unref()
   79: }
   80: 
   81: async function startSystemUpdateWorker(mode: 'update' | 'rollback', taskId: number, scriptName: string, args: string[], logPath: string): Promise<void> {
   82:   if (process.platform === 'linux' && process.env.NODE_ENV === 'production' && process.env.SYSTEM_UPDATE_USE_SYSTEMD !== 'false') {
   83:     const unitName = mode === 'rollback'
   84:       ? `incudal-online-rollback@${taskId}.service`
   85:       : `incudal-online-update@${taskId}.service`
   86:     await execFileAsync('sudo', ['-n', 'systemctl', 'start', '--no-block', unitName], {
   87:       cwd: getProjectRoot(),
   88:       timeout: 30000
   89:     })
   90:     return
   91:   }
   92: 
   93:   spawnUpdater(scriptName, args, logPath)
   94: }
