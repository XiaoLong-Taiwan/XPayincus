   48: const nonNegativeIntegerConfigPattern = /^(?:0|[1-9]\d*)$/
   49: const adminIdCsvPattern = /^(?:\s*[1-9]\d*\s*)(?:,\s*[1-9]\d*\s*)*$/
   50: const trustedHostPattern = /^(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)(?:\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)*$/i
