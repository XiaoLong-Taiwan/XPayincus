 838:       return reply.code(400).send({ error: 'Invalid review status', code: 'INVALID_REVIEW_STATUS' })
 839:     }
 840:     const submissions = await listPluginMarketSubmissions({
 841:       reviewStatus,
 842:       limit: parseLimit(request.query.limit)
 843:     })
 844:     return { submissions: submissions.map(serializePluginMarketSubmission) }
 845:   })
 846: 
 847:   fastify.patch<{
 848:     Params: ReviewParams
 849:     Body: ReviewBody
 850:   }>('/admin/:id/review', {
 851:     onRequest: [fastify.authenticateAdmin]
 852:   }, async (request, reply) => {
 853:     if (!(await requirePluginMarketReviewer(request, reply))) return
 854:     const id = parsePositiveId(request.params.id)
 855:     if (!id) return reply.code(400).send({ error: 'Invalid submission id', code: 'INVALID_SUBMISSION_ID' })
 856: 
 857:     const reviewStatus = normalizeReviewStatus(request.body?.reviewStatus)
 858:     const riskLevel = normalizeRiskLevel(request.body?.riskLevel) ?? 'medium'
 859:     const reviewNotes = normalizeOptionalText(request.body?.reviewNotes, 5000)
 860:     if (!reviewStatus) {
 861:       return reply.code(400).send({ error: 'Invalid review status', code: 'INVALID_REVIEW_STATUS' })
 862:     }
 863: 
 864:     if (reviewStatus === 'listed') {
 865:       const submission = await getPluginMarketSubmissionForReview(id)
 866:       if (submission && !isFreePricing(submission.pricing)) {
 867:         return reply.code(400).send({
 868:           error: PAID_MARKET_LISTING_NOT_AVAILABLE,
 869:           code: 'PAID_MARKET_LISTING_NOT_AVAILABLE'
 870:         })
 871:       }
 872:     }
 873: 
 874:     try {
 875:       const user = getRequestUser(request)
 876:       const submission = await reviewPluginMarketSubmission({
 877:         id,
 878:         reviewStatus,
 879:         riskLevel,
 880:         reviewNotes,
 881:         reviewedByUserId: user.id
 882:       })
 883:       await createLog(
 884:         user.id,
 885:         LogModule.PLUGIN,
 886:         'plugin.market_submission.review',
 887:         `Reviewed plugin market submission ${submission.pluginId}@${submission.version}: ${reviewStatus}/${riskLevel}`,
 888:         LogResult.SUCCESS
 889:       )
 890:       return { submission: serializePluginMarketSubmission(submission) }
 891:     } catch (error) {
 892:       if (error instanceof Prisma.PrismaClientKnownRequestError && error.code === 'P2025') {
 893:         return reply.code(404).send({ error: 'Submission not found', code: 'PLUGIN_SUBMISSION_NOT_FOUND' })
 894:       }
 895:       throw error
 896:     }
 897:   })
 898: 
 899:   fastify.post<{
 900:     Params: ReviewParams
 901:   }>('/admin/:id/scan', {
 902:     onRequest: [fastify.authenticateAdmin]
 903:   }, async (request, reply) => {
 904:     if (!(await requirePluginMarketReviewer(request, reply))) return
 905:     const id = parsePositiveId(request.params.id)
 906:     if (!id) return reply.code(400).send({ error: 'Invalid submission id', code: 'INVALID_SUBMISSION_ID' })
 907: 
 908:     const submission = await getPluginMarketSubmissionForReview(id)
