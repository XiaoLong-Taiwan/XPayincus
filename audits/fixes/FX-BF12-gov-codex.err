)

assert.ok(
  envExample.includes('PLUGIN_MARKET_PUBLISH_DIR=') &&
    envExample.includes('PLUGIN_MARKET_PUBLIC_BASE_URL=') &&
    installPanel.includes('PLUGIN_MARKET_PUBLISH_DIR') &&
