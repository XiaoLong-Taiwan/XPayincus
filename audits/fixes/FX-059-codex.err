diff --git a/server/src/services/traffic-bandwidth.ts b/server/src/services/traffic-bandwidth.ts
index 203cee5..2364e6c 100644
--- a/server/src/services/traffic-bandwidth.ts
+++ b/server/src/services/traffic-bandwidth.ts
@@ -1,4 +1,8 @@
-import { THROTTLE_BANDWIDTH } from '../lib/incus/incus-traffic.js'
+import type { IncusClient } from '../lib/incus/incus-client.js'
+import { prisma } from '../db/prisma.js'
+import { withLock } from '../lib/distributed-lock.js'
+import { getIncusClientFromPool } from '../lib/incus/incus-pool.js'
+import { restoreBandwidth, THROTTLE_BANDWIDTH } from '../lib/incus/incus-traffic.js'
 
