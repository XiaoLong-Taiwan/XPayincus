model UserQuota {
  id     Int @id @default(autoincrement())
  userId Int @unique @map("user_id")

  // æ–°é…é¢ç³»ç»Ÿï¼šæŽ§åˆ¶ç”¨æˆ·å¯æ‹¥æœ‰çš„èµ„æºæ•°é‡
RECORD MODELS
model LoginRecord {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  ip        String   // ç™»å½• IP
  country   String?  // å›½å®¶
  region    String?  // åœ°åŒº/çœä»½
  city      String?  // åŸŽå¸‚
  isp       String?  // ISP æœåŠ¡å•†
  timezone  String?  // æ—¶åŒº
  userAgent String?  @map("user_agent") // ç”¨æˆ·ä»£ç†
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, ip])
  @@map("login_records")
}

// ==================== å·¥å•ç³»ç»Ÿæ¨¡åž‹ ====================

// å·¥å•çŠ¶æ€æžšä¸¾
enum TicketStatus {
  open        // å¾…å¤„ç†
  in_progress // å¤„ç†ä¸­
  resolved    // å·²è§£å†³
  closed      // å·²å…³é—­
}

// å·¥å•ä¼˜å…ˆçº§æžšä¸¾
enum TicketPriority {
  low
  normal
  high
  urgent
}

// å·¥å•ä¸»è¡¨
model Ticket {
  id          Int            @id @default(autoincrement())
  userId      Int            @map("user_id")      // å‘èµ·å·¥å•çš„ç”¨æˆ·
  hostId      Int?           @map("host_id")      // å¯é€‰ï¼šå…³è”çš„å®¿ä¸»æœºï¼ˆæ— å®žä¾‹æ—¶ä¸ºnullï¼Œå·¥å•ç›´æŽ¥å‘ç»™ç®¡ç†å‘˜ï¼‰
  instanceId  Int?           @map("instance_id")  // å¯é€‰ï¼šå…³è”çš„å®žä¾‹
  
  subject     String                              // å·¥å•æ ‡é¢˜
  category    String         @default("general")  // åˆ†ç±»ï¼šgeneral/billing/technical/abuse
  priority    TicketPriority @default(normal)
  status      TicketStatus   @default(open)
  
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  resolvedAt  DateTime?      @map("resolved_at")
  closedAt    DateTime?      @map("closed_at")
  firstResponseDueAt DateTime? @map("first_response_due_at")
  resolutionDueAt    DateTime? @map("resolution_due_at")
model RedeemCodeUsage {
  id           Int      @id @default(autoincrement())
  redeemCodeId Int      @map("redeem_code_id")  // å…‘æ¢ç  ID
  userId       Int      @map("user_id")         // ä½¿ç”¨è€…
  instanceId   Int      @map("instance_id")     // åº”ç”¨åˆ°çš„å®žä¾‹
  batchId      String?  @map("batch_id")        // æ‰¹æ¬¡IDï¼ˆå†—ä½™å­˜å‚¨ï¼Œç”¨äºŽå”¯ä¸€çº¦æŸï¼‰
  usedAt       DateTime @default(now()) @map("used_at")

  redeemCode RedeemCode @relation(fields: [redeemCodeId], references: [id], onDelete: Cascade)
  user       User       @relation("RedeemCodeUsages", fields: [userId], references: [id], onDelete: Cascade)
  instance   Instance   @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([userId, batchId])  // åŒæ‰¹æ¬¡æ¯ç”¨æˆ·åªèƒ½ä½¿ç”¨ä¸€æ¬¡ï¼ˆNULLå€¼ä¸å‚ä¸Žçº¦æŸï¼‰
  @@index([redeemCodeId])
  @@index([userId])
  @@index([instanceId])
  @@map("redeem_code_usages")
}

// ==================== ç”¨æˆ·è‡ªå®šä¹‰åˆå§‹åŒ–å‘½ä»¤æ¨¡åž‹ ====================

model CustomInitCommand {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  name        String   // æ¨¡æ¿åç§°
  command     String   @db.Text // å‘½ä»¤å†…å®¹ï¼ˆå¤šè¡Œæ–‡æœ¬ï¼‰
  distros     String   // JSONæ•°ç»„ï¼Œé€‚é…çš„å‘è¡Œç‰ˆ ["ubuntu","alpine","all"]
  description String?  // å¤‡æ³¨è¯´æ˜Ž
  enabled     Boolean  @default(true) // æ˜¯å¦å¯ç”¨
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, enabled])
  @@map("custom_init_commands")
}

model TerminalSavedCommand {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  name        String
  command     String   @db.Text
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@map("terminal_saved_commands")
}

// ==================== è®¡è´¹ç³»ç»Ÿæ¨¡åž‹ ====================
model BalanceLog {
  id            Int            @id @default(autoincrement())
  userId        Int            @map("user_id")
  type          BalanceLogType
  amount        Decimal        @db.Decimal(10, 2) // æ­£æ•°=å¢žåŠ ï¼Œè´Ÿæ•°=å‡å°‘
  balanceBefore Decimal        @map("balance_before") @db.Decimal(10, 2)
  balanceAfter  Decimal        @map("balance_after") @db.Decimal(10, 2)

  // å…³è”ä¿¡æ¯
  orderId    String? @map("order_id")    // å……å€¼è®¢å•å·
  instanceId Int?    @map("instance_id") // å…³è”å®žä¾‹
  remark     String?                      // å¤‡æ³¨

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  adjustmentRequest BalanceAdjustmentRequest?

  @@index([userId, createdAt(sort: Desc)])
  @@index([type])
  @@map("balance_logs")
}

model BalanceAdjustmentRequest {
  id                Int                            @id @default(autoincrement())
  userId            Int                            @map("user_id")
  requestedByUserId Int                            @map("requested_by_user_id")
  reviewedByUserId  Int?                           @map("reviewed_by_user_id")
  amount            Decimal                        @db.Decimal(10, 2)
  requestType       BalanceAdjustmentRequestType   @default(manual_adjust) @map("request_type")
  status            BalanceAdjustmentRequestStatus @default(pending)
  sourceType        String?                        @map("source_type")
  sourceId          Int?                           @map("source_id")
  orderNo           String?                        @map("order_no")
  reason            String
  reviewRemark      String?                        @map("review_remark")
  balanceLogId      Int?                           @unique @map("balance_log_id")
  createdAt         DateTime                       @default(now()) @map("created_at")
  updatedAt         DateTime                       @updatedAt @map("updated_at")
  reviewedAt        DateTime?                      @map("reviewed_at")

  user        User        @relation("BalanceAdjustmentTarget", fields: [userId], references: [id], onDelete: Cascade)
  requestedBy User        @relation("BalanceAdjustmentRequester", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  reviewedBy  User?       @relation("BalanceAdjustmentReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  balanceLog  BalanceLog? @relation(fields: [balanceLogId], references: [id], onDelete: SetNull)
  orderOperationCase OrderOperationCase?

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([requestedByUserId])
  @@index([reviewedByUserId])
  @@index([orderNo])
  @@map("balance_adjustment_requests")
}

model RechargeRecord {
  id         Int @id @default(autoincrement())
  userId     Int @map("user_id")
  providerId Int @map("provider_id")

  // è®¢å•ä¿¡æ¯
  orderNo String  @unique @map("order_no") // ç³»ç»Ÿè®¢å•å·
  tradeNo String? @map("trade_no")          // ç¬¬ä¸‰æ–¹äº¤æ˜“å·

  // é‡‘é¢
  amount       Decimal  @db.Decimal(10, 2)                                // å……å€¼é‡‘é¢
  actualAmount Decimal? @map("actual_amount") @db.Decimal(10, 2)          // å®žé™…åˆ°è´¦é‡‘é¢
  fee          Decimal  @default(0) @db.Decimal(10, 2)                    // å¹³å°æ‰‹ç»­è´¹

  // æ”¯ä»˜æ–¹å¼
  paymentMethod String? @map("payment_method") // alipay/wxpay/card ç­‰

  status RechargeStatus @default(pending)

  // å›žè°ƒä¿¡æ¯
  callbackData Json?     @map("callback_data") // æ”¯ä»˜å›žè°ƒåŽŸå§‹æ•°æ®
  callbackAt   DateTime? @map("callback_at")
  providerConfigSnapshot String? @map("provider_config_snapshot") // è®¢å•åˆ›å»ºæ—¶çš„æ”¯ä»˜æ¸ é“é…ç½®å¿«ç…§ï¼ˆåŠ å¯†ï¼‰
  paymentDetails        Json?    @map("payment_details")          // ç»“æž„åŒ–æ”¯ä»˜è¯¦æƒ…ï¼ˆå¸ç§/ç½‘ç»œ/txidç­‰ï¼‰

  // å¤±è´¥ä¿¡æ¯
  failReason String? @map("fail_reason")

  // IP ä¸Žè®¾å¤‡
  ip        String?
  userAgent String? @map("user_agent")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  expiredAt   DateTime? @map("expired_at")   // è®¢å•è¿‡æœŸæ—¶é—´ï¼ˆæŒ‰æ”¯ä»˜æ¸ é“å‘ç¥¨æœ‰æ•ˆæœŸï¼‰
  completedAt DateTime? @map("completed_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider PaymentProvider @relation(fields: [providerId], references: [id])
  refundRequests RechargeRefundRequest[]

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([orderNo])
  @@index([tradeNo])
  @@map("recharge_records")
}

model RechargeRefundRequest {
  id                Int                  @id @default(autoincrement())
  rechargeRecordId  Int                  @map("recharge_record_id")
  userId            Int                  @map("user_id")
  providerId        Int                  @map("provider_id")
  requestedByUserId Int                  @map("requested_by_user_id")
  processedByUserId Int?                 @map("processed_by_user_id")
model HostingBalanceLog {
  id         Int                 @id @default(autoincrement())
  userId     Int                 @map("user_id")
  type       HostingBalanceType
  actionType HostingActionType?  @map("action_type") // å…·ä½“æ“ä½œç±»åž‹ï¼ˆå¼€é€š/ç»­è´¹/å‡çº§/é”€æ¯ç­‰ï¼‰
  amount     Decimal             @db.Decimal(10, 2) // é‡‘é¢ï¼ˆæ­£æ•°ï¼‰
  frozen     Boolean             @default(true)     // æ˜¯å¦å†»ç»“çŠ¶æ€
  unfreezeAt DateTime?           @map("unfreeze_at") // è§£å†»æ—¶é—´
  relatedId  Int?                @map("related_id") // å…³è”IDï¼ˆå®žä¾‹ID/æçŽ°IDï¼‰
  remark     String?

  // Snapshot fields for data persistence
  snapshotBuyerName    String?   @map("snapshot_buyer_name")
  snapshotBuyerEmail   String?   @map("snapshot_buyer_email")
  snapshotBuyerAvatar  String?   @map("snapshot_buyer_avatar")
  snapshotInstanceName String?   @map("snapshot_instance_name")
  snapshotHostName     String?   @map("snapshot_host_name")
  snapshotPackageName  String?   @map("snapshot_package_name")
  snapshotPlanName     String?   @map("snapshot_plan_name")

  createdAt  DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, frozen])
  @@index([unfreezeAt])
  @@map("hosting_balance_logs")
}

// æ‰˜ç®¡ä½™é¢æçŽ°è®°å½•
model HostingWithdrawal {
  id           Int              @id @default(autoincrement())
  userId       Int              @map("user_id")
  amount       Decimal          @db.Decimal(10, 2) // æçŽ°é‡‘é¢
  feeRate      Decimal          @map("fee_rate") @db.Decimal(5, 4)  // æ‰‹ç»­è´¹çŽ‡ï¼ˆå¦‚ 0.1000 è¡¨ç¤º 10%ï¼‰
  feeAmount    Decimal          @map("fee_amount") @db.Decimal(10, 2) // æ‰‹ç»­è´¹é‡‘é¢
  actualAmount Decimal          @map("actual_amount") @db.Decimal(10, 2) // å®žé™…åˆ°è´¦é‡‘é¢
  target       WithdrawalTarget
  usdtAddress  String?          @map("usdt_address") // USDTåœ°å€ï¼ˆä»…USDTæçŽ°ï¼‰
  status       WithdrawalStatus @default(pending)
  rejectReason String?          @map("reject_reason")
  processedAt  DateTime?        @map("processed_at")
  processedBy  Int?             @map("processed_by") // å¤„ç†çš„ç®¡ç†å‘˜ID
  createdAt    DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("hosting_withdrawals")
}

// æ‰˜ç®¡ç”¨æˆ·æ‹‰é»‘å…³ç³»
model HostingUserBlock {
  id            Int      @id @default(autoincrement())
  blockerId     Int      @map("blocker_id") // æ‰˜ç®¡ç”¨æˆ·
ERRORS
/**
 * Standardized API error codes and messages
 * Frontend will translate these based on error codes
 */

import { sanitizeTokensInString } from './log-sanitizer.js'

export const ErrorCode = {
    // Common errors
    INVALID_ID: 'INVALID_ID',
    NOT_FOUND: 'NOT_FOUND',
    UNAUTHORIZED: 'UNAUTHORIZED',
    FORBIDDEN: 'FORBIDDEN',
    ADMIN_REQUIRED: 'ADMIN_REQUIRED',
    FEATURE_DISABLED: 'FEATURE_DISABLED',
    INVALID_INPUT: 'INVALID_INPUT',

    // User errors
    USER_NOT_FOUND: 'USER_NOT_FOUND',
    USER_EXISTS: 'USER_EXISTS',
    CANNOT_MODIFY_SELF: 'CANNOT_MODIFY_SELF',
    CANNOT_DELETE_SELF: 'CANNOT_DELETE_SELF',
    CANNOT_BAN_ADMIN: 'CANNOT_BAN_ADMIN',
    CANNOT_DELETE_ADMIN: 'CANNOT_DELETE_ADMIN',
    USER_HAS_INSTANCES: 'USER_HAS_INSTANCES',
    USER_HAS_RESOURCES: 'USER_HAS_RESOURCES',

    // Auth errors
    INVALID_CREDENTIALS: 'INVALID_CREDENTIALS',
    ACCOUNT_BANNED: 'ACCOUNT_BANNED',
    TOO_MANY_ATTEMPTS: 'TOO_MANY_ATTEMPTS',
    REGISTRATION_DISABLED: 'REGISTRATION_DISABLED',
    INVALID_INVITE_CODE: 'INVALID_INVITE_CODE',
    INVITE_CODE_EXPIRED: 'INVITE_CODE_EXPIRED',
    INVALID_2FA_CODE: 'INVALID_2FA_CODE',
    TWO_FA_REQUIRED: 'TWO_FA_REQUIRED',
    TWO_FA_ALREADY_ENABLED: 'TWO_FA_ALREADY_ENABLED',
    TWO_FA_NOT_ENABLED: 'TWO_FA_NOT_ENABLED',
    REFRESH_TOKEN_MISSING: 'REFRESH_TOKEN_MISSING',
    REFRESH_TOKEN_INVALID: 'REFRESH_TOKEN_INVALID',
    SESSION_NOT_FOUND: 'SESSION_NOT_FOUND',

    // Validation errors
    INVALID_EMAIL: 'INVALID_EMAIL',
    EMAIL_CONTAINS_ILLEGAL: 'EMAIL_CONTAINS_ILLEGAL',
    USERNAME_CONTAINS_ILLEGAL: 'USERNAME_CONTAINS_ILLEGAL',
    PASSWORD_TOO_WEAK: 'PASSWORD_TOO_WEAK',
    INVALID_SSH_KEY: 'INVALID_SSH_KEY',
    SSH_KEY_EXISTS: 'SSH_KEY_EXISTS',
    INVALID_NAME: 'INVALID_NAME',

    // Instance errors
    INSTANCE_NOT_FOUND: 'INSTANCE_NOT_FOUND',
    INSTANCE_ALREADY_RUNNING: 'INSTANCE_ALREADY_RUNNING',
    INSTANCE_ALREADY_STOPPED: 'INSTANCE_ALREADY_STOPPED',

export type ErrorCodeType = typeof ErrorCode[keyof typeof ErrorCode]

// English error messages (default)
export const ErrorMessages: Record<ErrorCodeType, string> = {
    // Common errors
    [ErrorCode.INVALID_ID]: 'Invalid ID',
    [ErrorCode.NOT_FOUND]: 'Resource not found',
    [ErrorCode.UNAUTHORIZED]: 'Unauthorized',
    [ErrorCode.FORBIDDEN]: 'Access denied',
    [ErrorCode.ADMIN_REQUIRED]: 'Admin privileges required',
    [ErrorCode.FEATURE_DISABLED]: 'This feature has been disabled',
    [ErrorCode.INVALID_INPUT]: 'Invalid input',

    // User errors
    [ErrorCode.USER_NOT_FOUND]: 'User not found',
    [ErrorCode.USER_EXISTS]: 'Username already exists',
    [ErrorCode.CANNOT_MODIFY_SELF]: 'Cannot modify your own status',
    [ErrorCode.CANNOT_DELETE_SELF]: 'Cannot delete yourself',
    [ErrorCode.CANNOT_BAN_ADMIN]: 'Cannot ban admin account',
    [ErrorCode.CANNOT_DELETE_ADMIN]: 'Cannot delete admin account',
    [ErrorCode.USER_HAS_INSTANCES]: 'User has instances, please delete them first',
    [ErrorCode.USER_HAS_RESOURCES]: 'User owns resources, please transfer or remove them first',

    // Auth errors
    [ErrorCode.INVALID_CREDENTIALS]: 'Invalid username or password',
    [ErrorCode.ACCOUNT_BANNED]: 'Account has been disabled',
    [ErrorCode.TOO_MANY_ATTEMPTS]: 'Too many login attempts, please try again later',
    [ErrorCode.REGISTRATION_DISABLED]: 'Registration is currently closed',
    [ErrorCode.INVALID_INVITE_CODE]: 'Invalid or used invite code',
    [ErrorCode.INVITE_CODE_EXPIRED]: 'Invite code has expired',
    [ErrorCode.INVALID_2FA_CODE]: 'Invalid verification code or recovery code',
    [ErrorCode.TWO_FA_REQUIRED]: 'Two-factor authentication required',
    [ErrorCode.TWO_FA_ALREADY_ENABLED]: '2FA is already enabled, please disable it first',
    [ErrorCode.TWO_FA_NOT_ENABLED]: '2FA is not enabled',
    [ErrorCode.REFRESH_TOKEN_MISSING]: 'Refresh token missing',
    [ErrorCode.REFRESH_TOKEN_INVALID]: 'Refresh token invalid or expired',
    [ErrorCode.SESSION_NOT_FOUND]: 'Session not found',

