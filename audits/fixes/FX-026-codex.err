  rechargeRefundRequests RechargeRefundRequest[] @relation("RechargeRefundRequester")
  rechargeRefundProcessors RechargeRefundRequest[] @relation("RechargeRefundProcessor")
  balanceAdjustmentTargets BalanceAdjustmentRequest[] @relation("BalanceAdjustmentTarget")
  balanceAdjustmentRequests BalanceAdjustmentRequest[] @relation("BalanceAdjustmentRequester")
  balanceAdjustmentReviews BalanceAdjustmentRequest[] @relation("BalanceAdjustmentReviewer")
  orderOperationCases OrderOperationCase[] @relation("OrderOperationTarget")
