  // ç³»ç»Ÿå…‘æ¢ç 
  redeemCodesCreated RedeemCode[]      @relation("RedeemCodesCreated")
  redeemCodeUsages   RedeemCodeUsage[] @relation("RedeemCodeUsages")

  // ç¤¼å“å¡å…‘æ¢ç 
  giftCardsCreated   GiftCard[]        @relation("GiftCardsCreated")
  giftCardsOwned     GiftCard[]        @relation("GiftCardsOwner")
  giftCardsUsed      GiftCard[]        @relation("GiftCardsUsedBy")

  // ç”¨æˆ·è‡ªå®šä¹‰åˆå§‹åŒ–å‘½ä»¤
  customInitCommands CustomInitCommand[]

  // ç”¨æˆ·ç»ˆç«¯å¿«æ·å‘½ä»¤
  terminalSavedCommands TerminalSavedCommand[]

  // è®¡è´¹ç›¸å…³
  balanceLogs     BalanceLog[]
  rechargeRecords RechargeRecord[]
