  financialReconciliationItems FinancialReconciliationItem[]
  financialReconciliationItemsHandled FinancialReconciliationItem[] @relation("FinancialReconciliationItemHandler")
  badgeOwnerships UserBadgeOwnership[]
  vipBenefitClaims VipBenefitClaim[]

  // AFFæŽ¨èè®¡åˆ’
  affBalance       Decimal         @default(0) @map("aff_balance") @db.Decimal(10, 2)  // AFFä½™é¢
  affActivatedAt   DateTime?       @map("aff_activated_at")                            // AFFæ¿€æ´»æ—¶é—´
  affCodes         AffCode[]
  affLogs          AffLog[]
  affWithdrawals   AffWithdrawal[]

  // æ‰˜ç®¡ä½™é¢ç³»ç»Ÿ
  hostingBalance      Decimal              @default(0) @map("hosting_balance") @db.Decimal(10, 2) // å¯ç”¨æ‰˜ç®¡ä½™é¢
  hostingBalanceLogs  HostingBalanceLog[]
  hostingWithdrawals  HostingWithdrawal[]
  hostingBlocksCreated  HostingUserBlock[] @relation("HostingBlocker")
  hostingBlocksReceived HostingUserBlock[] @relation("HostingBlockedUser")
  hostingZone         HostingZone?         @relation("HostingZoneOwner")

  // åŸŸåé‚®ç®±ç³»ç»Ÿ
  mailSubscriptions   MailSubscription[]

  // æŠ½å¥–ç³»ç»Ÿ
  userPoints       UserPoints?
  pointsLogs       PointsLog[]
  lotteryRecords   LotteryRecord[]

  // èµ„æºæ± ç³»ç»Ÿ
  resourcePool     UserResourcePool?
  resourcePoolLogs ResourcePoolLog[]

  // é”€æ¯è®°å½•
  destroyRecords   UserDestroyRecord[]
  instanceAuditRules InstanceAuditRule[] @relation("InstanceAuditRuleCreator")
  instanceAuditBuiltinRuleOverrides InstanceAuditBuiltinRuleOverride[] @relation("InstanceAuditBuiltinRuleOverrideCreator")
  instanceAuditIgnores InstanceAuditIgnore[] @relation("InstanceAuditIgnoreCreator")
  instanceAuditScans InstanceAuditScan[] @relation("InstanceAuditScanUser")
  instanceAuditActions InstanceAuditAction[] @relation("InstanceAuditActionUser")
  systemUpdateTasks SystemUpdateTask[] @relation("SystemUpdateTaskStarter")
  pluginsInstalled Plugin[] @relation("PluginInstaller")
  pluginsEnabled Plugin[] @relation("PluginEnabler")
  pluginInstallTasks PluginInstallTask[] @relation("PluginInstallTaskStarter")
  pluginEventLogs PluginEventLog[] @relation("PluginEventLogUser")
  pluginUserData PluginUserData[] @relation("PluginUserDataUser")
  pluginStorageItemsCreated PluginStorageItem[] @relation("PluginStorageItemCreator")
  pluginStorageItemsUpdated PluginStorageItem[] @relation("PluginStorageItemUpdater")
  pluginStorageBackupRemoteArchives PluginStorageBackupRemoteArchive[] @relation("PluginStorageBackupRemoteArchiveUploader")
  pluginMarketSubmissions PluginMarketSubmission[] @relation("PluginMarketSubmissionSubmitter")
  pluginMarketReviews PluginMarketSubmission[] @relation("PluginMarketSubmissionReviewer")
  pluginEventAlertPreferences PluginEventAlertPreference[] @relation("PluginEventAlertPreferenceUser")
  themeMarketSubmissions ThemeMarketSubmission[] @relation("ThemeMarketSubmissionSubmitter")
  themeMarketReviews ThemeMarketSubmission[] @relation("ThemeMarketSubmissionReviewer")
  themesInstalled ThemePackage[] @relation("ThemeInstaller")
  themesEnabled ThemePackage[] @relation("ThemeEnabler")
  oauthAppsCreated OAuthClientApp[] @relation("OAuthClientAppCreator")
  oauthAuthorizationCodes OAuthAuthorizationCode[] @relation("OAuthAuthorizationCodeUser")
  oauthAccessTokens OAuthAccessToken[] @relation("OAuthAccessTokenUser")
