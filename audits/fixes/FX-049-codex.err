  274: async function claimInstanceForUserDestroy(
  275:   instanceId: number,
  276:   userId: number,
  277:   currentStatus: InstanceStatus
  278: ): Promise<boolean> {
  279:   return prisma.$transaction(async (tx) => {
  280:     const locked = await tryAdvisoryTransactionLock(tx, INSTANCE_OPERATION_LOCK_NAMESPACE, instanceId)
  281:     if (!locked) return false
  282: 
  283:     const blockingTask = await getDestroyBlockingTask(instanceId, tx)
  284:     if (blockingTask) return false
  285: 
  286:     const exchangeLock = await getExchangeDestroyLock(instanceId, tx)
  287:     if (exchangeLock) return false
  288: 
  289:     const result = await tx.instance.updateMany({
  290:       where: {
  291:         id: instanceId,
  292:         userId,
  293:         status: currentStatus
  294:       },
  295:       data: { status: 'deleted' }
  296:     })
  297: 
  298:     return result.count === 1
  299:   })
  300: }
