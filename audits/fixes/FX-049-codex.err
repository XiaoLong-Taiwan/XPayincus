  191:         amount: { gt: 0 }
  192:       },
  193:       _sum: { amount: true }
  194:     })
  195:   ])
  196: 
  197:   if (!affBinding) return
  198:   const originalPaidAmount = Number(paidAmountResult._sum.amount || 0)
  199:   if (!Number.isFinite(originalPaidAmount) || originalPaidAmount <= 0) return
  200: 
  201:   const refundRatio = Math.min(1, refundAmount / originalPaidAmount)
  202:   const affLogs = await tx.affLog.findMany({
  203:     where: {
  204:       instanceId,
  205:       affCodeId: affBinding.affCode.id,
  206:       userId: affBinding.affCode.userId,
