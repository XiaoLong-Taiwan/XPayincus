  129: async function getDestroyBlockingTask(instanceId: number, client: any = prisma): Promise<{
  130:   code: 'RESTORE_IN_PROGRESS' | 'UPLOAD_IN_PROGRESS' | 'TASK_IN_PROGRESS'
  131:   reason: string
  132: } | null> {
  133:   const [activeRestoreTask, activeUploadTask, activeInstanceTask] = await Promise.all([
  134:     client.restoreTask.findFirst({
  135:       where: {
  136:         instanceId,
  137:         status: { in: ['PENDING', 'PROCESSING'] }
  138:       },
  139:       select: { id: true }
  140:     }),
  141:     client.backupUploadTask.findFirst({
  142:       where: {
  143:         instanceId,
  144:         status: { in: ['PENDING', 'PROCESSING'] }
  145:       },
  146:       select: { id: true }
  147:     }),
  148:     client.instanceTask.findFirst({
  149:       where: {
  150:         instanceId,
  151:         status: { in: ['PENDING', 'PROCESSING'] }
  152:       },
  153:       select: { id: true }
  154:     })
  155:   ])
  156: 
  157:   if (activeRestoreTask) {
  158:     return { code: 'RESTORE_IN_PROGRESS', reason: 'è¯¥å®žä¾‹æœ‰æ­£åœ¨è¿›è¡Œçš„æ¢å¤ä»»åŠ¡ï¼Œè¯·ç­‰å¾…å®Œæˆæˆ–å–æ¶ˆ' }
  159:   }
  160:   if (activeUploadTask) {
  161:     return { code: 'UPLOAD_IN_PROGRESS', reason: 'è¯¥å®žä¾‹æœ‰æ­£åœ¨è¿›è¡Œçš„å¤‡ä»½ä¸Šä¼ ä»»åŠ¡ï¼Œè¯·ç­‰å¾…å®Œæˆæˆ–å–æ¶ˆ' }
  162:   }
  163:   if (activeInstanceTask) {
  164:     return { code: 'TASK_IN_PROGRESS', reason: 'è¯¥å®žä¾‹æœ‰æ­£åœ¨è¿›è¡Œçš„æ“ä½œä»»åŠ¡ï¼Œè¯·ç­‰å¾…å®Œæˆ' }
  165:   }
  166:   return null
  167: }
