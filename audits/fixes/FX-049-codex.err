+  if (updateResult.count === 0) {
+    console.log(`[Provisioning] 实例 ${instanceId} 已被其他失败补偿或超时清理处理，跳过重复补偿`)
+    return false
+  }
+
+  const rollbackPortCount = networkModeAllowsPortMapping(networkMode) ? portLimit : 0
