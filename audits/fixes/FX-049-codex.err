  213:     const typeLogs = affLogs.filter(log => log.type === type)
  214:     const issuedCommission = roundMoney(typeLogs.reduce(
  215:       (sum, log) => sum + Math.max(0, Number(log.amount)),
  216:       0
  217:     ))
  218:     const alreadyReversed = roundMoney(typeLogs.reduce(
  219:       (sum, log) => sum + Math.max(0, -Number(log.amount)),
  220:       0
  221:     ))
  222:     const remainingCommission = roundMoney(Math.max(0, issuedCommission - alreadyReversed))
  223:     const commissionAmount = Math.min(
  224:       remainingCommission,
  225:       roundMoney(issuedCommission * refundRatio)
  226:     )
