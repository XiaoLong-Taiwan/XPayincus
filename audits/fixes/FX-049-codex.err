  683:     return { id: instanceId, name: `#${instanceId}`, success: false, reason: BATCH_HIDDEN_REASON }
  684:   }
  685: 
  686:   if (instance.status === 'deleted') {
  687:     return { id: instance.id, name: instance.name, success: false, skipped: true, reason: 'å®žä¾‹å·²åˆ é™¤' }
  688:   }
  689: 
  690:   if (instance.status === 'creating') {
  691:     return { id: instance.id, name: instance.name, success: false, skipped: true, reason: 'å®žä¾‹æ­£åœ¨åˆ›å»ºä¸­ï¼Œæ— æ³•é”€æ¯' }
  692:   }
  693: 
  694:   if (instance.status === 'suspended' && !canUserDestroyExpiredSuspendedPaidInstance(instance)) {
  695:     return { id: instance.id, name: instance.name, success: false, skipped: true, reason: 'å®žä¾‹å·²è¢«å°åœï¼Œæ— æ³•é”€æ¯ï¼Œè¯·å…ˆè”ç³»ç®¡ç†å‘˜è§£å°' }
  696:   }
