    appSource.includes("status: 'creating' // åŽŸå­æ¡ä»¶ï¼šåªæœ‰çŠ¶æ€ä»ä¸º creating æ—¶æ‰æ›´æ–°") &&
    appSource.includes('const compensation = await compensateFailedInstancePurchase(instance.id, instance.user_id, instance.host_id)') &&
    appSource.includes("await markFlashSaleFailed(instance.id, 'å®žä¾‹åˆ›å»ºè¶…æ—¶', compensation.refunded)") &&
    appSource.includes("await markFlashSaleFailed(instance.id, 'å®žä¾‹åˆ›å»ºè¶…æ—¶', false)"),
