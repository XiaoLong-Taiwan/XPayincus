  751:         if (!isFirstTime) {
  752:           feeAmount = roundMoney(refundableValue * currentFeeRate)
  753:         }
  754:       }
  755:       refundAmount = roundMoney(Math.max(0, refundableValue - feeAmount))
  756:     }
  757:   }
  758: 
  759:   const claimed = await claimInstanceForUserDestroy(instanceId, user.id, instance.status)
  760:   if (!claimed) {
  761:     return { id: instance.id, name: instance.name, success: false, skipped: true, reason: '实例正在销毁或已删除' }
  762:   }
  763: 
  764:   try {
  765:     try {
  766:       await deleteIncusInstanceForUserDestroy(instance, logger)
  767:     } catch (incusErr) {
  768:       await restoreClaimedInstanceStatus(instanceId, user.id, instance.status)
  769:       throw incusErr
  770:     }
  771: 
  772:     if (!isFreeInstance) {
  773:       const billingResult = await settleUserDestroyBilling({
  774:         requestUserId: user.id,
  775:         instance,
  776:         refundableValue,
  777:         feeWaiver
  778:       })
  779:       refundAmount = billingResult.refundAmount
  780:       feeAmount = billingResult.feeAmount
  781:       isFirstTime = billingResult.isFirstTime
  782:     }
  783: 
  784:     const portMappings = await prisma.portMapping.findMany({ where: { instanceId } })
  785: 
  786:     try {
  787:       await prisma.snapshot.deleteMany({ where: { instanceId } })
  788:       await prisma.backup.deleteMany({ where: { instanceId } })
  789:       await prisma.portMapping.deleteMany({ where: { instanceId } })
  790:       await prisma.proxySite.deleteMany({ where: { instanceId } })
  791:       await prisma.dailyTraffic.deleteMany({ where: { instanceId } })
  792:       await prisma.ipAddress.deleteMany({ where: { instanceId } })
  793:       await prisma.ipv6Subnet.deleteMany({ where: { instanceId } })
  794:       await prisma.restoreTask.deleteMany({ where: { instanceId, status: { in: ['COMPLETED', 'FAILED'] } } })
  795:       await prisma.backupUploadTask.deleteMany({ where: { instanceId, status: { in: ['COMPLETED', 'FAILED'] } } })
  796:       await prisma.instanceTask.deleteMany({ where: { instanceId, status: { in: ['COMPLETED', 'FAILED'] } } })
  797:       await prisma.instanceTransfer.updateMany({
  798:         where: { instanceId, status: 'pending' },
  799:         data: { status: 'cancelled', cancelledAt: new Date() }
  800:       })
  801:     } catch (cleanupErr) {
  802:       logger.warn(cleanupErr, '清理关联数据失败')
  803:     }
  804: 
  805:     const portMappingsCount = portMappings?.length || 0
  806:     await db.rollbackResources({
  807:       hostId: instance.hostId,
  808:       cpu: instance.cpu,
  809:       memory: instance.memory,
  810:       disk: instance.disk,
  811:       portCount: portMappingsCount
  812:     })
  813: 
  814:     const usedResources = await db.calculateHostResourcesFromInstances(instance.hostId)
  815:     const actualPortsUsed = await prisma.portMapping.count({
  816:       where: {
  817:         instance: {
  818:           hostId: instance.hostId,
  819:           status: { not: 'deleted' }
  820:         }
  821:       }
  822:     })
  823:     await db.updateHostResources(instance.hostId, {
  824:       cpuUsed: usedResources.cpuUsed,
  825:       memoryUsed: usedResources.memoryUsed,
  826:       diskUsed: usedResources.diskUsed
  827:     })
  828:     await prisma.host.update({
  829:       where: { id: instance.hostId },
  830:       data: { natPortsUsedCount: actualPortsUsed }
  831:     })
  832: 
  833:     await createLog(
  834:       user.id,
  835:       'billing',
  836:       'instance.user_destroy',
  837:       `User destroyed instance "${instance.name}" (Host: ${instance.host.name}, Refund: ¥${refundAmount.toFixed(2)}, Fee: ¥${feeAmount.toFixed(2)})`,
  838:       'success'
  839:     )
  840: 
  841:     await sendNotification(user.id, 'instance_deleted_refunded', {
  842:       instanceName: instance.name,
  843:       refundAmount,
  844:       feeAmount,
  845:       isFreeInstance
  846:     })
  847: 
  848:     if (!isFreeInstance && instance.user?.email) {
  849:       try {
  850:         await sendInstanceDestroyRefundEmail(instance.user.email, {
  851:           username: instance.user.username,
  852:           instanceName: instance.name,
  853:           refundAmount,
  854:           feeAmount,
  855:           refundType: '余额退款',
  856:           isUserDestroy: true
  857:         })
  858:       } catch (emailErr) {
  859:         logger.warn(emailErr, '发送销毁退款邮件失败')
  860:       }
  861:     }
  862: 
  863:     sendHostManagedInstanceNotification(
  864:       instance.hostId,
  865:       'destroy',
  866:       {
  867:         username: user.username,
  868:         instanceName: instance.name,
  869:         refundAmount,
  870:         feeAmount
  871:       }
  872:     ).catch(err => {
  873:       logger.warn(err, '发送节点销毁通知失败')
  874:     })
  875: 
  876:     if (instance.packageId) {
  877:       sendReleaseNotification({
  878:         packageId: instance.packageId,
  879:         cpu: instance.cpu,
  880:         memory: instance.memory,
  881:         source: '用户销毁实例'
  882:       }).catch(() => {})
  883:     }
  884: 
  885:     return {
  886:       id: instance.id,
  887:       name: instance.name,
  888:       success: true,
  889:       refundAmount,
  890:       feeAmount,
  891:       isFirstTime,
  892:       isFreeInstance
  893:     }
  894:   } catch (error) {
  895:     logger.error(error, '销毁实例失败')
  896:     return {
  897:       id: instance.id,
  898:       name: instance.name,
  899:       success: false,
  900:       reason: '销毁实例失败'
  901:     }
  902:   }
  903: }
