   46: function safeErrorMessage(error: unknown): string {
   47:   const raw = error instanceof Error ? error.message : String(error)
   48:   return sanitizeTokensInString(raw).slice(0, 1000)
   49: }
   50: 
   51: function planForDetail(plan: PlanSummary | null) {
   52:   if (!plan) return null
   53:   const price = plan.price === undefined || plan.price === null
   54:     ? null
   55:     : typeof plan.price === 'bigint'
   56:       ? plan.price.toString()
   57:       : typeof plan.price === 'number' || typeof plan.price === 'string' || typeof plan.price === 'boolean'
   58:         ? plan.price
   59:         : String(plan.price)
   60:   return {
   61:     id: plan.id,
   62:     name: plan.name,
   63:     price,
   64:     billingCycle: plan.billingCycle ?? null
   65:   }
   66: }
