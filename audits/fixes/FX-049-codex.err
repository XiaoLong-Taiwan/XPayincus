  345: async function settleUserDestroyBilling(params: {
  346:   requestUserId: number
  347:   instance: {
  348:     id: number
  349:     userId: number
  350:     hostId: number
  351:     name: string
  352:   }
  353:   refundableValue: number
  354:   feeWaiver: boolean
  355: }): Promise<{ refundAmount: number; feeAmount: number; isFirstTime: boolean }> {
  356:   const { requestUserId, instance, refundableValue, feeWaiver } = params
  357:   const instanceId = instance.id
  358: 
  359:   return await prisma.$transaction(async (tx) => {
  360:     await advisoryTransactionLock(tx, USER_DESTROY_BILLING_LOCK_NAMESPACE, requestUserId)
  361: 
  362:     const destroyCount = await tx.userDestroyRecord.count({
  363:       where: { userId: requestUserId }
  364:     })
  365:     const isFirstTime = destroyCount === 0
  366:     let feeAmount = 0
  367:     if (!feeWaiver && !isFirstTime) {
  368:       feeAmount = roundMoney(refundableValue * calculateFeeRate(destroyCount))
  369:     }
  370:     const refundAmount = roundMoney(Math.max(0, refundableValue - feeAmount))
  371: 
  372:     if (refundAmount > 0) {
  373:       await advisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, instance.userId)
  374: 
  375:       const currentUser = await tx.user.findUnique({
  376:         where: { id: instance.userId },
  377:         select: { balance: true }
  378:       })
  379:       const oldBalance = Number(currentUser?.balance || 0)
  380: 
  381:       const updatedUser = await tx.user.update({
  382:         where: { id: instance.userId },
  383:         data: { balance: { increment: refundAmount } },
  384:         select: { balance: true }
  385:       })
  386:       const newBalance = Number(updatedUser.balance)
  387: 
  388:       const balanceLog = await tx.balanceLog.create({
  389:         data: {
  390:           userId: instance.userId,
  391:           type: 'refund',
  392:           amount: refundAmount,
  393:           balanceBefore: oldBalance,
  394:           balanceAfter: newBalance,
  395:           instanceId,
  396:           remark: `用户销毁实例退款：${instance.name}${feeWaiver ? '（异常实例免手续费）' : feeAmount > 0 ? `（手续费 ¥${feeAmount.toFixed(2)}）` : '（首次销毁免手续费）'}`
  397:         }
  398:       })
  399: 
  400:       await tx.instanceBillingRecord.create({
  401:         data: {
  402:           instanceId,
  403:           userId: instance.userId,
  404:           type: 'refund',
  405:           amount: -refundAmount,
  406:           months: 0,
  407:           periodStart: new Date(),
  408:           periodEnd: new Date(),
  409:           balanceLogId: balanceLog.id,
  410:           remark: `用户销毁实例退款${feeWaiver ? '（异常实例免手续费）' : feeAmount > 0 ? `（手续费 ¥${feeAmount.toFixed(2)}）` : '（首次销毁免手续费）'}`
  411:         }
  412:       })
  413: 
  414:       await reverseInstanceAffCommissionForRefund({
  415:         tx,
  416:         instanceId,
  417:         refundAmount,
  418:         remark: `用户销毁实例返利冲正：${instance.name}`
  419:       })
  420: 
  421:       await db.deductHostingBalance(
  422:         instance.hostId,
  423:         refundableValue,
  424:         instanceId,
  425:         `用户销毁托管实例退款扣除：${instance.name}`,
  426:         tx
  427:       )
  428:     }
  429: 
  430:     await tx.userDestroyRecord.create({
  431:       data: {
  432:         userId: requestUserId,
  433:         hostId: instance.hostId,
  434:         instanceId,
  435:         instanceName: instance.name,
  436:         refundAmount,
  437:         feeAmount,
  438:         isFirstTime
  439:       }
  440:     })
  441: 
  442:     return { refundAmount, feeAmount, isFirstTime }
  443:   })
  444: }
