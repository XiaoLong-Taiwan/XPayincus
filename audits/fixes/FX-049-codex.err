  674:       host: { select: { id: true, name: true, userId: true } }
  675:     }
  676:   })
  677: 
  678:   if (!instance) {
  679:     return { id: instanceId, name: `#${instanceId}`, success: false, reason: BATCH_HIDDEN_REASON }
  680:   }
  681: 
  682:   if (instance.userId !== user.id) {
  683:     return { id: instanceId, name: `#${instanceId}`, success: false, reason: BATCH_HIDDEN_REASON }
  684:   }
  685: 
  686:   if (instance.status === 'deleted') {
  687:     return { id: instance.id, name: instance.name, success: false, skipped: true, reason: '实例已删除' }
  688:   }
  689: 
  690:   if (instance.status === 'creating') {
  691:     return { id: instance.id, name: instance.name, success: false, skipped: true, reason: '实例正在创建中，无法销毁' }
  692:   }
  693: 
  694:   if (instance.status === 'suspended' && !canUserDestroyExpiredSuspendedPaidInstance(instance)) {
  695:     return { id: instance.id, name: instance.name, success: false, skipped: true, reason: '实例已被封停，无法销毁，请先联系管理员解封' }
  696:   }
  697: 
  698:   const blockingTask = await getDestroyBlockingTask(instanceId)
  699:   if (blockingTask) {
  700:     return { id: instance.id, name: instance.name, success: false, skipped: true, reason: blockingTask.reason }
  701:   }
  702: 
  703:   const exchangeLock = await getExchangeDestroyLock(instanceId)
  704:   if (exchangeLock) {
  705:     return { id: instance.id, name: instance.name, success: false, skipped: true, reason: exchangeLock.reason }
  706:   }
  707: 
  708:   const isFreeInstance = !instance.packagePlanId
  709:   const destroyRecords = await prisma.userDestroyRecord.findMany({
  710:     where: { userId: user.id },
  711:     orderBy: { destroyedAt: 'desc' }
  712:   })
  713:   let isFirstTime = destroyRecords.length === 0
  714:   const feeWaiver = instance.status === 'error'
  715: 
  716:   let currentMonthlyTrafficUsed = instance.monthlyTrafficUsed
  717:   if (!isFreeInstance && instance.status === 'running') {
  718:     const collectResult = await collectTrafficForRunningInstance(instanceId)
  719:     if (!collectResult.success) {
  720:       logger.warn({ instanceId, error: collectResult.error }, '销毁前即时采集流量失败')
  721:     } else {
  722:       currentMonthlyTrafficUsed = collectResult.currentUsage
  723:     }
  724:   }
