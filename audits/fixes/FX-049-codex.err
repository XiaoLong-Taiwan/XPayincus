  243:         userId: affBinding.affCode.userId,
  244:         type,
  245:         amount: -commissionAmount,
  246:         affCodeId: affBinding.affCode.id,
  247:         instanceId,
  248:         originalAmount: roundMoney(typeLogs.reduce(
  249:           (sum, log) => Number(log.amount) > 0
  250:             ? sum + Math.max(0, Number(log.originalAmount || 0))
  251:             : sum,
  252:           0
  253:         )),
  254:         balanceBefore: affBalanceBefore,
  255:         balanceAfter: Number(updatedAffUser.affBalance),
  256:         remark
  257:       }
  258:     })
  259: 
  260:     await tx.affCode.update({
  261:       where: { id: affBinding.affCode.id },
  262:       data: { totalEarnings: { decrement: commissionAmount } }
  263:     })
  264: 
  265:     if (type === 'new_purchase' && commissionAmount >= remainingCommission) {
  266:       await tx.affCode.updateMany({
  267:         where: { id: affBinding.affCode.id, usedCount: { gt: 0 } },
  268:         data: { usedCount: { decrement: 1 } }
  269:       })
  270:     }
  271:   }
  272: }
