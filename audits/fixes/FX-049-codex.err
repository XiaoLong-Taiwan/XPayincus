  665: async function executeDestroyForUser(
  666:   user: { id: number; username: string },
  667:   instanceId: number,
  668:   logger: { warn: (...args: any[]) => void; error: (...args: any[]) => void }
  669: ): Promise<BatchDestroyResultItem> {
