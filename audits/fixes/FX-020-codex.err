}

assert.ok(
  schedulerSource.includes('[...lockedAmounts.keys()].sort((a, b) => a - b)') &&
    schedulerSource.includes('tryAdvisoryTransactionLock(tx, HOSTING_BALANCE_LOG_LOCK_NAMESPACE, userId)'),
