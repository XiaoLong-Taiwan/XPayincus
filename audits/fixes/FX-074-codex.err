"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command '$path = (Resolve-Path '"'server/src/db/hosts.ts').Path
"'$bytes = [System.IO.File]::ReadAllBytes($path)
$encoding = New-Object System.Text.UTF8Encoding($false)
$needle = $encoding.GetBytes("}`nfunction buildPlanUpgradeCapacityResult(")
$replacement = $encoding.GetBytes("}`n`nfunction buildPlanUpgradeCapacityResult(")
$index = -1
for ($i = 0; $i -le $bytes.Length - $needle.Length; $i++) {
  $matched = $true
  for ($j = 0; $j -lt $needle.Length; $j++) {
    if ($bytes[$i + $j] -ne $needle[$j]) { $matched = $false; break }
  }
  if ($matched) { $index = $i; break }
}
if ($index -lt 0) { throw '"'helper boundary not found' }
"'$result = New-Object byte[] ($bytes.Length + 1)
[Array]::Copy($bytes, 0, $result, 0, $index)
[Array]::Copy($replacement, 0, $result, $index, $replacement.Length)
[Array]::Copy($bytes, $index + $needle.Length, $result, $index + $replacement.Length, $bytes.Length - $index - $needle.Length)
[System.IO.File]::WriteAllBytes($path, $result)
