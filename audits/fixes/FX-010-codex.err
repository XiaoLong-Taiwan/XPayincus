/**
 * иҺ·еҸ–з”ЁжҲ·е®һйҷ…ж¶Ҳиҙ№йўқпјҲеҮҖж¶Ҳиҙ№ = е®һдҫӢж¶Ҳиҙ№ вҲ’ е®һдҫӢзӣёе…ійҖҖж¬ҫпјүгҖӮ
 * еҺҶеҸІдёҠйғЁеҲҶдёҡеҠЎжҠҠ consume.amount еҶҷжҲҗжӯЈж•°пјҢдёҚиғҪзӣҙжҺҘ SUM(amount) еҶҚеҸ–з»қеҜ№еҖјпјҢ
 * еӣ жӯӨдјҳе…ҲдҪҝз”ЁдҪҷйўқеүҚеҗҺе·®йўқпјҢе…је®№жӯЈиҙҹеҸ·дёҚдёҖиҮҙзҡ„еҺҶеҸІж—Ҙеҝ—гҖӮ
 *
 * йҖҖж¬ҫжҢүеҗҢж ·еҸЈеҫ„жүЈеҮҸпјҢдҪҶ**д»…жүЈеҮҸжҢӮдәҶе®һдҫӢзҡ„йҖҖж¬ҫ**пјҲtype='refund' дё” instance_id йқһз©әпјҢ
 * еҚіе®һдҫӢеҲӣе»әеӨұиҙҘиҮӘеҠЁйҖҖж¬ҫгҖҒй”ҖжҜҒйҖҖж¬ҫгҖҒйҷҚзә§йҖҖж¬ҫзӯүж¶Ҳиҙ№еҶІжӯЈпјүгҖӮе……еҖјйҖҖж¬ҫгҖҒз®ЎзҗҶе‘ҳи°ғиҙҰйҖҖж¬ҫ
 * пјҲиө° type='refund' дҪҶж—  instance_idпјүдёҚи®Ўе…ҘпјҢйҒҝе…ҚжҠҠдёҺж¶Ҳиҙ№ж— е…ізҡ„йҖҖж¬ҫй”ҷиҜҜең°д»Һж¶Ҳиҙ№йўқдёӯжүЈжҺүгҖӮ
 * дёҺе®һдҫӢзә§зҡ„ getInstanceRefundableAmountпјҲж¶Ҳиҙ№ вҲ’ йҖҖж¬ҫпјүеҸЈеҫ„дҝқжҢҒдёҖиҮҙпјҢ
 * дҝ®еӨҚгҖҢж¶Ҳиҙ№вҶ’йҖҖж¬ҫвҶ’еҶҚж¶Ҳиҙ№гҖҚж—¶зҙҜи®Ўж¶Ҳиҙ№иў«йҮҚеӨҚи®Ўж•°гҖҒиҝӣиҖҢиҷҡй«ҳеҸҜе…‘жҚўз§ҜеҲҶ/VIP зӯүзә§зҡ„й—®йўҳгҖӮ
 */
export async function getUsersTotalConsumeMap(
  userIds: number[],
  client: BalanceQueryClient = prisma
): Promise<Map<number, number>> {
  const validUserIds = Array.from(new Set(
    userIds.filter(id => Number.isInteger(id) && id > 0)
  ))

  if (validUserIds.length === 0) {
    return new Map()
  }

  const rows = await client.$queryRaw<Array<{ userId: number; totalConsume: unknown }>>(Prisma.sql`
    SELECT
      user_id AS "userId",
      GREATEST(COALESCE(SUM(
        CASE
          WHEN type = 'consume' THEN
            CASE WHEN balance_before > balance_after THEN balance_before - balance_after ELSE ABS(amount) END
          WHEN type = 'refund' THEN
            -1 * (CASE WHEN balance_after > balance_before THEN balance_after - balance_before ELSE ABS(amount) END)
          ELSE 0
        END
      ), 0), 0)::numeric AS "totalConsume"
    FROM balance_logs
    WHERE user_id IN (${Prisma.join(validUserIds)})
      AND (
        type = 'consume'
        OR (type = 'refund' AND instance_id IS NOT NULL)
      )
    GROUP BY user_id
  `)

  return new Map(rows.map(row => [row.userId, toNumber(row.totalConsume)]))
}

export async function getUserTotalConsume(
  userId: number,
  client: BalanceQueryClient = prisma
): Promise<number> {
  const consumeMap = await getUsersTotalConsumeMap([userId], client)
  return consumeMap.get(userId) || 0
}

// ==================== жЈҖжҹҘж“ҚдҪң ====================

/**
 * жЈҖжҹҘз”ЁжҲ·дҪҷйўқжҳҜеҗҰи¶іеӨҹ
 */
export async function hasEnoughBalance(
  userId: number,
  amount: number
): Promise<boolean> {
  const balance = await getUserBalance(userId)
  return balance >= amount
}

/**
 * иҺ·еҸ–з”ЁжҲ·ж¶Ҳиҙ№з»ҹи®Ў
 */
export async function getUserConsumeStats(userId: number): Promise<{
  totalRecharge: number
  totalConsume: number
  totalRefund: number
  totalDestroyedValue: number
}> {
  const [logs, destroyedRefund, totalConsume] = await Promise.all([
    prisma.balanceLog.groupBy({
      by: ['type'],
      where: { userId },
      _sum: { amount: true }
    }),
    prisma.balanceLog.aggregate({
      where: {
        userId,
        type: 'refund',
        amount: { gt: 0 },
        remark: { contains: 'з”ЁжҲ·й”ҖжҜҒе®һдҫӢйҖҖж¬ҫ' }
      },
      _sum: { amount: true }
    }),
    getUserTotalConsume(userId)
  ])

  const stats = {
    totalRecharge: 0,
    totalConsume,
    totalRefund: 0,
    totalDestroyedValue: destroyedRefund._sum.amount !== null && destroyedRefund._sum.amount !== undefined
      ? parseFloat(String(destroyedRefund._sum.amount))
      : 0
  }

