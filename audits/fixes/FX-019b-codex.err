  231: export function calculatePlanChangeDetails(
  232:   oldPrice: number,
  233:   oldBillingCycle: number,
  234:   newPrice: number,
  235:   newBillingCycle: number,
  236:   remainingDays: number,
  237:   discountRate: number,
  238:   paidRemainingValue: number,
  239:   maxPaidAmount: number
  240: ): PlanChangeCalcResult {
  241:   // 计算折扣后的价格
  242:   const actualOldPrice = discountRate > 0
  243:     ? calculateDiscountedPrice(oldPrice, discountRate)
  244:     : oldPrice
  245:   const actualNewPrice = discountRate > 0
  246:     ? calculateDiscountedPrice(newPrice, discountRate)
  247:     : newPrice
  248: 
  249:   // 计算日价
  250:   const oldDailyPrice = calculateDailyPrice(actualOldPrice, oldBillingCycle)
  251:   const newDailyPrice = calculateDailyPrice(actualNewPrice, newBillingCycle)
  252: 
  253:   // 升降级抵扣只认实付账单的未使用价值，并封顶于尚可退的实付总额。
  254:   // paidRemainingValue / maxPaidAmount 由销毁退款的统一账单报价口径提供。
  255:   const remainingValue = Math.min(
  256:     Number(Math.max(0, paidRemainingValue).toFixed(2)),
  257:     Number(Math.max(0, maxPaidAmount).toFixed(2))
  258:   )
  259: 
  260:   // 新方案费用 = 新日价 × 剩余天数
  261:   const newPlanCost = Number((newDailyPrice * remainingDays).toFixed(2))
  262: 
  263:   // 折扣金额（基于新方案原价）
  264:   const discountAmount = discountRate > 0
  265:     ? Number(((newPrice / getCycleDays(newBillingCycle)) * remainingDays * discountRate).toFixed(2))
  266:     : 0
  267: 
  268:   // 差价
  269:   const priceDiff = Number((newPlanCost - remainingValue).toFixed(2))
  270:   const finalPriceDiff = Math.abs(priceDiff) < 0.01 ? 0 : priceDiff
  271: 
  272:   return {
  273:     oldDailyPrice: Number(oldDailyPrice.toFixed(4)),
  274:     newDailyPrice: Number(newDailyPrice.toFixed(4)),
  275:     remainingValue,
  276:     newPlanCost,
  277:     discountAmount,
  278:     priceDiff: finalPriceDiff,
  279:     isUpgrade: newDailyPrice > oldDailyPrice
  280:   }
  281: }
