  724: /**
  725:  * 执行升降级操作（带乐观锁并发控制）
  726:  * 
  727:  * 升级：从余额扣除差价
  728:  * 降级：差价退款到余额
  729:  */
  730: export async function performPlanChange(
  731:   userId: number,
  732:   instance: Instance,
  733:   newPlan: PackagePlan
  734: ): Promise<{
  735:   priceDiff: number
  736:   newConfig: { cpu: number; memory: number; disk: number }
  737:   needRestart: boolean  // 标记是否需要重启
  738:   refundAmount?: number // 降级时的退款金额
  739:   hostingIncomeResult?: { hostOwnerId: number; hostName: string } | null // 托管收入结果
  740:   bandwidthLimit: string | null
  741:   capacity: PlanUpgradeCapacityCheck
  742: }> {
  743:   if (instance.status === 'deleted') {
  744:     throw new Error('实例已删除，无法改配')
  745:   }
  746: 
  747:   const pkg = await prisma.package.findUnique({
  748:     where: { id: newPlan.packageId },
  749:     select: { instanceType: true }
  750:   })
  751:   const isVmPackage = pkg?.instanceType === 'vm'
  752: 
  753:   // 验证
  754:   if (!instance.packagePlanId) {
  755:     throw new Error('免费实例不支持升降级')
  756:   }
  757: 
  758:   // 升降级状态限制：仅 running 和 stopped 可以升降级
  759:   if (!['running', 'stopped'].includes(instance.status)) {
  760:     throw new Error('当前实例状态不允许升降级，仅运行中或已停止的实例可以升降级')
  761:   }
  762: 
  763:   if (newPlan.packageId !== instance.packageId) {
  764:     throw new Error('新方案必须属于同一套餐')
  765:   }
  766:   if (!newPlan.isActive) {
  767:     throw new Error('新方案已下架')
  768:   }
  769:   if (newPlan.isSoldOut) {
  770:     throw new Error('新方案已售罄')
  771:   }
  772:   if (instance.packagePlanId === newPlan.id) {
  773:     throw new Error('不能切换到相同方案')
  774:   }
  775: 
  776:   await assertInstanceNotExchangeLocked(instance.id)
  777: 
  778:   // 计算升级差价
  779:   const changeResult = await calculatePlanChange(instance, newPlan)
  780:   const normalizedPlanTrafficLimitSpeed = normalizePlanTrafficLimitSpeed(newPlan.trafficLimitSpeed)
  781:   if (normalizedPlanTrafficLimitSpeed === undefined) {
  782:     throw new Error('新方案带宽配置无效')
  783:   }
  784: 
  785:   // 检查是否可以变更
  786:   if (!changeResult.canChange) {
  787:     if (changeResult.cannotChangeReason === 'remaining_days_insufficient') {
  788:       throw new Error('剩余时间不足 15 天，无法变更方案')
  789:     }
  790:     throw new Error('当前不能变更方案')
  791:   }
  792: 
  793:   let refundAmount: number | undefined
  794: 
  795:   // 执行事务（带乐观锁）
  796:   const txResult = await prisma.$transaction(async (tx) => {
  797:     if (changeResult.priceDiff !== 0) {
  798:       const balanceLocked = await tryAdvisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, userId)
  799:       if (!balanceLocked) {
  800:         throw new Error('余额正在处理，请稍后重试')
  801:       }
  802:     }
  803: 
  804:     // 获取用户当前余额
  805:     const user = await tx.user.findUnique({
  806:       where: { id: userId },
  807:       select: { balance: true }
  808:     })
  809: 
  810:     if (!user) {
  811:       throw new Error('用户不存在')
  812:     }
  813: 
  814:     const capacity = await reservePlanUpgradeCapacityWithLock(tx, instance, newPlan)
  815:     if (!capacity.canUpgrade) {
  816:       throw new Error(`HOST_RESOURCES_INSUFFICIENT:${capacity.reason || 'unknown'}`)
  817:     }
  818: 
  819:     const oldBalance = Number(user.balance)
  820:     let hostingIncomeResult: { hostOwnerId: number; hostName: string } | null = null
  821: 
  822:     // 升级需要补差价
  823:     if (changeResult.priceDiff > 0) {
  824:       if (oldBalance < changeResult.priceDiff) {
  825:         throw new Error(`余额不足，需补差价 ${changeResult.priceDiff} 元`)
  826:       }
  827: 
  828:       const balanceUpdateResult = await tx.user.updateMany({
  829:         where: { id: userId, balance: { gte: changeResult.priceDiff } },
  830:         data: { balance: { decrement: changeResult.priceDiff } }
  831:       })
  832: 
  833:       if (balanceUpdateResult.count === 0) {
  834:         throw new Error('余额不足或并发冲突')
  835:       }
  836: 
  837:       const updatedUser = await tx.user.findUnique({
  838:         where: { id: userId },
  839:         select: { balance: true }
  840:       })
  841:       if (!updatedUser) {
  842:         throw new Error('用户不存在')
  843:       }
  844:       const newBalance = Number(updatedUser.balance)
  845: 
  846:       // 升级扣费记录
  847:       await tx.balanceLog.create({
  848:         data: {
  849:           userId,
  850:           type: 'consume',
  851:           amount: -changeResult.priceDiff,
  852:           balanceBefore: oldBalance,
  853:           balanceAfter: newBalance,
  854:           instanceId: instance.id,
  855:           remark: `升级方案：${changeResult.oldPlan.name} → ${newPlan.name}`
  856:         }
  857:       })
  858: 
  859:       const hostingOwner = await resolveHostedIncomeOwner(tx, instance.hostId)
  860:       if (hostingOwner) {
  861:         // 用户托管节点，记录托管收入（升级差价，带快照）
  862:         const unfreezeAt = addMonths(new Date(), 1)
  863:         await createHostingLogWithSnapshot(tx, {
  864:           userId: hostingOwner.userId,
  865:           type: 'income',
  866:           actionType: 'upgrade',
  867:           amount: changeResult.priceDiff,
  868:           instanceId: instance.id,
  869:           frozen: true,
  870:           unfreezeAt,
  871:           remark: `用户升级实例方案收入（冻结30天）`
  872:         })
  873:         console.log(`[HostingIncome] 记录升级托管收入: hostOwnerId=${hostingOwner.userId}, amount=${changeResult.priceDiff}, instanceId=${instance.id}`)
  874:         hostingIncomeResult = { hostOwnerId: hostingOwner.userId, hostName: hostingOwner.hostName }
  875:       }
  876:     }
  877: 
  878:     // 降级退款到余额
  879:     if (changeResult.priceDiff < 0) {
  880:       refundAmount = Math.abs(changeResult.priceDiff)
  881: 
  882:       const updatedUser = await tx.user.update({
  883:         where: { id: userId },
  884:         data: { balance: { increment: refundAmount } },
  885:         select: { balance: true }
  886:       })
  887:       const newBalance = Number(updatedUser.balance)
  888: 
  889:       // 降级退款记录
  890:       await tx.balanceLog.create({
  891:         data: {
  892:           userId,
  893:           type: 'refund',
  894:           amount: refundAmount,
  895:           balanceBefore: oldBalance,
  896:           balanceAfter: newBalance,
  897:           instanceId: instance.id,
  898:           remark: `降级方案退款：${changeResult.oldPlan.name} → ${newPlan.name}`
  899:         }
  900:       })
  901:     }
  902: 
  903:     const monthlyTrafficLimit = await resolveInstanceTrafficLimitForHost(tx as any, {
  904:       packageId: instance.packageId,
  905:       hostId: instance.hostId,
  906:       baseTrafficLimit: newPlan.trafficLimit
  907:     })
  908: 
