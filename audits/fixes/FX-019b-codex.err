  611: /**
  612:  * 获取用户消费统计
  613:  */
  614: export async function getUserConsumeStats(userId: number): Promise<{
  615:   totalRecharge: number
  616:   totalConsume: number
  617:   totalRefund: number
  618:   totalDestroyedValue: number
  619: }> {
  620:   const [logs, destroyedRefund, totalConsume] = await Promise.all([
  621:     prisma.balanceLog.groupBy({
  622:       by: ['type'],
  623:       where: { userId },
  624:       _sum: { amount: true }
  625:     }),
  626:     prisma.balanceLog.aggregate({
  627:       where: {
  628:         userId,
  629:         type: 'refund',
  630:         amount: { gt: 0 },
  631:         remark: { contains: '用户销毁实例退款' }
  632:       },
  633:       _sum: { amount: true }
  634:     }),
  635:     getUserTotalConsume(userId)
  636:   ])
  637: 
  638:   const stats = {
  639:     totalRecharge: 0,
  640:     totalConsume,
  641:     totalRefund: 0,
  642:     totalDestroyedValue: destroyedRefund._sum.amount !== null && destroyedRefund._sum.amount !== undefined
  643:       ? parseFloat(String(destroyedRefund._sum.amount))
  644:       : 0
  645:   }
  646: 
  647:   for (const log of logs) {
  648:     // 注意：Prisma aggregate 返回的 Decimal 类型需要先转为字符串再转数字
  649:     const amount = log._sum.amount !== null
  650:       ? parseFloat(String(log._sum.amount))
  651:       : 0
  652:     switch (log.type) {
  653:       case 'recharge':
  654:         stats.totalRecharge = amount
  655:         break
  656:       case 'refund':
  657:         stats.totalRefund = amount
  658:         break
  659:     }
  660:   }
  661: 
  662:   return stats
  663: }
