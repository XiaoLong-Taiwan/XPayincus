  702: export async function getInstanceRefundableAmount(instanceId: number): Promise<number> {
  703:   const [totalConsume, totalRefund] = await Promise.all([
  704:     getInstanceTotalConsume(instanceId),
  705:     getInstanceTotalRefund(instanceId)
  706:   ])
  707:   return Math.max(0, totalConsume - totalRefund)
  708: }
