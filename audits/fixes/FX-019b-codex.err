  145: /**
  146:  * 查询实例的最大可退款金额（基于历史账单）
  147:  * maxRefundable = 历史总消费 - 历史已退
  148:  * lastPaymentAmount = 最近一次付款金额（用于按时间比例退款）
  149:  *
  150:  * @param instanceId 实例 ID
  151:  * @returns { maxRefundable, lastPaymentAmount }
  152:  */
  153: export async function getMaxRefundable(instanceId: number): Promise<{ maxRefundable: number; lastPaymentAmount: number }> {
  154:   const billingLineageInstanceIds = await getInstanceBillingLineageIds(instanceId)
  155:   const instanceIds = billingLineageInstanceIds.length > 0 ? billingLineageInstanceIds : [instanceId]
  156: 
  157:   const [totalConsumed, refundRecords, lastPayment] = await Promise.all([
  158:     prisma.instanceBillingRecord.aggregate({
  159:       where: {
  160:         instanceId: { in: instanceIds },
  161:         type: { in: ['newPurchase', 'renew', 'upgrade'] },
  162:         amount: { gt: 0 }
  163:       },
  164:       _sum: { amount: true }
  165:     }),
  166:     prisma.instanceBillingRecord.findMany({
  167:       where: {
  168:         instanceId: { in: instanceIds },
  169:         type: 'refund'
  170:       },
  171:       select: { amount: true }
  172:     }),
  173:     prisma.instanceBillingRecord.findFirst({
  174:       where: {
  175:         instanceId: { in: instanceIds },
  176:         // 仅查询 newPurchase/renew（upgrade 记录的 amount 是差价，不是完整周期金额）
  177:         type: { in: ['newPurchase', 'renew'] },
  178:         amount: { gt: 0 }
  179:       },
  180:       orderBy: { createdAt: 'desc' },
  181:       select: { amount: true }
  182:     })
  183:   ])
  184: 
  185:   const consumedAmount = totalConsumed._sum?.amount !== null && totalConsumed._sum?.amount !== undefined
  186:     ? parseFloat(String(totalConsumed._sum.amount))
  187:     : 0
  188:   const refundedAmount = refundRecords.reduce((sum, record) => sum + Math.abs(Number(record.amount)), 0)
  189:   const lastPaymentAmount = lastPayment?.amount !== null && lastPayment?.amount !== undefined
  190:     ? parseFloat(String(lastPayment.amount))
  191:     : 0
  192: 
  193:   return {
  194:     maxRefundable: roundCurrency(Math.max(0, consumedAmount - refundedAmount)),
  195:     lastPaymentAmount
  196:   }
  197: }
  198: 
  199: function roundCurrency(value: number): number {
  200:   return Number(value.toFixed(2))
  201: }
  202: 
  203: /**
  204:  * 按账单记录计算实例的剩余价值退款报价
  205:  *
  206:  * 正向计费记录（newPurchase / renew / upgrade）各自对应独立的服务期区间，
  207:  * 退款时应按这些区间的未消耗比例逐条计算，而不是仅依赖实例当前 billingPrice。
  208:  * 这样升级补差价、后续续费、管理员延期等场景都能正确纳入剩余价值。
  209:  */
  210: export async function calculateInstanceRemainingRefundQuote(instance: {
  211:   id: number
  212:   billingPrice: any
  213:   billingCycle: number | null
  214:   expiresAt: Date | null
  215:   packagePlanId: number | null
  216: }): Promise<InstanceRemainingRefundQuote> {
  217:   const isPaid = !!(instance.packagePlanId && instance.expiresAt && instance.billingPrice)
  218: 
  219:   if (!isPaid) {
  220:     return {
  221:       remainingDays: 0,
  222:       remainingValue: 0,
  223:       refundableValue: 0,
  224:       maxRefundable: 0,
  225:       isPaid: false
  226:     }
  227:   }
  228: 
  229:   const now = new Date()
  230:   const expiresAt = new Date(instance.expiresAt!)
  231: 
  232:   if (expiresAt <= now) {
  233:     return {
  234:       remainingDays: 0,
  235:       remainingValue: 0,
  236:       refundableValue: 0,
  237:       maxRefundable: 0,
  238:       isPaid: true
  239:     }
  240:   }
  241: 
  242:   const remainingDays = calculateRemainingDays(expiresAt, now)
  243:   const billingLineageInstanceIds = await getInstanceBillingLineageIds(instance.id)
  244:   const instanceIds = billingLineageInstanceIds.length > 0 ? billingLineageInstanceIds : [instance.id]
  245:   const [maxRefundableInfo, positiveBillingRecords] = await Promise.all([
  246:     getMaxRefundable(instance.id),
  247:     prisma.instanceBillingRecord.findMany({
  248:       where: {
  249:         instanceId: { in: instanceIds },
  250:         type: { in: ['newPurchase', 'renew', 'upgrade'] },
  251:         amount: { gt: 0 }
  252:       },
  253:       select: {
  254:         amount: true,
  255:         periodStart: true,
  256:         periodEnd: true
  257:       },
  258:       orderBy: { periodStart: 'asc' }
  259:     })
  260:   ])
  261:   const { maxRefundable } = maxRefundableInfo
  262: 
  263:   let remainingValue = 0
  264: 
  265:   for (const record of positiveBillingRecords) {
  266:     const periodStart = new Date(record.periodStart)
  267:     const periodEnd = new Date(record.periodEnd)
  268:     const totalMs = periodEnd.getTime() - periodStart.getTime()
  269: 
  270:     if (totalMs <= 0 || periodEnd <= now) {
  271:       continue
  272:     }
  273: 
  274:     const remainingMs = Math.max(0, periodEnd.getTime() - now.getTime())
  275:     const unusedRatio = Math.min(remainingMs / totalMs, 1)
  276:     remainingValue += Number(record.amount) * unusedRatio
  277:   }
  278: 
  279:   remainingValue = roundCurrency(remainingValue)
  280: 
  281:   // 兼容历史/异常数据：如果缺少正向计费记录，则回退到旧逻辑，
  282:   // 避免老实例直接变成 0 退款。
  283:   if (positiveBillingRecords.length === 0 && instance.billingPrice && instance.billingCycle) {
  284:     let discountRate = 0
  285:     const affBinding = await getInstanceAffBinding(instance.id)
  286:     if (affBinding?.affCode?.enabled) {
  287:       discountRate = Number(affBinding.affCode.discountRate) || 0
  288:     }
  289: 
  290:     remainingValue = calculateRemainingValue(
  291:       Number(instance.billingPrice),
  292:       instance.billingCycle,
  293:       remainingDays,
  294:       discountRate
  295:     )
  296:   }
  297: 
  298:   const refundableValue = roundCurrency(Math.min(remainingValue, maxRefundable))
  299: 
  300:   return {
  301:     remainingDays,
  302:     remainingValue,
  303:     refundableValue,
  304:     maxRefundable,
  305:     isPaid: true
  306:   }
  307: }
  308: 
  309: /**
  310:  * 计算实例退款金额（用于节点所有者删除实例时）
  311:  * 节点所有者删除时不收取手续费
  312:  * 
  313:  * @param instance 实例信息（需包含计费相关字段）
  314:  * @returns 退款计算结果
  315:  */
  316: export async function calculateInstanceRefund(instance: {
  317:   id: number
  318:   billingPrice: any
  319:   billingCycle: number | null
  370:  * 1. 原方案日价 = 原方案周期价格 / 原方案周期天数
  371:  * 2. 新方案日价 = 新方案周期价格 / 新方案周期天数
  372:  * 3. 剩余价值 = 原方案日价 × 剩余天数 × (1 - 折扣率)
  373:  * 4. 新方案费用 = 新方案日价 × 剩余天数 × (1 - 折扣率)
  374:  * 5. 差价 = 新方案费用 - 剩余价值
  375:  */
  376: export async function calculatePlanChange(
  377:   instance: Instance,
  378:   newPlan: PackagePlan,
  379:   options: PlanChangeOptions = {}
  380: ): Promise<ChangePlanPreviewResult> {
  381:   const oldPlanId = instance.packagePlanId
  382:   if (!oldPlanId) {
  383:     throw new Error('免费实例不支持升降级')
  384:   }
  385: 
  386:   const oldPlan = await prisma.packagePlan.findUnique({
  387:     where: { id: oldPlanId }
  388:   })
  389: 
  390:   if (!oldPlan) {
  391:     throw new Error('原方案不存在')
  392:   }
  393: 
  394:   const expiresAt = instance.expiresAt!
  395:   const preciseRemainingDays = options.preciseRemainingDays ?? true
  396:   const minRemainingDays = options.minRemainingDays === undefined ? 15 : options.minRemainingDays
  397: 
  398:   // ========== 检查剩余天数 ==========
  399:   let canChange = true
  400:   let cannotChangeReason: string | undefined
  401: 
  402:   // 使用统一方法计算剩余时间；金额口径默认使用精确剩余天数
  403:   const remainingDays = preciseRemainingDays
  404:     ? calculateRemainingDaysPrecise(expiresAt)
  405:     : calculateRemainingDays(expiresAt)
  406: 
  407:   if (minRemainingDays !== null && remainingDays < minRemainingDays) {
  408:     canChange = false
  409:     cannotChangeReason = 'remaining_days_insufficient' // 剩余天数不足
  410:   }
  411: 
  412:   // ========== 获取 AFF 折扣率 ==========
  413:   let discountRate = 0
  414:   const affBinding = await getInstanceAffBinding(instance.id)
  415:   if (affBinding) {
  416:     discountRate = Number(affBinding.affCode.discountRate) || 0
  417:   }
  418: 
  419:   // ========== 使用公共方法计算差价 ==========
  420:   const oldCyclePrice = Number(instance.billingPrice) || 0 // 已是元
  421:   const newCyclePrice = Number(newPlan.price) / 100 // 分转元
  422: 
  423:   // 使用公共方法计算详情
  424:   const calcResult = calculatePlanChangeDetails(
  425:     oldCyclePrice,
  426:     instance.billingCycle || 1,
  427:     newCyclePrice,
  428:     newPlan.billingCycle,
  429:     remainingDays,
  430:     discountRate
  431:   )
  432: 
  433:   return {
  434:     oldPlan,
  435:     newPlan,
  436:     remainingDays,
  437:     oldDailyPrice: calcResult.oldDailyPrice,
  438:     newDailyPrice: calcResult.newDailyPrice,
  439:     remainingValue: calcResult.remainingValue,
  440:     newPlanCost: calcResult.newPlanCost,
  441:     discountRate,
  442:     discountAmount: calcResult.discountAmount,
  443:     priceDiff: calcResult.priceDiff,
  444:     isUpgrade: calcResult.isUpgrade,
  445:     newExpiresAt: expiresAt, // 到期时间保持不变
  446:     newConfig: {
  447:       cpu: newPlan.cpu,
  448:       memory: newPlan.memory,
  449:       disk: newPlan.disk
  450:     },
  451:     canChange,
  452:     cannotChangeReason
  453:   }
  454: }
  455: 
  456: /**
  457:  * 计算管理员调整实例续费价格时的差价结算报价
  458:  * 统一使用精确剩余天数，避免与升级报价口径分叉。
  459:  */
  460: export async function calculateInstancePriceAdjustmentQuote(
  461:   instance: {
  462:     id: number
  463:     billingPrice: any
  464:     billingCycle: number | null
  465:     expiresAt: Date | null
  466:   },
  467:   newPrice: number,
  468:   settleBalance: boolean,
  469:   tx?: Prisma.TransactionClient
  470: ): Promise<InstancePriceAdjustmentQuote> {
  471:   const oldPrice = Number(instance.billingPrice) || 0
  472:   const roundedNewPrice = roundCurrency(newPrice)
  473:   const billingCycle = instance.billingCycle || 1
  474: 
  475:   let discountRate = 0
  476:   const affBinding = await getInstanceAffBinding(instance.id, tx)
  477:   if (affBinding?.affCode?.enabled) {
  478:     discountRate = Number(affBinding.affCode.discountRate) || 0
  479:   }
  480: 
  481:   let remainingDays = 0
  482:   let priceDiff = 0
  483: 
  484:   if (settleBalance && instance.expiresAt) {
  485:     remainingDays = calculateRemainingDaysPrecise(new Date(instance.expiresAt))
  486:     if (remainingDays > 0) {
  487:       priceDiff = calculatePriceDiff(
  488:         oldPrice,
  489:         billingCycle,
  490:         roundedNewPrice,
  491:         billingCycle,
  492:         remainingDays,
  493:         discountRate
  494:       )
  720:     hostingIncomeResult: result.hostingIncomeResult
  721:   }
  722: }
