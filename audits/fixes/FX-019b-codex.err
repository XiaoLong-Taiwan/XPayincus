 3065:   // ==================== 修改实例价格 ====================
 3066: 
 3067:   // POST /api/admin/instances/:id/update-price - 修改实例专属价格
 3068:   app.post('/api/admin/instances/:id/update-price', {
 3069:     onRequest: [app.authenticate, app.requireAdmin],
 3070:     config: { rateLimit: { max: 20, timeWindow: '1 minute' } }
 3071:   }, async (request, reply) => {
 3072:     const admin = request.user!
 3073:     const { id } = request.params as { id: string }
 3074: 
 3075:     if (!request.body || typeof request.body !== 'object') {
 3076:       return reply.status(400).send({ error: '请求参数无效' })
 3077:     }
 3078: 
 3079:     const { newPrice, settleBalance, expectedVersion } = request.body as {
 3080:       newPrice: number  // 新的单周期价格（元）
 3081:       settleBalance: boolean  // 是否结算差价
 3082:       expectedVersion?: number
 3083:     }
 3084: 
 3085:     const instanceId = parsePositiveRouteId(id)
 3086:     if (!instanceId) {
 3087:       return reply.status(400).send({ error: '无效的实例ID' })
 3088:     }
 3089: 
 3090:     // 验证新价格
 3091:     if (typeof newPrice !== 'number' || !Number.isFinite(newPrice) || newPrice < 0 || newPrice > 100000) {
 3092:       return reply.status(400).send({ error: '价格必须是 0-100000 之间的数字' })
 3093:     }
 3094: 
 3095:     if (expectedVersion !== undefined && (!Number.isInteger(expectedVersion) || expectedVersion < 0)) {
 3096:       return reply.status(400).send({ error: '预览版本参数无效' })
 3097:     }
 3098: 
 3099:     try {
 3100:       // 1. 获取实例信息（包含 AFF 绑定）
 3101:       const instance = await prisma.instance.findUnique({
 3102:         where: { id: instanceId },
 3103:         include: {
 3104:           user: { select: { id: true, username: true, balance: true } },
 3105:           packagePlan: { select: { id: true, name: true, price: true, billingCycle: true } },
 3106:           affBinding: {
 3107:             select: {
 3108:               affCode: { select: { discountRate: true, enabled: true } }
 3109:             }
 3110:           }
 3111:         }
 3112:       })
 3113: 
 3114:       if (!instance) {
 3115:         return reply.status(404).send({ error: '实例不存在' })
 3116:       }
 3117: 
 3118:       if (instance.status === 'deleted') {
 3119:         return reply.status(400).send({ error: '实例已删除' })
 3120:       }
 3121: 
 3122:       if (await rejectAdminBillingExchangeLock(reply, instanceId)) return
 3123: 
 3124:       if (!instance.packagePlanId) {
 3125:         return reply.status(400).send({ error: '免费实例不支持修改价格' })
 3126:       }
 3127: 
 3128:       const oldPrice = Number(instance.billingPrice) || 0
 3129:       const roundedNewPrice = Number(newPrice.toFixed(2))
 3130: 
 3131:       if (Number.isInteger(expectedVersion) && instance.version !== expectedVersion) {
 3132:         return reply.status(409).send({ error: '实例计费信息已变化，请刷新后重试' })
 3133:       }
 3134: 
 3135:       // 如果价格没有变化，直接返回
 3136:       if (oldPrice === roundedNewPrice) {
 3137:         return { success: true, message: '价格未变更', priceDiff: 0 }
 3138:       }
 3139: 
 3140:       let priceDiff = 0
 3141:       let remainingDays = 0
 3142:       let billingCycle = instance.billingCycle || 1
 3143: 
 3144:       // 2. 执行事务：重新读取、重新报价、并发检查、价格更新和余额结算
 3145:       await prisma.$transaction(async (tx) => {
 3146:         const currentInstance = await tx.instance.findUnique({
 3147:           where: { id: instanceId },
 3148:           include: {
 3149:             user: { select: { id: true, username: true, balance: true } }
 3150:           }
 3151:         })
 3152: 
 3153:         if (!currentInstance) {
 3154:           throw new BatchPriceUpdateError('实例不存在', 404)
 3155:         }
 3156: 
 3157:         if (currentInstance.status === 'deleted') {
 3158:           throw new BatchPriceUpdateError('实例已删除')
 3159:         }
 3160: 
 3161:         if (!currentInstance.packagePlanId) {
 3162:           throw new BatchPriceUpdateError('免费实例不支持修改价格')
 3163:         }
 3164: 
 3165:         const currentOldPrice = Number(currentInstance.billingPrice) || 0
 3166:         const comparisonVersion = Number.isInteger(expectedVersion) ? expectedVersion : instance.version
 3167:         if (currentOldPrice !== oldPrice || currentInstance.version !== comparisonVersion) {
 3168:           throw new BatchPriceUpdateError('实例计费信息已变化，请刷新后重试', 409)
 3169:         }
 3170: 
 3171:         const quote = await db.calculateInstancePriceAdjustmentQuote(currentInstance, roundedNewPrice, settleBalance, tx)
 3172:         priceDiff = quote.priceDiff
 3173:         remainingDays = quote.remainingDays
 3174:         billingCycle = quote.billingCycle
 3175: 
 3176:         // 检查用户余额（如果需要补交）
 3177:         const userBalance = Number(currentInstance.user!.balance)
 3178:         if (priceDiff > 0 && priceDiff > userBalance) {
 3179:           throw new BatchPriceUpdateError(`用户余额不足，需补交 ¥${priceDiff.toFixed(2)}，当前余额 ¥${userBalance.toFixed(2)}`)
 3180:         }
 3181: 
 3182:         // 更新实例价格
 3183:         const instanceUpdateResult = await tx.instance.updateMany({
 3184:           where: {
 3185:             id: instanceId,
 3186:             version: currentInstance.version
 3187:           },
 3188:           data: {
 3189:             billingPrice: roundedNewPrice,
 3190:             version: { increment: 1 }
 3191:           }
 3192:         })
 3193: 
 3194:         if (instanceUpdateResult.count !== 1) {
 3195:           throw new BatchPriceUpdateError('实例计费信息已变化，请刷新后重试', 409)
 3196:         }
 3197: 
 3198:         // 如果需要结算差价
 3199:         if (settleBalance && priceDiff !== 0) {
 3200:           const balanceLocked = await tryAdvisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, currentInstance.userId)
 3201:           if (!balanceLocked) {
 3202:             throw new BatchPriceUpdateError('用户余额正在处理，请稍后重试', 409)
 3203:           }
 3204: 
 3205:           let balanceBefore = userBalance
 3206:           let balanceAfter = balanceBefore - priceDiff
 3207: 
 3208:           // 更新用户余额
 3209:           if (priceDiff > 0) {
 3210:             const userUpdateResult = await tx.user.updateMany({
 3211:               where: {
 3212:                 id: currentInstance.userId,
 3213:                 balance: { gte: priceDiff }
 3214:               },
 3215:               data: { balance: { decrement: priceDiff } }
 3216:             })
 3217: 
 3218:             if (userUpdateResult.count !== 1) {
 3219:               throw new BatchPriceUpdateError(`用户余额不足，需补交 ¥${priceDiff.toFixed(2)}`)
 3220:             }
 3221: 
 3222:             const updatedUser = await tx.user.findUnique({
 3223:               where: { id: currentInstance.userId },
 3224:               select: { balance: true }
 3225:             })
 3226:             balanceAfter = Number(updatedUser?.balance || 0)
 3227:             balanceBefore = roundMoney(balanceAfter + priceDiff)
 3228:           } else {
 3229:             const updatedUser = await tx.user.update({
 3230:               where: { id: currentInstance.userId },
 3231:               data: { balance: { increment: Math.abs(priceDiff) } },
 3232:               select: { balance: true }
 3233:             })
 3234:             balanceAfter = Number(updatedUser.balance)
 3235:             balanceBefore = roundMoney(balanceAfter - Math.abs(priceDiff))
 3236:           }
 3237: 
 3238:           // 记录余额变动日志
 3239:           const balanceLog = await tx.balanceLog.create({
 3240:             data: {
 3241:               userId: currentInstance.userId,
 3242:               type: priceDiff > 0 ? 'consume' : 'refund',
 3243:               amount: -priceDiff,
 3244:               balanceBefore,
 3245:               balanceAfter,
 3246:               instanceId,
 3247:               remark: priceDiff > 0
 3248:                 ? `管理员调整实例价格，补交差价 ¥${priceDiff.toFixed(2)}`
 3249:                 : `管理员调整实例价格，退还差价 ¥${Math.abs(priceDiff).toFixed(2)}`
