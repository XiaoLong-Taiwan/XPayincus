  230: 
  231: export function calculatePlanChangeDetails(
  232:   oldPrice: number,
  233:   oldBillingCycle: number,
  234:   newPrice: number,
  235:   newBillingCycle: number,
  236:   remainingDays: number,
  237:   discountRate: number = 0
  238: ): PlanChangeCalcResult {
  239:   // 计算折扣后的价格
  240:   const actualOldPrice = discountRate > 0
  241:     ? calculateDiscountedPrice(oldPrice, discountRate)
  242:     : oldPrice
  243:   const actualNewPrice = discountRate > 0
  244:     ? calculateDiscountedPrice(newPrice, discountRate)
  245:     : newPrice
  246: 
  247:   // 计算日价
  248:   const oldDailyPrice = calculateDailyPrice(actualOldPrice, oldBillingCycle)
  249:   const newDailyPrice = calculateDailyPrice(actualNewPrice, newBillingCycle)
  250: 
  251:   // 剩余价值 = 旧日价 × 剩余天数
  252:   const remainingValue = Number((oldDailyPrice * remainingDays).toFixed(2))
  253: 
  254:   // 新方案费用 = 新日价 × 剩余天数
  255:   const newPlanCost = Number((newDailyPrice * remainingDays).toFixed(2))
  256: 
  257:   // 折扣金额（基于新方案原价）
  258:   const discountAmount = discountRate > 0
  259:     ? Number(((newPrice / getCycleDays(newBillingCycle)) * remainingDays * discountRate).toFixed(2))
  260:     : 0
  261: 
  262:   // 差价
  263:   const priceDiff = Number((newPlanCost - remainingValue).toFixed(2))
  264:   const finalPriceDiff = Math.abs(priceDiff) < 0.01 ? 0 : priceDiff
  265: 
  266:   return {
  267:     oldDailyPrice: Number(oldDailyPrice.toFixed(4)),
  268:     newDailyPrice: Number(newDailyPrice.toFixed(4)),
  269:     remainingValue,
