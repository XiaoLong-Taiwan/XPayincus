  543: /**
  544:  * 获取用户实际消费额（净消费 = 实例消费 − 实例相关退款）。
  545:  * 历史上部分业务把 consume.amount 写成正数，不能直接 SUM(amount) 再取绝对值，
  546:  * 因此优先使用余额前后差额，兼容正负号不一致的历史日志。
  547:  *
  548:  * 退款按同样口径扣减，但**仅扣减挂了实例的退款**（type='refund' 且 instance_id 非空，
  549:  * 即实例创建失败自动退款、销毁退款、降级退款等消费冲正）。充值退款、管理员调账退款
  550:  * （走 type='refund' 但无 instance_id）不计入，避免把与消费无关的退款错误地从消费额中扣掉。
  551:  * 与实例级的 getInstanceRefundableAmount（消费 − 退款）口径保持一致，
  552:  * 修复「消费→退款→再消费」时累计消费被重复计数、进而虚高可兑换积分/VIP 等级的问题。
  553:  */
  554: export async function getUsersTotalConsumeMap(
  555:   userIds: number[],
  556:   client: BalanceQueryClient = prisma
  557: ): Promise<Map<number, number>> {
  558:   const validUserIds = Array.from(new Set(
  559:     userIds.filter(id => Number.isInteger(id) && id > 0)
  560:   ))
  561: 
  562:   if (validUserIds.length === 0) {
  563:     return new Map()
  564:   }
  565: 
  566:   const rows = await client.$queryRaw<Array<{ userId: number; totalConsume: unknown }>>(Prisma.sql`
  567:     SELECT
  568:       user_id AS "userId",
  569:       GREATEST(COALESCE(SUM(
  570:         CASE
  571:           WHEN type = 'consume' THEN
  572:             CASE WHEN balance_before > balance_after THEN balance_before - balance_after ELSE ABS(amount) END
  573:           WHEN type = 'refund' THEN
  574:             -1 * (CASE WHEN balance_after > balance_before THEN balance_after - balance_before ELSE ABS(amount) END)
  575:           ELSE 0
  576:         END
  577:       ), 0), 0)::numeric AS "totalConsume"
  578:     FROM balance_logs
  579:     WHERE user_id IN (${Prisma.join(validUserIds)})
  580:       AND (
  581:         type = 'consume'
  582:         OR (type = 'refund' AND instance_id IS NOT NULL)
  583:       )
  584:     GROUP BY user_id
  585:   `)
  586: 
  587:   return new Map(rows.map(row => [row.userId, toNumber(row.totalConsume)]))
  588: }
  589: 
  590: export async function getUserTotalConsume(
  591:   userId: number,
  592:   client: BalanceQueryClient = prisma
  593: ): Promise<number> {
  594:   const consumeMap = await getUsersTotalConsumeMap([userId], client)
  595:   return consumeMap.get(userId) || 0
  596: }
