  665: /**
  666:  * 获取实例的历史消费总额（用于退款上限计算）
  667:  */
  668: export async function getInstanceTotalConsume(instanceId: number): Promise<number> {
  669:   const result = await prisma.balanceLog.aggregate({
  670:     where: {
  671:       instanceId,
  672:       type: 'consume'
  673:     },
  674:     _sum: { amount: true }
  675:   })
  676:   // 注意：Prisma aggregate 返回的 Decimal 类型需要先转为字符串再转数字
  677:   return result._sum.amount !== null
  678:     ? Math.abs(parseFloat(String(result._sum.amount)))
  679:     : 0
  680: }
  681: 
  682: /**
  683:  * 获取实例的历史退款总额
  684:  */
  685: export async function getInstanceTotalRefund(instanceId: number): Promise<number> {
  686:   const result = await prisma.balanceLog.aggregate({
  687:     where: {
  688:       instanceId,
  689:       type: 'refund'
  690:     },
  691:     _sum: { amount: true }
  692:   })
  693:   // 注意：Prisma aggregate 返回的 Decimal 类型需要先转为字符串再转数字
  694:   return result._sum.amount !== null
  695:     ? parseFloat(String(result._sum.amount))
  696:     : 0
  697: }
