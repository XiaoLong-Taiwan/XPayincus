  336: /**
  337:  * 续费费用计算（支持任意月数）
  338:  */
  339: export function calculateRenewBilling(
  340:   instance: { billingPrice: any; billingCycle: number | null; expiresAt: Date | null },
  341:   months: number = 1
  342: ): RenewBillingResult {
  343:   // 验证续费月数范围
  344:   if (months < 1 || months > 24) {
  345:     throw new Error('续费月数必须在 1-24 之间')
  346:   }
  347: 
  348:   const monthlyPrice = calculateMonthlyPrice(instance)
  349:   const amount = Number((monthlyPrice * months).toFixed(2)) // 保留两位小数
  350: 
  351:   // 从当前到期时间续期（如已过期则从现在开始）
  352:   const now = new Date()
  353:   const baseDate = instance.expiresAt && instance.expiresAt > now
  354:     ? instance.expiresAt
  355:     : now
  356: 
  357:   const newExpiresAt = addMonths(baseDate, months)
  358: 
  359:   return { monthlyPrice, months, amount, newExpiresAt }
  360: }
  361: 
  362: // 周期天数常量和 getCycleDays 函数已移至公共模块 billing-calc.ts
  363: // 从 ../lib/billing-calc.js 导入使用
