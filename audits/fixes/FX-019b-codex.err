  365: /**
  366:  * 计算升降级差价（带优惠码折扣和冷却期检查）
  367:  * 使用公共模块 billing-calc.ts 的计算方法确保一致性
  368:  * 
  369:  * 计算公式：
  370:  * 1. 原方案日价 = 原方案周期价格 / 原方案周期天数
  371:  * 2. 新方案日价 = 新方案周期价格 / 新方案周期天数
  372:  * 3. 剩余价值 = 原方案日价 × 剩余天数 × (1 - 折扣率)
  373:  * 4. 新方案费用 = 新方案日价 × 剩余天数 × (1 - 折扣率)
  374:  * 5. 差价 = 新方案费用 - 剩余价值
  456: /**
  457:  * 计算管理员调整实例续费价格时的差价结算报价
  458:  * 统一使用精确剩余天数，避免与升级报价口径分叉。
  459:  */
  460: export async function calculateInstancePriceAdjustmentQuote(
  461:   instance: {
  462:     id: number
  463:     billingPrice: any
  464:     billingCycle: number | null
  465:     expiresAt: Date | null
  466:   },
  467:   newPrice: number,
  468:   settleBalance: boolean,
  469:   tx?: Prisma.TransactionClient
  470: ): Promise<InstancePriceAdjustmentQuote> {
  471:   const oldPrice = Number(instance.billingPrice) || 0
  472:   const roundedNewPrice = roundCurrency(newPrice)
  473:   const billingCycle = instance.billingCycle || 1
  474: 
  475:   let discountRate = 0
  476:   const affBinding = await getInstanceAffBinding(instance.id, tx)
  477:   if (affBinding?.affCode?.enabled) {
  478:     discountRate = Number(affBinding.affCode.discountRate) || 0
  479:   }
  480: 
  481:   let remainingDays = 0
  482:   let priceDiff = 0
  483: 
  484:   if (settleBalance && instance.expiresAt) {
  485:     remainingDays = calculateRemainingDaysPrecise(new Date(instance.expiresAt))
  486:     if (remainingDays > 0) {
  487:       priceDiff = calculatePriceDiff(
  488:         oldPrice,
  489:         billingCycle,
  490:         roundedNewPrice,
  491:         billingCycle,
  492:         remainingDays,
  493:         discountRate
  494:       )
  495:     }
  496:   }
  497: 
  498:   return {
  499:     oldPrice,
  500:     newPrice: roundedNewPrice,
  501:     billingCycle,
  502:     remainingDays,
  503:     discountRate,
  504:     priceDiff
  505:   }
  506: }
