  169: export default async function ticketsRoutes(fastify: FastifyInstance) {
  170: 
  171:   // ==================== 用户端 API ====================
  172: 
  173:   /**
  174:    * 创建工单
  175:    * POST /tickets
  176:    * instanceId 可选：如果不选实例，工单直接发给管理员
  177:    */
  178:   fastify.post('/', {
  179:     onRequest: [fastify.authenticate],
  180:     bodyLimit: TICKET_UPLOAD_BODY_LIMIT
  181:   }, async (request: FastifyRequest, reply: FastifyReply) => {
  182:     const { user } = request
  183:     let uploadedAttachments: ticketDb.CreateTicketMessageAttachmentData[] = []
  184: 
  185:     try {
  186:       if (!await db.getSystemConfigBoolean('ticket_enabled', true)) {
  187:         return reply.code(403).send(apiError(ErrorCode.FORBIDDEN, 'Ticket creation is disabled'))
  188:       }
  189: 
  190:       const payload = await readTicketPayload(request)
  191:       const instanceId = parseOptionalPositiveId(payload.fields.instanceId)
  192:       const subject = sanitizeContent(payload.fields.subject)
  193:       const category = sanitizeContent(payload.fields.category)
  194:       const priority = sanitizeContent(payload.fields.priority) as TicketPriority
  195:       const content = sanitizeContent(payload.fields.content)
  196: 
  197:       if (instanceId === null) {
  198:         return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
  199:       }
  200: 
  201:       // 输入验证
  202:       if (!subject || subject.length < 2 || subject.length > 200) {
  203:         return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Subject must be 2-200 characters'))
  204:       }
  205:       if (content.length > 5000) {
  206:         return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Content must be 0-5000 characters'))
  207:       }
  208:       if (payload.images.length === 0 && content.length < 10) {
  209:         return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Content must be 10-5000 characters when no images are attached'))
  210:       }
  211:       if (category && !VALID_CATEGORIES.includes(category)) {
  212:         return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid category'))
  213:       }
  214:       if (priority && !VALID_PRIORITIES.includes(priority)) {
  215:         return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid priority'))
  216:       }
  217: 
  218:       let hostId: number | null = null
  219:       let instance: Awaited<ReturnType<typeof db.getInstanceById>> | null = null
  220:       let host: Awaited<ReturnType<typeof getTicketHostOwnership>> | null = null
  221: 
  222:       // 如果选择了实例，验证实例存在且属于该用户
  223:       if (instanceId !== undefined) {
  224:         instance = await db.getInstanceById(instanceId)
  225:         if (!instance || instance.user_id !== user.id) {
  226:           return reply.code(400).send(apiError(ErrorCode.INSTANCE_NOT_FOUND))
  227:         }
  228:         hostId = instance.host_id
  229: 
  230:         // 检查宿主机是否存在
  231:         host = await getTicketHostOwnership(hostId)
  232:         if (!host) {
  233:           return reply.code(404).send(apiError(ErrorCode.HOST_NOT_FOUND))
  234:         }
  235:       }
  236: 
  237:       if (payload.images.length > 0) {
  238:         uploadedAttachments = await uploadTicketImages(payload.images)
  239:       }
  240: 
  241:       // 创建工单（instanceId 和 hostId 可以为 null，表示直接发给管理员）
  242:       const result = await ticketDb.createTicket({
  243:         userId: user.id,
  244:         hostId,
  245:         instanceId: instanceId ?? null,
  246:         subject,
  247:         category: category || 'general',
  248:         priority: priority || 'normal',
  249:         content,
  250:         attachments: uploadedAttachments
  251:       })
  252: 
  253:       // 发送通知：如果是用户托管节点的实例，发送给节点所有者；否则发送给管理员
  254:       try {
  255:         if (host && host.user.role !== 'admin') {
  256:           // 用户托管节点：发送通知给节点所有者
  257:           await sendNotification(host.userId, 'ticket_created', {
  258:             username: user.username,
  259:             subject,
  260:             hostName: host.name,
  261:             instanceName: instance?.name || '无'
  262:           })
  263:         } else {
  264:           // 官方节点或未选择实例：发送通知给所有管理员
  265:           const adminIds = await getAllAdminUserIds()
  266:           for (const adminId of adminIds) {
  267:             await sendNotification(adminId, 'ticket_created', {
  268:               username: user.username,
  269:               subject,
  270:               hostName: host?.name || '系统',
  271:               instanceName: instance?.name || '无'
  272:             })
  273:           }
  274:         }
  275:       } catch (err) {
  276:         console.error('[Tickets] Failed to send notification:', err)
  277:       }
  278: 
  279:       emitPluginEvent('ticket.created', {
  280:         dedupeKey: `ticket.created:${result.ticketId}:${result.messageId}`,
  281:         ticketId: result.ticketId,
  282:         messageId: result.messageId,
  283:         userId: user.id,
  284:         username: user.username,
  285:         subject,
  286:         category: category || 'general',
  287:         priority: priority || 'normal',
  288:         instanceId: instanceId ?? null,
  289:         hostId,
  290:         attachmentCount: uploadedAttachments.length
  291:       }, { id: user.id, role: user.role, username: user.username }, { dedupeKey: `ticket.created:${result.ticketId}:${result.messageId}` })
  292: 
  293:       return reply.code(201).send({
  294:         message: 'Ticket created successfully',
  295:         ticket: {
  296:           id: result.ticketId,
  297:           messageId: result.messageId
  298:         }
  299:       })
  300:     } catch (error: any) {
  301:       if (uploadedAttachments.length > 0) {
  302:         await cleanupUploadedTicketImages(uploadedAttachments)
  303:       }
  304:       if (!isHandledTicketPayloadError(error)) {
  305:         throw error
  306:       }
  307:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, error?.message || 'Invalid ticket payload'))
  308:     }
  309:   })
  310: 
  311:   /**
  312:    * 获取我的工单列表
  313:    * GET /tickets
  314:    * 支持 active 状态筛选（排除已关闭）、搜索
  315:    */
