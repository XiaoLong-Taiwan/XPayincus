 1304:  * 避免多进程调度或重复启动时对已经被其他进程关闭的工单重复通知。
 1305:  */
 1306: export async function autoCloseTickets(
 1307:   ticketIds: number[],
 1308:   timeoutMs: number = 24 * 60 * 60 * 1000
 1309: ): Promise<AutoClosedTicket[]> {
 1310:   if (ticketIds.length === 0) return []
 1311: 
 1312:   const uniqueTicketIds = [...new Set(ticketIds)]
 1313:   const closedTickets: AutoClosedTicket[] = []
 1314:   const cutoffTime = new Date(Date.now() - timeoutMs)
