  691: // Reply
  692: async function handleReply() {
  693:   if (!selectedTicket.value) return
  694:   if (!replyContent.value.trim() && replyAttachments.value.length === 0) return
  695:   
  696:   replying.value = true
  697:   try {
  698:     const res = await api.tickets.reply(selectedTicket.value.id, replyContent.value.trim(), replyAttachments.value)
  699:     messages.value.push(res.data)
  700:     messagesTotal.value++
  701:     await ensureMessageAttachmentUrls([res.data])
  702:     replyContent.value = ''
  703:     replyAttachments.value = []
  704:     toast.success(t('tickets.replySuccess'))
  705:     if (authStore.isAdmin) {
  706:       await loadSupportContext()
  707:     }
  708:     // Scroll to bottom
  709:     await nextTick()
  710:     const container = document.getElementById('messages-container')
  711:     if (container) container.scrollTop = container.scrollHeight
  712:   } catch (error: any) {
  713:     toast.error(error?.message || t('common.error'))
  714:   } finally {
  715:     replying.value = false
  716:   }
  717: }
  718: 
  719: // Status update
  720: async function updateStatus(status: TicketStatus) {
  721:   if (!selectedTicket.value) return
  722:   
  723:   try {
  724:     await api.tickets.updateStatus(selectedTicket.value.id, status)
  725:     selectedTicket.value.status = status
  726:     toast.success(t('tickets.statusUpdated'))
  727:     loadPendingCount()
  728:     loadTickets(true)
  729:     if (authStore.isAdmin) {
  730:       await loadSupportContext()
  731:     }
  732:   } catch (error: any) {
  733:     toast.error(error?.message || t('common.error'))
  734:   }
  735: }
  736: 
  737: // Close ticket
  738: async function closeTicket() {
  739:   if (!selectedTicket.value) return
  740:   if (!confirm(t('tickets.confirmCloseHint'))) return
  741:   
  742:   try {
  743:     await api.tickets.close(selectedTicket.value.id)
  744:     selectedTicket.value.status = 'closed'
  745:     toast.success(t('tickets.closeSuccess'))
  746:     loadPendingCount()
  747:     loadTickets(true)
  748:     if (authStore.isAdmin) {
  749:       await loadSupportContext()
  750:     }
  751:   } catch (error: any) {
  752:     toast.error(error?.message || t('common.error'))
  753:   }
  754: }
  755: 
  756: // Delete message (仅管理员)
  757: async function confirmDeleteMessage(message: TicketMessage) {
  758:   if (!selectedTicket.value) return
  759:   if (!confirm(t('tickets.confirmDeleteMessage'))) return
  760:   
  761:   try {
  762:     await api.tickets.deleteMessage(selectedTicket.value.id, message.id)
  763:     // 从列表中移除已删除的消息
  764:     messages.value = messages.value.filter(m => m.id !== message.id)
  765:     messagesTotal.value--
  766:     toast.success(t('tickets.deleteMessageSuccess'))
  767:   } catch (error: any) {
  768:     toast.error(error?.message || t('common.error'))
  769:   }
  770: }
  771: 
