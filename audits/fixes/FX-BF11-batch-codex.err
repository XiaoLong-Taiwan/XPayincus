+
+  try {
+    await api.tickets.updateStatus(selectedTicket.value.id, 'open')
+    selectedTicket.value.status = 'open'
+    toast.success(t('tickets.reopenSuccess'))
+    loadPendingCount()
+    loadTickets(true)
+  } catch (error: any) {
+    toast.error(error?.message || t('common.error'))
+  }
+}
