   49: async function getTicketHostOwnership(hostId: number | null | undefined) {
   50:   if (!hostId) return null
   51: 
   52:   return prisma.host.findUnique({
   53:     where: { id: hostId },
   54:     select: {
   55:       id: true,
   56:       name: true,
   57:       userId: true,
   58:       user: {
   59:         select: {
   60:           role: true
   61:         }
   62:       }
   63:     }
   64:   })
   65: }
   66: 
   67: // å·¥å•åˆ†ç±»
   68: const VALID_CATEGORIES = ['general', 'billing', 'technical', 'abuse']
   69: 
   70: // å·¥å•ä¼˜å…ˆçº§
   71: const VALID_PRIORITIES: TicketPriority[] = ['low', 'normal', 'high', 'urgent']
   72: 
   73: // å·¥å•çŠ¶æ€
   74: const VALID_STATUSES: TicketStatus[] = ['open', 'in_progress', 'resolved', 'closed']
   75: 
   76: // æ‰©å±•çš„çŠ¶æ€ç±»åž‹ï¼ˆåŒ…å« activeï¼‰
   77: type ExtendedTicketStatus = TicketStatus | 'active'
   78: 
   79: const TICKET_PROXY_FETCH_TIMEOUT_MS = 15_000
   80: const POSITIVE_INTEGER_ID_RE = /^[1-9]\d*$/
   81: 
   82: function normalizeAllowedImageMimeType(value: string | null | undefined): string | null {
   83:   const normalized = value?.split(';')[0]?.trim().toLowerCase()
   84:   return normalized && ALLOWED_IMAGE_MIME_TYPES.has(normalized) ? normalized : null
   85: }
   86: 
   87: function parsePositiveId(value: unknown): number | null {
   88:   if (typeof value === 'number') {
   89:     return Number.isSafeInteger(value) && value > 0 ? value : null
   90:   }
   91: 
   92:   if (typeof value !== 'string' || !POSITIVE_INTEGER_ID_RE.test(value)) {
   93:     return null
   94:   }
   95: 
   96:   const parsed = Number(value)
   97:   return Number.isSafeInteger(parsed) ? parsed : null
   98: }
   99: 
  100: function parseOptionalPositiveId(value: unknown): number | undefined | null {
  101:   if (value === undefined || value === null || value === '') {
  102:     return undefined
  103:   }
  104: 
  105:   return parsePositiveId(value)
  106: }
  107: 
  108: function parsePositiveInteger(value: unknown, fallback: number, max?: number): number {
  109:   const parsed = Number(value)
  110:   if (!Number.isInteger(parsed) || parsed <= 0) {
  111:     return fallback
  112:   }
  113: 
  114:   return max === undefined ? parsed : Math.min(parsed, max)
  115: }
  116: 
  117: function sanitizeContent(value: string | undefined): string {
  118:   return typeof value === 'string' ? value.trim() : ''
  119: }
  120: 
  121: function normalizeTicketStatusBody(body: unknown): TicketStatus | null {
  122:   if (!body || typeof body !== 'object' || Array.isArray(body)) {
  123:     return null
  124:   }
  125: 
  126:   const { status } = body as { status?: unknown }
  127:   return typeof status === 'string' && VALID_STATUSES.includes(status as TicketStatus)
  128:     ? status as TicketStatus
  129:     : null
  130: }
  131: 
  132: async function readRemoteImageBody(response: Response): Promise<Buffer> {
  133:   const contentLength = Number(response.headers.get('content-length') || '0')
  134:   if (Number.isFinite(contentLength) && contentLength > MAX_TICKET_IMAGE_SIZE) {
  135:     throw new Error('Remote image is too large')
  136:   }
  137: 
  138:   if (!response.body) {
  139:     const buffer = Buffer.from(await response.arrayBuffer())
  140:     if (buffer.length > MAX_TICKET_IMAGE_SIZE) {
  141:       throw new Error('Remote image is too large')
  142:     }
  143:     return buffer
  144:   }
  145: 
  146:   const reader = response.body.getReader()
  147:   const chunks: Buffer[] = []
  148:   let totalBytes = 0
  149: 
  150:   try {
  151:     while (true) {
  152:       const { done, value } = await reader.read()
  153:       if (done) break
  154:       const chunk = Buffer.from(value)
  155:       totalBytes += chunk.length
  156:       if (totalBytes > MAX_TICKET_IMAGE_SIZE) {
  157:         throw new Error('Remote image is too large')
  158:       }
  159:       chunks.push(chunk)
  160:     }
  161:   } catch (error) {
  162:     await reader.cancel().catch(() => undefined)
  163:     throw error
  164:   }
  165: 
  166:   return Buffer.concat(chunks, totalBytes)
  167: }
