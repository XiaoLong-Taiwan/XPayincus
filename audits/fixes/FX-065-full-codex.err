  294: function gbToBytes(gb: string | number): string | null {
  295:   if (gb === '' || gb === null || gb === undefined) return null
  296:   const str = String(gb).trim()
  297:   if (str === '') return null
  298:   const num = parseFloat(str)
  299:   if (isNaN(num) || num <= 0) return null
  300:   return (BigInt(Math.round(num)) * GB_TO_BYTES).toString()
  301: }
  302: 
  303: function normalizeTrafficMultiplier(value: unknown): number {
  304:   const num = Number(value)
  305:   if (!Number.isFinite(num) || num <= 0) return 1
  306:   return Math.round(Math.min(Math.max(num, 0.001), 100) * 1000) / 1000
  307: }
  308: 
  309: function normalizeMoneyCents(value: unknown): number | null {
  310:   const amount = Number(value)
  311:   if (!Number.isFinite(amount) || amount < 0 || amount > MAX_TRAFFIC_RESET_PRICE) {
  312:     return null
  313:   }
  314:   const cents = amount * 100
  315:   if (Math.abs(cents - Math.round(cents)) >= 1e-8) {
  316:     return null
  317:   }
  318:   return Math.round(cents)
  319: }
