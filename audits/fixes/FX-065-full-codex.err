diff --git a/server/prisma/migrations/20260712000000_traffic_reset_price_to_yuan/migration.sql b/server/prisma/migrations/20260712000000_traffic_reset_price_to_yuan/migration.sql
new file mode 100644
index 0000000000000000000000000000000000000000..1960f0ee705eb12caf66c938b8963275500c395d
--- /dev/null
+++ b/server/prisma/migrations/20260712000000_traffic_reset_price_to_yuan/migration.sql
@@ -0,0 +1,8 @@
+-- FX-065: traffic_reset_price 统一从“分”换算为“元”。
+UPDATE "packages"
+SET "traffic_reset_price" = "traffic_reset_price" / 100
+WHERE "traffic_reset_price" IS NOT NULL;
+
+UPDATE "package_plans"
+SET "traffic_reset_price" = "traffic_reset_price" / 100
+WHERE "traffic_reset_price" IS NOT NULL;
