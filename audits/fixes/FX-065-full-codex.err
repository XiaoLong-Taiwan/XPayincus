+  if (!Number.isFinite(price) || price < 0 || price > MAX_PACKAGE_PLAN_PRICE) {
+    return null
+  }
+
+  const rounded = Math.round(price * 100) / 100
+  return Math.abs(price - rounded) < 1e-8 ? rounded : null
+}
