  196:   const uniqueHostIds = [...new Set(hostIds.filter(id => Number.isInteger(id) && id > 0))]
  197:   if (uniqueHostIds.length === 0) {
  198:     return []
  199:   }
  200: 
  201:   const hosts = await prisma.host.findMany({
  202:     where: { id: { in: uniqueHostIds } },
  203:     select: { id: true, name: true }
  204:   })
  205:   const hostNameById = new Map(hosts.map(host => [host.id, host.name]))
  206:   const unavailable: Array<{ id: number; name: string; reason: string }> = []
  207: 
  208:   for (const hostId of uniqueHostIds) {
  209:     const hostName = hostNameById.get(hostId) || `#${hostId}`
  210:     const explicitPool = options.hostStoragePools?.[String(hostId)]
  211: 
  212:     if (explicitPool !== undefined) {
  213:       if (explicitPool) {
  214:         const ok = await db.isSystemDiskPool(hostId, explicitPool)
  215:         if (!ok) {
  216:           unavailable.push({ id: hostId, name: hostName, reason: `存储池 ${explicitPool} 不存在或不是系统盘池` })
  217:         }
  218:       } else {
  219:         const fallbackPool = await db.getRandomSystemDiskPool(hostId)
  220:         if (!fallbackPool) {
  221:           unavailable.push({ id: hostId, name: hostName, reason: '未配置系统盘存储池' })
  222:         }
  223:       }
  224:       continue
  225:     }
  226: 
  227:     const resolvedPool = await db.resolveStoragePoolForNewInstance(hostId, {
  228:       packageId: options.packageId
  229:     })
  230:     if (!resolvedPool) {
  231:       unavailable.push({ id: hostId, name: hostName, reason: '未配置系统盘存储池' })
  232:     }
  233:   }
  234: 
  235:   return unavailable
  236: }
