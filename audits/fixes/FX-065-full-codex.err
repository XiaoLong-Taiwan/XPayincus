+    routeSource.includes('const rateKeys = [AFF_COMMISSION_RATE_CONFIG_KEY, AFF_DISCOUNT_RATE_CONFIG_KEY]') &&
+    routeSource.includes('const rate = parseRateConfig(config.value, max)'),
