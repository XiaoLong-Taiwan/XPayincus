  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  domain      MailDomain  @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@unique([domainId, username])
  @@index([domainId])
  @@map("mail_accounts")
}

