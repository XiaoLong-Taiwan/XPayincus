+    const username = typeof user.userName === 'string' ? user.userName.trim() : ''
+    const diskUsedMb = parseDiskUsageMb(user.mailboxSizeUsed)
+    return username && diskUsedMb !== undefined ? [{ username, diskUsedMb }] : []
+  })
+}

