+/**
+ * 获取域下各邮箱账户的上游实际磁盘用量。
+ */
+export async function listAccountUsage(
+  source: MailSource,
+  domain: string,
+  adminUsername: string,
+  adminPassword: string
+): Promise<Array<{ username: string; diskUsedMb: number }>> {
