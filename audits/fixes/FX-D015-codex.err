 4916:           let explicitBatchIpv6 = (host as any).nat_bind_ipv6 || host.nat_public_ipv6 || host.ipv6_gateway || (host.ip_address?.includes(':') ? host.ip_address : null);
 4917:           if (!explicitBatchIpv6 && host) {
