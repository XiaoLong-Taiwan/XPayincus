 4819:         conflicts.forEach(c => allConflicts.push({ publicPort: c.port, protocol: proto }))
 4820:       }
 4821: 
 4822:       if (allConflicts.length > 0) {
 4823:         // åŽ»é‡å¹¶èŽ·å–å»ºè®®ç«¯å£
 4824:         const conflictPorts = [...new Set(allConflicts.map(c => c.publicPort))]
 4825:         const suggestedPorts = await db.suggestAvailablePorts(
 4826:           instance.host_id,
 4827:           conflictPorts.length,
 4828:           protocol === 'both' ? 'tcp' : protocol,
 4829:           publicPorts.filter(p => !conflictPorts.includes(p)),
 4830:           protocol === 'both'  // Both æ¨¡å¼éœ€è¦åŒæ—¶æ£€æŸ¥ TCP å’Œ UDP
 4831:         )
 4832: 
 4833:         const conflictsWithSuggestions = conflictPorts.map((port, index) => ({
 4834:           publicPort: port,
 4835:           suggestedPort: suggestedPorts[index] || null
 4836:         }))
 4837: 
 4838:         return reply.code(409).send({
 4839:           error: ErrorCode.PORT_CONFLICT,
 4840:           message: 'éƒ¨åˆ†ç«¯å£å·²è¢«å ç”¨',
