 4708:       privatePortStart: number
 4709:       privatePortEnd: number
 4710:       publicPortStart?: number
 4711:       publicPortEnd?: number
 4712:       remark?: string
 4713:       portMappings?: Array<{ privatePort: number; publicPort: number }>
 4714:     }
 4715:   }>, reply: FastifyReply) => {
 4716:     const { id } = request.params
 4717:     const instanceId = parsePositiveRouteId(id)
 4718: 
 4719:     if (!instanceId) {
 4720:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 4721:     }
 4722: 
 4723:     const { protocol, privatePortStart, privatePortEnd, publicPortStart, publicPortEnd, remark, portMappings } = request.body
 4724:     const { user } = request
 4725: 
 4726:     // 1. 验证实例
 4727:     const instance = await db.getInstanceById(instanceId)
 4728:     if (!instance) {
 4729:       return reply.code(404).send(apiError(ErrorCode.INSTANCE_NOT_FOUND))
 4730:     }
 4731: 
 4732:     if (instance.user_id !== user.id) {
 4733:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 4734:     }
 4735: 
 4736:     // 封停状态不允许添加端口映射
 4737:     if (instance.status === 'suspended') {
 4738:       if (instance.suspend_reason === 'expired') {
 4739:         return reply.code(403).send(apiError(ErrorCode.INSTANCE_SUSPENDED_EXPIRED))
 4740:       }
 4741:       return reply.code(403).send(apiError(ErrorCode.INSTANCE_SUSPENDED))
 4742:     }
 4743: 
 4744:     if (!['nat', 'nat_ipv6', 'nat_ipv6_nat'].includes(instance.network_mode)) {
 4745:       return reply.code(400).send(apiError(ErrorCode.PORT_MAPPING_NAT_ONLY))
 4746:     }
 4747: 
 4748:     // 检查转移锁定
 4749:     if (await checkTransferLock(instanceId, reply)) return
 4750: 
 4751:     const portLockKey = getInstancePortMappingLockKey(instanceId)
 4752:     const portLock = await acquireLock(portLockKey, PORT_MAPPING_LOCK_OPTIONS)
 4753:     if (!portLock.success || !portLock.ownerId) {
 4754:       return reply.code(409).send(apiError(ErrorCode.PORT_CONFLICT, 'Port mapping operation is busy, please retry later'))
 4755:     }
 4756: 
 4757:     try {
 4758:     // 2. 计算端口数量
 4759:     const privatePortCount = privatePortEnd - privatePortStart + 1
 4760:     if (privatePortCount <= 0 || privatePortCount > 100) {
 4761:       return reply.code(400).send({ error: '端口范围无效，最多支持 100 个连续端口' })
 4762:     }
 4763: 
 4764:     // 3. 检查配额
 4765:     // TCP/UDP 各占 1 个配额，Both 占 2 个配额
 4766:     const quotaNeeded = protocol === 'both' ? privatePortCount * 2 : privatePortCount
 4767:     const quotaCheck = await db.checkPortQuota(instance.user_id, instanceId)
 4768:     const remainingQuota = quotaCheck.limit - quotaCheck.current
 4769: 
 4770:     if (remainingQuota < quotaNeeded) {
 4771:       return reply.code(400).send({
 4772:         error: ErrorCode.QUOTA_PORT_BATCH_EXCEEDED,
 4773:         message: `配额不足，需要 ${quotaNeeded} 个，剩余 ${remainingQuota} 个`,
 4774:         needed: quotaNeeded,
 4775:         remaining: remainingQuota
 4776:       })
 4777:     }
 4778: 
 4779:     const host = await db.getHostById(instance.host_id)
 4780:     if (!host) {
 4781:       return reply.code(404).send(apiError(ErrorCode.HOST_NOT_FOUND))
 4782:     }
 4783: 
 4784:     // 4. 确定映射关系
 4785:     let finalMappings: Array<{ privatePort: number; publicPort: number }> = []
 4786: 
 4787:     if (portMappings && portMappings.length > 0) {
 4788:       // 使用用户提供的映射（冲突解决后重新提交）
 4789:       finalMappings = portMappings
 4790:     } else if (publicPortStart !== undefined && publicPortEnd !== undefined) {
 4791:       // 用户指定了公网端口范围
 4792:       const publicPortCount = publicPortEnd - publicPortStart + 1
 4793:       if (publicPortCount !== privatePortCount) {
 4794:         return reply.code(400).send(apiError(ErrorCode.PORT_RANGE_MISMATCH, `内网 ${privatePortCount} 个端口，公网 ${publicPortCount} 个端口`))
 4795:       }
 4796: 
 4797:       // 检查公网端口范围是否在允许范围内
 4798:       if (host.nat_port_start && host.nat_port_end) {
 4799:         if (publicPortStart < host.nat_port_start || publicPortEnd > host.nat_port_end) {
 4800:           return reply.code(400).send(apiError(ErrorCode.PORT_RANGE_INVALID, `允许范围: ${host.nat_port_start}-${host.nat_port_end}`))
 4801:         }
 4802:       }
 4803: 
 4804:       // 生成映射关系
 4805:       for (let i = 0; i < privatePortCount; i++) {
 4806:         finalMappings.push({
 4807:           privatePort: privatePortStart + i,
 4808:           publicPort: publicPortStart + i
 4809:         })
 4810:       }
 4811: 
 4812:       // 5. 检查端口冲突（需要检查 TCP 和 UDP）
 4813:       const publicPorts = finalMappings.map(m => m.publicPort)
 4814:       const protocolsToCheck: Array<'tcp' | 'udp'> = protocol === 'both' ? ['tcp', 'udp'] : [protocol]
 4815: 
 4816:       const allConflicts: Array<{ publicPort: number; protocol: string }> = []
 4817:       for (const proto of protocolsToCheck) {
 4818:         const conflicts = await db.checkPortsInUse(instance.host_id, publicPorts, proto)
 4819:         conflicts.forEach(c => allConflicts.push({ publicPort: c.port, protocol: proto }))
 4820:       }
 4821: 
 4822:       if (allConflicts.length > 0) {
 4823:         // 去重并获取建议端口
 4824:         const conflictPorts = [...new Set(allConflicts.map(c => c.publicPort))]
 4825:         const suggestedPorts = await db.suggestAvailablePorts(
 4826:           instance.host_id,
 4827:           conflictPorts.length,
 4828:           protocol === 'both' ? 'tcp' : protocol,
 4829:           publicPorts.filter(p => !conflictPorts.includes(p)),
 4830:           protocol === 'both'  // Both 模式需要同时检查 TCP 和 UDP
 4831:         )
 4832: 
 4833:         const conflictsWithSuggestions = conflictPorts.map((port, index) => ({
 4834:           publicPort: port,
 4835:           suggestedPort: suggestedPorts[index] || null
 4836:         }))
 4837: 
 4838:         return reply.code(409).send({
 4839:           error: ErrorCode.PORT_CONFLICT,
 4840:           message: '部分端口已被占用',
 4841:           conflicts: conflictsWithSuggestions,
 4842:           availableCount: suggestedPorts.length
 4843:         })
 4844:       }
 4845:     } else {
 4846:       // 公网端口留空，自动分配
 4847:       const protocolForAlloc = protocol === 'both' ? 'tcp' : protocol
 4848:       const allocatedPorts = await db.allocatePorts(
 4849:         instance.host_id,
 4850:         privatePortCount,
 4851:         protocolForAlloc,
 4852:         protocol === 'both'  // Both 模式需要同时检查 TCP 和 UDP
