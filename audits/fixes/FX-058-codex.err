+                    console.log(`[Traffic] Sent warning to user ${instance.userId}`)
+                } else {
+                    await releaseUserTrafficWarningLease(
+                        instance.userId,
+                        claimedAt,
+                        userQuota.trafficWarningSentAt,
+                        userQuota.trafficStatus
