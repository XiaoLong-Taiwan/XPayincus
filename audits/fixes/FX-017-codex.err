    if (!domain || domain.subscription.userId !== request.user.id) {
      return reply.code(404).send(apiError(ErrorCode.NOT_FOUND, 'åŸŸåä¸å­˜åœ¨'))
    }

    const account = await db.getMailAccountById(accountId)
