  145: /**
  146:  * 查询实例的最大可退款金额（基于历史账单）
  147:  * maxRefundable = 历史总消费 - 历史已退
  148:  * lastPaymentAmount = 最近一次付款金额（用于按时间比例退款）
  149:  *
  150:  * @param instanceId 实例 ID
  151:  * @returns { maxRefundable, lastPaymentAmount }
  152:  */
  153: export async function getMaxRefundable(instanceId: number): Promise<{ maxRefundable: number; lastPaymentAmount: number }> {
  154:   const billingLineageInstanceIds = await getInstanceBillingLineageIds(instanceId)
  155:   const instanceIds = billingLineageInstanceIds.length > 0 ? billingLineageInstanceIds : [instanceId]
  156: 
  157:   const [totalConsumed, refundRecords, lastPayment] = await Promise.all([
  158:     prisma.instanceBillingRecord.aggregate({
  159:       where: {
  160:         instanceId: { in: instanceIds },
  161:         type: { in: ['newPurchase', 'renew', 'upgrade'] },
  162:         amount: { gt: 0 }
  163:       },
  164:       _sum: { amount: true }
  165:     }),
  166:     prisma.instanceBillingRecord.findMany({
  167:       where: {
  168:         instanceId: { in: instanceIds },
  169:         type: 'refund'
  170:       },
  171:       select: { amount: true }
  172:     }),
  173:     prisma.instanceBillingRecord.findFirst({
  174:       where: {
  175:         instanceId: { in: instanceIds },
  176:         // 仅查询 newPurchase/renew（upgrade 记录的 amount 是差价，不是完整周期金额）
  177:         type: { in: ['newPurchase', 'renew'] },
  178:         amount: { gt: 0 }
  179:       },
  180:       orderBy: { createdAt: 'desc' },
  181:       select: { amount: true }
  182:     })
  183:   ])
  184: 
  185:   const consumedAmount = totalConsumed._sum?.amount !== null && totalConsumed._sum?.amount !== undefined
  186:     ? parseFloat(String(totalConsumed._sum.amount))
  187:     : 0
  188:   const refundedAmount = refundRecords.reduce((sum, record) => sum + Math.abs(Number(record.amount)), 0)
  189:   const lastPaymentAmount = lastPayment?.amount !== null && lastPayment?.amount !== undefined
  190:     ? parseFloat(String(lastPayment.amount))
  191:     : 0
  192: 
  193:   return {
  194:     maxRefundable: roundCurrency(Math.max(0, consumedAmount - refundedAmount)),
  195:     lastPaymentAmount
  196:   }
  197: }
  198: 
  199: function roundCurrency(value: number): number {
  200:   return Number(value.toFixed(2))
  201: }
