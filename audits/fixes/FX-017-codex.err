+        id: { gte: purchaseRecord.id },
+        type: 'consume',
+        OR: [
+          { remark: { startsWith: MAIL_PURCHASE_REMARK_PREFIX } },
+          { remark: { startsWith: MAIL_RENEW_REMARK_PREFIX } }
