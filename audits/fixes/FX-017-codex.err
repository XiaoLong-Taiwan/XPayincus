+      remainingValue += Math.abs(Number(record.amount)) * unusedRatio
+    }
+    periodEnd = periodStart
+  }
+
+  return {
+    maxRefundable,
+    remainingRefundable: roundMailCurrency(Math.min(remainingValue, maxRefundable))
+  }
+}
