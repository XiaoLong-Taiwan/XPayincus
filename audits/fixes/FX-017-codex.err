  287:       discountRate = Number(affBinding.affCode.discountRate) || 0
  288:     }
  289: 
  290:     remainingValue = calculateRemainingValue(
  291:       Number(instance.billingPrice),
  292:       instance.billingCycle,
  293:       remainingDays,
  294:       discountRate
  295:     )
  296:   }
  297: 
  298:   const refundableValue = roundCurrency(Math.min(remainingValue, maxRefundable))
  299: 
  300:   return {
  301:     remainingDays,
  302:     remainingValue,
  303:     refundableValue,
  304:     maxRefundable,
