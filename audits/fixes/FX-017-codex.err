  203: /**
  204:  * 按账单记录计算实例的剩余价值退款报价
  205:  *
  206:  * 正向计费记录（newPurchase / renew / upgrade）各自对应独立的服务期区间，
  207:  * 退款时应按这些区间的未消耗比例逐条计算，而不是仅依赖实例当前 billingPrice。
  208:  * 这样升级补差价、后续续费、管理员延期等场景都能正确纳入剩余价值。
  209:  */
  210: export async function calculateInstanceRemainingRefundQuote(instance: {
  211:   id: number
  212:   billingPrice: any
  213:   billingCycle: number | null
  214:   expiresAt: Date | null
  215:   packagePlanId: number | null
  216: }): Promise<InstanceRemainingRefundQuote> {
  217:   const isPaid = !!(instance.packagePlanId && instance.expiresAt && instance.billingPrice)
  218: 
  219:   if (!isPaid) {
  220:     return {
  221:       remainingDays: 0,
  222:       remainingValue: 0,
  223:       refundableValue: 0,
  224:       maxRefundable: 0,
  225:       isPaid: false
  226:     }
  227:   }
  228: 
  229:   const now = new Date()
  230:   const expiresAt = new Date(instance.expiresAt!)
  231: 
  232:   if (expiresAt <= now) {
  233:     return {
  234:       remainingDays: 0,
  235:       remainingValue: 0,
  236:       refundableValue: 0,
  237:       maxRefundable: 0,
  238:       isPaid: true
  239:     }
  240:   }
  241: 
  242:   const remainingDays = calculateRemainingDays(expiresAt, now)
  243:   const billingLineageInstanceIds = await getInstanceBillingLineageIds(instance.id)
  244:   const instanceIds = billingLineageInstanceIds.length > 0 ? billingLineageInstanceIds : [instance.id]
  245:   const [maxRefundableInfo, positiveBillingRecords] = await Promise.all([
  246:     getMaxRefundable(instance.id),
  247:     prisma.instanceBillingRecord.findMany({
  248:       where: {
  249:         instanceId: { in: instanceIds },
  250:         type: { in: ['newPurchase', 'renew', 'upgrade'] },
  251:         amount: { gt: 0 }
  252:       },
  253:       select: {
  254:         amount: true,
  255:         periodStart: true,
  256:         periodEnd: true
  257:       },
  258:       orderBy: { periodStart: 'asc' }
  259:     })
  260:   ])
  261:   const { maxRefundable } = maxRefundableInfo
  262: 
  263:   let remainingValue = 0
  264: 
  265:   for (const record of positiveBillingRecords) {
  266:     const periodStart = new Date(record.periodStart)
  267:     const periodEnd = new Date(record.periodEnd)
  268:     const totalMs = periodEnd.getTime() - periodStart.getTime()
  269: 
  270:     if (totalMs <= 0 || periodEnd <= now) {
  271:       continue
  272:     }
  273: 
  274:     const remainingMs = Math.max(0, periodEnd.getTime() - now.getTime())
  275:     const unusedRatio = Math.min(remainingMs / totalMs, 1)
  276:     remainingValue += Number(record.amount) * unusedRatio
  277:   }
  278: 
  279:   remainingValue = roundCurrency(remainingValue)
  280: 
  281:   // 兼容历史/异常数据：如果缺少正向计费记录，则回退到旧逻辑，
  282:   // 避免老实例直接变成 0 退款。
  283:   if (positiveBillingRecords.length === 0 && instance.billingPrice && instance.billingCycle) {
