+  const totalRefunded = refundRecords.reduce((sum, record) => sum + Math.abs(Number(record.amount)), 0)
+  const maxRefundable = roundMailCurrency(Math.max(0, totalPaid - totalRefunded))
+
+  let remainingValue = 0
