    })
    const accountDiskLimitMb = accountInput.diskLimitMb ?? Math.min(2048, maxDiskLimitMb)

    // æ£€æŸ¥è´¦æˆ·æ˜¯å¦å·²å­˜åœ¨
    const exists = await db.checkMailAccountExists(domainId, accountInput.username!)
    if (exists) {
