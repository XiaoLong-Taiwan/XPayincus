+        ...(sample.cpuUsageRaw !== undefined ? { cpuUsageRaw: sample.cpuUsageRaw } : {})
+    }
+
+    if (!previous) {
+        await tx.trafficSnapshot.create({
+            data: {
+                instanceId,
+                ...data
+            }
+        })
