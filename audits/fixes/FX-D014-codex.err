+import type { Prisma } from '@prisma/client'
+
+export interface TrafficSnapshotSample {
+    rxRaw: bigint
+    txRaw: bigint
+    sampledAt: Date
+    source: 'agent-report' | 'active-collector'
+    rxPacketsRaw?: bigint
+    txPacketsRaw?: bigint
+    cpuUsageRaw?: bigint | null
