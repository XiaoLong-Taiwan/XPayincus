+
+/**
+ * 原子推进两条采集通道共用的流量快照。
+ * updatedAt 作为快照采样时间；迟到样本不能回退基线，也不能参与增量计量。
+ */
+export async function advanceTrafficSnapshot(
+    tx: Prisma.TransactionClient,
+    instanceId: number,
+    sample: TrafficSnapshotSample
+) {
+    const previous = await tx.trafficSnapshot.findUnique({
+        where: { instanceId }
