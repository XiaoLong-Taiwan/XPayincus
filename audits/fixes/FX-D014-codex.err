 192: func buildIncusInstanceReportItem(client *http.Client, instance incusInstanceSummary) map[string]any {
 193: 	item := map[string]any{
 194: 		"name":       instance.Name,
 195: 		"status":     instance.Status,
 196: 		"statusCode": instance.StatusCode,
 197: 		"type":       instance.Type,
 198: 	}
 199: 
 200: 	if instance.Name == "" || !isRunningIncusStatus(instance.Status, instance.StatusCode) {
 201: 		return item
 202: 	}
 203: 
 204: 	state, err := getIncusInstanceState(client, instance.Name)
 205: 	if err != nil {
 206: 		item["error"] = truncateReportError(err)
 207: 		return item
 208: 	}
 209: 	if state.Status != "" {
 210: 		item["status"] = state.Status
 211: 	}
 212: 
 213: 	counters := getTrafficCountersFromIncusState(instance.Name, state)
 214: 	item["traffic"] = map[string]any{
 215: 		"rxBytes": strconv.FormatUint(counters.rx, 10),
 216: 		"txBytes": strconv.FormatUint(counters.tx, 10),
 217: 	}
 218: 
 219: 	if ipv4, ipv6 := firstRoutableAddresses(state.Network); ipv4 != "" || ipv6 != "" {
 220: 		network := map[string]any{}
 221: 		if ipv4 != "" {
 222: 			network["ipv4"] = ipv4
 223: 		}
 224: 		if ipv6 != "" {
 225: 			network["ipv6"] = ipv6
 226: 		}
 227: 		item["network"] = network
 228: 	}
 229: 
 230: 	return item
 231: }
