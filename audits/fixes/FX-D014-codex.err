+            instanceId,
+            source: sample.source,
+            sampledAt: sample.sampledAt.toISOString(),
+            snapshotSampledAt: previous.updatedAt.toISOString()
+        })
+        return { accepted: false, previous }
+    }
+
+    return { accepted: true, previous }
+}
