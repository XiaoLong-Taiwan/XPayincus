+            select: { id: true }
+          })
+          if (renewed) {
+            await craneMailService.resumeDomain(source, domain.domain)
+          }
+        } catch (error) {
+          console.error(`[Mail] Failed to suspend expired mail domain ${domain.domain}; pending retry:`, error)
