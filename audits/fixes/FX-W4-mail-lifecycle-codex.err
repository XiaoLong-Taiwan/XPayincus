 1578:   fastify.post<{
 1579:     Body: { domain: string }
 1580:   }>('/domains', {
 1581:     onRequest: [fastify.authenticate]
 1582:   }, async (request, reply) => {
 1583:     const { domain: domainName } = request.body
 1584:     const userId = request.user.id
 1585:     const normalizedDomain = domainName?.toLowerCase()
 1586: 
 1587:     if (!normalizedDomain || !/^[a-z0-9]([a-z0-9-]*[a-z0-9])?(\.[a-z0-9]([a-z0-9-]*[a-z0-9])?)*\.[a-z]{2,}$/i.test(normalizedDomain)) {
 1588:       return reply.code(400).send(apiError(ErrorCode.VALIDATION_ERROR, 'è¯·è¾“å…¥æœ‰æ•ˆçš„åŸŸå'))
 1589:     }
 1590: 
 1591:     const subscription = await db.getUserMailSubscription(userId)
 1592:     if (!subscription) {
 1593:       return reply.code(404).send(apiError(ErrorCode.NOT_FOUND, 'æ‚¨æ²¡æœ‰é‚®ç®±è®¢é˜…'))
 1594:     }
 1595: 
 1596:     if (subscription.status !== 'active') {
 1597:       return reply.code(400).send(apiError(ErrorCode.OPERATION_NOT_ALLOWED, 'è®¢é˜…å·²è¿‡æœŸæˆ–æš‚åœ'))
 1598:     }
 1599: 
 1600:     const createResult = await prisma.$transaction(async (tx) => {
 1601:       const subscriptionLocked = await tryAdvisoryTransactionLock(tx, MAIL_SUBSCRIPTION_LOCK_NAMESPACE, userId)
 1602:       if (!subscriptionLocked) {
 1603:         return { statusCode: 400, error: apiError(ErrorCode.OPERATION_NOT_ALLOWED, 'é‚®ç®±è®¢é˜…æ­£åœ¨å¤„ç†ï¼Œè¯·ç¨åŽé‡è¯•') }
 1604:       }
 1605: 
 1606:       const domainLocked = await tryAdvisoryTransactionLock(tx, MAIL_DOMAIN_LOCK_NAMESPACE, subscription.sourceId)
 1607:       if (!domainLocked) {
 1608:         return { statusCode: 400, error: apiError(ErrorCode.OPERATION_NOT_ALLOWED, 'é‚®ç®±åŸŸåæ­£åœ¨å¤„ç†ï¼Œè¯·ç¨åŽé‡è¯•') }
 1609:       }
 1610: 
 1611:       const currentSubscription = await tx.mailSubscription.findUnique({
 1612:         where: { id: subscription.id }
 1613:       })
 1614:       if (!currentSubscription || currentSubscription.userId !== userId) {
 1615:         return { statusCode: 404, error: apiError(ErrorCode.NOT_FOUND, 'æ‚¨æ²¡æœ‰é‚®ç®±è®¢é˜…') }
 1616:       }
 1617:       if (currentSubscription.status !== 'active') {
 1618:         return { statusCode: 400, error: apiError(ErrorCode.OPERATION_NOT_ALLOWED, 'è®¢é˜…å·²è¿‡æœŸæˆ–æš‚åœ') }
 1619:       }
 1620: 
 1621:       const domainCount = await tx.mailDomain.count({
 1622:         where: { subscriptionId: currentSubscription.id }
 1623:       })
 1624:       if (domainCount >= currentSubscription.domainLimit) {
 1625:         return { statusCode: 400, error: apiError(ErrorCode.QUOTA_EXCEEDED, 'å·²è¾¾åŸŸåæ•°é‡ä¸Šé™') }
 1626:       }
 1627: 
 1628:       const exists = await tx.mailDomain.findUnique({
 1629:         where: {
 1630:           domain_sourceId: {
 1631:             domain: normalizedDomain,
 1632:             sourceId: currentSubscription.sourceId
 1633:           }
 1634:         }
 1635:       })
 1636:       if (exists) {
 1637:         return { statusCode: 400, error: apiError(ErrorCode.RESOURCE_EXISTS, 'è¯¥åŸŸåå·²è¢«ä½¿ç”¨') }
 1638:       }
 1639: 
 1640:       const domainDiskLimitMb = Math.floor(currentSubscription.diskLimitGb * 1024 / currentSubscription.domainLimit)
 1641:       const adminDiskLimitMb = Math.min(2048, domainDiskLimitMb)
 1642:       const hasDiskQuota = await mailSubscriptionHasDiskQuota(
 1643:         tx,
 1644:         currentSubscription.id,
 1645:         currentSubscription.diskLimitGb,
 1646:         adminDiskLimitMb
 1647:       )
 1648:       if (!hasDiskQuota) {
 1649:         return { statusCode: 400, error: apiError(ErrorCode.QUOTA_EXCEEDED, 'è®¢é˜…å…±äº«ç£ç›˜é…é¢ä¸è¶³') }
 1650:       }
 1651: 
 1652:       let craneResult: { username?: string; password?: string; server?: string } = {}
 1653:       try {
 1654:         craneResult = await craneMailService.createDomain(
 1655:           subscription.source,
 1656:           normalizedDomain,
 1657:           currentSubscription.diskLimitGb,
 1658:           currentSubscription.domainLimit
 1659:         )
 1660:       } catch (err: any) {
 1661:         return { statusCode: 502, error: apiError(ErrorCode.UPSTREAM_ERROR, `åˆ›å»ºåŸŸåå¤±è´¥: ${err.message}`) }
 1662:       }
 1663: 
 1664:       const mailDomain = await db.createMailDomainWithTx(tx, {
 1665:         subscriptionId: currentSubscription.id,
 1666:         sourceId: currentSubscription.sourceId,
 1667:         domain: normalizedDomain,
 1668:         adminUsername: craneResult.username,
 1669:         adminPassword: craneResult.password
 1670:       })
 1671: 
 1672:       if (craneResult.username && craneResult.password) {
 1673:         const usernameWithoutDomain = craneResult.username.split('@')[0] || 'postmaster'
 1674:         await tx.mailAccount.create({
