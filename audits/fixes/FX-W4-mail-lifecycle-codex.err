diff --git a/server/src/routes/mail.ts b/server/src/routes/mail.ts
index cbfcfa4db3fc4e4c30e09c0ca8de102411c365ea..8349ddd6f66ff3df4ee965b69fb1c0134591882e
--- a/server/src/routes/mail.ts
