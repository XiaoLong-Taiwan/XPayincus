 1350:     }
 1351: 
 1352:     const plan = subscription.plan
 1353:     try {
 1354:       validateMailRenewMonthsForBillingCycle(renewMonths, plan.billingCycle)
 1355:     } catch (error) {
 1356:       return reply.code(400).send(error)
 1357:     }
 1358:     const monthlyPrice = plan.billingCycle === 'monthly' 
 1359:       ? Number(plan.price) 
 1360:       : Number(plan.price) / 12
 1361:     
 1362:     const originalPrice = Math.round(monthlyPrice * renewMonths * 100) / 100
 1363: 
 1364:     // æ£€æŸ¥ AFF ç»‘å®šï¼Œè®¡ç®—æŠ˜æ‰£
 1365:     const { getMailSubscriptionAffBinding, processMailAffCommission } = await import('../db/aff.js')
 1366:     const affBinding = await getMailSubscriptionAffBinding(subscription.id)
 1367:     let discountRate = 0
 1368:     let discountAmount = 0
 1369:     let finalPrice = originalPrice
 1370: 
 1371:     if (affBinding && affBinding.affCode.enabled) {
 1372:       discountRate = Number(affBinding.affCode.discountRate)
 1373:       discountAmount = calculateDiscountAmount(originalPrice, discountRate)
 1374:       finalPrice = calculateDiscountedPrice(originalPrice, discountRate)
 1375:     }
 1376: 
 1377:     // æ£€æŸ¥ä½™é¢
 1378:     const user = await prisma.user.findUnique({
 1379:       where: { id: userId },
 1380:       select: { balance: true }
 1381:     })
 1382:     if (!user || Number(user.balance) < finalPrice) {
 1383:       return reply.code(400).send(apiError(ErrorCode.INSUFFICIENT_BALANCE, `ä½™é¢ä¸è¶³ï¼Œéœ€è¦ Â¥${finalPrice.toFixed(2)}ï¼Œå½“å‰ä½™é¢ Â¥${Number(user?.balance || 0).toFixed(2)}`))
 1384:     }
 1385: 
 1386:     // äº‹åŠ¡ï¼šæ‰£è´¹ + ç»­è´¹ + è¿”åˆ©
 1387:     const renewResult = await prisma.$transaction(async (tx) => {
 1388:       const locked = await tryAdvisoryTransactionLock(tx, MAIL_SUBSCRIPTION_LOCK_NAMESPACE, userId)
 1389:       if (!locked) {
 1390:         return { error: apiError(ErrorCode.OPERATION_NOT_ALLOWED, 'é‚®ç®±è®¢é˜…æ­£åœ¨å¤„ç†ï¼Œè¯·ç¨åŽé‡è¯•') }
 1391:       }
 1392:       const balanceLocked = await tryAdvisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, userId)
 1393:       if (!balanceLocked) {
 1394:         return { error: apiError(ErrorCode.OPERATION_NOT_ALLOWED, 'ç”¨æˆ·ä½™é¢æ­£åœ¨å¤„ç†ï¼Œè¯·ç¨åŽé‡è¯•') }
 1395:       }
 1396: 
 1397:       const currentSubscription = await tx.mailSubscription.findUnique({
 1398:         where: { id: subscription.id },
 1399:         include: { plan: true }
 1400:       })
 1401:       if (!currentSubscription || currentSubscription.userId !== userId) {
 1402:         return { error: apiError(ErrorCode.NOT_FOUND, 'æ‚¨æ²¡æœ‰é‚®ç®±è®¢é˜…') }
 1403:       }
 1404:       if (currentSubscription.status === 'suspended') {
 1405:         return { error: apiError(ErrorCode.OPERATION_NOT_ALLOWED, 'è®¢é˜…å·²è¢«æš‚åœï¼Œæ— æ³•ç»­è´¹') }
 1406:       }
 1407:       try {
 1408:         validateMailRenewMonthsForBillingCycle(renewMonths, currentSubscription.plan.billingCycle)
 1409:       } catch (error) {
 1410:         return { error }
 1411:       }
 1412: 
 1413:       const deductResult = await tx.user.updateMany({
 1414:         where: {
 1415:           id: userId,
 1416:           balance: { gte: finalPrice }
 1417:         },
 1418:         data: { balance: { decrement: finalPrice } }
 1419:       })
 1420:       if (deductResult.count === 0) {
 1421:         const currentUser = await tx.user.findUnique({
 1422:           where: { id: userId },
 1423:           select: { balance: true }
 1424:         })
 1425:         return { error: apiError(ErrorCode.INSUFFICIENT_BALANCE, `ä½™é¢ä¸è¶³ï¼Œéœ€è¦ Â¥${finalPrice.toFixed(2)}ï¼Œå½“å‰ä½™é¢ Â¥${Number(currentUser?.balance || 0).toFixed(2)}`) }
 1426:       }
 1427: 
 1428:       const updatedUser = await tx.user.findUnique({
 1429:         where: { id: userId },
 1430:         select: { balance: true }
 1431:       })
 1432:       const balanceAfter = Number(updatedUser?.balance || 0)
 1433:       const balanceBefore = Number((balanceAfter + finalPrice).toFixed(2))
 1434:       const remarkText = discountAmount > 0
 1435:         ? `ç»­è´¹åŸŸåé‚®ç®± ${renewMonths} ä¸ªæœˆï¼ˆä¼˜æƒ ç æŠ˜æ‰£ -Â¥${discountAmount.toFixed(2)}ï¼‰`
 1436:         : `ç»­è´¹åŸŸåé‚®ç®± ${renewMonths} ä¸ªæœˆ`
 1437:       
 1438:       await tx.balanceLog.create({
 1439:         data: {
 1440:           userId,
 1441:           type: 'consume',
 1442:           amount: -finalPrice,
 1443:           balanceBefore,
 1444:           balanceAfter,
 1445:           remark: remarkText
 1446:         }
 1447:       })
