)
assert.ok(
  routeSource.includes("const months = requireSafeInteger(value, 'ç»­è´¹æœˆæ•°')"),
  'mail renewal months must require a runtime JSON integer'
)
assert.ok(
  !routeSource.includes('const months = Number(value)'),
