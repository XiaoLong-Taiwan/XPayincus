+
+          try {
+            await craneMailService.resumeDomain(source, domain.domain)
+            await prisma.mailDomain.updateMany({
+              where: {
+                id: domain.id,
+                subscription: { status: 'active', expiresAt: { gt: new Date() } }
+              },
