 1449:       // è®¡ç®—æ–°çš„è¿‡æœŸæ—¶é—´
 1450:       const currentExpiry = currentSubscription.expiresAt > new Date() ? currentSubscription.expiresAt : new Date()
 1451:       const newExpiry = new Date(currentExpiry)
 1452:       newExpiry.setMonth(newExpiry.getMonth() + renewMonths)
