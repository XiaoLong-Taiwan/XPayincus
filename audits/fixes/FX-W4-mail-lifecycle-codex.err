     console.log(`[Mail] Updated ${result.count} mail subscriptions to expired status`)
+
+    // 同时重试历史 expired 订阅：上游 suspend 是幂等操作，本地 expired 状态即待重试依据。
+    const subscriptionsToSuspend = await prisma.mailSubscription.findMany({
+      where: {
+        status: 'expired',
+        expiresAt: { lt: now }
+      },
+      select: {
+        id: true,
+        userId: true,
+        sourceId: true,
