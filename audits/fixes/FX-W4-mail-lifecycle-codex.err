@@ -4,6 +4,9 @@
  */
 
 import { prisma } from '../db/prisma.js'
+import { createLog } from '../db/logs.js'
+import { getMailSourceById } from '../db/mail.js'
+import * as craneMailService from './cranemail.js'
 
 let schedulerInterval: NodeJS.Timeout | null = null
 
