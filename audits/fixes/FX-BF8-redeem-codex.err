    title: 'æ‚¨æœ‰ä¸€å¼ å¯ç”¨èµ„æºå…‘æ¢ç ',
    content: `ç®¡ç†å‘˜ä¸ºæ‚¨å‘æ”¾äº†ä¸€å¼ å®šå‘èµ„æºå…‘æ¢ç ï¼š${code.code}ï¼Œè¯·åœ¨æœ‰æ•ˆæœŸå†…ä½¿ç”¨ã€‚`,
    data: { redeemCodeId: code.id, expiresAt: expiresAt.toISOString() }
  })

  await recordLifecycleAction({
    actionType: 'issue_redeem_code',
    actor: data.actor,
    targetUserId: data.userId,
    payload: {
      hostId: data.hostId,
      codeType: data.codeType,
      codeValue: data.codeValue,
      expiresInDays: data.expiresInDays
