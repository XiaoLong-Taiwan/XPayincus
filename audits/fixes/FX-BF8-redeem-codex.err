   if (ids.length === 0) {
-    return 0
+    return { foundCount: 0, deletedCount: 0, disabledCount: 0 }
   }
 
-  const result = await prisma.redeemCode.deleteMany({
-    where: { id: { in: ids }, hostId }
-  })
+  return prisma.$transaction(async (tx) => {
+    const sortedIds = [...ids].sort((a, b) => a - b)
