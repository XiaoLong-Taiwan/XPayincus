+export async function deleteRedeemCodeForHost(
+  hostId: number,
+  id: number
+): Promise<'deleted' | 'disabled' | 'not_found'> {
+  return prisma.$transaction(async (tx) => {
+    await advisoryTransactionLock(tx, REDEEM_CODE_LOCK_NAMESPACE, id)
