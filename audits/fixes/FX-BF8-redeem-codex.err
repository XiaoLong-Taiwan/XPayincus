 */
export async function hasUserUsedBatch(batchId: string, userId: number): Promise<boolean> {
  // æ‰¾å‡ºåŒæ‰¹æ¬¡çš„æ‰€æœ‰å…‘æ¢ç ID
  const batchCodes = await prisma.redeemCode.findMany({
