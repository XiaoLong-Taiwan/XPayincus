+    const unusedIds = foundIds.filter(id => !usedIds.includes(id))
+
+    if (usedIds.length > 0) {
+      await tx.redeemCode.updateMany({
+        where: { id: { in: usedIds }, hostId },
+        data: { enabled: false }
+      })
+    }
+    if (unusedIds.length > 0) {
