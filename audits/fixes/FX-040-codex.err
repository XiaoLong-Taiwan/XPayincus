+    })
+    console.log(`[Provisioning] 用户 ${userId} 资源已回滚 (CPU=${resources.cpu}, Mem=${resources.memory}MB, Disk=${resources.disk}MB)`)
+  } catch (rollbackErr) {
+    emitServiceResourceRollbackPluginEvent({
+      event: 'service.resource.rollback.failed',
+      instanceId,
