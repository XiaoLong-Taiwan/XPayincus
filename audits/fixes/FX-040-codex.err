 2294:     }
 2295: 
 2296:     // 计算带宽限制：使用事务中计算的方案带宽限制（如果有），否则使用套餐默认值
 2297:     const effectiveBandwidthLimit = planBandwidthLimit
 2298: 
 2299:     // 根据 ioLimitMode 选择性传入 IO 限制参数
 2300:     const ioMode = pkgConfig.io_limit_mode || 'throughput'
 2301: 
 2302:     createInstanceAsync(instanceId, host, {
 2303:       name: incusId,
 2304:       image: actualImageAlias,
 2305:       cpu: requestedCpu,
 2306:       memory: requestedMemory,
 2307:       disk: requestedDisk,
 2308:       swapEnabled: false,
 2309:       swapSize: effectiveInstanceType === 'container' ? (selectedPlan?.swapSize ?? null) : null,
 2310:       cloudInitConfig: finalConfigPayload,
 2311:       networkMode,
 2312:       nested: Boolean(pkg.nested),
 2313:       privileged: Boolean(pkg.privileged),
 2314:       portLimit: pkgWithExtras.port_limit || 20,
 2315:       // 实例类型：根据套餐的实例类型决定创建容器还是虚拟机
 2316:       instanceType: effectiveInstanceType,
 2317:       // SSH 端口（固定 22）
 2318:       sshPort: metaData.sshPort,
 2319:       // 存储池配置
 2320:       storagePool: selectedStoragePool,
 2321:       // IP 配置 (新双网卡架构)
 2322:       ipv4Address: staticIPv4,
 2323:       ipv6Address: staticIPv6,
 2324:       ipv6Gateway: hostWithIpv6.ipv6_gateway || null,
 2325:       hostInterface: hostWithIpv6.ipv6_parent_interface || 'eth0',
 2326:       // Advanced configuration from package (根据 ioLimitMode 选择性传入)
 2327:       limitsRead: ioMode === 'throughput' ? pkgConfig.limits_read : null,
 2328:       limitsWrite: ioMode === 'throughput' ? pkgConfig.limits_write : null,
 2329:       limitsReadIops: ioMode === 'iops' ? pkgConfig.limits_read_iops : null,
 2330:       limitsWriteIops: ioMode === 'iops' ? pkgConfig.limits_write_iops : null,
 2331:       limitsIngress: effectiveBandwidthLimit || pkgConfig.limits_ingress,
 6631:       console.log(`[ReassignIPv6] 实例 ${instance.name} IPv6 已更新: ${oldIPv6} → ${newIPv6}`)
 6632: 
 6633:       return {
 6634:         message: 'IPv6 已重新分配，请重装系统使其生效',
 6635:         oldIpv6: oldIPv6,
 6636:         newIpv6: newIPv6
 6637:       }
 6638:     } catch (err) {
 6639:       const errorMessage = err instanceof Error ? err.message : String(err)
 6640:       console.error(`[ReassignIPv6] 实例 ${instance.name} IPv6 重新分配失败:`, errorMessage)
 6641: 
 6642:       await createLog(
 6643:         user.id,
 6644:         'instance',
 6645:         'instance.reassign_ipv6',
 6646:         `Failed to reassign IPv6 for instance "${instance.name}": ${errorMessage}`,
 6647:         'failed',
 6648:         { instanceId }
 6649:       )
 6650: 
 6651:       return reply.code(500).send(apiError(ErrorCode.INSTANCE_IPV6_REASSIGN_FAILED, errorMessage))
 6652:     }
 6653:   })
 6654: }
 6655: 
 6656: // ==================== 辅助函数 ====================
 6657: 
 6658: /**
 6659:  * 异步创建实例
 6660:  */
 6661: async function createInstanceAsync(
 6662:   instanceId: number,
 6663:   host: Host,
 6664:   config: {
 6665:     name: string
 6666:     image: string
 6667:     cpu: number
 6668:     memory: number
 6669:     disk: number
 6670:     swapEnabled?: boolean
 6671:     swapSize?: number | null
 6672:     cloudInitConfig?: Record<string, string>
 6673:     networkMode: 'nat' | 'nat_ipv6' | 'nat_ipv6_nat' | 'ipv6_only' | 'ipv6_nat' | 'public_ipv4' | 'public_ipv4_ipv6'
 6674:     nested?: boolean
 6675:     privileged?: boolean
 6676:     portLimit?: number
 6677:     // 实例类型: container(容器) 或 vm(虚拟机)
 6678:     instanceType?: 'container' | 'vm'
 6679:     // SSH 端口（固定 22）
 6680:     sshPort?: number | null
 6681:     // 存储池配置
 6682:     storagePool?: string | null
 6683:     // IP 配置 (新双网卡架构)
 6684:     ipv4Address?: string | null  // 内网 IPv4 (随机分配)
 6685:     ipv6Address?: string | null  // IPv6 (随机分配)
 6686:     ipv6Gateway?: string | null
 6687:     hostInterface?: string | null  // 宿主机物理网卡名 (用于 routed 模式)
 6688:     // Advanced configuration options from package
 6689:     limitsRead?: string | null
 6690:     limitsWrite?: string | null
 6691:     limitsReadIops?: number | null
 6692:     limitsWriteIops?: number | null
 6693:     limitsIngress?: string | null
 6694:     limitsEgress?: string | null
 6695:     limitsProcesses?: number | null
 6696:     limitsCpuPriority?: number | null
 6697:     bootAutostart?: boolean | null
 6698:     bootAutostartPriority?: number | null
 6699:     bootAutostartDelay?: number | null
 6700:     bootHostShutdownTimeout?: number | null
 6701:   },
 6702:   userId: number,
 6703:   resources: { cpu: number; memory: number; disk: number },
 6704:   preflightError?: string
 6705: ): Promise<void> {
 6706:   try {
 6707:     if (preflightError) {
 6708:       throw new Error(preflightError)
 6709:     }
 6710: 
 6711:     console.log(`\n[Provisioning] ===== 开始创建实例流程 =====`)
 6712:     console.log(`[Provisioning] 实例ID: ${instanceId}, 名称: ${config.name}, 宿主机: ${host.name}`)
 6713: 
 6714:     const client = await getIncusClient(host)
 6715: 
 6716:     console.log(`[Provisioning] 正在构建 Incus 配置...`)
 6717:     // 构建 IPv6Config (如果有静态 IPv6)
 6718:     const ipv6Config = config.ipv6Address ? {
 6719:       primaryIp: config.ipv6Address
 6720:     } : null
 6721: 
 6722:     const incusConfig = buildInstanceConfig({
 6723:       name: config.name,
 6724:       image: config.image,
 6725:       cpu: config.cpu,
 6726:       memory: config.memory,
 6727:       disk: config.disk,
 6728:       swapEnabled: config.swapEnabled,
 6729:       swapSize: config.swapSize,
 6730:       sshKey: '',
 6731:       password: '',
 6732:       cloudInitConfig: config.cloudInitConfig as { 'user.user-data': string } | undefined,
 6733:       networkMode: (config.networkMode || 'nat') as 'nat' | 'nat_ipv6' | 'nat_ipv6_nat' | 'ipv6_only' | 'ipv6_nat' | 'public_ipv4' | 'public_ipv4_ipv6',
 6734:       nested: config.nested || false,
 6735:       privileged: config.privileged || false,
 6736:       instanceType: config.instanceType || 'container',
 6737:       // 存储池配置
 6738:       storagePool: config.storagePool || 'default',
 6739:       // IP 配置 (新双网卡架构)
 6740:       ipv4Address: config.ipv4Address,  // 内网 IPv4
 6741:       ipv6Config,
 6742:       hostInterface: config.hostInterface || 'eth0',
 6743:       // IPv6 静态地址配置 (向后兼容)
 6744:       ipv6Address: config.ipv6Address,
 6745:       ipv6Gateway: config.ipv6Gateway,
 6746:       // Advanced configuration options
 6747:       limitsRead: config.limitsRead,
 6748:       limitsWrite: config.limitsWrite,
 6749:       limitsReadIops: config.limitsReadIops,
 6750:       limitsWriteIops: config.limitsWriteIops,
 6751:       limitsIngress: config.limitsIngress,
 6752:       limitsEgress: config.limitsEgress,
 6753:       limitsProcesses: config.limitsProcesses,
 6754:       limitsCpuPriority: config.limitsCpuPriority,
 6755:       bootAutostart: config.bootAutostart,
 6756:       bootAutostartPriority: config.bootAutostartPriority,
 6757:       bootAutostartDelay: config.bootAutostartDelay,
 6758:       bootHostShutdownTimeout: config.bootHostShutdownTimeout
 6759:     })
 6760: 
 6761:     console.log(`[Provisioning] 开始创建实例 ${instanceId} (${config.name}) on ${host.name}`)
 6762:     console.log(`[Provisioning] 资源配置: CPU=${config.cpu}, Memory=${config.memory}MB, Disk=${config.disk}MB`)
 6763:     console.log(`[Provisioning] Incus 配置已生成，敏感字段已跳过日志输出`)
 6764: 
 6765:     await createInstance(client, incusConfig)
 6766:     const instanceTypeLabel = config.instanceType === 'vm' ? '虚拟机' : '容器'
 6767:     console.log(`[Provisioning] 实例 ${config.name} ${instanceTypeLabel}创建完成`)
 6768: 
 6769:     await startInstance(client, config.name)
 6770:     console.log(`[Provisioning] 实例 ${config.name} 启动命令已发送`)
 6771: 
 6772:     // KVM 虚拟机需要等待 QEMU 真正完成启动（BIOS→内核→cloud-init→agent）
 6773:     // 容器启动是瞬时的，不需要等待
 6774:     if (config.instanceType === 'vm') {
 6775:       console.log(`[Provisioning] VM ${config.name} 等待 QEMU 启动完成...`)
 6776:       const vmMaxWait = 90 // 最多等 90 轮 × 2秒 = 180秒
 6777:       let vmStarted = false
 6778:       for (let i = 0; i < vmMaxWait; i++) {
 6779:         await new Promise(r => setTimeout(r, 2000))
 6780:         try {
 6781:           const vmState = await getInstanceState(client, config.name) as { status?: string }
 6782:           if (vmState.status === 'Running') {
 6783:             console.log(`[Provisioning] VM ${config.name} 已确认启动 (耗时 ${(i + 1) * 2}s)`)
 6784:             vmStarted = true
 6785:             break
 6786:           }
 6787:           if (i % 10 === 0) {
 6788:             console.log(`[Provisioning] VM ${config.name} 等待启动中... (${(i + 1) * 2}s, 状态: ${vmState.status || 'unknown'})`)
 6789:           }
 6790:         } catch { /* 继续等待 */ }
 6791:       }
 6792:       if (!vmStarted) {
 6793:         console.warn(`[Provisioning] VM ${config.name} 启动等待超时 (180s)，继续流程`)
 6794:       }
 6795:     }
 6796: 
 6797:     // 使用传入的静态 IP 地址
 6798:     const ipv4: string | null = config.ipv4Address || null
 6799:     const ipv6: string | null = config.ipv6Address || null
 6800: 
 6801:     console.log(`[Provisioning] 实例 ${config.name} IP 配置: IPv4=${ipv4}, IPv6=${ipv6}`)
 6802: 
 6803:     // 使用原子操作更新状态，防止与超时清理任务竞争
 6804:     // 只有状态仍为 creating 时才更新为 running
 6805:     const updateResult = await prisma.instance.updateMany({
 6806:       where: {
 6807:         id: instanceId,
 6808:         status: 'creating' // 原子条件
 6809:       },
 6810:       data: {
 6811:         status: 'running',
 6812:         ipv4: ipv4 ?? null,
 6813:         ipv6: ipv6 ?? null,
 6814:         storagePoolName: config.storagePool || 'default'
 6815:       }
 6816:     })
 6817: 
 6818:     // 如果状态已被超时清理任务修改（变为 error），需要清理已创建的 Incus 实例
 6819:     if (updateResult.count === 0) {
 6820:       console.log(`[Provisioning] 实例 ${instanceId} 已被超时清理任务处理，清理已创建的 Incus 实例`)
 6821:       try {
 6822:         await stopInstance(client, config.name, true)
