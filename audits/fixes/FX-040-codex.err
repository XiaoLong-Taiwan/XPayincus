 6961:     const updateResult = await prisma.instance.updateMany({
 6962:       where: {
 6963:         id: instanceId,
 6964:         status: 'creating' // 原子条件
 6965:       },
 6966:       data: {
 6967:         status: 'error'
 6968:       }
 6969:     })
 6970: 
 6971:     // 只有成功更新状态时才回滚资源（避免与超时清理任务双重回滚）
 6972:     if (updateResult.count > 0 && userId && resources) {
 6973:       const rollbackPortCount = networkModeAllowsPortMapping(config.networkMode) ? (config.portLimit || 0) : 0
 6974:       try {
