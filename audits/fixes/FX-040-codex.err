 6920:           })
 6921:           const isPaid = instanceWithBilling?.packagePlanId !== null
 6922: 
 6923:           await sendInstanceCreatedEmail(user.email, {
 6924:             username: user.username,
 6925:             instanceName: instance.name,
 6926:             hostName: host.name,
 6927:             image: config.image,
 6928:             cpu: config.cpu,
 6929:             memory: config.memory,
 6930:             disk: config.disk,
 6931:             ipv4: ipv4 || undefined,
 6932:             ipv6: ipv6 || undefined,
 6933:             isPaid,
 6934:             planName: instanceWithBilling?.packagePlan?.name,
 6935:             amount: isPaid ? Number(instanceWithBilling?.billingPrice) : undefined,
 6936:             expiresAt: instanceWithBilling?.expiresAt ?? undefined
 6937:           })
