 7037:         await markFlashSaleFailed(instanceId, errorMessage, false).catch((err) => {
 7038:           console.error(`[Provisioning] 秒杀失败状态回写失败:`, err)
 7039:         })
 7040:       }
 7041:     } else if (updateResult.count === 0) {
 7042:       console.log(`[Provisioning] 实例 ${instanceId} 已被超时清理任务处理，跳过资源回滚`)
 7043:     }
 7044: 
