 6986:           hostId: host.id,
 6987:           instanceName: config.name,
 6988:           source: 'instance.provisioning.failure',
 6989:           reason: 'provisioning_failed',
 6990:           cpu: resources.cpu,
 6991:           memory: resources.memory,
 6992:           disk: resources.disk,
