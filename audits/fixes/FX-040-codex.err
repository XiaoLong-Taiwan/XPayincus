 7027:         await markFlashSaleFailed(instanceId, errorMessage, compensation.refunded).catch((err) => {
 7028:           console.error(`[Provisioning] 秒杀失败状态回写失败:`, err)
 7029:         })
 7030:         if (compensation.refunded) {
