 315:           <thead class="border-b border-themed text-left text-themed-muted">
 316:             <tr>
 317:               <th class="w-[4%] py-3 pr-4"></th>
 318:               <th class="w-[28%] py-3 pr-4">{{ t('giftCards.code') }}</th>
 319:               <th class="w-[14%] py-3 pr-4">{{ t('giftCards.amount') }}</th>
 320:               <th class="w-[12%] py-3 pr-4">{{ t('giftCards.statusTitle') }}</th>
 321:               <th class="w-[20%] py-3 pr-4">{{ t('giftCardsAdmin.createdAndUsed') }}</th>
 322:               <th class="w-[12%] py-3 pr-4">{{ t('giftCards.expiresAt') }}</th>
 323:               <th class="w-[10%] py-3 pr-4">{{ t('giftCards.action') }}</th>
 324:             </tr>
 325:           </thead>
 326:           <tbody>
 327:             <tr v-for="card in records" :key="card.id" class="border-b border-themed">
 328:               <td class="py-3 pr-4">
 329:                 <input type="checkbox" class="h-4 w-4 rounded text-accent" :checked="selectedIds.has(card.id)" @change="toggleSelected(card.id, ($event.target as HTMLInputElement).checked)" />
 330:               </td>
 331:               <td class="py-3 pr-4 font-mono text-xs text-themed">
 332:                 <span class="block truncate">{{ card.code }}</span>
 333:               </td>
 334:               <td class="py-3 pr-4 text-themed">
 335:                 <div>{{ formatMoney(card.balanceValue) }}</div>
 336:                 <div class="text-xs text-themed-muted">{{ t('giftCardsAdmin.faceValue', { amount: formatMoney(card.faceValue) }) }}</div>
 337:               </td>
 338:               <td class="py-3 pr-4" :class="statusClass(card.status)">{{ statusLabel(card.status) }}</td>
 339:               <td class="py-3 pr-4 text-xs text-themed-muted">
 340:                 <div class="truncate">{{ t('giftCardsAdmin.createdBy', { user: card.createdBy?.username || '-' }) }}</div>
 341:                 <div class="truncate">{{ t('giftCardsAdmin.owner', { user: card.owner?.username || '-' }) }}</div>
 342:                 <div class="truncate">{{ t('giftCardsAdmin.usedBy', { user: card.usedBy?.username || '-' }) }}</div>
 343:               </td>
 344:               <td class="py-3 pr-4 text-themed-muted">{{ formatDate(card.expiresAt) }}</td>
 345:               <td class="py-3 pr-4">
 346:                 <div class="flex flex-wrap gap-2">
 347:                   <button v-if="card.status === 'active' || card.status === 'disabled'" class="btn-secondary btn-sm" @click="updateCardStatus(card)">
 348:                     {{ card.status === 'disabled' ? t('giftCardsAdmin.enable') : t('giftCardsAdmin.disable') }}
 349:                   </button>
 350:                   <button v-if="card.status !== 'used'" class="btn-danger btn-sm" @click="deleteCard(card)">{{ t('giftCardsAdmin.delete') }}</button>
 351:                 </div>
 352:               </td>
 353:             </tr>
 354:             <tr v-if="!loading && records.length === 0">
 355:               <td colspan="7" class="py-8 text-center text-themed-muted">{{ t('giftCards.empty') }}</td>
