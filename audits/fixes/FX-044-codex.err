  669:             }
  670:           }
  671:         }
  672:       })
  673:     ])
  674: 
  675:     const taskCounts = Object.fromEntries(taskStatusCounts.map(item => [item.status, item._count._all]))
  676:     const notificationCounts = Object.fromEntries(notificationStatusCounts.map(item => [item.status, item._count._all]))
  677:     const caseCounts = Object.fromEntries(caseStatusCounts.map(item => [item.status, item._count._all]))
