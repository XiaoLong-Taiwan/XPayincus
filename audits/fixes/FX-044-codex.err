+  compensationClaimed: boolean
+  refundStatus: string
+  refundAmount: number
+  refundReason?: string | null
+  refundError?: string | null
+}) {
+  const title = `初始开通失败：${input.instanceName}`
+  const lastError = sanitizeTokensInString(input.errorMessage).slice(0, 1000)
+  const detail = {
