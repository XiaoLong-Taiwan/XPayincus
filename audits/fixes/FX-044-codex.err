  492: async function attachCaseContext(cases: Array<{
  493:   id: number
  494:   taskId: number | null
  495:   instanceId: number
  496:   hostId: number
  497:   userId: number
  498:   status: DeliveryAssuranceCaseStatus
  499:   issueType: DeliveryAssuranceIssueType
  500:   severity: string
  501:   retryable: boolean
  502:   retryTaskId: number | null
  503:   title: string
  504:   lastError: string | null
  505:   detail: Prisma.JsonValue | null
  506:   note: string | null
  507:   handledByUserId: number | null
  508:   handledByUsername: string | null
  509:   handledAt: Date | null
  510:   createdAt: Date
  511:   updatedAt: Date
  512: }>) {
  513:   const userIds = [...new Set(cases.map(item => item.userId))]
  514:   const hostIds = [...new Set(cases.map(item => item.hostId))]
  515:   const instanceIds = [...new Set(cases.map(item => item.instanceId))]
  516: 
  517:   const [users, hosts, instances, billingRecords] = await Promise.all([
  518:     prisma.user.findMany({
  519:       where: { id: { in: userIds } },
  520:       select: { id: true, username: true, email: true, status: true }
  521:     }),
  522:     prisma.host.findMany({
  523:       where: { id: { in: hostIds } },
  524:       select: { id: true, name: true, status: true, location: true, countryCode: true }
  525:     }),
  526:     prisma.instance.findMany({
  527:       where: { id: { in: instanceIds } },
  528:       select: {
  529:         id: true,
  530:         name: true,
  531:         status: true,
  532:         incusId: true,
  533:         image: true,
  534:         cpu: true,
  535:         memory: true,
  536:         disk: true,
  537:         limitsIngress: true,
  538:         limitsEgress: true
  539:       }
  540:     }),
  541:     prisma.instanceBillingRecord.findMany({
  542:       where: {
  543:         instanceId: { in: instanceIds },
  544:         type: 'upgrade'
  545:       },
  546:       orderBy: [{ createdAt: 'desc' }, { id: 'desc' }],
  547:       select: {
  548:         id: true,
  549:         instanceId: true,
  550:         type: true,
  551:         amount: true,
  552:         createdAt: true,
  553:         balanceLogId: true
  554:       }
  555:     })
  556:   ])
  557: 
  558:   const userMap = new Map(users.map(user => [user.id, user]))
  559:   const hostMap = new Map(hosts.map(host => [host.id, host]))
  560:   const instanceMap = new Map(instances.map(instance => [instance.id, instance]))
  561:   const billingMap = new Map<number, typeof billingRecords[number]>()
  562:   for (const record of billingRecords) {
  563:     if (!billingMap.has(record.instanceId)) billingMap.set(record.instanceId, record)
  564:   }
  565: 
  566:   return cases.map(deliveryCase => ({
  567:     id: deliveryCase.id,
  568:     instanceId: deliveryCase.instanceId,
  569:     hostId: deliveryCase.hostId,
  570:     userId: deliveryCase.userId,
  571:     instance: instanceMap.get(deliveryCase.instanceId) || null,
  572:     user: userMap.get(deliveryCase.userId) || null,
  573:     host: hostMap.get(deliveryCase.hostId) || null,
  574:     assuranceCase: serializeCase(deliveryCase),
  575:     billing: billingMap.get(deliveryCase.instanceId)
  576:       ? {
  577:           id: billingMap.get(deliveryCase.instanceId)!.id,
  578:           type: billingMap.get(deliveryCase.instanceId)!.type,
  579:           amount: Number(billingMap.get(deliveryCase.instanceId)!.amount),
  580:           createdAt: billingMap.get(deliveryCase.instanceId)!.createdAt,
  581:           balanceLogId: billingMap.get(deliveryCase.instanceId)!.balanceLogId
  582:         }
  583:       : null
  584:   }))
  585: }
