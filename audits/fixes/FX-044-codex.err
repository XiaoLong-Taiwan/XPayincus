 6798: async function createInstanceAsync(
 6799:   instanceId: number,
 6800:   host: Host,
 6801:   config: {
 6802:     name: string
 6803:     image: string
 6804:     cpu: number
 6805:     memory: number
 6806:     disk: number
 6807:     swapEnabled?: boolean
 6808:     swapSize?: number | null
 6809:     cloudInitConfig?: Record<string, string>
 6810:     networkMode: 'nat' | 'nat_ipv6' | 'nat_ipv6_nat' | 'ipv6_only' | 'ipv6_nat' | 'public_ipv4' | 'public_ipv4_ipv6'
 6811:     nested?: boolean
 6812:     privileged?: boolean
 6813:     portLimit?: number
 6814:     // 实例类型: container(容器) 或 vm(虚拟机)
 6815:     instanceType?: 'container' | 'vm'
 6816:     // SSH 端口（固定 22）
 6817:     sshPort?: number | null
 6818:     // 存储池配置
 6819:     storagePool?: string | null
 6820:     // IP 配置 (新双网卡架构)
 6821:     ipv4Address?: string | null  // 内网 IPv4 (随机分配)
 6822:     ipv6Address?: string | null  // IPv6 (随机分配)
 6823:     ipv6Gateway?: string | null
 6824:     hostInterface?: string | null  // 宿主机物理网卡名 (用于 routed 模式)
 6825:     // Advanced configuration options from package
 6826:     limitsRead?: string | null
 6827:     limitsWrite?: string | null
 6828:     limitsReadIops?: number | null
 6829:     limitsWriteIops?: number | null
 6830:     limitsIngress?: string | null
 6831:     limitsEgress?: string | null
 6832:     limitsProcesses?: number | null
 6833:     limitsCpuPriority?: number | null
 6834:     bootAutostart?: boolean | null
 6835:     bootAutostartPriority?: number | null
 6836:     bootAutostartDelay?: number | null
 6837:     bootHostShutdownTimeout?: number | null
 6838:   },
 6839:   userId: number,
 6840:   resources: { cpu: number; memory: number; disk: number }
 6841: ): Promise<void> {
 6842:   try {
 6843:     console.log(`\n[Provisioning] ===== 开始创建实例流程 =====`)
 6844:     console.log(`[Provisioning] 实例ID: ${instanceId}, 名称: ${config.name}, 宿主机: ${host.name}`)
 6845: 
 6846:     const client = await getIncusClient(host)
 6847: 
 6848:     console.log(`[Provisioning] 正在构建 Incus 配置...`)
 6849:     // 构建 IPv6Config (如果有静态 IPv6)
 6850:     const ipv6Config = config.ipv6Address ? {
 6851:       primaryIp: config.ipv6Address
 6852:     } : null
 6853: 
 6854:     const incusConfig = buildInstanceConfig({
 6855:       name: config.name,
 6856:       image: config.image,
 6857:       cpu: config.cpu,
 6858:       memory: config.memory,
 6859:       disk: config.disk,
 6860:       swapEnabled: config.swapEnabled,
 6861:       swapSize: config.swapSize,
 6862:       sshKey: '',
 6863:       password: '',
 6864:       cloudInitConfig: config.cloudInitConfig as { 'user.user-data': string } | undefined,
 6865:       networkMode: (config.networkMode || 'nat') as 'nat' | 'nat_ipv6' | 'nat_ipv6_nat' | 'ipv6_only' | 'ipv6_nat' | 'public_ipv4' | 'public_ipv4_ipv6',
 6866:       nested: config.nested || false,
 6867:       privileged: config.privileged || false,
 6868:       instanceType: config.instanceType || 'container',
 6869:       // 存储池配置
 6870:       storagePool: config.storagePool || 'default',
 6871:       // IP 配置 (新双网卡架构)
 6872:       ipv4Address: config.ipv4Address,  // 内网 IPv4
 6873:       ipv6Config,
 6874:       hostInterface: config.hostInterface || 'eth0',
 6875:       // IPv6 静态地址配置 (向后兼容)
 6876:       ipv6Address: config.ipv6Address,
 6877:       ipv6Gateway: config.ipv6Gateway,
 6878:       // Advanced configuration options
 6879:       limitsRead: config.limitsRead,
 6880:       limitsWrite: config.limitsWrite,
 6881:       limitsReadIops: config.limitsReadIops,
 6882:       limitsWriteIops: config.limitsWriteIops,
 6883:       limitsIngress: config.limitsIngress,
 6884:       limitsEgress: config.limitsEgress,
 6885:       limitsProcesses: config.limitsProcesses,
 6886:       limitsCpuPriority: config.limitsCpuPriority,
 6887:       bootAutostart: config.bootAutostart,
 6888:       bootAutostartPriority: config.bootAutostartPriority,
 6889:       bootAutostartDelay: config.bootAutostartDelay,
 6890:       bootHostShutdownTimeout: config.bootHostShutdownTimeout
 6891:     })
 6892: 
 6893:     console.log(`[Provisioning] 开始创建实例 ${instanceId} (${config.name}) on ${host.name}`)
 6894:     console.log(`[Provisioning] 资源配置: CPU=${config.cpu}, Memory=${config.memory}MB, Disk=${config.disk}MB`)
 6895:     console.log(`[Provisioning] Incus 配置已生成，敏感字段已跳过日志输出`)
 6896: 
 6897:     await createInstance(client, incusConfig)
 6898:     const instanceTypeLabel = config.instanceType === 'vm' ? '虚拟机' : '容器'
 6899:     console.log(`[Provisioning] 实例 ${config.name} ${instanceTypeLabel}创建完成`)
 6900: 
 6901:     await startInstance(client, config.name)
 6902:     console.log(`[Provisioning] 实例 ${config.name} 启动命令已发送`)
 6903: 
 6904:     // KVM 虚拟机需要等待 QEMU 真正完成启动（BIOS→内核→cloud-init→agent）
 6905:     // 容器启动是瞬时的，不需要等待
 6906:     if (config.instanceType === 'vm') {
 6907:       console.log(`[Provisioning] VM ${config.name} 等待 QEMU 启动完成...`)
 6908:       const vmMaxWait = 90 // 最多等 90 轮 × 2秒 = 180秒
 6909:       let vmStarted = false
 6910:       for (let i = 0; i < vmMaxWait; i++) {
 6911:         await new Promise(r => setTimeout(r, 2000))
 6912:         try {
 6913:           const vmState = await getInstanceState(client, config.name) as { status?: string }
 6914:           if (vmState.status === 'Running') {
 6915:             console.log(`[Provisioning] VM ${config.name} 已确认启动 (耗时 ${(i + 1) * 2}s)`)
 6916:             vmStarted = true
 6917:             break
 6918:           }
 6919:           if (i % 10 === 0) {
 6920:             console.log(`[Provisioning] VM ${config.name} 等待启动中... (${(i + 1) * 2}s, 状态: ${vmState.status || 'unknown'})`)
 6921:           }
 6922:         } catch { /* 继续等待 */ }
 6923:       }
 6924:       if (!vmStarted) {
 6925:         console.warn(`[Provisioning] VM ${config.name} 启动等待超时 (180s)，继续流程`)
 6926:       }
 6927:     }
 6928: 
 6929:     // 使用传入的静态 IP 地址
 6930:     const ipv4: string | null = config.ipv4Address || null
 6931:     const ipv6: string | null = config.ipv6Address || null
 6932: 
 6933:     console.log(`[Provisioning] 实例 ${config.name} IP 配置: IPv4=${ipv4}, IPv6=${ipv6}`)
 6934: 
 6935:     // 使用原子操作更新状态，防止与超时清理任务竞争
 6936:     // 只有状态仍为 creating 时才更新为 running
 6937:     const updateResult = await prisma.instance.updateMany({
 6938:       where: {
 6939:         id: instanceId,
 6940:         status: 'creating' // 原子条件
 6941:       },
 6942:       data: {
 6943:         status: 'running',
 6944:         ipv4: ipv4 ?? null,
 6945:         ipv6: ipv6 ?? null,
 6946:         storagePoolName: config.storagePool || 'default'
 6947:       }
 6948:     })
 6949: 
 6950:     // 如果状态已被超时清理任务修改（变为 error），需要清理已创建的 Incus 实例
 6951:     if (updateResult.count === 0) {
 6952:       console.log(`[Provisioning] 实例 ${instanceId} 已被超时清理任务处理，清理已创建的 Incus 实例`)
 6953:       try {
 6954:         await stopInstance(client, config.name, true)
 6955:         await deleteInstance(client, config.name)
 6956:         console.log(`[Provisioning] Incus 实例 ${config.name} 已清理（因超时）`)
 6957:       } catch (cleanupErr) {
 6958:         console.error(`[Provisioning] 清理超时实例失败:`, cleanupErr)
 6959:       }
 6960:       // 不再继续后续流程（IP 记录、通知等）
 6961:       return
 6962:     }
 6963: 
 6964:     await markFlashSaleDelivered(instanceId).catch((err) => {
 6965:       console.error(`[Provisioning] 秒杀交付状态回写失败:`, err)
