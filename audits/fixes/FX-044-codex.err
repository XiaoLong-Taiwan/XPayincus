+        severity: 'critical',
+        retryable: false,
+        title,
+        lastError,
+        detail
+      }
+    })
+
+    await tx.deliveryAssuranceAction.create({
+      data: {
+        caseId: deliveryCase.id,
+        actionType: 'detected',
+        actorUserId: null,
+        actorUsername: null,
+        note: '初始开通失败，已进入交付保障中心等待人工接管。',
+        detail
+      }
+    })
+
+    return deliveryCase
+  })
+}
