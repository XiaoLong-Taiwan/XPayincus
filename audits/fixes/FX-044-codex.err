  163: async function ensureCaseForTask(task: {
  164:   id: number
  165:   instanceId: number
  166:   hostId: number
  167:   userId: number
  168:   taskType: InstanceTaskType
  169:   status: InstanceTaskStatus
  170:   progress: string | null
  171:   error: string | null
  172:   createdAt: Date
  173:   startedAt: Date | null
  174:   finishedAt: Date | null
  175:   instance?: { name: string; status: string; image: string } | null
  176: }) {
  177:   const issue = classifyTaskIssue(task)
  178:   if (!issue) return null
  179: 
  180:   const detail = {
  181:     taskType: task.taskType,
  182:     taskStatus: task.status,
  183:     progress: task.progress,
  184:     instanceStatus: task.instance?.status || null,
  185:     image: task.instance?.image || null,
  186:     createdAt: task.createdAt.toISOString(),
  187:     startedAt: task.startedAt?.toISOString() ?? null,
  188:     finishedAt: task.finishedAt?.toISOString() ?? null
  189:   }
  190: 
  191:   const existing = await prisma.deliveryAssuranceCase.findUnique({
  192:     where: { taskId: task.id }
  193:   })
  194: 
  195:   if (!existing) {
  196:     const created = await prisma.deliveryAssuranceCase.create({
  197:       data: {
  198:         taskId: task.id,
  199:         instanceId: task.instanceId,
  200:         hostId: task.hostId,
  201:         userId: task.userId,
  202:         status: issue.status,
  203:         issueType: issue.issueType,
  204:         severity: issue.severity,
  205:         retryable: issue.retryable,
  206:         title: issue.title,
  207:         lastError: issue.lastError,
  208:         detail
  209:       }
  210:     })
  211:     await addCaseAction(created.id, 'detected', null, null, { taskId: task.id, issueType: issue.issueType })
  212:     return created
  213:   }
  214: 
  215:   const status = ['recovered', 'closed', 'in_progress'].includes(existing.status) ? existing.status : issue.status
  216:   return prisma.deliveryAssuranceCase.update({
  217:     where: { id: existing.id },
  218:     data: {
  219:       status,
  220:       issueType: issue.issueType,
  221:       severity: issue.severity,
  222:       retryable: issue.retryable,
  223:       title: issue.title,
  224:       lastError: issue.lastError,
  225:       detail
  226:     }
  227:   })
  228: }
