   83:   error: string | null
   84:   instance?: { name: string } | null
   85: }): {
   86:   issueType: DeliveryAssuranceIssueType
   87:   status: DeliveryAssuranceCaseStatus
   88:   severity: string
   89:   retryable: boolean
   90:   title: string
   91:   lastError: string | null
   92: } | null {
   93:   if (task.status === 'FAILED') {
   94:     const retryable = IDEMPOTENT_RETRY_TASKS.has(task.taskType)
   95:     return {
   96:       issueType: 'task_failed',
   97:       status: retryable ? 'auto_retryable' : 'pending_manual',
   98:       severity: retryable ? 'warning' : 'critical',
   99:       retryable,
  100:       title: `交付任务失败：${task.instance?.name || task.taskType}`,
  101:       lastError: task.error ? sanitizeTokensInString(task.error) : null
  102:     }
  103:   }
  104: 
  105:   if (isStaleTask(task)) {
  106:     return {
  107:       issueType: 'task_stale',
  108:       status: 'pending_manual',
  109:       severity: 'warning',
  110:       retryable: false,
  111:       title: `交付任务疑似卡住：${task.instance?.name || task.taskType}`,
  112:       lastError: '任务处理超过 30 分钟'
  113:     }
  114:   }
  115: 
  116:   return null
  117: }
