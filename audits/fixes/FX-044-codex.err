  128:     issueType: deliveryCase.issueType,
  129:     severity: deliveryCase.severity,
  130:     retryable: deliveryCase.retryable,
  131:     retryTaskId: deliveryCase.retryTaskId,
  132:     title: deliveryCase.title,
  133:     lastError: deliveryCase.lastError,
  134:     detail: deliveryCase.detail,
  135:     note: deliveryCase.note,
  136:     handledByUserId: deliveryCase.handledByUserId,
  137:     handledByUsername: deliveryCase.handledByUsername,
  138:     handledAt: deliveryCase.handledAt?.toISOString?.() ?? null,
  139:     createdAt: deliveryCase.createdAt?.toISOString?.() ?? null,
  140:     updatedAt: deliveryCase.updatedAt?.toISOString?.() ?? null
  141:   }
  142: }
