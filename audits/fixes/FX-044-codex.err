  793:       if (!task) return reply.code(404).send(apiError(ErrorCode.NOT_FOUND))
  794:       const deliveryCase = await ensureCaseForTask(task)
  795:       if (!deliveryCase) return reply.code(409).send({ error: '当前任务不需要交付保障接管' })
  796:       const note = normalizeNote(request.body?.note)
  797:       const actor = request.user!
  798:       const updated = await prisma.deliveryAssuranceCase.update({
  799:         where: { id: deliveryCase.id },
  800:         data: {
  801:           status: 'in_progress',
  802:           note,
  803:           handledByUserId: actor.id,
  804:           handledByUsername: actor.username,
  805:           handledAt: new Date()
  806:         }
  807:       })
  808:       await addCaseAction(updated.id, 'takeover', actor, note, { taskId })
  809:       await createLog(actor.id, 'delivery', 'delivery.takeover', `接管交付问题 #${updated.id}（任务 #${taskId}）`, 'success')
  810:       return { case: serializeCase(updated) }
