 6690: async function compensateFailedInstanceCreation(input: {
 6691:   instanceId: number
 6692:   host: Host
 6693:   userId: number
 6694:   resources: { cpu: number; memory: number; disk: number }
 6695:   networkMode: NetworkMode
 6696:   portLimit: number
 6697:   instanceName: string
 6698:   errorMessage: string
 6699: }): Promise<boolean> {
 6700:   const {
 6701:     instanceId,
 6702:     host,
 6703:     userId,
 6704:     resources,
 6705:     networkMode,
 6706:     portLimit,
 6707:     instanceName,
 6708:     errorMessage
 6709:   } = input
 6710:   const updateResult = await prisma.instance.updateMany({
 6711:     where: {
 6712:       id: instanceId,
 6713:       status: 'creating'
 6714:     },
 6715:     data: {
 6716:       status: 'error'
 6717:     }
 6718:   })
 6719: 
 6720:   // creating -> error 是资源、IPv4 和账务补偿的幂等总闸门。
 6721:   if (updateResult.count === 0) {
 6722:     console.log(`[Provisioning] 实例 ${instanceId} 已被其他失败补偿或超时清理处理，跳过重复补偿`)
 6723:     return false
 6724:   }
 6725: 
 6726:   const rollbackPortCount = networkModeAllowsPortMapping(networkMode) ? portLimit : 0
 6727:   try {
 6728:     await db.rollbackResources({
 6729:       hostId: host.id,
 6730:       cpu: resources.cpu,
 6731:       memory: resources.memory,
 6732:       disk: resources.disk,
 6733:       portCount: rollbackPortCount
 6734:     })
 6735:     emitServiceResourceRollbackPluginEvent({
 6736:       event: 'service.resource.rollback.completed',
 6737:       instanceId,
 6738:       userId,
 6739:       hostId: host.id,
 6740:       instanceName,
 6741:       source: 'instance.provisioning.failure',
 6742:       reason: 'provisioning_failed',
 6743:       cpu: resources.cpu,
 6744:       memory: resources.memory,
 6745:       disk: resources.disk,
 6746:       portCount: rollbackPortCount,
 6747:       dedupeKey: `service.resource.rollback.completed:provisioning:${instanceId}`
 6748:     })
 6749:     console.log(`[Provisioning] 用户 ${userId} 资源已回滚 (CPU=${resources.cpu}, Mem=${resources.memory}MB, Disk=${resources.disk}MB)`)
 6750:   } catch (rollbackErr) {
 6751:     emitServiceResourceRollbackPluginEvent({
 6752:       event: 'service.resource.rollback.failed',
 6753:       instanceId,
 6754:       userId,
 6755:       hostId: host.id,
 6756:       instanceName,
 6757:       source: 'instance.provisioning.failure',
 6758:       reason: 'rollback_failed',
 6759:       cpu: resources.cpu,
 6760:       memory: resources.memory,
 6761:       disk: resources.disk,
 6762:       portCount: rollbackPortCount,
 6763:       dedupeKey: `service.resource.rollback.failed:provisioning:${instanceId}`,
 6764:       metadata: { failureType: 'resource_rollback_failed' }
 6765:     })
 6766:     console.error(`[Provisioning] 资源回滚失败:`, rollbackErr)
 6767:   }
 6768: 
 6769:   try {
 6770:     await releaseReservedPublicIpv4ForFailedCreation(instanceId, networkMode)
 6771:   } catch (releaseErr) {
 6772:     console.error(`[Provisioning] 释放独立 IPv4 失败:`, releaseErr)
 6773:   }
 6774: 
 6775:   try {
 6776:     const compensation = await db.compensateFailedInstancePurchase(instanceId, userId, host.id)
 6777:     await markFlashSaleFailed(instanceId, errorMessage, compensation.refunded).catch((err) => {
 6778:       console.error(`[Provisioning] 秒杀失败状态回写失败:`, err)
 6779:     })
 6780:     if (compensation.refunded) {
 6781:       console.log(`[Provisioning] 实例 ${instanceId} 创建失败已自动退款 ¥${compensation.refundAmount.toFixed(2)}`)
 6782:     } else if (compensation.reason !== 'not_paid_purchase') {
 6783:       console.log(`[Provisioning] 实例 ${instanceId} 创建失败无需退款: ${compensation.reason || 'unknown'}`)
 6784:     }
 6785:   } catch (compensationErr) {
 6786:     console.error(`[Provisioning] 实例 ${instanceId} 创建失败后的账务补偿失败:`, compensationErr)
 6787:     await markFlashSaleFailed(instanceId, errorMessage, false).catch((err) => {
 6788:       console.error(`[Provisioning] 秒杀失败状态回写失败:`, err)
 6789:     })
 6790:   }
 6791: 
 6792:   return true
 6793: }
