   15: function indexOfOrThrow(source: string, pattern: string, label: string): number {
   16:   const index = source.indexOf(pattern)
   17:   assert.ok(index >= 0, `Missing ${label}: ${pattern}`)
   18:   return index
   19: }
   20: 
   21: function section(source: string, startPattern: string, endPattern: string): string {
   22:   const start = indexOfOrThrow(source, startPattern, startPattern)
   23:   const relativeEnd = indexOfOrThrow(source.slice(start), endPattern, endPattern)
   24:   return source.slice(start, start + relativeEnd)
   25: }
   26: 
   27: const compensationSection = compensationSource
