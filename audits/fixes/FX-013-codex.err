    return { valid: false, error: 'è¯¥ä¼˜æƒ ç ä»…é€‚ç”¨äºŽç‰¹å®šå®žä¾‹å¥—é¤ï¼Œä¸æ”¯æŒé‚®ç®±è®¢é˜…' }
  }

  // 3. æ£€æŸ¥æ˜¯å¦ä¸ºè‡ªå·±çš„ä¼˜æƒ ç ï¼ˆç¦æ­¢è‡ªè¿”åˆ©ï¼‰
  if (affCode.userId === userId) {
    return { valid: false, error: 'ä¸èƒ½ä½¿ç”¨è‡ªå·±çš„ä¼˜æƒ ç ' }
  }

  // 4. æ£€æŸ¥ä¼˜æƒ ç æ˜¯å¦å¯ç”¨
  if (!affCode.enabled) {
    return { valid: false, error: 'ä¼˜æƒ ç å·²ç¦ç”¨' }
  }

  return {
    valid: true,
    affCode,
    discountRate: Number(affCode.discountRate),
    commissionRate: Number(affCode.commissionRate)
  }
}

/**
 * åˆ›å»ºé‚®ç®±è®¢é˜…ä¸Žä¼˜æƒ ç çš„ç»‘å®š
 */
export async function createMailAffBinding(
  mailSubscriptionId: number,
  affCodeId: number,
  tx?: Prisma.TransactionClient
): Promise<void> {
  const client = tx || prisma
  await client.mailSubscriptionAffBinding.create({
    data: { mailSubscriptionId, affCodeId }
  })
}

