assert.ok(
  app.includes("import pluginMarketSubmissionRoutes from './routes/plugin-market-submissions.js'") &&
    app.includes("await fastify.register(pluginMarketSubmissionRoutes, { prefix: '/api/plugin-market-submissions' })"),
