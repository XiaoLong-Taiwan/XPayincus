 680:       const upload = await receiveUploadedPluginPackage(request)
 681:       packagePath = upload.packagePath
 682:       const validated = await validateAndExtractPluginPackage(packagePath, submissionUploadTaskId())
 683:       stagingDir = validated.stagingDir
 684: 
 685:       const suffix = `${validated.sha256.slice(0, 12)}-${randomUUID().slice(0, 8)}`
 686:       const baseName = `${validated.manifest.id}-${validated.manifest.version}-${suffix}`
 687:       const packageFilename = `${baseName}.tar.gz`
 688:       const manifestFilename = `${baseName}.plugin.json`
 689:       const uploadDir = getPluginSubmissionUploadDir()
 690:       await mkdir(uploadDir, { recursive: true })
 691:       const finalPackagePath = resolveInside(uploadDir, packageFilename)
 692:       const finalManifestPath = resolveInside(uploadDir, manifestFilename)
 693:       await rename(packagePath, finalPackagePath)
 694:       packagePath = null
 695:       await writeFile(finalManifestPath, `${JSON.stringify(validated.manifest, null, 2)}\n`, { mode: 0o644 })
 696: 
 697:       await createLog(
 698:         user.id,
 699:         LogModule.PLUGIN,
 700:         'plugin.market_submission.upload_package',
 701:         `Uploaded plugin market package ${validated.manifest.id}@${validated.manifest.version} (${validated.sha256})`,
 702:         LogResult.SUCCESS
 703:       )
 704: 
 705:       return reply.code(201).send({
 706:         upload: {
 707:           pluginId: validated.manifest.id,
 708:           version: validated.manifest.version,
 709:           name: validated.manifest.name,
 710:           packageUrl: await buildPublicUploadUrl(request, packageFilename),
 711:           manifestUrl: await buildPublicUploadUrl(request, manifestFilename),
 712:           sha256: validated.sha256,
 713:           permissions: {
 714:             manifest: validated.manifest.permissions || [],
 715:             events: (validated.manifest.capabilities?.events || []).map(event => event.event),
 716:             actions: (validated.manifest.capabilities?.actions || []).map(action => action.name)
 717:           },
 718:           compatibility: { payincus: validated.manifest.payincus },
 719:           sourceName: upload.sourceName
 720:         }
 721:       })
 722:     } catch (error) {
 723:       const message = error instanceof Error ? error.message : String(error)
 724:       await createLog(
 725:         user.id,
 726:         LogModule.PLUGIN,
 727:         'plugin.market_submission.upload_failed',
 728:         `Plugin market package upload failed: ${message}`,
 729:         LogResult.WARNING
 730:       ).catch(() => undefined)
 731:       return reply.code(400).send({ error: message, code: 'PLUGIN_SUBMISSION_UPLOAD_INVALID' })
 732:     } finally {
 733:       if (packagePath) await rm(packagePath, { force: true }).catch(() => undefined)
 734:       if (stagingDir) await rm(stagingDir, { recursive: true, force: true }).catch(() => undefined)
 735:     }
 736:   })
