 650: export default async function pluginMarketSubmissionRoutes(fastify: FastifyInstance) {
 651:   fastify.get<{
 652:     Params: UploadParams
 653:   }>('/uploads/plugins/:filename', async (request, reply) => {
 654:     const filename = normalizeUploadFilename(request.params.filename)
 655:     if (!filename) return reply.code(404).send({ error: 'Upload not found', code: 'PLUGIN_UPLOAD_NOT_FOUND' })
 656:     const uploadDir = getPluginSubmissionUploadDir()
 657:     const filePath = resolveInside(uploadDir, filename)
 658:     try {
 659:       await access(filePath)
 660:     } catch {
 661:       return reply.code(404).send({ error: 'Upload not found', code: 'PLUGIN_UPLOAD_NOT_FOUND' })
 662:     }
 663:     if (filename.endsWith('.tar.gz')) {
 664:       reply.header('Content-Type', 'application/gzip')
 665:       reply.header('Content-Disposition', `attachment; filename="${filename}"`)
 666:     } else {
 667:       reply.header('Content-Type', 'application/json; charset=utf-8')
 668:     }
 669:     reply.header('X-Content-Type-Options', 'nosniff')
 670:     return reply.send(createReadStream(filePath))
 671:   })
 672: 
 673:   fastify.post('/upload-package', {
 674:     onRequest: [fastify.authenticate]
 675:   }, async (request, reply) => {
