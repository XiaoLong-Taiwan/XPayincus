-    downloadUrl: submission.packageUrl,
+    manifestUrl: artifacts.manifestUrl,
+    downloadUrl: artifacts.packageUrl,
     sha256: submission.sha256,
     description: submission.notes || undefined,
     author: submission.developerName,
@@ -118,13 +162,13 @@
