 235:   const repoUrl = normalizeHttpsUrl(body.repoUrl)
 236:   const releaseUrl = normalizeHttpsUrl(body.releaseUrl)
 237:   const manifestUrl = normalizeHttpsUrl(body.manifestUrl)
 238:   const packageUrl = normalizeHttpsUrl(body.packageUrl)
 239:   const sha256 = normalizeText(body.sha256, 64)?.toLowerCase() ?? null
 240:   const developerName = normalizeText(body.developerName, 120)
 241:   const contactEmail = normalizeText(body.contactEmail, 254)
 242:   const developerHomepage = normalizeOptionalHttpsUrl(body.developerHomepage)
 243:   const developerGithub = normalizeOptionalHttpsUrl(body.developerGithub)
 244:   const notes = normalizeOptionalText(body.notes, 5000)
 245: 
 246:   if (!pluginId || !PLUGIN_ID_PATTERN.test(pluginId)) throw new Error('Invalid plugin id')
 247:   if (!version || !VERSION_PATTERN.test(version)) throw new Error('Invalid plugin version')
 248:   if (!name) throw new Error('Invalid plugin name')
 249:   if (!repoUrl || !releaseUrl || !manifestUrl || !packageUrl) throw new Error('Submission URLs must be HTTPS')
 250:   if (!sha256 || !SHA256_PATTERN.test(sha256)) throw new Error('Invalid package SHA256')
 251:   if (!developerName) throw new Error('Invalid developer name')
 252:   if (!contactEmail || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(contactEmail)) throw new Error('Invalid contact email')
 253: 
 254:   return {
 255:     pluginId,
 256:     version,
 257:     name,
 258:     repoUrl,
 259:     releaseUrl,
 260:     manifestUrl,
 261:     packageUrl,
 262:     sha256,
 263:     developerName,
 264:     developerHomepage,
 265:     developerGithub,
 266:     contactEmail,
 267:     permissions: normalizeJsonRecord(body.permissions),
 268:     compatibility: normalizeJsonRecord(body.compatibility),
 269:     pricing: normalizeJsonRecord(body.pricing),
 270:     notes
 271:   }
 272: }
 273: 
 274: function parsePositiveId(value: string): number | null {
 275:   if (!/^[1-9]\d*$/.test(value)) return null
 276:   const parsed = Number(value)
 277:   return Number.isSafeInteger(parsed) ? parsed : null
 278: }
 279: 
 280: function parseLimit(value: string | undefined): number {
 281:   if (!value || !/^[1-9]\d*$/.test(value)) return 100
 282:   const parsed = Number(value)
 283:   return Number.isSafeInteger(parsed) ? Math.min(parsed, 200) : 100
 284: }
 285: 
 286: function normalizeReviewStatus(value: unknown): PluginMarketSubmissionReviewStatus | null {
 287:   return typeof value === 'string' && REVIEW_STATUSES.includes(value as PluginMarketSubmissionReviewStatus)
 288:     ? value as PluginMarketSubmissionReviewStatus
 289:     : null
 290: }
 291: 
 292: function getPluginSubmissionUploadDir(): string {
 293:   return join(getPluginDataDir(), 'submission-uploads', 'plugins')
 294: }
 295: 
 296: function getPluginSubmissionUploadTempDir(): string {
 297:   return join(getPluginStagingDir(), 'submission-uploads')
 298: }
 299: 
 300: function normalizeUploadFilename(value: string): string | null {
 301:   const trimmed = value.trim()
 302:   return /^[a-z][a-z0-9.-]{2,180}\.(?:tar\.gz|plugin\.json)$/.test(trimmed) ? trimmed : null
 303: }
 304: 
 305: async function publicBaseUrlFromRequest(request: FastifyRequest): Promise<string> {
 306:   return getPluginSubmissionPublicBaseUrl(`${request.protocol}://${request.hostname}`)
 307: }
 308: 
 309: async function buildPublicUploadUrl(request: FastifyRequest, filename: string): Promise<string> {
 310:   const publicBaseUrl = await publicBaseUrlFromRequest(request)
 311:   return `${publicBaseUrl}/api/plugin-market-submissions/uploads/plugins/${encodeURIComponent(filename)}`
 312: }
 313: 
 314: function submissionUploadTaskId(): number {
 315:   return Math.floor(Date.now() % 1_000_000_000) * 1000 + Math.floor(Math.random() * 1000)
 316: }
 317: 
 318: async function receiveUploadedPluginPackage(request: FastifyRequest): Promise<{ packagePath: string; sourceName: string }> {
 319:   const multipartRequest = request as FastifyRequest & {
 320:     parts: () => AsyncIterable<any>
 321:   }
 322:   const uploadTempDir = getPluginSubmissionUploadTempDir()
 323:   await mkdir(uploadTempDir, { recursive: true })
 324:   const maxBytes = getPluginPackageMaxBytes()
 325: 
 326:   for await (const part of multipartRequest.parts()) {
 327:     if (part.type !== 'file') continue
 328:     if (part.fieldname !== 'package') {
 329:       await part.toBuffer()
 330:       continue
 620:       recentDeadLetter,
 621:       recentDeduped,
 622:       recentDueRetry,
 623:       recentSuccessRate,
 624:       trendWindowDays,
 625:       trend: buildDeveloperEventTrend(trendLogs, now, trendWindowDays),
 626:       alerts: buildDeveloperEventAlerts({
 627:         deadLetter,
 628:         dueRetry,
 629:         recentTotal,
 630:         recentFailed,
 631:         recentRetryPending,
 632:         recentDeadLetter,
 633:         recentSuccessRate
 634:       }),
 635:       breakdown
 636:     }
 637:   }))
 638: }
 639: 
 640: async function listSubmittedPluginIds(userId: number): Promise<string[]> {
 641:   const submissions = await prisma.pluginMarketSubmission.findMany({
 642:     where: { submittedByUserId: userId },
 643:     select: { pluginId: true },
 644:     distinct: ['pluginId'],
 645:     orderBy: { pluginId: 'asc' }
 646:   })
 647:   return submissions.map(submission => submission.pluginId)
 648: }
