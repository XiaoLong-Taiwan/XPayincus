 189: function normalizeText(value: unknown, maxLength: number): string | null {
 190:   if (typeof value !== 'string') return null
 191:   const trimmed = value.trim()
 192:   if (!trimmed || trimmed.length > maxLength) return null
 193:   return trimmed
 194: }
 195: 
 196: function normalizeOptionalText(value: unknown, maxLength: number): string | null {
 197:   if (value === undefined || value === null || value === '') return null
 198:   return normalizeText(value, maxLength)
 199: }
 200: 
 201: function normalizeHttpsUrl(value: unknown): string | null {
 202:   const text = normalizeText(value, 2048)
 203:   if (!text) return null
 204:   try {
 205:     const url = new URL(text)
 206:     if (url.protocol !== 'https:') return null
 207:     return url.toString()
 208:   } catch {
 209:     return null
 210:   }
 211: }
 212: 
 213: function normalizeOptionalHttpsUrl(value: unknown): string | null {
 214:   if (value === undefined || value === null || value === '') return null
 215:   return normalizeHttpsUrl(value)
 216: }
 217: 
 218: function normalizeJsonRecord(value: unknown): Record<string, unknown> {
 219:   return value && typeof value === 'object' && !Array.isArray(value)
 220:     ? value as Record<string, unknown>
 221:     : {}
 222: }
 223: 
 224: function isFreePricing(value: unknown): boolean {
 225:   if (value === undefined || value === null) return true
 226:   if (!value || typeof value !== 'object' || Array.isArray(value)) return false
 227:   const pricing = value as Record<string, unknown>
 228:   return pricing.type === undefined || pricing.type === 'free'
 229: }
 230: 
 231: function normalizeSubmissionBody(body: SubmissionBody) {
 232:   const pluginId = normalizeText(body.pluginId, 120)
 233:   const version = normalizeText(body.version, 64)
