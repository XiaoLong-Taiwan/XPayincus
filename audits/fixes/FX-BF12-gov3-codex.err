 159: function getRequestUser(request: FastifyRequest): { id: number; username: string; role: 'admin' | 'user' } {
 160:   return request.user as { id: number; username: string; role: 'admin' | 'user' }
 161: }
 162: 
 163: async function canManagePluginMarketSubmissions(user: { id: number; username: string; role: 'admin' | 'user' }): Promise<boolean> {
 164:   if (user.role !== 'admin') return false
 165:   const { ids: allowedIds } = await getCombinedAdminIdAllowlist(
 166:     'plugin_manager_allowed_admin_ids',
 167:     ['PLUGIN_MANAGER_ALLOWED_ADMIN_IDS', 'SYSTEM_UPDATE_ALLOWED_ADMIN_IDS']
 168:   )
 169:   if (allowedIds.size > 0) return allowedIds.has(user.id)
 170:   return user.username === 'admin'
 171: }
 172: 
 173: async function requirePluginMarketReviewer(request: FastifyRequest, reply: FastifyReply): Promise<boolean> {
 174:   const user = getRequestUser(request)
 175:   if (!(await canManagePluginMarketSubmissions(user))) {
 176:     await createLog(
 177:       user.id,
 178:       LogModule.PLUGIN,
 179:       'plugin.market_submission.review_denied',
 180:       `Denied plugin market submission review access for ${user.username}`,
 181:       LogResult.WARNING
 182:     )
 183:     reply.code(403).send({ error: 'Super administrator privileges required', code: 'SUPER_ADMIN_REQUIRED' })
 184:     return false
 185:   }
 186:   return true
 187: }
