+        if [[ -e "${INSTALL_DIR}/${mutable}" ]]; then
+            chown -R "${RUN_USER}:${RUN_USER}" "${INSTALL_DIR}/${mutable}"
+        fi
+    done
     chmod 751 "$INSTALL_DIR"
     if [[ -f "$ENV_FILE" ]]; then
