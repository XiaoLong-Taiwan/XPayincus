+    # The fixed helper came directly from the checksum-verified archive.  Use
+    # its non-executing harden action before any service account can modify the
+    # extracted code tree.
+    /usr/local/libexec/incudal/incudal-online-task harden
+
     log "产物包安装完成"
 }
 
