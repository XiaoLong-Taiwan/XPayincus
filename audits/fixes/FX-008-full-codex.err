configure_git_metadata() {
    step "é…ç½® Git åœ¨çº¿æ›´æ–°å…ƒæ•°æ®..."

    if ! command -v git &>/dev/null; then
        warn "git æœªå®‰è£…ï¼ŒåŽå°åœ¨çº¿æ›´æ–°å°†ä¸å¯ç”¨"
