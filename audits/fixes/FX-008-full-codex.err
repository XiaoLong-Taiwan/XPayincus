  exit 1
fi

if [[ ! "$TARGET_VERSION" =~ ^v[0-9]+\.[0-9]+\.[0-9]+([-+][0-9A-Za-z.-]+)?$ ]]; then
  echo "ç›®æ ‡ç‰ˆæœ¬å¿…é¡»æ˜¯ release tagï¼Œä¾‹å¦‚ v1.2.3" >&2
  exit 1
fi

APP_DIR="$INSTALL_DIR"
if [[ -L "$INSTALL_DIR/current" ]]; then
  APP_DIR="$INSTALL_DIR/current"
