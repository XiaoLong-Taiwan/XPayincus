cd "$INSTALL_DIR"

if [[ ! -d .git ]] || ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "å½“å‰ç›®å½•ä¸æ˜¯ Git å·¥ä½œåŒºï¼Œåœ¨çº¿æ›´æ–°éœ€è¦ /opt/incudal æ˜¯åŒ…å« release tag çš„ Git checkoutã€‚" >&2
  echo "å¦‚æžœå½“å‰æœºå™¨ä»ä½¿ç”¨ release tar åŒ…éƒ¨ç½²ï¼Œè¯·å…ˆç»§ç»­ä½¿ç”¨æ‰‹åŠ¨éƒ¨ç½²åŒ…ï¼Œæˆ–æŠŠç”Ÿäº§ç›®å½•è¿ç§»ä¸º Git checkout åŽå†æ‰§è¡Œåœ¨çº¿æ›´æ–°ã€‚" >&2
  exit 1
fi

corepack enable
corepack prepare pnpm@9.14.2 --activate

INCUDAL_APP_DIR="$APP_DIR" \
