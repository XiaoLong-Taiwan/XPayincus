    fi
}

# ========================== åˆ›å»ºç³»ç»Ÿç”¨æˆ· ==========================
create_user() {
    step "é…ç½®ç³»ç»Ÿç”¨æˆ·..."

    if id "$RUN_USER" &>/dev/null; then
        log "ç”¨æˆ· ${RUN_USER} å·²å­˜åœ¨ï¼Œè·³è¿‡"
    else
        useradd --system --home-dir "${INSTALL_DIR}" --shell /usr/sbin/nologin "$RUN_USER"
        log "ç³»ç»Ÿç”¨æˆ· ${RUN_USER} åˆ›å»ºå®Œæˆ"
