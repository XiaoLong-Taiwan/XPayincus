  120: function fillSeries(rows: BucketRow[], labels: string[], money = false): SeriesPoint[] {
  121:   const rowMap = new Map(rows.map(row => [row.bucket, toNumber(row.value)]))
  122:   return labels.map(label => {
  123:     const value = rowMap.get(label) || 0
  124:     return {
  125:       label,
  126:       value: money ? roundMoney(value) : value
  127:     }
  128:   })
  129: }
  130: 
  131: function scalarValue(rows: ScalarRow[], money = false): number {
  132:   const value = toNumber(rows[0]?.value)
  133:   return money ? roundMoney(value) : value
  134: }
  135: 
  136: function addRisk(risks: OperationRisk[], condition: boolean, key: string, severity: OperationRiskSeverity, count = 0): void {
  137:   if (condition) {
  138:     risks.push({ key, severity, count })
  139:   }
  140: }
