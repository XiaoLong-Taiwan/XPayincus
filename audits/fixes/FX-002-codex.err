index 93b5c24a455714c11ba2d59d249af8145d2dbd95..10d7cf5fe2dc5a8fb87a073a69c48f9f21f86516
--- a/client/src/utils/validation.ts
+++ b/client/src/utils/validation.ts
@@ -309,11 +309,19 @@
         return false
     }
 
-    if (trimmed.startsWith('//')) {
+    if (trimmed[1] === '/' || trimmed[1] === '\\') {
+        return false
+    }
+
+    if (trimmed.includes('\\')) {
         return false
     }
 
     const lowerUrl = trimmed.toLowerCase()
+    if (lowerUrl.includes('%5c') || lowerUrl.startsWith('/%2f') || lowerUrl.startsWith('/%5c')) {
+        return false
+    }
+
     if (lowerUrl.includes('javascript:') || lowerUrl.includes('data:') || lowerUrl.includes('vbscript:')) {
         return false
     }
