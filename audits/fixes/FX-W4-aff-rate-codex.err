  645: async function testSmtpConnection() {
  646:   testingSmtp.value = true
  647:   try {
  648:     const result = await api.systemConfig.testSmtp()
  649:     if (result.success) {
  650:       toast.success(t('admin.system.smtp.testSuccess'))
  651:     } else {
  652:       toast.error(t('admin.system.smtp.testFailed') + ': ' + (result.error || 'Unknown error'))
  653:     }
  654:   } catch (err: any) {
  655:     toast.error(t('admin.system.smtp.testFailed') + ': ' + (err?.message || String(err)))
  656:   } finally {
  657:     testingSmtp.value = false
  658:   }
  659: }
  660: 
  661: async function sendTestEmail() {
  662:   if (!testEmailTo.value || !testEmailTo.value.includes('@')) {
  663:     toast.error(t('admin.system.smtp.invalidEmail'))
  664:     return
  665:   }
  666: 
  667:   sendingTestEmail.value = true
  668:   try {
  669:     const result = await api.systemConfig.sendTestEmail(testEmailTo.value)
  670:     if (result.success) {
  671:       toast.success(t('admin.system.smtp.testEmailSent', { email: testEmailTo.value }))
  672:       testEmailTo.value = ''
  673:     } else {
  674:       toast.error(t('admin.system.smtp.testEmailFailed') + ': ' + (result.error || 'Unknown error'))
  675:     }
  676:   } catch (err: any) {
  677:     toast.error(t('admin.system.smtp.testEmailFailed') + ': ' + (err?.message || String(err)))
  678:   } finally {
  679:     sendingTestEmail.value = false
  680:   }
  681: }
