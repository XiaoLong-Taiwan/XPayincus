  235: async function loadConfigs() {
  236:   loading.value = true
  237:   try {
  238:     const response = await api.systemConfig.list()
  239: 
  240:     if (!response || typeof response !== 'object') {
  241:       console.warn('[SystemConfigView] Invalid response format:', response)
  242:       configs.value = []
  243:       return
  244:     }
  245: 
  246:     configs.value = Array.isArray(response.configs) ? response.configs : []
  247: 
  248:     // å¡«å……è¡¨å•
  249:     if (Array.isArray(response.configs)) {
  250:       for (const config of response.configs) {
  251:         if (config && typeof config === 'object' && config.key && config.key in form.value) {
  252:           try {
  253:             if (numericConfigKeys.includes(config.key)) {
  254:               (form.value as any)[config.key] = parseInt(config.value, 10) || 0
  255:             } else if (floatConfigKeys.includes(config.key)) {
  256:               (form.value as any)[config.key] = parseFloat(config.value) || 0
  257:             } else if (booleanConfigKeys.includes(config.key)) {
  258:               (form.value as any)[config.key] = config.value === 'true'
  259:             } else if (stringConfigKeys.includes(config.key)) {
  260:               (form.value as any)[config.key] = config.value || ''
  261:             } else if (jsonConfigKeys.includes(config.key)) {
  262:               try {
  263:                 (form.value as any)[config.key] = JSON.parse(config.value || '[]')
  264:               } catch {
  265:                 (form.value as any)[config.key] = []
  266:               }
  267:             }
  268:           } catch (configErr) {
  269:             console.error(`[SystemConfigView] Failed to process config key "${config.key}":`, configErr)
  270:           }
  271:         }
  272:       }
  273:     }
  274:   } catch (err: any) {
  275:     console.error('[SystemConfigView] Error loading configs:', err)
  276:     try {
  277:       toast.error((t('admin.system.loadFailed') || 'åŠ è½½é…ç½®å¤±è´¥') + ': ' + (err?.message || String(err)))
  278:     } catch (toastErr) {
  279:       console.error('[SystemConfigView] Failed to show toast:', toastErr)
  280:     }
  281:     // ç¡®ä¿configsæ˜¯ä¸€ä¸ªç©ºæ•°ç»„ï¼Œé¿å…åŽç»­ä»£ç å‡ºé”™
  282:     configs.value = []
  283:   } finally {
  284:     loading.value = false
  285:   }
  286: }
