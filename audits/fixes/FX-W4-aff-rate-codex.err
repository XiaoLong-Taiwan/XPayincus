  684: <template>
  685:   <div class="kawaii-page space-y-6 animate-fade-in">
  686:     <div class="page-header">
  687:       <div>
  688:         <h1 class="page-title">{{ t('admin.system.title') || 'ç³»ç»Ÿè®¾ç½®' }}</h1>
  689:         <p class="page-description">{{ t(currentSection.descriptionKey) || t('admin.system.description') }}</p>
  690:       </div>
  691:     </div>
  692: 
  693:     <div class="grid grid-cols-2 gap-2 border-b border-gray-200 pb-2 dark:border-gray-700 sm:flex sm:gap-0 sm:overflow-x-auto sm:pb-0">
  694:       <router-link
  695:         v-for="item in systemSettingsNavigationItems"
  696:         :key="item.path"
  697:         :to="item.path"
  698:         class="min-w-0 rounded-lg border px-3 py-2 text-center text-xs font-medium transition-colors sm:shrink-0 sm:rounded-none sm:border-0 sm:border-b-2 sm:px-4 sm:py-3 sm:text-left sm:text-sm"
  699:         :class="route.path === item.path
  700:           ? 'border-black bg-themed-secondary text-gray-900 dark:border-white dark:text-white sm:bg-transparent'
  701:           : 'border-gray-200 text-gray-500 hover:text-gray-700 dark:border-gray-700 dark:hover:text-gray-300 sm:border-transparent'"
  702:       >
  703:         {{ t(item.labelKey) }}
  704:       </router-link>
  705:     </div>
  706: 
  707:     <!-- Loading -->
  708:     <div v-if="loading" class="card p-6 animate-pulse">
  709:       <div class="h-6 bg-themed-secondary rounded w-1/4 mb-6"></div>
  710:       <div class="space-y-4">
  711:         <div v-for="i in 7" :key="i" class="h-12 bg-themed-secondary rounded"></div>
  712:       </div>
  713:     </div>
  714: 
  715:     <!-- Config Form -->
  716:     <div v-else class="space-y-6">
  717:       <div v-if="isPopupAnnouncementTab" class="card p-6">
  718:         <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between mb-2">
  719:           <div>
  720:             <h3 class="text-themed font-medium">{{ t('admin.system.popupAnnouncement.title') }}</h3>
  721:             <p class="text-sm text-themed-muted mt-1">{{ t('admin.system.popupAnnouncement.description') }}</p>
  722:           </div>
  723:           <button
  724:             type="button"
  725:             class="btn-primary text-sm px-4 py-1.5"
  726:             :disabled="!hasPopupAnnouncementChanges || savingPopupAnnouncement || form.popup_announcement.length > 5000"
  727:             @click="savePopupAnnouncement"
  728:           >
  729:             {{ savingPopupAnnouncement ? t('admin.system.saving') : t('admin.system.save') }}
  730:           </button>
  731:         </div>
  732: 
  733:         <div class="mt-6 space-y-2">
  734:           <label class="block text-sm text-themed-secondary">
  735:             {{ t('admin.system.popupAnnouncement.content') }}
