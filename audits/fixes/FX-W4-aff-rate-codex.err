  311: // é€šç”¨ä¿å­˜å‡½æ•°
  312: async function saveConfigGroup(keys: string[], savingRef: { value: boolean }) {
  313:   savingRef.value = true
  314:   try {
  315:     const configsToUpdate = keys.map(key => ({
  316:       key,
  317:       value: jsonConfigKeys.includes(key)
  318:         ? JSON.stringify((form.value as any)[key] || [])
  319:         : typeof (form.value as any)[key] === 'boolean'
  320:           ? ((form.value as any)[key] ? 'true' : 'false')
  321:           : String((form.value as any)[key])
  322:     }))
  323: 
  324:     await api.systemConfig.update(configsToUpdate)
  325:     toast.success(t('admin.system.saveSuccess'))
  326:     await loadConfigs()
  327:   } catch (err: any) {
  328:     toast.error(t('admin.system.saveFailed') + ': ' + getConfigSaveErrorMessage(err))
  329:   } finally {
  330:     savingRef.value = false
  331:   }
  332: }
