  347: function normalizeInviteCostOptions() {
  348:   const options = Array.isArray(form.value.invite_generation_costs)
  349:     ? form.value.invite_generation_costs
  350:     : []
  351:   const optionMap = new Map(options.map((option: any) => [option.resource, option]))
  352:   for (const resource of ['balance', 'points']) {
  353:     if (!optionMap.has(resource)) {
  354:       optionMap.set(resource, { resource, amount: 0, enabled: false })
  355:     }
  356:   }
  357:   form.value.invite_generation_costs = Array.from(optionMap.values()).map((option: any) => ({
  358:     resource: option.resource,
  359:     amount: option.resource === 'points'
  360:       ? Math.max(0, Math.floor(Number(option.amount) || 0))
  361:       : Math.max(0, Math.round((Number(option.amount) || 0) * 100) / 100),
  362:     enabled: option.enabled === true
  363:   }))
  364: }
