  372:   return invitePricingKeys.some(key => {
  373:     const config = configs.value.find(c => c.key === key)
  374:     if (!config) return false
  375:     const currentValue = jsonConfigKeys.includes(key)
  376:       ? JSON.stringify((form.value as any)[key] || [])
  377:       : String((form.value as any)[key])
  378:     return currentValue !== config.value
  379:   })
  380: })
