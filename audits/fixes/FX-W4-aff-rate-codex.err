  288: async function loadPopupPromoPackages() {
  289:   if (popupPromoPackagesLoading.value || popupPromoPackagesLoaded.value) {
  290:     return
  291:   }
  292:   popupPromoPackagesLoading.value = true
  293:   try {
  294:     const [officialResponse, marketResponse] = await Promise.all([
  295:       api.packages.list({ source: 'official' }),
  296:       api.packages.list({ source: 'market' })
  297:     ])
  298:     popupPromoPackages.value = [
  299:       ...(officialResponse.packages || []),
  300:       ...(marketResponse.packages || [])
  301:     ].filter(pkg => pkg.active === 1)
  302:     popupPromoPackagesLoaded.value = true
  303:   } catch (err) {
  304:     console.error('[SystemConfigView] Failed to load promo packages:', err)
  305:     popupPromoPackages.value = []
  306:   } finally {
  307:     popupPromoPackagesLoading.value = false
  308:   }
  309: }
