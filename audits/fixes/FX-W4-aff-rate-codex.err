  235: async function loadConfigs() {
  236:   loading.value = true
  237:   try {
  238:     const response = await api.systemConfig.list()
  239: 
  240:     if (!response || typeof response !== 'object') {
  241:       console.warn('[SystemConfigView] Invalid response format:', response)
  242:       configs.value = []
  243:       return
  244:     }
  245: 
  246:     configs.value = Array.isArray(response.configs) ? response.configs : []
  247: 
  248:     // å¡«å……è¡¨å•
  249:     if (Array.isArray(response.configs)) {
  250:       for (const config of response.configs) {
  251:         if (config && typeof config === 'object' && config.key && config.key in form.value) {
  252:           try {
  253:             if (numericConfigKeys.includes(config.key)) {
  254:               (form.value as any)[config.key] = parseInt(config.value, 10) || 0
  255:             } else if (floatConfigKeys.includes(config.key)) {
  256:               (form.value as any)[config.key] = parseFloat(config.value) || 0
  257:             } else if (booleanConfigKeys.includes(config.key)) {
  258:               (form.value as any)[config.key] = config.value === 'true'
  259:             } else if (stringConfigKeys.includes(config.key)) {
  260:               (form.value as any)[config.key] = config.value || ''
  261:             } else if (jsonConfigKeys.includes(config.key)) {
  262:               try {
  263:                 (form.value as any)[config.key] = JSON.parse(config.value || '[]')
  264:               } catch {
  265:                 (form.value as any)[config.key] = []
  266:               }
  267:             }
  268:           } catch (configErr) {
  269:             console.error(`[SystemConfigView] Failed to process config key "${config.key}":`, configErr)
  270:           }
  271:         }
  272:       }
  273:     }
  274:   } catch (err: any) {
  275:     console.error('[SystemConfigView] Error loading configs:', err)
  276:     try {
  277:       toast.error((t('admin.system.loadFailed') || 'åŠ è½½é…ç½®å¤±è´¥') + ': ' + (err?.message || String(err)))
  278:     } catch (toastErr) {
  279:       console.error('[SystemConfigView] Failed to show toast:', toastErr)
  280:     }
  281:     // ç¡®ä¿configsæ˜¯ä¸€ä¸ªç©ºæ•°ç»„ï¼Œé¿å…åŽç»­ä»£ç å‡ºé”™
  282:     configs.value = []
  283:   } finally {
  284:     loading.value = false
  285:   }
  286: }
  287: 
  288: async function loadPopupPromoPackages() {
  289:   if (popupPromoPackagesLoading.value || popupPromoPackagesLoaded.value) {
  290:     return
  291:   }
  292:   popupPromoPackagesLoading.value = true
  293:   try {
  294:     const [officialResponse, marketResponse] = await Promise.all([
  295:       api.packages.list({ source: 'official' }),
  296:       api.packages.list({ source: 'market' })
  297:     ])
  298:     popupPromoPackages.value = [
  299:       ...(officialResponse.packages || []),
  300:       ...(marketResponse.packages || [])
  301:     ].filter(pkg => pkg.active === 1)
  302:     popupPromoPackagesLoaded.value = true
  303:   } catch (err) {
  304:     console.error('[SystemConfigView] Failed to load promo packages:', err)
  305:     popupPromoPackages.value = []
  306:   } finally {
  307:     popupPromoPackagesLoading.value = false
  308:   }
  309: }
  310: 
  311: // é€šç”¨ä¿å­˜å‡½æ•°
  312: async function saveConfigGroup(keys: string[], savingRef: { value: boolean }) {
  313:   savingRef.value = true
  314:   try {
  315:     const configsToUpdate = keys.map(key => ({
  316:       key,
  317:       value: jsonConfigKeys.includes(key)
  318:         ? JSON.stringify((form.value as any)[key] || [])
  319:         : typeof (form.value as any)[key] === 'boolean'
  320:           ? ((form.value as any)[key] ? 'true' : 'false')
  321:           : String((form.value as any)[key])
  322:     }))
  323: 
  324:     await api.systemConfig.update(configsToUpdate)
  325:     toast.success(t('admin.system.saveSuccess'))
  326:     await loadConfigs()
  327:   } catch (err: any) {
  328:     toast.error(t('admin.system.saveFailed') + ': ' + getConfigSaveErrorMessage(err))
  329:   } finally {
