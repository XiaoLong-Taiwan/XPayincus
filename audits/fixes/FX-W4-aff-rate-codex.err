    const existing = await prisma.affCode.findUnique({
      where: { userId_packagePlanId: { userId, packagePlanId } }
    })
    if (existing) {
      return { success: false, error: 'è¯¥æ–¹æ¡ˆå·²åˆ›å»ºè¿‡ä¼˜æƒ ç ' }
    }

    // 5. åˆ›å»ºä¼˜æƒ ç 
    const code = generateAffCode(userId)
    const affCode = await prisma.affCode.create({
      data: {
        code,
        userId,
        packagePlanId,
        discountRate,
        commissionRate
      }
    })

    return { success: true, affCode }
  } catch (error) {
    return {
      success: false,
      error: error instanceof Error ? error.message : 'åˆ›å»ºä¼˜æƒ ç å¤±è´¥'
    }
  }
}

