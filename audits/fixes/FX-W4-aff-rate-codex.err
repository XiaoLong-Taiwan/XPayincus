+  const commissionRate = Number(form.value.aff_commission_rate)
+  const discountRate = Number(form.value.aff_discount_rate)
+  if (
+    !Number.isFinite(commissionRate) || commissionRate < 0 || commissionRate > MAX_AFF_COMMISSION_RATE ||
