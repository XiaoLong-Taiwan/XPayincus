codex
原因已定位为 Vite 默认“bundle config”加载器在沙箱内解析配置时越过工作区读取上级目录。Vite 6 支持 `--configLoader runner`，可直接运行同一配置而不做该越界打包；我将用 client 本地二进制分别构建 user/admin。这只是验证命令调整，不改仓库文件。
exec
"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command '$env:VITE_APP_ENTRY='"'user'; pnpm exec vue-tsc; if ("'$LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; pnpm exec vite build --configLoader runner; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; $env:VITE_APP_ENTRY='"'admin'; pnpm exec vue-tsc; if ("'$LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; pnpm exec vite build --configLoader runner; exit $LASTEXITCODE' in C:\Users\Administrator\Desktop\payinces\client
