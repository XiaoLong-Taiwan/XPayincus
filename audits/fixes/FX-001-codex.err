    ref="frameRef"
    :class="['w-full rounded-lg border border-themed bg-themed-surface', frameClass || 'min-h-[560px]']"
    :src="frameUrl"
    :title="title"
    sandbox="allow-forms allow-scripts allow-same-origin"
    referrerpolicy="same-origin"
    @load="refreshPluginConfig"
  />
</template>


