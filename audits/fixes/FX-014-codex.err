enum HostingActionType {
  purchase     // ç”¨æˆ·å¼€é€šå®žä¾‹
  renew        // ç”¨æˆ·ç»­è´¹å®žä¾‹
  upgrade      // ç”¨æˆ·å‡çº§æ–¹æ¡ˆ
