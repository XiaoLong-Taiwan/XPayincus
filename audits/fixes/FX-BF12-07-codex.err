+    }
+    await loadThemeSubmissions()
+  } catch (error: any) {
+    toast.error(t('extensions.themeSubmissions.submitFailed') + ': ' + (error?.message || String(error)))
+  } finally {
+    submittingTheme.value = false
+  }
+}
