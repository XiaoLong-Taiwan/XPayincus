  363:     if (network.ipv6 !== undefined) updateData.ipv6 = network.ipv6 ?? null
  364:   }
  365: 
  366:   if (status === 'deleted') {
  367:     await prisma.instance.update({
  368:       where: { id },
  369:       data: updateData
  370:     })
  371:     return
  372:   }
  373: 
  374:   await prisma.instance.updateMany({
  375:     where: {
  376:       id,
  377:       status: { not: 'deleted' }
  378:     },
  379:     data: updateData
  380:   })
  381: }
