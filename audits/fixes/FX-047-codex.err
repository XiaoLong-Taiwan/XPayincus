@@ -7,6 +7,7 @@
 const __dirname = dirname(__filename)
 
 const instancesSource = readFileSync(resolve(__dirname, '../src/routes/instances.ts'), 'utf8')
+const dbInstancesSource = readFileSync(resolve(__dirname, '../src/db/instances.ts'), 'utf8')
