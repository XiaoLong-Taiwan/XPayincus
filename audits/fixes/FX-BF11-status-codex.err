  788: /**
  789:  * 获取用户所有宿主机的工单（汇总视图）
  790:  * 支持 active 状态筛选、搜索、智能排序
  791:  */
  792: export async function getOwnerAllTickets(
  793:   ownerId: number | undefined,
  794:   options: {
  795:     status?: TicketStatus | 'active'
  796:     hostId?: number
  797:     sourceType?: 'user' | 'official' | 'hosted'
  798:     queue?: 'pending' | 'due_soon' | 'overdue' | 'waiting_user' | 'waiting_internal'
  799:     search?: string
  800:     page?: number
  801:     pageSize?: number
  802:   } = {}
  803: ): Promise<{
  804:   tickets: TicketWithDetailsExtended[]
  805:   total: number
  806:   page: number
  807:   pageSize: number
  808:   totalPages: number
  809: }> {
  810:   const { page, pageSize } = clampPagination(options.page, options.pageSize, 10)
  811:   const status = normalizeTicketStatus(options.status)
  812:   const searchTerm = normalizeSearchTerm(options.search)
  813:   const skip = (page - 1) * pageSize
  814: 
  815:   const where: any = {}
  816:   
  817:   // 如果指定了 ownerId，只查询该用户的节点工单；否则查询所有工单（管理员）
  818:   if (ownerId !== undefined) {
  819:     where.host = { userId: ownerId }
  820:   } else if (options.sourceType === 'user') {
  821:     where.hostId = null
  822:   } else if (options.sourceType === 'official') {
  823:     where.host = { user: { role: 'admin' } }
  824:   } else if (options.sourceType === 'hosted') {
  825:     where.host = { user: { role: { not: 'admin' } } }
  826:   }
  827:   
  828:   // 状态筛选
  829:   if (status === 'active') {
  830:     where.status = { not: 'closed' }
  831:   } else if (status) {
  832:     where.status = status
  833:   }
  834:   
  835:   if (Number.isInteger(options.hostId) && options.hostId !== undefined && options.hostId > 0 && options.sourceType !== 'user') {
  836:     where.hostId = options.hostId
  837:   }
  838: 
  839:   // 搜索
  840:   if (searchTerm) {
  841:     const searchId = getSearchId(searchTerm)
  842:     if (searchId !== null) {
  843:       where.OR = [
  844:         { id: searchId },
  845:         { subject: { contains: searchTerm, mode: 'insensitive' } },
  846:         { user: { username: { contains: searchTerm, mode: 'insensitive' } } }
  847:       ]
  848:     } else {
  849:       where.OR = [
  850:         { subject: { contains: searchTerm, mode: 'insensitive' } },
  851:         { user: { username: { contains: searchTerm, mode: 'insensitive' } } }
  852:       ]
  853:     }
  854:   }
  855: 
  856:   const [tickets, total] = await Promise.all([
  857:     prisma.ticket.findMany({
  858:       where,
  859:       include: {
  860:         user: {
  861:           select: {
  862:             id: true,
  863:             username: true,
  864:             avatarStyle: true,
  865:             avatarBadgeId: true
  866:           }
  867:         },
  868:         host: {
  869:           select: {
  870:             id: true,
  871:             name: true,
  872:             userId: true,
  873:             countryCode: true
  874:           }
  875:         },
  876:         instance: {
  877:           select: {
  878:             id: true,
  879:             name: true,
  880:             status: true,
  881:             iconBadgeId: true
  882:           }
  883:         },
  884:         _count: {
  885:           select: { messages: true }
  886:         },
  887:         messages: {
  888:           orderBy: { createdAt: 'desc' },
  889:           take: 1,
  890:           select: {
  891:             content: true,
  892:             isFromOwner: true,
  893:             createdAt: true
  894:           }
  895:         }
  896:       },
  897:       // 排序策略：按更新时间降序，便于在内存中排序
  898:       orderBy: { updatedAt: 'desc' },
  899:       skip,
  900:       take: pageSize
  901:     }),
  902:     prisma.ticket.count({ where })
  903:   ])
  904: 
  905:   // 构建返回数据，添加 needsReply 字段
  906:   let ticketsWithNeedsReply = tickets.map(ticket => {
  907:     const lastMsg = ticket.messages[0]
  908:     // 宿主机视角：如果最后一条消息来自用户（isFromOwner=false），说明需要宿主机主人回复
  909:     const needsReply = ticket.status !== 'closed' && lastMsg?.isFromOwner === false
  910:     
  911:     return {
  912:       id: ticket.id,
  913:       userId: ticket.userId,
  914:       hostId: ticket.hostId,
  915:       instanceId: ticket.instanceId,
  916:       subject: ticket.subject,
  917:       category: ticket.category,
  918:       priority: ticket.priority,
  919:       status: ticket.status,
  920:       createdAt: ticket.createdAt.toISOString(),
  921:       updatedAt: ticket.updatedAt.toISOString(),
  922:       resolvedAt: toIso(ticket.resolvedAt),
  923:       closedAt: toIso(ticket.closedAt),
  924:       firstResponseDueAt: toIso(ticket.firstResponseDueAt),
  925:       resolutionDueAt: toIso(ticket.resolutionDueAt),
  926:       firstRespondedAt: toIso(ticket.firstRespondedAt),
  927:       slaBreachedAt: toIso(ticket.slaBreachedAt),
  928:       slaStatus: computeSlaStatus({
  929:         status: ticket.status,
  930:         firstResponseDueAt: ticket.firstResponseDueAt,
  931:         resolutionDueAt: ticket.resolutionDueAt,
  932:         firstRespondedAt: ticket.firstRespondedAt,
  933:         resolvedAt: ticket.resolvedAt,
  934:         closedAt: ticket.closedAt,
  935:         lastMessage: lastMsg ?? null
  936:       }),
  937:       user: ticket.user,
  938:       host: ticket.host,
  939:       instance: ticket.instance,
  940:       messageCount: ticket._count.messages,
  941:       lastMessage: lastMsg ? {
  942:         content: lastMsg.content,
  943:         isFromOwner: lastMsg.isFromOwner,
  944:         createdAt: lastMsg.createdAt.toISOString()
  945:       } : null,
  946:       needsReply
  947:     }
  948:   })
  949: 
  950:   if (options.queue) {
  951:     ticketsWithNeedsReply = ticketsWithNeedsReply.filter(ticket => {
  952:       if (options.queue === 'pending') return ticket.needsReply
  953:       return ticket.slaStatus === options.queue
  954:     })
  955:   }
  956: 
  957:   // 智能排序：需要回复的排前面，再按优先级和更新时间
  958:   const priorityOrder: Record<string, number> = { urgent: 0, high: 1, normal: 2, low: 3 }
  959:   const statusOrder: Record<string, number> = { open: 0, in_progress: 1, resolved: 2, closed: 3 }
  960:   
  961:   ticketsWithNeedsReply.sort((a, b) => {
  962:     // 1. 需要回复的排前面
  963:     if (a.needsReply !== b.needsReply) return a.needsReply ? -1 : 1
  964:     // 2. 按状态排序
  965:     if (a.status !== b.status) return statusOrder[a.status] - statusOrder[b.status]
  966:     // 3. 按优先级排序
  967:     if (a.priority !== b.priority) return priorityOrder[a.priority] - priorityOrder[b.priority]
  968:     // 4. 按更新时间排序：需要回复的按旧到新，其他按新到旧
  969:     const aTime = new Date(a.updatedAt).getTime()
  970:     const bTime = new Date(b.updatedAt).getTime()
  971:     return a.needsReply ? aTime - bTime : bTime - aTime
  972:   })
  973: 
  974:   return {
  975:     tickets: ticketsWithNeedsReply,
  976:     total,
  977:     page,
  978:     pageSize,
  979:     totalPages: Math.ceil(total / pageSize)
  980:   }
  981: }
