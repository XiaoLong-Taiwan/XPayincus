 /**
+ * 获取曾通过资源池调整过的实例及资源类型，供 Incus/DB 轻量对账重放。
+ * DB 中的实例规格是持久化期望值，重复 patch Incus 是幂等的。
+ */
+export async function getResourcePoolApplyReconciliationCandidates(): Promise<Array<{
+  instanceId: number
+  resourceTypes: RedeemCodeType[]
+}>> {
+  const appliedResources = await prisma.resourcePoolLog.findMany({
+    where: {
+      action: 'apply',
+      instanceId: { not: null },
+      instance: {
+        status: { in: ['running', 'stopped'] }
+      }
+    },
+    select: {
+      instanceId: true,
+      resourceType: true
+    },
+    distinct: ['instanceId', 'resourceType']
+  })
+
+  const grouped = new Map<number, Set<RedeemCodeType>>()
+  for (const applied of appliedResources) {
+    if (applied.instanceId === null) continue
+    const resourceTypes = grouped.get(applied.instanceId) ?? new Set<RedeemCodeType>()
+    resourceTypes.add(applied.resourceType)
+    grouped.set(applied.instanceId, resourceTypes)
+  }
+
+  return Array.from(grouped, ([instanceId, resourceTypes]) => ({
+    instanceId,
+    resourceTypes: Array.from(resourceTypes)
+  }))
+}
