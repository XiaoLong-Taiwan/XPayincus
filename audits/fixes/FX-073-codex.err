 153: export async function applyResourcePoolToInstance(data: {
 154:   userId: number
 155:   instanceId: number
 156:   hostId: number
 157:   resourceType: RedeemCodeType
 158:   amount: number
 159:   remark?: string
 160:   instanceResources?: {
 161:     cpu?: number
 162:     memory?: number
 163:     disk?: number
 164:   }
 165:   hostResourceDelta?: {
 166:     cpuUsed?: number
 167:     memoryUsed?: number
 168:     diskUsed?: number
 169:   }
 170:   monthlyTrafficDelta?: bigint
 171: }): Promise<number | null> {
 172:   if (!Number.isSafeInteger(data.amount) || data.amount <= 0 || data.amount > MAX_RESOURCE_POOL_APPLY_AMOUNT) {
 173:     throw new Error('Invalid resource pool apply amount')
 174:   }
 175: 
 176:   const field = RESOURCE_FIELD_MAP[data.resourceType]
 177:   if (!field) {
 178:     throw new Error(`Invalid resource type: ${data.resourceType}`)
 179:   }
 180: 
 181:   return prisma.$transaction(async (tx) => {
 182:     await advisoryTransactionLock(tx, USER_RESOURCE_POOL_LOCK_NAMESPACE, data.userId)
 183:     await advisoryTransactionLock(tx, INSTANCE_OPERATION_LOCK_NAMESPACE, data.instanceId)
 184: 
 185:     let decrementResult = 0
 186:     if (field === 'cpu') {
 187:       decrementResult = await tx.$executeRaw`
 188:         UPDATE "user_resource_pools"
 189:         SET "cpu" = "cpu" - ${data.amount}
 190:         WHERE "user_id" = ${data.userId}
 191:           AND "cpu" >= ${data.amount}
 192:       `
 193:     } else if (field === 'memory') {
 194:       decrementResult = await tx.$executeRaw`
 195:         UPDATE "user_resource_pools"
 196:         SET "memory" = "memory" - ${data.amount}
 197:         WHERE "user_id" = ${data.userId}
 198:           AND "memory" >= ${data.amount}
 199:       `
 200:     } else if (field === 'disk') {
 201:       decrementResult = await tx.$executeRaw`
 202:         UPDATE "user_resource_pools"
 203:         SET "disk" = "disk" - ${data.amount}
 204:         WHERE "user_id" = ${data.userId}
 205:           AND "disk" >= ${data.amount}
 206:       `
 207:     } else {
 208:       const amount = BigInt(data.amount)
 209:       decrementResult = await tx.$executeRaw`
 210:         UPDATE "user_resource_pools"
 211:         SET "traffic" = "traffic" - ${amount}
 212:         WHERE "user_id" = ${data.userId}
 213:           AND "traffic" >= ${amount}
 214:       `
 215:     }
 216: 
 217:     if (decrementResult === 0) {
 218:       return false
 219:     }
 220: 
 221:     const applyLog = await tx.resourcePoolLog.create({
 222:       data: {
 223:         userId: data.userId,
 224:         action: 'apply',
 225:         resourceType: data.resourceType,
 226:         amount: -data.amount,
 227:         instanceId: data.instanceId,
 228:         remark: data.resourceType === 't'
 229:           ? data.remark
 230:           : `${RESOURCE_POOL_INCUS_PENDING_PREFIX}${data.remark ?? ''}`
 231:       }
 232:     })
 233: 
 234:     if (data.hostResourceDelta) {
 235:       const cpuDelta = data.hostResourceDelta.cpuUsed ?? 0
 236:       const memoryDelta = data.hostResourceDelta.memoryUsed ?? 0
 237:       const diskDelta = data.hostResourceDelta.diskUsed ?? 0
 238:       if (cpuDelta < 0 || memoryDelta < 0 || diskDelta < 0) {
 239:         throw new Error('Resource amounts must be non-negative')
 240:       }
 241: 
 242:       const host = await tx.host.findUnique({
 243:         where: { id: data.hostId },
 244:         select: {
 245:           cpuAllowanceMax: true,
 246:           memoryMax: true,
 247:           storageSize: true
 248:         }
 249:       })
 250:       if (!host) {
 251:         throw new Error('HOST_NOT_FOUND')
 252:       }
 253: 
 254:       const cpuLimit = host.cpuAllowanceMax || 0
 255:       const memoryLimit = host.memoryMax || 0
 256:       const diskLimit = host.storageSize > 0 ? host.storageSize * 1024 : 0
 257:       if (
 258:         (cpuLimit > 0 && cpuDelta > cpuLimit) ||
 259:         (memoryLimit > 0 && memoryDelta > memoryLimit) ||
 260:         (diskLimit > 0 && diskDelta > diskLimit)
 261:       ) {
 262:         throw new Error('HOST_RESOURCES_INSUFFICIENT')
 263:       }
 264: 
 265:       const applyWhere: Prisma.HostWhereInput = { id: data.hostId }
 266:       if (cpuLimit > 0) {
 267:         applyWhere.cpuUsed = { lte: cpuLimit - cpuDelta }
 268:       }
 269:       if (memoryLimit > 0) {
 270:         applyWhere.memoryUsed = { lte: memoryLimit - memoryDelta }
 271:       }
 272:       if (diskLimit > 0) {
 273:         applyWhere.diskUsed = { lte: diskLimit - diskDelta }
 274:       }
 275: 
 276:       const hostUpdate = await tx.host.updateMany({
 277:         where: applyWhere,
 278:         data: {
 279:           cpuUsed: { increment: cpuDelta },
 280:           memoryUsed: { increment: memoryDelta },
 281:           diskUsed: { increment: diskDelta }
 282:         }
 283:       })
 284:       if (hostUpdate.count === 0) {
 285:         throw new Error('HOST_RESOURCES_INSUFFICIENT')
 286:       }
 287:     }
 288: 
 289:     if (data.instanceResources) {
 290:       await tx.instance.update({
 291:         where: { id: data.instanceId },
 292:         data: data.instanceResources
 293:       })
 294:     }
 295: 
 296:     if (data.monthlyTrafficDelta !== undefined) {
 297:       await tx.$executeRaw`
 298:         UPDATE "instances"
 299:         SET "monthly_traffic_limit" = COALESCE("monthly_traffic_limit", 0) + ${data.monthlyTrafficDelta}
 300:         WHERE "id" = ${data.instanceId}
 301:       `
 302:     }
 303: 
 304:     return applyLog.id
 305:   })
 306: }
 307: 
