  305: async function createInstanceTaskOrConflict(
  306:   reply: FastifyReply,
  307:   data: CreateInstanceTaskData
  308: ): Promise<InstanceTaskWithDetails | null> {
  309:   try {
  310:     const task = await createInstanceTask(data)
  311:     const instance = await prisma.instance.findUnique({
  312:       where: { id: data.instanceId },
  313:       select: { name: true }
  314:     })
  315:     emitServiceTaskPluginEvent({
  316:       event: 'service.task.queued',
  317:       instanceId: task.instanceId,
  318:       userId: task.userId,
  319:       hostId: task.hostId,
  320:       instanceName: instance?.name || `instance-${task.instanceId}`,
  321:       taskId: task.id,
  322:       taskType: task.taskType,
  323:       taskStatus: task.status,
  324:       source: 'instances.route',
  325:       dedupeKey: `service.task.queued:instances:${task.id}`,
  326:       metadata: {
  327:         imageAlias: task.imageAlias,
  328:         targetName: task.targetName,
  329:         targetHostId: task.targetHostId,
  330:         snapshotName: task.snapshotName
  331:       }
  332:     })
  333:     return task
  334:   } catch (error) {
  335:     if (error instanceof InstanceTaskConflictError) {
  336:       sendActiveTaskConflict(reply, error.activeTask)
  337:       return null
  338:     }
  339:     throw error
  340:   }
  341: }
