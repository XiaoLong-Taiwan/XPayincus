    1: /**
    2:  * 实例操作任务数据库操作
    3:  */
    4: 
    5: import { prisma } from './prisma.js'
    6: import type { InstanceTaskType, InstanceTaskStatus, Prisma } from '@prisma/client'
    7: import { INSTANCE_OPERATION_LOCK_NAMESPACE, tryAdvisoryTransactionLock } from './advisory-locks.js'
    8: 
    9: export interface CreateInstanceTaskData {
   10:   instanceId: number
   11:   hostId: number
   12:   userId: number
   13:   taskType: InstanceTaskType
   14:   imageAlias?: string       // 重装使用的镜像别名
   15:   sshKeyId?: number         // 重装使用的 SSH 密钥 ID
   16:   customInitCommandIds?: number[]  // 重装使用的自定义初始化命令 ID 列表
   17:   targetName?: string       // 克隆的目标名称
   18:   targetHostId?: number     // 克隆的目标宿主机
   19:   snapshotName?: string     // 克隆时的快照名称
   20:   allowExchangeLocked?: boolean // 交易所内部交割任务可显式绕过挂牌锁
   21: }
   22: 
   23: export interface InstanceTaskWithDetails {
   24:   id: number
   25:   instanceId: number
   26:   hostId: number
   27:   userId: number
   28:   taskType: InstanceTaskType
   29:   status: InstanceTaskStatus
   30:   progress: string | null
   31:   retryCount: number
   32:   imageAlias: string | null
   33:   sshKeyId: number | null
   34:   customInitCommandIds: string | null  // JSON 字符串，解析后为 number[]
   35:   targetName: string | null
   36:   targetHostId: number | null
   37:   snapshotName: string | null
   38:   newInstanceId: number | null
   39:   error: string | null
   40:   createdAt: Date
   41:   startedAt: Date | null
   42:   finishedAt: Date | null
   43: }
   44: 
   45: export class InstanceTaskConflictError extends Error {
   46:   activeTask: InstanceTaskWithDetails | null
   47: 
   48:   constructor(activeTask: InstanceTaskWithDetails | null = null) {
   49:     super('Instance has an active task')
   50:     this.name = 'InstanceTaskConflictError'
   51:     this.activeTask = activeTask
   52:   }
   53: }
   54: 
   55: const INSTANCE_TASK_STATUSES = new Set<InstanceTaskStatus>([
   56:   'PENDING',
   57:   'PROCESSING',
   58:   'COMPLETED',
   59:   'FAILED'
   60: ])
   61: 
   62: function clampInstanceTaskPagination(
   63:   page: number | undefined,
   64:   pageSize: number | undefined
   65: ): { page: number; pageSize: number } {
   66:   return {
   67:     page: Number.isInteger(page) && page !== undefined && page > 0 ? page : 1,
   68:     pageSize: Number.isInteger(pageSize) && pageSize !== undefined
   69:       ? Math.min(Math.max(pageSize, 1), 100)
   70:       : 20
   71:   }
   72: }
   73: 
   74: function normalizeInstanceTaskStatuses(status?: InstanceTaskStatus[]): InstanceTaskStatus[] | undefined {
   75:   if (!Array.isArray(status)) {
   76:     return undefined
   77:   }
   78: 
   79:   const normalized = status.filter((value): value is InstanceTaskStatus => INSTANCE_TASK_STATUSES.has(value))
   80:   return normalized.length > 0 ? normalized : undefined
   81: }
   82: 
   83: /**
   84:  * 创建实例操作任务
   85:  */
   86: export async function createInstanceTask(data: CreateInstanceTaskData): Promise<InstanceTaskWithDetails> {
   87:   const result = await prisma.$transaction(async tx => {
   88:     const locked = await tryAdvisoryTransactionLock(tx, INSTANCE_OPERATION_LOCK_NAMESPACE, data.instanceId)
   89:     if (!locked) {
   90:       throw new InstanceTaskConflictError()
   91:     }
   92: 
   93:     const activeTask = await tx.instanceTask.findFirst({
   94:       where: {
   95:         instanceId: data.instanceId,
   96:         status: { in: ['PENDING', 'PROCESSING'] }
   97:       },
   98:       orderBy: [
   99:         { createdAt: 'asc' },
  100:         { id: 'asc' }
  101:       ]
  102:     })
  103:     if (activeTask) {
  104:       throw new InstanceTaskConflictError(activeTask as unknown as InstanceTaskWithDetails)
  105:     }
  106: 
  107:     if (!data.allowExchangeLocked) {
  108:       const exchangeLocked = await tx.exchangeListing.findFirst({
  109:         where: {
  110:           instanceId: data.instanceId,
  111:           status: { in: ['active', 'paused', 'locked', 'delivery_failed'] }
  112:         },
  113:         select: { id: true, status: true }
  114:       })
  115:       if (exchangeLocked) {
  116:         throw new Error('实例已上架交易所或处于交易锁定中，不能执行该操作')
  117:       }
  118: 
  119:       const exchangeOrder = await tx.exchangeOrder.findFirst({
  120:         where: {
  121:           instanceId: data.instanceId,
  122:           status: { in: ['escrowed', 'delivering', 'delivered', 'confirming', 'disputed', 'manual_review', 'failed'] }
  123:         },
  124:         select: { id: true, status: true }
  125:       })
  126:       if (exchangeOrder) {
  127:         throw new Error('实例存在未完成的交易所订单，不能执行该操作')
  128:       }
  129:     }
  130: 
  131:     // 注：使用 as any 绕过 Prisma 类型检查，因为 customInitCommandIds 字段在迁移后才会生成类型
  132:     return tx.instanceTask.create({
  133:       data: {
  134:         instanceId: data.instanceId,
  135:         hostId: data.hostId,
  136:         userId: data.userId,
  137:         taskType: data.taskType,
  138:         imageAlias: data.imageAlias || null,
  139:         sshKeyId: data.sshKeyId || null,
  140:         customInitCommandIds: data.customInitCommandIds ? JSON.stringify(data.customInitCommandIds) : null,
  141:         targetName: data.targetName || null,
  142:         targetHostId: data.targetHostId || null,
  143:         snapshotName: data.snapshotName || null,
  144:         status: 'PENDING'
  145:       } as any
  146:     })
  147:   })
  148:   return result as unknown as InstanceTaskWithDetails
  149: }
  150: 
  151: /**
  152:  * 获取任务详情
  153:  */
  154: export async function getInstanceTaskById(taskId: number): Promise<InstanceTaskWithDetails | null> {
  155:   const result = await prisma.instanceTask.findUnique({
  156:     where: { id: taskId }
  157:   })
  158:   return result as unknown as InstanceTaskWithDetails | null
  159: }
  160: 
  161: /**
  162:  * 获取实例的活跃任务（PENDING 或 PROCESSING）
  163:  */
  164: export async function getActiveTaskForInstance(instanceId: number): Promise<InstanceTaskWithDetails | null> {
  165:   const result = await prisma.instanceTask.findFirst({
  166:     where: {
  167:       instanceId,
  168:       status: { in: ['PENDING', 'PROCESSING'] }
  169:     },
  170:     orderBy: { createdAt: 'desc' }
  171:   })
  172:   return result as unknown as InstanceTaskWithDetails | null
  173: }
  174: 
  175: /**
  176:  * 获取用户的任务列表
  177:  */
  178: export async function getUserInstanceTasks(
  179:   userId: number,
  180:   options: { page?: number; pageSize?: number; status?: InstanceTaskStatus[] } = {}
  181: ): Promise<{ items: InstanceTaskWithDetails[]; total: number }> {
  182:   const { page, pageSize } = clampInstanceTaskPagination(options.page, options.pageSize)
  183:   const status = normalizeInstanceTaskStatuses(options.status)
  184: 
  185:   const where: Prisma.InstanceTaskWhereInput = { userId }
  186:   if (status && status.length > 0) {
  187:     where.status = { in: status }
  188:   }
  189: 
  190:   const [items, total] = await Promise.all([
  191:     prisma.instanceTask.findMany({
  192:       where,
  193:       orderBy: { createdAt: 'desc' },
  194:       skip: (page - 1) * pageSize,
  195:       take: pageSize
  196:     }),
  197:     prisma.instanceTask.count({ where })
  198:   ])
  199: 
  200:   return { items: items as unknown as InstanceTaskWithDetails[], total }
  201: }
  202: 
  203: /**
  204:  * 更新任务状态
  205:  */
  206: export async function updateInstanceTaskStatus(
  207:   taskId: number,
  208:   status: InstanceTaskStatus,
  209:   updates?: {
  210:     progress?: string
  211:     error?: string
  212:     startedAt?: Date
  213:     finishedAt?: Date
  214:     newInstanceId?: number
  215:   }
  216: ): Promise<InstanceTaskWithDetails> {
  217:   const result = await prisma.instanceTask.update({
  218:     where: { id: taskId },
  219:     data: {
  220:       status,
  221:       ...updates
  222:     }
  223:   })
  224:   return result as unknown as InstanceTaskWithDetails
  225: }
  226: 
  227: /**
  228:  * 更新任务进度
  229:  */
  230: export async function updateInstanceTaskProgress(taskId: number, progress: string): Promise<void> {
  231:   await prisma.instanceTask.update({
  232:     where: { id: taskId },
  233:     data: { progress }
  234:   })
  235: }
  236: 
  237: /**
  238:  * 获取队列位置
  239:  */
