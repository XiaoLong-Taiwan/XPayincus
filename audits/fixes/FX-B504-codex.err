 6602: // ==================== 辅助函数 ====================
 6603: 
 6604: /**
 6605:  * 异步创建实例
 6606:  */
 6607: async function createInstanceAsync(
 6608:   instanceId: number,
 6609:   host: Host,
 6610:   config: {
 6611:     name: string
 6612:     image: string
 6613:     cpu: number
 6614:     memory: number
 6615:     disk: number
 6616:     swapEnabled?: boolean
 6617:     swapSize?: number | null
 6618:     cloudInitConfig?: Record<string, string>
 6619:     networkMode: 'nat' | 'nat_ipv6' | 'nat_ipv6_nat' | 'ipv6_only' | 'ipv6_nat' | 'public_ipv4' | 'public_ipv4_ipv6'
 6620:     nested?: boolean
 6621:     privileged?: boolean
 6622:     portLimit?: number
 6623:     // 实例类型: container(容器) 或 vm(虚拟机)
 6624:     instanceType?: 'container' | 'vm'
 6625:     // SSH 端口（固定 22）
 6626:     sshPort?: number | null
 6627:     // 存储池配置
 6628:     storagePool?: string | null
 6629:     // IP 配置 (新双网卡架构)
 6630:     ipv4Address?: string | null  // 内网 IPv4 (随机分配)
 6631:     ipv6Address?: string | null  // IPv6 (随机分配)
 6632:     ipv6Gateway?: string | null
 6633:     hostInterface?: string | null  // 宿主机物理网卡名 (用于 routed 模式)
 6634:     // Advanced configuration options from package
 6635:     limitsRead?: string | null
