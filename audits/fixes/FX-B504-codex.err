diff --git a/server/scripts/test-instance-create-failure-compensation.ts b/server/scripts/test-instance-create-failure-compensation.ts
index 3462d490312a9faf2807fd2ab2ab222d3a5acb6b..345b56a58fb1f0197ddf712a21741d781de8c891
--- a/server/scripts/test-instance-create-failure-compensation.ts
+++ b/server/scripts/test-instance-create-failure-compensation.ts
@@ -32,6 +32,30 @@
   '    throw error\n  }\n}'
 )
 
+const staticIpAllocationSection = section(
+  instancesSource,
+  '    if (networkModeNeedsNatIpv4(networkMode)) {',
+  '    console.log(`[Provisioning] IP 分配完成: IPv4=${staticIPv4}, IPv6=${staticIPv6}`)'
+)
+
+assert.ok(
+  staticIpAllocationSection.includes('staticIpAllocationError = `NAT 内网 IPv4 分配失败') &&
+    staticIpAllocationSection.includes("staticIpAllocationError ||= '宿主机未配置 routed IPv6 子网'") &&
+    staticIpAllocationSection.includes('staticIpAllocationError ||= `routed IPv6 分配失败') &&
+    staticIpAllocationSection.includes('await createInstanceAsync(instanceId, host, {') &&
+    staticIpAllocationSection.includes('return reply.code(503).send(apiError(ErrorCode.HOST_RESOURCES_INSUFFICIENT, staticIpAllocationError))'),
+  'fatal NAT IPv4 and routed IPv6 allocation failures must enter provisioning compensation and return an explicit failure'
+)
+
+assert.ok(
+  instancesSource.indexOf('if (preflightError) {') < instancesSource.indexOf('const client = await getIncusClient(host)') &&
+    failureSection.includes('await db.compensateFailedInstancePurchase(instanceId, userId, host.id)') &&
+    failureSection.includes("data: { status: 'error' }") &&
+    !staticIpAllocationSection.includes('实例将使用动态 IP') &&
+    !staticIpAllocationSection.includes('将使用动态分配'),
+  'fatal static IP allocation failures must be compensated and refunded before Incus creation, never delivered as running with dynamic addressing'
+)
+
 assert.ok(
   failureSection.includes('if (updateResult.count > 0 && userId && resources)') &&
     failureSection.includes('await db.compensateFailedInstancePurchase(instanceId, userId, host.id)'),
