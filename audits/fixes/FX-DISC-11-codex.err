 515:                 关闭
 516:               </button>
 517:             </div>
 518:           </div>
 519:         </div>
 520:         <div class="hidden overflow-x-auto lg:block">
 521:           <table class="w-full min-w-[900px] text-left text-sm">
 522:             <thead class="border-b border-themed text-xs uppercase text-themed-muted">
 523:               <tr>
 524:                 <th class="px-4 py-3 font-medium">Case</th>
 525:                 <th class="px-4 py-3 font-medium">实例</th>
 526:                 <th class="px-4 py-3 font-medium">目标资源</th>
 527:                 <th class="px-4 py-3 font-medium">最近扣费</th>
 528:                 <th class="px-4 py-3 font-medium">状态</th>
 529:                 <th class="px-4 py-3 font-medium">错误</th>
 530:                 <th class="px-4 py-3 font-medium">操作</th>
 531:               </tr>
 532:             </thead>
 533:             <tbody>
 534:               <tr v-for="item in repairCases" :key="item.id" class="border-b border-themed last:border-b-0">
 535:                 <td class="px-4 py-3">
 536:                   <div class="font-medium text-themed">#{{ item.id }}</div>
 537:                   <div class="text-xs text-themed-muted">{{ issueTypeLabel(item.assuranceCase.issueType) }}</div>
 538:                 </td>
 539:                 <td class="px-4 py-3">
 540:                   <div class="font-medium text-themed">{{ item.instance?.name || `#${item.instanceId}` }}</div>
 541:                   <div class="text-xs text-themed-muted">{{ item.user?.username || `用户 #${item.userId}` }} · {{ item.host?.name || `节点 #${item.hostId}` }}</div>
 542:                 </td>
 543:                 <td class="px-4 py-3 text-xs text-themed-muted">
 544:                   <div>CPU {{ item.instance?.cpu ?? '-' }}%</div>
 545:                   <div>内存 {{ item.instance?.memory ?? '-' }} MB</div>
 546:                   <div>磁盘 {{ item.instance?.disk ?? '-' }} MB</div>
 547:                   <div>带宽 {{ item.instance?.limitsIngress || '不限速' }} / {{ item.instance?.limitsEgress || '不限速' }}</div>
 548:                 </td>
 549:                 <td class="px-4 py-3">
 550:                   <div class="text-themed">{{ formatAmount(item.billing?.amount) }}</div>
 551:                   <div class="text-xs text-themed-muted">{{ formatDate(item.billing?.createdAt) }}</div>
 552:                 </td>
 553:                 <td class="px-4 py-3">
 554:                   <span class="rounded-md border px-2 py-1 text-xs" :class="caseStatusClass(item.assuranceCase.status)">
 555:                     {{ caseStatusLabel(item.assuranceCase.status) }}
 556:                   </span>
 557:                 </td>
 558:                 <td class="max-w-[260px] px-4 py-3">
 559:                   <div class="truncate text-xs text-themed-muted" :title="item.assuranceCase.lastError || ''">
 560:                     {{ item.assuranceCase.lastError || item.assuranceCase.title }}
 561:                   </div>
 562:                   <div v-if="item.assuranceCase.handledByUsername" class="mt-1 text-xs text-themed-muted">
 563:                     {{ item.assuranceCase.handledByUsername }} · {{ formatDate(item.assuranceCase.handledAt) }}
 564:                   </div>
 565:                 </td>
 566:                 <td class="px-4 py-3">
 567:                   <div class="flex flex-wrap gap-2">
 568:                     <button
 569:                       class="btn-primary btn-sm"
 570:                       :disabled="!!caseActionLoading || item.assuranceCase.status === 'recovered' || item.assuranceCase.status === 'closed'"
 571:                       @click="runRepairCaseAction(item, 'retry-sync')"
 572:                     >
 573:                       {{ caseActionLoading === `retry-sync:${item.id}` ? '同步中...' : '重试同步' }}
 574:                     </button>
 575:                     <button
 576:                       class="btn-secondary btn-sm"
 577:                       :disabled="!!caseActionLoading || item.assuranceCase.status === 'recovered'"
 578:                       @click="runRepairCaseAction(item, 'recovered')"
 579:                     >
 580:                       标记恢复
 581:                     </button>
 582:                     <button
 583:                       class="btn-secondary btn-sm"
 584:                       :disabled="!!caseActionLoading || item.assuranceCase.status === 'closed'"
 585:                       @click="runRepairCaseAction(item, 'closed')"
 586:                     >
 587:                       关闭
 588:                     </button>
 589:                   </div>
 590:                 </td>
 591:               </tr>
 592:               <tr v-if="repairCases.length === 0">
 593:                 <td colspan="7" class="px-4 py-10 text-center text-sm text-themed-muted">
 594:                   暂无升级同步修复任务
 595:                 </td>
 596:               </tr>
 597:             </tbody>
 598:           </table>
 599:         </div>
 600: 
 601:         <div class="flex items-center justify-between border-t border-themed p-4 text-sm text-themed-muted">
 602:           <span>共 {{ repairTotal }} 条</span>
 603:           <div class="flex items-center gap-2">
 604:             <button class="btn-secondary" :disabled="repairPage <= 1" @click="goRepairPage(repairPage - 1)">上一页</button>
 605:             <span>{{ repairPage }} / {{ repairTotalPages }}</span>
 606:             <button class="btn-secondary" :disabled="repairPage >= repairTotalPages" @click="goRepairPage(repairPage + 1)">下一页</button>
 607:           </div>
