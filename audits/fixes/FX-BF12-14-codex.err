  738: function themeConfigFieldOrder([, field]: ThemeConfigFieldEntry): number {
  739:   return typeof field.order === 'number' && Number.isFinite(field.order) ? field.order : 1000
  740: }
  741: 
  742: function themeConfigGroupName(field: PayIncusThemeConfigField): string {
  743:   return field.group?.trim() || DEFAULT_THEME_CONFIG_GROUP
  744: }
  745: 
  746: function sortThemeConfigFields(fields: ThemeConfigFieldEntry[]): ThemeConfigFieldEntry[] {
  747:   return fields.sort((left, right) => {
  748:     const leftOrder = themeConfigFieldOrder(left)
  749:     const rightOrder = themeConfigFieldOrder(right)
  750:     if (leftOrder !== rightOrder) return leftOrder - rightOrder
  751:     return left[0].localeCompare(right[0])
  752:   })
  753: }
  754: 
  755: function themeConfigFields(theme: ThemePackageRecord): ThemeConfigFieldEntry[] {
  756:   return sortThemeConfigFields(Object.entries(theme.manifest.configSchema || {}))
  757: }
  758: 
  759: function themeConfigGroups(theme: ThemePackageRecord): ThemeConfigGroup[] {
  760:   const groups = new Map<string, ThemeConfigFieldEntry[]>()
  761:   for (const entry of themeConfigFields(theme)) {
  762:     const groupName = themeConfigGroupName(entry[1])
  763:     const fields = groups.get(groupName) || []
  764:     fields.push(entry)
  765:     groups.set(groupName, fields)
  766:   }
  767:   return Array.from(groups.entries())
  768:     .map(([name, fields]) => ({ name, fields }))
  769:     .sort((left, right) => {
  770:       const leftOrder = themeConfigFieldOrder(left.fields[0])
  771:       const rightOrder = themeConfigFieldOrder(right.fields[0])
  772:       if (leftOrder !== rightOrder) return leftOrder - rightOrder
  773:       return left.name.localeCompare(right.name)
  774:     })
  775: }
  776: 
  777: function themeConfigFieldCount(theme: ThemePackageRecord): number {
  778:   return themeConfigFields(theme).filter(([, field]) => field.type !== 'placeholder').length
  779: }
