  432: function assertPluginStorageAccess(manifest: PayIncusPluginManifest, mode: 'read' | 'write'): { ok: true } | { ok: false; code: string; status: number; message: string } {
  433:   if (manifest.capabilities?.storage?.kind !== 'kv') {
  434:     return { ok: false, status: 403, code: 'PLUGIN_STORAGE_NOT_DECLARED', message: 'Plugin storage is not declared in manifest capabilities' }
  435:   }
  436:   if (mode === 'read' && (hasPluginPermission(manifest, 'plugin-storage:read') || hasPluginPermission(manifest, 'plugin-storage:write'))) {
  437:     return { ok: true }
  438:   }
  439:   if (mode === 'write' && hasPluginPermission(manifest, 'plugin-storage:write')) {
  440:     return { ok: true }
  441:   }
  442:   return { ok: false, status: 403, code: 'PLUGIN_STORAGE_PERMISSION_REQUIRED', message: 'Plugin manifest does not grant storage permission' }
  443: }
