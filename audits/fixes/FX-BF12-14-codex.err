  454:   return manifest.capabilities?.storage?.tables?.find(table => table.name === tableName) || null
  455: }
  456: 
  457: function assertPluginTableScope(
  458:   manifest: PayIncusPluginManifest,
  459:   table: PluginTableManifest,
  460:   scope: 'user' | 'global' | 'service'
  461: ): { ok: true } | { ok: false; code: string; status: number; message: string } {
  462:   const tableScopes = table.scopes && table.scopes.length > 0
  463:     ? table.scopes
  464:     : manifest.capabilities?.storage?.scopes || ['user']
  465:   if (!tableScopes.includes(scope)) {
  466:     return { ok: false, status: 403, code: 'PLUGIN_TABLE_SCOPE_NOT_DECLARED', message: 'Plugin table scope is not declared in manifest capabilities' }
  467:   }
  468:   return { ok: true }
  469: }
  470: 
  471: async function resolvePluginStorageScope(
  472:   scope: 'user' | 'global' | 'service',
  473:   query: PluginScopedStorageQuery,
  474:   user: { id: number; role: 'admin' | 'user' }
  475: ): Promise<{ ok: true; scopeId: string } | { ok: false; status: number; code: string; message: string }> {
  476:   if (scope === 'global') return { ok: true, scopeId: '_' }
  477:   if (scope === 'user') return { ok: true, scopeId: String(user.id) }
  478: 
  479:   const instanceId = parsePositiveId(query.scopeId)
  480:   if (!instanceId) {
  481:     return { ok: false, status: 400, code: 'PLUGIN_STORAGE_SCOPE_ID_REQUIRED', message: 'service storage requires a valid scopeId' }
  482:   }
  483:   const instance = await prisma.instance.findFirst({
  484:     where: { id: instanceId, userId: user.id },
  485:     select: { id: true }
  486:   })
  487:   if (!instance) {
  488:     return { ok: false, status: 404, code: 'PLUGIN_STORAGE_SERVICE_NOT_FOUND', message: 'Service scope not found for current user' }
  489:   }
  490:   return { ok: true, scopeId: String(instance.id) }
  491: }
