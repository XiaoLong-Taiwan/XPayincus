  426: function submissionScanFindings(submission: PluginMarketSubmission): Array<{ severity: string; code: string; message: string }> {
  427:   const result = submission.scanResult
  428:   if (!result || typeof result !== 'object' || Array.isArray(result)) return []
  429:   const findings = (result as { findings?: unknown }).findings
  430:   if (!Array.isArray(findings)) return []
  431:   return findings
  432:     .map(item => item && typeof item === 'object' ? item as { severity?: unknown; code?: unknown; message?: unknown } : null)
  433:     .filter((item): item is { severity?: unknown; code?: unknown; message?: unknown } => !!item)
  434:     .map(item => ({
  435:       severity: typeof item.severity === 'string' ? item.severity : 'info',
  436:       code: typeof item.code === 'string' ? item.code : 'unknown',
  437:       message: typeof item.message === 'string' ? item.message : ''
  438:     }))
  439: }
  440: 
  441: function themeSubmissionScanFindings(submission: ThemeMarketSubmission): Array<{ severity: string; code: string; message: string }> {
  442:   const result = submission.scanResult
  443:   if (!result || typeof result !== 'object' || Array.isArray(result)) return []
  444:   const findings = (result as { findings?: unknown }).findings
  445:   if (!Array.isArray(findings)) return []
  446:   return findings
  447:     .map(item => item && typeof item === 'object' ? item as { severity?: unknown; code?: unknown; message?: unknown } : null)
  448:     .filter((item): item is { severity?: unknown; code?: unknown; message?: unknown } => !!item)
  449:     .map(item => ({
  450:       severity: typeof item.severity === 'string' ? item.severity : 'info',
  451:       code: typeof item.code === 'string' ? item.code : 'unknown',
  452:       message: typeof item.message === 'string' ? item.message : ''
  453:     }))
  454: }
