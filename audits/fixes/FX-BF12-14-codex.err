  460: function buildMarketInstallConfirmation(entry: PluginMarketEntry): string {
  461:   const permissions = [
  462:     ...entry.permissions.adminPages.map(item => `åŽå°é¡µé¢ï¼š${item}`),
  463:     ...entry.permissions.userPages.map(item => `ç”¨æˆ·é¡µé¢ï¼š${item}`),
  464:     ...entry.permissions.api.map(item => `æŽ¥å£æƒé™ï¼š${formatMarketPermission(item)}`),
  465:     ...entry.permissions.storage.map(item => `å­˜å‚¨ç›®å½•ï¼š${item}`)
  466:   ]
  467:   return [
  468:     `ç¡®è®¤å®‰è£… ${entry.name} ${entry.latest}ï¼Ÿ`,
  469:     `å®¡æ ¸çŠ¶æ€ï¼š${marketReviewLabels[entry.reviewStatus]}`,
  470:     `å¯ä¿¡æ¥æºï¼š${marketTrustLabels[entry.trustLevel]}`,
  471:     `å…¼å®¹èŒƒå›´ï¼š${formatCompatibility(entry)}`,
  472:     `åŒ…æ ¡éªŒï¼šSHA256 ${entry.sha256.slice(0, 16)}...`,
  473:     `æƒé™å£°æ˜Žï¼š${permissions.length ? permissions.join('ï¼›') : 'æ— '}`
  474:   ].join('\n')
  475: }
