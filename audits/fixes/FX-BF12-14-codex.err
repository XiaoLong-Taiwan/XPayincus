  785: function normalizeThemeConfigDraftValue(value: unknown, fallback: ThemeConfigDraftValue): ThemeConfigDraftValue {
  786:   if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') return value
  787:   if (Array.isArray(value)) return value.filter((item): item is string => typeof item === 'string')
  788:   return fallback
  789: }
  790: 
  791: function buildThemeConfigDraft(theme: ThemePackageRecord): Record<string, ThemeConfigDraftValue> {
  792:   const draft: Record<string, ThemeConfigDraftValue> = {}
  793:   for (const [key, field] of themeConfigFields(theme)) {
  794:     if (field.type === 'placeholder') continue
  795:     const currentValue = theme.configValues?.[key]
  796:     const fallback: ThemeConfigDraftValue = field.type === 'checkbox'
  797:       ? false
  798:       : field.type === 'tags'
  799:         ? []
  800:         : typeof field.default === 'number' || typeof field.default === 'boolean' || typeof field.default === 'string'
  801:           ? field.default
  802:           : ''
  803:     if (currentValue !== undefined) {
  804:       draft[key] = normalizeThemeConfigDraftValue(currentValue, fallback)
  805:     } else if (field.default !== undefined) {
  806:       draft[key] = normalizeThemeConfigDraftValue(field.default, fallback)
  807:     } else if (field.type === 'checkbox') {
  808:       draft[key] = false
  809:     } else if (field.type === 'tags') {
  810:       draft[key] = []
  811:     } else {
  812:       draft[key] = ''
  813:     }
  814:   }
  815:   return draft
  816: }
