  498: 
  499: async function loadPluginStorageUsage(pluginId = selectedPluginId.value) {
  500:   if (!pluginId) {
  501:     pluginStorageUsage.value = null
  502:     pluginStorageUsageError.value = ''
  503:     return
  504:   }
  505:   pluginStorageUsageLoading.value = true
  506:   pluginStorageUsageError.value = ''
  507:   try {
  508:     const response = await api.plugins.getStorageUsage(pluginId)
  509:     if (selectedPluginId.value === pluginId) {
  510:       pluginStorageUsage.value = response.usage
