  547: function downloadJsonFile(filename: string, value: unknown): void {
  548:   const blob = new Blob([JSON.stringify(value, null, 2)], { type: 'application/json' })
  549:   const url = URL.createObjectURL(blob)
  550:   const link = document.createElement('a')
  551:   link.href = url
  552:   link.download = filename
  553:   link.click()
  554:   URL.revokeObjectURL(url)
  555: }
