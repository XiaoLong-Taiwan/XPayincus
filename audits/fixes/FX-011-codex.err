  243: async function settleUserDestroyBilling(params: {
  244:   requestUserId: number
  245:   instance: {
  246:     id: number
  247:     userId: number
  248:     hostId: number
  249:     name: string
  250:   }
  251:   refundableValue: number
  252:   feeWaiver: boolean
  253: }): Promise<{ refundAmount: number; feeAmount: number; isFirstTime: boolean }> {
  254:   const { requestUserId, instance, refundableValue, feeWaiver } = params
  255:   const instanceId = instance.id
  256: 
  257:   return await prisma.$transaction(async (tx) => {
  258:     await advisoryTransactionLock(tx, USER_DESTROY_BILLING_LOCK_NAMESPACE, requestUserId)
  259: 
  260:     const destroyCount = await tx.userDestroyRecord.count({
  261:       where: { userId: requestUserId }
  262:     })
  263:     const isFirstTime = destroyCount === 0
  264:     let feeAmount = 0
  265:     if (!feeWaiver && !isFirstTime) {
  266:       feeAmount = roundMoney(refundableValue * calculateFeeRate(destroyCount))
  267:     }
  268:     const refundAmount = roundMoney(Math.max(0, refundableValue - feeAmount))
  269: 
  270:     if (refundAmount > 0) {
  271:       await advisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, instance.userId)
  272: 
  273:       const currentUser = await tx.user.findUnique({
  274:         where: { id: instance.userId },
  275:         select: { balance: true }
  276:       })
  277:       const oldBalance = Number(currentUser?.balance || 0)
  278: 
  279:       const updatedUser = await tx.user.update({
  280:         where: { id: instance.userId },
  281:         data: { balance: { increment: refundAmount } },
  282:         select: { balance: true }
  283:       })
  284:       const newBalance = Number(updatedUser.balance)
  285: 
  286:       const balanceLog = await tx.balanceLog.create({
  287:         data: {
  288:           userId: instance.userId,
  289:           type: 'refund',
  290:           amount: refundAmount,
  291:           balanceBefore: oldBalance,
  292:           balanceAfter: newBalance,
  293:           instanceId,
  294:           remark: `用户销毁实例退款：${instance.name}${feeWaiver ? '（异常实例免手续费）' : feeAmount > 0 ? `（手续费 ¥${feeAmount.toFixed(2)}）` : '（首次销毁免手续费）'}`
  295:         }
  296:       })
  297: 
  298:       await tx.instanceBillingRecord.create({
  299:         data: {
  300:           instanceId,
  301:           userId: instance.userId,
  302:           type: 'refund',
  303:           amount: -refundAmount,
  304:           months: 0,
  305:           periodStart: new Date(),
  306:           periodEnd: new Date(),
  307:           balanceLogId: balanceLog.id,
  308:           remark: `用户销毁实例退款${feeWaiver ? '（异常实例免手续费）' : feeAmount > 0 ? `（手续费 ¥${feeAmount.toFixed(2)}）` : '（首次销毁免手续费）'}`
  309:         }
  310:       })
  311: 
  312:       await db.deductHostingBalance(
  313:         instance.hostId,
  314:         refundAmount,
  315:         instanceId,
  316:         `用户销毁托管实例退款扣除：${instance.name}`,
  317:         tx
  318:       )
  319:     }
  320: 
  321:     await tx.userDestroyRecord.create({
  322:       data: {
 2480:               expiresAt: newExpiresAt,
 2481:               // 如果是因到期被封停，解除封停
 2482:               ...(instance.status === 'suspended' && instance.suspendReason === 'expired' ? {
 2483:                 status: 'stopped',
 2484:                 suspendedAt: null,
 2485:                 suspendedBy: null,
 2486:                 suspendReason: null
 2487:               } : {})
 2488:             }
 2489:           })
 2490: 
 2491:           // 记录免费延期记录
 2492:           await tx.instanceBillingRecord.create({
 2493:             data: {
 2494:               instanceId,
 2495:               userId: instance.userId,
 2496:               type: 'renew',  // 使用 renew 类型表示免费延期
 2497:               amount: 0,
 2498:               months: 0,
 2499:               periodStart: baseDate,
 2500:               periodEnd: newExpiresAt,
 2501:               remark: `管理员免费延期 ${days} 天（操作者: ${admin.username}）：${reason || '免费延期'}`
 2502:             }
 2503:           })
 2504:         })
 2505:       }
 2506: 
 2507:       await createLog(
 2508:         admin.id,
 2509:         'admin',
 2510:         'instance.admin_extend',
 2511:         `Admin extended instance "${instance.name}" by ${days} days (User: ${instance.user?.username}, Amount: ${extendAmount})`,
 2512:         'success',
 2513:         { instanceId }
 2514:       )
 2515: 
 2516:       // 通知用户
 2517:       await sendNotification(instance.userId, 'instance_extended', {
 2518:         instanceName: instance.name,
 2519:         days,
 2520:         newExpiresAt: newExpiresAt.toISOString(),
 2521:         amount: extendAmount
 2522:       })
 2523: 
 2524:       return {
 2525:         success: true,
 2526:         message: `实例已延期 ${days} 天`,
 2527:         amount: extendAmount,
 2528:         newExpiresAt: newExpiresAt.toISOString()
 2529:       }
 2530:     } catch (error) {
 2531:       const errorMessage = error instanceof Error ? error.message : String(error)
 2532:       if (errorMessage.includes('BALANCE_CONFLICT')) {
 2533:         return reply.status(409).send({ error: '用户余额正在处理，请稍后重试' })
 2534:       }
 2535:       if (errorMessage.includes('BALANCE_INSUFFICIENT')) {
 2536:         return reply.status(400).send({ error: '用户余额不足' })
 2537:       }
 2538:       request.log.error(error, '延期实例失败')
 2539:       return reply.status(500).send({ error: '延期实例失败' })
 2540:     }
 2541:   })
 2542: 
 2543:   // ==================== 管理员退款 ====================
 2544: 
 2545:   // POST /api/admin/instances/:id/refund - 管理员退款
 2546:   app.post('/api/admin/instances/:id/refund', {
 2547:     onRequest: [app.authenticate, app.requireAdmin],
 2548:     config: { rateLimit: { max: 10, timeWindow: '1 minute' } }
 2549:   }, async (request, reply) => {
 2550:     try {
 2551:       const admin = request.user!
 2552:       const { id } = request.params as { id: string }
 2553:       const { amount, reason } = request.body as {
 2554:         amount: number
 2555:         reason: string
 2556:       }
 2557: 
 2558:       const instanceId = parsePositiveRouteId(id)
 2559:       if (!instanceId) {
 2560:         return reply.status(400).send({ error: '无效的实例ID' })
 2561:       }
 2562: 
 2563:       if (!amount || amount <= 0) {
 2564:         return reply.status(400).send({ error: '退款金额必须大于0' })
 2565:       }
 2566: 
 2567:       if (!reason || reason.trim().length < 2) {
 2568:         return reply.status(400).send({ error: '请填写退款原因' })
 2569:       }
 2570: 
 2571:       const instance = await prisma.instance.findUnique({
 2572:         where: { id: instanceId },
 2573:         include: { user: { select: { id: true, username: true, balance: true } } }
 2574:       })
 2575: 
 2576:       if (!instance) {
