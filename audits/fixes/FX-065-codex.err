  205: async function changeBalanceInTransaction(
  206:   tx: Prisma.TransactionClient,
  207:   input: BalanceChangeInput
  208: ): Promise<{ balanceLog: BalanceLog; newBalance: number }> {
  209:   const { userId, type, amount, orderId, instanceId, remark } = input
  210:   const normalizedAmount = normalizeBalanceAmount(amount)
  211: 
  212:   const locked = await tryAdvisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, userId)
  213:   if (!locked) {
  214:     throw new Error('余额正在处理，请稍后重试')
  215:   }
  216: 
  217:   const user = await tx.user.findUnique({
  218:     where: { id: userId },
  219:     select: { balance: true }
  220:   })
  221: 
  222:   if (!user) {
  223:     throw new Error('用户不存在')
  224:   }
  225: 
  226:   const balanceBefore = Number(user.balance)
  227:   const balanceAfter = Number((balanceBefore + normalizedAmount).toFixed(2))
  228: 
  229:   if (normalizedAmount < 0 && balanceAfter < 0) {
  230:     throw new Error('余额不足')
  231:   }
  232: 
  233:   if (Math.abs(balanceAfter) > MAX_BALANCE_AMOUNT) {
  234:     throw new Error('余额超出系统允许范围')
  235:   }
  236: 
  237:   const updateResult = await tx.user.updateMany({
  238:     where: {
  239:       id: userId,
  240:       ...(normalizedAmount < 0 ? { balance: { gte: Math.abs(normalizedAmount) } } : {})
  241:     },
  242:     data: { balance: { increment: normalizedAmount } }
  243:   })
  244: 
  245:   if (updateResult.count === 0) {
  246:     throw new Error('余额不足或并发冲突')
  247:   }
  248: 
  249:   const updatedUser = await tx.user.findUnique({
  250:     where: { id: userId },
  251:     select: { balance: true }
  252:   })
  253: 
  254:   if (!updatedUser) {
  255:     throw new Error('用户不存在')
  256:   }
  257: 
  258:   const persistedBalanceAfter = Number(updatedUser.balance)
  259: 
  260:   const balanceLog = await tx.balanceLog.create({
