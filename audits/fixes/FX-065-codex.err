  684:     return
  685:   }
  686: 
  687:   // Validate startup delay (5-600)
  688:   if (startupDelay < 5 || startupDelay > 600) {
  689:     formError.value = t('packageForm.validation.startupDelayRange')
  690:     return
  691:   }
  692: 
  693:   // Validate shutdown timeout (30-600)
  694:   if (shutdownTimeout < 30 || shutdownTimeout > 600) {
  695:     formError.value = t('packageForm.validation.shutdownTimeoutRange')
  696:     return
  697:   }
  698: 
  699:   // Validate port limit (must be >= 1, cannot be 0)
  700:   if (form.value.portLimit !== null && form.value.portLimit !== undefined) {
  701:     if (form.value.portLimit < 1) {
  702:       formError.value = t('packageForm.validation.portLimitMin')
  703:       return
  704:     }
  705:   }
  706: 
