  357: export async function approveBalanceAdjustmentRequest(
  358:   requestId: number,
  359:   reviewerUserId: number,
  360:   reviewRemark?: string
  361: ): Promise<{ request: BalanceAdjustmentRequestWithRelations; newBalance: number }> {
  362:   return prisma.$transaction(async (tx) => {
  363:     const request = await tx.balanceAdjustmentRequest.findUnique({
  364:       where: { id: requestId },
  365:       include: includeBalanceAdjustmentRequestRelations()
  366:     })
  367: 
  368:     if (!request) {
  369:       throw new Error('调账申请不存在')
  370:     }
  371:     if (request.status !== 'pending') {
  372:       throw new Error('调账申请已处理')
  373:     }
  374: 
  375:     const claimed = await tx.balanceAdjustmentRequest.updateMany({
  376:       where: { id: requestId, status: 'pending' },
  377:       data: {
  378:         status: 'approved',
  379:         reviewedByUserId: reviewerUserId,
  380:         reviewedAt: new Date(),
  381:         reviewRemark
  382:       }
  383:     })
  384: 
  385:     if (claimed.count !== 1) {
  386:       throw new Error('调账申请已处理')
  387:     }
  388: 
  389:     const isRechargeRefund = request.requestType === 'refund' && request.sourceType === 'recharge'
  390:     const logType: BalanceLogType = request.requestType === 'refund' && Number(request.amount) > 0 && !isRechargeRefund
  391:       ? 'refund'
  392:       : 'admin_adjust'
  393:     const balanceChangeAmount = isRechargeRefund
  394:       ? -Math.abs(Number(request.amount))
  395:       : Number(request.amount)
  396:     const remark = [
  397:       `[审批通过] ${request.reason}`,
  398:       request.orderNo ? `订单 ${request.orderNo}` : '',
  399:       isRechargeRefund ? '充值退款收回余额' : '',
  400:       reviewRemark ? `审核备注: ${reviewRemark}` : ''
  401:     ].filter(Boolean).join('；')
  402: 
  403:     const balanceResult = await changeBalanceInTransaction(tx, {
  404:       userId: request.userId,
  405:       type: logType,
  406:       amount: balanceChangeAmount,
  407:       orderId: request.orderNo || undefined,
  408:       remark
  409:     })
  410: 
  411:     const updatedRequest = await tx.balanceAdjustmentRequest.update({
  412:       where: { id: requestId },
  413:       data: { balanceLogId: balanceResult.balanceLog.id },
  414:       include: includeBalanceAdjustmentRequestRelations()
  415:     })
  416: 
  417:     return {
  418:       request: updatedRequest as BalanceAdjustmentRequestWithRelations,
  419:       newBalance: balanceResult.newBalance
  420:     }
  421:   })
  422: }
