  328: function normalizePackagePlanInput(input: unknown, options: {
  329:   requireAll: boolean
  330:   isVm: boolean
  331: }): NormalizedPackagePlanInput {
  332:   if (!isPlainRecord(input)) {
  333:     throw apiError(ErrorCode.VALIDATION_ERROR, '请求参数无效')
  334:   }
  335: 
  336:   const normalized: NormalizedPackagePlanInput = {}
  337: 
  338:   if (options.requireAll) {
  339:     for (const field of ['name', 'cpu', 'memory', 'disk', 'portLimit', 'snapshotLimit', 'backupLimit', 'siteLimit', 'trafficLimit', 'price'] as const) {
  340:       if (input[field] === undefined) {
  341:         throw apiError(ErrorCode.VALIDATION_ERROR, '请填写所有必填字段')
  342:       }
  343:     }
  344:     if (!options.isVm && input.swapSize === undefined) {
  345:       throw apiError(ErrorCode.VALIDATION_ERROR, '请填写所有必填字段')
  346:     }
  347:   }
  348: 
  349:   if (input.name !== undefined) {
  350:     const nameValidation = validatePackagePlanName(input.name)
  351:     if (!nameValidation.valid) {
  352:       throw apiError(ErrorCode.VALIDATION_ERROR, nameValidation.message)
  353:     }
  354:     normalized.name = nameValidation.sanitized!
  355:   }
  356: 
  357:   normalized.description = normalizePackagePlanDescription(input.description)
  358:   normalized.cpu = optionalPlanInteger(input, 'cpu', 'CPU', 15, 10000)
  359:   normalized.memory = optionalPlanInteger(input, 'memory', '内存', 128, 62144)
  360:   normalized.disk = optionalPlanInteger(input, 'disk', '磁盘', 512, 104857600)
  361:   normalized.portLimit = optionalPlanInteger(input, 'portLimit', '端口映射数', 0, POSTGRES_INT_MAX)
  362:   normalized.snapshotLimit = optionalPlanInteger(input, 'snapshotLimit', '快照数', 0, POSTGRES_INT_MAX)
  363:   normalized.backupLimit = optionalPlanInteger(input, 'backupLimit', '备份数', 0, POSTGRES_INT_MAX)
  364:   normalized.siteLimit = optionalPlanInteger(input, 'siteLimit', '反代站点数', 0, POSTGRES_INT_MAX)
  365:   normalized.swapSize = options.isVm
  366:     ? 0
  367:     : optionalPlanInteger(input, 'swapSize', 'SWAP', 0, 1048576)
  368:   normalized.price = optionalPlanInteger(input, 'price', '价格', 0, MAX_PACKAGE_PLAN_PRICE_CENTS)
  369:   normalized.trafficResetPrice = optionalMoneyCents(input, 'trafficResetPrice', '流量重置价格', MAX_TRAFFIC_RESET_PRICE_CENTS, { nullable: true })
  370:   normalized.billingCycle = optionalPlanInteger(input, 'billingCycle', '计费周期', 1, MAX_PACKAGE_PLAN_BILLING_CYCLE_MONTHS)
  371:   normalized.sortOrder = optionalPlanInteger(input, 'sortOrder', '排序值', -MAX_PACKAGE_PLAN_SORT_ORDER, MAX_PACKAGE_PLAN_SORT_ORDER)
  372:   normalized.isActive = optionalPlanBoolean(input, 'isActive', 'isActive')
  373:   normalized.isSoldOut = optionalPlanBoolean(input, 'isSoldOut', 'isSoldOut')
  374:   normalized.slaGuarantee = normalizePackagePlanSlaGuarantee(input.slaGuarantee)
  375: 
  376:   if (input.trafficLimit !== undefined) {
  377:     normalized.trafficLimit = input.trafficLimit
  378:   }
  379:   if (input.trafficLimitSpeed !== undefined) {
  380:     normalized.trafficLimitSpeed = input.trafficLimitSpeed
  381:   }
  382: 
  383:   return normalized
  384: }
