  315:       userId: input.userId,
  316:       requestedByUserId: input.requestedByUserId,
  317:       amount,
  318:       requestType: input.requestType,
  319:       reason: input.reason,
  320:       sourceType: input.sourceType,
  321:       sourceId: input.sourceId,
  322:       orderNo: input.orderNo
  323:     },
  324:     include: includeBalanceAdjustmentRequestRelations()
  325:   }) as Promise<BalanceAdjustmentRequestWithRelations>
  326: }
  327: 
  328: export async function getBalanceAdjustmentRequests(
  329:   options: BalanceAdjustmentRequestListOptions = {}
  330: ): Promise<{
  331:   requests: BalanceAdjustmentRequestWithRelations[]
  332:   total: number
  333:   page: number
  334:   pageSize: number
  335: }> {
  336:   const { page, pageSize } = clampPagination(options.page, options.pageSize)
  337:   const skip = (page - 1) * pageSize
  338:   const where: Prisma.BalanceAdjustmentRequestWhereInput = {
  339:     ...(options.status ? { status: options.status } : {}),
  340:     ...(options.userId ? { userId: options.userId } : {})
  341:   }
  342: 
  343:   const [requests, total] = await Promise.all([
  344:     prisma.balanceAdjustmentRequest.findMany({
  345:       where,
  346:       include: includeBalanceAdjustmentRequestRelations(),
  347:       orderBy: { createdAt: 'desc' },
  348:       skip,
  349:       take: pageSize
  350:     }),
  351:     prisma.balanceAdjustmentRequest.count({ where })
  352:   ])
  353: 
  354:   return { requests: requests as BalanceAdjustmentRequestWithRelations[], total, page, pageSize }
  355: }
