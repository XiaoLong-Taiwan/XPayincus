  708:   if (form.value.globalShared && (!Number.isInteger(globalMaxInstances) || globalMaxInstances < 1 || globalMaxInstances > 5)) {
  709:     formError.value = t('packageForm.validation.globalMaxInstancesRange')
  710:     return
  711:   }
  712: 
  713:   const trafficResetPriceCents = normalizeMoneyCents(form.value.trafficResetPrice)
  714:   if (trafficResetPriceCents === null) {
  715:     formError.value = `流量重置价格必须在 0-${MAX_TRAFFIC_RESET_PRICE.toFixed(2)} 元之间，且最多两位小数`
