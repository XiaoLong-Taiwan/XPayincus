  596: 
  597: function gbToBytes(gb: string | number): string {
  598:   if (gb === '' || gb === null || gb === undefined) return ''
  599:   try {
  600:     const gbNum = typeof gb === 'string' ? parseFloat(gb) : gb
  601:     if (isNaN(gbNum) || gbNum <= 0) return ''
  602:     // 使用普通数学运算支持小数，然后转为BigInt字符串
  603:     const bytes = Math.floor(gbNum * 1024 * 1024 * 1024)
  604:     return bytes.toString()
  605:   } catch {
  606:     return ''
  607:   }
  608: }
  609: 
  610: // Mbps 转换为字节数（后端按 bytes / (1024*1024) = Mbit 计算）
  611: function mbpsToBytes(mbps: string | number): string {
  612:   if (mbps === '' || mbps === null || mbps === undefined) return ''
  613:   try {
  614:     const mbpsNum = typeof mbps === 'string' ? parseFloat(mbps) : mbps
  615:     if (isNaN(mbpsNum) || mbpsNum <= 0) return ''
  616:     // 后端计算: bytes / (1024 * 1024) = Mbit，所以 bytes = Mbit * 1024 * 1024
  617:     const bytes = Math.floor(mbpsNum * 1024 * 1024)
  618:     return bytes.toString()
  619:   } catch {
  620:     return ''
  621:   }
  622: }
  623: 
