   26: /**
   27:  * BigInt 序列化为字符串
   28:  */
   29: function serializeBigInt(value: bigint | null): string | null {
   30:     return value === null ? null : value.toString()
   31: }
   32: 
   33: function parsePositiveId(value: string): number | null {
   34:     if (!/^\d+$/.test(value)) {
   35:         return null
   36:     }
   37: 
   38:     const parsed = Number(value)
   39:     return Number.isSafeInteger(parsed) && parsed > 0 ? parsed : null
   40: }
   41: 
   42: function normalizeMoney(value: number): number {
   43:     return Number(value.toFixed(2))
   44: }
   45: 
   46: function resolveTrafficResetPriceCents(instance: {
   47:     package?: { trafficResetPrice: unknown } | null
   48:     packagePlan?: { trafficResetPrice: unknown } | null
   49: }): number {
   50:     const planPrice = instance.packagePlan?.trafficResetPrice
   51:     if (planPrice !== null && planPrice !== undefined) {
   52:         return Math.max(0, Math.round(Number(planPrice) || 0))
   53:     }
   54:     return Math.max(0, Math.round(Number(instance.package?.trafficResetPrice) || 0))
   55: }
   56: 
   57: /**
   58:  * 计算百分比
   59:  * 注意: 先转换为 Number 再计算,避免 BigInt 整数除法精度丢失
   60:  * 例如: 160MB / 257GB 用 BigInt 整数除法会得到 0,而非 0.061%
   61:  */
   62: function calculatePercentage(used: bigint, limit: bigint | null): number {
   63:     if (limit === null || limit === 0n) return 0
   64:     // 先转换为浮点数再计算百分比,避免整数除法导致的精度丢失
   65:     const percentage = (Number(used) / Number(limit)) * 100
   66:     return Math.min(100, percentage)
   67: }
