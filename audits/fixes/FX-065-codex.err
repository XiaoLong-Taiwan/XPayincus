  641: async function savePackage(): Promise<void> {
  642:   formError.value = ''
  643:   
  644:   // Validation
  645:   if (!form.value.name) {
  646:     formError.value = t('admin.packages.enterName')
  647:     return
  648:   }
  649: 
  650:   const nameValidation = validateName(form.value.name, t('admin.packages.name'), 2, 64)
  651:   if (!nameValidation.valid) {
  652:     formError.value = nameValidation.message || t('admin.packages.enterName')
  653:     return
  654:   }
  655: 
  656:   if (form.value.description) {
  657:     const descValidation = validateText(form.value.description, t('admin.packages.descLabel'), 500)
  658:     if (!descValidation.valid) {
  659:       formError.value = descValidation.message || ''
  660:       return
  661:     }
  662:   }
  663: 
  664:   if (!form.value.hostIds || form.value.hostIds.length === 0) {
  665:     formError.value = t('admin.packages.mustBindHost')
  666:     return
  667:   }
  668: 
  669:   // 确保数值字段有有效值（处理空字符串或 NaN 的情况）
  670:   const cpuPriority = Number(form.value.limitsCpuPriority) || 10
  671:   const bootPriority = Number(form.value.bootAutostartPriority) || 20
  672:   const startupDelay = Number(form.value.bootAutostartDelay) || 15
  673:   const shutdownTimeout = Number(form.value.bootHostShutdownTimeout) || 30
  674: 
  675:   // Validate CPU priority (0-10)
  676:   if (cpuPriority < 0 || cpuPriority > 10) {
  677:     formError.value = t('packageForm.validation.cpuPriorityRange')
  678:     return
  679:   }
  680: 
  681:   // Validate boot priority (0-100)
  682:   if (bootPriority < 0 || bootPriority > 100) {
  683:     formError.value = t('packageForm.validation.bootPriorityRange')
  684:     return
  685:   }
  686: 
  687:   // Validate startup delay (5-600)
  688:   if (startupDelay < 5 || startupDelay > 600) {
  689:     formError.value = t('packageForm.validation.startupDelayRange')
  690:     return
  691:   }
  692: 
  693:   // Validate shutdown timeout (30-600)
  694:   if (shutdownTimeout < 30 || shutdownTimeout > 600) {
  695:     formError.value = t('packageForm.validation.shutdownTimeoutRange')
  696:     return
  697:   }
  698: 
  699:   // Validate port limit (must be >= 1, cannot be 0)
  700:   if (form.value.portLimit !== null && form.value.portLimit !== undefined) {
  701:     if (form.value.portLimit < 1) {
  702:       formError.value = t('packageForm.validation.portLimitMin')
  703:       return
  704:     }
  705:   }
  706: 
  707:   const globalMaxInstances = Number(form.value.globalMaxInstances)
  708:   if (form.value.globalShared && (!Number.isInteger(globalMaxInstances) || globalMaxInstances < 1 || globalMaxInstances > 5)) {
  709:     formError.value = t('packageForm.validation.globalMaxInstancesRange')
  710:     return
  711:   }
  712: 
  713:   const trafficResetPriceCents = normalizeMoneyCents(form.value.trafficResetPrice)
  714:   if (trafficResetPriceCents === null) {
  715:     formError.value = `流量重置价格必须在 0-${MAX_TRAFFIC_RESET_PRICE.toFixed(2)} 元之间，且最多两位小数`
  716:     return
  717:   }
  718: 
  719:   // 更新表单值为验证后的数值
  720:   form.value.limitsCpuPriority = cpuPriority
  721:   form.value.bootAutostartPriority = bootPriority
  722:   form.value.bootAutostartDelay = startupDelay
  723:   form.value.bootHostShutdownTimeout = shutdownTimeout
  724: 
  725:   saving.value = true
  726: 
  727:   try {
  728:     const trafficLimitBytes = gbToBytes(form.value.monthlyTrafficLimitGB)
  729:     const hostStoragePools = Object.fromEntries(
  730:       form.value.hostIds.map(hostId => {
  731:         const selectedPool = form.value.hostStoragePools[String(hostId)] || ''
  732:         return [String(hostId), selectedPool.trim() || null]
  733:       })
  734:     )
  735:     const hostTrafficMultipliers = Object.fromEntries(
  736:       form.value.hostIds.map(hostId => [
  737:         String(hostId),
  738:         normalizeTrafficMultiplier(form.value.hostTrafficMultipliers[String(hostId)])
  739:       ])
  740:     )
  741:     
  742:     const data: CreatePackageRequest | UpdatePackageRequest = {
  743:       name: form.value.name,
  744:       description: form.value.description || undefined,
  745:       cpuMax: form.value.cpuMax,
  746:       memoryMax: form.value.memoryMax,
  747:       diskMax: form.value.diskMax,
  748:       hostIds: form.value.hostIds,
  749:       hostStoragePools,
  750:       hostTrafficMultipliers,
  751:       networkMode: form.value.networkMode,
  752:       instanceType: form.value.instanceType,
  753:       privileged: form.value.privileged,
  754:       nested: form.value.nested,
  755:       active: form.value.active,
  756:       monthlyTrafficLimit: trafficLimitBytes,
  757:       trafficResetPrice: trafficResetPriceCents,
  758:       // 实例配额
