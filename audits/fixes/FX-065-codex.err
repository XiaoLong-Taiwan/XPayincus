  439: 
  440:     if (claimed.count !== 1) {
  441:       throw new Error('调账申请不存在或已处理')
  442:     }
  443: 
  444:     const request = await tx.balanceAdjustmentRequest.findUnique({
  445:       where: { id: requestId },
  446:       include: includeBalanceAdjustmentRequestRelations()
  447:     })
  448: 
  449:     if (!request) {
  450:       throw new Error('调账申请不存在')
  451:     }
  452: 
  453:     return request as BalanceAdjustmentRequestWithRelations
  454:   })
  455: }
