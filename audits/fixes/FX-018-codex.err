  244: 
  245: function normalizeMailAccountInput(input: MailAccountInput, options: {
  246:   requireUsername?: boolean
  247:   requirePassword?: boolean
  248:   maxDiskLimitMb: number
  249: }): MailAccountInput {
  250:   const normalized: MailAccountInput = {}
  251:   const maxDiskLimitMb = Math.floor(Number(options.maxDiskLimitMb))
  252:   if (!Number.isInteger(maxDiskLimitMb) || maxDiskLimitMb <= 0) {
  253:     throw apiError(ErrorCode.VALIDATION_ERROR, '订阅磁盘配额无效')
  254:   }
  255: 
  256:   if (options.requireUsername || input.username !== undefined) {
  257:     const username = String(input.username || '').trim().toLowerCase()
  258:     if (!username || username.length > 64 || !/^[a-z0-9._-]+$/i.test(username)) {
  259:       throw apiError(ErrorCode.VALIDATION_ERROR, '用户名只能包含 1-64 位字母、数字、点、下划线和连字符')
  260:     }
  261:     normalized.username = username
  262:   }
  263: 
  264:   if (options.requirePassword || input.password !== undefined) {
  265:     const password = String(input.password || '')
  266:     if (password.length < 8 || password.length > 128) {
  267:       throw apiError(ErrorCode.VALIDATION_ERROR, '密码长度需为 8-128 位')
  268:     }
  269:     normalized.password = password
  270:   }
  271: 
  272:   if (input.displayName !== undefined) {
  273:     const displayName = String(input.displayName).trim()
  274:     if (displayName.length > 100) {
