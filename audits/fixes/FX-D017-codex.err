   24: 
   25: /**
   26:  * BigInt åºåˆ—åŒ–ä¸ºå­—ç¬¦ä¸²
   27:  */
   28: function serializeBigInt(value: bigint | null): string | null {
   29:     return value === null ? null : value.toString()
   30: }
   31: 
   32: function parsePositiveId(value: string): number | null {
   33:     if (!/^\d+$/.test(value)) {
   34:         return null
   35:     }
   36: 
   37:     const parsed = Number(value)
   38:     return Number.isSafeInteger(parsed) && parsed > 0 ? parsed : null
   39: }
   40: 
   41: function normalizeMoney(value: number): number {
   42:     return Number(value.toFixed(2))
   43: }
   44: 
   45: function resolveTrafficResetPriceCents(instance: {
   46:     package?: { trafficResetPrice: unknown } | null
   47:     packagePlan?: { trafficResetPrice: unknown } | null
   48: }): number {
   49:     const planPrice = instance.packagePlan?.trafficResetPrice
   50:     if (planPrice !== null && planPrice !== undefined) {
   51:         return Math.max(0, Math.round(Number(planPrice) || 0))
   52:     }
   53:     return Math.max(0, Math.round(Number(instance.package?.trafficResetPrice) || 0))
   54: }
   55: 
   56: /**
   57:  * è®¡ç®—ç™¾åˆ†æ¯”
   58:  * æ³¨æ„: å…ˆè½¬æ¢ä¸º Number å†è®¡ç®—,é¿å… BigInt æ•´æ•°é™¤æ³•ç²¾åº¦ä¸¢å¤±
   59:  * ä¾‹å¦‚: 160MB / 257GB ç”¨ BigInt æ•´æ•°é™¤æ³•ä¼šå¾—åˆ° 0,è€Œéž 0.061%
   60:  */
   61: function calculatePercentage(used: bigint, limit: bigint | null): number {
   62:     if (limit === null || limit === 0n) return 0
   63:     // å…ˆè½¬æ¢ä¸ºæµ®ç‚¹æ•°å†è®¡ç®—ç™¾åˆ†æ¯”,é¿å…æ•´æ•°é™¤æ³•å¯¼è‡´çš„ç²¾åº¦ä¸¢å¤±
   64:     const percentage = (Number(used) / Number(limit)) * 100
   65:     return Math.min(100, percentage)
   66: }
   67: 
   68: export default async function trafficRoutes(fastify: FastifyInstance): Promise<void> {
   69:     // ==================== ç”¨æˆ·æµé‡ API ====================
   70: 
  330:      * é‡ç½®å®žä¾‹æœˆåº¦æµé‡ï¼ˆç®¡ç†å‘˜æˆ–å®¿ä¸»æœºæ‰€æœ‰è€…ï¼‰
  331:      */
  332:     fastify.post<{
  333:         Params: { instanceId: string }
  334:     }>('/instances/:instanceId/traffic/reset', {
  335:         onRequest: [fastify.authenticate]
  336:     }, async (request: FastifyRequest<{
  337:         Params: { instanceId: string }
  338:     }>, reply: FastifyReply) => {
  339:         const instanceId = parsePositiveId(request.params.instanceId)
  340:         if (instanceId === null) {
  341:             return reply.code(400).send({ error: 'Invalid instance ID' })
  342:         }
  343: 
  344:         const instance = await trafficDb.getInstanceTrafficInfo(instanceId)
  345:         if (!instance) {
  346:             return reply.code(404).send({ error: 'Instance not found' })
  347:         }
  348: 
  349:         // æƒé™æ£€æŸ¥ï¼šç®¡ç†å‘˜ã€å®¿ä¸»æœºæ‰€æœ‰è€…æˆ–å®žä¾‹æ‰€æœ‰è€…å¯ä»¥é‡ç½®å®žä¾‹æµé‡
  350:         const isAdmin = request.user.role === 'admin'
  351:         const isInstanceOwner = instance.userId === request.user.id
  352:         if (!isAdmin && !isInstanceOwner) {
  353:             if (instance.hostId) {
  354:                 const host = await db.getHostById(instance.hostId)
  355:                 if (!host || host.user_id !== request.user.id) {
  356:                     return reply.code(403).send({ error: 'Only admin, host owner, or instance owner can reset instance traffic' })
  357:                 }
  358:             } else {
  359:                 return reply.code(403).send({ error: 'Access denied' })
  360:             }
  361:         }
  362: 
  363:         const exchangeLock = await getExchangeOperationLock(instanceId)
  364:         if (exchangeLock.locked) {
  365:             return reply.code(409).send({
  366:                 error: exchangeLock.message,
  367:                 code: exchangeLock.code,
  368:                 listingId: exchangeLock.listingId,
  369:                 orderId: exchangeLock.orderId
  370:             })
  371:         }
  372: 
  373:         let price = 0
  374:         const shouldChargeOwner = isInstanceOwner && !isAdmin
  375: 
  376:         if (shouldChargeOwner) {
  377:             try {
  378:                 const result = await prisma.$transaction(async tx => {
  379:                     const resetLocked = await tryAdvisoryTransactionLock(tx, INSTANCE_TRAFFIC_RESET_LOCK_NAMESPACE, instanceId)
  380:                     if (!resetLocked) {
  381:                         throw new Error('æµé‡é‡ç½®æ­£åœ¨å¤„ç†ï¼Œè¯·ç¨åŽé‡è¯•')
  382:                     }
  383: 
  384:                     const currentInstance = await tx.instance.findUnique({
  385:                         where: { id: instanceId },
  386:                         select: {
  387:                             id: true,
  388:                             name: true,
  389:                             userId: true,
  390:                             status: true,
  391:                             package: { select: { trafficResetPrice: true } },
  392:                             packagePlan: { select: { trafficResetPrice: true } },
  393:                             user: { select: { balance: true } }
  394:                         }
  395:                     })
  396: 
  397:                     if (!currentInstance || currentInstance.status === 'deleted') {
  398:                         throw new Error('Instance not found')
  399:                     }
  400:                     if (currentInstance.userId !== request.user.id) {
  401:                         throw new Error('Access denied')
  402:                     }
  403: 
  404:                     const priceCents = resolveTrafficResetPriceCents(currentInstance)
  405:                     const priceYuan = normalizeMoney(priceCents / 100)
  406: 
  407:                     if (priceYuan > 0) {
  408:                         const balanceLocked = await tryAdvisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, currentInstance.userId)
  409:                         if (!balanceLocked) {
  410:                             throw new Error('ä½™é¢æ­£åœ¨å¤„ç†ï¼Œè¯·ç¨åŽé‡è¯•')
  411:                         }
  412: 
  413:                         const balanceBefore = Number(currentInstance.user.balance)
  414:                         const balanceAfter = normalizeMoney(balanceBefore - priceYuan)
  415:                         if (balanceAfter < 0) {
  416:                             throw new Error('ä½™é¢ä¸è¶³')
  417:                         }
  418: 
  419:                         const balanceUpdate = await tx.user.updateMany({
  420:                             where: {
  421:                                 id: currentInstance.userId,
  422:                                 balance: { gte: priceYuan }
  423:                             },
  424:                             data: { balance: { decrement: priceYuan } }
  425:                         })
  426:                         if (balanceUpdate.count === 0) {
  427:                             throw new Error('ä½™é¢ä¸è¶³æˆ–å¹¶å‘å†²çª')
  428:                         }
  429: 
  430:                         const updatedUser = await tx.user.findUnique({
  431:                             where: { id: currentInstance.userId },
  432:                             select: { balance: true }
  433:                         })
  434:                         if (!updatedUser) {
  435:                             throw new Error('ç”¨æˆ·ä¸å­˜åœ¨')
  436:                         }
  437: 
  438:                         await tx.balanceLog.create({
  439:                             data: {
  440:                                 userId: currentInstance.userId,
  441:                                 type: 'consume',
  442:                                 amount: -priceYuan,
  443:                                 balanceBefore,
  444:                                 balanceAfter: Number(updatedUser.balance),
  445:                                 instanceId,
  446:                                 remark: `é‡ç½®å®žä¾‹ ${currentInstance.name} æœˆæµé‡`
  447:                             }
  448:                         })
  449:                     }
  450: 
  451:                     await tx.instance.updateMany({
  452:                         where: {
  453:                             id: instanceId,
  454:                             status: { not: 'deleted' }
  455:                         },
  456:                         data: {
  457:                             monthlyTrafficUsed: 0n,
  458:                             trafficStatus: 'NORMAL'
  459:                         }
  460:                     })
  461: 
  462:                     return { price: priceYuan }
  463:                 })
  464:                 price = result.price
  465:             } catch (error) {
  466:                 const message = error instanceof Error ? error.message : String(error)
  467:                 const statusCode = message.includes('ä½™é¢ä¸è¶³') ? 400 : message.includes('æ­£åœ¨å¤„ç†') ? 409 : 400
  468:                 return reply.code(statusCode).send({ error: message })
  469:             }
  470:         } else {
  471:             await trafficDb.resetInstanceMonthlyTraffic(instanceId)
  472:         }
  473:         const { reconcileTrafficStateForInstanceIds } = await import('../services/traffic-scheduler.js')
  474:         await reconcileTrafficStateForInstanceIds([instanceId])
  475: 
  476:         return { success: true, message: 'Instance traffic reset completed', price }
  477:     })
  478: 
