   55: 
   56: function isRecord(value: unknown): value is Record<string, unknown> {
   57:   return typeof value === 'object' && value !== null && !Array.isArray(value)
   58: }
   59: 
   60: function sanitizeShortString(value: unknown, maxLength: number): string | null {
   61:   if (typeof value !== 'string') {
   62:     return null
   63:   }
   64:   const trimmed = value.trim()
   65:   return trimmed ? trimmed.slice(0, maxLength) : null
   66: }
   67: 
   68: function parseCounter(value: unknown): bigint | null {
   69:   if (typeof value === 'bigint') {
   70:     return value >= 0n ? value : null
   71:   }
   72:   if (typeof value === 'number') {
   73:     if (!Number.isSafeInteger(value) || value < 0) {
   74:       return null
   75:     }
   76:     return BigInt(value)
   77:   }
   78:   if (typeof value === 'string' && /^\d{1,30}$/.test(value.trim())) {
   79:     return BigInt(value.trim())
   80:   }
   81:   return null
   82: }
   83: 
   84: function normalizeStatus(value: unknown): InstanceStatus | null {
   85:   const raw = sanitizeShortString(value, 40)
   86:   if (!raw) {
   87:     return null
   88:   }
   89: 
   90:   if (raw === 'running' || raw === 'stopped' || raw === 'error') {
   91:     return raw
   92:   }
   93: 
   94:   const mapped = mapInstanceStatus(raw)
   95:   if (mapped === 'running' || mapped === 'stopped' || mapped === 'error') {
   96:     return mapped
   97:   }
