  202: export async function collectTrafficForInstanceWithClient(
  203:   input: CollectTrafficWithClientInput,
  204:   lockOptions: LockOptions = {}
  205: ): Promise<CollectInstanceTrafficResult> {
  206:   const { instanceId, userId, incusId, client, currentUsage = 0n } = input
  207:   const lockKey = getTrafficLockKey(instanceId)
  208:   const effectiveLockOptions = { ...DEFAULT_TRAFFIC_LOCK_OPTIONS, ...lockOptions }
  209:   const lockResult = await acquireLock(lockKey, effectiveLockOptions)
  210: 
  211:   if (!lockResult.success || !lockResult.ownerId) {
  212:     return {
  213:       success: false,
  214:       skipped: false,
  215:       totalDelta: 0n,
  216:       currentUsage,
  217:       error: lockResult.error || 'æµé‡é‡‡é›†é”èŽ·å–å¤±è´¥'
  218:     }
  219:   }
  220: 
  221:   const renewIntervalMs = Math.max(1000, Math.floor((effectiveLockOptions.expireMs || DEFAULT_TRAFFIC_LOCK_OPTIONS.expireMs || 30000) / 3))
  222:   let renewTimer: ReturnType<typeof setInterval> | null = null
  223: 
  224:   try {
  225:     renewTimer = setInterval(() => {
  226:       extendLock(lockKey, lockResult.ownerId!, effectiveLockOptions.expireMs).catch((error) => {
  227:         console.warn(`[Traffic] Failed to extend lock ${lockKey}:`, error)
  228:       })
  229:     }, renewIntervalMs)
  230: 
  231:     const counters = await getTrafficCounters(client, incusId)
  232:     const result = await applyTrafficCounters(instanceId, userId, counters)
  233: 
  234:     return {
  235:       success: true,
  236:       skipped: result.skipped,
  237:       totalDelta: result.totalDelta,
  238:       currentUsage: result.currentUsage
  239:     }
  240:   } catch (error) {
  241:     return {
  242:       success: false,
  243:       skipped: false,
  244:       totalDelta: 0n,
  245:       currentUsage,
  246:       error: error instanceof Error ? error.message : String(error)
  247:     }
  248:   } finally {
  249:     if (renewTimer) clearInterval(renewTimer)
  250:     await releaseLock(lockKey, lockResult.ownerId)
  251:   }
  252: }
