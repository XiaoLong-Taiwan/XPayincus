    9: import {
   10:     INSTANCE_TRAFFIC_RESET_LOCK_NAMESPACE,
   11:     USER_BALANCE_LOCK_NAMESPACE,
   12:     tryAdvisoryTransactionLock
   13: } from '../db/advisory-locks.js'
