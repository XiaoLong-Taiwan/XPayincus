+  '// ==================== 管理员应用AFF优惠码 ===================='
+)
+assert.ok(
+  adminDeleteRefundSource.includes('await reverseInstanceAffCommissionForRefund({') &&
+    adminDeleteRefundSource.includes('refundAmount,'),
+  'admin delete-and-refund must reverse AFF commission in the refund transaction'
+)
+
