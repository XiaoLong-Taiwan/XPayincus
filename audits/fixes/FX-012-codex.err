const DESTROY_RULES = {
  FEE_RATE: 0.10,                // æ‰‹ç»­è´¹çŽ‡ 10%ï¼ˆé¦–æ¬¡å…æ‰‹ç»­è´¹ï¼‰
  MAX_PAID_DESTROY_MONTHLY_TRAFFIC: 5n * 1024n * 1024n * 1024n // 5 GiB
}

const DESTROY_TRAFFIC_LIMIT_REASON = 'å½“å‰æœˆæµé‡å‘¨æœŸæ— æ³•é”€æ¯ï¼Œå·²ç”¨æµé‡è¾¾åˆ°æˆ–è¶…è¿‡ 5G'
const EXCHANGE_DESTROY_LOCK_REASON = 'å®žä¾‹å·²ä¸Šæž¶äº¤æ˜“æ‰€æˆ–å¤„äºŽäº¤æ˜“äº¤å‰²ä¸­ï¼Œä¸èƒ½é”€æ¯'

