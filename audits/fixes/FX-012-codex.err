  server\prisma\schema.prisma:4257:  amount Decimal           @db.Decimal(10, 2) // 扣费金额（正数）
  server\prisma\schema.prisma:4258:  months Int               @default(1)        // 购买/续费月数
  server\prisma\schema.prisma:4259:
