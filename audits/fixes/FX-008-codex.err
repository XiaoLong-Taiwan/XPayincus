 441: # ========================== 手动包目录 ==========================
 442: readonly MANUAL_PKG_DIR="/tmp/incudal"
 443: 
 444: # ========================== 获取最新版本号（快速尝试） ==========================
 445: get_latest_version() {
 446:     local api_url="https://api.github.com/repos/${GITHUB_REPO}/releases/latest"
 447:     local response=""
 448:     local version=""
 449: 
 450:     # 5 秒超时速查，不阻塞
 451:     response=$(curl -sL --connect-timeout 5 --max-time 8 "$api_url" 2>/dev/null) || true
 452: 
 453:     if [[ -n "$response" ]]; then
 454:         version=$(echo "$response" | grep '"tag_name"' | sed -E 's/.*"tag_name": *"([^"]+)".*/\1/' || true)
 455:     fi
 456: 
 457:     echo "$version"
 458: }
