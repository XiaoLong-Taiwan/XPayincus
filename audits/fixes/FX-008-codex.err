1014: # ========================== 运行数据库迁移 ==========================
1015: run_migrations() {
1016:     step "执行数据库迁移..."
1017: 
1018:     cd "${INSTALL_DIR}/server"
1019: 
1020:     # 以 incudal 用户身份加载 .env 并运行迁移
1021:     # HOME 需要指向有写权限的目录，否则 npm 缓存报 EACCES
1022:     sudo -u "$RUN_USER" HOME="${INSTALL_DIR}" bash -c "
1023:         set -a
1024:         source '${ENV_FILE}'
1025:         set +a
1026:         cd '${INSTALL_DIR}/server'
1027:         pnpm exec prisma migrate deploy
1028:     "
1029: 
1030:     log "数据库迁移完成"
1031: }
