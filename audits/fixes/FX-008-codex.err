 833: # ========================== 生成面板客户端证书 ==========================
 834: generate_panel_cert() {
 835:     local cert_dir="${INSTALL_DIR}/server/certs"
 836:     local cert_file="${cert_dir}/client.crt"
 837:     local key_file="${cert_dir}/client.key"
 838: 
 839:     step "配置面板客户端证书..."
 840: 
 841:     # 幂等性：证书已存在则跳过
 842:     if [[ -f "$cert_file" && -f "$key_file" ]]; then
 843:         log "面板客户端证书已存在，跳过生成"
 844:         return 0
 845:     fi
 846: 
 847:     mkdir -p "$cert_dir"
 848: 
 849:     # 生成自签名客户端证书（用于面板与 Incus API 的 mTLS 通信）
 850:     info "生成面板客户端证书（RSA 4096 位，有效期 10 年）..."
 851:     openssl req -x509 -newkey rsa:4096 \
 852:         -keyout "$key_file" \
 853:         -out "$cert_file" \
 854:         -days 3650 -nodes \
 855:         -subj "/CN=incudal-panel/O=PayIncus" \
 856:         2>/dev/null
 857: 
 858:     # 设置权限：只有 incudal 用户可读
 859:     chmod 600 "$cert_file" "$key_file"
 860:     chown "${RUN_USER}:${RUN_USER}" "$cert_file" "$key_file"
 861: 
 862:     log "面板客户端证书生成完成"
 863:     info "证书路径: ${cert_file}"
 864:     info "密钥路径: ${key_file}"
 865: }
 866: 
 867: # ========================== 配置数据库 ==========================
 868: setup_database() {
 869:     local db_password="$1"
 870: 
 871:     step "配置 PostgreSQL 数据库..."
 872: 
 873:     # 检查数据库和用户是否已存在
 874:     local db_exists
 875:     db_exists=$(sudo -u postgres psql -tAc "SELECT 1 FROM pg_database WHERE datname='incudal'" 2>/dev/null || echo "")
 876: 
 877:     if [[ "$db_exists" == "1" ]]; then
 878:         info "数据库 'incudal' 已存在，跳过创建"
 879:         # 更新密码
 880:         sudo -u postgres psql -c "ALTER USER incudal WITH PASSWORD '${db_password}';" >/dev/null 2>&1 || true
 881:     else
 882:         # 创建用户和数据库
 883:         sudo -u postgres psql -c "CREATE USER incudal WITH PASSWORD '${db_password}';" >/dev/null 2>&1 || true
 884:         sudo -u postgres psql -c "CREATE DATABASE incudal OWNER incudal;" >/dev/null 2>&1
 885:         sudo -u postgres psql -c "GRANT ALL PRIVILEGES ON DATABASE incudal TO incudal;" >/dev/null 2>&1
 886:         log "数据库 'incudal' 创建完成"
 887:     fi
 888: }
