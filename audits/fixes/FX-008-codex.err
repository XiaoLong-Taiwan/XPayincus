 651:                     return 1
 652:                 fi
 653:             done
 654:         fi
 655: 
 656:         # 显示等待动画（输出到 stderr）
 657:         local spin_idx=$((wait_count % ${#spin_chars}))
 658:         local spin_char="${spin_chars:$spin_idx:1}"
 659:         printf "\r  ${CYAN}${spin_char}${NC} 等待产物包... (已等待 %ds，输入 Ctrl+C 取消)  " "$wait_count" >&2
 660: 
 661:         sleep 2
 662:         wait_count=$((wait_count + 2))
 663: 
 664:         if [[ $wait_count -ge $max_wait ]]; then
 665:             echo "" >&2
 666:             error "等待超时 (${max_wait}s)，请重新运行脚本"
 667:             return 1
 668:         fi
 669:     done
 670: }
