1289: setup_nginx_certbot() {
1290:     info "准备配置 Nginx 反代及 Let's Encrypt SSL 自动证书"
1291:     local client_dist
1292:     local admin_client_dist
1293:     client_dist="$(resolve_static_dist_dir "client/dist/user")"
1294:     admin_client_dist="$(resolve_static_dist_dir "client/dist/admin")"
1295: 
1296:     if [[ ! -d "$client_dist" ]]; then
1297:         error "未找到前端构建目录: $client_dist"
1298:         error "请确认安装包包含 client/dist/user，或先完成前端构建后再配置 Nginx。"
1299:         return 1
1300:     fi
1301: 
1302:     if [[ ! -d "$admin_client_dist" ]]; then
1303:         error "未找到后台前端构建目录: $admin_client_dist"
1304:         error "请确认安装包包含 client/dist/admin，或先完成前端构建后再配置 Nginx。"
1305:         return 1
1306:     fi
1307: 
1308:     echo -ne "  ${BOLD}请输入客户面板域名 (例如 pay.payincus.com): ${NC}"
1309:     read -r DOMAIN
1310: 
1311:     if [[ -z "$DOMAIN" ]]; then
1312:         error "域名不能为空！"
1313:         return 1
1314:     fi
1315: 
1316:     echo -ne "  ${BOLD}请输入管理后台域名 (例如 admin.payincus.com): ${NC}"
1317:     read -r ADMIN_DOMAIN
1318: 
1319:     if [[ -z "$ADMIN_DOMAIN" ]]; then
1320:         error "管理后台域名不能为空！"
1321:         return 1
1322:     fi
1323: 
1324:     if [[ "$ADMIN_DOMAIN" == "$DOMAIN" ]]; then
1325:         error "管理后台域名必须与客户面板域名分开！"
1326:         return 1
1327:     fi
1328: 
1329:     echo -ne "  ${BOLD}请输入你的邮箱 (用于证书过期通知，可留空): ${NC}"
1330:     read -r EMAIL
1331: 
1332:     info "安装 Nginx 与 Certbot..."
1333:     apt-get install -y -qq nginx certbot python3-certbot-nginx >/dev/null 2>&1
1334: 
1335:     # 更新公网 URL：CORS、页面链接、支付回调都应使用浏览器可访问的前端域名
1336:     set_env_value "FRONTEND_URL" "https://${DOMAIN}" "前端公网地址"
1337:     set_env_value "ADMIN_FRONTEND_URL" "https://${ADMIN_DOMAIN}" "管理后台公网地址"
1338:     set_env_value "SITE_URL" "https://${DOMAIN}" "站点公网地址"
1339:     set_env_value "PAYMENT_CALLBACK_BASE_URL" "https://${DOMAIN}" "支付回调公网地址"
1340:     set_env_value "VITE_CUSTOMER_BASE_URL" "https://${DOMAIN}" "管理后台生成客户链接的前端地址"
1341:     set_env_value "VITE_ADMIN_BASE_URL" "https://${ADMIN_DOMAIN}" "前端管理后台地址"
1342: 
1343:     log "配置 Nginx 站点..."
1344:     {
1345:         write_nginx_split_maps
1346:         write_nginx_split_server_block "$DOMAIN" "$client_dist"
1347:         write_nginx_split_server_block "$ADMIN_DOMAIN" "$admin_client_dist"
1348:     } > /etc/nginx/sites-available/incudal.conf
1349: 
1350:     ln -sf /etc/nginx/sites-available/incudal.conf /etc/nginx/sites-enabled/
1351:     # 移除默认站点（避免冲突）
1352:     rm -f /etc/nginx/sites-enabled/default 2>/dev/null || true
1353:     nginx -t >/dev/null 2>&1
1354:     systemctl reload nginx
1355: 
1356:     log "申请 Let's Encrypt SSL 证书..."
1357:     if [[ -n "$EMAIL" ]]; then
1358:         certbot --nginx -d "$DOMAIN" -d "$ADMIN_DOMAIN" --non-interactive --agree-tos -m "$EMAIL" --redirect
1359:     else
1360:         certbot --nginx -d "$DOMAIN" -d "$ADMIN_DOMAIN" --non-interactive --agree-tos --register-unsafely-without-email --redirect
1361:     fi
1362: 
1363:     log "HTTPS 配置完成！客户面板: https://${DOMAIN}，管理后台: https://${ADMIN_DOMAIN}"
1364: }
1365: 
1366: # ========================== Cloudflare Tunnel ==========================
1367: setup_cf_tunnel() {
1368:     info "准备配置 Cloudflare Tunnel 内网穿透"
1369:     echo -e "  ${DIM}请先在 Cloudflare Zero Trust 管理后台创建 Tunnel${NC}"
1370:     echo -e "  ${DIM}当前部署为前后端分离，脚本会在本机配置 Nginx 托管前端并反代 /api 到后端${NC}"
1371:     echo -e "  ${DIM}请将 Cloudflare Public Hostname 的目标路由设置为 http://localhost:80${NC}"
1372:     echo ""
1373:     echo -ne "  ${BOLD}请输入 Cloudflare Tunnel Token: ${NC}"
1374:     read -r CF_TOKEN
1375: 
1376:     if [[ -z "$CF_TOKEN" ]]; then
1377:         error "Token 不能为空！"
1378:         return 1
1379:     fi
1380: 
1381:     echo -ne "  ${BOLD}请输入客户面板域名 (例: pay.payincus.com): ${NC}"
1382:     read -r DOMAIN
1383: 
1384:     if [[ -z "$DOMAIN" ]]; then
1385:         error "域名不能为空！Cloudflare Tunnel 生产部署必须配置浏览器访问域名。"
1386:         error "FRONTEND_URL/SITE_URL/PAYMENT_CALLBACK_BASE_URL 会用于 WebSocket Origin、OAuth 和支付回调。"
1387:         return 1
1388:     fi
1389: 
1390:     echo -ne "  ${BOLD}请输入管理后台域名 (例: admin.payincus.com): ${NC}"
1391:     read -r ADMIN_DOMAIN
1392: 
1393:     if [[ -z "$ADMIN_DOMAIN" ]]; then
1394:         error "管理后台域名不能为空！Cloudflare Tunnel 生产部署必须配置浏览器访问域名。"
1395:         return 1
1396:     fi
1397: 
1398:     if [[ "$ADMIN_DOMAIN" == "$DOMAIN" ]]; then
1399:         error "管理后台域名必须与客户面板域名分开！"
1400:         return 1
1401:     fi
1402: 
1403:     set_env_value "FRONTEND_URL" "https://${DOMAIN}" "前端公网地址"
1404:     set_env_value "ADMIN_FRONTEND_URL" "https://${ADMIN_DOMAIN}" "管理后台公网地址"
1405:     set_env_value "SITE_URL" "https://${DOMAIN}" "站点公网地址"
1406:     set_env_value "PAYMENT_CALLBACK_BASE_URL" "https://${DOMAIN}" "支付回调公网地址"
1407:     set_env_value "VITE_CUSTOMER_BASE_URL" "https://${DOMAIN}" "管理后台生成客户链接的前端地址"
1408:     set_env_value "VITE_ADMIN_BASE_URL" "https://${ADMIN_DOMAIN}" "前端管理后台地址"
1409: 
1410:     local client_dist
1411:     local admin_client_dist
1412:     client_dist="$(resolve_static_dist_dir "client/dist/user")"
1413:     admin_client_dist="$(resolve_static_dist_dir "client/dist/admin")"
1414:     if [[ ! -d "$client_dist" ]]; then
1415:         error "未找到前端构建目录: $client_dist"
1416:         error "请确认安装包包含 client/dist/user，或先完成前端构建后再配置 Cloudflare Tunnel。"
1417:         return 1
1418:     fi
1419: 
1420:     if [[ ! -d "$admin_client_dist" ]]; then
1421:         error "未找到后台前端构建目录: $admin_client_dist"
1422:         error "请确认安装包包含 client/dist/admin，或先完成前端构建后再配置 Cloudflare Tunnel。"
1423:         return 1
1424:     fi
1425: 
1426:     local server_name="${DOMAIN}"
1427:     info "安装并配置本机 Nginx 静态前端与 /api 反代..."
1428:     apt-get install -y -qq nginx >/dev/null 2>&1
1429: 
1430:     {
1431:         write_nginx_split_maps
1432:         write_nginx_split_server_block "$server_name" "$client_dist" "default"
1433:         write_nginx_split_server_block "$ADMIN_DOMAIN" "$admin_client_dist"
1434:     } > /etc/nginx/sites-available/incudal.conf
1435: 
1436:     ln -sf /etc/nginx/sites-available/incudal.conf /etc/nginx/sites-enabled/
1437:     rm -f /etc/nginx/sites-enabled/default 2>/dev/null || true
1438:     nginx -t >/dev/null 2>&1
1439:     systemctl enable nginx >/dev/null 2>&1
1440:     systemctl restart nginx
1441: 
1442:     # 安装 cloudflared
1443:     if ! command -v cloudflared &>/dev/null; then
1444:         info "安装 cloudflared..."
1445:         curl -fsSL https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-${ARCH} \
1446:             -o /usr/local/bin/cloudflared
1447:         chmod +x /usr/local/bin/cloudflared
1448:     fi
1449: 
1450:     # 创建 cloudflared systemd 服务
1451:     cloudflared service install "$CF_TOKEN" 2>/dev/null || true
1452: 
1453:     log "Cloudflare Tunnel 配置完成！"
1454:     echo -e "  访问地址: ${GREEN}https://${DOMAIN}${NC}"
1455: }
1456: 
1457: # ========================== 启动服务 ==========================
1458: start_service() {
1459:     step "启动 PayIncus 服务..."
1460: 
1461:     systemctl start "$SERVICE_NAME"
1462: 
1463:     # 等待几秒检查状态
1464:     sleep 3
1465: 
1466:     if systemctl is-active --quiet "$SERVICE_NAME"; then
1467:         log "PayIncus 服务启动成功！"
1468:     else
1469:         error "服务启动失败，查看日志："
1470:         journalctl -u "$SERVICE_NAME" --no-pager -n 20
1471:         exit 1
1472:     fi
1473: }
1474: 
1475: # ========================== 显示安装结果 ==========================
1476: show_result() {
1477:     local admin_password
1478:     admin_password="$(get_env_value "ADMIN_PASSWORD")"
1479:     local admin_email
1480:     admin_email="$(get_env_value "ADMIN_EMAIL")"
1481: 
1482:     echo ""
1483:     divider
1484:     echo -e "  ${GREEN}${BOLD}✅ PayIncus 面板部署成功！${NC}"
1485:     divider
1486:     echo ""
1487:     echo -e "  ${BOLD}面板信息${NC}"
1488:     echo -e "  安装路径  :  ${GREEN}${INSTALL_DIR}${NC}"
1489:     echo -e "  配置文件  :  ${GREEN}${ENV_FILE}${NC}"
1490:     echo -e "  服务名称  :  ${GREEN}${SERVICE_NAME}${NC}"
1491:     echo -e "  监听端口  :  ${GREEN}${DEFAULT_PORT}${NC}"
1492:     echo ""
1493:     echo -e "  ${BOLD}默认账号${NC}"
1494:     echo -e "  用户名    :  ${GREEN}admin${NC}"
1495:     echo -e "  邮箱      :  ${GREEN}${admin_email:-admin@payincus.local}${NC}"
1496:     if [[ -n "$admin_password" ]]; then
1497:         echo -e "  密码      :  ${GREEN}${admin_password}${NC}  ${YELLOW}（请在首次登录后立即修改！）${NC}"
1498:     else
1499:         echo -e "  密码      :  ${YELLOW}请查看 ${ENV_FILE} 中的 ADMIN_PASSWORD${NC}"
1500:     fi
1501:     echo ""
1502:     echo -e "  ${BOLD}常用命令${NC}"
1503:     echo -e "  启动服务  :  ${CYAN}systemctl start ${SERVICE_NAME}${NC}"
1504:     echo -e "  停止服务  :  ${CYAN}systemctl stop ${SERVICE_NAME}${NC}"
1505:     echo -e "  重启服务  :  ${CYAN}systemctl restart ${SERVICE_NAME}${NC}"
1506:     echo -e "  查看状态  :  ${CYAN}systemctl status ${SERVICE_NAME}${NC}"
1507:     echo -e "  查看日志  :  ${CYAN}journalctl -u ${SERVICE_NAME} -f${NC}"
1508:     echo ""
1509:     divider
1510: }
1511: 
1512: # ========================== 升级流程 ==========================
1513: do_upgrade() {
1514:     show_banner
1515:     check_os
1516: 
1517:     if ! check_existing; then
1518:         error "未检测到已安装的 PayIncus，请先执行全新安装"
1519:         exit 1
1520:     fi
1521: 
1522:     if is_atomic_layout; then
1523:         error "检测到原子 OTA 布局，不能使用旧版 --upgrade 覆盖 current/releases"
1524:         error "请在管理后台执行 OTA；如需命令行维护，请使用后台生成的更新任务"
1525:         exit 1
1526:     fi
1527: 
1528:     info "检测到已安装的 PayIncus，准备升级..."
1529: 
1530:     apt-get update -qq >/dev/null 2>&1
1531:     install_system_tools
1532: 
1533:     # 停止服务
1534:     info "停止当前服务..."
1535:     systemctl stop "$SERVICE_NAME" 2>/dev/null || true
1536:     systemctl stop incudal 2>/dev/null || true
1537: 
1538:     # 获取产物包（自动下载或手动放置）
1539:     local tar_file
1540:     tar_file=$(obtain_release) || exit 1
1541:     if [[ -z "$tar_file" ]]; then
1542:         exit 1
1543:     fi
1544:     install_release "$tar_file" true
1545: 
1546:     local version="unknown"
1547:     if [[ -f "${INSTALL_DIR}/version.json" ]]; then
1548:         version=$(node -e "try { console.log(require('${INSTALL_DIR}/version.json').version || 'unknown') } catch { console.log('unknown') }")
1549:     fi
1550: 
1551:     # 修复权限
1552:     chown -R "${RUN_USER}:${RUN_USER}" "$INSTALL_DIR"
1553:     chmod 751 "$INSTALL_DIR"
1554:     chmod 600 "${ENV_FILE}" 2>/dev/null || true
1555: 
1556:     configure_git_metadata
1557:     ensure_env_keys
1558:     create_service
1559:     create_online_update_service
1560: 
1561:     # 运行迁移
1562:     run_migrations
1563: 
1564:     # 重启服务
1565:     start_service
1566: 
1567:     echo ""
1568:     divider
1569:     echo -e "  ${GREEN}${BOLD}✅ PayIncus 升级到 ${version} 完成！${NC}"
1570:     divider
1571: }
1572: 
1573: # ========================== 卸载流程 ==========================
1574: do_uninstall() {
1575:     show_banner
1576: 
1577:     echo -e "  ${RED}${BOLD}⚠️  警告：卸载将执行以下操作：${NC}"
1578:     echo -e "  ${RED}  1. 停止并删除 PayIncus systemd 服务${NC}"
1579:     echo -e "  ${RED}  2. 删除安装目录 ${INSTALL_DIR}${NC}"
1580:     echo -e "  ${RED}  3. 删除系统用户 ${RUN_USER}${NC}"
1581:     echo -e "  ${RED}  安装目录中的插件、主题、运行资产、OTA release 和更新日志也会被删除${NC}"
1582:     echo -e "  ${YELLOW}  注意：PostgreSQL/Redis 和数据库数据不会被删除${NC}"
1583:     echo ""
1584:     echo -ne "  ${BOLD}确认卸载？${NC}[y/N]: "
1585:     read -r confirm
1586:     if [[ ! "$confirm" =~ ^[yY]$ ]]; then
1587:         info "已取消卸载"
1588:         exit 0
1589:     fi
1590: 
1591:     # 停止服务
1592:     systemctl stop "$SERVICE_NAME" 2>/dev/null || true
1593:     systemctl disable "$SERVICE_NAME" 2>/dev/null || true
1594:     systemctl stop incudal 2>/dev/null || true
1595:     systemctl disable incudal 2>/dev/null || true
1596:     rm -f "$SERVICE_FILE"
1597:     rm -f /etc/systemd/system/incudal.service
1598:     rm -f /etc/systemd/system/incudal-online-update@.service
1599:     rm -f /etc/systemd/system/incudal-online-rollback@.service
1600:     rm -f /etc/sudoers.d/incudal-online-update
1601:     systemctl daemon-reload
1602: 
1603:     # 删除安装目录
1604:     rm -rf "$INSTALL_DIR"
1605: 
1606:     # 删除用户
1607:     userdel "$RUN_USER" 2>/dev/null || true
1608: 
1609:     # 清理 Nginx 配置
1610:     rm -f /etc/nginx/sites-enabled/incudal.conf 2>/dev/null || true
1611:     rm -f /etc/nginx/sites-available/incudal.conf 2>/dev/null || true
1612:     systemctl reload nginx 2>/dev/null || true
1613: 
1614:     echo ""
1615:     log "PayIncus 已完全卸载"
1616:     info "数据库数据保留在 PostgreSQL 中，如需删除请手动执行："
1617:     echo -e "  ${CYAN}sudo -u postgres psql -c \"DROP DATABASE incudal;\"${NC}"
1618:     echo -e "  ${CYAN}sudo -u postgres psql -c \"DROP USER incudal;\"${NC}"
1619: }
1620: 
1621: # ========================== 全新安装流程 ==========================
1622: do_install() {
1623:     show_banner
1624:     check_os
1625: 
1626:     if check_existing; then
1627:         warn "检测到已安装的 PayIncus (${INSTALL_DIR})"
1628:         info "产物包已解压就绪，将跳过下载步骤，直接从配置阶段继续"
1629:         info "如需全新安装，请先运行: sudo bash $0 --uninstall"
1630:         echo "" >&2
1631:     fi
1632: 
1633:     # 密码处理：如果 .env 已存在则复用旧密码，避免密码不一致
1634:     local db_password
1635:     local redis_password
1636:     local admin_email
1637: 
1638:     if [[ -f "$ENV_FILE" ]]; then
1639:         info "检测到已有 .env 配置，复用现有密码"
1640:         # 从 DATABASE_URL 提取密码: postgresql://user:PASSWORD@host:port/db
1641:         db_password=$(grep -oP 'DATABASE_URL=postgresql://[^:]+:\K[^@]+' "$ENV_FILE" 2>/dev/null || echo "")
1642:         # 从 REDIS_URL 提取密码: redis://:PASSWORD@host:port
1643:         redis_password=$(grep -oP 'REDIS_URL=redis://:\K[^@]+' "$ENV_FILE" 2>/dev/null || echo "")
1644: 
1645:         if [[ -z "$db_password" ]]; then
1646:             warn "无法从 .env 提取数据库密码，将生成新密码并重写 .env"
1647:             db_password=$(gen_password 24)
1648:             rm -f "$ENV_FILE"
1649:         fi
1650:         if [[ -z "$redis_password" ]]; then
1651:             redis_password=$(gen_password 24)
1652:         fi
1653:     else
1654:         db_password=$(gen_password 24)
1655:         redis_password=$(gen_password 24)
1656:     fi
1657: 
1658:     # 初始管理员邮箱
1659:     admin_email="$(prompt_initial_admin_email)"
1660:     if [[ -f "$ENV_FILE" && -z "$(get_env_value "ADMIN_EMAIL")" ]]; then
1661:         set_env_value "ADMIN_EMAIL" "$admin_email" "管理员初始邮箱"
1662:     fi
1663: 
1664:     # 安装依赖
1665:     step "更新系统包索引..."
1666:     apt-get update -qq >/dev/null 2>&1
1667: 
1668:     install_system_tools
1669:     install_nodejs
1670:     install_pnpm
1671:     install_postgresql
1672:     install_redis
1673: 
1674:     # 仅在全新安装时获取和解压产物包（已安装则跳过）
1675:     if ! check_existing; then
1676:         # 获取产物包（自动下载或手动放置）
1677:         local tar_file
1678:         tar_file=$(obtain_release) || exit 1
1679:         if [[ -z "$tar_file" ]]; then
1680:             exit 1
1681:         fi
1682: 
1683:         # 解压安装
1684:         install_release "$tar_file" false
1685:     else
1686:         log "产物包已就绪，跳过下载和解压"
1687:     fi
1688: 
1689:     # 创建用户
1690:     create_user
1691: 
1692:     # 配置 Git 元数据
1693:     configure_git_metadata
1694: 
1695:     # 生成面板客户端证书（与 Incus API mTLS 通信所需）
1696:     generate_panel_cert
1697: 
1698:     # 配置数据库
1699:     setup_database "$db_password"
1700: 
1701:     # 配置 Redis
1702:     setup_redis "$redis_password"
1703: 
1704:     # 生成 .env
1705:     generate_env "$db_password" "$redis_password" "$(gen_password 16)" "$admin_email"
1706: 
1707:     # 创建 systemd 服务
1708:     create_service
1709:     create_online_update_service
1710: 
1711:     # 运行数据库迁移
1712:     run_migrations
1713: 
1714:     # 选择网络方案
1715:     echo ""
1716:     divider
1717:     echo -e "  ${BOLD}请选择外部访问方案：${NC}"
1718:     divider
1719:     echo -e "  ${CYAN}[1]${NC} Nginx + Certbot   ${YELLOW}（推荐：自动 HTTPS，需要公网 IP 和域名）${NC}"
1720:     echo -e "  ${CYAN}[2]${NC} Cloudflare Tunnel  ${YELLOW}（适合无公网 IP 或隐藏源站 IP）${NC}"
1721:     echo -e "  ${CYAN}[3]${NC} 仅启动服务        ${DIM}（手动配置反代）${NC}"
1722:     echo ""
1723:     echo -ne "  ${BOLD}请选择 [1-3]: ${NC}"
1724:     read -r net_opt
1725: 
1726:     case "${net_opt:-3}" in
1727:         1) setup_nginx_certbot ;;
1728:         2) setup_cf_tunnel ;;
1729:         3) info "跳过网络配置，服务将监听 127.0.0.1:${DEFAULT_PORT}" ;;
1730:         *) info "无效选项，跳过网络配置" ;;
1731:     esac
1732: 
1733:     # 启动服务
1734:     start_service
1735: 
1736:     # 显示结果
1737:     show_result
1738: }
1739: 
1740: # ========================== 主入口 ==========================
1741: main() {
1742:     check_root
1743: 
1744:     case "${1:-}" in
1745:         --upgrade|-u)
1746:             do_upgrade
1747:             ;;
1748:         --uninstall|--remove)
1749:             do_uninstall
1750:             ;;
1751:         --help|-h)
1752:             echo "PayIncus 面板部署脚本 v${SCRIPT_VERSION}"
1753:             echo ""
1754:             echo "用法: sudo bash $0 [选项]"
1755:             echo ""
1756:             echo "选项:"
1757:             echo "  (无参数)      全新安装"
1758:             echo "  --upgrade     升级已有安装"
1759:             echo "  --uninstall   卸载 PayIncus"
1760:             echo "  --help        显示帮助"
1761:             ;;
1762:         *)
1763:             do_install
1764:             ;;
1765:     esac
1766: }
1767: 
1768: if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
1769:     main "$@"
1770: fi

