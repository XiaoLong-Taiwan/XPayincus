 500: async function restoreRuntimeAssets(backupDir: string, targetDir = installDir): Promise<void> {
 501:   await copyIfExists(join(backupDir, '.env'), join(targetDir, '.env'))
 502:   await copyIfExists(join(backupDir, 'server/certs'), join(targetDir, 'server/certs'))
 503:   await copyIfExists(join(backupDir, 'agent-release'), join(targetDir, 'agent-release'))
 504:   await copyIfExists(join(backupDir, 'plugins'), join(installDir, 'plugins'))
 505:   await copyIfExists(join(backupDir, 'plugin-data'), join(installDir, 'plugin-data'))
 506:   await copyIfExists(join(backupDir, 'plugin-logs'), join(installDir, 'plugin-logs'))
 507:   await copyIfExists(join(backupDir, 'plugin-staging'), join(installDir, 'plugin-staging'))
 508:   await copyIfExists(join(backupDir, 'themes'), join(installDir, 'themes'))
 509:   await copyIfExists(join(backupDir, 'theme-data'), join(installDir, 'theme-data'))
 510:   await copyIfExists(join(backupDir, 'theme-staging'), join(installDir, 'theme-staging'))
 511:   await mkdir(join(installDir, '.npm'), { recursive: true })
 512:   await mkdir(join(installDir, '.cache'), { recursive: true })
 513:   await mkdir(join(targetDir, 'server/certs'), { recursive: true })
 514: }
