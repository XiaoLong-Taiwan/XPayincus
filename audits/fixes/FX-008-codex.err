Environment=NPM_CONFIG_CACHE=/opt/incudal/.npm
Environment=XDG_CACHE_HOME=/opt/incudal/.cache

ExecStartPre=/usr/bin/bash -lc 'cd /opt/incudal/current/server && pnpm exec prisma migrate deploy'
ExecStart=/usr/bin/node /opt/incudal/current/server/dist/app.js

Restart=on-failure
RestartSec=10
KillMode=mixed
KillSignal=SIGTERM
TimeoutStopSec=30
LimitNOFILE=65536

# Online updates start root-owned systemd oneshot units through a restricted
# sudoers rule. Keep this false or sudo cannot elevate from the backend service.
NoNewPrivileges=false
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/incudal /opt/incudal/current /opt/incudal/releases /opt/incudal/server/certs /opt/incudal/plugins /opt/incudal/plugin-data /opt/incudal/plugin-logs /opt/incudal/plugin-staging /opt/incudal/themes /opt/incudal/theme-data /opt/incudal/theme-staging /opt/incudal/.npm /opt/incudal/.cache /opt/incudal/.git /opt/incudal/update-logs
PrivateTmp=true

StandardOutput=journal
StandardError=journal
SyslogIdentifier=incudal-backend

[Install]
WantedBy=multi-user.target

[Unit]
Description=PayIncus online update task %i
Documentation=https://github.com/XiaoLong-Taiwan/payincus
After=network.target postgresql.service redis-server.service
Requires=postgresql.service redis-server.service

[Service]
Type=oneshot
User=root
Group=root
WorkingDirectory=/opt/incudal/current
EnvironmentFile=/opt/incudal/.env
Environment=HOME=/opt/incudal
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=NPM_CONFIG_CACHE=/opt/incudal/.npm
Environment=XDG_CACHE_HOME=/opt/incudal/.cache
Environment=INCUDAL_APP_DIR=/opt/incudal/current
Environment=INSTALL_DIR=/opt/incudal
Environment=SERVICE_NAME=incudal-backend
ExecStart=/usr/bin/node /opt/incudal/current/server/dist/scripts/run-system-update-task.js %i
TimeoutStartSec=1800
StandardOutput=journal
StandardError=journal
SyslogIdentifier=incudal-online-update

[Unit]
Description=PayIncus online update rollback task %i
Documentation=https://github.com/XiaoLong-Taiwan/payincus
After=network.target postgresql.service redis-server.service
Requires=postgresql.service redis-server.service

[Service]
Type=oneshot
User=root
Group=root
WorkingDirectory=/opt/incudal/current
EnvironmentFile=/opt/incudal/.env
Environment=HOME=/opt/incudal
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=NPM_CONFIG_CACHE=/opt/incudal/.npm
Environment=XDG_CACHE_HOME=/opt/incudal/.cache
Environment=INCUDAL_APP_DIR=/opt/incudal/current
Environment=INSTALL_DIR=/opt/incudal
Environment=SERVICE_NAME=incudal-backend
ExecStart=/usr/bin/node /opt/incudal/current/server/dist/scripts/rollback-system-update-task.js %i
TimeoutStartSec=900
StandardOutput=journal
StandardError=journal
SyslogIdentifier=incudal-online-rollback

