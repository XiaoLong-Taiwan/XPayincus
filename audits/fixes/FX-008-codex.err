 grep -Fq '检测到原子 OTA 布局' "$REPO_ROOT/scripts/install-panel.sh"
+grep -Fq 'ExecStart=/usr/local/libexec/incudal/incudal-online-task update %i' "$REPO_ROOT/scripts/install-panel.sh"
