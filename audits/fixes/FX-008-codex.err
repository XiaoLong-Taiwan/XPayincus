 672: # ========================== 统一入口：获取产物包 ==========================
 673: obtain_release() {
 674:     step "获取 PayIncus 产物包..."
 675: 
 676:     # ---- 阶段 0：检查是否已有手动放置的包 ----
 677:     local existing_pkg=""
 678:     existing_pkg=$(scan_manual_package) || true
 679:     if [[ -n "$existing_pkg" ]]; then
 680:         log "检测到手动放置的产物包: $(basename "$existing_pkg")"
 681:         echo "$existing_pkg"
 682:         return 0
 683:     fi
 684: 
 685:     # ---- 阶段 1：尝试 API 自动获取版本号 ----
 686:     info "正在查询最新版本（5 秒超时）..."
 687:     local version=""
 688:     version=$(get_latest_version)
 689: 
 690:     if [[ -n "$version" ]]; then
 691:         info "最新版本: ${version}"
 692: 
 693:         # ---- 阶段 2：尝试自动下载 ----
 694:         local tar_file=""
 695:         tar_file=$(download_release "$version") || true
 696: 
 697:         if [[ -n "$tar_file" && -f "$tar_file" ]]; then
 698:             echo "$tar_file"
 699:             return 0
 700:         fi
 701: 
 702:         warn "自动下载失败（文件可能不存在或网络受限）"
 703:     else
 704:         warn "自动获取版本号失败（仓库可能是私有的）"
 705:     fi
 706: 
 707:     # ---- 阶段 3：引导用户手动放置包 ----
 708:     local manual_file=""
 709:     manual_file=$(wait_for_manual_package) || return 1
 710:     echo "$manual_file"
 711:     return 0
 712: }
 713: 
 714: # ========================== 解压安装 ==========================
 715: install_release() {
 716:     local tar_file="$1"
 717:     local is_upgrade="${2:-false}"
 718: 
 719:     step "安装产物包..."
 720: 
 721:     verify_release_checksum "$tar_file" || return 1
 722:     validate_release_archive "$tar_file" || return 1
 723: 
 724:     # 创建安装目录
 725:     mkdir -p "$INSTALL_DIR"
 726: 
 727:     if [[ "$is_upgrade" == "true" ]]; then
 728:         # 升级模式：先备份当前版本
 729:         info "备份当前版本..."
 730:         local backup_dir="${INSTALL_DIR}.bak.$(date +%Y%m%d%H%M%S)"
 731:         cp -r "$INSTALL_DIR" "$backup_dir"
 732:         info "备份已保存到: ${backup_dir}"
 733: 
 734:         # 保留 .env 文件和证书目录
 735:         local env_backup=""
 736:         local certs_backup=""
 737:         if [[ -f "${INSTALL_DIR}/.env" ]]; then
 738:             env_backup=$(mktemp)
 739:             cp "${INSTALL_DIR}/.env" "$env_backup"
 740:         fi
 741:         if [[ -d "${INSTALL_DIR}/server/certs" ]]; then
 742:             certs_backup=$(mktemp -d)
 743:             cp -r "${INSTALL_DIR}/server/certs" "$certs_backup/"
 744:         fi
 745: 
 746:         # 清理旧文件（保留 .env 和 certs）
 747:         rm -rf "${INSTALL_DIR}/client" "${INSTALL_DIR}/server/dist" "${INSTALL_DIR}/server/node_modules"
 748: 
 749:         # 解压新版本
 750:         tar -xzf "$tar_file" -C "$INSTALL_DIR" --strip-components=0
 751: 
 752:         # 恢复 .env 和证书
 753:         if [[ -n "$env_backup" && -f "$env_backup" ]]; then
 754:             cp "$env_backup" "${INSTALL_DIR}/.env"
 755:             rm -f "$env_backup"
 756:         fi
 757:         if [[ -n "$certs_backup" && -d "$certs_backup/certs" ]]; then
 758:             mkdir -p "${INSTALL_DIR}/server/certs"
 759:             cp -r "$certs_backup/certs/"* "${INSTALL_DIR}/server/certs/" 2>/dev/null || true
 760:             rm -rf "$certs_backup"
 761:         fi
 762:     else
 763:         # 全新安装
 764:         tar -xzf "$tar_file" -C "$INSTALL_DIR" --strip-components=0
 765:     fi
 766: 
 767:     # 清理下载的临时文件
 768:     rm -f "$tar_file" "${tar_file}.sha256"
 769: 
 770:     # 创建证书目录
 771:     mkdir -p "${INSTALL_DIR}/server/certs"
 772: 
 773:     log "产物包安装完成"
 774: }
 775: 
 776: # ========================== 配置 Git 在线更新元数据 ==========================
 777: configure_git_metadata() {
 778:     step "配置 Git 在线更新元数据..."
 779: 
 780:     if ! command -v git &>/dev/null; then
 781:         warn "git 未安装，后台在线更新将不可用"
 782:         return 0
 783:     fi
 784: 
 785:     cd "$INSTALL_DIR"
 786: 
 787:     if [[ -d "${INSTALL_DIR}/.git" ]]; then
 788:         git remote get-url origin >/dev/null 2>&1 && \
 789:             git remote set-url origin "https://github.com/${GITHUB_REPO}.git" || \
 790:             git remote add origin "https://github.com/${GITHUB_REPO}.git"
 791:     else
 792:         git init -q
 793:         git remote add origin "https://github.com/${GITHUB_REPO}.git" 2>/dev/null || \
 794:             git remote set-url origin "https://github.com/${GITHUB_REPO}.git" 2>/dev/null || true
 795:     fi
 796: 
 797:     git config --global --add safe.directory "$INSTALL_DIR" 2>/dev/null || true
 798:     sudo -u "$RUN_USER" HOME="$INSTALL_DIR" git config --global --add safe.directory "$INSTALL_DIR" 2>/dev/null || true
 799:     if git fetch --tags --force --quiet origin; then
