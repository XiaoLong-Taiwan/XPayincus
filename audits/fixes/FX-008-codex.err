 806: # ========================== 创建系统用户 ==========================
 807: create_user() {
 808:     step "配置系统用户..."
 809: 
 810:     if id "$RUN_USER" &>/dev/null; then
 811:         log "用户 ${RUN_USER} 已存在，跳过"
 812:     else
 813:         useradd --system --home-dir "${INSTALL_DIR}" --shell /usr/sbin/nologin "$RUN_USER"
 814:         log "系统用户 ${RUN_USER} 创建完成"
 815:     fi
 816: 
 817:     # 创建 npm 缓存目录（npx/prisma 需要可写的 home 目录）
 818:     mkdir -p "${INSTALL_DIR}/.npm"
 819:     mkdir -p "${INSTALL_DIR}/.cache"
 820:     mkdir -p "${INSTALL_DIR}/plugins"
 821:     mkdir -p "${INSTALL_DIR}/plugin-data"
 822:     mkdir -p "${INSTALL_DIR}/plugin-logs"
 823:     mkdir -p "${INSTALL_DIR}/plugin-staging"
 824:     mkdir -p "${INSTALL_DIR}/theme-data"
 825: 
 826:     # Nginx runs as www-data and must be able to traverse the install root
 827:     # to serve client/dist while .env stays owner-only below.
 828:     chown -R "${RUN_USER}:${RUN_USER}" "$INSTALL_DIR"
 829:     chmod 751 "$INSTALL_DIR"
 830:     chmod 600 "${ENV_FILE}" 2>/dev/null || true
 831: }
