 245: # ========================== 系统检查 ==========================
 246: check_root() {
 247:     if [[ "$EUID" -ne 0 ]]; then
 248:         error "请以 root 权限运行此部署脚本！"
 249:         error "用法: sudo bash $0"
 250:         exit 1
 251:     fi
 252: }
 253: 
 254: check_os() {
 255:     if [[ ! -f /etc/os-release ]]; then
 256:         error "无法检测操作系统（/etc/os-release 不存在）"
 257:         exit 1
 258:     fi
 259: 
 260:     source /etc/os-release
 261:     OS_ID="${ID:-unknown}"
 262:     OS_VERSION="${VERSION_ID:-unknown}"
 263:     OS_CODENAME="${VERSION_CODENAME:-unknown}"
 264:     ARCH=$(dpkg --print-architecture 2>/dev/null || uname -m)
 265: 
 266:     # 仅支持 Ubuntu 和 Debian
 267:     if [[ "$OS_ID" != "ubuntu" && "$OS_ID" != "debian" ]]; then
 268:         error "不支持的操作系统: ${OS_ID}"
 269:         error "本脚本仅支持 Ubuntu 和 Debian 系统"
 270:         exit 1
 271:     fi
 272: 
 273:     # 版本检查
 274:     case "$OS_ID" in
 275:         ubuntu)
 276:             local major="${OS_VERSION%%.*}"
 277:             if [[ "$major" -lt 22 ]] 2>/dev/null; then
 278:                 error "Ubuntu 版本过低 (${OS_VERSION})，最低要求 Ubuntu 22.04"
 279:                 exit 1
 280:             fi
 281:             ;;
 282:         debian)
 283:             local major="${OS_VERSION%%.*}"
 284:             if [[ "$major" -lt 12 ]] 2>/dev/null; then
 285:                 error "Debian 版本过低 (${OS_VERSION})，最低要求 Debian 12 (Bookworm)"
 286:                 exit 1
 287:             fi
 288:             ;;
 289:     esac
 290: 
 291:     # 架构检查
 292:     case "$ARCH" in
 293:         amd64|x86_64) ARCH="amd64" ;;
 294:         arm64|aarch64) ARCH="arm64" ;;
 295:         *)
 296:             error "不支持的系统架构: ${ARCH}"
 297:             error "仅支持 amd64 (x86_64) 和 arm64 (aarch64)"
 298:             exit 1
 299:             ;;
 300:     esac
 301: 
 302:     log "系统检测通过: ${OS_ID} ${OS_VERSION} (${ARCH})"
 303: }
