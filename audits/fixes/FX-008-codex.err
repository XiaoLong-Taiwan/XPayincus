 335: # ========================== 安装 Node.js ==========================
 336: install_nodejs() {
 337:     step "安装 Node.js ${NODE_MAJOR}..."
 338: 
 339:     if command -v node &>/dev/null; then
 340:         local current_ver
 341:         current_ver=$(node -v 2>/dev/null | sed 's/v//' | cut -d. -f1)
 342:         if [[ "$current_ver" -ge "$NODE_MAJOR" ]] 2>/dev/null; then
 343:             log "Node.js $(node -v) 已安装，跳过"
 344:             return 0
 345:         fi
 346:         warn "当前 Node.js 版本较低 ($(node -v))，将升级到 v${NODE_MAJOR}"
 347:     fi
 348: 
 349:     # 通过 NodeSource 安装
 350:     info "添加 NodeSource APT 源..."
 351:     curl -fsSL "https://deb.nodesource.com/setup_${NODE_MAJOR}.x" | bash - >/dev/null 2>&1
 352:     apt-get install -y -qq nodejs >/dev/null 2>&1
 353: 
 354:     log "Node.js $(node -v) 安装完成"
 355: }
 356: 
 357: # ========================== 安装 pnpm ==========================
 358: install_pnpm() {
 359:     step "安装 pnpm ${PNPM_VERSION}..."
 360: 
 361:     if command -v pnpm &>/dev/null; then
 362:         log "pnpm $(pnpm --version) 已安装，跳过"
 363:         return 0
 364:     fi
 365: 
 366:     if command -v corepack &>/dev/null; then
 367:         corepack enable >/dev/null 2>&1
 368:         corepack prepare "pnpm@${PNPM_VERSION}" --activate >/dev/null 2>&1
 369:     else
 370:         npm install -g "pnpm@${PNPM_VERSION}" >/dev/null 2>&1
 371:     fi
 372: 
 373:     if ! command -v pnpm &>/dev/null; then
 374:         error "pnpm 安装失败，请检查 Node.js/Corepack 环境"
 375:         exit 1
 376:     fi
 377: 
 378:     log "pnpm $(pnpm --version) 安装完成"
 379: }
 380: 
 381: # ========================== 安装系统工具 ==========================
 382: install_system_tools() {
 383:     step "安装基础系统工具..."
 384: 
 385:     apt-get install -y -qq ca-certificates curl git sudo tar >/dev/null 2>&1
 386: 
 387:     log "基础系统工具安装完成"
 388: }
