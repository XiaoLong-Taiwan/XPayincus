 377: async function switchCurrentRelease(targetDir: string): Promise<void> {
 378:   await mkdir(getReleasesDir(), { recursive: true })
 379:   const currentLink = getCurrentLinkPath()
 380:   const nextLink = join(getReleasesDir(), `.next-current-${taskId}-${Date.now()}`)
 381:   await rm(nextLink, { force: true })
 382:   await symlink(targetDir, nextLink)
 383:   await rename(nextLink, currentLink)
 384:   await log(`Switched current release to ${targetDir}`)
 385: }
