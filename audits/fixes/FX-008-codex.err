 442: async function assertArtifactStaging(stagingDir: string): Promise<void> {
 443:   const requiredPaths = [
 444:     'package.json',
 445:     'pnpm-lock.yaml',
 446:     'client/dist/user/index.html',
 447:     'client/dist/admin/index.html',
 448:     'server/dist/app.js',
 449:     'server/prisma/schema.prisma',
 450:     'scripts/verify-split-host.sh',
 451:     'scripts/verify-production-readiness.sh',
 452:     'scripts/verify-log-header-exposure.sh',
 453:     'version.json'
 454:   ]
 455: 
 456:   for (const relativePath of requiredPaths) {
 457:     if (!existsSync(join(stagingDir, relativePath))) {
 458:       throw new Error(`OTA artifact is missing required path: ${relativePath}`)
 459:     }
 460:   }
 461: }
