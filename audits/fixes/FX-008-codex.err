 ExecStart=/usr/bin/node /opt/incudal/current/server/dist/app.js
diff --git a/deploy/incudal-online-rollback@.service.example b/deploy/incudal-online-rollback@.service.example
index 7adc26168ce00d1d3d8aea78d339a8e50caa0851..8f0619b89ef609db3434d23b8425c77070f2997d
