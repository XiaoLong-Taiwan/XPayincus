 890: # ========================== 生成环境变量 ==========================
 891: generate_env() {
 892:     local db_password="$1"
 893:     local redis_password="$2"
 894:     local admin_password="${3:-$(gen_password 16)}"
 895:     local admin_email="${4:-admin@payincus.local}"
 896: 
 897:     step "生成环境配置..."
 898: 
 899:     if [[ -f "$ENV_FILE" ]]; then
 900:         info ".env 文件已存在，检查并补齐缺失的密钥配置"
 901:         ensure_env_keys
 902:         return 0
 903:     fi
 904: 
 905:     local jwt_secret
 906:     jwt_secret=$(gen_secret 48)
 907:     local cookie_secret
 908:     cookie_secret=$(gen_secret 48)
 909:     local encryption_key
 910:     encryption_key=$(openssl rand -base64 32)
 911: 
 912:     cat > "$ENV_FILE" << EOF
 913: # ============================================================================
 914: # PayIncus 环境配置
 915: # 由安装脚本自动生成于 $(date '+%Y-%m-%d %H:%M:%S')
 916: # ============================================================================
 917: 
 918: # ============ 运行环境 ============
 919: NODE_ENV=production
 920: HOST=127.0.0.1
 921: PORT=${DEFAULT_PORT}
 922: TRUST_PROXY=true
 923: 
 924: # ============ 数据库配置 ============
 925: DATABASE_URL=postgresql://incudal:${db_password}@127.0.0.1:5432/incudal
 926: # 生产环境不要设置 RESET_DATABASE；真要清库还必须设置
 927: # ALLOW_PRODUCTION_DATABASE_RESET=RESET_PRODUCTION_DATABASE
 928: 
 929: # ============ Redis 配置 ============
 930: REDIS_URL=redis://:${redis_password}@127.0.0.1:6379
 931: 
 932: # ============ 安全配置（请勿泄露！）============
 933: JWT_SECRET=${jwt_secret}
 934: COOKIE_SECRET=${cookie_secret}
 935: ENCRYPTION_KEY=${encryption_key}
 936: 
 937: # ============ 应用配置 ============
 938: ADMIN_EMAIL=${admin_email}
 939: ADMIN_PASSWORD=${admin_password}
 940: SERVE_STATIC_CLIENT=false
 941: VITE_API_BASE_URL=/api
 942: VITE_CUSTOMER_BASE_URL=
 943: VITE_ADMIN_BASE_URL=
 944: LOG_LEVEL=info
 945: DISABLE_REQUEST_LOG=true
 946: 
 947: # ============ 后台在线更新 ============
 948: SYSTEM_UPDATE_ALLOWED_ADMIN_IDS=
 949: SYSTEM_UPDATE_LOG_DIR=${INSTALL_DIR}/update-logs
 950: SYSTEM_UPDATE_STARTED_BY_USER_ID=
 951: SYSTEM_UPDATE_RELEASE_REPOSITORY=${GITHUB_REPO}
 952: SYSTEM_UPDATE_RELEASE_TOKEN=
 953: SYSTEM_UPDATE_APPLY_MODE=auto
 954: 
 955: # ============ Agent Release 配置 ============
 956: # 可使用 GitHub Release 仓库、本地 release 目录，或自定义二进制 URL+SHA256。
 957: INCUDAL_AGENT_RELEASE_REPOSITORY=
 958: INCUDAL_AGENT_RELEASE_TOKEN=
 959: INCUDAL_AGENT_RELEASE_DIR=
 960: INCUDAL_AGENT_BINARY_URL=
 961: INCUDAL_AGENT_BINARY_SHA256=
 962: 
 963: # ============ CORS 配置（必须修改为实际域名！）============
 964: # 支付回调地址也会使用这个域名，必须是公网可访问的地址
 965: FRONTEND_URL=
 966: ADMIN_FRONTEND_URL=
 967: SITE_URL=
 968: PAYMENT_CALLBACK_BASE_URL=
 969: 
 970: # ============ Cookie 配置 ============
 971: # HTTPS 同域 /api 反代部署保持留空即可。仅 HTTP 内网验证时可设置 COOKIE_SECURE=false。
 972: # 若 API 与前端跨站，请设置：
 973: # COOKIE_SAME_SITE=none
 974: # COOKIE_SECURE=true
 975: # COOKIE_DOMAIN must stay empty so customer/admin subdomains do not share refresh cookies.
 976: COOKIE_SAME_SITE=
 977: COOKIE_SECURE=
 978: COOKIE_DOMAIN=
 979: 
 980: # ============ 监控告警（可选）============
 981: # ALERT_WEBHOOK_URL=https://your-webhook-url
 982: EOF
 983: 
 984:     chmod 600 "$ENV_FILE"
 985:     chown "${RUN_USER}:${RUN_USER}" "$ENV_FILE"
 986: 
 987:     log "环境配置文件生成完成: ${ENV_FILE}"
 988: }
 989: 
 990: # ========================== 配置 Redis 密码 ==========================
 991: setup_redis() {
 992:     local redis_password="$1"
 993: 
 994:     step "配置 Redis..."
 995: 
 996:     local redis_conf="/etc/redis/redis.conf"
 997:     if [[ -f "$redis_conf" ]]; then
 998:         # 设置密码
 999:         if grep -q "^requirepass" "$redis_conf" 2>/dev/null; then
1000:             sed -i "s/^requirepass.*/requirepass ${redis_password}/" "$redis_conf"
1001:         elif grep -q "^# requirepass" "$redis_conf" 2>/dev/null; then
1002:             sed -i "s/^# requirepass.*/requirepass ${redis_password}/" "$redis_conf"
1003:         else
1004:             echo "requirepass ${redis_password}" >> "$redis_conf"
1005:         fi
1006: 
1007:         systemctl restart redis-server
1008:         log "Redis 密码配置完成"
1009:     else
1010:         warn "Redis 配置文件不存在，跳过密码配置"
1011:     fi
1012: }
1013: 
1014: # ========================== 运行数据库迁移 ==========================
1015: run_migrations() {
1016:     step "执行数据库迁移..."
1017: 
1018:     cd "${INSTALL_DIR}/server"
1019: 
1020:     # 以 incudal 用户身份加载 .env 并运行迁移
1021:     # HOME 需要指向有写权限的目录，否则 npm 缓存报 EACCES
1022:     sudo -u "$RUN_USER" HOME="${INSTALL_DIR}" bash -c "
1023:         set -a
1024:         source '${ENV_FILE}'
1025:         set +a
1026:         cd '${INSTALL_DIR}/server'
1027:         pnpm exec prisma migrate deploy
1028:     "
1029: 
1030:     log "数据库迁移完成"
1031: }
1032: 
1033: # ========================== 创建 systemd 服务 ==========================
1034: create_service() {
1035:     step "创建 systemd 服务..."
1036: 
1037:     local app_dir="${INSTALL_DIR}"
1038:     if [[ -L "${INSTALL_DIR}/current" ]]; then
1039:         app_dir="${INSTALL_DIR}/current"
1040:     fi
1041: 
1042:     cat > "$SERVICE_FILE" << EOF
1043: [Unit]
1044: Description=PayIncus 容器虚拟化管理平台
1045: Documentation=https://github.com/${GITHUB_REPO}
1046: After=network.target postgresql.service redis-server.service
1047: Requires=postgresql.service redis-server.service
1048: 
1049: [Service]
1050: Type=simple
1051: User=${RUN_USER}
1052: Group=${RUN_USER}
1053: WorkingDirectory=${app_dir}
1054: EnvironmentFile=${ENV_FILE}
1055: 
1056: # 确保 npm 缓存目录可写
1057: Environment=HOME=${INSTALL_DIR}
1058: Environment=NPM_CONFIG_CACHE=${INSTALL_DIR}/.npm
1059: Environment=XDG_CACHE_HOME=${INSTALL_DIR}/.cache
1060: 
1061: # 启动前自动执行数据库迁移
1062: ExecStartPre=/usr/bin/bash -c 'cd ${app_dir}/server && pnpm exec prisma migrate deploy'
1063: 
1064: # 启动主程序
1065: ExecStart=/usr/bin/node ${app_dir}/server/dist/app.js
1066: 
1067: # 优雅关闭
1068: KillMode=mixed
1069: KillSignal=SIGTERM
1070: TimeoutStopSec=30
1071: 
1072: # 自动重启
1073: Restart=on-failure
1074: RestartSec=10
1075: StartLimitBurst=5
1076: StartLimitIntervalSec=300
1077: 
1078: # 安全加固
1079: # 后台在线更新需要通过受限 sudoers 启动 root-owned systemd oneshot 单元。
1080: # 如果启用 NoNewPrivileges，sudo 会被内核直接拒绝。
1081: NoNewPrivileges=false
1082: ProtectSystem=strict
1083: ProtectHome=true
1084: ReadWritePaths=${INSTALL_DIR} ${INSTALL_DIR}/current ${INSTALL_DIR}/releases ${INSTALL_DIR}/server/certs ${INSTALL_DIR}/plugins ${INSTALL_DIR}/plugin-data ${INSTALL_DIR}/plugin-logs ${INSTALL_DIR}/plugin-staging ${INSTALL_DIR}/themes ${INSTALL_DIR}/theme-data ${INSTALL_DIR}/theme-staging ${INSTALL_DIR}/.npm ${INSTALL_DIR}/.cache ${INSTALL_DIR}/.git ${INSTALL_DIR}/update-logs
1085: PrivateTmp=true
1086: 
1087: # 资源限制
1088: LimitNOFILE=65536
1089: 
1090: # 日志
1091: StandardOutput=journal
1092: StandardError=journal
1093: SyslogIdentifier=${SERVICE_NAME}
1094: 
1095: [Install]
1096: WantedBy=multi-user.target
1097: EOF
1098: 
1099:     systemctl daemon-reload
1100:     systemctl enable "$SERVICE_NAME" >/dev/null 2>&1
1101: 
1102:     log "systemd 服务创建完成"
1103: }
1104: 
1105: # ========================== 创建在线更新 systemd 单元和 sudoers ==========================
1106: create_online_update_service() {
1107:     step "创建在线更新 systemd 单元..."
1108: 
1109:     mkdir -p "${INSTALL_DIR}/update-logs"
1110:     mkdir -p "${INSTALL_DIR}/plugins" "${INSTALL_DIR}/plugin-data" "${INSTALL_DIR}/plugin-logs" "${INSTALL_DIR}/plugin-staging" "${INSTALL_DIR}/themes" "${INSTALL_DIR}/theme-data" "${INSTALL_DIR}/theme-staging"
1111:     local app_dir="${INSTALL_DIR}"
1112:     if [[ -L "${INSTALL_DIR}/current" ]]; then
1113:         app_dir="${INSTALL_DIR}/current"
1114:     fi
1115: 
1116:     cat > /etc/systemd/system/incudal-online-update@.service << EOF
1117: [Unit]
1118: Description=PayIncus online update task %i
1119: Documentation=https://github.com/${GITHUB_REPO}
1120: After=network.target postgresql.service redis-server.service
1121: Requires=postgresql.service redis-server.service
1122: 
1123: [Service]
1124: Type=oneshot
1125: User=root
1126: Group=root
1127: WorkingDirectory=${app_dir}
1128: EnvironmentFile=${ENV_FILE}
1129: Environment=HOME=${INSTALL_DIR}
1130: Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
1131: Environment=NPM_CONFIG_CACHE=${INSTALL_DIR}/.npm
1132: Environment=XDG_CACHE_HOME=${INSTALL_DIR}/.cache
1133: Environment=INCUDAL_APP_DIR=${app_dir}
1134: Environment=INSTALL_DIR=${INSTALL_DIR}
1135: Environment=SERVICE_NAME=${SERVICE_NAME}
1136: ExecStart=/usr/bin/node ${app_dir}/server/dist/scripts/run-system-update-task.js %i
1137: TimeoutStartSec=1800
1138: StandardOutput=journal
1139: StandardError=journal
1140: SyslogIdentifier=incudal-online-update
1141: EOF
1142: 
1143:     cat > /etc/systemd/system/incudal-online-rollback@.service << EOF
1144: [Unit]
1145: Description=PayIncus online update rollback task %i
1146: Documentation=https://github.com/${GITHUB_REPO}
1147: After=network.target postgresql.service redis-server.service
1148: Requires=postgresql.service redis-server.service
1149: 
1150: [Service]
1151: Type=oneshot
1152: User=root
1153: Group=root
1154: WorkingDirectory=${app_dir}
1155: EnvironmentFile=${ENV_FILE}
1156: Environment=HOME=${INSTALL_DIR}
1157: Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
1158: Environment=NPM_CONFIG_CACHE=${INSTALL_DIR}/.npm
1159: Environment=XDG_CACHE_HOME=${INSTALL_DIR}/.cache
1160: Environment=INCUDAL_APP_DIR=${app_dir}
1161: Environment=INSTALL_DIR=${INSTALL_DIR}
1162: Environment=SERVICE_NAME=${SERVICE_NAME}
1163: ExecStart=/usr/bin/node ${app_dir}/server/dist/scripts/rollback-system-update-task.js %i
1164: TimeoutStartSec=900
1165: StandardOutput=journal
1166: StandardError=journal
1167: SyslogIdentifier=incudal-online-rollback
1168: EOF
1169: 
1170:     local systemctl_bin
1171:     systemctl_bin="$(command -v systemctl)"
1172:     cat > /etc/sudoers.d/incudal-online-update << EOF
1173: Defaults:${RUN_USER} !requiretty
1174: ${RUN_USER} ALL=(root) NOPASSWD: ${systemctl_bin} start --no-block incudal-online-update@*.service, ${systemctl_bin} start --no-block incudal-online-rollback@*.service
1175: EOF
1176:     chmod 440 /etc/sudoers.d/incudal-online-update
1177:     visudo -cf /etc/sudoers.d/incudal-online-update >/dev/null
1178: 
1179:     systemctl daemon-reload
1180:     chown -R "${RUN_USER}:${RUN_USER}" "${INSTALL_DIR}/update-logs" "${INSTALL_DIR}/plugins" "${INSTALL_DIR}/plugin-data" "${INSTALL_DIR}/plugin-logs" "${INSTALL_DIR}/plugin-staging" "${INSTALL_DIR}/themes" "${INSTALL_DIR}/theme-data" "${INSTALL_DIR}/theme-staging" "${INSTALL_DIR}/.git" 2>/dev/null || true
1181: 
1182:     log "在线更新 systemd 单元和 sudoers 创建完成"
1183: }
