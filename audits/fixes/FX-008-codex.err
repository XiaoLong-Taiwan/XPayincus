 390: # ========================== 安装 PostgreSQL ==========================
 391: install_postgresql() {
 392:     step "安装 PostgreSQL ${PG_VERSION}..."
 393: 
 394:     if command -v psql &>/dev/null; then
 395:         local pg_ver
 396:         pg_ver=$(psql --version 2>/dev/null | awk '{print $3}' | cut -d. -f1)
 397:         if [[ "$pg_ver" -ge "$PG_VERSION" ]] 2>/dev/null; then
 398:             log "PostgreSQL ${pg_ver} 已安装，跳过"
 399:             return 0
 400:         fi

