 387: function getRuntimePlatform(): string {
 388:   return process.platform
 389: }
 390: 
 391: function getRuntimeArch(): string {
 392:   if (process.arch === 'x64') return 'amd64'
 393:   if (process.arch === 'arm64') return 'arm64'
 394:   return process.arch
 395: }
 396: 
 397: function selectRuntimeArtifact(artifacts: OtaArtifactInfo[]): OtaArtifactInfo | null {
 398:   const platform = getRuntimePlatform()
 399:   const arch = getRuntimeArch()
 400:   return artifacts.find(artifact => artifact.platform === platform && artifact.arch === arch) || null
 401: }
 402: 
 403: async function sha256File(path: string): Promise<string> {
 404:   const hash = createHash('sha256')
 405:   await pipeline(createReadStream(path), hash)
 406:   return hash.digest('hex')
 407: }
 408: 
 409: async function downloadArtifact(artifact: OtaArtifactInfo): Promise<string> {
 410:   await mkdir(updateDownloadDir, { recursive: true })
 411:   const artifactPath = join(updateDownloadDir, `${taskId}-${artifact.name}`)
 412:   await log(`Downloading OTA artifact ${artifact.name} (${artifact.size ?? 'unknown'} bytes)`)
 413: 
 414:   const headers: Record<string, string> = {
 415:     'user-agent': 'payincus-online-update'
 416:   }
 417:   const token = getReleaseToken()
 418:   // 仅对可信 GitHub 主机附带 release token，避免被构造的 artifact.url 把凭证泄露到攻击者主机
 419:   if (token && isTrustedReleaseHost(artifact.url)) headers.authorization = `Bearer ${token}`
 420: 
 421:   const response = await fetch(artifact.url, { headers })
 422:   if (!response.ok || !response.body) {
 423:     throw new Error(`Failed to download OTA artifact: HTTP ${response.status}`)
 424:   }
 425: 
 426:   await pipeline(Readable.fromWeb(response.body), createWriteStream(artifactPath))
 427: 
 428:   const fileStat = await stat(artifactPath)
 429:   if (artifact.size !== null && fileStat.size !== artifact.size) {
 430:     throw new Error(`OTA artifact size mismatch: expected ${artifact.size}, got ${fileStat.size}`)
 431:   }
 432: 
 433:   const actualSha256 = await sha256File(artifactPath)
 434:   if (actualSha256 !== artifact.sha256) {
 435:     throw new Error(`OTA artifact sha256 mismatch: expected ${artifact.sha256}, got ${actualSha256}`)
 436:   }
 437: 
 438:   await log(`OTA artifact verified: sha256=${actualSha256}`)
 439:   return artifactPath
 440: }
