 558: # ========================== 等待用户放置产物包 ==========================
 559: wait_for_manual_package() {
 560:     echo "" >&2
 561:     divider
 562:     echo -e "  ${YELLOW}${BOLD}⚠ 自动获取产物包失败${NC}" >&2
 563:     echo -e "  ${DIM}（仓库可能是私有的，或网络无法连接 GitHub）${NC}" >&2
 564:     divider
 565:     echo "" >&2
 566:     echo -e "  ${BOLD}请手动下载产物包并放到以下目录：${NC}" >&2
 567:     echo "" >&2
 568:     echo -e "  ${CYAN}${BOLD}${MANUAL_PKG_DIR}/${NC}" >&2
 569:     echo "" >&2
 570:     echo -e "  ${BOLD}下载地址：${NC}" >&2
 571:     echo -e "  ${CYAN}https://github.com/${GITHUB_REPO}/releases${NC}" >&2
 572:     echo "" >&2
 573:     echo -e "  ${BOLD}所需文件名格式：${NC}" >&2
 574:     echo -e "  ${GREEN}incudal-vX.Y.Z-linux-${ARCH}.tar.gz${NC}" >&2
 575:     echo -e "  ${GREEN}incudal-vX.Y.Z-linux-${ARCH}.tar.gz.sha256${NC}" >&2
 576:     echo "" >&2
 577:     echo -e "  ${DIM}提示: 可使用 scp、wget、rz 等方式将文件传到服务器${NC}" >&2
 578:     echo -e "  ${DIM}例如: scp incudal-v1.0.0-linux-${ARCH}.tar.gz root@服务器IP:${MANUAL_PKG_DIR}/${NC}" >&2
 579:     divider
 580:     echo "" >&2
 581: 
 582:     # 创建目录
 583:     mkdir -p "$MANUAL_PKG_DIR"
 584: 
 585:     # 轮询等待文件出现
 586:     local wait_count=0
 587:     local max_wait=600  # 最多等 10 分钟（含上传时间）
 588:     local spin_chars='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
 589:     local MIN_SIZE_KB=10240  # 产物包至少 10MB
 590: 
 591:     while true; do
 592:         # 尝试扫描
 593:         local pkg_file=""
 594:         pkg_file=$(scan_manual_package) || true
 595: 
 596:         if [[ -n "$pkg_file" ]]; then
 597:             # 检测到文件，等待上传完成（文件大小稳定）
 598:             echo "" >&2
 599:             info "检测到文件: $(basename "$pkg_file")"
 600:             info "等待上传完成..."
 601: 
 602:             local stable_count=0
 603:             local last_size=0
 604: 
 605:             while true; do
 606:                 local current_size
 607:                 current_size=$(stat -c%s "$pkg_file" 2>/dev/null || echo "0")
 608:                 local current_size_human
 609:                 current_size_human=$(du -h "$pkg_file" 2>/dev/null | cut -f1 || echo "?")
 610: 
 611:                 if [[ "$current_size" -eq "$last_size" && "$current_size" -gt 0 ]]; then
 612:                     stable_count=$((stable_count + 1))
 613:                 else
 614:                     stable_count=0
 615:                     last_size="$current_size"
 616:                 fi
 617: 
 618:                 # 连续 3 次（9 秒）大小不变，认为上传完成
 619:                 if [[ $stable_count -ge 3 ]]; then
 620:                     if [[ ! -f "${pkg_file}.sha256" ]]; then
 621:                         info "已收到产物包，继续等待对应的 $(basename "${pkg_file}.sha256")..."
 622:                         stable_count=0
 623:                         sleep 3
 624:                         continue
 625:                     fi
 626: 
 627:                     # 检查最小文件大小
 628:                     local size_kb=$((current_size / 1024))
 629:                     if [[ $size_kb -lt $MIN_SIZE_KB ]]; then
 630:                         warn "文件过小 (${current_size_human})，产物包通常 >100MB，可能不完整"
 631:                         warn "如确认无误，请将文件删除后重新放置"
 632:                         # 继续等待
 633:                         stable_count=0
 634:                         last_size=0
 635:                         sleep 3
 636:                         continue
 637:                     fi
 638: 
 639:                     log "上传完成！文件大小: ${current_size_human}"
 640:                     echo "$pkg_file"
 641:                     return 0
 642:                 fi
 643: 
 644:                 printf "\r  ${CYAN}⏳${NC} 上传中... 当前大小: ${current_size_human}  " >&2
 645:                 sleep 3
 646:                 wait_count=$((wait_count + 3))
 647: 
 648:                 if [[ $wait_count -ge $max_wait ]]; then
 649:                     echo "" >&2
 650:                     error "等待超时 (${max_wait}s)，请重新运行脚本"

