1186: write_nginx_split_server_block() {
1187:     local server_name="$1"
1188:     local root_dir="$2"
1189:     local default_server="${3:-}"
1190:     local listen_suffix=""
1191: 
1192:     if [[ "$default_server" == "default" ]]; then
1193:         listen_suffix=" default_server"
1194:     fi
1195: 
1196:     cat <<NGINX
1197: server {
1198:     listen 80${listen_suffix};
1199:     listen [::]:80${listen_suffix};
1200:     server_name ${server_name};
1201: 
1202:     root ${root_dir};
1203:     index index.html;
1204:     client_max_body_size 100m;
1205: 
1206:     add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: http: https: https://kkksr.com https://api.dicebear.com https://dicebear.incudal.com https://*.githubusercontent.com https://avatars.githubusercontent.com https://lh3.googleusercontent.com; connect-src 'self' ws: wss: https://challenges.cloudflare.com https://cloudflareinsights.com https://api.dicebear.com https://dicebear.incudal.com; frame-src 'self' https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'" always;
1207:     add_header X-Content-Type-Options nosniff always;
1208:     add_header X-Frame-Options DENY always;
1209:     add_header Referrer-Policy strict-origin-when-cross-origin always;
1210:     add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
1211: 
1212:     location = /healthz {
1213:         add_header Content-Type text/plain;
1214:         return 200 "ok\n";
1215:     }
1216: 
1217:     location = /index.html {
1218:         expires epoch;
1219:     }
1220: 
1221:     location /assets/ {
1222:         try_files \$uri =404;
1223:         expires 1y;
1224:     }
1225: 
1226:     location /api/ws/ {
1227:         proxy_pass http://127.0.0.1:${DEFAULT_PORT};
1228:         proxy_http_version 1.1;
1229:         proxy_set_header Upgrade \$http_upgrade;
1230:         proxy_set_header Connection 'upgrade';
1231:         proxy_set_header Host \$host;
1232:         proxy_set_header X-Forwarded-Host \$incudal_forwarded_host;
1233:         proxy_set_header X-Real-IP \$remote_addr;
1234:         proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
1235:         proxy_set_header X-Forwarded-Proto \$incudal_forwarded_proto;
1236:         proxy_cache_bypass \$http_upgrade;
1237:         proxy_read_timeout 3600s;
1238:         proxy_send_timeout 3600s;
1239:         proxy_buffering off;
1240:     }
1241: 
1242:     location /api/ {
1243:         proxy_pass http://127.0.0.1:${DEFAULT_PORT};
1244:         proxy_http_version 1.1;
1245:         proxy_set_header Host \$host;
1246:         proxy_set_header X-Forwarded-Host \$incudal_forwarded_host;
1247:         proxy_set_header X-Real-IP \$remote_addr;
1248:         proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
1249:         proxy_set_header X-Forwarded-Proto \$incudal_forwarded_proto;
1250:         proxy_read_timeout 300s;
1251:         proxy_send_timeout 300s;
1252:     }
1253: 
1254:     location / {
1255:         try_files \$uri \$uri/ /index.html;
1256:     }
1257: }
1258: NGINX
1259: }
