--- a/deploy/incudal-backend.service.example
+++ b/deploy/incudal-backend.service.example
@@ -13,6 +13,7 @@
 Environment=HOME=/opt/incudal
 Environment=NPM_CONFIG_CACHE=/opt/incudal/.npm
 Environment=XDG_CACHE_HOME=/opt/incudal/.cache
+Environment=PATH=/usr/local/libexec/incudal:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
 
 ExecStartPre=/usr/bin/bash -lc 'cd /opt/incudal/current/server && pnpm exec prisma migrate deploy'
 ExecStart=/usr/bin/node /opt/incudal/current/server/dist/app.js
