1261: resolve_static_dist_dir() {
1262:     local relative_dist="$1"
1263:     local current_dist="${INSTALL_DIR}/current/${relative_dist}"
1264:     local legacy_dist="${INSTALL_DIR}/${relative_dist}"
1265: 
1266:     if [[ -d "$current_dist" ]]; then
1267:         printf '%s\n' "$current_dist"
1268:         return 0
1269:     fi
1270: 
1271:     printf '%s\n' "$legacy_dist"
1272: }
