diff --git a/deploy/incudal-online-task.sh.example b/deploy/incudal-online-task.sh.example
new file mode 100644
index 0000000000000000000000000000000000000000..7ad14efc5e2df6d2326c4ff6cd3d896b4fd58d65
--- /dev/null
+++ b/deploy/incudal-online-task.sh.example
@@ -0,0 +1,168 @@
+#!/usr/bin/env bash
+set -Eeuo pipefail
+
+readonly INSTALL_DIR="/opt/incudal"
+readonly RUN_USER="incudal"
+readonly RUN_GROUP="incudal"
+readonly MANIFEST_DIR="${INSTALL_DIR}/.trusted-release-manifests"
+readonly ROOT_CACHE_DIR="/var/cache/incudal-ota"
+readonly SYSTEM_PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
+readonly OTA_PATH="${INSTALL_DIR}/libexec/incudal-ota:${SYSTEM_PATH}"
+
+fail() {
+  echo "incudal online task: $*" >&2
+  exit 1
+}
+
+resolve_app_dir() {
+  local app_dir="$INSTALL_DIR"
+  if [[ -L "${INSTALL_DIR}/current" ]]; then
+    app_dir="$(readlink -f -- "${INSTALL_DIR}/current")"
+    [[ "$app_dir" == "${INSTALL_DIR}/releases/"* ]] || fail "current points outside releases"
+  fi
+  [[ -d "$app_dir" ]] || fail "application directory is missing"
+  printf '%s\n' "$app_dir"
+}
+
+manifest_path() {
+  local app_dir="$1"
+  local key
+  key="$(printf '%s' "$app_dir" | sha256sum | awk '{print $1}')"
+  printf '%s/%s.sha256\n' "$MANIFEST_DIR" "$key"
+}
+
+static_files() {
+  find . -xdev -type f \
+    ! -path './.env' \
+    ! -path './server/certs/*' \
+    ! -path './update-logs/*' \
+    -print0 | sort -z
+}
+
+apply_secure_ownership() {
+  local app_dir
+  app_dir="$(resolve_app_dir)"
+
+  /usr/bin/chown root:root "$INSTALL_DIR"
+  /usr/bin/chmod 0751 "$INSTALL_DIR"
+  if [[ -e "${INSTALL_DIR}/current" || -L "${INSTALL_DIR}/current" ]]; then
+    /usr/bin/chown -h root:root "${INSTALL_DIR}/current"
+  fi
+  if [[ -d "${INSTALL_DIR}/releases" ]]; then
+    /usr/bin/chown -R root:root "${INSTALL_DIR}/releases"
+    find "${INSTALL_DIR}/releases" -xdev -type d -exec /usr/bin/chmod u=rwx,go=rx {} +
+    find "${INSTALL_DIR}/releases" -xdev -type f -exec /usr/bin/chmod u+rw,go+r,go-w {} +
+  else
+    /usr/bin/chown -R root:root "$app_dir"
+    find "$app_dir" -xdev -type d -exec /usr/bin/chmod u=rwx,go=rx {} +
+    find "$app_dir" -xdev -type f -exec /usr/bin/chmod u+rw,go+r,go-w {} +
+  fi
+
+  local mutable
+  for mutable in \
+    .npm .cache .incudal-update-downloads update-logs \
+    plugins plugin-data plugin-logs plugin-staging \
+    themes theme-data theme-staging agent-release; do
+    if [[ -e "${INSTALL_DIR}/${mutable}" ]]; then
+      /usr/bin/chown -R "${RUN_USER}:${RUN_GROUP}" "${INSTALL_DIR}/${mutable}"
+      find "${INSTALL_DIR}/${mutable}" -xdev -type d -exec /usr/bin/chmod u=rwx,go= {} +
+      find "${INSTALL_DIR}/${mutable}" -xdev -type f -exec /usr/bin/chmod u+rw,go-rwx {} +
+    fi
+  done
+
+  if [[ -f "${INSTALL_DIR}/.env" ]]; then
+    /usr/bin/chown root:"${RUN_GROUP}" "${INSTALL_DIR}/.env"
+    /usr/bin/chmod 0640 "${INSTALL_DIR}/.env"
+  fi
+  if [[ -d "${app_dir}/server/certs" ]]; then
+    /usr/bin/chown -R "${RUN_USER}:${RUN_GROUP}" "${app_dir}/server/certs"
+    find "${app_dir}/server/certs" -xdev -type d -exec /usr/bin/chmod 0700 {} +
+    find "${app_dir}/server/certs" -xdev -type f -exec /usr/bin/chmod 0600 {} +
+  fi
+
+  /usr/bin/install -d -o root -g root -m 0755 "$MANIFEST_DIR" "$ROOT_CACHE_DIR"
+  /usr/bin/chown -R root:root "${INSTALL_DIR}/bin" "${INSTALL_DIR}/libexec" 2>/dev/null || true
+  /usr/bin/chmod 0755 \
+    "${INSTALL_DIR}/bin/incudal-online-task" \
+    "${INSTALL_DIR}/bin/systemctl" \
+    "${INSTALL_DIR}/libexec/incudal-ota/chown"
+}
+
+write_manifest() {
+  local app_dir manifest tmp
+  app_dir="$(resolve_app_dir)"
+  manifest="$(manifest_path "$app_dir")"
+  tmp="$(mktemp "${MANIFEST_DIR}/.manifest.XXXXXX")"
+  (cd "$app_dir" && static_files | xargs -0 -r sha256sum) > "$tmp"
+  /usr/bin/chown root:root "$tmp"
+  /usr/bin/chmod 0644 "$tmp"
+  /usr/bin/mv -f "$tmp" "$manifest"
+}
+
+verify_manifest() {
+  local app_dir manifest
+  app_dir="$(resolve_app_dir)"
+  manifest="$(manifest_path "$app_dir")"
+  [[ -f "$manifest" && ! -L "$manifest" ]] || fail "trusted manifest is missing"
+  [[ "$(stat -c '%u:%g' "$manifest")" == "0:0" ]] || fail "trusted manifest is not root-owned"
+  if find "$manifest" -perm /022 -print -quit | grep -q .; then
+    fail "trusted manifest is writable by group/other"
+  fi
+  (cd "$app_dir" && sha256sum --check --strict --quiet "$manifest") || fail "release integrity verification failed"
+}
+
+seal_release() {
+  apply_secure_ownership
+  write_manifest
+}
+
+run_task() {
+  local mode="$1"
+  local task_id="$2"
+  [[ "$task_id" =~ ^[1-9][0-9]*$ ]] || fail "task id must be a positive integer"
+
+  apply_secure_ownership
+  verify_manifest
+
+  local app_dir script
+  app_dir="$(resolve_app_dir)"
+  case "$mode" in
+    update) script="server/dist/scripts/run-system-update-task.js" ;;
+    rollback) script="server/dist/scripts/rollback-system-update-task.js" ;;
+    *) fail "unsupported mode" ;;
+  esac
+  [[ -f "${app_dir}/${script}" && ! -L "${app_dir}/${script}" ]] || fail "worker entry is missing or is a symlink"
+
+  set +e
+  env \
+    PATH="$OTA_PATH" \
+    HOME="$ROOT_CACHE_DIR" \
+    NPM_CONFIG_CACHE="${ROOT_CACHE_DIR}/npm" \
+    XDG_CACHE_HOME="${ROOT_CACHE_DIR}/xdg" \
+    INCUDAL_APP_DIR="$app_dir" \
+    INSTALL_DIR="$INSTALL_DIR" \
+    SERVICE_NAME="incudal-backend" \
+    /usr/bin/node "${app_dir}/${script}" "$task_id"
+  local status=$?
+  set -e
+
+  apply_secure_ownership
+  if [[ "$status" -eq 0 ]]; then
+    write_manifest
+  fi
+  return "$status"
+}
+
+case "${1:-}" in
+  seal)
+    [[ "$#" -eq 1 ]] || fail "seal accepts no arguments"
+    seal_release
+    ;;
+  update|rollback)
+    [[ "$#" -eq 2 ]] || fail "task mode requires exactly one task id"
+    run_task "$1" "$2"
+    ;;
+  *)
+    fail "usage: incudal-online-task {seal|update TASK_ID|rollback TASK_ID}"
+    ;;
+esac
diff --git a/deploy/incudal-online-update@.service.example b/deploy/incudal-online-update@.service.example
index 3e39aed2626dfd050683c9f43d140eea1719b18a..d7ed4b7163255bf408d2c360b780cb41ef18436d
--- a/deploy/incudal-online-update@.service.example
+++ b/deploy/incudal-online-update@.service.example
@@ -8,16 +8,11 @@
 Type=oneshot
 User=root
 Group=root
-WorkingDirectory=/opt/incudal/current
+WorkingDirectory=/opt/incudal
 EnvironmentFile=/opt/incudal/.env
-Environment=HOME=/opt/incudal
+Environment=HOME=/var/cache/incudal-ota
 Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
-Environment=NPM_CONFIG_CACHE=/opt/incudal/.npm
-Environment=XDG_CACHE_HOME=/opt/incudal/.cache
-Environment=INCUDAL_APP_DIR=/opt/incudal/current
-Environment=INSTALL_DIR=/opt/incudal
-Environment=SERVICE_NAME=incudal-backend
-ExecStart=/usr/bin/node /opt/incudal/current/server/dist/scripts/run-system-update-task.js %i
+ExecStart=/opt/incudal/bin/incudal-online-task update %i
 TimeoutStartSec=1800
 StandardOutput=journal
 StandardError=journal
diff --git a/deploy/incudal-ota-chown-wrapper.sh.example b/deploy/incudal-ota-chown-wrapper.sh.example
new file mode 100644
index 0000000000000000000000000000000000000000..e83b0346ac7075a97dadd4031ef3ed31f30a7e63
--- /dev/null
+++ b/deploy/incudal-ota-chown-wrapper.sh.example
@@ -0,0 +1,12 @@
+#!/usr/bin/env bash
+set -Eeuo pipefail
+
+# The existing OTA workers call exactly this recursive chown.  Running them
+# with this root-owned PATH shim preserves their control flow while preventing
+# releases/current from becoming writable by the service account again.
+if [[ "$#" -ne 3 || "$1" != "-R" || "$2" != "incudal:incudal" || "$3" != "/opt/incudal" ]]; then
+  echo "incudal OTA chown wrapper: unsupported arguments" >&2
+  exit 64
+fi
+
+exec /opt/incudal/bin/incudal-online-task seal
diff --git a/deploy/incudal-systemctl-wrapper.sh.example b/deploy/incudal-systemctl-wrapper.sh.example
new file mode 100644
index 0000000000000000000000000000000000000000..0546fa15137320c9e254ae6bdd07e2968b52d2b8
--- /dev/null
+++ b/deploy/incudal-systemctl-wrapper.sh.example
@@ -0,0 +1,18 @@
+#!/usr/bin/env bash
+set -Eeuo pipefail
+
+# This file must be installed as /opt/incudal/bin/systemctl, owned by root:root
+# and mode 0755.  It is intentionally the only systemctl command reachable via
+# the incudal sudoers rule.
+if [[ "$#" -ne 3 || "$1" != "start" || "$2" != "--no-block" ]]; then
+  echo "incudal systemctl wrapper: unsupported arguments" >&2
+  exit 64
+fi
+
+readonly UNIT_NAME="$3"
+if [[ ! "$UNIT_NAME" =~ ^incudal-online-(update|rollback)@[1-9][0-9]*\.service$ ]]; then
+  echo "incudal systemctl wrapper: invalid unit name" >&2
+  exit 64
+fi
+
+exec /usr/bin/systemctl start --no-block "$UNIT_NAME"
