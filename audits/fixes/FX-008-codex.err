--- a/scripts/install-panel.sh
+++ b/scripts/install-panel.sh
@@ -238,8 +238,10 @@
         set_env_if_missing "PAYMENT_CALLBACK_BASE_URL" "$frontend_url" "支付回调公网地址"
     fi
 
-    chmod 600 "$ENV_FILE"
