1033: # ========================== 创建 systemd 服务 ==========================
1034: create_service() {
1035:     step "创建 systemd 服务..."
1036: 
1037:     local app_dir="${INSTALL_DIR}"
1038:     if [[ -L "${INSTALL_DIR}/current" ]]; then
1039:         app_dir="${INSTALL_DIR}/current"
1040:     fi
1041: 
1042:     cat > "$SERVICE_FILE" << EOF
1043: [Unit]
1044: Description=PayIncus 容器虚拟化管理平台
1045: Documentation=https://github.com/${GITHUB_REPO}
1046: After=network.target postgresql.service redis-server.service
1047: Requires=postgresql.service redis-server.service
1048: 
1049: [Service]
1050: Type=simple
1051: User=${RUN_USER}
1052: Group=${RUN_USER}
1053: WorkingDirectory=${app_dir}
1054: EnvironmentFile=${ENV_FILE}
1055: 
1056: # 确保 npm 缓存目录可写
1057: Environment=HOME=${INSTALL_DIR}
1058: Environment=NPM_CONFIG_CACHE=${INSTALL_DIR}/.npm
1059: Environment=XDG_CACHE_HOME=${INSTALL_DIR}/.cache
1060: 
1061: # 启动前自动执行数据库迁移
1062: ExecStartPre=/usr/bin/bash -c 'cd ${app_dir}/server && pnpm exec prisma migrate deploy'
1063: 
1064: # 启动主程序
1065: ExecStart=/usr/bin/node ${app_dir}/server/dist/app.js
1066: 
1067: # 优雅关闭
1068: KillMode=mixed
1069: KillSignal=SIGTERM
1070: TimeoutStopSec=30
1071: 
1072: # 自动重启
1073: Restart=on-failure
1074: RestartSec=10
1075: StartLimitBurst=5
1076: StartLimitIntervalSec=300
1077: 
1078: # 安全加固
1079: # 后台在线更新需要通过受限 sudoers 启动 root-owned systemd oneshot 单元。
1080: # 如果启用 NoNewPrivileges，sudo 会被内核直接拒绝。
1081: NoNewPrivileges=false
1082: ProtectSystem=strict
1083: ProtectHome=true
1084: ReadWritePaths=${INSTALL_DIR} ${INSTALL_DIR}/current ${INSTALL_DIR}/releases ${INSTALL_DIR}/server/certs ${INSTALL_DIR}/plugins ${INSTALL_DIR}/plugin-data ${INSTALL_DIR}/plugin-logs ${INSTALL_DIR}/plugin-staging ${INSTALL_DIR}/themes ${INSTALL_DIR}/theme-data ${INSTALL_DIR}/theme-staging ${INSTALL_DIR}/.npm ${INSTALL_DIR}/.cache ${INSTALL_DIR}/.git ${INSTALL_DIR}/update-logs
1085: PrivateTmp=true
1086: 
1087: # 资源限制
1088: LimitNOFILE=65536
1089: 
1090: # 日志
1091: StandardOutput=journal
1092: StandardError=journal
1093: SyslogIdentifier=${SERVICE_NAME}
1094: 
1095: [Install]
1096: WantedBy=multi-user.target
1097: EOF
1098: 
1099:     systemctl daemon-reload
1100:     systemctl enable "$SERVICE_NAME" >/dev/null 2>&1
1101: 
1102:     log "systemd 服务创建完成"
1103: }
1104: 
