 492: async function copyIfExists(from: string, to: string): Promise<void> {
 493:   if (existsSync(from)) {
 494:     await rm(to, { recursive: true, force: true })
 495:     await mkdir(dirname(to), { recursive: true })
 496:     await cp(from, to, { recursive: true, preserveTimestamps: true })
 497:   }
 498: }
