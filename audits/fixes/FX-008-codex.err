 441: # ========================== 手动包目录 ==========================
 442: readonly MANUAL_PKG_DIR="/tmp/incudal"
 443: 
 444: # ========================== 获取最新版本号（快速尝试） ==========================
 445: get_latest_version() {
 446:     local api_url="https://api.github.com/repos/${GITHUB_REPO}/releases/latest"
 447:     local response=""
 448:     local version=""
 449: 
 450:     # 5 秒超时速查，不阻塞
 451:     response=$(curl -sL --connect-timeout 5 --max-time 8 "$api_url" 2>/dev/null) || true
 452: 
 453:     if [[ -n "$response" ]]; then
 454:         version=$(echo "$response" | grep '"tag_name"' | sed -E 's/.*"tag_name": *"([^"]+)".*/\1/' || true)
 455:     fi
 456: 
 457:     echo "$version"
 458: }
 459: 
 460: # ========================== 自动下载产物包 ==========================
 461: download_release() {
 462:     local version="$1"
 463:     local filename="incudal-${version}-linux-${ARCH}.tar.gz"
 464:     local download_url="https://github.com/${GITHUB_REPO}/releases/download/${version}/${filename}"
 465:     local tmp_file="/tmp/${filename}"
 466:     local checksum_url="${download_url}.sha256"
 467:     local checksum_file="${tmp_file}.sha256"
 468: 
 469:     info "下载地址: ${download_url}"
 470: 
 471:     if curl -fSL --progress-bar --connect-timeout 15 --max-time 600 \
 472:         "$download_url" -o "$tmp_file" 2>/dev/null && \
 473:         curl -fsSL --connect-timeout 15 --max-time 60 \
 474:         "$checksum_url" -o "$checksum_file" 2>/dev/null && \
 475:         verify_release_checksum "$tmp_file"; then
 476:         local file_size
 477:         file_size=$(du -h "$tmp_file" | cut -f1 || true)
 478:         log "下载和 SHA256 校验完成 (${file_size})"
 479:         echo "$tmp_file"
 480:         return 0
 481:     fi
 482: 
 483:     rm -f "$tmp_file" "$checksum_file" 2>/dev/null || true
 484:     return 1
 485: }
 486: 
 487: verify_release_checksum() {
 488:     local tar_file="$1"
 489:     local checksum_file="${tar_file}.sha256"
 490:     local expected=""
 491:     local actual=""
 492: 
 493:     if [[ ! -f "$checksum_file" ]]; then
 494:         error "缺少校验文件: ${checksum_file}"
 495:         error "请从同一 GitHub Release 下载对应的 .sha256 文件"
 496:         return 1
 497:     fi
 498: 
 499:     expected=$(grep -Eo '^[A-Fa-f0-9]{64}' "$checksum_file" | head -n1 || true)
 500:     if [[ ! "$expected" =~ ^[A-Fa-f0-9]{64}$ ]]; then
 501:         error "SHA256 文件格式无效: ${checksum_file}"
 502:         return 1
 503:     fi
 504: 
 505:     actual=$(sha256sum "$tar_file" | awk '{print $1}')
 506:     if [[ "${actual,,}" != "${expected,,}" ]]; then
 507:         error "产物包 SHA256 校验失败: $(basename "$tar_file")"
 508:         return 1
 509:     fi
 510: 
 511:     return 0
 512: }
 513: 
 514: validate_release_archive() {
 515:     local tar_file="$1"
 516:     local entry=""
 517: 
 518:     if ! tar -tzf "$tar_file" >/dev/null 2>&1; then
 519:         error "产物包不是有效的 tar.gz 文件: ${tar_file}"
 520:         return 1
 521:     fi
 522: 
 523:     while IFS= read -r entry; do
 524:         entry="${entry#./}"
 525:         if [[ "$entry" == /* || "$entry" == ".." || "$entry" == ../* || "$entry" == */../* || "$entry" == */.. ]]; then
 526:             error "产物包包含不安全路径: ${entry}"
 527:             return 1
 528:         fi
 529:     done < <(tar -tzf "$tar_file")
 530: 
 531:     return 0
 532: }
 533: 
 534: # ========================== 扫描手动放置的产物包 ==========================
 535: scan_manual_package() {
 536:     local found=""
 537: 
 538:     if [[ ! -d "$MANUAL_PKG_DIR" ]]; then
 539:         return 1
 540:     fi
 541: 
 542:     # 优先匹配当前架构的包
 543:     found=$(find "$MANUAL_PKG_DIR" -maxdepth 1 -name "incudal-*-linux-${ARCH}.tar.gz" -type f 2>/dev/null | head -n1 || true)
 544: 
 545:     # 退而匹配任意 incudal tar.gz
 546:     if [[ -z "$found" ]]; then
 547:         found=$(find "$MANUAL_PKG_DIR" -maxdepth 1 -name "incudal-*.tar.gz" -type f 2>/dev/null | head -n1 || true)
 548:     fi
 549: 
 550:     if [[ -n "$found" ]]; then
 551:         echo "$found"
 552:         return 0
 553:     fi
 554: 
 555:     return 1
 556: }
 557: 
 558: # ========================== 等待用户放置产物包 ==========================
 559: wait_for_manual_package() {
 560:     echo "" >&2
 561:     divider
 562:     echo -e "  ${YELLOW}${BOLD}⚠ 自动获取产物包失败${NC}" >&2
 563:     echo -e "  ${DIM}（仓库可能是私有的，或网络无法连接 GitHub）${NC}" >&2
 564:     divider
 565:     echo "" >&2
 566:     echo -e "  ${BOLD}请手动下载产物包并放到以下目录：${NC}" >&2
 567:     echo "" >&2
 568:     echo -e "  ${CYAN}${BOLD}${MANUAL_PKG_DIR}/${NC}" >&2
 569:     echo "" >&2
 570:     echo -e "  ${BOLD}下载地址：${NC}" >&2
 571:     echo -e "  ${CYAN}https://github.com/${GITHUB_REPO}/releases${NC}" >&2
 572:     echo "" >&2
 573:     echo -e "  ${BOLD}所需文件名格式：${NC}" >&2
 574:     echo -e "  ${GREEN}incudal-vX.Y.Z-linux-${ARCH}.tar.gz${NC}" >&2
 575:     echo -e "  ${GREEN}incudal-vX.Y.Z-linux-${ARCH}.tar.gz.sha256${NC}" >&2
 576:     echo "" >&2
 577:     echo -e "  ${DIM}提示: 可使用 scp、wget、rz 等方式将文件传到服务器${NC}" >&2
 578:     echo -e "  ${DIM}例如: scp incudal-v1.0.0-linux-${ARCH}.tar.gz root@服务器IP:${MANUAL_PKG_DIR}/${NC}" >&2
 579:     divider
 580:     echo "" >&2
 581: 
 582:     # 创建目录
 583:     mkdir -p "$MANUAL_PKG_DIR"
 584: 
 585:     # 轮询等待文件出现
 586:     local wait_count=0
 587:     local max_wait=600  # 最多等 10 分钟（含上传时间）
 588:     local spin_chars='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
 589:     local MIN_SIZE_KB=10240  # 产物包至少 10MB
 590: 
 591:     while true; do
 592:         # 尝试扫描
 593:         local pkg_file=""
 594:         pkg_file=$(scan_manual_package) || true
 595: 
 596:         if [[ -n "$pkg_file" ]]; then
 597:             # 检测到文件，等待上传完成（文件大小稳定）
 598:             echo "" >&2
 599:             info "检测到文件: $(basename "$pkg_file")"
 600:             info "等待上传完成..."
 601: 
 602:             local stable_count=0
 603:             local last_size=0
 604: 
 605:             while true; do
 606:                 local current_size
 607:                 current_size=$(stat -c%s "$pkg_file" 2>/dev/null || echo "0")
 608:                 local current_size_human
 609:                 current_size_human=$(du -h "$pkg_file" 2>/dev/null | cut -f1 || echo "?")
 610: 
 611:                 if [[ "$current_size" -eq "$last_size" && "$current_size" -gt 0 ]]; then
 612:                     stable_count=$((stable_count + 1))
 613:                 else
 614:                     stable_count=0
 615:                     last_size="$current_size"
 616:                 fi
 617: 
 618:                 # 连续 3 次（9 秒）大小不变，认为上传完成
 619:                 if [[ $stable_count -ge 3 ]]; then
 620:                     if [[ ! -f "${pkg_file}.sha256" ]]; then
 621:                         info "已收到产物包，继续等待对应的 $(basename "${pkg_file}.sha256")..."
 622:                         stable_count=0
 623:                         sleep 3
 624:                         continue
 625:                     fi
 626: 
 627:                     # 检查最小文件大小
 628:                     local size_kb=$((current_size / 1024))
 629:                     if [[ $size_kb -lt $MIN_SIZE_KB ]]; then
 630:                         warn "文件过小 (${current_size_human})，产物包通常 >100MB，可能不完整"
 631:                         warn "如确认无误，请将文件删除后重新放置"
 632:                         # 继续等待
 633:                         stable_count=0
 634:                         last_size=0
 635:                         sleep 3
 636:                         continue
 637:                     fi
 638: 
 639:                     log "上传完成！文件大小: ${current_size_human}"
 640:                     echo "$pkg_file"
 641:                     return 0
 642:                 fi
 643: 
 644:                 printf "\r  ${CYAN}⏳${NC} 上传中... 当前大小: ${current_size_human}  " >&2
 645:                 sleep 3
 646:                 wait_count=$((wait_count + 3))
 647: 
 648:                 if [[ $wait_count -ge $max_wait ]]; then
 649:                     echo "" >&2
 650:                     error "等待超时 (${max_wait}s)，请重新运行脚本"
 651:                     return 1
 652:                 fi
 653:             done
 654:         fi
 655: 
 656:         # 显示等待动画（输出到 stderr）
 657:         local spin_idx=$((wait_count % ${#spin_chars}))
 658:         local spin_char="${spin_chars:$spin_idx:1}"
 659:         printf "\r  ${CYAN}${spin_char}${NC} 等待产物包... (已等待 %ds，输入 Ctrl+C 取消)  " "$wait_count" >&2
 660: 
 661:         sleep 2
 662:         wait_count=$((wait_count + 2))
 663: 
 664:         if [[ $wait_count -ge $max_wait ]]; then
 665:             echo "" >&2
 666:             error "等待超时 (${max_wait}s)，请重新运行脚本"
 667:             return 1
 668:         fi
 669:     done
 670: }
 671: 
 672: # ========================== 统一入口：获取产物包 ==========================
 673: obtain_release() {
 674:     step "获取 PayIncus 产物包..."
 675: 
 676:     # ---- 阶段 0：检查是否已有手动放置的包 ----
 677:     local existing_pkg=""
 678:     existing_pkg=$(scan_manual_package) || true
 679:     if [[ -n "$existing_pkg" ]]; then
 680:         log "检测到手动放置的产物包: $(basename "$existing_pkg")"
 681:         echo "$existing_pkg"
 682:         return 0
 683:     fi
 684: 
 685:     # ---- 阶段 1：尝试 API 自动获取版本号 ----
 686:     info "正在查询最新版本（5 秒超时）..."
 687:     local version=""
 688:     version=$(get_latest_version)
 689: 
 690:     if [[ -n "$version" ]]; then
 691:         info "最新版本: ${version}"
 692: 
 693:         # ---- 阶段 2：尝试自动下载 ----
 694:         local tar_file=""
 695:         tar_file=$(download_release "$version") || true
 696: 
 697:         if [[ -n "$tar_file" && -f "$tar_file" ]]; then
 698:             echo "$tar_file"
 699:             return 0
 700:         fi
 701: 
 702:         warn "自动下载失败（文件可能不存在或网络受限）"
 703:     else
 704:         warn "自动获取版本号失败（仓库可能是私有的）"
 705:     fi
 706: 
 707:     # ---- 阶段 3：引导用户手动放置包 ----
 708:     local manual_file=""
 709:     manual_file=$(wait_for_manual_package) || return 1
 710:     echo "$manual_file"
 711:     return 0
 712: }
 713: 
 714: # ========================== 解压安装 ==========================
 715: install_release() {
 716:     local tar_file="$1"
 717:     local is_upgrade="${2:-false}"
 718: 
 719:     step "安装产物包..."
 720: 
 721:     verify_release_checksum "$tar_file" || return 1
 722:     validate_release_archive "$tar_file" || return 1
 723: 
 724:     # 创建安装目录
 725:     mkdir -p "$INSTALL_DIR"
 726: 
 727:     if [[ "$is_upgrade" == "true" ]]; then
 728:         # 升级模式：先备份当前版本
 729:         info "备份当前版本..."
 730:         local backup_dir="${INSTALL_DIR}.bak.$(date +%Y%m%d%H%M%S)"
 731:         cp -r "$INSTALL_DIR" "$backup_dir"
 732:         info "备份已保存到: ${backup_dir}"
 733: 
 734:         # 保留 .env 文件和证书目录
 735:         local env_backup=""
 736:         local certs_backup=""
 737:         if [[ -f "${INSTALL_DIR}/.env" ]]; then
 738:             env_backup=$(mktemp)
 739:             cp "${INSTALL_DIR}/.env" "$env_backup"
 740:         fi
 741:         if [[ -d "${INSTALL_DIR}/server/certs" ]]; then
 742:             certs_backup=$(mktemp -d)
 743:             cp -r "${INSTALL_DIR}/server/certs" "$certs_backup/"
 744:         fi
 745: 
 746:         # 清理旧文件（保留 .env 和 certs）
 747:         rm -rf "${INSTALL_DIR}/client" "${INSTALL_DIR}/server/dist" "${INSTALL_DIR}/server/node_modules"
 748: 
 749:         # 解压新版本
 750:         tar -xzf "$tar_file" -C "$INSTALL_DIR" --strip-components=0
 751: 
 752:         # 恢复 .env 和证书
 753:         if [[ -n "$env_backup" && -f "$env_backup" ]]; then
 754:             cp "$env_backup" "${INSTALL_DIR}/.env"
 755:             rm -f "$env_backup"
 756:         fi
 757:         if [[ -n "$certs_backup" && -d "$certs_backup/certs" ]]; then
 758:             mkdir -p "${INSTALL_DIR}/server/certs"
 759:             cp -r "$certs_backup/certs/"* "${INSTALL_DIR}/server/certs/" 2>/dev/null || true
 760:             rm -rf "$certs_backup"
 761:         fi
 762:     else
 763:         # 全新安装
 764:         tar -xzf "$tar_file" -C "$INSTALL_DIR" --strip-components=0
 765:     fi
 766: 
 767:     # 清理下载的临时文件
 768:     rm -f "$tar_file" "${tar_file}.sha256"
 769: 
 770:     # 创建证书目录
 771:     mkdir -p "${INSTALL_DIR}/server/certs"
 772: 
 773:     log "产物包安装完成"
 774: }
