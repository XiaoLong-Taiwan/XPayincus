 527: async function writeVersionFile(root = appDir): Promise<void> {
 528:   const version = await getCurrentVersionMetadata(root)
 529:   const payload = {
 530:     ...version,
 531:     deployedAt: now()
 532:   }
 533:   await writeFile(join(root, 'version.json'), `${JSON.stringify(payload, null, 2)}\n`)
 534: }
