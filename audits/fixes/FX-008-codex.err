+    if [[ "$RELEASE_VERIFIED_THIS_RUN" != "true" ]]; then
+        error "本次运行未验证并安装 Release 产物，拒绝为既有目录建立可信清单"
+        error "既有机器请由 owner 按 audits/fixes/FX-008-owner-steps.md 从已验证产物迁移"
+        return 1
+    fi
 
     cat > "$SERVICE_FILE" << EOF
 [Unit]
@@ -1057,6 +1069,7 @@
