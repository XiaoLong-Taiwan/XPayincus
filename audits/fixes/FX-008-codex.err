 536: async function updateTask(data: Parameters<typeof prisma.systemUpdateTask.update>[0]['data']): Promise<void> {
 537:   await prisma.systemUpdateTask.update({
 538:     where: { id: taskId },
 539:     data
 540:   })
 541: }
