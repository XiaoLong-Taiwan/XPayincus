   1: #!/usr/bin/env bash
   2: # ============================================================================
   3: # PayIncus 面板一键部署脚本（产物包模式）
   4: #
   5: # 功能：
   6: #   - 安装 Node.js 22、PostgreSQL 16 和系统仓库提供的 Redis
   7: #   - 从 GitHub Releases 下载预构建产物包
   8: #   - 自动配置数据库、环境变量、systemd 服务
   9: #   - 支持 Nginx+Certbot / Cloudflare Tunnel / 纯端口 三种外部访问方案
  10: #   - 支持升级已有安装
  11: #
  12: # 用法：
  13: #   安装：  sudo bash install-panel.sh
  14: #   升级：  sudo bash install-panel.sh --upgrade
  15: #   卸载：  sudo bash install-panel.sh --uninstall
  16: #
  17: # 项目地址: https://github.com/XiaoLong-Taiwan/payincus
  18: # ============================================================================
  19: set -euo pipefail
  20: 
  21: # ========================== 全局常量 ==========================
  22: readonly SCRIPT_VERSION="3.0.0"
  23: readonly GITHUB_REPO="XiaoLong-Taiwan/payincus"
  24: readonly INSTALL_DIR="/opt/incudal"
  25: readonly SERVICE_NAME="incudal-backend"
  26: readonly SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}.service"
  27: readonly ENV_FILE="${INSTALL_DIR}/.env"
  28: readonly RUN_USER="incudal"
  29: readonly DEFAULT_PORT=3001
  30: readonly NODE_MAJOR=22
  31: readonly PNPM_VERSION="9.14.2"
  32: readonly PG_VERSION=16
  33: 
  34: # ========================== 颜色定义 ==========================
  35: readonly RED='\033[1;31m'
  36: readonly GREEN='\033[1;32m'
  37: readonly YELLOW='\033[1;33m'
  38: readonly CYAN='\033[1;36m'
  39: readonly BOLD='\033[1m'
  40: readonly DIM='\033[2m'
  41: readonly NC='\033[0m'
  42: 
  43: # ========================== 工具函数 ==========================
  44: # 所有日志输出到 stderr，避免在 $() 子 shell 中被捕获
  45: log()   { echo -e "${GREEN}[✓]${NC} $1" >&2; }
  46: info()  { echo -e "${CYAN}[i]${NC} $1" >&2; }
  47: warn()  { echo -e "${YELLOW}[!]${NC} $1" >&2; }
  48: error() { echo -e "${RED}[✗]${NC} $1" >&2; }
  49: step()  { echo -e "\n${CYAN}[▶]${NC} ${BOLD}$1${NC}" >&2; }
  50: 
  51: divider() {
  52:     echo -e "${DIM}────────────────────────────────────────────────────${NC}" >&2
  53: }
  54: 
  55: # 生成随机密码
  56: gen_password() {
  57:     openssl rand -hex 64 | cut -c "1-${1:-24}"
  58: }
  59: 
  60: gen_secret() {
  61:     printf 'A1!%s' "$(openssl rand -hex 64)" | cut -c "1-${1:-48}"
  62: }
  63: 
  64: is_valid_email() {
  65:     local email="$1"
  66:     [[ "$email" =~ ^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$ ]]
  67: }
  68: 
  69: prompt_initial_admin_email() {
  70:     local default_email="${ADMIN_EMAIL:-admin@payincus.local}"
  71:     local input
  72: 
  73:     if [[ -f "$ENV_FILE" ]]; then
  74:         local existing_email
  75:         existing_email="$(get_env_value "ADMIN_EMAIL")"
  76:         if [[ -n "$existing_email" ]]; then
  77:             printf '%s' "$existing_email"
  78:             return 0
  79:         fi
  80:     fi
  81: 
  82:     echo -ne "  ${BOLD}请输入初始管理员邮箱 [${default_email}]: ${NC}" >&2
  83:     read -r input
  84:     input="${input:-$default_email}"
  85: 
  86:     if ! is_valid_email "$input"; then
  87:         error "管理员邮箱格式不正确: ${input}"
  88:         exit 1
  89:     fi
  90: 
  91:     printf '%s' "$input"
  92: }
  93: 
  94: get_env_value() {
  95:     local key="$1"
  96:     if [[ ! -f "$ENV_FILE" ]]; then
  97:         return 0
  98:     fi
  99:     grep -E "^${key}=" "$ENV_FILE" 2>/dev/null | tail -n 1 | cut -d'=' -f2- || true
 100: }
 101: 
 102: set_env_if_missing() {
 103:     local key="$1"
 104:     local value="$2"
 105:     local label="$3"
 106:     local current
 107:     current="$(get_env_value "$key")"
 108: 
 109:     if [[ -n "$current" ]]; then
 110:         return 0
 111:     fi
 112: 
 113:     if grep -qE "^${key}=" "$ENV_FILE" 2>/dev/null; then
 114:         local tmp_file
 115:         tmp_file="$(mktemp)"
 116:         awk -v key="$key" -v value="$value" '
 117:             BEGIN { replaced = 0 }
 118:             $0 ~ "^" key "=" && replaced == 0 {
 119:                 print key "=" value
 120:                 replaced = 1
 121:                 next
 122:             }
 123:             { print }
 124:         ' "$ENV_FILE" > "$tmp_file"
 125:         cat "$tmp_file" > "$ENV_FILE"
 126:         rm -f "$tmp_file"
 127:     else
 128:         printf '\n%s=%s\n' "$key" "$value" >> "$ENV_FILE"
 129:     fi
 130: 
 131:     log "已自动补充 ${label}: ${key}"
 132: }
 133: 
 134: set_env_value() {
 135:     local key="$1"
 136:     local value="$2"
 137:     local label="$3"
 138: 
 139:     if grep -qE "^${key}=" "$ENV_FILE" 2>/dev/null; then
 140:         local tmp_file
 141:         tmp_file="$(mktemp)"
 142:         awk -v key="$key" -v value="$value" '
 143:             BEGIN { replaced = 0 }
 144:             $0 ~ "^" key "=" && replaced == 0 {
 145:                 print key "=" value
 146:                 replaced = 1
 147:                 next
 148:             }
 149:             { print }
 150:         ' "$ENV_FILE" > "$tmp_file"
 151:         cat "$tmp_file" > "$ENV_FILE"
 152:         rm -f "$tmp_file"
 153:     else
 154:         printf '\n%s=%s\n' "$key" "$value" >> "$ENV_FILE"
 155:     fi
 156: 
 157:     log "已更新 ${label}: ${key}"
 158: }
 159: 
 160: set_env_if_value() {
 161:     local key="$1"
 162:     local expected_current="$2"
 163:     local new_value="$3"
 164:     local label="$4"
 165:     local current
 166:     current="$(get_env_value "$key")"
 167: 
 168:     if [[ "$current" == "$expected_current" ]]; then
 169:         set_env_value "$key" "$new_value" "$label"
 170:     fi
 171: }
