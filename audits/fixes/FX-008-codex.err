 516: async function chownInstallDir(): Promise<void> {
 517:   if (process.platform !== 'linux') return
 518:   try {
 519:     await run('id', ['incudal'], { timeoutMs: 30000 })
 520:   } catch {
 521:     await log('Skipping ownership fix: user incudal does not exist')
 522:     return
 523:   }
 524:   await run('chown', ['-R', 'incudal:incudal', installDir], { timeoutMs: 120000 })
 525: }
