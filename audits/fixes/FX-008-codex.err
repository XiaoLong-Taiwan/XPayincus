1274: write_nginx_split_maps() {
1275:     cat <<'NGINX'
1276: map $http_x_forwarded_proto $incudal_forwarded_proto {
1277:     default $http_x_forwarded_proto;
1278:     "" $scheme;
1279: }
1280: 
1281: map $http_x_forwarded_host $incudal_forwarded_host {
1282:     default $http_x_forwarded_host;
1283:     "" $host;
1284: }
1285: 
1286: NGINX
1287: }
