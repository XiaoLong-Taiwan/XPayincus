 grep -Fq -- '-f "${INSTALL_DIR}/current/server/dist/app.js"' "$REPO_ROOT/scripts/install-panel.sh"
 grep -Fq '检测到原子 OTA 布局' "$REPO_ROOT/scripts/install-panel.sh"
