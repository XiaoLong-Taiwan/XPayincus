1185: # ========================== Nginx + Certbot ==========================
1186: write_nginx_split_server_block() {
1187:     local server_name="$1"
1188:     local root_dir="$2"
1189:     local default_server="${3:-}"
1190:     local listen_suffix=""
1191: 
1192:     if [[ "$default_server" == "default" ]]; then
