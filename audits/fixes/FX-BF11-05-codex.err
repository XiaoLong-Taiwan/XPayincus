  471: async function inspectAiReplySendLimits(ticketId: number, config: AiTicketAgentConfig): Promise<string[]> {
  472:   const blockedReasons: string[] = []
  473:   const ticketMarker = `ticket #${ticketId}`
  474:   const todayStart = new Date()
  475:   todayStart.setHours(0, 0, 0, 0)
  476: 
  477:   const [dailySuccessCount, ticketSuccessCount, latestTicketSuccess] = await Promise.all([
  478:     prisma.log.count({
  479:       where: {
  480:         module: LogModule.PLUGIN,
  481:         action: 'ai_ticket.reply_send',
  482:         result: LogResult.SUCCESS,
  483:         createdAt: { gte: todayStart }
  484:       }
  485:     }),
  486:     prisma.log.count({
  487:       where: {
  488:         module: LogModule.PLUGIN,
  489:         action: 'ai_ticket.reply_send',
  490:         result: LogResult.SUCCESS,
  491:         content: { contains: ticketMarker }
  492:       }
  493:     }),
  494:     prisma.log.findFirst({
  495:       where: {
  496:         module: LogModule.PLUGIN,
  497:         action: 'ai_ticket.reply_send',
  498:         result: LogResult.SUCCESS,
  499:         content: { contains: ticketMarker }
  500:       },
  501:       orderBy: { createdAt: 'desc' },
  502:       select: { createdAt: true }
  503:     })
  504:   ])
  505: 
  506:   if (config.dailyAutoReplyLimit > 0 && dailySuccessCount >= config.dailyAutoReplyLimit) {
  507:     blockedReasons.push('daily_auto_reply_limit_reached')
  508:   }
  509:   if (config.ticketAutoReplyLimit > 0 && ticketSuccessCount >= config.ticketAutoReplyLimit) {
  510:     blockedReasons.push('ticket_auto_reply_limit_reached')
  511:   }
  512:   if (
  513:     config.cooldownSeconds > 0 &&
  514:     latestTicketSuccess &&
  515:     latestTicketSuccess.createdAt.getTime() > Date.now() - (config.cooldownSeconds * 1000)
  516:   ) {
  517:     blockedReasons.push('ticket_auto_reply_cooldown_active')
  518:   }
  519: 
  520:   return blockedReasons
  521: }
