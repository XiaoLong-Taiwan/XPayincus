 1024: async function generateAiTicketReplyCandidate(ticketId: number): Promise<AiTicketReplyCandidate> {
 1025:   const config = await loadAiTicketAgentConfig()
 1026:   if (!config.enabled) {
 1027:     throw new Error('AI_TICKET_AGENT_DISABLED')
 1028:   }
 1029:   if (!config.apiBaseUrl || !config.apiKey) {
 1030:     throw new Error('AI_TICKET_AGENT_MODEL_NOT_CONFIGURED')
 1031:   }
 1032: 
 1033:   const context = await buildAiTicketContext(ticketId)
 1034:   if (!context) {
 1035:     throw new Error('TICKET_NOT_FOUND')
 1036:   }
 1037: 
 1038:   const decision = config.mode === 'draft'
 1039:     ? {
 1040:         draft: await requestAiTicketDraft(context, config),
 1041:         confidence: 1,
 1042:         handoffRequired: false,
 1043:         handoffReason: null
 1044:       }
 1045:     : await requestAiTicketDecision(context, config)
 1046:   const draft = decision.draft
 1047:   const safety = inspectAiDraftSafety(draft)
 1048:   const sendBlockedReasons = [
 1049:     ...inspectAiReplySendEligibility(context, config),
 1050:     ...(decision.handoffRequired ? [`model_handoff_required${decision.handoffReason ? `:${decision.handoffReason}` : ''}`] : []),
 1051:     ...(decision.confidence < config.confidenceThreshold ? ['confidence_below_threshold'] : []),
 1052:     ...(config.mode === 'draft' ? [] : await inspectAiReplySendLimits(ticketId, config))
 1053:   ]
 1054: 
 1055:   return {
 1056:     draft,
 1057:     model: config.model,
 1058:     safety,
 1059:     mode: config.mode,
 1060:     confidence: decision.confidence,
 1061:     confidenceThreshold: config.confidenceThreshold,
 1062:     canSend: (config.mode === 'semi_auto' || config.mode === 'auto') && sendBlockedReasons.length === 0,
 1063:     sendBlockedReasons
 1064:   }
 1065: }
 1066: 
 1067: export async function generateAiTicketDraft(ticketId: number): Promise<AiTicketDraftResult> {
 1068:   const config = await loadAiTicketAgentConfig()
 1069:   if (!config.enabled) {
 1070:     throw new Error('AI_TICKET_AGENT_DISABLED')
 1071:   }
 1072:   if (!config.apiBaseUrl || !config.apiKey) {
 1073:     throw new Error('AI_TICKET_AGENT_MODEL_NOT_CONFIGURED')
 1074:   }
 1075: 
 1076:   const context = await buildAiTicketContext(ticketId)
 1077:   if (!context) {
 1078:     throw new Error('TICKET_NOT_FOUND')
 1079:   }
 1080: 
 1081:   const draft = await requestAiTicketDraft(context, config)
 1082:   return {
 1083:     draft,
 1084:     model: config.model,
 1085:     safety: inspectAiDraftSafety(draft)
 1086:   }
 1087: }
 1088: 
 1089: export async function generateAiTicketReply(ticketId: number): Promise<AiTicketReplyCandidate> {
 1090:   return generateAiTicketReplyCandidate(ticketId)
 1090:   return generateAiTicketReplyCandidate(ticketId)
 1091: }

