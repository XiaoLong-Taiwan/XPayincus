68:async function requireVerifiedOperation(
69:    reply: FastifyReply,
70:    userId: number,
71:    resourceId: number
72:): Promise<boolean> {
73:    const verification = await claimOperationVerificationRequirement(userId, 'transfer_instance', resourceId)
74:    if (!verification.verified) {
75:        reply.code(403).send({
76:            error: 'Sensitive operation requires verification',
77:            code: 'VERIFICATION_REQUIRED',
78:            required: verification.required
79:        })
80:        return false
445:        }
446:    })
447:
448:    // 接受转移
449:    fastify.post<{ Params: { id: string } }>('/:id/accept', {
450:        onRequest: [fastify.authenticateUser]
451:    }, async (request: FastifyRequest<{ Params: { id: string } }>, reply: FastifyReply) => {
452:        const transferId = parsePositiveInteger(request.params.id)
453:        const { user } = request
454:
455:        if (transferId === null) {
456:            return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
457:        }
458:
459:        // ===== 并发安全：使用乐观锁，原子性地检查并更新状态 =====
460:        // 使用 updateMany 原子操作，只有 status='pending' 时才更新为 'processing'
461:        const lockResult = await prisma.instanceTransfer.updateMany({
462:            where: {
463:                id: transferId,
464:                status: 'pending',
465:                toUserId: user.id  // 同时验证权限
466:            },
467:            data: {
468:                status: 'processing'  // 临时锁定状态
469:            }
470:        })
471:
472:        // 如果没有更新任何记录，说明状态已变化或权限不足
473:        if (lockResult.count === 0) {
474:            // 需要区分是不存在、权限不足还是状态已变化
475:            const transfer = await db.getTransferById(transferId)
476:            if (!transfer) {
477:                return reply.code(404).send(apiError(ErrorCode.TRANSFER_NOT_FOUND))
478:            }
479:            if (transfer.toUserId !== user.id) {
480:                return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
481:            }
482:            // 状态已不是 pending（可能是 processing 或其他）
483:            return reply.code(400).send(apiError(ErrorCode.TRANSFER_NOT_PENDING))
484:        }
485:
486:        // 重新获取完整的转移信息
487:        const transfer = await db.getTransferById(transferId)
488:        if (!transfer) {
489:            return reply.code(404).send(apiError(ErrorCode.TRANSFER_NOT_FOUND))
490:        }
491:
492:        // ===== 失败时的回滚函数 =====
493:        const rollbackToPending = async () => {
494:            try {
495:                await prisma.instanceTransfer.update({
496:                    where: { id: transferId },
497:                    data: { status: 'pending' }
498:                })
499:            } catch (err) {
500:                console.error('[Transfer] Failed to rollback status:', err)
501:            }
502:        }
503:
504:        // 检查实例是否还存在
505:        const instance = await db.getInstanceById(transfer.instanceId)



