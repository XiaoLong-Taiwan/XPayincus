1829:export async function transferExchangeBalanceToUserBalance(input: TransferInput) {
1830:  const amount = normalizeMoney(input.amount, '划转金额')
1831:  const idempotencyKey = normalizeIdempotencyKey(input.idempotencyKey)
1832:  return prisma.$transaction(async tx => {
1833:    if (idempotencyKey) {
1834:      const existingLog = await tx.exchangeWalletLog.findUnique({
1835:        where: { idempotencyKey },
1836:        include: { wallet: true }
1837:      })
1838:      if (existingLog) {
1839:        if (existingLog.userId !== input.userId || existingLog.type !== 'balance_transfer') {
1840:          throw new ExchangeError('EXCHANGE_IDEMPOTENCY_KEY_CONFLICT', '幂等键已被其他资金请求使用', 409)
1841:        }
1842:        return {
1843:          wallet: serializeWallet(existingLog.wallet),
1844:          walletLogId: existingLog.id,
1845:          balanceLogId: existingLog.balanceLogId,
1846:          transferredAmount: Math.abs(toNumber(existingLog.amount))
1847:        }
1848:      }
1849:    }
1850:    const policy = await getPolicy(tx)
1851:    if (!policy.allowBalanceTransfer) {
1852:      throw new ExchangeError('EXCHANGE_TRANSFER_DISABLED', '当前不允许交易所余额划转到账户余额')
1853:    }
1854:    const account = await tx.user.findUnique({
1855:      where: { id: input.userId },
1856:      select: { status: true }
1857:    })
1858:    if (!account || account.status !== 'active') {
1859:      throw new ExchangeError('EXCHANGE_ACCOUNT_NOT_ACTIVE', '账号状态异常，不能划转交易所余额')
1860:    }
1861:    const restriction = await tx.userOrderRestriction.findFirst({
1862:      where: { userId: input.userId, status: 'active' },
1863:      select: { id: true }
1864:    })
1865:    if (restriction) {
1866:      throw new ExchangeError('EXCHANGE_ACCOUNT_RESTRICTED', '账号处于风控限制中，不能划转交易所余额')
1867:    }
1868:    await assertExchangeFundsRiskClear(tx, input.userId, '划转交易所余额')
1869:    const openDisputes = await tx.exchangeDispute.count({
1870:      where: {
1871:        status: { in: activeDisputeStatuses },
1872:        order: {
1873:          OR: [
1874:            { buyerUserId: input.userId },
1875:            { sellerUserId: input.userId }
1876:          ]
1877:        }
1878:      }
1879:    })
1880:    if (openDisputes > 0) {
1881:      throw new ExchangeError('EXCHANGE_HAS_OPEN_DISPUTE', '存在未完结争议，不能划转交易所余额')
1882:    }
1883:    const walletLocked = await tryAdvisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, input.userId)
1884:    if (!walletLocked) {
1885:      throw new ExchangeError('EXCHANGE_WALLET_BUSY', '交易所余额正在处理，请稍后重试')
1886:    }
1887:    const wallet = await tx.exchangeWallet.upsert({
1888:      where: { userId: input.userId },
1889:      update: {},
1890:      create: { userId: input.userId }
1891:    })
1892:    const availableBefore = toNumber(wallet.availableAmount)
1893:    if (availableBefore < amount) {
1894:      throw new ExchangeError('EXCHANGE_WALLET_NOT_ENOUGH', '交易所余额不足')
1895:    }
1896:    const availableAfter = Number((availableBefore - amount).toFixed(2))
1897:    const debitedWallet = await tx.exchangeWallet.updateMany({
1898:      where: { id: wallet.id, availableAmount: { gte: amount } },
1899:      data: { availableAmount: { decrement: amount } }
1900:    })
1901:    if (debitedWallet.count !== 1) {
1902:      throw new ExchangeError('EXCHANGE_WALLET_NOT_ENOUGH', '交易所余额不足')
1903:    }
1904:    const user = await tx.user.findUnique({
1905:      where: { id: input.userId },
1906:      select: { balance: true }
1907:    })
1908:    if (!user) throw new ExchangeError('EXCHANGE_USER_NOT_FOUND', '用户不存在', 404)
1909:    const balanceBefore = toNumber(user.balance)
1910:    const balanceAfter = Number((balanceBefore + amount).toFixed(2))
1911:    await tx.user.update({
1912:      where: { id: input.userId },
1913:      data: { balance: { increment: amount } }
1914:    })
1915:    const balanceLog = await tx.balanceLog.create({
1916:      data: {
1917:        userId: input.userId,
1918:        type: 'exchange_transfer',
1919:        amount,
1920:        balanceBefore,
1921:        balanceAfter,
1922:        remark: '交易所余额划转到账户余额'
1923:      }
1924:    })
1925:	    const walletLog = await tx.exchangeWalletLog.create({
1926:	      data: {
1927:	        walletId: wallet.id,
1928:        userId: input.userId,
1929:        type: 'balance_transfer',
1930:        amount: -amount,
1931:        availableBefore,
1932:        availableAfter,
1933:        frozenBefore: wallet.frozenAmount,
1934:        frozenAfter: wallet.frozenAmount,
1935:        balanceLogId: balanceLog.id,
1936:        idempotencyKey,
1937:	        remark: '划转到账户余额'
1938:	      }
1939:	    })
1940:	    await tx.exchangeAuditLog.create({
1941:	      data: {
1942:	        actorUserId: input.userId,
1943:	        action: 'wallet.balance_transfer',
1944:	        targetType: 'exchange_wallet_log',
1945:	        targetId: walletLog.id,
1946:	        detail: {
1947:	          amount,
1948:	          balanceLogId: balanceLog.id,
1949:	          availableBefore,
1950:	          availableAfter
1951:	        }
1952:	      }
1953:	    })
1954:	    const updatedWallet = await tx.exchangeWallet.findUniqueOrThrow({
1955:	      where: { id: wallet.id }
1956:	    })
1957:    return {
1958:      wallet: serializeWallet(updatedWallet),
1959:      walletLogId: walletLog.id,
1960:      balanceLogId: balanceLog.id,
1961:      transferredAmount: amount
1962:    }
1963:  })
1964:}
1965:
1966:export async function createExchangeWithdrawal(input: WithdrawalInput) {
1967:  const amount = normalizeMoney(input.amount, '提现金额')
1968:  const idempotencyKey = normalizeIdempotencyKey(input.idempotencyKey)
1969:  const method = normalizeOptionalText(input.method, 64)
1970:  const rawAccount = input.accountSnapshot?.account
1971:  const account = typeof rawAccount === 'string' ? rawAccount.trim().slice(0, 200) : ''
1972:  if (!method) {
1973:    throw new ExchangeError('EXCHANGE_WITHDRAWAL_METHOD_REQUIRED', '必须填写提现方式')
1974:  }
1975:  if (!account) {
1976:    throw new ExchangeError('EXCHANGE_WITHDRAWAL_ACCOUNT_REQUIRED', '必须填写收款账号')
1977:  }
1978:  const accountSnapshot = {
1979:    ...(input.accountSnapshot || {}),
1980:    account
1980:    account
1981:  }
1982:  return prisma.$transaction(async tx => {
1983:    if (idempotencyKey) {
1984:      const existing = await tx.exchangeWithdrawal.findUnique({
1985:        where: { idempotencyKey }
1986:      })
1987:      if (existing) {
1988:        if (existing.userId !== input.userId) {
