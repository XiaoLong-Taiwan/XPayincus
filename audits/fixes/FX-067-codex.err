26:// 自定义 nanoid，只使用小写字母和数字（Incus 不允许下划线）
27:const nanoid = customAlphabet('abcdefghijklmnopqrstuvwxyz0123456789', 8)
28:const TRANSFER_TARGET_USERNAME_MAX_LENGTH = 64
29:const TRANSFER_REMARK_MAX_LENGTH = 200
30:
31:type TransferCreateInput = {
32:    targetUsername: string
33:    remark?: string
34:}
35:
36:function isPlainRecord(value: unknown): value is Record<string, unknown> {
37:    return typeof value === 'object' && value !== null && !Array.isArray(value)
38:}
39:
40:function normalizeTransferCreateInput(input: unknown): TransferCreateInput {
41:    if (!isPlainRecord(input)) {
42:        throw { error: 'Invalid request body' }
43:    }
44:
45:    if (typeof input.targetUsername !== 'string') {
46:        throw { error: 'Target username is required' }
47:    }
48:    const targetUsername = input.targetUsername.trim()
49:    if (targetUsername.length < 2 || targetUsername.length > TRANSFER_TARGET_USERNAME_MAX_LENGTH) {
50:        throw { error: `Target username must be 2-${TRANSFER_TARGET_USERNAME_MAX_LENGTH} characters` }
51:    }
52:
53:    let remark: string | undefined
54:    if (input.remark !== undefined && input.remark !== null) {
55:        if (typeof input.remark !== 'string') {
56:            throw { error: 'Remark must be a string' }
57:        }
58:        const normalizedRemark = input.remark.trim()
59:        if (normalizedRemark.length > TRANSFER_REMARK_MAX_LENGTH) {
60:            throw { error: `Remark must be no longer than ${TRANSFER_REMARK_MAX_LENGTH} characters` }
61:        }
62:        remark = normalizedRemark || undefined
63:    }
64:
65:    return { targetUsername, remark }
66:}
