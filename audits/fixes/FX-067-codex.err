1810:  const pageSize = Math.min(Math.max(1, Math.floor(options.pageSize || 20)), 100)
1811:  const where = { userId }
1812:  const [items, total] = await Promise.all([
1813:    prisma.exchangeWalletLog.findMany({
1814:      where,
1815:      orderBy: { createdAt: 'desc' },
1816:      skip: (page - 1) * pageSize,
1817:      take: pageSize
1818:    }),
1819:    prisma.exchangeWalletLog.count({ where })
1820:  ])
1821:  return {
1822:    items: items.map(serializeWalletLog),
1823:    total,
1824:    page,
1825:    pageSize
1826:  }
1827:}
