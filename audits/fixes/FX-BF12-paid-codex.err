  82:   return (await getRuntimeConfigString(
  83:     'plugin_market_public_base_url',
  84:     'PLUGIN_MARKET_PUBLIC_BASE_URL',
  85:     'https://payincus.com/plugin-market'
  86:   )).replace(/\/+$/, '')
  87: }
  88: 
  89: function submissionToMarketEntry(submission: Awaited<ReturnType<typeof prisma.pluginMarketSubmission.findMany>>[number], publicBaseUrl: string): PluginMarketEntry {
  90:   const manifestUrl = submission.manifestUrl || `${publicBaseUrl}/manifests/${submission.pluginId}/${submission.version}.json`
  91:   return {
  92:     id: submission.pluginId,
  93:     name: submission.name,
  94:     latest: submission.version,
  95:     repo: submission.repoUrl,
  96:     manifestUrl,
  97:     downloadUrl: submission.packageUrl,
  98:     sha256: submission.sha256,
  99:     description: submission.notes || undefined,
 100:     author: submission.developerName,
 101:     reviewStatus: 'listed',
 102:     trustLevel: submission.developerGithub ? 'verified' : 'third_party',
 103:     developer: {
 104:       name: submission.developerName,
 105:       homepage: submission.developerHomepage || undefined,
 106:       github: submission.developerGithub || undefined,
 107:       verified: Boolean(submission.developerGithub),
 108:       contact: submission.contactEmail
 109:     },
 110:     permissions: normalizePermissions(submission.permissions),
 111:     compatibility: normalizeCompatibility(submission.compatibility),
 112:     security: {
 113:       checksumPinned: true,
 114:       signature: { status: 'unsigned' },
 115:       notes: getScanNotes(submission.scanResult, submission.riskLevel)
 116:     },
 117:     pricing: normalizePricing(submission.pricing),
 118:     rating: { average: 0, count: 0 },
 119:     installCount: 0,
 120:     releaseNotes: submission.notes || undefined,
 121:     upgradeNotes: 'Install from the stable PayIncus extension market after reviewing permissions and SHA256.',
 122:     rollbackNotes: 'Disable or uninstall the extension from the extension center.'
 123:   }
 124: }
