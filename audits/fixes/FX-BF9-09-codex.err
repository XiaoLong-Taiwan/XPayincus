  264:   }
  265:   const trimmed = value.trim()
  266:   if (!trimmed || trimmed.length > maxLength) {
  267:     throw apiError(ErrorCode.VALIDATION_ERROR, `${field} éœ€ä¸º 1-${maxLength} ä¸ªå­—ç¬¦`)
  268:   }
  269:   return trimmed
  270: }
