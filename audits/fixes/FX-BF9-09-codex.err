  319:   }
  320: 
  321:   if (input.enabled !== undefined) {
  322:     if (typeof input.enabled !== 'boolean') {
  323:       throw apiError(ErrorCode.VALIDATION_ERROR, 'å¯ç”¨çŠ¶æ€æ— æ•ˆ')
