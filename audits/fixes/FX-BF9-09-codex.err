  179: function normalizeMailPlanInput(input: MailPlanInput, requireAll: boolean): MailPlanInput {
  180:   const normalized: MailPlanInput = {}
  181: 
  182:   if (requireAll && (!input.sourceId || !input.name || !input.domainLimit || !input.diskLimitGb || !input.billingCycle || input.price === undefined)) {
  183:     throw apiError(ErrorCode.VALIDATION_ERROR, 'è¯·å¡«å†™æ‰€æœ‰å¿…å¡«å­—æ®µ')
  184:   }
  185: 
  186:   if (input.sourceId !== undefined) {
  187:     const sourceId = requireSafeInteger(input.sourceId, 'é‚®ç®±æº')
  188:     if (sourceId <= 0) {
