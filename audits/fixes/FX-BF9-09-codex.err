  368:     if (displayName.length > 100) {
  369:       throw apiError(ErrorCode.VALIDATION_ERROR, 'æ˜¾ç¤ºåç§°ä¸èƒ½è¶…è¿‡ 100 ä¸ªå­—ç¬¦')
  370:     }
  371:     normalized.displayName = displayName || undefined
  372:   }
  373: 
  374:   if (input.diskLimitMb !== undefined) {
  375:     const diskLimitMb = requireSafeInteger(input.diskLimitMb, 'é‚®ç®±å®¹é‡')
  376:     if (diskLimitMb <= 0 || diskLimitMb > maxDiskLimitMb) {
  377:       throw apiError(ErrorCode.VALIDATION_ERROR, `é‚®ç®±å®¹é‡éœ€ä¸º 1-${maxDiskLimitMb} MB çš„æ•´æ•°`)
  378:     }
  379:     normalized.diskLimitMb = diskLimitMb
  380:   }
  381: 
  382:   return normalized
