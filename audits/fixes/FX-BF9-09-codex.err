+): Promise<boolean> {
+  const allocatedDiskLimitMb = await getMailSubscriptionAllocatedDiskMb(tx, subscriptionId, excludeAccountId)
+  return allocatedDiskLimitMb + requestedDiskLimitMb <= subscriptionDiskLimitGb * 1024
+}
