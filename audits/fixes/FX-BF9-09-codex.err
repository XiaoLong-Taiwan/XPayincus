  352:     if (!username || username.length > 64 || !/^[a-z0-9._-]+$/i.test(username)) {
  353:       throw apiError(ErrorCode.VALIDATION_ERROR, 'ç”¨æˆ·ååªèƒ½åŒ…å« 1-64 ä½å­—æ¯ã€æ•°å­—ã€ç‚¹ã€ä¸‹åˆ’çº¿å’Œè¿žå­—ç¬¦')
  354:     }
  355:     normalized.username = username
  356:   }
  357: 
  358:   if (options.requirePassword || input.password !== undefined) {
  359:     const password = String(input.password || '')
  360:     if (password.length < 8 || password.length > 128) {
  361:       throw apiError(ErrorCode.VALIDATION_ERROR, 'å¯†ç é•¿åº¦éœ€ä¸º 8-128 ä½')
  362:     }
  363:     normalized.password = password
  364:   }
  365: 
  366:   if (input.displayName !== undefined) {
