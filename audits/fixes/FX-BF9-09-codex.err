  201: 
  202:   if (input.description !== undefined) {
  203:     const description = String(input.description).trim()
  204:     if (description.length > 1000) {
  205:       throw apiError(ErrorCode.VALIDATION_ERROR, 'æ–¹æ¡ˆæè¿°ä¸èƒ½è¶…è¿‡ 1000 ä¸ªå­—ç¬¦')
  206:     }
  207:     normalized.description = description || undefined
  208:   }
  209: 
  210:   if (input.domainLimit !== undefined) {
  211:     const domainLimit = requireSafeInteger(input.domainLimit, 'åŸŸåæ•°é‡é™åˆ¶')
  212:     if (domainLimit <= 0 || domainLimit > 1000) {
  213:       throw apiError(ErrorCode.VALIDATION_ERROR, 'åŸŸåæ•°é‡é™åˆ¶éœ€ä¸º 1-1000 çš„æ•´æ•°')
  214:     }
  215:     normalized.domainLimit = domainLimit
  216:   }
  217: 
  218:   if (input.diskLimitGb !== undefined) {
  219:     const diskLimitGb = requireSafeInteger(input.diskLimitGb, 'ç£ç›˜å®¹é‡')
  220:     if (diskLimitGb <= 0 || diskLimitGb > 102400) {
  221:       throw apiError(ErrorCode.VALIDATION_ERROR, 'ç£ç›˜å®¹é‡éœ€ä¸º 1-102400 GB çš„æ•´æ•°')
  222:     }
  223:     normalized.diskLimitGb = diskLimitGb
  224:   }
  225: 
  226:   if (input.billingCycle !== undefined) {
  227:     if (input.billingCycle !== 'monthly' && input.billingCycle !== 'yearly') {
  228:       throw apiError(ErrorCode.VALIDATION_ERROR, 'è®¡è´¹å‘¨æœŸæ— æ•ˆ')
  229:     }
  230:     normalized.billingCycle = input.billingCycle
  231:   }
  232: 
  233:   if (input.price !== undefined) {
  234:     const price = requireNumber(input.price, 'ä»·æ ¼')
  235:     if (price <= 0 || price > 99999999.99) {
  236:       throw apiError(ErrorCode.VALIDATION_ERROR, 'ä»·æ ¼éœ€å¤§äºŽ 0 ä¸”ä¸è¶…è¿‡ 99999999.99')
  237:     }
  238:     const roundedPrice = Math.round(price * 100) / 100
  239:     if (Math.abs(price - roundedPrice) > 1e-8) {
  240:       throw apiError(ErrorCode.VALIDATION_ERROR, 'ä»·æ ¼æœ€å¤šæ”¯æŒä¸¤ä½å°æ•°')
  241:     }
  242:     normalized.price = roundedPrice
  243:   }
  244: 
  245:   if (input.enabled !== undefined) {
  246:     normalized.enabled = input.enabled === true
  247:   }
  248: 
  249:   if (input.sortOrder !== undefined) {
  250:     const sortOrder = requireSafeInteger(input.sortOrder, 'æŽ’åºå€¼')
  251:     if (sortOrder < -1000000 || sortOrder > 1000000) {
  252:       throw apiError(ErrorCode.VALIDATION_ERROR, 'æŽ’åºå€¼æ— æ•ˆ')
  253:     }
  254:     normalized.sortOrder = sortOrder
  255:   }
  256: 
  257:   return normalized
  258: }
