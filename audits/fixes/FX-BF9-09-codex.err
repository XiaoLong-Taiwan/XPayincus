 1564: 
 1565:     const subscription = await db.getUserMailSubscription(userId)
 1566:     if (!subscription) {
 1567:       return reply.code(404).send(apiError(ErrorCode.NOT_FOUND, 'æ‚¨æ²¡æœ‰é‚®ç®±è®¢é˜…'))
 1568:     }
 1569: 
 1570:     if (subscription.status !== 'active') {
 1571:       return reply.code(400).send(apiError(ErrorCode.OPERATION_NOT_ALLOWED, 'è®¢é˜…å·²è¿‡æœŸæˆ–æš‚åœ'))
