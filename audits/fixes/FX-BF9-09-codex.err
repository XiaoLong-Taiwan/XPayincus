   domain: string,
-  diskLimitGb: number
+  subscriptionDiskLimitGb: number,
+  domainLimit: number
 ): Promise<{ username?: string; password?: string; server?: string }> {
+  // CraneMail only supports a per-domain cap. Split the subscription's shared
