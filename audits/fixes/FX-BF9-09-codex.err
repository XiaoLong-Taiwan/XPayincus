   91: 
   92: async function getMailRefundableAmount(
   93:   tx: Prisma.TransactionClient,
   94:   subscription: {
   95:     userId: number
   96:     createdAt: Date
   97:     expiresAt: Date
   98:     billingCycle: 'monthly' | 'yearly'
   99:   },
  100:   now: Date
  101: ): Promise<{ maxRefundable: number; remainingRefundable: number }> {
  102:   // é‚®ç®±æš‚æ— ç‹¬ç«‹è®¡è´¹è¡¨ï¼šä»¥è®¢é˜…åˆ›å»ºæ—¶åŒä¸€äº‹åŠ¡å†™å…¥çš„è´­ä¹° BalanceLog ä½œä¸ºæµæ°´èµ·ç‚¹ã€‚
  103:   const purchaseRecord = await tx.balanceLog.findFirst({
  104:     where: {
  105:       userId: subscription.userId,
  106:       type: 'consume',
  107:       remark: { startsWith: MAIL_PURCHASE_REMARK_PREFIX },
  108:       createdAt: { lte: subscription.createdAt }
  109:     },
  110:     orderBy: [{ createdAt: 'desc' }, { id: 'desc' }],
  111:     select: { id: true }
  112:   })
  113: 
  114:   if (!purchaseRecord) {
  115:     return { maxRefundable: 0, remainingRefundable: 0 }
  116:   }
  117: 
  118:   const [paymentRecords, refundRecords] = await Promise.all([
  119:     tx.balanceLog.findMany({
  120:       where: {
  121:         userId: subscription.userId,
  122:         id: { gte: purchaseRecord.id },
  123:         type: 'consume',
  124:         OR: [
  125:           { remark: { startsWith: MAIL_PURCHASE_REMARK_PREFIX } },
  126:           { remark: { startsWith: MAIL_RENEW_REMARK_PREFIX } }
  127:         ]
  128:       },
  129:       orderBy: { id: 'asc' },
  130:       select: { amount: true, remark: true }
  131:     }),
  132:     tx.balanceLog.findMany({
  133:       where: {
  134:         userId: subscription.userId,
  135:         id: { gte: purchaseRecord.id },
  136:         type: 'refund',
  137:         remark: { startsWith: MAIL_REFUND_REMARK_PREFIX }
  138:       },
  139:       select: { amount: true }
  140:     })
  141:   ])
  142: 
  143:   const totalPaid = paymentRecords.reduce((sum, record) => sum + Math.abs(Number(record.amount)), 0)
  144:   const totalRefunded = refundRecords.reduce((sum, record) => sum + Math.abs(Number(record.amount)), 0)
  145:   const maxRefundable = roundMailCurrency(Math.max(0, totalPaid - totalRefunded))
  146: 
  147:   let remainingValue = 0
  148:   let periodEnd = new Date(subscription.expiresAt).getTime()
  149:   for (const record of [...paymentRecords].reverse()) {
  150:     const periodMs = getMailPaymentPeriodMs(record.remark, subscription.billingCycle)
  151:     const periodStart = periodEnd - periodMs
  152:     if (periodEnd > now.getTime()) {
  153:       const unusedRatio = Math.min(Math.max(periodEnd - now.getTime(), 0) / periodMs, 1)
  154:       remainingValue += Math.abs(Number(record.amount)) * unusedRatio
  155:     }
  156:     periodEnd = periodStart
  157:   }
  158: 
  159:   return {
  160:     maxRefundable,
  161:     remainingRefundable: roundMailCurrency(Math.min(remainingValue, maxRefundable))
  162:   }
  163: }
