  196:     if (!name || name.length > 100) {
  197:       throw apiError(ErrorCode.VALIDATION_ERROR, 'æ–¹æ¡ˆåç§°éœ€ä¸º 1-100 ä¸ªå­—ç¬¦')
  198:     }
  199:     normalized.name = name
