+  const allocated = await tx.mailAccount.aggregate({
+    where: {
+      domain: { subscriptionId },
+      ...(excludeAccountId !== undefined ? { id: { not: excludeAccountId } } : {})
+    },
+    _sum: { diskLimitMb: true }
+  })
+  return allocated._sum.diskLimitMb ?? 0
