  327: 
  328:   if (input.sortOrder !== undefined) {
  329:     const sortOrder = requireSafeInteger(input.sortOrder, 'æŽ’åºå€¼')
  330:     if (sortOrder < -1000000 || sortOrder > 1000000) {
  331:       throw apiError(ErrorCode.VALIDATION_ERROR, 'æŽ’åºå€¼æ— æ•ˆ')
  332:     }
  333:     normalized.sortOrder = sortOrder
