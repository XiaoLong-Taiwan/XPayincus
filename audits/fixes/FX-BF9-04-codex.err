diff --git a/server/scripts/test-mail-subscription-cancel-guards.ts b/server/scripts/test-mail-subscription-cancel-guards.ts
index ab6b9b9e69002be06d9f72bab4521aa08be37b7e..f84e20a8669deca02943abbdf869c755248e3bde
--- a/server/scripts/test-mail-subscription-cancel-guards.ts
