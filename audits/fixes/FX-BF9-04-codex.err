+assert.ok(
+  purchaseRouteSection.includes("where: { userId, sourceId: source.id, status: 'active' }") &&
+    purchaseRouteSection.match(/where: \{ userId, sourceId: source\.id, status: 'active' \}/g)?.length === 2,
