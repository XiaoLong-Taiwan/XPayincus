  809:       currentBandwidthLimit: limit,
  810:       lastTriggeredAt: new Date(),
  811:       reason,
  812:       evidence
  813:     }
  814:   })
  815:   await reconcileEffectiveBandwidth(instance.id)
  816: 
  817:   const event = await prisma.instanceRiskEvent.create({
  818:     data: {
  819:       instanceId: instance.id,
  820:       userId: instance.userId,
  821:       hostId: instance.hostId,
  822:       type: 'manual_qos_limited',
  823:       severity: 'medium',
  824:       scoreDelta: nextScore - previousScore,
  825:       scoreAfter: nextScore,
  826:       actionTaken: 'manual_qos_limited',
  827:       message: `管理员人工限速到 ${limit}：${reason}`,
  828:       evidence
  829:     }
  830:   })
  831: 
  832:   if (input.restrictOrders) {
  833:     await restrictUserOrdersForRisk({
  834:       userId: instance.userId,
  835:       sourceInstanceId: instance.id,
  950:     }).catch((error) => {
  951:       console.error('[ResourceRisk] Failed to send manual suspend notification:', error)
