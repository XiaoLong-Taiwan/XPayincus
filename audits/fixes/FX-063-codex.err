diff --git a/server/src/services/traffic-bandwidth.ts b/server/src/services/traffic-bandwidth.ts
index 203cee5e01ec5553c9b1f2e007b0a1c85df45b2a..2364e6cd75591f5332b784b21ff45b3fbffee434
--- a/server/src/services/traffic-bandwidth.ts
