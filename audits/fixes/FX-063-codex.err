  753: /**
  754:  * 更新实例的带宽限制配置（用于流量限速/恢复时同步数据库）
  755:  */
  756: export async function updateInstanceBandwidthLimits(
  757:     instanceId: number,
  758:     limitsIngress: string | null,
  759:     limitsEgress: string | null
  760: ) {
  761:     return prisma.instance.update({
  762:         where: { id: instanceId },
  763:         data: {
  764:             limitsIngress,
  765:             limitsEgress
  766:         }
  767:     })
  768: }
  769: 
  770: /**
  771:  * 重置指定节点下所有实例的月度流量用量
  772:  * @param hostIds 节点 ID 数组
  773:  */
  774: export async function resetHostInstancesMonthlyTraffic(hostIds: number[]) {
  775:     const instances = await prisma.instance.findMany({
  776:         where: {
  777:             hostId: { in: hostIds },
  778:             status: { not: 'deleted' }
  779:         },
  780:         select: { id: true }
  781:     })
  782: 
  783:     let count = 0
  784:     for (const instance of instances) {
  785:         const result = await resetInstanceMonthlyTraffic(instance.id)
  786:         count += result.count
  787:     }
  788: 
  789:     return { count }
  790: }
