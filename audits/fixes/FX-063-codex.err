  769:       },
  770:       resourceRiskState: true
  771:     }
  772:   })
  773:   if (!instance || instance.status === 'deleted') return null
  774:   if (input.bandwidthMbps <= 0 || !Number.isFinite(input.bandwidthMbps)) {
  775:     throw new Error('Invalid bandwidth limit')
  776:   }
  777: 
  778:   const limit = `${Math.round(input.bandwidthMbps)}Mbit`
  779:   const previousScore = instance.resourceRiskState?.score ?? 0
  780:   const nextScore = clampScore(Math.max(previousScore, 50))
