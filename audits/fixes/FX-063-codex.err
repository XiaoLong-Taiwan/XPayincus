  390: async function autoSuspendInstance(input: {
  391:   instance: {
  392:     id: number
  393:     incusId: string
  394:     name: string
  395:     userId: number
  396:     status: string
  397:     host: {
  398:       id: number
  399:       url: string
  400:       certPath: string | null
  401:       keyPath: string | null
  402:       status: string
  403:     }
  404:   }
  405:   reason: string
  406: }) {
  407:   if (input.instance.status === 'suspended') return
  408: 
  409:   await prisma.instance.update({
  410:     where: { id: input.instance.id },
  411:     data: {
  412:       status: 'suspended',
  413:       suspendedAt: new Date(),
  414:       suspendedBy: null,
  415:       suspendReason: input.reason,
  416:       version: { increment: 1 }
  417:     }
  418:   })
  419: 
  420:   if (input.instance.host.status === 'online' && input.instance.host.certPath && input.instance.host.keyPath) {
  421:     const client = await getIncusClientFromPool({
  422:       id: input.instance.host.id,
  423:       url: input.instance.host.url,
  424:       certPath: input.instance.host.certPath,
  425:       keyPath: input.instance.host.keyPath
  426:     })
  427:     await stopInstance(client, input.instance.incusId, true)
  428:   }
  429: 
  430:   await sendNotification(input.instance.userId, 'instance_suspended', {
  431:     instanceName: input.instance.name,
  432:     suspendReason: input.reason
  433:   }).catch((error) => {
  434:     console.error('[ResourceRisk] Failed to send suspend notification:', error)
  435:   })
  436: }
  437: 
  438: export async function evaluateInstanceRisk(instanceId: number, policyInput?: RiskPolicy) {
  439:   const policy = policyInput ?? await getDefaultPolicy()
  440:   if (!policy.enabled) return null
  441: 
  442:   const instance = await prisma.instance.findUnique({
  443:     where: { id: instanceId },
  444:     include: {
  445:       host: {
  446:         select: {
  447:           id: true,
  448:           name: true,
  449:           status: true,
  450:           url: true,
  451:           certPath: true,
  452:           keyPath: true
  453:         }
  454:       },
  455:       resourceRiskState: true
  456:     }
  457:   })
  458: 
  459:   if (!instance || instance.status === 'deleted') return null
  460: 
  461:   const now = new Date()
  462:   const windowMinutes = Math.max(policy.bandwidthWindowMinutes, policy.cpuWindowMinutes)
  463:   const samples = await prisma.instanceResourceSample.findMany({
  464:     where: {
  465:       instanceId,
  466:       sampledAt: {
  467:         gte: new Date(now.getTime() - windowMinutes * 60 * 1000)
  468:       }
  469:     },
  470:     orderBy: { sampledAt: 'desc' },
  471:     take: 500
  472:   })
  473: 
  474:   const previousScore = instance.resourceRiskState?.score ?? 0
  475:   const decayAnchorAt = instance.resourceRiskState?.lastTriggeredAt ??
  476:     (previousScore > 0 ? instance.resourceRiskState?.lastEvaluatedAt : null)
  477:   const projection = projectRisk({
  478:     samples,
  479:     policy,
  480:     previousScore,
  481:     decayAnchorAt,
  482:     decayAppliedSinceTrigger: getDecayAppliedSinceTrigger(instance.resourceRiskState?.evidence)
  483:   })
  484:   const {
  485:     triggers,
  486:     nextScore,
  487:     nextLevel,
  488:     qosTiers,
  489:     targetTier,
  490:     shouldRestrictOrders,
  491:     shouldAutoSuspend
  492:   } = projection
  493: 
  494:   const currentStatus = instance.resourceRiskState?.status ?? 'normal'
  495:   const manualLocked = currentStatus === 'manual_suspended' || currentStatus === 'manual_qos_limited'
  496:   const currentQosLevel = instance.resourceRiskState?.qosLevel ?? 0
  497:   const currentTier = currentQosLevel > 0 ? (qosTiers.find(tier => tier.level === currentQosLevel) ?? null) : null
  498:   const lastActionMinutes = minutesSince(instance.resourceRiskState?.lastTriggeredAt, now)
  499: 
  500:   let actionTaken: string | null = manualLocked ? 'manual_state_preserved' : null
  501:   let bandwidthLimit: string | null = instance.resourceRiskState?.currentBandwidthLimit ?? null
  502:   let nextQosLevel = currentQosLevel
  503:   let nextStatus = shouldAutoSuspend && !manualLocked ? 'suspended' : (currentQosLevel > 0 ? 'qos_limited' : nextLevel)
  504:   let nextLastTriggeredAt: Date | undefined = triggers.length > 0
  505:     ? now
  506:     : (instance.resourceRiskState?.lastTriggeredAt ? undefined : decayAnchorAt ?? undefined)
  507:   let nextLastRecoveredAt: Date | undefined
  508:   let effectiveTargetTier = targetTier
  509: 
  510:   const canRecoverQos = !manualLocked &&
  511:     currentTier &&
  512:     triggers.length === 0 &&
  513:     nextScore <= currentTier.recoverScore &&
  514:     (lastActionMinutes === null || lastActionMinutes >= currentTier.minDurationMinutes)
  515: 
  516:   if (canRecoverQos) {
  517:     try {
  518:       await restoreQosLimit({
  519:         instance,
  520:         state: {
  521:           originalIngress: instance.resourceRiskState?.originalIngress ?? null,
  522:           originalEgress: instance.resourceRiskState?.originalEgress ?? null
  523:         }
  524:       })
  525:       actionTaken = 'qos_recovered'
  526:       bandwidthLimit = null
  527:       nextQosLevel = 0
  528:       nextStatus = nextLevel
  529:       effectiveTargetTier = null
  530:       nextLastRecoveredAt = now
  531:     } catch (error) {
  532:       console.error(`[ResourceRisk] Failed to recover QoS for instance ${instance.id}:`, error)
  533:     }
  534:   }
  535: 
  536:   const canEscalateQos = !manualLocked &&
  537:     effectiveTargetTier &&
  538:     effectiveTargetTier.level > nextQosLevel &&
  539:     (!currentTier || currentTier.allowFurtherDowngrade) &&
  540:     (lastActionMinutes === null || lastActionMinutes >= effectiveTargetTier.cooldownMinutes)
  541: 
  542:   if (canEscalateQos && effectiveTargetTier) {
  543:     try {
  544:       bandwidthLimit = await applyQosLimit({
  545:         instance,
  546:         tier: effectiveTargetTier,
  547:         state: instance.resourceRiskState
  548:       })
  549:       if (bandwidthLimit) {
  550:         nextQosLevel = effectiveTargetTier.level
  551:         nextStatus = 'qos_limited'
  552:         nextLastTriggeredAt = now
  553:         actionTaken = `qos_level_${effectiveTargetTier.level}`
  554:         if (effectiveTargetTier.notifyUser) {
  555:           await sendNotification(instance.userId, 'resource_risk_qos_limited', {
  556:             instanceName: instance.name,
  557:             hostName: instance.host.name,
  558:             bandwidthLimit,
  559:             score: nextScore,
  560:             reason: triggers.map(trigger => trigger.message).join('；') || '资源使用触发自动风控'
  561:           }).catch((error) => {
  562:             console.error('[ResourceRisk] Failed to send QoS notification:', error)
  563:           })
  564:         }
  565:       }
  566:     } catch (error) {
  567:       console.error(`[ResourceRisk] Failed to apply QoS for instance ${instance.id}:`, error)
  568:     }
  569:   }
  570: 
  571:   if (!manualLocked && effectiveTargetTier && effectiveTargetTier.level <= nextQosLevel) {
  572:     nextStatus = 'qos_limited'
  573:   }
  574: 
  575:   if (manualLocked) {
  576:     nextStatus = currentStatus
  577:   }
  578: 
  579:   if (shouldAutoSuspend && !manualLocked) {
