   99: /**
  100:  * 采集单个实例的流量数据
  101:  */
  102: async function collectInstanceTraffic(
  103:     instance: {
  104:         id: number
  105:         incusId: string
  106:         userId: number
  107:         monthlyTrafficUsed: bigint
  108:     },
  109:     client: IncusClient
  110: ): Promise<TrafficDelta | null> {
  111:     const result = await collectTrafficForInstanceWithClient({
  112:         instanceId: instance.id,
  113:         userId: instance.userId,
  114:         incusId: instance.incusId,
  115:         client,
  116:         currentUsage: instance.monthlyTrafficUsed
  117:     }, {
  118:         waitTimeoutMs: 200,
  119:         retryIntervalMs: 50,
  120:         expireMs: 30000
  121:     })
  122: 
  123:     if (!result.success) {
  124:         console.error(`[Traffic] Failed to collect traffic for instance ${instance.id}: ${result.error}`)
  125:         return null
  126:     }
  127: 
  128:     return {
  129:         instanceId: instance.id,
  130:         totalDelta: result.totalDelta
  131:     }
  132: }
  133: 
  134: /**
  135:  * 检查并执行限速
  136:  */
  137: async function checkAndThrottle(
  138:     instance: RunningTrafficInstance,
  139:     client: IncusClient
  140: ): Promise<void> {
  141:     const userQuota = instance.user.quota
  142:     if (!userQuota) return
  143: 
  144:     const userEffectiveLimit = getEffectiveLimit(userQuota.monthlyTrafficLimit, userQuota.extraTrafficQuota)
  145:     const instanceLimit = getEffectiveLimit(instance.monthlyTrafficLimit, userQuota.extraTrafficQuota)
  146:     const instanceUsesExtraTraffic = instance.monthlyTrafficLimit !== null &&
  147:         instance.monthlyTrafficUsed >= instance.monthlyTrafficLimit
  148:     const extraTrafficExhausted = userQuota.extraTrafficQuota > 0n &&
  149:         userQuota.extraTrafficUsed >= userQuota.extraTrafficQuota
  150: 
  151:     // 检查用户级别限额
  152:     const userOverLimit = isOverLimit(userQuota.monthlyTrafficUsed, userEffectiveLimit)
  153:     // 检查实例级别限额
  154:     const instanceOverLimit = isOverLimit(instance.monthlyTrafficUsed, instanceLimit) ||
  155:         (instanceUsesExtraTraffic && extraTrafficExhausted)
  156: 
  157:     if (userOverLimit || instanceOverLimit) {
  158:         const remoteThrottled = await isThrottled(client, instance.incusId)
  159: 
  160:         if (instance.trafficStatus !== 'LIMITED' || !remoteThrottled) {
  161:             try {
  162:                 await applyThrottle(client, instance.incusId)
  163:                 const shouldNotifyThrottled = await trafficDb.markInstanceTrafficLimitedIfNeeded(instance.id)
  164:                 if (userOverLimit && userQuota.trafficStatus !== 'LIMITED') {
  165:                     await trafficDb.updateUserTrafficStatus(instance.userId, 'LIMITED')
  166:                 }
  167: 
  168:                 if (shouldNotifyThrottled) {
  169:                     await sendTrafficThrottledNotification(instance.userId, instance.name, instance.host.name)
  170:                 }
  171: 
  172:                 console.log(`[Traffic] Throttled instance ${instance.id} (${instance.incusId})`)
  173:             } catch (error) {
  174:                 console.error(`[Traffic] Failed to throttle instance ${instance.id}:`, error)
  175:             }
  176:         } else if (userOverLimit && userQuota.trafficStatus !== 'LIMITED') {
  177:             await trafficDb.updateUserTrafficStatus(instance.userId, 'LIMITED')
  178:         }
  179:     } else {
  180:         // 检查预警
  181:         const userWarning = isWarningThreshold(userQuota.monthlyTrafficUsed, userEffectiveLimit)
  182:         if (userWarning && !isWarningSentThisMonth(userQuota.trafficWarningSentAt)) {
  183:             const shouldNotifyWarning = await trafficDb.markUserTrafficWarningIfNeeded(instance.userId, new Date())
  184:             if (shouldNotifyWarning) {
  185:                 await sendTrafficWarningNotification(
  186:                     instance.userId,
  187:                     userQuota.monthlyTrafficUsed,
  188:                     userEffectiveLimit!
  189:                 )
  190:                 console.log(`[Traffic] Sent warning to user ${instance.userId}`)
  191:             }
  192:         }
  193: 
  194:         const instanceWarning = isWarningThreshold(instance.monthlyTrafficUsed, instanceLimit)
  195:         if (instanceWarning && instance.trafficStatus === 'NORMAL') {
  196:             const shouldNotifyWarning = await markInstanceTrafficWarningIfNeeded(instance.id)
  197:             if (shouldNotifyWarning) {
  198:                 await sendTrafficWarningNotification(
  199:                     instance.userId,
  200:                     instance.monthlyTrafficUsed,
  201:                     instanceLimit!,
  202:                     instance.name
  203:                 )
  204:                 console.log(`[Traffic] Sent warning for instance ${instance.id} to user ${instance.userId}`)
  205:             }
  206:         }
  207:     }
  208: }
  209: 
  210: /**
  211:  * 检查并恢复带宽
  212:  */
  213: async function checkAndRestore(
  214:     instance: RunningTrafficInstance,
  215:     client: IncusClient
  216: ): Promise<void> {
  217:     const userQuota = instance.user.quota
  218:     if (!userQuota) return
  219: 
  220:     const userEffectiveLimit = getEffectiveLimit(userQuota.monthlyTrafficLimit, userQuota.extraTrafficQuota)
  221:     const instanceLimit = getEffectiveLimit(instance.monthlyTrafficLimit, userQuota.extraTrafficQuota)
  222:     const instanceUsesExtraTraffic = instance.monthlyTrafficLimit !== null &&
  223:         instance.monthlyTrafficUsed >= instance.monthlyTrafficLimit
  224:     const extraTrafficExhausted = userQuota.extraTrafficQuota > 0n &&
  225:         userQuota.extraTrafficUsed >= userQuota.extraTrafficQuota
  226: 
  227:     const userUnderLimit = !isOverLimit(userQuota.monthlyTrafficUsed, userEffectiveLimit)
  228:     const instanceUnderLimit = !isOverLimit(instance.monthlyTrafficUsed, instanceLimit) &&
  229:         !(instanceUsesExtraTraffic && extraTrafficExhausted)
  230:     const desiredUserStatus = calculateUserTrafficStatus(userQuota.monthlyTrafficUsed, userEffectiveLimit)
  231: 
  232:     if (userUnderLimit && instanceUnderLimit) {
  233:         const remoteThrottled = await isThrottled(client, instance.incusId)
  234:         if (instance.trafficStatus !== 'LIMITED' && !remoteThrottled) {
  235:             if (userQuota.trafficStatus !== desiredUserStatus) {
  236:                 await trafficDb.updateUserTrafficStatus(instance.userId, desiredUserStatus)
  237:             }
  238:             return
  239:         }
  240: 
  241:         try {
  242:             const resolvedLimits = resolveTrafficBandwidthLimits(instance, {
  243:                 stripThrottleOverride: remoteThrottled || instance.trafficStatus === 'LIMITED'
  244:             })
  245: 
  246:             await restoreBandwidth(
  247:                 client,
  248:                 instance.incusId,
  249:                 resolvedLimits.incusIngress,
  250:                 resolvedLimits.incusEgress
  251:             )
  252:             await trafficDb.updateInstanceTrafficStatus(instance.id, 'NORMAL')
  253:             await trafficDb.updateInstanceBandwidthLimits(
  254:                 instance.id,
  255:                 resolvedLimits.dbIngress,
  256:                 resolvedLimits.dbEgress
  257:             )
  258: 
  259:             if (userQuota.trafficStatus !== desiredUserStatus) {
  260:                 await trafficDb.updateUserTrafficStatus(instance.userId, desiredUserStatus)
  261:             }
  262: 
  263:             console.log(`[Traffic] Restored bandwidth for instance ${instance.id}`)
  264:         } catch (error) {
  265:             console.error(`[Traffic] Failed to restore bandwidth for instance ${instance.id}:`, error)
  266:         }
  267:     }
  268: }
  269: 
  270: async function reconcileTrafficState(instances: RunningTrafficInstance[]): Promise<void> {
  271:     if (instances.length === 0) {
  272:         return
  273:     }
  274: 
  275:     const instancesByHost = new Map<number, RunningTrafficInstance[]>()
  276:     for (const instance of instances) {
  277:         if (instance.host.status !== 'online') continue
  278: 
  279:         const hostInstances = instancesByHost.get(instance.host.id) || []
  280:         hostInstances.push(instance)
  281:         instancesByHost.set(instance.host.id, hostInstances)
  282:     }
  283: 
  284:     for (const [hostId, hostInstances] of instancesByHost) {
  285:         const host = hostInstances[0].host
  286:         const client = await getHostClient({
  287:             id: hostId,
  288:             url: host.url,
  289:             certPath: host.certPath,
  290:             keyPath: host.keyPath
  291:         })
  292: 
  293:         if (!client) continue
  294: 
  295:         const hostLimit = pLimit(CONCURRENCY_PER_HOST)
  296:         await Promise.all(
  297:             hostInstances.map(instance =>
  298:                 hostLimit(async () => {
  299:                     await checkAndThrottle(instance, client)
  300:                     await checkAndRestore(instance, client)
  301:                 })
  302:             )
  303:         )
  304:     }
  305: }
  306: 
  307: export async function reconcileTrafficStateForInstanceIds(instanceIds: number[]): Promise<void> {
  308:     const instances = await trafficDb.getRunningInstancesForTrafficByIds(instanceIds)
  309:     await reconcileTrafficState(instances)
  310: }
  311: 
  312: export async function reconcileTrafficStateForUser(userId: number): Promise<void> {
  313:     const instances = await trafficDb.getRunningInstancesForTrafficByUserId(userId)
  314:     await reconcileTrafficState(instances)
  315: }
