  317: /**
  318:  * 带超时的任务执行（带定时器清理，防止内存泄漏）
  319:  */
  320: async function withTimeout<T>(
  321:     promise: Promise<T>,
  322:     timeoutMs: number,
  323:     timeoutMessage: string
  324: ): Promise<T> {
  325:     let timeoutId: ReturnType<typeof setTimeout> | null = null
  326:     
  327:     const timeoutPromise = new Promise<never>((_, reject) => {
  328:         timeoutId = setTimeout(() => reject(new Error(timeoutMessage)), timeoutMs)
  329:     })
  330: 
  331:     try {
  332:         return await Promise.race([promise, timeoutPromise])
  333:     } finally {
  334:         if (timeoutId) clearTimeout(timeoutId)
  335:     }
  336: }
  337: 
  338: /**
  339:  * 主流量采集任务
  340:  */
  300:     score: tier.score,
  301:     recoverScore: tier.recoverScore,
  302:     minDurationMinutes: tier.minDurationMinutes,
  303:     cooldownMinutes: tier.cooldownMinutes,
  304:     allowFurtherDowngrade: tier.allowFurtherDowngrade,
  305:     notifyUser: tier.notifyUser,
  306:     restrictOrders: tier.restrictOrders
  307:   }
  308: }
