  310: async function restoreQosLimit(input: {
  311:   instance: {
  312:     id: number
  313:     incusId: string
  314:     host: {
  315:       id: number
  316:       url: string
  317:       certPath: string | null
  318:       keyPath: string | null
  319:       status: string
  320:     }
  321:   }
  322:   state: {
  323:     originalIngress: string | null
  324:     originalEgress: string | null
  325:   }
  326: }): Promise<void> {
  327:   if (input.instance.host.status === 'online' && input.instance.host.certPath && input.instance.host.keyPath) {
  328:     const client = await getIncusClientFromPool({
  329:       id: input.instance.host.id,
  330:       url: input.instance.host.url,
  331:       certPath: input.instance.host.certPath,
  332:       keyPath: input.instance.host.keyPath
  333:     })
  334:     await restoreBandwidth(client, input.instance.incusId, input.state.originalIngress, input.state.originalEgress)
  335:   }
  336: 
  337:   await prisma.instance.update({
  338:     where: { id: input.instance.id },
  339:     data: {
  340:       limitsIngress: input.state.originalIngress,
  341:       limitsEgress: input.state.originalEgress
  342:     }
  343:   })
  344: }
  345: 
  346: async function applyQosLimit(input: {
  347:   instance: {
  348:     id: number
  349:     incusId: string
  350:     limitsIngress: string | null
  351:     limitsEgress: string | null
  352:     host: {
  353:       id: number
  354:       url: string
  355:       certPath: string | null
  356:       keyPath: string | null
  357:       status: string
  358:     }
  359:   }
  360:   tier: QosTier
  361:   state: {
  362:     originalIngress: string | null
  363:     originalEgress: string | null
  364:   } | null
  365: }): Promise<string | null> {
  366:   if (input.instance.host.status !== 'online' || !input.instance.host.certPath || !input.instance.host.keyPath) {
  367:     return null
  368:   }
  369: 
  370:   const limit = `${input.tier.bandwidthMbps}Mbit`
  371:   const client = await getIncusClientFromPool({
  372:     id: input.instance.host.id,
  373:     url: input.instance.host.url,
  374:     certPath: input.instance.host.certPath,
  375:     keyPath: input.instance.host.keyPath
  376:   })
  377: 
  378:   await restoreBandwidth(client, input.instance.incusId, limit, limit)
  379:   await prisma.instance.update({
  380:     where: { id: input.instance.id },
  381:     data: {
  382:       limitsIngress: limit,
  383:       limitsEgress: limit
  384:     }
  385:   })
  386: 
  387:   return limit
  388: }
