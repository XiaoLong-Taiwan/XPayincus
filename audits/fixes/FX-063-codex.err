   72:   if (/^\d+$/.test(trimmed)) {
   73:     const bytes = BigInt(trimmed)
   74:     const mbps = bytes / MB_IN_BYTES
   75:     return mbps > 0n ? `${mbps.toString()}Mbit` : null
   76:   }
   77: 
   78:   return undefined
   79: }
   80: 
   81: function bandwidthMbps(value: string | null | undefined): number | null {
   82:   const normalized = normalizePlanTrafficLimitSpeed(value)
   83:   if (!normalized) return null
   84:   return Number(normalized.slice(0, -'Mbit'.length))
   85: }
   86: 
   87: function mostRestrictiveBandwidth(...values: Array<string | null | undefined>): string | null {
   88:   const candidates = values
   89:     .map(value => bandwidthMbps(value))
   90:     .filter((value): value is number => value !== null)
   91:   if (candidates.length === 0) return null
   92:   return `${Math.min(...candidates)}Mbit`
   93: }
   94: 
   95: /**
   96:  * 单一带宽仲裁点：配置线速、流量超量和资源风控三者取最严格值。
   97:  * 正常线速只读取套餐/实例方案配置，绝不从当前实际 limits 字段捕获。
   98:  */
   99: export function computeEffectiveBandwidth(instance: BandwidthArbitrationSource): EffectiveBandwidth {
  100:   const planBaseline = normalizePlanTrafficLimitSpeed(instance.packagePlan?.trafficLimitSpeed)
  101:   const baselineIngress = planBaseline ?? instance.package?.limitsIngress ?? null
  102:   const baselineEgress = planBaseline ?? instance.package?.limitsEgress ?? null
  103:   const trafficConstraint = instance.trafficStatus === 'LIMITED' ? THROTTLE_BANDWIDTH : null
  104:   const riskConstraint = instance.resourceRiskState?.currentBandwidthLimit ?? null
  105: 
  106:   return {
  107:     ingress: mostRestrictiveBandwidth(baselineIngress, trafficConstraint, riskConstraint),
  108:     egress: mostRestrictiveBandwidth(baselineEgress, trafficConstraint, riskConstraint)
  109:   }
  110: }
  111: 
  112: /** 按数据库中仍生效的约束重算并落地实际带宽。 */
  113: export async function reconcileEffectiveBandwidth(instanceId: number, existingClient?: IncusClient): Promise<EffectiveBandwidth> {
  114:   const locked = await withLock(`bandwidth:instance:${instanceId}`, async () => {
  115:     const instance = await prisma.instance.findUnique({
  116:       where: { id: instanceId },
  117:       include: {
  118:         host: {
  119:           select: { id: true, url: true, certPath: true, keyPath: true, status: true }
  120:         },
  121:         package: {
  122:           select: { limitsIngress: true, limitsEgress: true }
  123:         },
  124:         packagePlan: {
  125:           select: { trafficLimitSpeed: true }
  126:         },
  127:         resourceRiskState: {
  128:           select: { currentBandwidthLimit: true }
  129:         }
  130:       }
  131:     })
  132:     if (!instance || instance.status === 'deleted') {
  133:       throw new Error(`Instance ${instanceId} is unavailable for bandwidth arbitration`)
  134:     }
  135: 
  136:     const effective = computeEffectiveBandwidth(instance)
  137:     if (instance.host.status === 'online' && instance.host.certPath && instance.host.keyPath) {
  138:       const client = existingClient ?? await getIncusClientFromPool({
  139:         id: instance.host.id,
  140:         url: instance.host.url,
  141:         certPath: instance.host.certPath,
  142:         keyPath: instance.host.keyPath
  143:       })
  144:       await restoreBandwidth(client, instance.incusId, effective.ingress, effective.egress)
  145:     }
  146: 
  147:     await prisma.instance.update({
  148:       where: { id: instanceId },
  149:       data: {
  150:         limitsIngress: effective.ingress,
  151:         limitsEgress: effective.egress
  152:       }
  153:     })
  154:     return effective
  155:   }, { expireMs: 30_000, waitTimeoutMs: 10_000, retryIntervalMs: 50 })
  156: 
  157:   if (!locked.success || !locked.result) {
  158:     throw new Error(locked.error || `Failed to arbitrate bandwidth for instance ${instanceId}`)
  159:   }
  160:   return locked.result
  161: }
