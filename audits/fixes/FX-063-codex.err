  756: export async function manualLimitInstanceRisk(input: {
  757:   instanceId: number
  758:   actorUserId: number
  759:   bandwidthMbps: number
  760:   reason: string
  761:   restrictOrders?: boolean
  762: }) {
  763:   const reason = getManualReason(input.reason, '管理员人工限速')
  764:   const instance = await prisma.instance.findUnique({
  765:     where: { id: input.instanceId },
