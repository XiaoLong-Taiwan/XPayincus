 697: /**
 698:  * 重置所有用户的月度流量用量
 699:  */
 700: export async function resetAllUserMonthlyTraffic() {
 701:     const quotas = await prisma.userQuota.findMany({
 702:         select: { userId: true }
 703:     })
 704: 
 705:     let count = 0
 706:     for (const quota of quotas) {
 707:         const result = await withLock(getTrafficUserLockKey(quota.userId), async () => {
 708:             const updated = await prisma.userQuota.updateMany({
 709:                 where: { userId: quota.userId },
 710:                 data: {
 711:                     monthlyTrafficUsed: 0n,
 712:                     trafficStatus: 'NORMAL',
 713:                     trafficWarningSentAt: null
 714:                 }
 715:             })
 716:             return updated.count
 717:         }, TRAFFIC_RESET_LOCK_OPTIONS)
 718: 
 719:         if (!result.success || result.result === undefined) {
 720:             throw new Error(result.error || `用户 ${quota.userId} 流量重置锁获取失败`)
 721:         }
 722:         count += result.result
 723:     }
 724: 
 725:     return { count }
 726: }
