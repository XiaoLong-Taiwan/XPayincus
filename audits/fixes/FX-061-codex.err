 551: export async function runDailyHostTrafficResetJob(): Promise<void> {
 552:     const today = trafficDb.shanghaiDateParts().day
 553:     console.log(`[Traffic] Starting daily host traffic reset check (today is day ${today})...`)
 554: 
 555:     try {
 556:         // 查找今天需要重置的节点
 557:         const { prisma } = await import('../db/prisma.js')
 558:         const hostsToReset = await prisma.host.findMany({
 559:             where: { trafficResetDay: today },
 560:             select: { id: true, name: true }
 561:         })
 562: 
 563:         if (hostsToReset.length === 0) {
 564:             console.log('[Traffic] No hosts need traffic reset today')
 565:             return
 566:         }
 567: 
 568:         console.log(`[Traffic] Found ${hostsToReset.length} hosts to reset: ${hostsToReset.map(h => h.name).join(', ')}`)
 569: 
 570:         // 重置这些节点下所有实例的流量
 571:         const hostIds = hostsToReset.map(h => h.id)
 572:         await trafficDb.resetHostInstancesMonthlyTraffic(hostIds)
 573: 
 574:         const instances = await trafficDb.getRunningInstancesForTraffic()
 575:         const instancesToReconcile = instances.filter(i => hostIds.includes(i.host.id))
 576:         await reconcileTrafficState(instancesToReconcile)
 577: 
 578:         console.log(`[Traffic] Daily host traffic reset completed for ${hostsToReset.length} hosts`)
 579:     } catch (error) {
 580:         console.error('[Traffic] Daily host traffic reset failed:', error)
 581:     }
 582: }
