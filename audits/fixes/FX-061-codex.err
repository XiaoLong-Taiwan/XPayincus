}

/**
 * èŽ·å–å®žä¾‹çš„æ¯æ—¥æµé‡åŽ†å²
 */
export async function getDailyTraffic(instanceId: number, days: number = 30) {
    const startDate = shanghaiDateOnly(new Date(), -days)

    return prisma.dailyTraffic.findMany({
        where: {
            instanceId,
            date: { gte: startDate }
        },
        orderBy: { date: 'asc' }
    })
}

/**
 * èŽ·å–å®žä¾‹çš„æ¯æ—¥æµé‡åŽ†å²ï¼ˆæŒ‰å‘¨æœŸï¼‰
 * @param instanceId å®žä¾‹ ID
 * @param periodStart å‘¨æœŸå¼€å§‹æ—¥æœŸ
 */
export async function getDailyTrafficByPeriod(instanceId: number, periodStart: Date) {
    return prisma.dailyTraffic.findMany({
        where: {
            instanceId,
            date: { gte: periodStart }
        },
        orderBy: { date: 'asc' }
    })
}

/**
 * èŽ·å–èŠ‚ç‚¹çš„æ¯æ—¥æµé‡åŽ†å²ï¼ˆèšåˆè¯¥èŠ‚ç‚¹ä¸‹æ‰€æœ‰å®žä¾‹çš„æµé‡ï¼‰
 * æ ¹æ®èŠ‚ç‚¹çš„ trafficResetDay è®¡ç®—å‘¨æœŸèµ·å§‹æ—¥æœŸ
 * @param hostId èŠ‚ç‚¹ ID
 * @param trafficResetDay æµé‡é‡ç½®æ—¥ï¼ˆé»˜è®¤ 1ï¼‰
 */
export async function getHostDailyTraffic(hostId: number, trafficResetDay: number = 1) {
    const day = Math.max(1, Math.min(28, trafficResetDay))
    const now = new Date()
    const { year, month, day: currentDay } = shanghaiDateParts(now)
    const periodStart = currentDay >= day
        ? new Date(Date.UTC(year, month, day))
        : new Date(Date.UTC(year, month - 1, day))

    // ä½¿ç”¨åŽŸç”Ÿ SQL è¿›è¡ŒèšåˆæŸ¥è¯¢
    // æŒ‰æ—¥æœŸåˆ†ç»„ï¼ŒèšåˆèŠ‚ç‚¹ä¸‹æ‰€æœ‰å½“å‰å­˜åœ¨çš„å®žä¾‹çš„æµé‡
    // æ³¨æ„ï¼šSUM() è¿”å›ž numeric ç±»åž‹ï¼Œå¿…é¡»æ˜¾å¼è½¬æ¢ä¸º bigintï¼Œå¦åˆ™ Prisma è¿”å›ž Decimal å¯¹è±¡
    const result = await prisma.$queryRaw<Array<{
        date: Date
        rx_total: bigint
        tx_total: bigint
    }>>`
        SELECT 
            dt.date,
            COALESCE(SUM(dt.rx_total), 0)::bigint as rx_total,
            COALESCE(SUM(dt.tx_total), 0)::bigint as tx_total
        FROM daily_traffic dt
        INNER JOIN instances i ON dt.instance_id = i.id
        WHERE i.host_id = ${hostId}
          AND i.status != 'deleted'
          AND dt.date >= ${periodStart}
        GROUP BY dt.date
        ORDER BY dt.date ASC
    `

    return result.map(row => ({
        date: row.date,
        rxTotal: row.rx_total,
        txTotal: row.tx_total
    }))
}

