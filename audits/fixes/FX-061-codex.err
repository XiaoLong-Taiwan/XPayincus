 728: /**
 729:  * 重置所有实例的月度流量用量
 730:  */
 731: export async function resetAllInstanceMonthlyTraffic() {
 732:     const instances = await prisma.instance.findMany({
 733:         where: {
 734:             status: { not: 'deleted' }
 735:         },
 736:         select: { id: true }
 737:     })
 738: 
 739:     let count = 0
 740:     for (const instance of instances) {
 741:         const result = await resetInstanceMonthlyTraffic(instance.id)
 742:         count += result.count
 743:     }
 744: 
 745:     return { count }
 746: }
 747: 
 748: /**
 749:  * 重置单个实例的月度流量用量
 750:  */
 751: export async function resetInstanceMonthlyTraffic(instanceId: number) {
 752:     const result = await withLock(getTrafficInstanceLockKey(instanceId), async () => {
 753:         const sample = await getTrafficResetSample(instanceId)
 754:         return prisma.$transaction(async tx => {
 755:             await advanceTrafficSnapshot(tx, instanceId, sample)
 756:             return tx.instance.updateMany({
 757:                 where: {
 758:                     id: instanceId,
 759:                     status: { not: 'deleted' }
 760:                 },
 761:                 data: {
 762:                     monthlyTrafficUsed: 0n,
 763:                     trafficStatus: 'NORMAL'
 764:                 }
 765:             })
 766:         })
 767:     }, TRAFFIC_RESET_LOCK_OPTIONS)
 768: 
 769:     if (!result.success || !result.result) {
 770:         throw new Error(result.error || `实例 ${instanceId} 流量重置锁获取失败`)
 771:     }
 772: 
 773:     return result.result
 774: }
