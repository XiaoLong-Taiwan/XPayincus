 203: /**
 204:  * 检查并恢复带宽
 205:  */
 206: async function checkAndRestore(
 207:     instance: RunningTrafficInstance,
 208:     client: IncusClient
 209: ): Promise<void> {
 210:     const userQuota = instance.user.quota
 211:     if (!userQuota) return
 212: 
 213:     const userEffectiveLimit = getEffectiveLimit(userQuota.monthlyTrafficLimit, userQuota.extraTrafficQuota)
 214:     const instanceLimit = getEffectiveLimit(instance.monthlyTrafficLimit, userQuota.extraTrafficQuota)
 215:     const instanceUsesExtraTraffic = instance.monthlyTrafficLimit !== null &&
 216:         instance.monthlyTrafficUsed >= instance.monthlyTrafficLimit
 217:     const extraTrafficExhausted = userQuota.extraTrafficQuota > 0n &&
 218:         userQuota.extraTrafficUsed >= userQuota.extraTrafficQuota
 219: 
 220:     const userUnderLimit = !isOverLimit(userQuota.monthlyTrafficUsed, userEffectiveLimit)
 221:     const instanceUnderLimit = !isOverLimit(instance.monthlyTrafficUsed, instanceLimit) &&
 222:         !(instanceUsesExtraTraffic && extraTrafficExhausted)
 223:     const desiredUserStatus = calculateUserTrafficStatus(userQuota.monthlyTrafficUsed, userEffectiveLimit)
 224: 
 225:     if (userUnderLimit && instanceUnderLimit) {
 226:         try {
 227:             if (instance.trafficStatus === 'LIMITED') {
 228:                 // 只清除流量约束；仲裁会保留仍生效的风控 QoS。
 229:                 await trafficDb.updateInstanceTrafficStatus(instance.id, 'NORMAL')
 230:             }
 231:             await reconcileEffectiveBandwidth(instance.id, client)
 232: 
 233:             if (userQuota.trafficStatus !== desiredUserStatus) {
 234:                 await trafficDb.updateUserTrafficStatus(instance.userId, desiredUserStatus)
 235:             }
 236: 
 237:             console.log(`[Traffic] Restored bandwidth for instance ${instance.id}`)
 238:         } catch (error) {
 239:             console.error(`[Traffic] Failed to restore bandwidth for instance ${instance.id}:`, error)
 240:         }
 241:     }
 242: }
