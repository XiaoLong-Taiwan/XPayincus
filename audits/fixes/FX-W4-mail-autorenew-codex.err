+function normalizeMailSubscriptionAutoRenewInput(input: unknown): boolean {
+  if (!isPlainRecord(input) || typeof input.autoRenew !== 'boolean') {
+    throw apiError(ErrorCode.VALIDATION_ERROR, '自动续费设置无效')
+  }
+
+  return input.autoRenew
+}
+
