diff --git a/server/scripts/test-scheduler-startup-idempotency.ts b/server/scripts/test-scheduler-startup-idempotency.ts
index d888d55ab6921d9258c5f10e2bb66a40357cd3a5..c84144274dd788f333472ba7222544d9b3f6f244
--- a/server/scripts/test-scheduler-startup-idempotency.ts
