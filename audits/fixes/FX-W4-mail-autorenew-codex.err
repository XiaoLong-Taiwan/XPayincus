+      expiresAt: { gt: now, lte: deadline }
+    },
+    select: { id: true, userId: true, expiresAt: true },
+    orderBy: [{ expiresAt: 'asc' }, { id: 'asc' }]
   })
 }
diff --git a/server/src/routes/mail.ts b/server/src/routes/mail.ts
index 09345044c2e6b69b0d7c5be5a139b8e9d9dde61a..09293476914ac08517b21c18a2efd42757f27649
--- a/server/src/routes/mail.ts
+++ b/server/src/routes/mail.ts
