+    throw apiError(ErrorCode.VALIDATION_ERROR, '自动续费设置无效')
+  }
+
+  return input.autoRenew
+}
+
 function normalizeMailSubscriptionCancelInput(input: unknown): MailSubscriptionCancelInput {
