/**
 * æ ¼å¼åŒ–å†…å­˜å¤§å°
 */
function formatMemory(mb: number | undefined): string {
  if (!mb) return '-'
  if (mb >= 1024) return `${(mb / 1024).toFixed(1)} GB`
  return `${mb} MB`
}

/**
 * æ ¼å¼åŒ–ç£ç›˜å¤§å°
 */
function formatDisk(mb: number | undefined): string {
  if (!mb) return '-'
  if (mb >= 1024) return `${(mb / 1024).toFixed(0)} GB`
  return `${mb} MB`
}

