+    }
+
+    await createLog(
+      userId,
+      'mail',
+      'set_mail_auto_renew',
+      `${autoRenew ? 'Enabled' : 'Disabled'} mail subscription auto-renew for subscription #${subscription.id}`,
+      'success'
+    )
+
+    return { autoRenew: updateResult.autoRenew }
+  })
