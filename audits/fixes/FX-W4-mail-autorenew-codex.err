function normalizeBaseUrl(url: URL): string {
  return url.toString().replace(/\/+$/, '')
}

type MailPlanInput = {
  sourceId?: number
  name?: string
  description?: string
  domainLimit?: number
  diskLimitGb?: number
  billingCycle?: 'monthly' | 'yearly'
  price?: number
  enabled?: boolean
  sortOrder?: number
}

type MailSourceInput = {
