      rollupOptions: {
        output: {
          // ä½¿ç”¨çº¯å“ˆå¸Œå‘½åï¼Œä¸åŒ…å«æ–‡ä»¶åï¼Œæé«˜å®‰å…¨æ€§
          chunkFileNames: 'assets/[hash].js',
