+      if (!locked) {
+        return { error: apiError(ErrorCode.OPERATION_NOT_ALLOWED, '邮箱订阅正在处理，请稍后重试') }
+      }
+
+      const updated = await tx.mailSubscription.updateMany({
+        where: { id: subscription.id, userId },
