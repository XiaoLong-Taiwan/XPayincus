diff --git a/client/src/locales/zh-CN.ts b/client/src/locales/zh-CN.ts
index ef0ab595c091df70b945ade0f9f40da79fa97cba..7b2816a74a3396cdd5bc6365e4427f5bae3b9498
--- a/client/src/locales/zh-CN.ts
