  server\prisma\schema.prisma:4919:  domain         String           // 域名
  server\prisma\schema.prisma:4920:  status         MailDomainStatus @default(pending)
  server\prisma\schema.prisma:4921:  adminUsername  String?          @map("admin_username") // CraneMail 返回的管理员账号
  server\prisma\schema.prisma:4922:  adminPassword  String?          @map("admin_password") // CraneMail 返回的管理员密码（加密存储）
  server\prisma\schema.prisma:4923:  diskUsedMb     Int              @default(0) @map("disk_used_mb") // 已用空间 MB
  server\prisma\schema.prisma:4924:  verifiedAt     DateTime?        @map("verified_at")
  }, async () => {
    if (!await db.hasAvailableMailOffering()) {
      return { sources: [] }
    }

    const sources = await db.getAllMailSources(false)
    
    const sourcesWithPlans = await Promise.all(
      sources.map(async (source) => {
        const plans = await db.getMailPlansBySource(source.id, false)
        return {
          id: source.id,
          name: source.name,
          code: source.code,
          plans: plans.map(plan => ({
            id: plan.id,
            name: plan.name,
            description: plan.description,
            domainLimit: plan.domainLimit,
            diskLimitGb: plan.diskLimitGb,
            billingCycle: plan.billingCycle,
            price: Number(plan.price)
          }))
        }
      })
    )
    
    return { sources: sourcesWithPlans }
  })

