 377: async function autoSuspendInstance(input: {
 378:   instance: {
 379:     id: number
 380:     incusId: string
 381:     name: string
 382:     userId: number
 383:     status: string
 384:     host: {
 385:       id: number
 386:       url: string
 387:       certPath: string | null
 388:       keyPath: string | null
 389:       status: string
 390:     }
 391:   }
 392:   reason: string
 393: }) {
 394:   if (input.instance.status === 'suspended') return
 395: 
 396:   await prisma.instance.update({
 397:     where: { id: input.instance.id },
 398:     data: {
 399:       status: 'suspended',
 400:       suspendedAt: new Date(),
 401:       suspendedBy: null,
 402:       suspendReason: input.reason,
 403:       version: { increment: 1 }
 404:     }
 405:   })
 406: 
 407:   if (input.instance.host.status === 'online' && input.instance.host.certPath && input.instance.host.keyPath) {
 408:     const client = await getIncusClientFromPool({
 409:       id: input.instance.host.id,
 410:       url: input.instance.host.url,
 411:       certPath: input.instance.host.certPath,
 412:       keyPath: input.instance.host.keyPath
 413:     })
 414:     await stopInstance(client, input.instance.incusId, true)
 415:   }
 416: 
 417:   await sendNotification(input.instance.userId, 'instance_suspended', {
 418:     instanceName: input.instance.name,
 419:     suspendReason: input.reason
 420:   }).catch((error) => {
 421:     console.error('[ResourceRisk] Failed to send suspend notification:', error)
 422:   })
 423: }
