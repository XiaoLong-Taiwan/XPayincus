 247: function projectRisk(input: {
 248:   samples: Parameters<typeof buildRiskTriggers>[0]['samples']
 249:   policy: RiskPolicy
 250:   previousScore: number
 251:   lastEvaluatedAt: Date | null | undefined
 252: }): RiskProjection {
 253:   const now = new Date()
 254:   const { triggers, evidence } = buildRiskTriggers({ samples: input.samples, policy: input.policy })
 255:   const elapsedHours = input.lastEvaluatedAt ? Math.max(0, (now.getTime() - input.lastEvaluatedAt.getTime()) / 3_600_000) : 0
 256:   const decay = triggers.length === 0 ? Math.floor(elapsedHours * input.policy.scoreDecayPerHour) : 0
 257:   const scoreDelta = triggers.reduce((sum, trigger) => sum + trigger.delta, 0)
 258:   const nextScore = clampScore(input.previousScore + scoreDelta - decay)
 259:   const qosTiers = parseQosTiers(input.policy.qosTiers)
 260:   const targetTier = qosTiers.filter(tier => nextScore >= tier.score).at(-1) ?? null
 261:   const shouldRestrictOrders = Boolean(input.policy.accountOrderRestrictEnabled && (
 262:     nextScore >= input.policy.orderRestrictScore || targetTier?.restrictOrders
 263:   ))
 264: 
 265:   return {
 266:     previousScore: input.previousScore,
 267:     nextScore,
 268:     nextLevel: riskLevel(nextScore),
 269:     triggers,
 270:     evidence: {
 271:       ...evidence,
 272:       scoreDelta,
 273:       decay
 274:     },
 275:     qosTiers,
 276:     targetTier,
 277:     shouldRestrictOrders,
 278:     shouldAutoSuspend: input.policy.autoSuspendEnabled && nextScore >= input.policy.autoSuspendScore
 279:   }
 280: }
 281: 
 282: function qosTierEvidence(tier: QosTier | null): Record<string, unknown> | null {
 283:   if (!tier) return null
 284:   return {
 285:     level: tier.level,
 286:     bandwidthMbps: tier.bandwidthMbps,
 287:     score: tier.score,
 288:     recoverScore: tier.recoverScore,
 289:     minDurationMinutes: tier.minDurationMinutes,
 290:     cooldownMinutes: tier.cooldownMinutes,
 291:     allowFurtherDowngrade: tier.allowFurtherDowngrade,
 292:     notifyUser: tier.notifyUser,
 293:     restrictOrders: tier.restrictOrders
 294:   }
 295: }
