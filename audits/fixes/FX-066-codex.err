 180:     cpuPercent: unknown
 181:     pps: unknown
 182:     totalPacketsDelta: bigint | number | string | null
 183:     totalBytesDelta: bigint | number | string | null
 184:   }>
 185:   policy: RiskPolicy
 186: }): { triggers: RiskTrigger[]; evidence: Record<string, unknown> } {
 187:   const { samples, policy } = input
 188:   const bandwidthHits = samples.filter(sample => decimalToNumber(sample.totalMbps) >= policy.bandwidthThresholdMbps)
 189:   const cpuHits = samples.filter(sample => sample.cpuPercent !== null && decimalToNumber(sample.cpuPercent) >= policy.cpuThresholdPercent)
 190:   const ppsHits = samples.filter(sample => decimalToNumber(sample.pps) >= policy.ppsThreshold)
 191:   const smallPacketHits = samples.filter(sample => {
 192:     const packets = Number(sample.totalPacketsDelta)
 193:     if (packets <= 0) return false
 194:     const averageBytes = Number(sample.totalBytesDelta) / packets
 195:     return averageBytes > 0 && averageBytes <= 300 && decimalToNumber(sample.pps) >= policy.ppsThreshold * 0.5
 196:   })
 197: 
 198:   const triggers: RiskTrigger[] = []
 199:   if (bandwidthHits.length >= sampleThresholdCount(policy.bandwidthActiveMinutes)) {
 200:     triggers.push({
 201:       type: 'bandwidth_sustained',
 202:       message: `实例持续带宽超过 ${policy.bandwidthThresholdMbps} Mbps`,
 203:       delta: 18,
 204:       severity: 'medium'
 205:     })
 206:   }
 207:   if (cpuHits.length >= sampleThresholdCount(policy.cpuActiveMinutes)) {
 208:     triggers.push({
 209:       type: 'cpu_sustained',
 210:       message: `实例 CPU 持续超过 ${policy.cpuThresholdPercent}%`,
 211:       delta: 15,
 212:       severity: 'medium'
 213:     })
 214:   }
 215:   if (ppsHits.length >= 3) {
 216:     triggers.push({
 217:       type: 'packet_anomaly',
 218:       message: `实例 PPS 超过 ${policy.ppsThreshold}`,
 219:       delta: 25,
 220:       severity: 'high'
 221:     })
 222:   }
 223:   if (smallPacketHits.length >= 3) {
 224:     triggers.push({
 225:       type: 'scan_suspected',
 226:       message: '实例存在小包高频发包特征，疑似扫描或异常发包',
 227:       delta: 25,
 228:       severity: 'high'
 229:     })
 230:   }
 231: 
 232:   return {
 233:     triggers,
 234:     evidence: {
 235:       sampleCount: samples.length,
 236:       bandwidthHits: bandwidthHits.length,
 237:       cpuHits: cpuHits.length,
 238:       ppsHits: ppsHits.length,
 239:       smallPacketHits: smallPacketHits.length,
 240:       bandwidthThresholdMbps: policy.bandwidthThresholdMbps,
 241:       cpuThresholdPercent: policy.cpuThresholdPercent,
 242:       ppsThreshold: policy.ppsThreshold
 243:     }
 244:   }
 245: }
