 770: export async function releaseInstanceRisk(input: {
 771:   instanceId: number
 772:   actorUserId: number
 773:   reason: string
 774: }) {
 775:   const state = await prisma.instanceRiskState.findUnique({
 776:     where: { instanceId: input.instanceId },
 777:     include: {
 778:       instance: {
 779:         include: {
 780:           host: {
 781:             select: { id: true, url: true, certPath: true, keyPath: true, status: true }
 782:           }
 783:         }
 784:       }
 785:     }
 786:   })
 787:   if (!state) return null
 788: 
 789:   if ((state.qosLevel > 0 || state.currentBandwidthLimit) && state.instance.host.status === 'online' && state.instance.host.certPath && state.instance.host.keyPath) {
 790:     const client = await getIncusClientFromPool({
 791:       id: state.instance.host.id,
 792:       url: state.instance.host.url,
 793:       certPath: state.instance.host.certPath,
 794:       keyPath: state.instance.host.keyPath
 795:     })
 796:     await restoreBandwidth(client, state.instance.incusId, state.originalIngress, state.originalEgress)
 797:     await prisma.instance.update({
 798:       where: { id: state.instanceId },
 799:       data: {
 800:         limitsIngress: state.originalIngress,
 801:         limitsEgress: state.originalEgress
 802:       }
 803:     })
 804:   }
 805: 
 806:   const released = await prisma.instanceRiskState.update({
 807:     where: { instanceId: input.instanceId },
 808:     data: {
 809:       score: 0,
 810:       level: 'normal',
 811:       status: 'normal',
 812:       qosLevel: 0,
 813:       currentBandwidthLimit: null,
 814:       lastRecoveredAt: new Date(),
 815:       reason: input.reason || '人工解除风控',
 816:       evidence: {}
 817:     }
 818:   })
 819: 
 820:   await prisma.instanceRiskEvent.create({
 821:     data: {
 822:       instanceId: state.instanceId,
 823:       userId: state.userId,
 824:       hostId: state.hostId,
 825:       type: 'manual_release',
 826:       severity: 'low',
 827:       scoreDelta: -state.score,
 828:       scoreAfter: 0,
 829:       actionTaken: 'release',
 830:       message: input.reason || '管理员人工解除实例风控',
 831:       evidence: { actorUserId: input.actorUserId }
 832:     }
 833:   })
 834: 
 835:   await createLog(input.actorUserId, 'instance', 'resource_risk.release', `Released resource risk for instance #${input.instanceId}`, 'success', { instanceId: input.instanceId })
 836:   return released
 837: }
