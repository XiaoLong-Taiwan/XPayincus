 425: export async function evaluateInstanceRisk(instanceId: number, policyInput?: RiskPolicy) {
 426:   const policy = policyInput ?? await getDefaultPolicy()
 427:   if (!policy.enabled) return null
 428: 
 429:   const instance = await prisma.instance.findUnique({
 430:     where: { id: instanceId },
 431:     include: {
 432:       host: {
 433:         select: {
 434:           id: true,
 435:           name: true,
 436:           status: true,
 437:           url: true,
 438:           certPath: true,
 439:           keyPath: true
 440:         }
 441:       },
 442:       resourceRiskState: true
 443:     }
 444:   })
 445: 
 446:   if (!instance || instance.status === 'deleted') return null
 447: 
 448:   const now = new Date()
 449:   const windowMinutes = Math.max(policy.bandwidthWindowMinutes, policy.cpuWindowMinutes)
 450:   const samples = await prisma.instanceResourceSample.findMany({
 451:     where: {
 452:       instanceId,
 453:       sampledAt: {
 454:         gte: new Date(now.getTime() - windowMinutes * 60 * 1000)
 455:       }
 456:     },
 457:     orderBy: { sampledAt: 'desc' },
 458:     take: 500
 459:   })
 460: 
 461:   const previousScore = instance.resourceRiskState?.score ?? 0
 462:   const projection = projectRisk({
 463:     samples,
 464:     policy,
 465:     previousScore,
 466:     lastEvaluatedAt: instance.resourceRiskState?.lastEvaluatedAt
 467:   })
 468:   const {
 469:     triggers,
 470:     nextScore,
 471:     nextLevel,
 472:     qosTiers,
 473:     targetTier,
 474:     shouldRestrictOrders,
 475:     shouldAutoSuspend
 476:   } = projection
 477: 
 478:   const currentStatus = instance.resourceRiskState?.status ?? 'normal'
 479:   const manualLocked = currentStatus === 'manual_suspended' || currentStatus === 'manual_qos_limited'
 480:   const currentQosLevel = instance.resourceRiskState?.qosLevel ?? 0
 481:   const currentTier = currentQosLevel > 0 ? (qosTiers.find(tier => tier.level === currentQosLevel) ?? null) : null
 482:   const lastActionMinutes = minutesSince(instance.resourceRiskState?.lastTriggeredAt, now)
 483: 
 484:   let actionTaken: string | null = manualLocked ? 'manual_state_preserved' : null
 485:   let bandwidthLimit: string | null = instance.resourceRiskState?.currentBandwidthLimit ?? null
 486:   let nextQosLevel = currentQosLevel
 487:   let nextStatus = shouldAutoSuspend && !manualLocked ? 'suspended' : (currentQosLevel > 0 ? 'qos_limited' : nextLevel)
 488:   let nextLastTriggeredAt: Date | undefined
 489:   let nextLastRecoveredAt: Date | undefined
 490:   let effectiveTargetTier = targetTier
 491: 
 492:   const canRecoverQos = !manualLocked &&
 493:     currentTier &&
 494:     triggers.length === 0 &&
 495:     nextScore <= currentTier.recoverScore &&
 496:     (lastActionMinutes === null || lastActionMinutes >= currentTier.minDurationMinutes)
 497: 
 498:   if (canRecoverQos) {
 499:     try {
 500:       await restoreQosLimit({
 501:         instance,
 502:         state: {
 503:           originalIngress: instance.resourceRiskState?.originalIngress ?? null,
 504:           originalEgress: instance.resourceRiskState?.originalEgress ?? null
 505:         }
 506:       })
 507:       actionTaken = 'qos_recovered'
 508:       bandwidthLimit = null
 509:       nextQosLevel = 0
 510:       nextStatus = nextLevel
 511:       effectiveTargetTier = null
 512:       nextLastRecoveredAt = now
 513:     } catch (error) {
 514:       console.error(`[ResourceRisk] Failed to recover QoS for instance ${instance.id}:`, error)
 515:     }
 516:   }
 517: 
 518:   const canEscalateQos = !manualLocked &&
 519:     effectiveTargetTier &&
 520:     effectiveTargetTier.level > nextQosLevel &&
 521:     (!currentTier || currentTier.allowFurtherDowngrade) &&
 522:     (lastActionMinutes === null || lastActionMinutes >= effectiveTargetTier.cooldownMinutes)
 523: 
 524:   if (canEscalateQos && effectiveTargetTier) {
 525:     try {
 526:       bandwidthLimit = await applyQosLimit({
 527:         instance,
 528:         tier: effectiveTargetTier,
 529:         state: instance.resourceRiskState
 530:       })
 531:       if (bandwidthLimit) {
 532:         nextQosLevel = effectiveTargetTier.level
 533:         nextStatus = 'qos_limited'
 534:         nextLastTriggeredAt = now
 535:         actionTaken = `qos_level_${effectiveTargetTier.level}`
 536:         if (effectiveTargetTier.notifyUser) {
 537:           await sendNotification(instance.userId, 'resource_risk_qos_limited', {
 538:             instanceName: instance.name,
 539:             hostName: instance.host.name,
 540:             bandwidthLimit,
 541:             score: nextScore,
 542:             reason: triggers.map(trigger => trigger.message).join('；') || '资源使用触发自动风控'
 543:           }).catch((error) => {
 544:             console.error('[ResourceRisk] Failed to send QoS notification:', error)
 545:           })
 546:         }
 547:       }
 548:     } catch (error) {
 549:       console.error(`[ResourceRisk] Failed to apply QoS for instance ${instance.id}:`, error)
 550:     }
 551:   }
 552: 
 553:   if (!manualLocked && effectiveTargetTier && effectiveTargetTier.level <= nextQosLevel) {
 554:     nextStatus = 'qos_limited'
 555:   }
 556: 
 557:   if (manualLocked) {
 558:     nextStatus = currentStatus
 559:   }
 560: 
 561:   if (shouldAutoSuspend && !manualLocked) {
 562:     try {
 563:       await autoSuspendInstance({
 564:         instance,
 565:         reason: 'resource_risk_auto_suspend'
 566:       })
 567:       actionTaken = actionTaken ? `${actionTaken},auto_suspend` : 'auto_suspend'
 568:       nextStatus = 'suspended'
 569:     } catch (error) {
 570:       console.error(`[ResourceRisk] Failed to auto suspend instance ${instance.id}:`, error)
 571:     }
 572:   }
 573: 
 574:   const evidence: Record<string, unknown> = {
 575:     ...projection.evidence,
 576:     targetQosTier: qosTierEvidence(targetTier),
 577:     effectiveQosTier: qosTierEvidence(effectiveTargetTier),
 578:     currentQosTier: qosTierEvidence(currentTier),
 579:     manualStatePreserved: manualLocked,
 580:     lastActionMinutes,
 581:     recoveryBlocked: currentTier && triggers.length === 0 && !canRecoverQos
 582:       ? {
 583:           recoverScore: currentTier.recoverScore,
 584:           minDurationMinutes: currentTier.minDurationMinutes
 585:         }
 586:       : null,
 587:     escalationBlocked: effectiveTargetTier && effectiveTargetTier.level > nextQosLevel && !canEscalateQos
 588:       ? {
 589:           allowFurtherDowngrade: currentTier?.allowFurtherDowngrade ?? true,
 590:           cooldownMinutes: effectiveTargetTier.cooldownMinutes,
 591:           lastActionMinutes
 592:         }
 593:       : null
 594:   }
 595:   const evidenceJson = evidence as Prisma.InputJsonObject
 596: 
 597:   const state = await prisma.instanceRiskState.upsert({
 598:     where: { instanceId },
 599:     update: {
 600:       score: nextScore,
 601:       level: nextLevel,
 602:       status: nextStatus,
 603:       qosLevel: nextQosLevel,
 604:       currentBandwidthLimit: bandwidthLimit,
 605:       originalIngress: instance.resourceRiskState?.originalIngress ?? instance.limitsIngress,
 606:       originalEgress: instance.resourceRiskState?.originalEgress ?? instance.limitsEgress,
 607:       lastEvaluatedAt: now,
 608:       lastTriggeredAt: nextLastTriggeredAt,
 609:       lastRecoveredAt: nextLastRecoveredAt,
 610:       reason: triggers.at(-1)?.message ?? instance.resourceRiskState?.reason ?? null,
 611:       evidence: evidenceJson
 612:     },
 613:     create: {
 614:       instanceId,
 615:       userId: instance.userId,
 616:       hostId: instance.hostId,
 617:       score: nextScore,
 618:       level: nextLevel,
 619:       status: nextStatus,
