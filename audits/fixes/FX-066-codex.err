 297: async function restoreQosLimit(input: {
 298:   instance: {
 299:     id: number
 300:     incusId: string
 301:     host: {
 302:       id: number
 303:       url: string
 304:       certPath: string | null
 305:       keyPath: string | null
 306:       status: string
 307:     }
 308:   }
 309:   state: {
 310:     originalIngress: string | null
 311:     originalEgress: string | null
 312:   }
 313: }): Promise<void> {
 314:   if (input.instance.host.status === 'online' && input.instance.host.certPath && input.instance.host.keyPath) {
 315:     const client = await getIncusClientFromPool({
 316:       id: input.instance.host.id,
 317:       url: input.instance.host.url,
 318:       certPath: input.instance.host.certPath,
 319:       keyPath: input.instance.host.keyPath
 320:     })
 321:     await restoreBandwidth(client, input.instance.incusId, input.state.originalIngress, input.state.originalEgress)
 322:   }
 323: 
 324:   await prisma.instance.update({
 325:     where: { id: input.instance.id },
 326:     data: {
 327:       limitsIngress: input.state.originalIngress,
 328:       limitsEgress: input.state.originalEgress
 329:     }
 330:   })
 330:   })
 331: }
 332: 
 333: async function applyQosLimit(input: {
 334:   instance: {
 335:     id: number
 336:     incusId: string
 337:     limitsIngress: string | null
 338:     limitsEgress: string | null
 339:     host: {
 340:       id: number
 341:       url: string
 342:       certPath: string | null
 343:       keyPath: string | null
 344:       status: string
 345:     }
 346:   }
 347:   tier: QosTier
 348:   state: {
 349:     originalIngress: string | null
 350:     originalEgress: string | null
 351:   } | null
 352: }): Promise<string | null> {
 353:   if (input.instance.host.status !== 'online' || !input.instance.host.certPath || !input.instance.host.keyPath) {
 354:     return null
 355:   }
 356: 
 357:   const limit = `${input.tier.bandwidthMbps}Mbit`
 358:   const client = await getIncusClientFromPool({
 359:     id: input.instance.host.id,
 360:     url: input.instance.host.url,
 361:     certPath: input.instance.host.certPath,
 362:     keyPath: input.instance.host.keyPath
 363:   })
 364: 
 365:   await restoreBandwidth(client, input.instance.incusId, limit, limit)
 366:   await prisma.instance.update({
 367:     where: { id: input.instance.id },
 368:     data: {
 369:       limitsIngress: limit,
 370:       limitsEgress: limit
 371:     }
 372:   })
 373: 
 374:   return limit
 375: }
