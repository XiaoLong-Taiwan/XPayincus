 663: export async function simulateResourceRiskPolicy(policyInput?: RiskPolicy): Promise<ResourceRiskSimulationResult> {
 664:   const policy = policyInput ?? await getDefaultPolicy()
 665:   if (!policy.enabled) {
 666:     return {
 667:       sampledInstances: 0,
 668:       wouldTrigger: 0,
 669:       wouldQosLimit: 0,
 670:       wouldRestrictOrders: 0,
 671:       wouldAutoSuspend: 0,
 672:       tierHits: [],
 673:       topInstances: []
 674:     }
 675:   }
 676: 
 677:   const now = new Date()
 678:   const windowMinutes = Math.max(policy.bandwidthWindowMinutes, policy.cpuWindowMinutes)
 679:   const instances = await prisma.instance.findMany({
 680:     where: {
 681:       status: { in: ['running', 'suspended'] }
 682:     },
 683:     orderBy: { updatedAt: 'desc' },
 684:     take: 500,
 685:     include: {
 686:       resourceRiskState: true
 687:     }
 688:   })
 689:   const instanceIds = instances.map(instance => instance.id)
 690:   const samples = instanceIds.length > 0
 691:     ? await prisma.instanceResourceSample.findMany({
 692:         where: {
 693:           instanceId: { in: instanceIds },
 694:           sampledAt: {
 695:             gte: new Date(now.getTime() - windowMinutes * 60 * 1000)
 696:           }
 697:         },
 698:         orderBy: { sampledAt: 'desc' },
 699:         take: 5000
 700:       })
 701:     : []
 702: 
 703:   const samplesByInstanceId = new Map<number, typeof samples>()
 704:   for (const sample of samples) {
 705:     const items = samplesByInstanceId.get(sample.instanceId) ?? []
 706:     if (items.length < 500) {
 707:       items.push(sample)
 708:       samplesByInstanceId.set(sample.instanceId, items)
 709:     }
 710:   }
 711: 
 712:   const tierHitMap = new Map<number, { level: number; count: number; bandwidthMbps: number }>()
 713:   const topInstances: ResourceRiskSimulationResult['topInstances'] = []
 714:   let wouldTrigger = 0
 715:   let wouldQosLimit = 0
 716:   let wouldRestrictOrders = 0
 717:   let wouldAutoSuspend = 0
 718: 
 719:   for (const instance of instances) {
 720:     const projection = projectRisk({
 721:       samples: samplesByInstanceId.get(instance.id) ?? [],
 722:       policy,
 723:       previousScore: instance.resourceRiskState?.score ?? 0,
 724:       lastEvaluatedAt: instance.resourceRiskState?.lastEvaluatedAt
 725:     })
 726:     const manualLocked = instance.resourceRiskState?.status === 'manual_suspended' || instance.resourceRiskState?.status === 'manual_qos_limited'
 727:     const currentQosLevel = instance.resourceRiskState?.qosLevel ?? 0
 728:     const targetQosLevel = projection.targetTier?.level ?? null
 729:     const wouldApplyQos = Boolean(!manualLocked && projection.targetTier && projection.targetTier.level > currentQosLevel)
 730: 
 731:     if (projection.triggers.length > 0) wouldTrigger += 1
 732:     if (wouldApplyQos) wouldQosLimit += 1
 733:     if (!manualLocked && projection.shouldRestrictOrders) wouldRestrictOrders += 1
 734:     if (!manualLocked && projection.shouldAutoSuspend) wouldAutoSuspend += 1
 735:     if (projection.targetTier) {
 736:       const existing = tierHitMap.get(projection.targetTier.level)
 737:       tierHitMap.set(projection.targetTier.level, {
 738:         level: projection.targetTier.level,
 739:         count: (existing?.count ?? 0) + 1,
 740:         bandwidthMbps: projection.targetTier.bandwidthMbps
 741:       })
 742:     }
 743: 
 744:     topInstances.push({
 745:       instanceId: instance.id,
 746:       name: instance.name,
 747:       userId: instance.userId,
 748:       hostId: instance.hostId,
 749:       previousScore: projection.previousScore,
 750:       projectedScore: projection.nextScore,
