      env: {
        ...process.env,
        PATH: executionPath,
    await cleanupOldReleases(currentBackupPath)
  } catch (error) {
    const message = error instanceof Error ? error.message : String(error)
    await log(`æ—§ release æ¸…ç†å¤±è´¥ï¼š${message}`)
  }
}

