+  }
+
+  await mkdir(backupDir, { recursive: true })
+  const backupPath = join(backupDir, `db-pre-migrate-${targetVersion}-${timestamp}.sql`)
+  const temporaryPath = `${backupPath}.tmp`
+  await rm(temporaryPath, { force: true })
+
