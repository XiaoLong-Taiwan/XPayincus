codex
Vite 默认用 esbuild 打包配置时被当前文件沙箱阻止向工作区父目录探测。我已确认本机 Vite 支持 `--configLoader runner`，改用其等价的运行时配置加载器继续构建，不改项目配置文件。
exec
"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command '$env:VITE_APP_ENTRY='"'user'; pnpm exec vite build --configLoader runner; if ("'$LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; $env:VITE_APP_ENTRY='"'admin'; pnpm exec vite build --configLoader runner" in C:\Users\Administrator\Desktop\payinces\client
