  storagePoolName  String?        @map("storage_pool_name")
  image            String
  status           InstanceStatus @default(creating)
  cpu              Int
  memory           Int
  disk             Int
  ipv4             String?
  ipv6             String?
  networkMode      NetworkMode    @default(nat) @map("network_mode")
  sshPort          Int?           @map("ssh_port")
  rootPassword     String?        @map("root_password")
