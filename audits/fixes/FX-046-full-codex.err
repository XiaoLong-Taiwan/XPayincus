        console.error(`[Provisioning] IPv4 åˆ†é…é”™è¯¯:`, err)
        staticIpAllocationError = `NAT å†…ç½‘ IPv4 åˆ†é…é”™è¯¯: ${err instanceof Error ? err.message : String(err)}`
      }
    } else if (networkModeNeedsPublicIpv4(networkMode)) {
      publicIpv4Assignment = await prisma.$transaction(async (tx) => {
        return db.reservePublicIpv4ForInstance(tx, { hostId: host.id, instanceId })
      })
      if (!publicIpv4Assignment) {
        throw new Error(`å®¿ä¸»æœº ${host.name} æ²¡æœ‰å¯ç”¨ç‹¬ç«‹ IPv4 åœ°å€`)
      }
      staticIPv4 = publicIpv4Assignment.address
      console.log(`[Provisioning] åˆ†é…ç‹¬ç«‹ IPv4: ${staticIPv4}`)
    }

    // åˆ†é… IPv6ï¼ˆä»…å½“å­˜åœ¨ IPv6 å­ç½‘é…ç½®ä¸”æ˜¯ Routed æ¨¡å¼æ—¶ï¼Œå³éœ€è¦ç‹¬ç«‹ IPv6 åœ°å€ï¼‰
    // nat_ipv6 å’Œ ipv6_only ä»Žå­ç½‘åˆ†é…ç‹¬ç«‹ IPv6ï¼Œnat_ipv6_nat å’Œ ipv6_nat å…±äº«å®¿ä¸»æœº IPv6
    const needsRoutedIPv6 = networkModeNeedsRoutedIpv6(networkMode)
    if (needsRoutedIPv6) {
      if (!hostWithIpv6.ipv6_subnet) {
        staticIpAllocationError ||= 'å®¿ä¸»æœºæœªé…ç½® routed IPv6 å­ç½‘'
        console.error(`[Provisioning] ${staticIpAllocationError}`)
      } else try {
        let attempts = 0
        const maxAttempts = 50

        while (attempts < maxAttempts) {
          staticIPv6 = generateRandomIPv6(hostWithIpv6.ipv6_subnet)
          const exists = await db.isIpAddressExists(staticIPv6)

          if (!exists) {
            console.log(`[Provisioning] åˆ†é…é™æ€ IPv6: ${staticIPv6} (å°è¯•æ¬¡æ•°: ${attempts + 1})`)
            break
          }

          attempts++
          staticIPv6 = null
        }

        if (!staticIPv6) {
          staticIpAllocationError ||= `routed IPv6 åˆ†é…å¤±è´¥ï¼ˆå·²å°è¯• ${maxAttempts} æ¬¡ï¼‰`
          console.error(`[Provisioning] ${staticIpAllocationError}`)
        }
      } catch (err) {
        console.error(`[Provisioning] routed IPv6 åˆ†é…é”™è¯¯:`, err)
        staticIPv6 = null
        staticIpAllocationError ||= `routed IPv6 åˆ†é…é”™è¯¯: ${err instanceof Error ? err.message : String(err)}`
      }
    }

    if (staticIpAllocationError) {
      throw new Error(staticIpAllocationError)
    }

    console.log(`[Provisioning] IP åˆ†é…å®Œæˆ: IPv4=${staticIPv4}, IPv6=${staticIPv6}`)

    // VM å’Œå®¹å™¨éƒ½éœ€è¦åœ¨ IP åˆ†é…å®ŒæˆåŽé‡æ–°ç”Ÿæˆ cloud-init network-config
    // ç¡®ä¿é™æ€ IPv4 å’Œ IPv6 åœ°å€æ­£ç¡®æ³¨å…¥åˆ° guest OS
    const ipv4Cidr = publicIpv4Assignment
      ? `${publicIpv4Assignment.address}/${publicIpv4Assignment.prefixLength}`
      : (staticIPv4 ? `${staticIPv4}/22` : null)
model Instance {
  id               Int            @id @default(autoincrement())
  incusId          String         @map("incus_id")
