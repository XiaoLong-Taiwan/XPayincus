index 0000000000000000000000000000000000000000..ec162795da4e21b8c596e6b5f9006e2fa505c515
--- /dev/null
+++ b/server/prisma/migrations/20260711000000_add_instance_idempotency_key/migration.sql
@@ -0,0 +1,5 @@
+-- AlterTable
+ALTER TABLE "instances" ADD COLUMN "idempotency_key" TEXT;
+
