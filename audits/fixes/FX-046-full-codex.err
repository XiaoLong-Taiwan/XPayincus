+      name: true,
+      incusId: true,
+      userId: true,
+      hostId: true,
+      status: true,
+      sshPort: true
+    }
+  })
+  if (!instance || instance.userId !== userId) {
+    return null
+  }
+
+  const host = await db.getHostById(instance.hostId)
+  return {
+    message: 'Instance request already accepted',
+    instance: {
+      id: instance.id,
+      name: instance.name,
+      incusId: instance.incusId,
+      host: host?.name || '',
+      status: instance.status,
+      sshPort: instance.sshPort
+    }
+  }
