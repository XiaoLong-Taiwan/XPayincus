  limitsCpuPriority Int? @map("limits_cpu_priority")

  // å¯åŠ¨é…ç½®
  bootAutostart           Boolean? @map("boot_autostart")
  bootAutostartPriority   Int?     @map("boot_autostart_priority")
  bootAutostartDelay      Int?     @map("boot_autostart_delay")
  bootHostShutdownTimeout Int?     @map("boot_host_shutdown_timeout")

  // æ¢å¤æ¥æºä¿¡æ¯
  restoredFrom Json? @map("restored_from") // { backupId, backupName, restoredAt }

  // ========== è®¡è´¹ä¸Žå°åœç›¸å…³å­—æ®µ ==========
  // åˆ°æœŸæ—¶é—´ï¼šnull è¡¨ç¤ºæ°¸ä¸åˆ°æœŸï¼ˆå…è´¹å®žä¾‹ï¼‰ï¼Œæœ‰å€¼è¡¨ç¤ºä»˜è´¹å®žä¾‹çš„åˆ°æœŸæ—¶é—´
  expiresAt        DateTime? @map("expires_at")
  // å°åœä¿¡æ¯
  suspendedAt      DateTime? @map("suspended_at")      // å°åœæ—¶é—´
  suspendedBy      Int?      @map("suspended_by")      // å°åœæ“ä½œè€…ï¼ˆnull=ç³»ç»Ÿè‡ªåŠ¨ï¼Œæœ‰å€¼=ç”¨æˆ·IDï¼‰
  suspendReason    String?   @map("suspend_reason")    // å°åœåŽŸå› ï¼ˆexpired=åˆ°æœŸå°åœï¼Œå…¶ä»–=æ‰‹åŠ¨å°åœåŽŸå› ï¼‰
  // è®¡è´¹ä»·æ ¼ï¼ˆä»Žæ–¹æ¡ˆå¤åˆ¶ï¼Œæ”¯æŒåŽç»­è°ƒæ•´ï¼‰
  billingPrice     Decimal?  @map("billing_price") @db.Decimal(10, 2)  // å•å‘¨æœŸä»·æ ¼
  billingCycle     Int?      @map("billing_cycle")  // è®¡è´¹å‘¨æœŸï¼ˆæœˆï¼‰
  // è‡ªåŠ¨ç»­è´¹
  autoRenew        Boolean   @default(false) @map("auto_renew")
  iconBadgeId      String?   @map("icon_badge_id")
  autoRenewAttempts     Int        @default(0) @map("auto_renew_attempts")      // å·²å°è¯•æ¬¡æ•°
  lastAutoRenewAttemptAt DateTime? @map("last_auto_renew_attempt_at")           // ä¸Šæ¬¡å°è¯•æ—¶é—´
  // åˆ°æœŸæé†’è®°å½•
  expiryNotifiedAt DateTime? @map("expiry_notified_at") // ä¸Šæ¬¡å‘é€åˆ°æœŸæé†’æ—¶é—´
