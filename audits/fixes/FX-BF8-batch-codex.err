          idempotencyKey: { type: 'string', maxLength: 128 },
          turnstileToken: { type: 'string', maxLength: 2048 },
          customInitCommandIds: { type: 'array', items: { type: 'integer' }, maxItems: 20 },
          promoCode: { type: 'string', maxLength: 32 }
        }
      }
