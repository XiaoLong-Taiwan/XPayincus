+        // 并封顶于已购买额度，避免调度任务重跑时重复累加。
+        const extraTrafficUsedByUser = new Map<number, bigint>()
+        for (const instance of instances) {
+            const quota = instance.user.quota
+            if (!quota || extraTrafficUsedByUser.has(instance.userId)) continue
+
+            const monthlyTrafficUsed = userUpdatedUsage.get(instance.userId) ?? quota.monthlyTrafficUsed
+            const extraTrafficUsed = quota.monthlyTrafficLimit === null
+                ? 0n
+                : monthlyTrafficUsed > quota.monthlyTrafficLimit
+                    ? monthlyTrafficUsed - quota.monthlyTrafficLimit > quota.extraTrafficQuota
+                        ? quota.extraTrafficQuota
+                        : monthlyTrafficUsed - quota.monthlyTrafficLimit
+                    : 0n
+            extraTrafficUsedByUser.set(instance.userId, extraTrafficUsed)
+        }
+        await Promise.all(Array.from(extraTrafficUsedByUser, ([userId, extraTrafficUsed]) => (
+            trafficDb.updateUserExtraTrafficUsed(userId, extraTrafficUsed)
+        )))
+
         // 构建用于限速检查的实例列表
         const instancesToCheck = Array.from(instancesToCheckForThrottle)
             .map(instanceId => instanceMap.get(instanceId))
@@ -511,7 +532,8 @@
                         ...instance.user,
                         quota: instance.user.quota ? {
                             ...instance.user.quota,
-                            monthlyTrafficUsed: updatedUserUsage
+                            monthlyTrafficUsed: updatedUserUsage,
+                            extraTrafficUsed: extraTrafficUsedByUser.get(instance.userId) ?? instance.user.quota.extraTrafficUsed
                         } : null
                     }
                 }

codex
复核时发现一个必须修正的边界：若用户级基础限额为 `null`、只有实例基础限额（这正是常规场景），按“用户基础限额超额”计算会让 `extraTrafficUsed` 仍为 0。我要把它改为对该用户所有未删除实例的“`monthlyTrafficUsed - 实例基础限额` 正部分”求和并封顶加油包额度；付费重置事务内先清本实例，再据此重算，确保记录的是实例级加油包实际消耗。
