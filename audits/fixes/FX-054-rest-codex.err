  444:                                 balanceAfter: Number(updatedUser.balance),
  445:                                 instanceId,
  446:                                 remark: `重置实例 ${currentInstance.name} 月流量`
  447:                             }
  448:                         })
  449:                     }
  450: 
  451:                     await advanceTrafficSnapshot(tx, instanceId, resetSample)
  452:                     await tx.instance.updateMany({
  453:                         where: {
  454:                             id: instanceId,
  455:                             status: { not: 'deleted' }
  456:                         },
  457:                         data: {
  458:                             monthlyTrafficUsed: 0n,
  459:                             trafficStatus: 'NORMAL'
  460:                         }
  461:                     })
  462: 
  463:                     return { price: priceYuan }
  464:                 })
  465:                 price = result.price
  466:             } catch (error) {
  467:                 const message = error instanceof Error ? error.message : String(error)
  468:                 const statusCode = message.includes('余额不足') ? 400 : message.includes('正在处理') ? 409 : 400
  469:                 return reply.code(statusCode).send({ error: message })
  470:             }
  471:         } else {
  472:             await trafficDb.resetInstanceMonthlyTraffic(instanceId)
  473:         }
  474:         const { reconcileTrafficStateForInstanceIds } = await import('../services/traffic-scheduler.js')
  475:         await reconcileTrafficStateForInstanceIds([instanceId])
  476: 
  477:         return { success: true, message: 'Instance traffic reset completed', price }
  478:     })
  479: 
