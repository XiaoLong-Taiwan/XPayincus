  438: /**
  439:  * 批量增加实例流量用量
  440:  * 使用 PostgreSQL 的 UPDATE ... FROM VALUES 进行高效的批量更新
  441:  * 支持大规模实例（10000+），使用分片处理避免事务过大
  442:  */
  443: export async function bulkIncrementInstanceTrafficUsage(
  444:     updates: Array<{ instanceId: number; delta: bigint }>
  445: ) {
  446:     if (updates.length === 0) return
  447: 
  448:     // 按实例 ID 分组，累加同一个实例的增量（理论上不应该出现，但为了安全）
  449:     const instanceDeltas = new Map<number, bigint>()
  450:     for (const { instanceId, delta } of updates) {
  451:         const current = instanceDeltas.get(instanceId) || 0n
  452:         instanceDeltas.set(instanceId, current + delta)
  453:     }
  454: 
  455:     // 转换为数组并按分片大小分批处理
  456:     const deltasArray = Array.from(instanceDeltas.entries())
  457:     
  458:     // 分批处理，避免单次事务过大
  459:     for (let i = 0; i < deltasArray.length; i += BATCH_SIZE) {
  460:         const batch = deltasArray.slice(i, i + BATCH_SIZE)
  461:         
  462:         // 使用 PostgreSQL 的 UPDATE ... FROM VALUES 语法进行批量更新
  463:         // 构建 VALUES 子句（验证并清理所有值）
  464:         const valuesClause = batch
  465:             .map(([instanceId, delta]) => {
  466:                 const instanceIdStr = sanitizeNumber(instanceId)
  467:                 const deltaStr = sanitizeNumber(delta)
  468:                 return `(${instanceIdStr}, ${deltaStr})`
  469:             })
  470:             .join(', ')
  471:         
  472:         // 使用原生 SQL 批量更新
  473:         try {
  474:             await prisma.$executeRawUnsafe(`
  475:                 UPDATE instances AS i
  476:                 SET monthly_traffic_used = i.monthly_traffic_used + v.delta::bigint
  477:                 FROM (VALUES ${valuesClause}) AS v(id, delta)
  478:                 WHERE i.id = v.id
  479:             `)
  480:         } catch (error) {
  481:             console.error(`[Traffic] Failed to bulk increment instance traffic usage (batch ${i}-${i + batch.length}):`, error)
  482:             throw error
  483:         }
  484:     }
  485: }
  486: 
