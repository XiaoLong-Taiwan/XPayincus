  307: /**
  308:  * 带超时的任务执行（带定时器清理，防止内存泄漏）
  309:  */
  310: async function withTimeout<T>(
  311:     promise: Promise<T>,
  312:     timeoutMs: number,
  313:     timeoutMessage: string
  314: ): Promise<T> {
  315:     let timeoutId: ReturnType<typeof setTimeout> | null = null
  316:     
  317:     const timeoutPromise = new Promise<never>((_, reject) => {
  318:         timeoutId = setTimeout(() => reject(new Error(timeoutMessage)), timeoutMs)
  319:     })
  320: 
  321:     try {
  322:         return await Promise.race([promise, timeoutPromise])
  323:     } finally {
  324:         if (timeoutId) clearTimeout(timeoutId)
  325:     }
  326: }
  327: 
  328: /**
  329:  * 主流量采集任务
  330:  */
  331: export async function runTrafficJob(): Promise<void> {
  332:     console.log('[Traffic] Starting traffic collection job...')
  333:     const startTime = Date.now()
  334: 
  335:     try {
  336:         // 使用超时包装整个任务
  337:         await withTimeout(
  338:             executeTrafficJob(startTime),
  339:             JOB_TIMEOUT_MS,
  340:             `[Traffic] Job timeout after ${JOB_TIMEOUT_MS}ms`
  341:         )
  342:     } catch (error) {
  343:         const duration = Date.now() - startTime
  344:         if (error instanceof Error && error.message.includes('timeout')) {
  345:             console.error(`[Traffic] Job timed out after ${duration}ms`)
  346:         } else {
  347:             console.error('[Traffic] Job failed:', error)
  348:         }
  349:         throw error
  350:     }
  351: }
