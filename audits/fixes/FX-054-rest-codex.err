  225:             if (userQuota.trafficStatus !== desiredUserStatus) {
  226:                 await trafficDb.updateUserTrafficStatus(instance.userId, desiredUserStatus)
  227:             }
  228:             return
  229:         }
  230: 
  231:         try {
  232:             const resolvedLimits = resolveTrafficBandwidthLimits(instance, {
  233:                 stripThrottleOverride: remoteThrottled || instance.trafficStatus === 'LIMITED'
  234:             })
  235: 
  236:             await restoreBandwidth(
  237:                 client,
  238:                 instance.incusId,
  239:                 resolvedLimits.incusIngress,
  240:                 resolvedLimits.incusEgress
