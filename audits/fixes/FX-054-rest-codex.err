  487:     fastify.get<{
  488:         Params: { hostId: string }
  489:     }>('/hosts/:hostId/traffic/history', {
  490:         onRequest: [fastify.authenticate]
===== scheduler 1-240 =====
    1: /**
    2:  * 流量调度器服务
    3:  * 负责定时采集流量数据、检查配额、执行限速/恢复
    4:  * 
    5:  * 高可用优化:
    6:  * - 使用统一的 incus-pool 连接池管理
    7:  * - 增量收集：只处理有流量变化的实例
    8:  * - 性能监控日志
    9:  */
   10: 
   11: import { schedule } from 'node-cron'
   12: import pLimit from 'p-limit'
   13: import { IncusClient } from '../lib/incus/incus-client.js'
   14: import { getIncusClientFromPool, updateClientResponseTime, recordClientError, getPoolStatus } from '../lib/incus/incus-pool.js'
   15: import { applyThrottle, isThrottled, restoreBandwidth } from '../lib/incus/incus-traffic.js'
   16: import * as trafficDb from '../db/traffic.js'
   17: import { sendTrafficWarningNotification, sendTrafficThrottledNotification } from './traffic-notifier.js'
   18: import { collectTrafficForInstanceWithClient } from './instance-traffic-collector.js'
   19: import { resolveTrafficBandwidthLimits } from './traffic-bandwidth.js'
   20: import {
   21:     calculateUserTrafficStatus,
   22:     getEffectiveLimit,
   23:     isOverLimit,
   24:     isWarningThreshold,
   25:     isWarningSentThisMonth
   26: } from './traffic-utils.js'
   27: 
   28: // 任务超时时间（15分钟，大规模实例需要更长时间）
   29: const JOB_TIMEOUT_MS = 15 * 60 * 1000
   30: let schedulerStarted = false
   31: 
   32: function parsePositiveInt(value: string | undefined, fallback: number): number {
   33:     const parsed = Number.parseInt(value || '', 10)
   34:     return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback
   35: }
   36: 
   37: // 每宿主机并发限制
   38: // 生产事故修复：默认值从 100 降到 10，并允许通过环境变量覆盖
   39: const CONCURRENCY_PER_HOST = parsePositiveInt(process.env.TRAFFIC_CONCURRENCY_PER_HOST, 10)
   40: 
   41: // 宿主机并行处理数量（同时采集多个宿主机）
   42: const HOST_CONCURRENCY = parsePositiveInt(process.env.TRAFFIC_HOST_CONCURRENCY, 3)
   43: 
   44: /**
   45:  * 流量增量数据
   46:  */
   47: interface TrafficDelta {
   48:     instanceId: number
   49:     totalDelta: bigint
   50: }
   51: 
   52: type RunningTrafficInstance = Awaited<ReturnType<typeof trafficDb.getRunningInstancesForTraffic>>[number]
   53: 
   54: async function markInstanceTrafficWarningIfNeeded(instanceId: number): Promise<boolean> {
   55:     const { prisma } = await import('../db/prisma.js')
   56:     const result = await prisma.instance.updateMany({
   57:         where: {
   58:             id: instanceId,
   59:             status: { not: 'deleted' },
   60:             trafficStatus: 'NORMAL'
   61:         },
   62:         data: { trafficStatus: 'WARNING' }
   63:     })
   64: 
   65:     return result.count > 0
   66: }
   67: 
   68: /**
   69:  * 获取或创建主机客户端（使用统一连接池）
   70:  */
   71: async function getHostClient(host: {
   72:     id: number
   73:     url: string
   74:     certPath: string | null
   75:     keyPath: string | null
   76: }): Promise<IncusClient | null> {
   77:     if (!host.certPath || !host.keyPath) {
   78:         return null
   79:     }
   80: 
   81:     try {
   82:         const startTime = Date.now()
   83:         const client = await getIncusClientFromPool({
   84:             id: host.id,
   85:             url: host.url,
   86:             certPath: host.certPath,
   87:             keyPath: host.keyPath
   88:         })
   89:         const duration = Date.now() - startTime
   90:         updateClientResponseTime(host.id, duration)
   91:         return client
   92:     } catch (error) {
   93:         console.error(`[Traffic] Failed to get client for host ${host.id}:`, error)
   94:         recordClientError(host.id)
   95:         return null
   96:     }
   97: }
   98: 
   99: /**
  100:  * 采集单个实例的流量数据
  101:  */
  102: async function collectInstanceTraffic(
  103:     instance: {
  104:         id: number
  105:         incusId: string
  106:         userId: number
  107:         monthlyTrafficUsed: bigint
  108:     },
  109:     client: IncusClient
  110: ): Promise<TrafficDelta | null> {
  111:     const result = await collectTrafficForInstanceWithClient({
  112:         instanceId: instance.id,
  113:         userId: instance.userId,
  114:         incusId: instance.incusId,
  115:         client,
  116:         currentUsage: instance.monthlyTrafficUsed
  117:     }, {
  118:         waitTimeoutMs: 200,
  119:         retryIntervalMs: 50,
  120:         expireMs: 30000
  121:     })
  122: 
  123:     if (!result.success) {
  124:         console.error(`[Traffic] Failed to collect traffic for instance ${instance.id}: ${result.error}`)
  125:         return null
  126:     }
  127: 
  128:     return {
  129:         instanceId: instance.id,
  130:         totalDelta: result.totalDelta
  131:     }
  132: }
  133: 
  134: /**
  135:  * 检查并执行限速
  136:  */
  137: async function checkAndThrottle(
  138:     instance: RunningTrafficInstance,
  139:     client: IncusClient
  140: ): Promise<void> {
  141:     const userQuota = instance.user.quota
  142:     if (!userQuota) return
  143: 
  144:     const userEffectiveLimit = getEffectiveLimit(userQuota.monthlyTrafficLimit, userQuota.extraTrafficQuota)
  145:     const instanceLimit = instance.monthlyTrafficLimit
  146: 
  147:     // 检查用户级别限额
  148:     const userOverLimit = isOverLimit(userQuota.monthlyTrafficUsed, userEffectiveLimit)
  149:     // 检查实例级别限额
  150:     const instanceOverLimit = isOverLimit(instance.monthlyTrafficUsed, instanceLimit)
  151: 
  152:     if (userOverLimit || instanceOverLimit) {
  153:         const remoteThrottled = await isThrottled(client, instance.incusId)
  154: 
  155:         if (instance.trafficStatus !== 'LIMITED' || !remoteThrottled) {
  156:             try {
  157:                 await applyThrottle(client, instance.incusId)
  158:                 const shouldNotifyThrottled = await trafficDb.markInstanceTrafficLimitedIfNeeded(instance.id)
  159:                 if (userOverLimit && userQuota.trafficStatus !== 'LIMITED') {
  160:                     await trafficDb.updateUserTrafficStatus(instance.userId, 'LIMITED')
  161:                 }
  162: 
  163:                 if (shouldNotifyThrottled) {
  164:                     await sendTrafficThrottledNotification(instance.userId, instance.name, instance.host.name)
  165:                 }
  166: 
  167:                 console.log(`[Traffic] Throttled instance ${instance.id} (${instance.incusId})`)
  168:             } catch (error) {
  169:                 console.error(`[Traffic] Failed to throttle instance ${instance.id}:`, error)
  170:             }
  171:         } else if (userOverLimit && userQuota.trafficStatus !== 'LIMITED') {
  172:             await trafficDb.updateUserTrafficStatus(instance.userId, 'LIMITED')
  173:         }
  174:     } else {
  175:         // 检查预警
  176:         const userWarning = isWarningThreshold(userQuota.monthlyTrafficUsed, userEffectiveLimit)
  177:         if (userWarning && !isWarningSentThisMonth(userQuota.trafficWarningSentAt)) {
  178:             const shouldNotifyWarning = await trafficDb.markUserTrafficWarningIfNeeded(instance.userId, new Date())
  179:             if (shouldNotifyWarning) {
  180:                 await sendTrafficWarningNotification(
  181:                     instance.userId,
  182:                     userQuota.monthlyTrafficUsed,
  183:                     userEffectiveLimit!
  184:                 )
  185:                 console.log(`[Traffic] Sent warning to user ${instance.userId}`)
  186:             }
  187:         }
  188: 
  189:         const instanceWarning = isWarningThreshold(instance.monthlyTrafficUsed, instanceLimit)
  190:         if (instanceWarning && instance.trafficStatus === 'NORMAL') {
  191:             const shouldNotifyWarning = await markInstanceTrafficWarningIfNeeded(instance.id)
  192:             if (shouldNotifyWarning) {
  193:                 await sendTrafficWarningNotification(
  194:                     instance.userId,
  195:                     instance.monthlyTrafficUsed,
  196:                     instanceLimit!,
  197:                     instance.name
  198:                 )
  199:                 console.log(`[Traffic] Sent warning for instance ${instance.id} to user ${instance.userId}`)
  200:             }
  201:         }
  202:     }
  203: }
  204: 
  205: /**
  206:  * 检查并恢复带宽
  207:  */
  208: async function checkAndRestore(
  209:     instance: RunningTrafficInstance,
  210:     client: IncusClient
  211: ): Promise<void> {
  212:     const userQuota = instance.user.quota
  213:     if (!userQuota) return
  214: 
  215:     const userEffectiveLimit = getEffectiveLimit(userQuota.monthlyTrafficLimit, userQuota.extraTrafficQuota)
  216:     const instanceLimit = instance.monthlyTrafficLimit
  217: 
  218:     const userUnderLimit = !isOverLimit(userQuota.monthlyTrafficUsed, userEffectiveLimit)
  219:     const instanceUnderLimit = !isOverLimit(instance.monthlyTrafficUsed, instanceLimit)
