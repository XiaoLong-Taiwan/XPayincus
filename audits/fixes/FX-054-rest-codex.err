+                            if (userInstance.monthlyTrafficLimit === null || userInstance.monthlyTrafficUsed <= userInstance.monthlyTrafficLimit) {
+                                return total
+                            }
+                            return total + userInstance.monthlyTrafficUsed - userInstance.monthlyTrafficLimit
+                        }, 0n)
+                        const extraTrafficUsed = consumedExtraTraffic > userQuota.extraTrafficQuota
+                            ? userQuota.extraTrafficQuota
