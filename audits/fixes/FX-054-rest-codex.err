===== getRunningInstancesForTraffic =====
  740: /**
  741:  * 获取所有运行中的实例（用于流量采集）
  742:  */
  743: export async function getRunningInstancesForTraffic() {
  744:     return prisma.instance.findMany({
  745:         where: {
  746:             status: 'running'
  747:         },
  748:         include: {
  749:             host: {
  750:                 select: {
  751:                     id: true,
  752:                     name: true,
  753:                     url: true,
  754:                     certPath: true,
  755:                     keyPath: true,
  756:                     status: true
  757:                 }
  758:             },
  759:             user: {
  760:                 select: {
  761:                     id: true,
  762:                     quota: true
  763:                 }
  764:             },
  765:             package: {
  766:                 select: {
  767:                     bandwidthMax: true,
  768:                     limitsIngress: true,
  769:                     limitsEgress: true
  770:                 }
  771:             },
  772:             packagePlan: {
  773:                 select: {
  774:                     trafficLimitSpeed: true
  775:                 }
  776:             },
  777:             trafficSnapshot: true
  778:         }
  779:     })
  780: }
  781: 
  782: /**
  783:  * 获取指定实例中所有运行中的实例（用于即时流量状态重算）
  784:  */
  785: export async function getRunningInstancesForTrafficByIds(instanceIds: number[]) {
  786:     if (instanceIds.length === 0) {
  787:         return []
  788:     }
  789: 
  790:     return prisma.instance.findMany({
  791:         where: {
  792:             id: { in: instanceIds },
  793:             status: 'running'
  794:         },
  795:         include: {
  796:             host: {
  797:                 select: {
  798:                     id: true,
  799:                     name: true,
  800:                     url: true,
  801:                     certPath: true,
  802:                     keyPath: true,
  803:                     status: true
  804:                 }
  805:             },
  806:             user: {
  807:                 select: {
  808:                     id: true,
  809:                     quota: true
  810:                 }
  811:             },
  812:             package: {
  813:                 select: {
  814:                     bandwidthMax: true,
  815:                     limitsIngress: true,
  816:                     limitsEgress: true
  817:                 }
  818:             },
  819:             packagePlan: {
  820:                 select: {
  821:                     trafficLimitSpeed: true
  822:                 }
  823:             },
  824:             trafficSnapshot: true
  825:         }
  826:     })
  827: }
  828: 
  829: /**
  830:  * 获取指定用户的所有运行中实例（用于用户级流量状态重算）
  831:  */
  832: export async function getRunningInstancesForTrafficByUserId(userId: number) {
  833:     return prisma.instance.findMany({
  834:         where: {
  835:             userId,
  836:             status: 'running'
  837:         },
  838:         include: {
  839:             host: {
  840:                 select: {
  841:                     id: true,
  842:                     name: true,
  843:                     url: true,
  844:                     certPath: true,
  845:                     keyPath: true,
  846:                     status: true
  847:                 }
  848:             },
  849:             user: {
  850:                 select: {
  851:                     id: true,
  852:                     quota: true
  853:                 }
  854:             },
  855:             package: {
  856:                 select: {
  857:                     bandwidthMax: true,
  858:                     limitsIngress: true,
  859:                     limitsEgress: true
  860:                 }
  861:             },
  862:             packagePlan: {
  863:                 select: {
