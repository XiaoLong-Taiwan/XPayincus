  445: 
  446:     // 优化限速检查：检查有流量更新的实例以及当前处于限速状态的实例
  447:     // 在内存中计算更新后的用量，避免重新查询数据库
  448:     // 需要检查的实例：1) 有流量更新的实例 2) 当前处于限速状态的实例（可能因为配额调整而需要恢复）
  449:     const instancesToCheckForThrottle = new Set<number>()
  450:     
  451:     // 添加有流量更新的实例
  452:     for (const delta of deltas) {
  453:         instancesToCheckForThrottle.add(delta.instanceId)
  454:     }
  455:     
  456:     // 添加当前处于限速状态的实例（可能需要恢复）
  457:     for (const instance of instances) {
  458:         if (instance.trafficStatus === 'LIMITED' || (instance.user.quota?.trafficStatus === 'LIMITED')) {
  459:             instancesToCheckForThrottle.add(instance.id)
  460:         }
  461:     }
  462: 
  463:     if (instancesToCheckForThrottle.size > 0) {
  464:         // 计算每个实例和用户更新后的用量（在内存中）
  465:         const instanceUpdatedUsage = new Map<number, bigint>()
  466:         const userUpdatedUsage = new Map<number, bigint>()
  467: 
  468:         // 初始化用量（使用原始值）
  469:         for (const instance of instances) {
  470:             instanceUpdatedUsage.set(instance.id, instance.monthlyTrafficUsed)
  471:             if (instance.user.quota) {
  472:                 const currentUserUsage = userUpdatedUsage.get(instance.userId) ?? instance.user.quota.monthlyTrafficUsed
  473:                 userUpdatedUsage.set(instance.userId, currentUserUsage)
  474:             }
  475:         }
  476: 
  477:         // 累加更新量
  478:         for (const delta of deltas) {
  479:             if (delta.totalDelta > 0n) {
  480:                 const instance = instanceMap.get(delta.instanceId)
  481:                 if (!instance) continue
  482: 
  483:                 // 更新实例用量
  484:                 const currentInstanceUsage = instanceUpdatedUsage.get(delta.instanceId) ?? 0n
  485:                 instanceUpdatedUsage.set(delta.instanceId, currentInstanceUsage + delta.totalDelta)
  486: 
  487:                 // 更新用户用量
  488:                 const currentUserUsage = userUpdatedUsage.get(instance.userId) ?? 0n
  489:                 userUpdatedUsage.set(instance.userId, currentUserUsage + delta.totalDelta)
  490:             }
  491:         }
  492: 
  493:         // 构建用于限速检查的实例列表
  494:         const instancesToCheck = Array.from(instancesToCheckForThrottle)
