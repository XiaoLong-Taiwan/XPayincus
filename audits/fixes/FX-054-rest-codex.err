  497:                 if (!instance || instance.host.status !== 'online') return false
  498:                 return true
  499:             })
  500:             .map(instance => {
  501:                 const updatedInstanceUsage = instanceUpdatedUsage.get(instance.id) ?? instance.monthlyTrafficUsed
  502:                 const updatedUserUsage = instance.user.quota
  503:                     ? (userUpdatedUsage.get(instance.userId) ?? instance.user.quota.monthlyTrafficUsed)
  504:                     : 0n
  505: 
  506:                 // 构建更新后的实例对象（用于限速检查）
  507:                 return {
