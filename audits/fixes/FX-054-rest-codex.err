  896:   hostLimit    Int @default(0) @map("host_limit") // 宿主机数量上限（0 = 未授权）
  897:   hostUsed     Int @default(0) @map("host_used") // 已使用宿主机数量
  898:   friendLimit  Int @default(0) @map("friend_limit") // 好友数量上限（0 = 未授权）
  899:   friendUsed   Int @default(0) @map("friend_used") // 已使用好友数量
  900:   packageLimit Int @default(0) @map("package_limit") // 套餐数量上限（0 = 未授权）
  901:   packageUsed  Int @default(0) @map("package_used") // 已使用套餐数量
  902: 
  903:   // 流量控制 (单位: Bytes)
  904:   monthlyTrafficLimit  BigInt?       @map("monthly_traffic_limit") // null = 无限制
  905:   monthlyTrafficUsed   BigInt        @default(0) @map("monthly_traffic_used")
  906:   trafficStatus        TrafficStatus @default(NORMAL) @map("traffic_status")
  907:   trafficWarningSentAt DateTime?     @map("traffic_warning_sent_at")
  908: 
  909:   // 流量包扩展 (预留)
  910:   extraTrafficQuota BigInt @default(0) @map("extra_traffic_quota")
  911:   extraTrafficUsed  BigInt @default(0) @map("extra_traffic_used")
  912: 
  913:   user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  914: 
  915:   @@map("user_quotas")
  916: }
