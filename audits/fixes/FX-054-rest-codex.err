   25: /**
   26:  * BigInt 序列化为字符串
   27:  */
   28: function serializeBigInt(value: bigint | null): string | null {
   29:     return value === null ? null : value.toString()
   30: }
   31: 
   32: function parsePositiveId(value: string): number | null {
   33:     if (!/^\d+$/.test(value)) {
   34:         return null
   35:     }
   36: 
   37:     const parsed = Number(value)
   38:     return Number.isSafeInteger(parsed) && parsed > 0 ? parsed : null
   39: }
   40: 
   41: function normalizeMoney(value: number): number {
   42:     return Number(value.toFixed(2))
   43: }
   44: 
   45: function resolveTrafficResetPriceCents(instance: {
   46:     package?: { trafficResetPrice: unknown } | null
   47:     packagePlan?: { trafficResetPrice: unknown } | null
   48: }): number {
   49:     const planPrice = instance.packagePlan?.trafficResetPrice
   50:     if (planPrice !== null && planPrice !== undefined) {
   51:         return Math.max(0, Math.round(Number(planPrice) || 0))
   52:     }
   53:     return Math.max(0, Math.round(Number(instance.package?.trafficResetPrice) || 0))
   54: }
   55: 
   56: /**
   57:  * 计算百分比
   58:  * 注意: 先转换为 Number 再计算,避免 BigInt 整数除法精度丢失
   59:  * 例如: 160MB / 257GB 用 BigInt 整数除法会得到 0,而非 0.061%
   60:  */
   61: function calculatePercentage(used: bigint, limit: bigint | null): number {
   62:     if (limit === null || limit === 0n) return 0
   63:     // 先转换为浮点数再计算百分比,避免整数除法导致的精度丢失
   64:     const percentage = (Number(used) / Number(limit)) * 100
   65:     return Math.min(100, percentage)
   66: }
