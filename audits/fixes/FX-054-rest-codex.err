+                        const extraTrafficUsed = consumedExtraTraffic > userQuota.extraTrafficQuota
+                            ? userQuota.extraTrafficQuota
+                            : consumedExtraTraffic
+                        const effectiveLimit = getEffectiveLimit(
+                            userQuota.monthlyTrafficLimit,
+                            userQuota.extraTrafficQuota
+                        )
+
+                        await tx.userQuota.update({
+                            where: { userId: currentInstance.userId },
+                            data: {
+                                monthlyTrafficUsed,
+                                extraTrafficUsed,
