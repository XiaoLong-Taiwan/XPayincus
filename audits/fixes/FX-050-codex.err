+const boostRouteStart = source.indexOf("}>('/:id/boost-processes'")
+assert.ok(boostRouteStart >= 0, 'boost-processes route not found')
+const boostRouteEnd = source.indexOf("}>('/:id/task'", boostRouteStart)
