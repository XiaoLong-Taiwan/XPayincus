+      pluginId: input.pluginId,
+      manifestVersion: input.manifestVersion,
+      riskLevel: { in: ['high', 'critical'] }
+    },
+    select: { status: true }
+  })
+  return { ok: reviews.length > 0 && reviews.every(review => review.status === 'approved') }
+}
