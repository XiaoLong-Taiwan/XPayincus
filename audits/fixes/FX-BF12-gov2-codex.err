+  manifestVersion: string
+  riskLevel: PluginCapabilityRiskLevel
+}): Promise<{ ok: boolean }> {
+  if (input.riskLevel !== 'high' && input.riskLevel !== 'critical') return { ok: true }
+
+  const reviews = await prisma.pluginCapabilityReview.findMany({
