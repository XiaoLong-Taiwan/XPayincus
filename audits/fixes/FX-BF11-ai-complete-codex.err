+  await createLog(
+    actorUserId,
+    LogModule.PLUGIN,
+    'ai_ticket.needs_human',
+    `AI ticket requires human handling ${needsHumanTicketMarker(ticketId)} (${reason})`,
+    LogResult.WARNING
+  )
