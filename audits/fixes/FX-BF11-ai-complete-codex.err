+
+type SensitiveHandoffRule = keyof typeof SENSITIVE_HANDOFF_RULES
+
+const DEFAULT_SENSITIVE_HANDOFF_RULES = Object.keys(SENSITIVE_HANDOFF_RULES) as SensitiveHandoffRule[]
