+  const sendBlockedReasons = inspectAiReplySendEligibility(context, config)
+  return {
+    draft: reviewedBody,
+    model: config.model,
+    safety,
+    mode: config.mode,
+    confidence: 1,
+    confidenceThreshold: config.confidenceThreshold,
+    canSend: (config.mode === 'semi_auto' || config.mode === 'auto') && sendBlockedReasons.length === 0,
