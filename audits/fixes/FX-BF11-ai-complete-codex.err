diff --git a/server/src/services/ai-ticket-auto-reply-scheduler.ts b/server/src/services/ai-ticket-auto-reply-scheduler.ts
index c48bdda00193c448c251fd6ec0b8a4b0990abb28..d8b75e733cff7f9de9668aa5145fb238c1662f8e
