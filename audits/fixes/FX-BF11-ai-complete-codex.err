+export function resolveSensitiveHandoffRules(value: unknown): SensitiveHandoffRule[] {
+  if (!Array.isArray(value) || value.length === 0) return [...DEFAULT_SENSITIVE_HANDOFF_RULES]
+
+  const normalized = value
