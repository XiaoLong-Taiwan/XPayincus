+export async function validateAiTicketReviewedReply(
+  ticketId: number,
+  reviewedBody: string
+): Promise<AiTicketReplyCandidate> {
+  const config = await loadAiTicketAgentConfig()
+  if (!config.enabled) {
+    throw new Error('AI_TICKET_AGENT_DISABLED')
+  }
+
