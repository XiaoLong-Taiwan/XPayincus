  464: /**
  465:  * 删除指定宿主机下的兑换码。
  466:  */
  467: export async function deleteRedeemCodeForHost(
  468:   hostId: number,
  469:   id: number
  470: ): Promise<'deleted' | 'disabled' | 'not_found'> {
  471:   return prisma.$transaction(async (tx) => {
  472:     await advisoryTransactionLock(tx, REDEEM_CODE_LOCK_NAMESPACE, id)
  473: 
  474:     const code = await tx.redeemCode.findFirst({
  475:       where: { id, hostId },
  476:       select: { id: true }
  477:     })
  478:     if (!code) return 'not_found'
  479: 
  480:     const usageCount = await tx.redeemCodeUsage.count({ where: { redeemCodeId: id } })
  481:     if (usageCount > 0) {
  482:       await tx.redeemCode.updateMany({
  483:         where: { id, hostId },
  484:         data: { enabled: false }
  485:       })
  486:       return 'disabled'
  487:     }
  488: 
  489:     await tx.redeemCode.deleteMany({ where: { id, hostId } })
  490:     return 'deleted'
  491:   })
  492: }
  493: 
  494: /**
  495:  * 批量删除指定宿主机下的兑换码。
  496:  */
  497: export async function deleteRedeemCodeBatchForHost(
  498:   hostId: number,
  499:   ids: number[]
  500: ): Promise<{ foundCount: number; deletedCount: number; disabledCount: number }> {
  501:   if (ids.length === 0) {
  502:     return { foundCount: 0, deletedCount: 0, disabledCount: 0 }
  503:   }
  504: 
  505:   return prisma.$transaction(async (tx) => {
  506:     const sortedIds = [...ids].sort((a, b) => a - b)
  507:     for (const id of sortedIds) {
  508:       await advisoryTransactionLock(tx, REDEEM_CODE_LOCK_NAMESPACE, id)
  509:     }
  510: 
  511:     const codes = await tx.redeemCode.findMany({
  512:       where: { id: { in: sortedIds }, hostId },
  513:       select: { id: true }
  514:     })
  515:     const foundIds = codes.map(code => code.id)
  516:     if (foundIds.length === 0) {
  517:       return { foundCount: 0, deletedCount: 0, disabledCount: 0 }
  518:     }
  519: 
  520:     const usages = await tx.redeemCodeUsage.groupBy({
  521:       by: ['redeemCodeId'],
  522:       where: { redeemCodeId: { in: foundIds } }
  523:     })
  524:     const usedIds = usages.map(usage => usage.redeemCodeId)
  525:     const unusedIds = foundIds.filter(id => !usedIds.includes(id))
