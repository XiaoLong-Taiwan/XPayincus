  170:     if (!systemCodeRecord) {
  171:       return reply.code(404).send(apiError(ErrorCode.REDEEM_CODE_NOT_FOUND))
  172:     }
  173: 
  174:     // 检查兑换码是否启用
  175:     if (!systemCodeRecord.enabled) {
  176:       return reply.code(400).send(apiError(ErrorCode.REDEEM_CODE_DISABLED))
  177:     }
  178: 
  179:     if (systemCodeRecord.targetUserId !== null && systemCodeRecord.targetUserId !== user.id) {
  180:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN, 'This redeem code is assigned to another user'))
  181:     }
  182: 
  183:     // 检查兑换码是否过期
  184:     if (systemCodeRecord.expiresAt && systemCodeRecord.expiresAt < new Date()) {
  185:       return reply.code(400).send(apiError(ErrorCode.REDEEM_CODE_EXPIRED))
  186:     }
