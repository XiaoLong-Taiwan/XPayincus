  155:   }, async (request: FastifyRequest<{ Body: { redeemCode: string; instanceId: number } }>, reply: FastifyReply) => {
  156:     const { user } = request
  157:     const { redeemCode, instanceId } = request.body
  158:     const trimmedCode = redeemCode.trim()
