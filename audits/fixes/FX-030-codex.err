+    return user ? toMoney(user.balance) : null
+  }
+
+  const user = await tx.user.findUnique({ where: { id: issuerId }, select: { balance: true } })
+  if (!user) throw new Error('USER_NOT_FOUND')
+
+  const amount = toMoney(giftCard.faceValue)
