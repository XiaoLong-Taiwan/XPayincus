 275:   const [logs, total] = await Promise.all([
 276:     prisma.resourcePoolLog.findMany({
 277:       where,
 278:       orderBy: { createdAt: 'desc' },
 279:       take: limit,
 280:       skip: offset,
 281:       include: {
 282:         instance: {
 283:           select: {
 284:             id: true,
 285:             name: true
 286:           }
 287:         }
 288:       }
 289:     }),
 290:     prisma.resourcePoolLog.count({ where })
 291:   ])
 292: 
 293:   return {
 294:     records: logs.map(log => ({
 295:       id: log.id,
 296:       action: log.action,
 297:       resourceType: log.resourceType,
