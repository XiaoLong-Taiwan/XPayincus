   1: /**
   2:  * 用户资源池数据库操作
   3:  */
   4: 
   5: import { prisma } from './prisma.js'
   6: import type { RedeemCodeType, ResourcePoolAction } from '@prisma/client'
   7: import { INSTANCE_OPERATION_LOCK_NAMESPACE, USER_RESOURCE_POOL_LOCK_NAMESPACE, advisoryTransactionLock } from './advisory-locks.js'
   8: 
   9: // 资源类型到字段的映射
  10: const RESOURCE_FIELD_MAP: Record<string, 'cpu' | 'memory' | 'disk' | 'traffic'> = {
  11:   c: 'cpu',
  12:   r: 'memory',
  13:   d: 'disk',
  14:   t: 'traffic'
  15: }
  16: 
  17: /**
  18:  * 获取用户资源池
  19:  */
  20: export async function getUserResourcePool(userId: number) {
  21:   // 使用 upsert 避免并发时的 unique constraint 错误
  22:   const pool = await prisma.userResourcePool.upsert({
  23:     where: { userId },
  24:     update: {},  // 已存在时不更新
  25:     create: { userId }
  26:   })
  27: 
  28:   return {
  29:     cpu: pool.cpu,
  30:     memory: pool.memory,
  31:     disk: pool.disk,
  32:     traffic: Number(pool.traffic)
  33:   }
  34: }
  35: 
  36: /**
  37:  * 添加资源到资源池
  38:  */
  39: export async function addToResourcePool(
  40:   userId: number,
  41:   resourceType: RedeemCodeType,
  42:   amount: number,
  43:   action: ResourcePoolAction,
  44:   remark?: string
  45: ): Promise<void> {
  46:   const field = RESOURCE_FIELD_MAP[resourceType]
  47:   if (!field) {
  48:     throw new Error(`Invalid resource type: ${resourceType}`)
  49:   }
  50: 
  51:   await prisma.$transaction(async (tx) => {
  52:     await advisoryTransactionLock(tx, USER_RESOURCE_POOL_LOCK_NAMESPACE, userId)
  53: 
  54:     // 更新资源池
  55:     await tx.userResourcePool.upsert({
  56:       where: { userId },
  57:       update: {
  58:         [field]: field === 'traffic'
  59:           ? { increment: BigInt(amount) }
  60:           : { increment: amount }
  61:       },
  62:       create: {
  63:         userId,
  64:         [field]: field === 'traffic' ? BigInt(amount) : amount
  65:       }
  66:     })
  67: 
  68:     // 记录日志
  69:     await tx.resourcePoolLog.create({
  70:       data: {
  71:         userId,
  72:         action,
  73:         resourceType,
  74:         amount,
  75:         remark
  76:       }
  77:     })
  78:   })
  79: }
  80: 
  81: /**
  82:  * 从资源池扣减资源（应用到实例前的检查和扣减）
  83:  */
  84: export async function deductFromResourcePool(
  85:   userId: number,
  86:   resourceType: RedeemCodeType,
  87:   amount: number,
  88:   instanceId: number,
  89:   remark?: string
  90: ): Promise<boolean> {
  91:   const field = RESOURCE_FIELD_MAP[resourceType]
  92:   if (!field) {
  93:     throw new Error(`Invalid resource type: ${resourceType}`)
  94:   }
  95: 
  96:   return prisma.$transaction(async (tx) => {
  97:     await advisoryTransactionLock(tx, USER_RESOURCE_POOL_LOCK_NAMESPACE, userId)
  98: 
  99:     let decrementResult = 0
 100:     if (field === 'cpu') {
 101:       decrementResult = await tx.$executeRaw`
 102:         UPDATE "user_resource_pools"
 103:         SET "cpu" = "cpu" - ${amount}
 104:         WHERE "user_id" = ${userId}
 105:           AND "cpu" >= ${amount}
 106:       `
 107:     } else if (field === 'memory') {
 108:       decrementResult = await tx.$executeRaw`
 109:         UPDATE "user_resource_pools"
 110:         SET "memory" = "memory" - ${amount}
 111:         WHERE "user_id" = ${userId}
 112:           AND "memory" >= ${amount}
 113:       `
 114:     } else if (field === 'disk') {
 115:       decrementResult = await tx.$executeRaw`
 116:         UPDATE "user_resource_pools"
 117:         SET "disk" = "disk" - ${amount}
 118:         WHERE "user_id" = ${userId}
 119:           AND "disk" >= ${amount}
 120:       `
 121:     } else {
 122:       const trafficAmount = BigInt(amount)
 123:       decrementResult = await tx.$executeRaw`
 124:         UPDATE "user_resource_pools"
 125:         SET "traffic" = "traffic" - ${trafficAmount}
 126:         WHERE "user_id" = ${userId}
 127:           AND "traffic" >= ${trafficAmount}
 128:       `
 129:     }
 130: 
 131:     if (decrementResult === 0) {
 132:       return false
 133:     }
 134: 
 135:     await tx.resourcePoolLog.create({
 136:       data: {
 137:         userId,
 138:         action: 'apply',
 139:         resourceType,
 140:         amount: -amount, // 负数表示消耗
 141:         instanceId,
 142:         remark
 143:       }
 144:     })
 145: 
 146:     return true
 147:   })
 148: }
