 346: /**
 347:  * 记录系统 h- 兑换码兑换到资源池日志（仅记录，不加资源池，因为资源直接应用到实例）
 348:  */
 349: export async function logSystemRedeemToInstance(
 350:   userId: number,
 351:   resourceType: RedeemCodeType,
 352:   amount: number,
 353:   instanceId: number,
 354:   remark?: string
 355: ): Promise<void> {
 356:   await prisma.resourcePoolLog.create({
 357:     data: {
 358:       userId,
 359:       action: 'system_redeem',
 360:       resourceType,
   1: /**
   2:  * 资源池路由
   3:  */
   4: 
   5: import type { FastifyInstance, FastifyRequest, FastifyReply } from 'fastify'
   6: import * as db from '../db/index.js'
   7: import { getIncusClient } from '../lib/incus/index.js'
   8: import { patchInstanceResources } from '../lib/incus/incus-instances.js'
   9: import { apiError, ErrorCode } from '../lib/errors.js'
  10: import { createLog } from '../db/logs.js'
  11: import type { RedeemCodeType, ResourcePoolAction } from '@prisma/client'
  12: import { acquireLock, releaseLock } from '../lib/distributed-lock.js'
  13: 
  14: // 资源类型名称
  15: const RESOURCE_TYPE_NAMES: Record<string, { zh: string; en: string }> = {
  16:   c: { zh: 'CPU', en: 'CPU' },
  17:   r: { zh: '内存', en: 'Memory' },
  18:   d: { zh: '硬盘', en: 'Disk' },
  19:   t: { zh: '流量', en: 'Traffic' }
  20: }
  21: 
  22: // 资源类型单位
  23: const RESOURCE_TYPE_UNITS: Record<string, string> = {
  24:   c: '%',
  25:   r: 'MB',
  26:   d: 'MB',
  27:   t: 'GB'
  28: }
  29: 
  30: const POSITIVE_INTEGER_QUERY_PATTERN = /^[1-9]\d*$/
  31: const NON_NEGATIVE_INTEGER_QUERY_PATTERN = /^(0|[1-9]\d*)$/
  32: const RESOURCE_POOL_ACTIONS = new Set<ResourcePoolAction>([
  33:   'checkin',
  34:   'redeem',
  35:   'admin_grant',
  36:   'system_grant',
  37:   'lottery',
  38:   'apply',
  39:   'system_redeem'
  40: ])
  41: const RESOURCE_POOL_RESOURCE_TYPES = new Set<RedeemCodeType>(['c', 'r', 'd', 't'])
  42: 
  43: function parseClampedPositiveIntegerQuery(value: string | undefined, fallback: number, max: number): number {
  44:   if (!value || !POSITIVE_INTEGER_QUERY_PATTERN.test(value)) return fallback
  45:   const parsed = Number(value)
  46:   return Number.isSafeInteger(parsed) ? Math.min(parsed, max) : fallback
  47: }
  48: 
  49: function parseNonNegativeIntegerQuery(value: string | undefined, fallback: number): number {
  50:   if (!value || !NON_NEGATIVE_INTEGER_QUERY_PATTERN.test(value)) return fallback
  51:   const parsed = Number(value)
  52:   return Number.isSafeInteger(parsed) ? parsed : fallback
  53: }
  54: 
  55: function normalizeResourcePoolAction(value: string | undefined): ResourcePoolAction | undefined {
  56:   return value && RESOURCE_POOL_ACTIONS.has(value as ResourcePoolAction)
  57:     ? value as ResourcePoolAction
  58:     : undefined
  59: }
  60: 
  61: function normalizeResourcePoolType(value: string | undefined): RedeemCodeType | undefined {
  62:   return value && RESOURCE_POOL_RESOURCE_TYPES.has(value as RedeemCodeType)
  63:     ? value as RedeemCodeType
  64:     : undefined
  65: }
  66: 
  67: async function withResourcePoolApplyLocks<T>(
  68:   userId: number,
  69:   instanceId: number,
  70:   resourceType: string,
  71:   fn: () => Promise<T>
  72: ): Promise<T> {
  73:   const lockKeys = [
  74:     `resource-pool:${userId}:${resourceType}`,
  75:     `instance:${instanceId}:resource-pool-apply`
  76:   ]
  77:   const acquired: Array<{ lockKey: string; ownerId: string }> = []
  78: 
  79:   try {
  80:     for (const lockKey of lockKeys) {
  81:       const lock = await acquireLock(lockKey, {
  82:         expireMs: 120_000,
  83:         waitTimeoutMs: 10_000,
  84:         retryIntervalMs: 100
  85:       })
  86:       if (!lock.success || !lock.ownerId) {
  87:         throw new Error('RESOURCE_POOL_BUSY')
  88:       }
  89:       acquired.push({ lockKey, ownerId: lock.ownerId })
  90:     }
  91: 
  92:     return await fn()
  93:   } finally {
  94:     for (const lock of acquired.reverse()) {
  95:       await releaseLock(lock.lockKey, lock.ownerId)
  96:     }
  97:   }
  98: }
  99: 
 100: export default async function resourcePoolRoutes(fastify: FastifyInstance) {
 101:   // ==================== 获取用户资源池 ====================
 102:   fastify.get('/', {
 103:     onRequest: [fastify.authenticateUser]
 104:   }, async (request: FastifyRequest, _reply: FastifyReply) => {
 105:     const { user } = request
 106:     const pool = await db.getUserResourcePool(user.id)
 107:     return pool
 108:   })
 109: 
 110:   // ==================== 应用资源到实例 ====================
 111:   fastify.post<{
 112:     Body: {
 113:       instanceId: number
 114:       resourceType: string
 115:       amount: number
 116:     }
 117:   }>('/apply', {
 118:     onRequest: [fastify.authenticateUser],
 119:     schema: {
 120:       body: {
 121:         type: 'object',
 122:         required: ['instanceId', 'resourceType', 'amount'],
 123:         properties: {
 124:           instanceId: { type: 'integer', minimum: 1 },
 125:           resourceType: { type: 'string', enum: ['c', 'r', 'd', 't'] },
 126:           amount: { type: 'integer', minimum: 1 }
 127:         }
 128:       }
 129:     }
 130:   }, async (request: FastifyRequest<{ Body: { instanceId: number; resourceType: string; amount: number } }>, reply: FastifyReply) => {
 131:     const { user } = request
 132:     const { instanceId, resourceType, amount } = request.body
 133: 
 134:     try {
 135:       const response = await withResourcePoolApplyLocks(user.id, instanceId, resourceType, async () => {
 136:         const instance = await db.getInstanceById(instanceId)
 137:         if (!instance) {
 138:           throw new Error('INSTANCE_NOT_FOUND')
 139:         }
 140: 
 141:         if (instance.user_id !== user.id) {
 142:           throw new Error('FORBIDDEN')
 143:         }
 144: 
 145:         if (!['running', 'stopped'].includes(instance.status)) {
 146:           throw new Error('INSTANCE_STATUS_INVALID')
 147:         }
 148: 
 149:         const host = await db.getHostById(instance.host_id)
 150:         if (!host) {
 151:           throw new Error('HOST_NOT_FOUND')
 152:         }
 153: 
 154:         if (!host.enable_resource_pool) {
 155:           throw new Error('RESOURCE_POOL_DISABLED')
 156:         }
 157: 
 158:         if (resourceType === 'c' && host.instance_type === 'vm' && amount % 100 !== 0) {
 159:           throw new Error('RESOURCE_POOL_KVM_CPU_MULTIPLE')
 160:         }
 161: 
 162:         if (resourceType === 'r' && host.instance_type === 'vm' && amount % 128 !== 0) {
 163:           throw new Error('RESOURCE_POOL_KVM_MEMORY_MULTIPLE')
 164:         }
 165: 
 166:         if (resourceType === 'd' && host.instance_type === 'vm' && amount % 1024 !== 0) {
 167:           throw new Error('RESOURCE_POOL_KVM_DISK_MULTIPLE')
 168:         }
 169: 
 170:         if ((resourceType === 'r' || resourceType === 'd') && host.instance_type === 'vm' && instance.status !== 'stopped') {
 171:           throw new Error('RESOURCE_POOL_VM_MUST_STOP')
 172:         }
 173: 
 174:         let patchedRollback: (() => Promise<void>) | null = null
 175: 
 176:         try {
 177:           if (resourceType === 'c') {
 178:             const newCpu = instance.cpu + amount
 179:             const client = await getIncusClient(host)
 180:             await patchInstanceResources(client, instance.incus_id, { cpu: newCpu })
 181:             patchedRollback = async () => {
 182:               await patchInstanceResources(client, instance.incus_id, { cpu: instance.cpu })
 183:             }
 184:             const applied = await db.applyResourcePoolToInstance({
 185:               userId: user.id,
 186:               instanceId,
 187:               hostId: instance.host_id,
 188:               resourceType: resourceType as RedeemCodeType,
 189:               amount,
 190:               remark: `应用到实例 ${instance.name}`,
 191:               instanceResources: { cpu: newCpu },
 192:               hostResourceDelta: { cpuUsed: amount }
 193:             })
 194:             if (!applied) {
 195:               throw new Error('RESOURCE_POOL_INSUFFICIENT')
 196:             }
 197:           } else if (resourceType === 'r') {
 198:             const newMemory = instance.memory + amount
 199:             const client = await getIncusClient(host)
 200:             await patchInstanceResources(client, instance.incus_id, { memory: newMemory })
 201:             patchedRollback = async () => {
 202:               await patchInstanceResources(client, instance.incus_id, { memory: instance.memory })
 203:             }
 204:             const applied = await db.applyResourcePoolToInstance({
 205:               userId: user.id,
 206:               instanceId,
 207:               hostId: instance.host_id,
 208:               resourceType: resourceType as RedeemCodeType,
 209:               amount,
 210:               remark: `应用到实例 ${instance.name}`,
 211:               instanceResources: { memory: newMemory },
 212:               hostResourceDelta: { memoryUsed: amount }
 213:             })
 214:             if (!applied) {
 215:               throw new Error('RESOURCE_POOL_INSUFFICIENT')
 216:             }
 217:           } else if (resourceType === 'd') {
 218:             const newDisk = instance.disk + amount
 219:             const client = await getIncusClient(host)
 220:             await patchInstanceResources(client, instance.incus_id, { disk: newDisk })
 221:             patchedRollback = async () => {
 222:               await patchInstanceResources(client, instance.incus_id, { disk: instance.disk })
 223:             }
 224:             const applied = await db.applyResourcePoolToInstance({
 225:               userId: user.id,
 226:               instanceId,
 227:               hostId: instance.host_id,
 228:               resourceType: resourceType as RedeemCodeType,
 229:               amount,
 230:               remark: `应用到实例 ${instance.name}`,
 231:               instanceResources: { disk: newDisk },
 232:               hostResourceDelta: { diskUsed: amount }
 233:             })
 234:             if (!applied) {
 235:               throw new Error('RESOURCE_POOL_INSUFFICIENT')
 236:             }
 237:           } else if (resourceType === 't') {
 238:             const trafficBytes = BigInt(amount) * BigInt(1024 * 1024 * 1024)
 239:             const applied = await db.applyResourcePoolToInstance({
 240:               userId: user.id,
 241:               instanceId,
 242:               hostId: instance.host_id,
 243:               resourceType: resourceType as RedeemCodeType,
 244:               amount,
 245:               remark: `应用到实例 ${instance.name}`,
 246:               monthlyTrafficDelta: trafficBytes
 247:             })
 248:             if (!applied) {
 249:               throw new Error('RESOURCE_POOL_INSUFFICIENT')
 250:             }
 251:           }
 252:         } catch (error) {
 253:           if (patchedRollback) {
 254:             try {
 255:               await patchedRollback()
 256:             } catch (rollbackError) {
 257:               request.log.error({ err: rollbackError, instanceId }, 'Failed to roll back Incus resource patch after resource-pool DB failure')
 258:             }
 259:           }
 260:           throw error
 261:         }
 262: 
 263:         const typeName = RESOURCE_TYPE_NAMES[resourceType]?.zh || resourceType
 264:         const unit = RESOURCE_TYPE_UNITS[resourceType] || ''
 265: 
 266:         await createLog(
 267:           user.id,
 268:           'resource_pool',
 269:           'apply.success',
 270:           `Applied ${amount}${unit} ${typeName} to instance ${instance.name}`,
 271:           'success',
 272:           { instanceId }
 273:         )
 274: 
 275:         return {
 276:           message: 'Resource applied successfully',
 277:           resourceType,
 278:           amount,
 279:           instanceId,
 280:           instanceName: instance.name
 281:         }
 282:       })
 283: 
 284:       return response
 285:     } catch (error) {
 286:       const errorMessage = error instanceof Error ? error.message : String(error)
 287:       if (errorMessage === 'INSTANCE_NOT_FOUND') {
 288:         return reply.code(404).send(apiError(ErrorCode.INSTANCE_NOT_FOUND))
 289:       }
 290:       if (errorMessage === 'FORBIDDEN') {
 291:         return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 292:       }
 293:       if (errorMessage === 'INSTANCE_STATUS_INVALID') {
 294:         return reply.code(400).send(apiError(ErrorCode.INSTANCE_STATUS_INVALID))
 295:       }
 296:       if (errorMessage === 'HOST_NOT_FOUND') {
 297:         return reply.code(404).send(apiError(ErrorCode.HOST_NOT_FOUND))
 298:       }
 299:       if (errorMessage === 'RESOURCE_POOL_DISABLED') {
 300:         return reply.code(403).send(apiError(ErrorCode.FEATURE_DISABLED, '该节点未开启资源池玩法'))
 301:       }
 302:       if (errorMessage === 'RESOURCE_POOL_KVM_CPU_MULTIPLE') {
 303:         return reply.code(400).send(apiError(ErrorCode.RESOURCE_POOL_KVM_CPU_MULTIPLE))
 304:       }
 305:       if (errorMessage === 'RESOURCE_POOL_KVM_MEMORY_MULTIPLE') {
 306:         return reply.code(400).send(apiError(ErrorCode.RESOURCE_POOL_KVM_MEMORY_MULTIPLE))
 307:       }
 308:       if (errorMessage === 'RESOURCE_POOL_KVM_DISK_MULTIPLE') {
 309:         return reply.code(400).send(apiError(ErrorCode.RESOURCE_POOL_KVM_DISK_MULTIPLE))
 310:       }
 311:       if (errorMessage === 'RESOURCE_POOL_VM_MUST_STOP') {
 312:         return reply.code(400).send(apiError(ErrorCode.RESOURCE_POOL_VM_MUST_STOP))
 313:       }
 314:       if (errorMessage === 'RESOURCE_POOL_INSUFFICIENT') {
 315:         return reply.code(400).send(apiError(ErrorCode.RESOURCE_POOL_INSUFFICIENT))
 316:       }
 317:       if (errorMessage === 'RESOURCE_POOL_BUSY') {
 318:         return reply.code(409).send({ error: 'RESOURCE_POOL_BUSY', message: 'Resource pool apply is busy, please retry' })
 319:       }
 320:       await createLog(
 321:         user.id,
 322:         'resource_pool',
 323:         'apply.failed',
 324:         `Failed to apply resource to instance ${instanceId}: ${errorMessage}`,
 325:         'failed',
 326:         { instanceId }
 327:       )
 328:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, errorMessage))
 329:     }
 330:   })
 331: 
