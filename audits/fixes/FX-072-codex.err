 263:     limit?: number
 264:     offset?: number
 265:   } = {}
 266: ) {
 267:   const { action, resourceType, limit = 20, offset = 0 } = options
 268: 
 269:   const where = {
 270:     userId,
 271:     ...(action ? { action } : {}),
 272:     ...(resourceType ? { resourceType } : {})
 273:   }
