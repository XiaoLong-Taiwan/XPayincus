)
assert.ok(
  createOrderRoute.indexOf('!Number.isFinite(actualAmount) || actualAmount <= 0') <
    createOrderRoute.indexOf('await db.createRechargeOrder'),
  'credited amount guard must run before creating the recharge order'
)

