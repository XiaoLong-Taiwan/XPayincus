 1615:       const { paymentMethod } = request.body as { paymentMethod?: string }
 1616: 
 1617:       const record = await db.getRechargeRecordByOrderNo(orderNo)
 1618:       if (!record) {
 1619:         return reply.status(404).send({ error: '订单不存在' })
 1620:       }
 1621: 
 1622:       // 验证订单所有权
 1623:       if (record.userId !== user.id) {
