  831: async function dispatchPluginGatewayPaymentHook(input: {
  832:   hook: Extract<PluginGatewayExtensionHook, 'webhook' | 'verifyPayment'>
  833:   provider: { id: number; type: string }
  834:   config: Record<string, unknown>
