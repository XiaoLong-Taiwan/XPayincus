 1625:       }
 1626: 
 1627:       // 只有待支付的订单才能重新支付
 1628:       if (record.status !== 'pending') {
 1629:         return reply.status(400).send({ error: '当前订单状态不允许支付' })
 1630:       }
 1631: 
