  908: async function createRechargePayUrl(
  909:   provider: { id: number; type: string; methods: unknown },
  910:   config: Record<string, unknown>,
  911:   orderNo: string,
  912:   amount: number,
  913:   paymentMethod: string | undefined,
  914:   urls: { notifyUrl: string; returnUrl: string; successUrl: string },
  915:   context?: PluginGatewayPaymentContext
  916: ): Promise<string | null> {
  917:   if (provider.type === 'yipay') {
  918:     const { epayConfig, valid, error } = buildEpayConfig(config)
  919:     if (!valid) {
  920:       throw new Error(error || 'æ”¯ä»˜æ¸ é“é…ç½®ä¸å®Œæ•´')
  921:     }
  922: 
  923:     const safeApiUrl = await assertSafeHttpUrl(epayConfig.apiurl, 'Epay API URL')
  924:     const safeEpayConfig = {
  925:       ...epayConfig,
  926:       apiurl: safeApiUrl.toString().replace(/\/+$/, '')
  927:     } as EpayConfig
  928:     const epay = createEpayClient(safeEpayConfig)
  929:     return epay.getPayLink({
  930:       type: paymentMethod || 'alipay',
  931:       out_trade_no: orderNo,
  932:       name: 'è´¦æˆ·å……å€¼',
  933:       money: amount.toFixed(2),
  934:       notify_url: urls.notifyUrl,
  935:       return_url: urls.successUrl
  936:     })
  937:   }
  938: 
  939:   if (provider.type === 'heleket') {
  940:     const { heleketConfig, valid, error } = buildHeleketConfig(config)
  941:     if (!valid) {
  942:       throw new Error(error || 'æ”¯ä»˜æ¸ é“é…ç½®ä¸å®Œæ•´')
  943:     }
  944: 
  945:     const heleket = createHeleketClient(heleketConfig)
  946:     const invoice = await heleket.createInvoice({
  947:       amount: amount.toFixed(2),
  948:       currency: heleketConfig.currency || 'CNY',
  949:       lifetime: heleketConfig.lifetimeSeconds,
  950:       order_id: orderNo,
  951:       url_return: urls.returnUrl,
  952:       url_success: urls.successUrl,
  953:       url_callback: urls.notifyUrl
  954:     })
  955: 
  956:     return typeof invoice.url === 'string' && invoice.url.trim() ? invoice.url : null
  957:   }
  958: 
  959:   if (provider.type === 'antom') {
  960:     const { config: antomConfig, valid, error } = buildAntomConfig(config)
  961:     if (!valid) throw new Error(error || 'Antom æ”¯ä»˜æ¸ é“é…ç½®ä¸å®Œæ•´')
  962:     const antom = new AntomClient(antomConfig)
  963:     const session = await antom.createPaymentSession({
  964:       orderNo,
  965:       amountCny: amount,
  966:       notifyUrl: urls.notifyUrl,
  967:       redirectUrl: urls.successUrl
  968:     })
  969:     if (session.result?.resultStatus !== 'S' || session.result.resultCode !== 'SUCCESS') {
  970:       throw new Error(session.result?.resultMessage || 'Antom åˆ›å»ºæ”¯ä»˜ä¼šè¯å¤±è´¥')
  971:     }
  972:     if (typeof session.normalUrl !== 'string' || !session.normalUrl.trim()) {
  973:       throw new Error('Antom æœªè¿”å›ž Hosted Checkout åœ°å€')
  974:     }
  975:     const normalUrl = await assertSafeHttpUrl(session.normalUrl, 'Antom Hosted Checkout URL')
  976:     if (normalUrl.protocol !== 'https:') throw new Error('Antom Hosted Checkout åœ°å€å¿…é¡»ä½¿ç”¨ HTTPS')
  977:     return normalUrl.toString()
  978:   }
  979: 
  980:   if (provider.type === PLUGIN_GATEWAY_PROVIDER_TYPE) {
  981:     return createPluginGatewayRechargePayUrl({
  982:       provider,
  983:       config,
  984:       orderNo,
  985:       amount,
  986:       paymentMethod,
  987:       urls,
  988:       context
  989:     })
  990:   }
  991: 
  992:   return null
  993: }
