  881:         ? {
  882:             data: input.callbackData,
  883:             headers: input.callbackHeaders ?? {},
  884:             ip: input.callbackIp ?? null
  885:           }
  886:         : null,
  887:       source: input.source,
  888:       occurredAt: new Date().toISOString()
  889:     },
  890:     idempotencyKey: `plugin-gateway-payment:${input.hook}:${input.orderNo}:${parsed.pluginConfig.pluginId}:${parsed.pluginConfig.gatewayExtensionKey}`,
  891:     actor: input.actor
  892:   })
  893: 
  894:   const normalized = normalizePluginGatewayDispatchResult({
  895:     actionRequestId: action.action.requestId,
  896:     contract: action.contract,
  897:     fallbackOrderNo: input.orderNo
  898:   })
  899:   if (!normalized.valid) return normalized
  900: 
  901:   return {
  902:     valid: true,
  903:     pluginConfig: parsed.pluginConfig,
  904:     result: normalized.result
  905:   }
  906: }
