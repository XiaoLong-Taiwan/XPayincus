 1031: async function validatePaymentProviderApiUrl(
 1032:   providerType: string,
 1033:   config: Record<string, unknown>
 1034: ): Promise<{ valid: boolean; error?: string; config: Record<string, unknown> }> {
 1035:   if (providerType !== 'yipay' && providerType !== 'heleket') {
 1036:     return { valid: true, config }
 1037:   }
 1038: 
 1039:   if (typeof config.apiurl !== 'string' || !config.apiurl.trim()) {
 1040:     return { valid: true, config }
 1041:   }
 1042: 
 1043:   try {
 1044:     const safeApiUrl = await assertSafeHttpUrl(
 1045:       config.apiurl,
 1046:       providerType === 'heleket' ? 'Heleket API URL' : 'Epay API URL'
 1047:     )
 1048:     return {
 1049:       valid: true,
 1050:       config: {
 1051:         ...config,
 1052:         apiurl: safeApiUrl.toString().replace(/\/+$/, '')
 1053:       }
 1054:     }
 1055:   } catch (error) {
 1056:     return {
 1057:       valid: false,
 1058:       error: error instanceof Error ? error.message : 'æ”¯ä»˜æ¸ é“æŽ¥å£åœ°å€ä¸åˆæ³•',
 1059:       config
 1060:     }
 1061:   }
 1062: }
