  592: function extractRechargeOrderNoFromCallback(
  593:   providerType: string,
  594:   callbackData: Record<string, unknown>
  595: ): string | undefined {
  596:   switch (providerType) {
  597:     case 'yipay':
  598:     case 'alipay_direct':
  599:     case 'wechat_direct':
  600:       return typeof callbackData.out_trade_no === 'string' ? callbackData.out_trade_no : undefined
  601:     case 'heleket':
  602:       return typeof callbackData.order_id === 'string' ? callbackData.order_id : undefined
  603:     case 'antom':
  604:       return typeof callbackData.paymentRequestId === 'string' ? callbackData.paymentRequestId : undefined
  605:     case 'stripe': {
  606:       const data = callbackData.data as { object?: { metadata?: { orderNo?: string } } } | undefined
  607:       return data?.object?.metadata?.orderNo
  608:     }
  609:     default:
  610:       return (callbackData.orderNo || callbackData.order_no || callbackData.out_trade_no) as string | undefined
  611:   }
  612: }
