  629: function getStringMetadata(metadata: Record<string, unknown>, keys: string[]): string | null {
  630:   for (const key of keys) {
  631:     const value = metadata[key]
  632:     if (typeof value === 'string' && value.trim()) {
  633:       return value.trim()
  634:     }
  635:   }
  636:   return null
  637: }
  638: 
  639: function getNumberMetadata(metadata: Record<string, unknown>, keys: string[]): number | null {
  640:   for (const key of keys) {
  641:     const value = metadata[key]
  642:     if (typeof value === 'number' && Number.isFinite(value) && value > 0) {
  643:       return Number(value.toFixed(2))
  644:     }
  645:     if (typeof value === 'string' && value.trim()) {
  646:       const parsed = Number(value.trim())
  647:       if (Number.isFinite(parsed) && parsed > 0) {
  648:         return Number(parsed.toFixed(2))
  649:       }
  650:     }
  651:   }
  652:   return null
  653: }
  654: 
  655: function normalizePluginGatewayPaymentState(status: string, metadata: Record<string, unknown>): PluginGatewayPaymentState {
  656:   const rawState = getStringMetadata(metadata, ['paymentState', 'gatewayState', 'state', 'status'])
  657:   const state = (rawState || status || 'pending').trim().toLowerCase()
  658:   if (state === 'completed' || state === 'complete' || state === 'paid' || state === 'success' || state === 'succeeded') {
  659:     return 'completed'
  660:   }
  661:   if (state === 'failed' || state === 'failure' || state === 'error' || state === 'declined') {
  662:     return 'failed'
  663:   }
  664:   if (state === 'cancelled' || state === 'canceled' || state === 'cancel' || state === 'expired' || state === 'closed') {
  665:     return 'cancelled'
  666:   }
  667:   return 'pending'
  668: }
  669: 
  670: function buildPluginGatewayCallbackHeaders(headers: Record<string, unknown>): Record<string, string> {
  671:   const result: Record<string, string> = {}
  672:   for (const [key, value] of Object.entries(headers)) {
  673:     const normalizedKey = key.trim().toLowerCase()
  674:     if (!normalizedKey || PLUGIN_GATEWAY_CALLBACK_HEADER_BLOCKLIST.has(normalizedKey)) continue
  675:     if (typeof value === 'string') {
  676:       result[normalizedKey] = value.slice(0, 1024)
  677:     } else if (Array.isArray(value)) {
  678:       result[normalizedKey] = value.map(item => String(item)).join(', ').slice(0, 1024)
  679:     }
  680:   }
  681:   return result
  682: }
