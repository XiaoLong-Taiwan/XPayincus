  500: function getRechargeCallbackBaseUrl(): string {
  501:   const callbackUrl = process.env.PAYMENT_CALLBACK_BASE_URL?.trim()
  502:   if (callbackUrl) {
  503:     return validatePublicBaseUrl(callbackUrl, 'PAYMENT_CALLBACK_BASE_URL')
  504:   }
  505: 
  506:   return getRechargeFrontendUrl()
  507: }
  508: 
  509: function getRechargeOrderExpiryAt(providerType: string, config: Record<string, unknown>): Date {
  510:   if (providerType === 'heleket') {
  511:     const { heleketConfig } = buildHeleketConfig(config)
  512:     return new Date(Date.now() + heleketConfig.lifetimeSeconds * 1000)
  513:   }
  514: 
  515:   if (providerType === 'antom') {
  516:     const { config: antomConfig } = buildAntomConfig(config)
  517:     return new Date(Date.now() + antomConfig.sessionExpiryMinutes * 60_000)
  518:   }
  519: 
  520:   return new Date(Date.now() + 30 * 60 * 1000)
  521: }
  522: 
  523: function getHeleketStatusMessage(status: string): string {
  524:   return getHeleketStatusDescription(status)
  525: }
  526: 
  527: function resolveRechargeProviderConfig(
  528:   providerType: string,
  529:   currentConfig: Record<string, unknown>,
  530:   snapshotValue: unknown
  531: ): { config: Record<string, unknown>; source: 'snapshot' | 'provider' } {
  532:   return resolveRechargeProviderConfigSnapshot(providerType, currentConfig, snapshotValue)
  533: }
  534: 
  535: function buildRechargeRecordView(record: {
  536:   id?: number
  537:   orderNo: string
  538:   amount: unknown
  539:   actualAmount?: unknown
  540:   fee?: unknown
  541:   status: string
  542:   provider?: { id: number; name: string; type: string } | null
  543:   paymentMethod?: string | null
  544:   paymentDetails?: unknown
  545:   tradeNo?: string | null
  546:   failReason?: string | null
  547:   createdAt: Date
  548:   expiredAt?: Date | null
  549:   completedAt?: Date | null
  550: }) {
  551:   const paymentInfo = extractRechargePaymentDisplayInfo(record.paymentDetails)
  552:   const paymentDetails = readRechargePaymentDetails(record.paymentDetails)
  553:   const amount = Number(record.amount)
  554:   const actualAmount = record.actualAmount !== undefined && record.actualAmount !== null
  555:     ? Number(record.actualAmount)
  556:     : null
  557:   const fee = record.fee !== undefined && record.fee !== null ? Number(record.fee) : 0
  558:   const payableAmount = paymentDetails.recharge?.payableAmount !== undefined && paymentDetails.recharge.payableAmount !== null
  559:     ? Number(paymentDetails.recharge.payableAmount)
  560:     : amount
  561: 
  562:   return {
  563:     id: record.id,
  564:     orderNo: record.orderNo,
  565:     amount,
  566:     payableAmount,
  567:     actualAmount,
  568:     fee,
  569:     status: record.status,
  570:     provider: record.provider ? {
  571:       id: record.provider.id,
  572:       name: record.provider.name,
  573:       type: record.provider.type
  574:     } : null,
  575:     paymentMethod: record.paymentMethod || null,
  576:     actualPaymentMethod: paymentInfo.actualPaymentMethod,
  577:     paymentCurrency: paymentInfo.paymentCurrency,
  578:     paymentNetwork: paymentInfo.paymentNetwork,
  579:     paymentUuid: paymentInfo.paymentUuid,
  580:     paymentTxid: paymentInfo.paymentTxid,
  581:     invoiceCurrency: paymentInfo.invoiceCurrency,
  582:     gatewayStatus: paymentInfo.gatewayStatus,
  583:     gatewayStatusDescription: paymentInfo.gatewayStatusDescription,
  584:     tradeNo: record.tradeNo || null,
  585:     failReason: record.failReason || null,
  586:     createdAt: record.createdAt.toISOString(),
  587:     expiredAt: record.expiredAt?.toISOString() || null,
  588:     completedAt: record.completedAt?.toISOString() || null
  589:   }
  590: }
