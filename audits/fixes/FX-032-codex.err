  995: function validateActiveRechargeProvider(
  996:   provider: { type: string; config: Record<string, unknown> }
  997: ): { valid: boolean; error?: string } {
  998:   if (!isRechargeProviderTypeSupported(provider.type)) {
  999:     return { valid: false, error: getUnsupportedProviderError(provider.type) }
 1000:   }
 1001: 
 1002:   if (provider.type === 'yipay') {
 1003:     const { valid, error } = buildEpayConfig(provider.config)
 1004:     return { valid, error }
 1005:   }
 1006: 
 1007:   if (provider.type === 'heleket') {
 1008:     const { valid, error } = buildHeleketConfig(provider.config)
 1009:     return { valid, error }
 1010:   }
 1011: 
 1012:   if (provider.type === 'antom') {
 1013:     const { valid, error } = buildAntomConfig(provider.config)
 1014:     return { valid, error }
 1015:   }
 1016: 
 1017:   if (provider.type === PLUGIN_GATEWAY_PROVIDER_TYPE) {
 1018:     const { valid, error } = buildPluginGatewayProviderConfig(provider.config)
 1019:     return { valid, error }
 1020:   }
 1021: 
 1022:   if (provider.type === MANUAL_PROVIDER_TYPE) {
 1023:     return normalizeManualRechargeInstructions(provider.config.instructions)
 1024:       ? { valid: true }
 1025:       : { valid: false, error: 'äººå·¥å……å€¼æ¸ é“å¿…é¡»å¡«å†™ä»˜æ¬¾è¯´æ˜Ž' }
 1026:   }
 1027: 
 1028:   return { valid: false, error: getUnsupportedProviderError(provider.type) }
 1029: }
