 3159:     providerIdNum: number,
 3160:     callbackData: Record<string, unknown>,
 3161:     clientIp: string
 3162:   ) {
 3163:     const preliminaryOrderNo = extractRechargeOrderNoFromCallback(PLUGIN_GATEWAY_PROVIDER_TYPE, callbackData)
 3164:     if (!preliminaryOrderNo) {
 3165:       request.log.warn({ providerId: providerIdNum, data: sanitizeObject(callbackData) }, '插件支付回调缺少订单号')
 3166:       return reply.status(400).send({ error: '缺少订单号' })
 3167:     }
 3168: 
 3169:     const record = await db.getRechargeRecordByOrderNo(preliminaryOrderNo)
 3170:     if (!record) {
 3171:       request.log.warn({ providerId: providerIdNum, orderNo: preliminaryOrderNo }, '插件支付回调订单不存在')
 3172:       return reply.status(404).send({ error: '订单不存在' })
 3173:     }
 3174: 
 3175:     if (record.providerId !== providerIdNum) {
 3176:       request.log.warn({ orderNo: preliminaryOrderNo, expected: record.providerId, actual: providerIdNum }, '插件支付回调支付渠道不匹配')
 3177:       return reply.status(400).send({ error: '支付渠道不匹配' })
 3178:     }
 3179: 
 3180:     const currentConfig = typeof provider.config === 'string'
 3181:       ? JSON.parse(provider.config)
 3182:       : (provider.config || {}) as Record<string, unknown>
 3183:     const { config, source: configSource } = resolveRechargeProviderConfig(
 3184:       provider.type,
 3185:       currentConfig,
 3186:       (record as any).providerConfigSnapshot
 3187:     )
 3188:     const providerValidation = validateActiveRechargeProvider({ type: provider.type, config })
 3189:     if (!providerValidation.valid) {
 3190:       request.log.error({ providerId: providerIdNum, type: provider.type, error: providerValidation.error, configSource }, '插件支付回调拒绝未安全实现的支付渠道')
 3191:       return reply.status(400).send({ error: providerValidation.error || '支付渠道未安全启用' })
 3192:     }
 3193: 
 3194:     const rechargeAmount = Number(record.amount)
 3195:     const expectedAmount = getRechargePayableAmount({
 3196:       amount: record.amount,
 3197:       fee: record.fee,
 3198:       paymentDetails: (record as any).paymentDetails
 3199:     })
 3200:     const creditedAmount = record.actualAmount !== null && record.actualAmount !== undefined ? Number(record.actualAmount) : rechargeAmount
 3201:     const pluginPayment = await dispatchPluginGatewayPaymentHook({
 3202:       hook: 'webhook',
 3203:       provider,
 3204:       config,
 3205:       orderNo: record.orderNo,
 3206:       rechargeId: record.id,
 3207:       userId: record.userId,
 3208:       amount: rechargeAmount,
 3209:       payableAmount: expectedAmount,
 3210:       paymentMethod: (record as any).paymentMethod || null,
 3211:       paymentDetails: (record as any).paymentDetails,
 3212:       source: 'recharge.callback',
 3213:       callbackData,
 3214:       callbackHeaders: buildPluginGatewayCallbackHeaders(request.headers || {}),
 3215:       callbackIp: clientIp,
 3216:       actor: { id: null, role: 'system' }
 3217:     })
 3218: 
 3219:     if (!pluginPayment.valid) {
 3220:       request.log.warn({ providerId: providerIdNum, orderNo: record.orderNo, error: pluginPayment.error }, '插件支付回调归一化失败')
 3221:       return reply.status(400).send({ error: pluginPayment.error })
 3222:     }
 3223: 
 3224:     const pluginResult = pluginPayment.result
 3225:     if (!isRechargeGatewayOrderNoMatch(record.orderNo, pluginResult.orderNo)) {
 3226:       request.log.warn(
 3227:         { orderNo: record.orderNo, pluginOrderNo: pluginResult.orderNo },
 3228:         '插件支付回调返回订单号不匹配，拒绝处理'
 3229:       )
 3230:       return reply.status(400).send({ error: '支付订单号校验失败' })
 3231:     }
 3232: 
 3233:     const tradeNoForIndex = getTradeNoForIndex(record.orderNo, pluginResult.tradeNo)
 3234:     if (await isCallbackProcessed(providerIdNum, record.orderNo, tradeNoForIndex)) {
 3235:       request.log.info({ orderNo: record.orderNo }, '插件支付重复回调，忽略')
 3236:       return { code: 'SUCCESS', message: 'OK' }
 3237:     }
 3238: 
 3239:     const paymentDetails = buildPluginGatewayCallbackPaymentDetails((record as any).paymentDetails, {
 3240:       providerCode: pluginPayment.pluginConfig.providerCode,
 3241:       pluginId: pluginPayment.pluginConfig.pluginId,
 3242:       gatewayExtensionKey: pluginPayment.pluginConfig.gatewayExtensionKey,
 3243:       state: pluginResult.state,
 3244:       requestId: pluginResult.requestId,
 3245:       tradeNo: pluginResult.tradeNo,
 3246:       message: pluginResult.message,
 3247:       metadata: pluginResult.metadata
 3248:     })
 3249:     const callbackPayload = {
 3250:       source: 'plugin_gateway_callback',
 3251:       pluginRequestId: pluginResult.requestId,
 3252:       pluginState: pluginResult.state,
 3253:       pluginMessage: pluginResult.message,
 3254:       pluginMetadata: sanitizeObject(pluginResult.metadata),
 3255:       callbackData: sanitizeObject(callbackData)
 3256:     }
 3257: 
 3258:     if (pluginResult.state === 'pending') {
 3259:       await db.updateRechargeOrderMetadata(record.orderNo, {
 3260:         tradeNo: pluginResult.tradeNo,
 3261:         callbackData: callbackPayload,
 3262:         paymentDetails
 3263:       })
 3264:       request.log.info({ orderNo: record.orderNo, pluginRequestId: pluginResult.requestId }, '插件支付回调仍为待处理状态')
 3265:       return { code: 'SUCCESS', message: 'OK' }
 3266:     }
 3267: 
 3268:     if (record.status === 'completed') {
 3269:       await markCallbackProcessed(providerIdNum, record.orderNo, tradeNoForIndex, clientIp)
 3270:       request.log.info({ orderNo: record.orderNo }, '插件支付回调订单已完成，幂等返回')
 3271:       return { code: 'SUCCESS', message: 'OK' }
 3272:     }
 3273: 
 3274:     if (record.status !== 'pending' && record.status !== 'paid') {
 3275:       request.log.warn({ orderNo: record.orderNo, status: record.status }, '插件支付回调订单状态不允许处理')
 3276:       return reply.status(400).send({ error: '订单状态异常' })
 3277:     }
 3278: 
 3279:     if (pluginResult.state === 'cancelled') {
 3280:       const cancelledRecord = await db.cancelRecharge(record.orderNo, callbackPayload, paymentDetails)
 3281:       await markCallbackProcessed(providerIdNum, record.orderNo, tradeNoForIndex, clientIp)
 3282:       request.log.info({ orderNo: record.orderNo, id: cancelledRecord.id }, '插件支付回调已取消订单')
 3283:       return { code: 'SUCCESS', message: 'OK' }
 3284:     }
 3285: 
 3286:     if (pluginResult.state === 'failed') {
 3287:       const failReason = pluginResult.message || '插件支付网关返回支付失败'
 3288:       const failedRecord = await db.failRecharge(record.orderNo, failReason, callbackPayload, paymentDetails)
 3289:       await markCallbackProcessed(providerIdNum, record.orderNo, tradeNoForIndex, clientIp)
 3290:       request.log.info({ orderNo: record.orderNo, id: failedRecord.id }, '插件支付回调已标记失败')
 3291:       return { code: 'SUCCESS', message: 'OK' }
 3292:     }
 3293: 
 3294:     if (pluginResult.actualAmount === null || !Number.isFinite(pluginResult.actualAmount) || pluginResult.actualAmount <= 0) {
 3295:       request.log.warn({ providerId: providerIdNum, orderNo: record.orderNo, actualAmount: pluginResult.actualAmount }, '插件支付回调缺少有效支付金额')
 3296:       return reply.status(400).send({ error: '缺少有效支付金额' })
 3297:     }
 3298: 
 3299:     const diff = Math.abs(pluginResult.actualAmount - expectedAmount)
 3300:     if (diff > AMOUNT_TOLERANCE_CENTS / 100) {
 3301:       request.log.warn({
 3302:         orderNo: record.orderNo,
 3303:         expected: expectedAmount,
 3304:         actual: pluginResult.actualAmount,
 3305:         diff
 3306:       }, '插件支付回调金额与订单金额不匹配，拒绝处理')
 3307:       await createLog(
 3308:         record.userId,
 3309:         'system',
 3310:         'recharge.amount_mismatch',
 3311:         `Plugin gateway amount mismatch rejected: order ${record.orderNo}, expected ${expectedAmount}, actual ${pluginResult.actualAmount}`,
 3312:         'warning'
 3313:       )
 3314:       return reply.status(400).send({ error: '支付金额与订单金额不匹配' })
 3315:     }
 3316: 
 3317:     // 订单本地过期不再静默丢弃：回调已验签验额说明款项真实到账，
 3318:     // 继续走幂等入账（completeRecharge 只会对 pending/paid 订单入账一次）。
 3319:     if (record.expiredAt && new Date(record.expiredAt) < new Date()) {
 3320:       request.log.warn({ orderNo: record.orderNo, expiredAt: record.expiredAt }, '插件支付回调订单已过本地过期时间，但已验签验额，按真实到账继续入账')
 3321:     }
 3322: 
 3323:     const completion = await db.completeRecharge(record.orderNo, {
 3324:       tradeNo: pluginResult.tradeNo || undefined,
 3325:       actualAmount: creditedAmount,
 3326:       callbackData: callbackPayload,
 3327:       paymentDetails
 3328:     })
 3329: 
 3330:     await markCallbackProcessed(providerIdNum, record.orderNo, tradeNoForIndex, clientIp)
 3331: 
 3332:     if (completion.completedNow) {
 3333:       await createLog(
 3334:         record.userId,
 3335:         'user',
 3336:         'recharge.completed',
 3337:         `Recharge completed via plugin gateway callback: order ${record.orderNo}, amount ${creditedAmount}, tradeNo: ${pluginResult.tradeNo || 'N/A'}`,
 3338:         'success'
 3339:       )
 3340: 
 3341:       try {
 3342:         await createInboxMessage({
