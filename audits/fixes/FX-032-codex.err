  100: function parsePositiveId(value: unknown): number | null {
  101:   if (typeof value === 'number') {
  102:     return Number.isSafeInteger(value) && value > 0 ? value : null
  103:   }
  104: 
  105:   if (typeof value !== 'string' || !POSITIVE_ID_PATTERN.test(value)) {
  106:     return null
  107:   }
  108: 
  109:   const parsed = Number(value)
  110:   return Number.isSafeInteger(parsed) ? parsed : null
  111: }
  112: 
  113: function parsePositiveJsonMoney(value: unknown): number | null {
  114:   if (typeof value !== 'number' || !Number.isFinite(value) || value <= 0) {
  115:     return null
  116:   }
  117: 
  118:   return value
  119: }
