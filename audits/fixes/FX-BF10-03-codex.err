    5: import { FastifyInstance } from 'fastify'
    6: import { Prisma } from '@prisma/client'
    7: import { prisma } from '../db/prisma.js'
    8: import { createLog } from '../db/logs.js'
    9: import { buildHostingVipSql, calculateVipLevel, getVipBadgeStyleForLevel, getVipRules, type NormalizedVipRule } from '../services/vip-levels.js'
   10: 
   11: interface HostingOwnerRow {
   12:   id: number
   13:   username: string
   14:   email: string | null
   15:   status: string
   16:   avatarStyle: string
   17:   avatarBadgeId: string | null
   18:   hostingBalance: unknown
   19:   createdAt: Date
   20:   hostCount: number
   21:   listedPackageCount: number
   22:   instanceCount: number
   23:   frozenBalance: unknown
   24:   totalHostingIncome: unknown
   25:   hostingZoneId: number | null
   26: }
   27: 
   28: interface CountRow {
   29:   total: number
   30: }
   31: 
   32: interface SummaryRow {
   33:   totalHosts: number
   34:   totalListedPackages: number
   35:   totalInstances: number
   36:   totalAvailableBalance: unknown
   37:   totalFrozenBalance: unknown
   38:   totalHostingIncome: unknown
   39: }
   40: 
   41: interface HostingZonePayload {
   42:   name?: string
   43:   ownerId?: number
   44:   logoUrl?: string
   45: }
   46: 
   47: const MAX_LOGO_URL_LENGTH = 2048
   48: const POSITIVE_ROUTE_ID_PATTERN = /^[1-9]\d*$/
   49: const HOSTING_OWNER_SORT_FIELDS = [
   50:   'vipLevel',
   51:   'hostingBalance',
   52:   'frozenBalance',
   53:   'totalIncome',
   54:   'hostCount',
   55:   'packageCount',
   56:   'instanceCount'
   57: ] as const
   58: 
   59: type HostingOwnerSortBy = typeof HOSTING_OWNER_SORT_FIELDS[number]
   60: type SortOrder = 'asc' | 'desc'
   61: 
   62: function toNumber(value: unknown): number {
   63:   if (value === null || value === undefined) return 0
   64:   if (typeof value === 'number') return value
   65:   if (typeof value === 'bigint') return Number(value)
   66:   return Number.parseFloat(String(value)) || 0
   67: }
   68: 
   69: function roundMoney(value: number): number {
   70:   return Number(value.toFixed(2))
   71: }
   72: 
   73: function parsePositiveRouteId(value: string): number | null {
   74:   if (!POSITIVE_ROUTE_ID_PATTERN.test(value)) return null
   75:   const parsed = Number(value)
   76:   return Number.isSafeInteger(parsed) ? parsed : null
   77: }
   78: 
   79: function parseBoundedInt(value: string | undefined, fallback: number, min: number, max: number): number {
   80:   const parsed = Number.parseInt(value || '', 10)
   81:   if (!Number.isFinite(parsed)) return fallback
   82:   return Math.min(max, Math.max(min, parsed))
   83: }
   84: 
   85: function normalizeHostingOwnerSortBy(value: string | undefined): HostingOwnerSortBy {
   86:   return HOSTING_OWNER_SORT_FIELDS.includes(value as HostingOwnerSortBy)
   87:     ? value as HostingOwnerSortBy
   88:     : 'totalIncome'
   89: }
   90: 
   91: function normalizeSortOrder(value: string | undefined): SortOrder {
   92:   return value === 'asc' ? 'asc' : 'desc'
   93: }
   94: 
   95: function buildHostingOwnerOrderSql(sortBy: HostingOwnerSortBy, sortOrder: SortOrder, vipRules: NormalizedVipRule[]): Prisma.Sql {
   96:   const direction = Prisma.raw(sortOrder === 'asc' ? 'ASC' : 'DESC')
   97:   const expression = (() => {
   98:     switch (sortBy) {
   99:       case 'vipLevel':
  100:         return buildHostingVipSql(vipRules)
  101:       case 'hostingBalance':
  102:         return Prisma.sql`"hostingBalance"`
  103:       case 'frozenBalance':
  104:         return Prisma.sql`"frozenBalance"`
  105:       case 'hostCount':
  106:         return Prisma.sql`"hostCount"`
  107:       case 'packageCount':
  108:         return Prisma.sql`"listedPackageCount"`
  109:       case 'instanceCount':
  110:         return Prisma.sql`"instanceCount"`
  111:       case 'totalIncome':
  112:       default:
  113:         return Prisma.sql`"totalHostingIncome"`
  114:     }
  115:   })()
  116: 
  117:   return Prisma.sql`ORDER BY ${expression} ${direction}, id ASC`
  118: }
  119: 
  120: function escapeLike(value: string): string {
  121:   return value.replace(/[\\%_]/g, char => `\\${char}`)
  122: }
  123: 
  124: function normalizeZoneName(value: unknown): string {
  125:   return String(value || '').trim().replace(/\s+/g, ' ').slice(0, 40)
  126: }
  127: 
  128: function validateLogoUrl(value: unknown): string | null {
  129:   if (typeof value !== 'string') return null
  130:   const trimmed = value.trim()
  131:   if (!trimmed || trimmed.length > MAX_LOGO_URL_LENGTH || /\s/.test(trimmed)) return null
  132: 
  133:   let url: URL
  134:   try {
  135:     url = new URL(trimmed)
  136:   } catch {
  137:     return null
  138:   }
  139: 
  140:   if (url.protocol !== 'http:' && url.protocol !== 'https:') return null
  141:   if (!url.hostname || url.username || url.password) return null
  142: 
  143:   url.hash = ''
  144:   return url.toString()
  145: }
  146: 
  147: function buildSearchSql(search: string): Prisma.Sql {
  148:   const keyword = search.trim()
  149:   if (!keyword) {
  150:     return Prisma.empty
  151:   }
  152: 
  153:   const pattern = `%${escapeLike(keyword)}%`
  154:   const numericId = /^\d+$/.test(keyword) ? Number(keyword) : null
  155:   const idCondition = numericId !== null && Number.isSafeInteger(numericId)
  156:     ? Prisma.sql`u.id = ${numericId}`
  157:     : Prisma.sql`false`
  158: 
  159:   return Prisma.sql`
  160:     AND (
  161:       ${idCondition}
  162:       OR u.username ILIKE ${pattern} ESCAPE '\\'
  163:       OR u.email ILIKE ${pattern} ESCAPE '\\'
  164:     )
  165:   `
  166: }
  167: 
  168: function buildQualifiedOwnersCte(searchSql: Prisma.Sql): Prisma.Sql {
  169:   return Prisma.sql`
  170:     WITH host_stats AS (
  171:       SELECT user_id, COUNT(*)::int AS host_count
  172:       FROM hosts
  173:       GROUP BY user_id
  174:     ),
  175:     listed_package_stats AS (
  176:       SELECT p.user_id, COUNT(DISTINCT p.id)::int AS listed_package_count
  177:       FROM packages p
  178:       WHERE p.active = true
  179:         AND p.global_shared = true
  180:         AND EXISTS (
  181:           SELECT 1
  182:           FROM package_hosts ph
  183:           JOIN hosts package_host ON package_host.id = ph.host_id
  184:           WHERE ph.package_id = p.id
  185:             AND package_host.user_id = p.user_id
  186:         )
  187:       GROUP BY p.user_id
  188:     ),
  189:     instance_stats AS (
  190:       SELECT h.user_id, COUNT(i.id)::int AS instance_count
  191:       FROM hosts h
  192:       LEFT JOIN instances i ON i.host_id = h.id AND i.status <> 'deleted'
  193:       GROUP BY h.user_id
  194:     ),
  195:     frozen_stats AS (
  196:       SELECT user_id, COALESCE(SUM(amount), 0)::numeric AS frozen_balance
  197:       FROM hosting_balance_logs
  198:       WHERE frozen = true
  199:         AND type = 'income'
  200:       GROUP BY user_id
  201:     ),
  202:     income_stats AS (
  203:       SELECT user_id, COALESCE(SUM(amount), 0)::numeric AS total_hosting_income
  204:       FROM hosting_balance_logs
  205:       WHERE type = 'income'
  206:       GROUP BY user_id
  207:     ),
  208:     qualified_owners AS (
  209:       SELECT
  210:         u.id,
  211:         u.username,
  212:         u.email,
  213:         u.status::text AS status,
  214:         u.avatar_style AS "avatarStyle",
  215:         u.avatar_badge_id AS "avatarBadgeId",
  216:         u.hosting_balance AS "hostingBalance",
  217:         u.created_at AS "createdAt",
  218:         hs.host_count AS "hostCount",
  219:         lps.listed_package_count AS "listedPackageCount",
  220:         COALESCE(ins.instance_count, 0)::int AS "instanceCount",
  221:         COALESCE(fs.frozen_balance, 0)::numeric AS "frozenBalance",
  222:         COALESCE(inc.total_hosting_income, 0)::numeric AS "totalHostingIncome",
  223:         hz.id AS "hostingZoneId"
  224:       FROM users u
  225:       JOIN host_stats hs ON hs.user_id = u.id AND hs.host_count > 0
  226:       JOIN listed_package_stats lps ON lps.user_id = u.id AND lps.listed_package_count > 0
  227:       JOIN income_stats inc ON inc.user_id = u.id AND inc.total_hosting_income <> 0
  228:       LEFT JOIN instance_stats ins ON ins.user_id = u.id
  229:       LEFT JOIN frozen_stats fs ON fs.user_id = u.id
  230:       LEFT JOIN hosting_zones hz ON hz.owner_id = u.id
  231:       WHERE u.role <> 'admin'
  232:       ${searchSql}
  233:     )
  234:   `
  235: }
  236: 
  237: async function getQualifiedOwner(ownerId: number): Promise<HostingOwnerRow | null> {
  238:   const qualifiedOwnersCte = buildQualifiedOwnersCte(Prisma.sql`AND u.id = ${ownerId}`)
  239:   const owners = await prisma.$queryRaw<HostingOwnerRow[]>(Prisma.sql`
  240:     ${qualifiedOwnersCte}
  241:     SELECT *
  242:     FROM qualified_owners
  243:     LIMIT 1
  244:   `)
  245:   return owners[0] || null
  246: }
  247: 
  248: function formatZone(zone: any) {
  249:   return {
  250:     id: zone.id,
  251:     name: zone.name,
  252:     logoUrl: zone.logoUrl,
  253:     active: zone.active,
  254:     sortOrder: zone.sortOrder,
  255:     createdAt: zone.createdAt.toISOString(),
  256:     updatedAt: zone.updatedAt.toISOString(),
  257:     owner: {
  258:       id: zone.owner.id,
  259:       username: zone.owner.username,
  260:       email: zone.owner.email,
  261:       avatarStyle: zone.owner.avatarStyle,
  262:       avatarBadgeId: zone.owner.avatarBadgeId ?? null
  263:     },
  264:     listedPackageCount: zone.listedPackageCount || 0,
  265:     hostCount: zone.hostCount || 0
  266:   }
  267: }
  268: 
  269: async function attachZoneStats(zones: any[]) {
  270:   if (zones.length === 0) return []
  271: 
  272:   const ownerIds = zones.map(zone => zone.ownerId)
  273:   const [packageRows, hostRows] = await Promise.all([
  274:     prisma.package.groupBy({
  275:       by: ['userId'],
  276:       where: {
  277:         userId: { in: ownerIds },
  278:         active: true,
  279:         globalShared: true
  280:       },
  281:       _count: { _all: true }
  282:     }),
  283:     prisma.host.groupBy({
  284:       by: ['userId'],
  285:       where: {
  286:         userId: { in: ownerIds }
  287:       },
  288:       _count: { _all: true }
  289:     })
  290:   ])
  291: 
  292:   const packageCounts = new Map(packageRows.map(row => [row.userId, row._count._all]))
  293:   const hostCounts = new Map(hostRows.map(row => [row.userId, row._count._all]))
  294: 
  295:   return zones.map(zone => ({
  296:     ...zone,
  297:     listedPackageCount: packageCounts.get(zone.ownerId) || 0,
  298:     hostCount: hostCounts.get(zone.ownerId) || 0
  299:   }))
  300: }
