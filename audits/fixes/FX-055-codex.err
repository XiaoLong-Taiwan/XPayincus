/**
 * Caddy API å®¢æˆ·ç«¯
 * é€šè¿‡ 8444 ç«¯å£ Basic Auth ä¿æŠ¤çš„é€šé“è°ƒç”¨ Caddy Admin API
 */

import { Agent, request as undiciRequest } from 'undici'
import { formatHostForUrl } from './network-address.js'

// è¯·æ±‚è¶…æ—¶é…ç½®ï¼ˆæ¯«ç§’ï¼‰
const REQUEST_TIMEOUT = 30000 // 30ç§’
const CONNECT_TIMEOUT = 10000 // 10ç§’

export interface CaddyClientConfig {
  host: string // å®¿ä¸»æœº IP æˆ–åŸŸå
  port: number // Caddy API ç«¯å£ (é»˜è®¤ 8444)
  username: string // Basic Auth ç”¨æˆ·å
  password: string // Basic Auth å¯†ç 
}

export interface CaddyRoute {
  '@id'?: string
  match?: Array<{ host?: string[]; protocol?: string }>
  handle?: Array<{
    handler: string
    upstreams?: Array<{ dial: string }>
    routes?: CaddyRoute[]
  }>
  terminal?: boolean
}

/**
 * Caddy API å®¢æˆ·ç«¯ç±»
 */
export class CaddyClient {
  private baseUrl: string
  private authHeader: string
  private agent: Agent

  constructor(config: CaddyClientConfig) {
    this.baseUrl = `https://${formatHostForUrl(config.host)}:${config.port}`
    this.authHeader = 'Basic ' + Buffer.from(`${config.username}:${config.password}`).toString('base64')
    
    // åˆ›å»º undici Agentï¼Œå¿½ç•¥è‡ªç­¾åè¯ä¹¦é”™è¯¯ï¼Œé…ç½®è¶…æ—¶
    this.agent = new Agent({
      connect: {
        rejectUnauthorized: false,
        timeout: CONNECT_TIMEOUT
      }
    })
  }

  /**
   * å‘èµ· API è¯·æ±‚
   */
  private async request<T>(
    method: string,
    path: string,
    body?: unknown
  ): Promise<T> {
    const url = `${this.baseUrl}${path}`
    
    const controller = new AbortController()
    const timeoutId = setTimeout(() => controller.abort(), REQUEST_TIMEOUT)

    try {
      const response = await undiciRequest(url, {
        method,
        dispatcher: this.agent,
        signal: controller.signal,
        headers: {
          'Authorization': this.authHeader,
          'Content-Type': 'application/json'
        },
        body: body ? JSON.stringify(body) : undefined
      })

      if (response.statusCode >= 400) {
        const errorText = await response.body.text()
        throw new Error(`Caddy API error: ${response.statusCode} ${errorText}`)
      }

      // æŸäº›è¯·æ±‚æ²¡æœ‰å“åº”ä½“
      const text = await response.body.text()
      if (!text) {
        return {} as T
      }
      
      return JSON.parse(text) as T
    } finally {
      clearTimeout(timeoutId)
    }
  }

  /**
   * èŽ·å– Caddy é…ç½®
   */
  async getConfig(): Promise<unknown> {
    return this.request('GET', '/config/')
  }

  /**
   * æµ‹è¯•è¿žæŽ¥
   */
  async testConnection(): Promise<boolean> {
    try {
      console.log(`[Caddy Client] æµ‹è¯•è¿žæŽ¥: ${this.baseUrl}/config/`)
      await this.getConfig()
      console.log(`[Caddy Client] è¿žæŽ¥æˆåŠŸ: ${this.baseUrl}`)
      return true
    } catch (error) {
      const errorMessage = error instanceof Error ? error.message : String(error)
      // æ£€æŸ¥æ˜¯å¦æ˜¯è¶…æ—¶é”™è¯¯
      const isTimeout = errorMessage.includes('abort') || errorMessage.includes('timeout') || errorMessage.includes('ETIMEDOUT')
      console.error(`[Caddy Client] è¿žæŽ¥å¤±è´¥: ${this.baseUrl}`, {
        error: errorMessage,
        isTimeout,
        stack: error instanceof Error ? error.stack : undefined
      })
      return false
    }
  }

  /**
   * æ·»åŠ åä»£ç«™ç‚¹
   * 
   * æž¶æž„è¯´æ˜Žï¼š
   * - ä½¿ç”¨ç»Ÿä¸€çš„ `sites` æœåŠ¡å™¨ç›‘å¬ :80 å’Œ :443
   * - HTTPS ç«™ç‚¹ï¼šæ­£å¸¸é…ç½®ï¼ŒCaddy è‡ªåŠ¨å¤„ç†è¯ä¹¦å’Œé‡å®šå‘
   * - HTTP ç«™ç‚¹ï¼šæ·»åŠ  protocol åŒ¹é…ï¼Œä»…å“åº” HTTP è¯·æ±‚
   * 
   * @param domain åŸŸå
   * @param targetIp ç›®æ ‡ IP (å®žä¾‹å†…ç½‘ IP)
   * @param targetPort ç›®æ ‡ç«¯å£
   * @param httpsEnabled æ˜¯å¦å¯ç”¨ HTTPSï¼ˆè‡ªåŠ¨ç”³è¯· Let's Encrypt è¯ä¹¦ï¼‰
   */
  async addSite(domain: string, targetIp: string, targetPort: number, httpsEnabled: boolean = true): Promise<void> {
    const routeId = `site-${domain.replace(/\./g, '-')}`
    
    // æž„å»ºè·¯ç”±é…ç½®
    const route: CaddyRoute = {
      '@id': routeId,
      match: [{ host: [domain] }],
      handle: [{
        handler: 'reverse_proxy',
        upstreams: [{ dial: `${targetIp}:${targetPort}` }]
      }],
      terminal: true
    }

    // HTTP-only ç«™ç‚¹ï¼šæ·»åŠ åè®®åŒ¹é…ï¼Œä»…å“åº” HTTP è¯·æ±‚
    if (!httpsEnabled) {
      route.match = [{ host: [domain], protocol: 'http' }]
    }

    // ç»Ÿä¸€ä½¿ç”¨ sites æœåŠ¡å™¨
    const serverName = 'sites'

    // ç­–ç•¥ï¼šä¼˜å…ˆä½¿ç”¨ç²¾ç¡®çš„ API è·¯å¾„ï¼Œé¿å…å½±å“ Caddyfile å®šä¹‰çš„æœåŠ¡å™¨
    try {
      // å°è¯•æ·»åŠ è·¯ç”±åˆ°çŽ°æœ‰æœåŠ¡å™¨
      await this.request('POST', `/config/apps/http/servers/${serverName}/routes`, route)
      return
    } catch (postError) {
      // POST å¤±è´¥ï¼Œå¯èƒ½æœåŠ¡å™¨ä¸å­˜åœ¨
      const postErrorMsg = postError instanceof Error ? postError.message : String(postError)
      console.log(`[Caddy] POST è·¯ç”±å¤±è´¥: ${postErrorMsg}`)
    }

    // æœåŠ¡å™¨ä¸å­˜åœ¨ï¼Œåˆ›å»ºå®ƒ
    const serverConfig: Record<string, unknown> = {
      listen: [':80', ':443'],
      routes: [route]
    }
    
    // ç¦ç”¨è‡ªåŠ¨ HTTPS é‡å®šå‘ï¼ˆæˆ‘ä»¬é€šè¿‡è·¯ç”±åŒ¹é…æŽ§åˆ¶ï¼‰
    serverConfig.automatic_https = {
      disable_redirects: true
    }

    try {
      // å°è¯•ç›´æŽ¥åˆ›å»ºæœåŠ¡å™¨
      await this.request('PUT', `/config/apps/http/servers/${serverName}`, serverConfig)
      return
    } catch (putError) {
      const putErrorMsg = putError instanceof Error ? putError.message : String(putError)
      console.log(`[Caddy] PUT æœåŠ¡å™¨å¤±è´¥: ${putErrorMsg}`)
      
      // åªæœ‰å½“æ˜¯ 404 é”™è¯¯æ—¶ï¼Œæ‰è¯´æ˜Ž http åº”ç”¨ä¸å­˜åœ¨
      if (!putErrorMsg.includes('404')) {
        // å…¶ä»–é”™è¯¯ï¼Œç›´æŽ¥æŠ›å‡º
        throw putError
      }
    }

    // http åº”ç”¨ä¸å­˜åœ¨ï¼Œè¿™æ˜¯éžå¸¸ç½•è§çš„æƒ…å†µï¼ˆCaddyfile æ²¡æœ‰ä»»ä½• HTTP é…ç½®ï¼‰
    // ä½¿ç”¨ PATCH åˆå¹¶ï¼Œä¸è¦ä½¿ç”¨ PUT è¦†ç›–
    console.log('[Caddy] http åº”ç”¨ä¸å­˜åœ¨ï¼Œä½¿ç”¨ PATCH åˆ›å»º')
    const httpApp = {
      servers: {
        [serverName]: serverConfig
      }
    }
    
    // å°è¯• PATCHï¼Œå¦‚æžœå¤±è´¥åˆ™æŠ›å‡ºé”™è¯¯
    try {
      await this.request('PATCH', '/config/apps/http', httpApp)
    } catch (patchError) {
      const patchErrorMsg = patchError instanceof Error ? patchError.message : String(patchError)
      console.error(`[Caddy] PATCH http åº”ç”¨å¤±è´¥: ${patchErrorMsg}`)
      throw new Error(`æ— æ³•åˆ›å»ºç«™ç‚¹é…ç½®: ${patchErrorMsg}`)
    }
  }

  /**
   * åˆ é™¤åä»£ç«™ç‚¹
   * @param domain åŸŸå
   */
  async deleteSite(domain: string): Promise<void> {
    const routeId = `site-${domain.replace(/\./g, '-')}`
    
    try {
      await this.request('DELETE', `/id/${routeId}`)
    } catch (error) {
      // å¦‚æžœè·¯ç”±ä¸å­˜åœ¨ï¼Œå¿½ç•¥é”™è¯¯
      if (error instanceof Error && !error.message.includes('404')) {
        throw error
      }
    }
  }

  /**
   * èŽ·å–æ‰€æœ‰åä»£ç«™ç‚¹
   */
  async getSites(): Promise<string[]> {
    try {
      const config = await this.getConfig() as {
        apps?: {
          http?: {
            servers?: Record<string, {
              routes?: CaddyRoute[]
            }>
          }
        }
      }

      const servers = config?.apps?.http?.servers || {}
      const domains: string[] = []

      // ä»Žæ‰€æœ‰æœåŠ¡å™¨æ”¶é›†åŸŸå
      for (const serverName of Object.keys(servers)) {
        const routes = servers[serverName]?.routes || []
        for (const route of routes) {
          if (route.match?.[0]?.host) {
            domains.push(...route.match[0].host)
          }
        }
      }

      return domains
    } catch {
      return []
    }
  }

  /**
   * é‡æ–°åŠ è½½é…ç½®
   */
  async reload(): Promise<void> {
    // Caddy ä¼šè‡ªåŠ¨åº”ç”¨é…ç½®æ›´æ”¹ï¼Œä¸éœ€è¦æ˜¾å¼ reload
    // è¿™ä¸ªæ–¹æ³•ä¿ç•™ç”¨äºŽå…¼å®¹æ€§
  }
}

/**
 * åˆ›å»º Caddy å®¢æˆ·ç«¯å®žä¾‹
 */
export function createCaddyClient(config: CaddyClientConfig): CaddyClient {
  return new CaddyClient(config)
}


