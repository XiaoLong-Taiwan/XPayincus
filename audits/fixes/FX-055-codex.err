       // 某些请求没有响应体
@@ -154,61 +164,69 @@
 
     // 统一使用 sites 服务器
     const serverName = 'sites'
+    const serverPath = `/config/apps/http/servers/${serverName}`
+    const routesPath = `${serverPath}/routes`
 
-    // 策略：优先使用精确的 API 路径，避免影响 Caddyfile 定义的服务器
