+      // 父级也已明确确认不存在；严格创建，不覆盖任何现有 HTTP 配置。
+      await this.request('PUT', httpAppPath, {
+        servers: {
+          [serverName]: serverConfig
+        }
+      })
+      return
     }
+
+    // http 在复核期间已由其他请求创建；回到精确 server 路径严格创建。
+    await this.request('PUT', serverPath, serverConfig)
   }
 
   /**

