+]) {
+  assert.ok(
+    !caddyClientSource.includes(forbiddenPattern),
+    `Caddy route guard forbids unsafe fallback: ${forbiddenPattern}`
+  )
+}
+
 console.log('proxy site route ID guard tests passed')
