/**
 * å·¥å•è‡ªåŠ¨å…³é—­è°ƒåº¦å™¨
 * 
 * åŠŸèƒ½ï¼šè‡ªåŠ¨å…³é—­æ»¡è¶³æ¡ä»¶çš„å·²è§£å†³å·¥å•
 * æ¡ä»¶ï¼š
 * 1. çŠ¶æ€ä¸º resolvedï¼ˆå·²è§£å†³ï¼‰
 * 2. è¶…è¿‡24å°æ—¶æœªæ›´æ–°
 * 3. æœ€åŽä¸€æ¡æ¶ˆæ¯æ¥è‡ªå®¿ä¸»æœºä¸»äººï¼ˆä¸éœ€è¦ç®¡ç†å‘˜å†å›žå¤ï¼‰
 */

import { getTicketsForAutoClose, autoCloseTickets } from '../db/tickets.js'
import { sendNotification } from '../lib/notifier.js'
import { createLog } from '../db/logs.js'
import { getHostById } from '../db/index.js'

// é…ç½®å¸¸é‡
const AUTO_CLOSE_TIMEOUT_MS = 24 * 60 * 60 * 1000 // 24å°æ—¶
const CHECK_INTERVAL_MS = 60 * 60 * 1000 // æ¯å°æ—¶æ£€æŸ¥ä¸€æ¬¡

let schedulerInterval: ReturnType<typeof setInterval> | null = null

/**
 * å¤„ç†å·¥å•è‡ªåŠ¨å…³é—­
 */
async function processTicketAutoClose(): Promise<void> {
  try {
    // èŽ·å–éœ€è¦è‡ªåŠ¨å…³é—­çš„å·¥å•
    const ticketsToClose = await getTicketsForAutoClose(AUTO_CLOSE_TIMEOUT_MS)

    if (ticketsToClose.length === 0) {
      return
    }

    console.log(`[TicketAutoClose] å‘çŽ° ${ticketsToClose.length} ä¸ªéœ€è¦è‡ªåŠ¨å…³é—­çš„å·¥å•`)

    // æ‰¹é‡å…³é—­å·¥å•ã€‚åªå¯¹æœ¬è½®å®žé™…æŠ¢å å¹¶å…³é—­æˆåŠŸçš„å·¥å•å‘é€é€šçŸ¥/å†™æ—¥å¿—ã€‚
    const ticketIds = ticketsToClose.map(t => t.id)
    const closedTickets = await autoCloseTickets(ticketIds, AUTO_CLOSE_TIMEOUT_MS)

    // å‘é€é€šçŸ¥å’Œè®°å½•æ—¥å¿—
    for (const ticket of closedTickets) {
      try {
        // èŽ·å–å®¿ä¸»æœºä¿¡æ¯ï¼ˆhostId å¯èƒ½ä¸º nullï¼Œè¡¨ç¤ºç›´æŽ¥å‘ç»™ç®¡ç†å‘˜çš„å·¥å•ï¼‰
        const host = ticket.hostId ? await getHostById(ticket.hostId) : null

        // é€šçŸ¥å·¥å•åˆ›å»ºè€…ï¼ˆç”¨æˆ·ï¼‰
        await sendNotification(ticket.userId, 'ticket_auto_closed', {
          subject: ticket.subject,
          hostName: host?.name || 'ç³»ç»Ÿ'
        })

        // è®°å½•æ—¥å¿—
        await createLog(
          ticket.userId,
          'ticket',
          'ticket.auto_closed',
          `Ticket #${ticket.id} "${ticket.subject}" auto-closed after 24 hours`,
          'success'
        )
      } catch (notifyErr) {
        console.error(`[TicketAutoClose] é€šçŸ¥/æ—¥å¿—å¤±è´¥ (å·¥å• #${ticket.id}):`, notifyErr)
      }
    }

    console.log(`[TicketAutoClose] æˆåŠŸè‡ªåŠ¨å…³é—­ ${closedTickets.length} ä¸ªå·¥å•`)
  } catch (err) {
    console.error('[TicketAutoClose] å¤„ç†å¤±è´¥:', err)
  }
}

/**
 * å¯åŠ¨å·¥å•è‡ªåŠ¨å…³é—­è°ƒåº¦å™¨
 */
export function startTicketAutoCloseScheduler(): void {
  if (schedulerInterval) {
    console.warn('[TicketAutoClose] è°ƒåº¦å™¨å·²åœ¨è¿è¡Œ')
    return
  }

  // å¯åŠ¨æ—¶æ‰§è¡Œä¸€æ¬¡
  processTicketAutoClose()

  // å®šæœŸæ‰§è¡Œ
  schedulerInterval = setInterval(processTicketAutoClose, CHECK_INTERVAL_MS)

  console.log('ðŸŽ« å·¥å•è‡ªåŠ¨å…³é—­è°ƒåº¦å™¨å·²å¯åŠ¨ï¼ˆ24å°æ—¶è¶…æ—¶ï¼Œæ¯å°æ—¶æ£€æŸ¥ï¼‰')
}

/**
 * åœæ­¢å·¥å•è‡ªåŠ¨å…³é—­è°ƒåº¦å™¨
 */
export function stopTicketAutoCloseScheduler(): void {
  if (schedulerInterval) {
    clearInterval(schedulerInterval)
    schedulerInterval = null
    console.log('[TicketAutoClose] è°ƒåº¦å™¨å·²åœæ­¢')
