  36: // 并发限制
  37: const limit = pLimit(5)
  38: 
  39: // 配置常量
  40: const AUTO_RENEW_HOURS_BEFORE = 24 // 到期前24小时尝试自动续费
  41: const AUTO_RENEW_MAX_ATTEMPTS = 3 // 最大自动续费尝试次数
  42: const SUSPEND_AFTER_DELETE_DAYS = 3 // 封停后3天自动删除
  43: const EXPIRY_NOTIFY_DAYS = [3] // 仅在到期前3天提醒一次
  44: const INSTANCE_BILLING_JOB_LOCK_EXPIRE_MS = 30 * 60 * 1000
  45: const INSTANCE_BILLING_JOB_LOCK_WAIT_MS = 100
  46: let schedulerStarted = false
  47: 
  48: /**
  49:  * 延迟函数
  50:  */
  51: function delay(ms: number): Promise<void> {
  52:   return new Promise(resolve => setTimeout(resolve, ms))
  53: }
  54: 
  55: async function withInstanceBillingJobLock(
  56:   purpose: 'auto-renew' | 'expiry-suspend' | 'expiry-delete' | 'expiry-notify',
  57:   instanceId: number,
  58:   fn: () => Promise<void>
  59: ): Promise<void> {
  60:   const lockKey = `billing:${purpose}:instance:${instanceId}`
  61:   const lock = await acquireLock(lockKey, {
  62:     expireMs: INSTANCE_BILLING_JOB_LOCK_EXPIRE_MS,
  63:     waitTimeoutMs: INSTANCE_BILLING_JOB_LOCK_WAIT_MS,
  64:     retryIntervalMs: 50
  65:   })
  66: 
  67:   if (!lock.success || !lock.ownerId) {
  68:     console.log(`[Billing] Skip ${purpose} for instance ${instanceId}: lock not acquired`)
  69:     return
  70:   }
  71: 
  72:   try {
  73:     await fn()
  74:   } finally {
  75:     await releaseLock(lockKey, lock.ownerId)
  76:   }
  77: }
  78: 
  79: function buildAutoRenewAttemptGuard(instance: any, now: Date, expiryThreshold: Date) {
  80:   return {
  81:     now,
  82:     expiryThreshold,
  83:     version: instance.version,
  84:     currentAttempts: instance.autoRenewAttempts || 0
  85:   }
  86: }
