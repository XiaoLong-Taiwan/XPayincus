  88: // ==================== 自动续费任务 ====================
  89: 
  90: /**
  91:  * 执行自动续费
  92:  */
  93: async function executeAutoRenew(): Promise<void> {
  94:   console.log('[Billing] Starting auto-renew job...')
  95:   const startTime = Date.now()
  96: 
  97:   try {
  98:     // 获取24小时内到期且开启了自动续费的实例
  99:     const instances = await getAutoRenewInstances(AUTO_RENEW_HOURS_BEFORE)
 100: 
 101:     console.log(`[Billing] Found ${instances.length} instances for auto-renew`)
 102: 
 103:     // 并发处理
 104:     await Promise.all(
 105:       instances.map(instance =>
 106:         limit(() => withInstanceBillingJobLock('auto-renew', instance.id, () => processAutoRenew(instance)))
 107:       )
 108:     )
 109: 
 110:     const duration = Date.now() - startTime
 111:     console.log(`[Billing] Auto-renew job completed in ${duration}ms`)
 112:   } catch (error) {
 113:     console.error('[Billing] Auto-renew job failed:', error)
 114:   }
 115: }
 116: 
 117: /**
 118:  * 处理单个实例的自动续费
 119:  */
 120: async function processAutoRenew(instance: any): Promise<void> {
 121:   const now = new Date()
 122:   const expiryThreshold = new Date(now.getTime() + AUTO_RENEW_HOURS_BEFORE * 60 * 60 * 1000)
 123:   const latestInstance = await prisma.instance.findUnique({
 124:     where: { id: instance.id }
 125:   })
 126:   if (
 127:     !latestInstance ||
 128:     !latestInstance.autoRenew ||
 129:     !latestInstance.expiresAt ||
 130:     latestInstance.expiresAt <= now ||
 131:     latestInstance.expiresAt > expiryThreshold ||
 132:     latestInstance.status === 'suspended' ||
 133:     latestInstance.status === 'deleted'
 134:   ) {
 135:     console.log(`[Billing] Skip auto-renew for instance ${instance.id}: no longer eligible`)
 136:     return
 137:   }
 138: 
 139:   instance = latestInstance
 140:   const attempts = (instance.autoRenewAttempts || 0) + 1
 141:   const attemptGuard = buildAutoRenewAttemptGuard(instance, now, expiryThreshold)
 142: 
 143:   const exchangeLock = await getExchangeOperationLock(instance.id)
 144:   if (exchangeLock.locked) {
 145:     console.log(`[Billing] Skip auto-renew for instance ${instance.id}: exchange locked (${exchangeLock.code})`)
 146:     return
 147:   }
 148: 
 149:   // 检查是否超过最大尝试次数
 150:   if (attempts > AUTO_RENEW_MAX_ATTEMPTS) {
 151:     console.log(`[Billing] Instance ${instance.id} exceeded max auto-renew attempts, disabling`)
 152:     const attemptClaimed = await updateAutoRenewAttempt(instance.id, attempts, true, attemptGuard)
 153:     if (!attemptClaimed) {
 154:       console.log(`[Billing] Skip max-attempt update for instance ${instance.id}: no longer eligible`)
 155:     }
 156:     return
 157:   }
 158: 
 159:   try {
 160:     // 按原计费周期续费（如季付续3个月）
 161:     const renewMonths = instance.billingCycle || 1
 162:     const renewInfo = calculateRenewBilling(instance, renewMonths)
 163: 
 164:     // 获取用户信息（包括邮箱）
 165:     const user = await prisma.user.findUnique({
 166:       where: { id: instance.userId },
 167:       select: { balance: true, email: true, username: true }
 168:     })
 169: 
 170:     if (!user) {
 171:       console.log(`[Billing] User ${instance.userId} not found for instance ${instance.id}`)
 172:       const attemptClaimed = await updateAutoRenewAttempt(instance.id, attempts, false, attemptGuard)
 173:       if (!attemptClaimed) {
 174:         console.log(`[Billing] Skip auto-renew attempt update for instance ${instance.id}: no longer eligible`)
 175:       }
 176:       return
 177:     }
 178: 
 179:     const balance = Number(user.balance)
 180: 
 181:     // 余额不足
 182:     if (balance < renewInfo.amount) {
 183:       console.log(`[Billing] Insufficient balance for instance ${instance.id}: need ${renewInfo.amount}, have ${balance}`)
 184:       const attemptClaimed = await updateAutoRenewAttempt(instance.id, attempts, false, attemptGuard)
 185:       if (!attemptClaimed) {
 186:         console.log(`[Billing] Skip auto-renew failure notification for instance ${instance.id}: no longer eligible`)
 187:         return
 188:       }
 189: 
 190:       // 发送自动续费失败站内通知
 191:       await sendNotification(instance.userId, 'auto_renew_failed', {
 192:         instanceName: instance.name,
 193:         failReason: `余额不足（需要 ¥${renewInfo.amount.toFixed(2)}，当前 ¥${balance.toFixed(2)}）`,
 194:         renewAmount: renewInfo.amount  // 元（calculateRenewBilling 返回的是元）
 195:       })
 196: 
 197:       // 发送自动续费失败邮件
 198:       if (user.email) {
 199:         try {
 200:           await sendAutoRenewFailedEmail(user.email, {
 201:             username: user.username,
 202:             instanceName: instance.name,
 203:             failReason: `余额不足（需要 ¥${renewInfo.amount.toFixed(2)}，当前 ¥${balance.toFixed(2)}）`,
 204:             currentAttempt: attempts,
 205:             maxAttempts: AUTO_RENEW_MAX_ATTEMPTS,
 206:             expiresAt: instance.expiresAt
 207:           })
 208:         } catch (emailErr) {
 209:           console.warn(`[Billing] Failed to send auto-renew failed email:`, emailErr)
 210:         }
 211:       }
 212: 
 213:       await createLog(
 214:         instance.userId,
 215:         'instance',
 216:         'instance.auto_renew_failed',
 217:         `Auto-renew failed for instance "${instance.name}": insufficient balance`,
 218:         'failed',
 219:         { instanceId: instance.id }
 220:       )
 221:       return
 222:     }
 223: 
 224:     // 执行续费
 225:     const result = await performRenewal(instance.userId, instance, renewMonths)
 226: 
 227:     // 发送续费成功站内通知
 228:     await sendNotification(instance.userId, 'instance_renewed', {
 229:       instanceName: instance.name,
 230:       renewAmount: result.amount,  // 元（performRenewal 返回的是元）
 231:       renewMonths: renewMonths,
 232:       newExpiresAt: result.newExpiresAt.toISOString()
 233:     })
 234: 
 235:     if (result.hostingIncomeResult) {
 236:       sendHostManagedInstanceNotification(
 237:         instance.hostId,
 238:         'renew',
 239:         {
 240:           username: user.username,
 241:           instanceName: instance.name,
 242:           amount: result.amount
 243:         }
 244:       ).catch(err => {
 245:         console.warn('[Billing] Failed to send host renew notification:', err)
 246:       })
 247:     }
 248: 
 249:     // 发送自动续费成功邮件
 250:     if (user.email) {
 251:       try {
 252:         // 获取续费后的余额
 253:         const userAfter = await prisma.user.findUnique({
 254:           where: { id: instance.userId },
 255:           select: { balance: true }
 256:         })
 257:         const newBalance = Number(userAfter?.balance ?? 0)
 258: 
 259:         await sendAutoRenewSuccessEmail(user.email, {
 260:           username: user.username,
 261:           instanceName: instance.name,
 262:           amount: result.amount,
 263:           months: renewMonths,
 264:           newExpiresAt: result.newExpiresAt,
 265:           newBalance
 266:         })
 267:       } catch (emailErr) {
 268:         console.warn(`[Billing] Failed to send auto-renew success email:`, emailErr)
 269:       }
 270:     }
 271: 
 272:     await createLog(
 273:       instance.userId,
 274:       'instance',
 275:       'instance.auto_renew',
 276:       `Auto-renewed instance "${instance.name}" for ${renewMonths} month(s), amount: ${result.amount}`,
 277:       'success',
 278:       { instanceId: instance.id }
 279:     )
