  975: /**
  976:  * 发送通知到用户的所有启用渠道
  977:  * 同时创建站内信
  978:  */
  979: export async function sendNotification(
  980:   userId: number,
  981:   eventType: EventType,
  982:   data: EventData
  983: ): Promise<SendResult> {
  984:   try {
  985:     const template = EVENT_TEMPLATES[eventType]
  986:     if (!template) {
  987:       console.warn(`[Notifier] Unknown event type: ${eventType}`)
  988:       return { sent: 0, failed: 0 }
  989:     }
  990: 
  991:     const title = template.title
  992:     const message = template.message(data)
  993: 
  994:     // 1. 创建站内信（始终创建）
  995:     try {
  996:       await createInboxMessage({
  997:         userId,
  998:         eventType,
  999:         title,
 1000:         content: message,
 1001:         data: data as Record<string, unknown>
 1002:       })
 1003:     } catch (err) {
 1004:       console.error('[Notifier] Failed to create inbox message:', err)
 1005:     }
 1006: 
 1007:     // 2. 发送外部通知
 1008:     const channels = await db.getEnabledChannelsByUserId(userId)
 1009: 
 1010:     if (channels.length === 0) {
 1011:       emitNotificationSentPluginEvent({ userId, eventType, sent: 0, failed: 0, channelCount: 0 })
 1012:       return { sent: 0, failed: 0 }
 1013:     }
 1014: 
 1015:     let sent = 0
 1016:     let failed = 0
 1017: 
 1018:     for (const channel of channels) {
 1019:       try {
 1020:         const config = typeof channel.config === 'string'
 1021:           ? JSON.parse(channel.config)
 1022:           : channel.config
 1023: 
 1024:         // 创建日志记录
 1025:         const logId = await db.createNotificationLog({
 1026:           channelId: channel.id,
 1027:           eventType,
 1028:           message,
 1029:           status: 'pending'
 1030:         })
 1031: 
 1032:         // 根据渠道类型发送通知（带重试）
 1033:         let result: NotificationResult
 1034: 
 1035:         switch (channel.type) {
 1036:           case 'telegram':
 1037:             result = await sendWithRetry(
 1038:               () => sendTelegram(config as TelegramConfig, title, message),
 1039:               'Telegram'
 1040:             )
 1041:             break
 1042:           case 'discord':
 1043:             result = await sendWithRetry(
 1044:               () => sendDiscord(config as DiscordConfig, title, message),
 1045:               'Discord'
 1046:             )
 1047:             break
 1048:           case 'webhook':
 1049:             result = await sendWithRetry(
 1050:               () => sendWebhook(config as WebhookConfig, eventType, title, message, data),
 1051:               'Webhook'
 1052:             )
 1053:             break
 1054:           case 'email':
 1055:             result = { success: false, error: 'Email notifications not yet implemented' }
 1056:             break
 1057:           default:
 1058:             result = { success: false, error: `Unknown channel type: ${channel.type}` }
 1059:         }
 1060: 
 1061:         // 更新日志状态
 1062:         await db.updateNotificationLogStatus(logId, result.success ? 'sent' : 'failed', result.error)
 1063: 
 1064:         if (result.success) {
 1065:           sent++
 1066:         } else {
 1067:           failed++
 1068:         }
 1069:       } catch (err) {
 1070:         const error = err instanceof Error ? err.message : String(err)
 1530:     }
 1531: 
 1532:     return { success: true }
 1533:   } catch (err) {
 1534:     const error = err instanceof Error ? err.message : String(err)
