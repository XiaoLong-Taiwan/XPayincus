  454:     fastify.post<{ Params: { id: string } }>('/:id/accept', {
  455:         onRequest: [fastify.authenticateUser]
  456:     }, async (request: FastifyRequest<{ Params: { id: string } }>, reply: FastifyReply) => {
  457:         const transferId = parsePositiveInteger(request.params.id)
  458:         const { user } = request
  459: 
  460:         if (transferId === null) {
  461:             return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
  462:         }
  463: 
  464:         // ===== 并发安全：使用乐观锁，原子性地检查并更新状态 =====
  465:         // 使用 updateMany 原子操作，只有 status='pending' 时才更新为 'processing'
  466:         const lockResult = await prisma.instanceTransfer.updateMany({
  467:             where: {
  468:                 id: transferId,
  469:                 status: 'pending',
  470:                 toUserId: user.id  // 同时验证权限
  471:             },
  472:             data: {
  473:                 status: 'processing'  // 临时锁定状态
  474:             }
  475:         })
  476: 
  477:         // 如果没有更新任何记录，说明状态已变化或权限不足
  478:         if (lockResult.count === 0) {
  479:             // 需要区分是不存在、权限不足还是状态已变化
  480:             const transfer = await db.getTransferById(transferId)
  481:             if (!transfer) {
  482:                 return reply.code(404).send(apiError(ErrorCode.TRANSFER_NOT_FOUND))
  483:             }
  484:             if (transfer.toUserId !== user.id) {
  485:                 return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
  486:             }
  487:             // 状态已不是 pending（可能是 processing 或其他）
  488:             return reply.code(400).send(apiError(ErrorCode.TRANSFER_NOT_PENDING))
