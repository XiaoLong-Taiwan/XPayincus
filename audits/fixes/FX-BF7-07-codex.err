 1542:  * 
 1543:  * 注意：该函数不检查 channel.enabled 状态，因为资源释放通知渠道
 1544:  * 就是专门设置为禁用状态的（只用于资源释放通知，不接收系统事件通知）
 1545:  * 
 1546:  * @param link 可选的超链接，Telegram 会渲染为可点击的内联链接，其他渠道渲染为纯文本
 1547:  */
 1548: export async function sendToChannel(
 1549:   channelId: number,
 1550:   title: string,
 1551:   message: string,
 1552:   link?: { label: string; url: string }
 1553: ): Promise<{ success: boolean; error?: string }> {
 1554:   try {
 1555:     const channel = await db.getNotificationChannelById(channelId)
 1556:     if (!channel) {
 1557:       return { success: false, error: 'Channel not found' }
 1558:     }
 1559: 
 1560:     // 不检查 enabled 状态，因为资源释放通知渠道就是禁用状态的
 1561:     // 设计说明：禁用状态的渠道不会接收系统事件通知，但可以接收资源释放通知
 1562: 
 1563:     const config = typeof channel.config === 'string'
 1564:       ? JSON.parse(channel.config)
 1565:       : channel.config
 1566: 
 1567:     // 创建日志记录
 1568:     const logId = await db.createNotificationLog({
 1569:       channelId: channel.id,
 1570:       eventType: 'package.quota_release',
 1571:       message,
 1572:       status: 'pending'
 1573:     })
 1574: 
 1575:     let result: NotificationResult
 1576: 
 1577:     switch (channel.type) {
 1578:       case 'telegram': {
 1579:         // Telegram MarkdownV2: 主消息体先 escape，然后将超链接作为 [label](url)
 1580:         // 内联链接的 URL 部分不需要 escape，label 需要 escape
 1581:         // 这样确保 URL 中的 . ? = & 等字符不被转义，链接可以被 Telegram 正确解析为可点击链接
 1582:         const telegramConfig = config as TelegramConfig
 1583:         if (!telegramConfig.botToken || !telegramConfig.chatId) {
 1584:           result = { success: false, error: 'Missing botToken or chatId' }
 1585:           break
 1586:         }
 1587:         try {
 1588:           let text = `*${escapeMarkdown(title)}*\n\n${escapeMarkdown(message)}`
 1589:           if (link) {
 1590:             // [转义后的label](原始url) — URL 不转义，确保链接可点击
 1591:             text += `\n[${escapeMarkdown(link.label)}](${link.url})`
 1592:           }
 1593:           const response = await fetch(`https://api.telegram.org/bot${telegramConfig.botToken}/sendMessage`, {
 1594:             method: 'POST',
 1595:             redirect: 'manual',
 1596:             signal: AbortSignal.timeout(NOTIFICATION_FETCH_TIMEOUT_MS),
 1597:             headers: { 'Content-Type': 'application/json' },
 1598:             body: JSON.stringify({
 1599:               chat_id: telegramConfig.chatId,
 1600:               text,

