  494:             return reply.code(404).send(apiError(ErrorCode.TRANSFER_NOT_FOUND))
  495:         }
  496: 
  497:         // ===== 失败时的回滚函数 =====
  498:         const rollbackToPending = async () => {
  499:             try {
  500:                 await prisma.instanceTransfer.update({
  501:                     where: { id: transferId },
  502:                     data: { status: 'pending' }
  503:                 })
  504:             } catch (err) {
  505:                 console.error('[Transfer] Failed to rollback status:', err)
