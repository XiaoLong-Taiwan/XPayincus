/**
 * å¢žåŠ ç”¨æˆ·æµé‡ç”¨é‡
 */
export async function incrementUserTrafficUsage(userId: number, delta: bigint) {
    return prisma.userQuota.update({
        where: { userId },
        data: {
            monthlyTrafficUsed: { increment: delta }
        }
    })
}

/**
 * æŒ‰å®žä¾‹åŸºç¡€é™é¢åŒæ­¥ç”¨æˆ·å·²æ¶ˆè€—çš„é¢å¤–æµé‡åŒ…ç”¨é‡
 */
async function syncUserExtraTrafficUsedInTransaction(
    tx: Prisma.TransactionClient,
    userId: number
): Promise<bigint> {
    const quota = await tx.userQuota.findUnique({
        where: { userId },
        select: { extraTrafficQuota: true }
    })
    if (!quota) return 0n

    const instances = await tx.instance.findMany({
        where: {
            userId,
            status: { not: 'deleted' }
        },
        select: {
            monthlyTrafficLimit: true,
            monthlyTrafficUsed: true
        }
    })
    const consumed = instances.reduce((total, instance) => {
        if (instance.monthlyTrafficLimit === null || instance.monthlyTrafficUsed <= instance.monthlyTrafficLimit) {
            return total
        }
        return total + instance.monthlyTrafficUsed - instance.monthlyTrafficLimit
    }, 0n)
    const extraTrafficUsed = consumed > quota.extraTrafficQuota ? quota.extraTrafficQuota : consumed

    await tx.userQuota.update({
        where: { userId },
        data: { extraTrafficUsed }
    })
    return extraTrafficUsed
}

export async function syncUserExtraTrafficUsed(userId: number): Promise<bigint> {
    const result = await withLock(getTrafficUserLockKey(userId), async () => prisma.$transaction(
        tx => syncUserExtraTrafficUsedInTransaction(tx, userId)
    ), TRAFFIC_RESET_LOCK_OPTIONS)

    if (!result.success || result.result === undefined) {
        throw new Error(result.error || `ç”¨æˆ· ${userId} é¢å¤–æµé‡ç”¨é‡åŒæ­¥é”èŽ·å–å¤±è´¥`)
    }

    return result.result
}

/**
 * æ‰¹é‡å¢žåŠ ç”¨æˆ·æµé‡ç”¨é‡
 * ä½¿ç”¨ PostgreSQL çš„ UPDATE ... FROM VALUES è¿›è¡Œé«˜æ•ˆçš„æ‰¹é‡æ›´æ–°
 * æ”¯æŒå¤§è§„æ¨¡ç”¨æˆ·ï¼ˆ10000+ï¼‰ï¼Œä½¿ç”¨åˆ†ç‰‡å¤„ç†é¿å…äº‹åŠ¡è¿‡å¤§
 */
export async function bulkIncrementUserTrafficUsage(
    updates: Array<{ userId: number; delta: bigint }>
) {
    if (updates.length === 0) return

    // æŒ‰ç”¨æˆ· ID åˆ†ç»„ï¼Œç´¯åŠ åŒä¸€ä¸ªç”¨æˆ·çš„å¢žé‡
    const userDeltas = new Map<number, bigint>()
    for (const { userId, delta } of updates) {
        const current = userDeltas.get(userId) || 0n
        userDeltas.set(userId, current + delta)
    }

    // è½¬æ¢ä¸ºæ•°ç»„å¹¶æŒ‰åˆ†ç‰‡å¤§å°åˆ†æ‰¹å¤„ç†
    const deltasArray = Array.from(userDeltas.entries())
    
    // åˆ†æ‰¹å¤„ç†ï¼Œé¿å…å•æ¬¡äº‹åŠ¡è¿‡å¤§
    for (let i = 0; i < deltasArray.length; i += BATCH_SIZE) {
        const batch = deltasArray.slice(i, i + BATCH_SIZE)
        
        // ä½¿ç”¨ PostgreSQL çš„ UPDATE ... FROM VALUES è¯­æ³•è¿›è¡Œæ‰¹é‡æ›´æ–°
        // æž„å»º VALUES å­å¥ï¼ˆéªŒè¯å¹¶æ¸…ç†æ‰€æœ‰å€¼ï¼‰
        const valuesClause = batch
            .map(([userId, delta]) => {
                const userIdStr = sanitizeNumber(userId)
                const deltaStr = sanitizeNumber(delta)
                return `(${userIdStr}, ${deltaStr})`
            })
            .join(', ')
        
        // ä½¿ç”¨åŽŸç”Ÿ SQL æ‰¹é‡æ›´æ–°
        try {
            await prisma.$executeRawUnsafe(`
                UPDATE user_quotas AS uq
                SET monthly_traffic_used = uq.monthly_traffic_used + v.delta::bigint
                FROM (VALUES ${valuesClause}) AS v(user_id, delta)
                WHERE uq.user_id = v.user_id
            `)
        } catch (error) {
            console.error(`[Traffic] Failed to bulk increment user traffic usage (batch ${i}-${i + batch.length}):`, error)
            throw error
        }
    }
}

