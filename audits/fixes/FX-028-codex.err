  375:   const where: Prisma.LotteryRecordWhereInput = { userId }
  376:   if (prizeType) {
  377:     where.prizeType = prizeType
  378:   }
  379: 
  380:   const [records, total] = await Promise.all([
  381:     prisma.lotteryRecord.findMany({
