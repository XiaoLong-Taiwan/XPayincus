  386:         },
  387:         prize: {
  388:           select: { instanceDesc: true }
  389:         }
  390:       },
  391:       orderBy: { createdAt: 'desc' },
  392:       take: pageSize,
  393:       skip
  394:     }),
  395:     prisma.lotteryRecord.count({ where })
  396:   ])
  397: 
  398:   return { records, total, page, pageSize }
  399: }
