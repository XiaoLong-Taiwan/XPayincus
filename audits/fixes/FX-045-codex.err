 6921:     console.log(`[Provisioning] å®žä¾‹ ${config.name} å¯åŠ¨å‘½ä»¤å·²å‘é€`)
 6922: 
 6923:     // KVM è™šæ‹Ÿæœºéœ€è¦ç­‰å¾… QEMU çœŸæ­£å®Œæˆå¯åŠ¨ï¼ˆBIOSâ†’å†…æ ¸â†’cloud-initâ†’agentï¼‰
 6924:     // å®¹å™¨å¯åŠ¨æ˜¯çž¬æ—¶çš„ï¼Œä¸éœ€è¦ç­‰å¾…
 6925:     if (config.instanceType === 'vm') {
 6926:       console.log(`[Provisioning] VM ${config.name} ç­‰å¾… QEMU å¯åŠ¨å®Œæˆ...`)
 6927:       const vmMaxWait = 90 // æœ€å¤šç­‰ 90 è½® Ã— 2ç§’ = 180ç§’
 6928:       let vmStarted = false
 6929:       for (let i = 0; i < vmMaxWait; i++) {
 6930:         await new Promise(r => setTimeout(r, 2000))
 6931:         try {
 6932:           const vmState = await getInstanceState(client, config.name) as { status?: string }
 6933:           if (vmState.status === 'Running') {
 6934:             console.log(`[Provisioning] VM ${config.name} å·²ç¡®è®¤å¯åŠ¨ (è€—æ—¶ ${(i + 1) * 2}s)`)
 6935:             vmStarted = true
 6936:             break
 6937:           }
 6938:           if (i % 10 === 0) {
 6939:             console.log(`[Provisioning] VM ${config.name} ç­‰å¾…å¯åŠ¨ä¸­... (${(i + 1) * 2}s, çŠ¶æ€: ${vmState.status || 'unknown'})`)
 6940:           }
 6941:         } catch { /* ç»§ç»­ç­‰å¾… */ }
 6942:       }
 6943:       if (!vmStarted) {
 6944:         console.warn(`[Provisioning] VM ${config.name} å¯åŠ¨ç­‰å¾…è¶…æ—¶ (180s)ï¼Œç»§ç»­æµç¨‹`)
 6945:       }
 6946:     }
 6947: 
 6948:     // ä½¿ç”¨ä¼ å…¥çš„é™æ€ IP åœ°å€
 6949:     const ipv4: string | null = config.ipv4Address || null
 6950:     const ipv6: string | null = config.ipv6Address || null
 6951: 
 6952:     console.log(`[Provisioning] å®žä¾‹ ${config.name} IP é…ç½®: IPv4=${ipv4}, IPv6=${ipv6}`)
 6953: 
 6954:     // ä½¿ç”¨åŽŸå­æ“ä½œæ›´æ–°çŠ¶æ€ï¼Œé˜²æ­¢ä¸Žè¶…æ—¶æ¸…ç†ä»»åŠ¡ç«žäº‰
 6955:     // åªæœ‰çŠ¶æ€ä»ä¸º creating æ—¶æ‰æ›´æ–°ä¸º running
 6956:     const updateResult = await prisma.instance.updateMany({
 6957:       where: {
 6958:         id: instanceId,
 6959:         status: 'creating' // åŽŸå­æ¡ä»¶
 6960:       },
 6961:       data: {
 6962:         status: 'running',
 6963:         ipv4: ipv4 ?? null,
 6964:         ipv6: ipv6 ?? null,
 6965:         storagePoolName: config.storagePool || 'default'
 6966:       }
 6967:     })
 6968: 
 6969:     // å¦‚æžœçŠ¶æ€å·²è¢«è¶…æ—¶æ¸…ç†ä»»åŠ¡ä¿®æ”¹ï¼ˆå˜ä¸º errorï¼‰ï¼Œéœ€è¦æ¸…ç†å·²åˆ›å»ºçš„ Incus å®žä¾‹
 6970:     if (updateResult.count === 0) {
 6971:       console.log(`[Provisioning] å®žä¾‹ ${instanceId} å·²è¢«è¶…æ—¶æ¸…ç†ä»»åŠ¡å¤„ç†ï¼Œæ¸…ç†å·²åˆ›å»ºçš„ Incus å®žä¾‹`)
 6972:       try {
 6973:         await stopInstance(client, config.name, true)
 6974:         await deleteInstance(client, config.name)
 6975:         console.log(`[Provisioning] Incus å®žä¾‹ ${config.name} å·²æ¸…ç†ï¼ˆå› è¶…æ—¶ï¼‰`)
 6976:       } catch (cleanupErr) {
 6977:         console.error(`[Provisioning] æ¸…ç†è¶…æ—¶å®žä¾‹å¤±è´¥:`, cleanupErr)
 6978:       }
 6979:       // ä¸å†ç»§ç»­åŽç»­æµç¨‹ï¼ˆIP è®°å½•ã€é€šçŸ¥ç­‰ï¼‰
 6980:       return
 6981:     }
 6982: 
 6983:     await markFlashSaleDelivered(instanceId).catch((err) => {
 6984:       console.error(`[Provisioning] ç§’æ€äº¤ä»˜çŠ¶æ€å›žå†™å¤±è´¥:`, err)
 6985:     })
 6986: 
 6987:     // åˆ›å»º IP åœ°å€è®°å½• (æ–°åŒç½‘å¡æž¶æž„: eth0=IPv4, eth1=IPv6)
 6988:     if (ipv4) {
 6989:       try {
 6990:         await db.createIpAddress({
 6991:           address: ipv4,
 6992:           type: 'inet4',
 6993:           isPrimary: true,
 6994:           device: 'eth0',  // æ–°åŒç½‘å¡æž¶æž„: IPv4 åœ¨ eth0
 6995:           instanceId
 6996:         })
 6997:         console.log(`[Provisioning] ä¸» IPv4 åœ°å€è®°å½•å·²åˆ›å»º: ${ipv4} (device: eth0)`)
 6998:       } catch (err) {
 6999:         console.warn(`[Provisioning] åˆ›å»º IPv4 è®°å½•å¤±è´¥ (å¯èƒ½å·²å­˜åœ¨):`, err)
 7000:       }
 7001:     }
 7002: 
 7003:     if (ipv6) {
 7004:       try {
 7005:         await db.createIpAddress({
 7006:           address: ipv6,
 7007:           type: 'inet6',
 7008:           isPrimary: true,
 7009:           device: 'eth1',  // æ–°åŒç½‘å¡æž¶æž„: IPv6 åœ¨ eth1
 7010:           instanceId
 7011:         })
 7012:         console.log(`[Provisioning] ä¸» IPv6 åœ°å€è®°å½•å·²åˆ›å»º: ${ipv6} (device: eth1)`)
 7013:       } catch (err) {
 7014:         console.warn(`[Provisioning] åˆ›å»º IPv6 è®°å½•å¤±è´¥ (å¯èƒ½å·²å­˜åœ¨):`, err)
 7015:       }
 7016:     }
 7017: 
 7018:     console.log(`[Provisioning] âœ” å®žä¾‹ ${instanceId} (${config.name}) åˆ›å»ºæˆåŠŸ!`)
 7019: 
 7020:     const instance = await db.getInstanceById(instanceId)
 7021:     if (instance) {
 7022:       // å‘é€é€šçŸ¥
 7023:       const { sendNotification } = await import('../lib/notifier.js')
 7024:       await sendNotification(userId, 'instance_created', {
 7025:         instanceName: instance.name,
 7026:         status: 'running',
 7027:         hostName: host.name,
 7028:         hostLocation: host.location || undefined,
 7029:         image: config.image,
 7030:         cpu: config.cpu,
 7031:         memory: config.memory,
 7032:         disk: config.disk,
 7033:         networkMode: config.networkMode,
 7034:         ipv4: ipv4 || undefined,
 7035:         ipv6: ipv6 || undefined
 7036:       })
 7037:       emitServicePluginEvent({
 7038:         event: 'service.provisioned',
 7039:         instanceId,
 7040:         userId,
 7041:         hostId: host.id,
 7042:         instanceName: instance.name,
 7043:         status: 'running',
 7044:         incusId: config.name,
 7045:         source: 'instance.provisioning',
 7046:         metadata: {
 7047:           image: config.image,
 7048:           cpu: config.cpu,
 7049:           memory: config.memory,
 7050:           disk: config.disk,
 7051:           networkMode: config.networkMode,
 7052:           ipv4: ipv4 || null,
 7053:           ipv6: ipv6 || null
 7054:         }
 7055:       })
 7056: 
 7057:       // å‘é€å®žä¾‹åˆ›å»ºæˆåŠŸé‚®ä»¶é€šçŸ¥
 7058:       try {
 7059:         const { sendInstanceCreatedEmail } = await import('../lib/mailer.js')
 7060:         const user = await db.findUserById(userId)
 7061:         if (user && user.email) {
 7062:           // èŽ·å–è®¡è´¹ä¿¡æ¯
 7063:           const instanceWithBilling = await prisma.instance.findUnique({
 7064:             where: { id: instanceId },
 7065:             select: {
 7066:               packagePlanId: true,
 7067:               billingPrice: true,
 7068:               expiresAt: true,
 7069:               packagePlan: { select: { name: true } }
 7070:             }
 7071:           })
 7072:           const isPaid = instanceWithBilling?.packagePlanId !== null
 7073: 
 7074:           await sendInstanceCreatedEmail(user.email, {
 7075:             username: user.username,
 7076:             instanceName: instance.name,
 7077:             hostName: host.name,
 7078:             image: config.image,
 7079:             cpu: config.cpu,
 7080:             memory: config.memory,
 7081:             disk: config.disk,
 7082:             ipv4: ipv4 || undefined,
 7083:             ipv6: ipv6 || undefined,
 7084:             isPaid,
 7085:             planName: instanceWithBilling?.packagePlan?.name,
 7086:             amount: isPaid ? Number(instanceWithBilling?.billingPrice) : undefined,
 7087:             expiresAt: instanceWithBilling?.expiresAt ?? undefined
 7088:           })
 7089:         }
 7090:       } catch (emailErr) {
 7091:         console.warn(`[Provisioning] å‘é€å®žä¾‹åˆ›å»ºæˆåŠŸé‚®ä»¶å¤±è´¥:`, emailErr)
 7092:       }
 7093: 
 7094:       // æ³¨æ„ï¼šä¸å†æ£€æŸ¥å®žä¾‹é…é¢ä½¿ç”¨çŽ‡è­¦å‘Šï¼Œå› ä¸ºä¸å†é™åˆ¶ç”¨æˆ·çš„å®žä¾‹é…é¢
 7095: 
 7096:       await createLog(
 7097:         userId,
 7098:         'instance',
 7099:         'instance.create',
 7100:         `Created instance "${instance.name}" [host: ${host.name}, image: ${config.image}, CPU: ${config.cpu}%, Memory: ${config.memory}MB, Disk: ${config.disk}MB, IPv4: ${ipv4 || 'N/A'}, IPv6: ${ipv6 || 'N/A'}, network: ${config.networkMode}]`,
 7101:         'success',
 7102:         { instanceId }
 7103:       )
 7104:     }
 7105: 
 7106:   } catch (error) {
 7107:     const errorMessage = error instanceof Error ? error.message : String(error)
 7108:     console.error(`[Provisioning] âœ˜ å®žä¾‹ ${instanceId} åˆ›å»ºå¤±è´¥:`, errorMessage)
 7109: 
 7110:     let compensationResult: Awaited<ReturnType<typeof compensateFailedInstanceCreation>>
 7111:     try {
 7112:       compensationResult = await compensateFailedInstanceCreation({
 7113:         instanceId,
 7114:         host,
 7115:         userId,
 7116:         resources,
 7117:         networkMode: config.networkMode,
 7118:         portLimit: config.portLimit || 0,
 7119:         instanceName: config.name,
 7120:         errorMessage
 7121:       })
 7122:     } catch (compensationError) {
 7123:       const refundError = compensationError instanceof Error ? compensationError.message : String(compensationError)
 7124:       console.error(`[Provisioning] å®žä¾‹ ${instanceId} åˆ›å»ºå¤±è´¥è¡¥å¿æµç¨‹å¼‚å¸¸:`, compensationError)
 7125:       compensationResult = {
 7126:         claimed: false,
 7127:         refundStatus: 'failed',
 7128:         refundAmount: 0,
 7129:         refundError
 7130:       }
 7131:     }
 7132: 
 7133:     try {
 7134:       await recordInitialProvisioningFailureCase({
 7135:         instanceId,
 7136:         instanceName: config.name,
 7137:         hostId: host.id,
 7138:         userId,
 7139:         errorMessage,
 7140:         compensationClaimed: compensationResult.claimed,
 7141:         refundStatus: compensationResult.refundStatus,
 7142:         refundAmount: compensationResult.refundAmount,
 7143:         refundReason: compensationResult.refundReason,
 7144:         refundError: compensationResult.refundError
 7145:       })
 7146:     } catch (caseError) {
 7147:       console.error(`[Provisioning] å®žä¾‹ ${instanceId} åˆå§‹å¼€é€šå¤±è´¥ case åˆ›å»ºå¤±è´¥:`, caseError)
 7148:     }
 7149: 
 7150:     try {
 7151:       const client = await getIncusClient(host)
 7152:       await deleteInstance(client, config.name)
 7153:       console.log(`[Provisioning] æ®‹ç•™å®¹å™¨ ${config.name} å·²æ¸…ç†`)
 7154:     } catch (cleanupErr) {
 7155:       const errorMessage = cleanupErr instanceof Error ? cleanupErr.message : String(cleanupErr)
 7156:       console.log(`[Provisioning] æ¸…ç†æ®‹ç•™å®¹å™¨å¤±è´¥ (å¯èƒ½ä¸å­˜åœ¨):`, errorMessage)
 7157:     }
 7158: 
 7159:     const instance = await db.getInstanceById(instanceId)
 7160:     if (instance) {
 7161:       // å‘é€å¤±è´¥é€šçŸ¥ç»™ç”¨æˆ·
 7162:       try {
 7163:         const { sendNotification } = await import('../lib/notifier.js')
 7164:         await sendNotification(userId, 'instance_create_failed', {
 7165:           instanceName: instance.name,
 7166:           hostName: host.name,
 7167:           error: errorMessage
 7168:         })
 7169:       } catch (notifyErr) {
 7170:         console.error(`[Provisioning] å‘é€å¤±è´¥é€šçŸ¥å¤±è´¥:`, notifyErr)
 7171:       }
 7172: 
 7173:       await createLog(
 7174:         userId,
 7175:         'instance',
 7176:         'instance.create',
 7177:         `Failed to create instance "${instance.name}": ${errorMessage}`,
 7178:         'failed',
 7179:         { instanceId }
 7180:       )
 7181:     }
 7182: 
 7183:     throw error
 7184:   }
 7185: }
  348: model InstanceTask {
  349:   id         Int                @id @default(autoincrement())
  350:   instanceId Int                @map("instance_id")
  351:   hostId     Int                @map("host_id")
  352:   userId     Int                @map("user_id")
  353:   taskType   InstanceTaskType   @map("task_type")
  354:   status     InstanceTaskStatus @default(PENDING)
  355:   progress   String? // å½“å‰æ‰§è¡Œæ­¥éª¤
  356:   retryCount Int                @default(0) @map("retry_count")
  357: 
  358:   // é‡è£…/å…‹éš†æ“ä½œç‰¹æœ‰å­—æ®µ
  359:   imageAlias           String? @map("image_alias") // é‡è£…ä½¿ç”¨çš„é•œåƒåˆ«å
  360:   sshKeyId             Int?    @map("ssh_key_id") // é‡è£…ä½¿ç”¨çš„ SSH å¯†é’¥ ID
  361:   customInitCommandIds String? @map("custom_init_command_ids") // é‡è£…ä½¿ç”¨çš„è‡ªå®šä¹‰åˆå§‹åŒ–å‘½ä»¤IDåˆ—è¡¨ (JSONæ•°ç»„)
  362:   targetName           String? @map("target_name") // å…‹éš†çš„ç›®æ ‡åç§°
  363:   targetHostId         Int?    @map("target_host_id") // å…‹éš†çš„ç›®æ ‡å®¿ä¸»æœº
  364:   snapshotName         String? @map("snapshot_name") // å…‹éš†æ—¶çš„å¿«ç…§åç§°
  365:   newInstanceId        Int?    @map("new_instance_id") // å…‹éš†åŽçš„æ–°å®žä¾‹ ID
  366: 
  367:   error      String?
  368:   createdAt  DateTime  @default(now()) @map("created_at")
  369:   startedAt  DateTime? @map("started_at")
  370:   finishedAt DateTime? @map("finished_at")
  371: 
  372:   instance Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  373:   exchangeDeliveryTask ExchangeDeliveryTask?
  374: 
  375:   @@index([hostId, status])
  376:   @@index([instanceId])
  377:   @@index([userId])
  378:   @@map("instance_tasks")
  379: }
