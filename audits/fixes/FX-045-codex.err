diff --git a/server/scripts/test-instance-route-id-guards.ts b/server/scripts/test-instance-route-id-guards.ts
index 8b8ab92ba64d3edfb29f182778bb9f1e520724be..d2bcea884d6620831d7345a58f0e7cc218a5e60e
