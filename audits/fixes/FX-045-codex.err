 6691: async function compensateFailedInstanceCreation(input: {
 6692:   instanceId: number
 6693:   host: Host
 6694:   userId: number
 6695:   resources: { cpu: number; memory: number; disk: number }
 6696:   networkMode: NetworkMode
 6697:   portLimit: number
 6698:   instanceName: string
 6699:   errorMessage: string
 6700: }): Promise<{
 6701:   claimed: boolean
 6702:   refundStatus: 'refunded' | 'not_required' | 'already_refunded' | 'not_completed' | 'failed' | 'already_handled'
 6703:   refundAmount: number
 6704:   refundReason?: string
 6705:   refundError?: string
 6706: }> {
 6707:   const {
 6708:     instanceId,
 6709:     host,
 6710:     userId,
 6711:     resources,
 6712:     networkMode,
 6713:     portLimit,
 6714:     instanceName,
 6715:     errorMessage
 6716:   } = input
 6717:   const updateResult = await prisma.instance.updateMany({
 6718:     where: {
 6719:       id: instanceId,
 6720:       status: 'creating'
 6721:     },
 6722:     data: {
 6723:       status: 'error'
 6724:     }
 6725:   })
 6726: 
 6727:   // creating -> error æ˜¯èµ„æºã€IPv4 å’Œè´¦åŠ¡è¡¥å¿çš„å¹‚ç­‰æ€»é—¸é—¨ã€‚
 6728:   if (updateResult.count === 0) {
 6729:     console.log(`[Provisioning] å®žä¾‹ ${instanceId} å·²è¢«å…¶ä»–å¤±è´¥è¡¥å¿æˆ–è¶…æ—¶æ¸…ç†å¤„ç†ï¼Œè·³è¿‡é‡å¤è¡¥å¿`)
 6730:     return { claimed: false, refundStatus: 'already_handled', refundAmount: 0 }
 6731:   }
 6732: 
 6733:   const rollbackPortCount = networkModeAllowsPortMapping(networkMode) ? portLimit : 0
 6734:   try {
 6735:     await db.rollbackResources({
 6736:       hostId: host.id,
 6737:       cpu: resources.cpu,
 6738:       memory: resources.memory,
 6739:       disk: resources.disk,
 6740:       portCount: rollbackPortCount
 6741:     })
 6742:     emitServiceResourceRollbackPluginEvent({
 6743:       event: 'service.resource.rollback.completed',
 6744:       instanceId,
 6745:       userId,
 6746:       hostId: host.id,
 6747:       instanceName,
 6748:       source: 'instance.provisioning.failure',
 6749:       reason: 'provisioning_failed',
 6750:       cpu: resources.cpu,
 6751:       memory: resources.memory,
 6752:       disk: resources.disk,
 6753:       portCount: rollbackPortCount,
 6754:       dedupeKey: `service.resource.rollback.completed:provisioning:${instanceId}`
 6755:     })
 6756:     console.log(`[Provisioning] ç”¨æˆ· ${userId} èµ„æºå·²å›žæ»š (CPU=${resources.cpu}, Mem=${resources.memory}MB, Disk=${resources.disk}MB)`)
 6757:   } catch (rollbackErr) {
 6758:     emitServiceResourceRollbackPluginEvent({
 6759:       event: 'service.resource.rollback.failed',
 6760:       instanceId,
 6761:       userId,
 6762:       hostId: host.id,
 6763:       instanceName,
 6764:       source: 'instance.provisioning.failure',
 6765:       reason: 'rollback_failed',
 6766:       cpu: resources.cpu,
 6767:       memory: resources.memory,
 6768:       disk: resources.disk,
 6769:       portCount: rollbackPortCount,
 6770:       dedupeKey: `service.resource.rollback.failed:provisioning:${instanceId}`,
 6771:       metadata: { failureType: 'resource_rollback_failed' }
 6772:     })
 6773:     console.error(`[Provisioning] èµ„æºå›žæ»šå¤±è´¥:`, rollbackErr)
 6774:   }
 6775: 
 6776:   try {
 6777:     await releaseReservedPublicIpv4ForFailedCreation(instanceId, networkMode)
 6778:   } catch (releaseErr) {
 6779:     console.error(`[Provisioning] é‡Šæ”¾ç‹¬ç«‹ IPv4 å¤±è´¥:`, releaseErr)
 6780:   }
 6781: 
 6782:   try {
 6783:     const compensation = await db.compensateFailedInstancePurchase(instanceId, userId, host.id)
 6784:     await markFlashSaleFailed(instanceId, errorMessage, compensation.refunded).catch((err) => {
 6785:       console.error(`[Provisioning] ç§’æ€å¤±è´¥çŠ¶æ€å›žå†™å¤±è´¥:`, err)
 6786:     })
 6787:     if (compensation.refunded) {
 6788:       console.log(`[Provisioning] å®žä¾‹ ${instanceId} åˆ›å»ºå¤±è´¥å·²è‡ªåŠ¨é€€æ¬¾ Â¥${compensation.refundAmount.toFixed(2)}`)
 6789:     } else if (compensation.reason !== 'not_paid_purchase') {
 6790:       console.log(`[Provisioning] å®žä¾‹ ${instanceId} åˆ›å»ºå¤±è´¥æ— éœ€é€€æ¬¾: ${compensation.reason || 'unknown'}`)
 6791:     }
 6792:     return {
 6793:       claimed: true,
 6794:       refundStatus: compensation.refunded
 6795:         ? 'refunded'
 6796:         : compensation.reason === 'not_paid_purchase'
 6797:           ? 'not_required'
 6798:           : compensation.reason === 'already_refunded'
 6799:             ? 'already_refunded'
 6800:             : 'not_completed',
 6801:       refundAmount: compensation.refundAmount,
 6802:       refundReason: compensation.reason
 6803:     }
 6804:   } catch (compensationErr) {
 6805:     const refundError = compensationErr instanceof Error ? compensationErr.message : String(compensationErr)
 6806:     console.error(`[Provisioning] å®žä¾‹ ${instanceId} åˆ›å»ºå¤±è´¥åŽçš„è´¦åŠ¡è¡¥å¿å¤±è´¥:`, compensationErr)
 6807:     await markFlashSaleFailed(instanceId, errorMessage, false).catch((err) => {
 6808:       console.error(`[Provisioning] ç§’æ€å¤±è´¥çŠ¶æ€å›žå†™å¤±è´¥:`, err)
 6809:     })
 6810:     return { claimed: true, refundStatus: 'failed', refundAmount: 0, refundError }
 6811:   }
 6812: }
