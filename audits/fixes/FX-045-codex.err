  233: async function ensureCaseForTask(task: {
  234:   id: number
  235:   instanceId: number
  236:   hostId: number
  237:   userId: number
  238:   taskType: InstanceTaskType
  239:   status: InstanceTaskStatus
  240:   progress: string | null
  241:   error: string | null
  242:   createdAt: Date
  243:   startedAt: Date | null
  244:   finishedAt: Date | null
  245:   instance?: { name: string; status: string; image: string } | null
