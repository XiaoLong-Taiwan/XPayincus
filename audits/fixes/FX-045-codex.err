 6679: async function releaseReservedPublicIpv4ForFailedCreation(
 6680:   instanceId: number,
 6681:   networkMode: NetworkMode
 6682: ): Promise<void> {
 6683:   if (!networkModeNeedsPublicIpv4(networkMode)) {
 6684:     return
 6685:   }
 6686: 
 6687:   await prisma.$transaction((tx) => db.releasePublicIpv4ForInstance(tx, instanceId))
 6688:   console.log(`[Provisioning] ç‹¬ç«‹ IPv4 å·²é‡Šæ”¾: instance=${instanceId}`)
 6689: }
