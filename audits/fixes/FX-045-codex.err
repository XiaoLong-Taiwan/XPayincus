   46: 
   47: const operationTypeKeys = [
   48:   'change_password',
   49:   'disable_2fa',
   50:   'change_email',
   51:   'delete_account',
   52:   'delete_instance',
   53:   'reinstall_instance',
   54:   'recreate_instance',
   55:   'transfer_instance',
   56:   'delete_snapshot',
