  929: 
  930:   // è°ƒæ•´æˆ‘çš„å®žä¾‹æ˜¾ç¤ºé¡ºåºã€‚åªå…è®¸å®žä¾‹æ‰€æœ‰è€…è°ƒæ•´è‡ªå·±çš„åˆ—è¡¨é¡ºåºã€‚
  931:   fastify.patch<{
  932:     Params: { id: string }
  933:     Body: {
  934:       action: 'top' | 'up' | 'down' | 'bottom'
  935:     }
  936:   }>('/:id/order', {
  937:     onRequest: [fastify.authenticate],
  938:     schema: {
  939:       params: {
  940:         type: 'object',
  941:         required: ['id'],
  942:         properties: {
  943:           id: { type: 'string', pattern: '^[1-9]\\d*$' }
  944:         },
  945:         additionalProperties: false
  946:       },
  947:       body: {
  948:         type: 'object',
  949:         required: ['action'],
  950:         properties: {
  951:           action: { type: 'string', enum: ['top', 'up', 'down', 'bottom'] }
  952:         },
  953:         additionalProperties: false
  954:       }
  955:     }
  956:   }, async (request, reply) => {
  957:     const instanceId = parsePositiveRouteId(request.params.id)
  958:     if (!instanceId) {
  959:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
  960:     }
  961: 
  962:     const result = await prisma.$transaction(async tx => {
  963:       const orderedInstances = await tx.instance.findMany({
  964:         where: {
  965:           userId: request.user.id,
  966:           status: { not: 'deleted' }
  967:         },
  968:         orderBy: [
  969:           { displayOrder: 'asc' },
  970:           { createdAt: 'desc' },
  971:           { id: 'asc' }
  972:         ],
  973:         select: { id: true }
  974:       })
  975: 
  976:       const currentIndex = orderedInstances.findIndex(instance => instance.id === instanceId)
  977:       if (currentIndex < 0) {
  978:         return null
  979:       }
  980: 
  981:       let targetIndex = currentIndex
  982:       if (request.body.action === 'top') targetIndex = 0
  983:       else if (request.body.action === 'up') targetIndex = currentIndex - 1
  984:       else if (request.body.action === 'down') targetIndex = currentIndex + 1
  985:       else targetIndex = orderedInstances.length - 1
  986: 
  987:       targetIndex = Math.max(0, Math.min(targetIndex, orderedInstances.length - 1))
  988:       if (targetIndex === currentIndex) {
  989:         return { updated: 0 }
  990:       }
  991: 
  992:       const nextOrder = [...orderedInstances]
  993:       const [moved] = nextOrder.splice(currentIndex, 1)
  994:       if (!moved) {
  995:         return { updated: 0 }
  996:       }
  997:       nextOrder.splice(targetIndex, 0, moved)
  998: 
  999:       await Promise.all(nextOrder.map((instance, index) => tx.instance.update({
 1000:         where: { id: instance.id },
 1001:         data: { displayOrder: index * 1000 }
 1002:       })))
 1003: 
 1004:       return { updated: nextOrder.length }
 1005:     })
 1006: 
 1007:     if (result === null) {
 1008:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 1009:     }
 1010: 
 1011:     return {
 1012:       message: 'Instance order updated',
 1013:       updated: result.updated
 1014:     }
 1015:   })
 1016: 
 1017:   // èŽ·å–å¯ç”¨å®¿ä¸»æœºåˆ—è¡¨ï¼ˆç”¨äºŽåˆ›å»ºå®žä¾‹æ—¶é€‰æ‹©ï¼‰
 1018:   // æ ¹æ®å¥—é¤æ‰€æœ‰æƒè¿”å›žå¯¹åº”çš„èŠ‚ç‚¹ï¼š
 1019:   // - è‡ªå·±çš„å¥—é¤ï¼šè¿”å›žè‡ªå·±çš„èŠ‚ç‚¹ï¼ˆå®Œæ•´ä¿¡æ¯ï¼‰
 1020:   // - å…±äº«çš„å¥—é¤ï¼šè¿”å›žå¥—é¤æ‰€æœ‰è€…çš„èŠ‚ç‚¹ï¼ˆéƒ¨åˆ†ä¿¡æ¯ï¼‰
 1021:   // - ç®¡ç†å‘˜ï¼šå¯ä»¥è®¿é—®æ‰€æœ‰å¥—é¤çš„å®¿ä¸»æœº
 1022:   fastify.get<{
