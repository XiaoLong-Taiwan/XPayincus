   61:   'email',
   62:   'telegram',
   63:   'discord',
   64:   'webhook'
   65: ] as const
   66: 
   67: function assertLocaleContainsKeys(localeName: string, source: string): void {
   68:   assert.ok(source.includes('sensitiveVerification: {'), `${localeName} must define sensitiveVerification messages`)
   69: 
   70:   for (const key of sensitiveVerificationKeys) {
   71:     assert.ok(
   72:       new RegExp(`\\b${key}:\\s*'`).test(source),
   73:       `${localeName} must define sensitiveVerification.${key}`
   74:     )
   75:   }
   76: 
   77:   for (const key of operationTypeKeys) {
   78:     assert.ok(
   79:       new RegExp(`\\b${key}:\\s*'`).test(source),
   80:       `${localeName} must define sensitiveVerification.operationTypes.${key}`
   81:     )
   82:   }
   83: 
   84:   for (const key of channelKeys) {
   85:     assert.ok(
   86:       new RegExp(`\\b${key}:\\s*'`).test(source),
   87:       `${localeName} must define sensitiveVerification.channels.${key}`
   88:     )
   89:   }
   90: }
   91: 
   92: function collectFrontendTranslationKeys(): Set<string> {
   93:   const files = [
   94:     'client/src/views/admin/EntertainmentView.vue',
   95:     'client/src/views/admin/AffReviewView.vue'
   96:   ]
   97:   const keys = new Set<string>()
   98:   const keyPatterns = [
   99:     /\$t\(\s*['"`]([A-Za-z0-9_.-]+)['"`]/g,
  100:     /\bt\(\s*['"`]([A-Za-z0-9_.-]+)['"`]/g,
  101:     /titleKey:\s*['"`]([A-Za-z0-9_.-]+)['"`]/g,
  102:     /label:\s*['"`]([A-Za-z0-9_.-]+)['"`]/g
  103:   ]
  104: 
  105:   for (const file of files) {
  106:     const source = readFileSync(resolve(repoRoot, file), 'utf8')
  107:     for (const pattern of keyPatterns) {
  108:       for (const match of source.matchAll(pattern)) {
  109:         const key = match[1]
  110:         if (key.startsWith('entertainment.') || key.startsWith('aff.')) keys.add(key)
  111:       }
  112:     }
  113:   }
  114: 
  115:   return keys
  116: }
  117: 
  118: function resolveMessage(source: unknown, key: string): unknown {
  119:   let current = source
  120:   for (const part of key.split('.')) {
  121:     if (!current || typeof current !== 'object' || !(part in current)) return undefined
  122:     current = (current as Record<string, unknown>)[part]
  123:   }
  124:   return current
  125: }
  126: 
  127: function assertFrontendKeysExist(): void {
  128:   const keys = collectFrontendTranslationKeys()
  129:   assert.ok(keys.has('entertainment.admin.title'), 'frontend i18n guard must cover admin benefits page keys')
  130:   assert.ok(keys.has('entertainment.prizeTypes.badge'), 'frontend i18n guard must cover shared benefits prize type keys')
  131:   assert.ok(keys.has('aff.adminTitle'), 'frontend i18n guard must cover admin AFF review title')
  132:   assert.ok(keys.has('aff.withdrawalStatus.pending'), 'frontend i18n guard must cover admin AFF review nested status labels')
  133: 
  134:   for (const [localeName, messages] of Object.entries(localeMessages)) {
  135:     for (const key of keys) {
  136:       assert.equal(
  137:         typeof resolveMessage(messages, key),
  138:         'string',
  139:         `${localeName} must define frontend i18n key ${key}`
  140:       )
  141:     }
  142:   }
  143: }
  144: 
  145: function assertSplitLocalePruneKeepsAdminBenefits(): void {
  146:   const adminPruneStart = viteConfigSource.indexOf('function stripAdminOnlyLocaleMessages')
  147:   const userPruneStart = viteConfigSource.indexOf('function stripUserOnlyLocaleMessages')
  148:   assert.ok(adminPruneStart >= 0 && userPruneStart > adminPruneStart, 'Vite config must define split locale prune helpers')
  149: 
  150:   const adminPruneSource = viteConfigSource.slice(adminPruneStart, userPruneStart)
  151:   const userPruneSource = viteConfigSource.slice(userPruneStart)
  152:   const userOnlyTopLevelMatch = /const userOnlyTopLevelKeys = \[([\s\S]*?)\]/.exec(adminPruneSource)
  153:   assert.ok(userOnlyTopLevelMatch, 'admin locale prune must define userOnlyTopLevelKeys')
  154:   const userOnlyTopLevelKeysSource = userOnlyTopLevelMatch[1]
  155:   const adminEntertainmentRemovedKeysMatch = /const adminEntertainmentRemovedKeys = \[([\s\S]*?)\]/.exec(adminPruneSource)
  156:   assert.ok(adminEntertainmentRemovedKeysMatch, 'admin locale prune must define adminEntertainmentRemovedKeys')
  157:   const adminEntertainmentRemovedKeysSource = adminEntertainmentRemovedKeysMatch[1]
  158: 
  159:   assert.ok(
  160:     !userOnlyTopLevelKeysSource.includes("'entertainment'"),
  161:     'admin locale prune must not remove the whole entertainment namespace because the admin benefits page uses entertainment.admin'
  162:   )
  163:   assert.ok(
  164:     !userOnlyTopLevelKeysSource.includes("'aff'"),
  165:     'admin locale prune must not remove the aff namespace because the admin billing AFF review page uses aff.* labels'
  166:   )
  167:   assert.ok(
  168:     adminPruneSource.includes('adminEntertainmentRemovedKeys') &&
  169:       adminEntertainmentRemovedKeysSource.includes("'wonInstance'") === false &&
  170:       adminEntertainmentRemovedKeysSource.includes("'admin'") === false,
  171:     'admin locale prune must keep entertainment.admin plus shared prize result labels required by the admin benefits page'
