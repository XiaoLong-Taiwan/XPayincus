--- full operation remainder ---
  680:   fastify.post<{ Params: { type: string; id: string }; Body: OrderOperationInput }>('/api/admin/orders/:type/:id/operation', {
  681:     preHandler: [fastify.authenticateAdmin],
  682:     config: { rateLimit: { max: 30, timeWindow: '1 minute' } }
  683:   }, async (request, reply) => {
  684:     const type = normalizeOrderType(request.params.type)
  685:     const id = parsePositiveId(request.params.id)
  686:     if (!type || !id) {
  687:       return reply.code(400).send({ error: '订单 ID 无效', code: 'INVALID_ORDER_ID' })
  688:     }
  689: 
  690:     let input: ReturnType<typeof normalizeOrderOperationInput>
  691:     try {
  692:       input = normalizeOrderOperationInput(request.body)
  693:     } catch (error) {
  694:       return reply.code(400).send(error)
  695:     }
  696: 
  697:     const rechargeOrder = type === 'recharge'
  698:       ? await prisma.rechargeRecord.findUnique({
  699:           where: { id },
  700:           include: { provider: { select: { id: true, name: true, type: true } } }
  701:         })
  702:       : null
  703:     const billingOrder = type === 'instance_billing'
  704:       ? await prisma.instanceBillingRecord.findUnique({
  705:           where: { id }
  706:         })
  707:       : null
  708:     const order = rechargeOrder ?? billingOrder
  709: 
  710:     if (!order) {
  711:       return reply.code(404).send({ error: '订单不存在', code: 'ORDER_NOT_FOUND' })
  712:     }
  713: 
  714:     if (input.refundAmount !== undefined && input.refundAmount > toMoney(order.amount)) {
  715:       return reply.code(400).send({ error: '退款金额不能超过订单金额' })
  716:     }
  717: 
  718:     const existingPendingRefund = input.createRefundRequest
  719:       ? await prisma.balanceAdjustmentRequest.findFirst({
  720:           where: {
  721:             requestType: 'refund',
  722:             status: 'pending',
  723:             sourceType: type,
  724:             sourceId: id
  725:           },
  726:           select: { id: true }
  727:         })
  728:       : null
  729: 
  730:     if (existingPendingRefund) {
  731:       return reply.code(409).send({ error: `该订单已有待审核退款审批 #${existingPendingRefund.id}` })
  732:     }
  733: 
  734:     const orderNo = rechargeOrder ? rechargeOrder.orderNo : `BILL-${order.id}`
  735:     const providerSummary = rechargeOrder
  736:       ? buildProviderStatusSummary(rechargeOrder)
  737:       : Prisma.JsonNull
  738:     const adjustmentRequest = input.createRefundRequest
  739:       ? await createBalanceAdjustmentRequest({
  740:           userId: order.userId,
  741:           requestedByUserId: request.user.id,
  742:           amount: input.refundAmount!,
  743:           requestType: 'refund',
  744:           sourceType: type,
  745:           sourceId: id,
  746:           orderNo,
  747:           reason: input.reason
  748:         })
  749:       : null
  750: 
  751:     const operationCase = await prisma.orderOperationCase.upsert({
  752:       where: { sourceType_sourceId: { sourceType: type, sourceId: id } },
  753:       create: {
  754:         sourceType: type,
  755:         sourceId: id,
  756:         orderNo,
  757:         userId: order.userId,
  758:         createdByUserId: request.user.id,
  759:         updatedByUserId: request.user.id,
  760:         status: input.status,
  761:         reason: input.reason,
  762:         result: input.result,
  763:         refundAmount: input.refundAmount,
  764:         providerSummary,
  765:         balanceAdjustmentRequestId: adjustmentRequest?.id
  766:       },
  767:       update: {
  768:         status: input.status,
  769:         reason: input.reason,
  770:         result: input.result,
  771:         refundAmount: input.refundAmount ?? null,
  772:         providerSummary,
  773:         updatedByUserId: request.user.id,
  774:         ...(adjustmentRequest ? { balanceAdjustmentRequestId: adjustmentRequest.id } : {})
  775:       },
  776:       include: includeOrderOperationCaseRelations()
  777:     })
  778: 
  779:     await createLog(
  780:       request.user.id,
  781:       'admin',
