    throw new ExchangeError('EXCHANGE_INVALID_AMOUNT', `${field}æœ€å¤šä¿ç•™ä¸¤ä½å°æ•°`)
  }
  return normalized
}

function normalizeOptionalText(value: string | null | undefined, maxLength: number): string | null {
