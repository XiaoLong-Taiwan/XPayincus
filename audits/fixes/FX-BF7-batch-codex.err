export class ExchangeError extends Error {
  code: string
  httpStatus: number
  detail?: unknown

  constructor(code: string, message: string, httpStatus = 400, detail?: unknown) {
    super(message)
    this.name = 'ExchangeError'
    this.code = code
    this.httpStatus = httpStatus
    this.detail = detail
  }
}

