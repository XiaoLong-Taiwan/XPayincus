    }

    try {
      const eligibility = await checkExchangeListingEligibility(request.user.id, instanceId)
      if (eligibility.status === 'can_list') {
        return {
          message: 'å®žä¾‹å·²æš‚åœï¼Œå¯ç»§ç»­æŒ‚ç‰Œ',
