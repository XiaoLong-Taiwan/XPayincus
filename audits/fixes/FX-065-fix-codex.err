diff --git a/server/prisma/schema.prisma b/server/prisma/schema.prisma
index c256e38b7e42232caa1272d17569db812af5d7a1..91a9d3d6566d3dd342e2df105e9b4575c3164308
--- a/server/prisma/schema.prisma
+++ b/server/prisma/schema.prisma
@@ -1324,7 +1324,7 @@
   backupLimit         Int          @default(3) @map("backup_limit") // 备份数上限
   siteLimit           Int          @default(10) @map("site_limit") // 反代站点数上限
   monthlyTrafficLimit BigInt?      @map("monthly_traffic_limit") // 月流量限额 (Bytes)，null = 无限制
-  trafficResetPrice   Decimal      @default(0) @map("traffic_reset_price") @db.Decimal(10, 2) // 用户自助重置月流量价格（元）
+  trafficResetPrice   Decimal      @default(0) @map("traffic_reset_price") @db.Decimal(10, 2) // 用户自助重置月流量价格（存储单位：分，表单按元输入，提交前×100）
 
   // 存储 I/O 限制
   ioLimitMode     String @default("throughput") @map("io_limit_mode") // "throughput" | "iops" - IO限制模式
@@ -4223,7 +4223,7 @@
   price        Decimal @db.Decimal(10, 2)                             // 价格
   billingCycle Int     @default(1) @map("billing_cycle")              // 计费周期（月）
   setupFee     Decimal @default(0) @map("setup_fee") @db.Decimal(10, 2) // 开通费
-  trafficResetPrice Decimal? @map("traffic_reset_price") @db.Decimal(10, 2) // 用户自助重置月流量价格覆盖（元），null=继承套餐
+  trafficResetPrice Decimal? @map("traffic_reset_price") @db.Decimal(10, 2) // 用户自助重置月流量价格覆盖（存储单位：分，表单按元输入，提交前×100），null=继承套餐
 
   // ========== 状态与排序 ==========
   isActive  Boolean @default(true) @map("is_active") // 是否启用
diff --git a/server/scripts/test-traffic-reset-locks.ts b/server/scripts/test-traffic-reset-locks.ts
index 387eb63f5cc46956656a8f386b485f4b2793d7cf..761df072be785cc47f16858b510665fdc305865a
--- a/server/scripts/test-traffic-reset-locks.ts
+++ b/server/scripts/test-traffic-reset-locks.ts
@@ -27,20 +27,7 @@
 const collectorSource = readFileSync(resolve(repoRoot, 'server/src/services/instance-traffic-collector.ts'), 'utf8')
 const agentReportSource = readFileSync(resolve(repoRoot, 'server/src/services/agent-instance-report.ts'), 'utf8')
 
-const trafficResetPriceResolver = section(
-  trafficRoutesSource,
-  'function resolveTrafficResetPriceYuan(',
-  '/**\n * 计算百分比'
-)
 assert(
-  trafficResetPriceResolver.includes('normalizeMoney(Number(planPrice) || 0)') &&
-    trafficResetPriceResolver.includes('normalizeMoney(Number(instance.package?.trafficResetPrice) || 0)') &&
-    !trafficResetPriceResolver.includes('Math.round') &&
-    !trafficResetPriceResolver.includes('/ 100'),
-  'traffic reset price resolver must preserve two-decimal yuan values without cents conversion'
-)
-
-assert(
   trafficDbSource.includes("function getTrafficInstanceLockKey(instanceId: number): string {\n    return `traffic:instance:${instanceId}`"),
   'traffic reset code must use the same instance traffic lock key as collectors'
 )
@@ -122,10 +109,8 @@
   '    // ==================== 管理员操作'
 )
 assert(
-  userResetRoute.includes('const priceYuan = resolveTrafficResetPriceYuan(currentInstance)') &&
