codex
使用 Vite 官方的 runner 配置加载方式后，user 端生产构建已通过；该方式仅绕过沙箱不允许的配置预打包扫描，不改变项目配置或产物逻辑。接着并行构建 admin 与 server，最后再做 dist 边界确认。
exec
"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command '$env:VITE_APP_ENTRY='"'admin'; .\\node_modules\\.bin\\vite.CMD build --configLoader runner" in C:\Users\Administrator\Desktop\payinces\client
exec
"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command 'pnpm --filter server build' in C:\Users\Administrator\Desktop\payinces
