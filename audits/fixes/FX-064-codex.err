+        const context = await resolveTrafficNotificationContext(userId, instanceName)
         const title = '⚠️ 流量预警'
         const scope = instanceName ? `您的实例 ${instanceName} 月度流量` : '您的月度流量'
         const message = `${scope}已使用 ${percentage}%\n` +
