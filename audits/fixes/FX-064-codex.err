> server\prisma\schema.prisma:4200:model PackagePlan {
  server\prisma\schema.prisma:4201:  id        Int @id @default(autoincrement())
  server\prisma\schema.prisma:4202:  packageId Int @map("package_id")
  server\prisma\schema.prisma:4203:
  server\prisma\schema.prisma:4204:  // 基本信息
  server\prisma\schema.prisma:4205:  name        String  // 方案名称，如"低配"、"高配"、"标准版"
  server\prisma\schema.prisma:4206:  description String? // 方案描述
  server\prisma\schema.prisma:4207:
  server\prisma\schema.prisma:4208:  // ========== 资源配置（预设固定值） ==========
  server\prisma\schema.prisma:4209:  cpu    Int // CPU 额度 (%)，如 50, 100, 200
  server\prisma\schema.prisma:4210:  memory Int // 内存 (MB)，如 512, 1024, 2048
  server\prisma\schema.prisma:4211:  disk   Int // 磁盘 (MB)，如 10240, 20480, 51200
  server\prisma\schema.prisma:4212:
  server\prisma\schema.prisma:4213:  // ========== 配额限制（方案级别独立配置） ==========
  server\prisma\schema.prisma:4214:  portLimit         Int    @map("port_limit")          // 端口映射数上限
  server\prisma\schema.prisma:4215:  snapshotLimit     Int    @map("snapshot_limit")      // 快照数上限
  server\prisma\schema.prisma:4216:  backupLimit       Int    @map("backup_limit")        // 备份数上限
  server\prisma\schema.prisma:4217:  siteLimit         Int    @map("site_limit")          // 反代站点数上限
