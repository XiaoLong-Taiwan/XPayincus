const fs = require('node:fs')
const trafficBandwidth = fs.readFileSync('server/src/services/traffic-bandwidth.ts', 'utf8')
const riskService = fs.readFileSync('server/src/services/resource-risk.ts', 'utf8')
const checks = {
  computeEffectiveBandwidth: trafficBandwidth.includes('export function computeEffectiveBandwidth'),
  minCandidates: trafficBandwidth.includes('Math.min(...candidates)'),
  planLimit: trafficBandwidth.includes('instance.packagePlan?.trafficLimitSpeed'),
  trafficStatusLimit: trafficBandwidth.includes(\"instance.trafficStatus === 'LIMITED' ? THROTTLE_BANDWIDTH : null\"),
  riskLimit: trafficBandwidth.includes('instance.resourceRiskState?.currentBandwidthLimit ?? null'),
  reconcileExport: trafficBandwidth.includes('export async function reconcileEffectiveBandwidth'),
  setRiskConstraint: riskService.includes('currentBandwidthLimit: bandwidthLimit'),
  reconcileApply: riskService.includes('await reconcileEffectiveBandwidth(instance.id)'),
  reconcileRecover: riskService.includes('await reconcileEffectiveBandwidth(state.instanceId)'),
  noOriginalIngress: "'!riskService.includes('"'originalIngress:'),
  noOriginalEgress: "'!riskService.includes('"'originalEgress:'),
  noRestoreBandwidth: "'!riskService.includes('"'restoreBandwidth('),
}
console.log(checks)
if (Object.values(checks).every(Boolean)) process.exit(0)
process.exit(1)
