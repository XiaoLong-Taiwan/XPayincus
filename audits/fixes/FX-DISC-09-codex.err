const fs = require('node:fs')
const cp = require('node:child_process')
const current = fs.readFileSync('client/src/views/admin/ResourceRiskView.vue', 'utf8')
const baseline = cp.execFileSync('git', ['show', 'HEAD:client/src/views/admin/ResourceRiskView.vue'], { encoding: 'utf8' })
const clicks = text => [...text.matchAll(/@click=\"(["'^"]+)"/g)].map(match => match[1])
const groups = [...current.matchAll(/<colgroup>(['"\\s\\S]*?)<\\/colgroup>/g)].map((match, index) => ({
  table: index + 1,
  widths: [...match[1].matchAll(/w-\\[(\\d+)%\\]/g)].map(width => Number(width[1])),
})).map(group => ({ ...group, total: group.widths.reduce((sum, width) => sum + width, 0) }))
const clickPathsUnchanged = JSON.stringify(clicks(current)) === JSON.stringify(clicks(baseline))
console.log({ groups, clickPathsUnchanged, currentClickCount: clicks(current).length, baselineClickCount: clicks(baseline).length })
if ("'!clickPathsUnchanged || groups.length !== 8 || groups.some(group => group.total !== 100)) process.exit(1)
