}

async function simulatePolicy() {
  const qosTiers = normalizeQosTiers()
  if (!qosTiers) return

  simulating.value = true
  try {
    const res = await api.resourceRisk.simulatePolicy(buildPolicyPayload(qosTiers))
    policySimulation.value = res.result
    toast.success('ç­–ç•¥è¯•è¿è¡Œå®Œæˆ')
  } catch (error: any) {
    toast.error(`è¯•è¿è¡Œå¤±è´¥ï¼š${error?.message || error}`)
  } finally {
    simulating.value = false
  }
}

async function savePolicy() {
  const qosTiers = normalizeQosTiers()
  if (!qosTiers) return

  saving.value = true
  try {
    const res = await api.resourceRisk.updatePolicy(buildPolicyPayload(qosTiers))
    syncPolicyForm(res.policy)
    toast.success('èµ„æºé£ŽæŽ§ç­–ç•¥å·²ä¿å­˜')
  } catch (error: any) {
    toast.error(`ä¿å­˜å¤±è´¥ï¼š${error?.message || error}`)
  } finally {
    saving.value = false
  }
}

