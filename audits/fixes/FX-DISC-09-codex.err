        reason,
        ticketId: context.restriction.ticketId
      })
      toast.success('ä¸‹å•é™åˆ¶å·²è§£é™¤')
    }
    await reloadOperationalLists()
    closeManualAction(true)
  } catch (error: any) {
    toast.error(`æ“ä½œå¤±è´¥ï¼š${error?.message || error}`)
  } finally {
    manualSubmitting.value = false
  }
}

