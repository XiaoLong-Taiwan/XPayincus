 157: function parseItemUpdateInput(body: Record<string, unknown>, actorUserId: number) {
 158:   const flashPrice = parseOptionalMoneyCents(body.flashPrice)
 159:   const totalStock = parseOptionalNonNegativeInteger(body.totalStock)
 160:   const perUserLimit = parseOptionalPositiveInteger(body.perUserLimit)
 161:   const sortOrder = parseOptionalNonNegativeInteger(body.sortOrder)
 162:   if (flashPrice === null || totalStock === null || perUserLimit === null || sortOrder === null) {
 163:     throw new FlashSaleError('FLASH_SALE_INVALID_ITEM', 'ç§’æ€å•†å“é…ç½®æ— æ•ˆ')
 164:   }
 165:   if (body.allowCoupon !== undefined && typeof body.allowCoupon !== 'boolean') {
 166:     throw new FlashSaleError('FLASH_SALE_INVALID_ITEM', 'ä¼˜æƒ ç å¼€å…³æ— æ•ˆ')
 167:   }
 168:   if (body.allowAff !== undefined && typeof body.allowAff !== 'boolean') {
 169:     throw new FlashSaleError('FLASH_SALE_INVALID_ITEM', 'AFF å¼€å…³æ— æ•ˆ')
 170:   }
 171: 
 172:   return {
 173:     ...(flashPrice !== undefined ? { flashPrice } : {}),
 174:     ...(totalStock !== undefined ? { totalStock } : {}),
 175:     ...(perUserLimit !== undefined ? { perUserLimit } : {}),
 176:     ...(typeof body.allowCoupon === 'boolean' ? { allowCoupon: body.allowCoupon } : {}),
 177:     ...(typeof body.allowAff === 'boolean' ? { allowAff: body.allowAff } : {}),
 178:     ...(sortOrder !== undefined ? { sortOrder } : {}),
 179:     actorUserId,
 180:     reason: normalizeText(body.reason, 500) ?? undefined
 181:   }
 182: }
