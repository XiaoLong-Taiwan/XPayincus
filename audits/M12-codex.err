 523: export async function adjustFlashSaleItemStock(itemId: number, totalStock: number, actorUserId: number, reason?: string) {
 524:   if (!Number.isInteger(totalStock) || totalStock < 0) {
 525:     throw new FlashSaleError('FLASH_SALE_INVALID_STOCK', 'åº“å­˜ä¸èƒ½å°äºŽ 0')
 526:   }
 527:   const item = await prisma.flashSaleItem.findUnique({ where: { id: itemId } })
 528:   if (!item) return null
 529:   if (totalStock < item.soldCount + item.reservedCount) {
 530:     throw new FlashSaleError('FLASH_SALE_STOCK_BELOW_SOLD', 'åº“å­˜ä¸èƒ½å°äºŽå·²å”®å’Œé”å®šæ•°é‡')
 531:   }
 532:   const updated = await prisma.$transaction(async (tx) => {
 533:     const next = await tx.flashSaleItem.update({
 534:       where: { id: itemId },
 535:       data: { totalStock }
 536:     })
 537:     await tx.flashSaleAuditLog.create({
 538:       data: {
 539:         campaignId: item.campaignId,
 540:         itemId,
 541:         actorUserId,
 542:         action: 'stock_adjust',
 543:         beforeData: item as unknown as Prisma.InputJsonValue,
 544:         afterData: next as unknown as Prisma.InputJsonValue,
 545:         reason
 546:       }
 547:     })
 548:     return next
 549:   })
 550:   return updated
 551: }
