 249: export async function findGiftCardByCode(code: string) {
 250:   const card = await prisma.giftCard.findUnique({
 251:     where: { code },
 252:     select: {
 253:       id: true,
 254:       code: true,
 255:       faceValue: true,
 256:       balanceValue: true,
 257:       status: true,
 258:       createdById: true,
 259:       ownerId: true,
 260:       usedById: true,
 261:       usedAt: true,
 262:       expiresAt: true,
 263:       remark: true,
 264:       batchId: true,
 265:       createdAt: true,
 266:       createdBy: { select: { id: true, username: true } },
 267:       owner: { select: { id: true, username: true } },
 268:       usedBy: { select: { id: true, username: true } }
 269:     }
 270:   })
 271:   return card ? serializeGiftCard(card, { revealCode: true }) : null
 272: }
