 128: function parseItems(value: unknown) {
 129:   if (!Array.isArray(value)) {
 130:     throw new FlashSaleError('FLASH_SALE_ITEM_REQUIRED', 'è‡³å°‘éœ€è¦ä¸€ä¸ªç§’æ€å•†å“')
 131:   }
 132: 
 133:   return value.map((raw) => {
 134:     const item = raw as Record<string, unknown>
 135:     const packagePlanId = parsePositiveId(item.packagePlanId)
 136:     const flashPrice = parseMoneyCents(item.flashPrice)
 137:     const totalStock = parsePositiveInteger(item.totalStock, 1)
 138:     const perUserLimit = parsePositiveInteger(item.perUserLimit, 1)
 139:     const sortOrder = parseNonNegativeInteger(item.sortOrder, 0)
 140: 
 141:     if (!packagePlanId || flashPrice === null || totalStock === null || perUserLimit === null || sortOrder === null) {
 142:       throw new FlashSaleError('FLASH_SALE_INVALID_ITEM', 'ç§’æ€å•†å“é…ç½®æ— æ•ˆ')
 143:     }
 144: 
 145:     return {
 146:       packagePlanId,
 147:       flashPrice,
 148:       totalStock,
 149:       perUserLimit,
 150:       allowCoupon: item.allowCoupon === true,
 151:       allowAff: item.allowAff === true,
 152:       sortOrder
 153:     }
 154:   })
 155: }
