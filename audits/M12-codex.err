   1: <script setup lang="ts">
   2: import { computed, onMounted, ref } from 'vue'
   3: import { useI18n } from 'vue-i18n'
   4: import api from '@/api'
   5: import { useToast } from '@/stores/toast'
   6: import { useThemeStore } from '@/stores/theme'
   7: import TurnstileWidget from '@/components/TurnstileWidget.vue'
   8: import type { GiftCardRecord, GiftCardStatus } from '@/types/api'
   9: 
  10: const { t, locale } = useI18n()
  11: const toast = useToast()
  12: const themeStore = useThemeStore()
  13: 
  14: const redeemCode = ref('')
  15: const generateAmount = ref<number | null>(null)
  16: const generateRemark = ref('')
  17: const cards = ref<GiftCardRecord[]>([])
  18: const loading = ref(false)
  19: const redeeming = ref(false)
  20: const generating = ref(false)
  21: const statusFilter = ref<GiftCardStatus | ''>('')
  22: const lastGeneratedCode = ref('')
  23: const revealedCodeIds = ref<Set<number>>(new Set())
  24: const turnstileEnabled = ref(false)
  25: const turnstileSiteKey = ref('')
  26: const turnstileToken = ref('')
  27: const turnstileRef = ref<InstanceType<typeof TurnstileWidget> | null>(null)
  28: const isTurnstileChallengeAvailable = computed<boolean>(() => turnstileEnabled.value && Boolean(turnstileSiteKey.value))
  29: 
  30: const statusOptions = computed<Array<{ value: GiftCardStatus | ''; label: string }>>(() => [
  31:   { value: '', label: t('giftCards.status.all') },
  32:   { value: 'active', label: t('giftCards.status.active') },
  33:   { value: 'used', label: t('giftCards.status.used') },
  34:   { value: 'disabled', label: t('giftCards.status.disabled') },
  35:   { value: 'expired', label: t('giftCards.status.expired') }
  36: ])
  37: 
  38: const totalActiveValue = computed(() =>
  39:   cards.value
  40:     .filter(card => card.status === 'active')
  41:     .reduce((sum, card) => sum + card.balanceValue, 0)
  42: )
  43: 
  44: function formatMoney(value: number): string {
  45:   return new Intl.NumberFormat(locale.value, {
  46:     style: 'currency',
  47:     currency: 'CNY',
  48:     maximumFractionDigits: 2
  49:   }).format(value || 0)
  50: }
  51: 
  52: function formatDate(value?: string | null): string {
  53:   if (!value) return t('giftCards.neverExpires')
  54:   return new Date(value).toLocaleString(locale.value)
  55: }
  56: 
  57: function statusLabel(status: GiftCardStatus): string {
  58:   return t(`giftCards.status.${status}`)
  59: }
  60: 
  61: function statusClass(status: GiftCardStatus): string {
  62:   return {
  63:     active: 'text-green-500',
  64:     used: 'text-themed-muted',
  65:     disabled: 'text-gray-400 dark:text-gray-500',
  66:     expired: 'text-red-500'
  67:   }[status]
  68: }
  69: 
  70: function maskGiftCardCode(code: string): string {
  71:   if (!code) return ''
  72:   if (code.length <= 12) return `${code.slice(0, 3)}...`
  73:   return `${code.slice(0, 6)}...${code.slice(-4)}`
  74: }
  75: 
  76: function isCodeRevealed(card: GiftCardRecord): boolean {
  77:   return revealedCodeIds.value.has(card.id)
  78: }
  79: 
  80: function displayCardCode(card: GiftCardRecord): string {
  81:   return isCodeRevealed(card) ? card.code : (card.codeMasked || maskGiftCardCode(card.code))
  82: }
  83: 
  84: function toggleCodeReveal(card: GiftCardRecord): void {
  85:   const next = new Set(revealedCodeIds.value)
  86:   if (next.has(card.id)) {
  87:     next.delete(card.id)
  88:   } else {
  89:     next.add(card.id)
  90:   }
  91:   revealedCodeIds.value = next
  92: }
  93: 
  94: async function loadTurnstileConfig(): Promise<void> {
  95:   try {
  96:     const config = await api.systemConfig.getPublic()
  97:     turnstileEnabled.value = config.turnstileEnabled || false
  98:     turnstileSiteKey.value = config.turnstileSiteKey || ''
  99:   } catch (err) {
 100:     console.error('[GiftCardsView] Failed to load Turnstile config:', err)
 101:     turnstileEnabled.value = false
 102:     turnstileSiteKey.value = ''
 103:   }
 104: }
 105: 
 106: async function loadCards(): Promise<void> {
 107:   loading.value = true
 108:   try {
 109:     const response = await api.giftCards.mine({
 110:       page: 1,
 111:       pageSize: 100,
 112:       status: statusFilter.value || undefined
 113:     })
 114:     cards.value = response.records
 115:     revealedCodeIds.value = new Set()
 116:   } catch (err: any) {
 117:     toast.error(t('giftCards.toast.loadFailed', { message: err?.message || String(err) }))
 118:   } finally {
 119:     loading.value = false
 120:   }
 121: }
 122: 
 123: function getTurnstileToken(): string | undefined {
 124:   if (!isTurnstileChallengeAvailable.value) return undefined
 125:   const widgetToken = turnstileRef.value?.getToken?.()
 126:   if (widgetToken) {
 127:     turnstileToken.value = widgetToken
 128:     return widgetToken
 129:   }
 130: 
 131:   if (turnstileToken.value) return turnstileToken.value
 132: 
 133:   const domToken = document
 134:     .querySelector<HTMLInputElement>('input[name="cf-turnstile-response"]')
 135:     ?.value
 136:     ?.trim()
 137:   if (domToken) {
 138:     turnstileToken.value = domToken
 139:     return domToken
 140:   }
 141: 
 142:   return undefined
 143: }
 144: 
 145: function resetTurnstile(): void {
 146:   turnstileToken.value = ''
 147:   turnstileRef.value?.reset?.()
 148: }
 149: 
 150: function requireTurnstileToken(): string | undefined | null {
 151:   const token = getTurnstileToken()
 152:   if (isTurnstileChallengeAvailable.value && !token) {
 153:     toast.warning(t('giftCards.toast.turnstileRequired'))
 154:     return null
 155:   }
 156:   return token
 157: }
 158: 
 159: function onTurnstileExpire(): void {
 160:   turnstileToken.value = ''
 161: }
 162: 
 163: function onTurnstileError(): void {
 164:   turnstileToken.value = ''
 165:   toast.error(t('giftCards.toast.turnstileFailed'))
 166: }
 167: 
 168: function onTurnstileVerify(token: string): void {
 169:   turnstileToken.value = token
 170: }
 171: 
 172: async function redeemGiftCard(): Promise<void> {
 173:   const code = redeemCode.value.trim()
 174:   if (!code) {
 175:     toast.warning(t('giftCards.toast.redeemCodeRequired'))
 176:     return
 177:   }
 178:   redeeming.value = true
 179:   try {
 180:     const token = requireTurnstileToken()
 181:     if (token === null) return
 182:     const response = await api.giftCards.redeem(code, token)
 183:     toast.success(t('giftCards.toast.redeemSuccess', { amount: formatMoney(response.amount) }))
 184:     redeemCode.value = ''
 185:     await loadCards()
 186:   } catch (err: any) {
 187:     toast.error(t('giftCards.toast.redeemFailed', { message: err?.message || String(err) }))
 188:   } finally {
 189:     resetTurnstile()
 190:     redeeming.value = false
 191:   }
 192: }
 193: 
 194: async function generateGiftCard(): Promise<void> {
 195:   const amount = Number(generateAmount.value)
 196:   if (!Number.isFinite(amount) || amount <= 0) {
 197:     toast.warning(t('giftCards.toast.generateAmountRequired'))
 198:     return
 199:   }
 200:   generating.value = true
 201:   try {
 202:     const token = requireTurnstileToken()
 203:     if (token === null) return
 204:     const response = await api.giftCards.generate(amount, generateRemark.value.trim() || undefined, token)
 205:     lastGeneratedCode.value = response.giftCard.code
 206:     toast.success(t('giftCards.toast.generateSuccess', { balance: formatMoney(response.newBalance) }))
 207:     generateAmount.value = null
 208:     generateRemark.value = ''
 209:     await loadCards()
 210:   } catch (err: any) {
 211:     toast.error(t('giftCards.toast.generateFailed', { message: err?.message || String(err) }))
 212:   } finally {
 213:     resetTurnstile()
 214:     generating.value = false
 215:   }
 216: }
 217: 
