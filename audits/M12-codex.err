 492: export async function changeFlashSaleStatus(id: number, status: FlashSaleCampaignStatus, actorUserId: number, reason?: string) {
 493:   const existing = await prisma.flashSaleCampaign.findUnique({ where: { id } })
 494:   if (!existing) return null
 495:   const actionByStatus: Partial<Record<FlashSaleCampaignStatus, FlashSaleAuditAction>> = {
 496:     active: existing.status === 'paused' ? 'resume' : 'start',
 497:     paused: 'pause',
 498:     ended: 'finish',
 499:     cancelled: 'cancel',
 500:     scheduled: 'update',
 501:     draft: 'update'
 502:   }
 503:   const updated = await prisma.$transaction(async (tx) => {
 504:     const campaign = await tx.flashSaleCampaign.update({
 505:       where: { id },
 506:       data: { status }
 507:     })
 508:     await tx.flashSaleAuditLog.create({
 509:       data: {
 510:         campaignId: id,
 511:         actorUserId,
 512:         action: actionByStatus[status] ?? 'update',
 513:         beforeData: existing as unknown as Prisma.InputJsonValue,
 514:         afterData: campaign as unknown as Prisma.InputJsonValue,
 515:         reason
 516:       }
 517:     })
 518:     return campaign
 519:   })
 520:   return getAdminFlashSale(updated.id)
 521: }
