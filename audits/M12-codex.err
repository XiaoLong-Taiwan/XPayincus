 363:             }
 364:           }
 365:           throw error
 366:         }
 367: 
 368:         const typeName = CODE_TYPE_NAMES[codeType]?.en || codeType
 369:         const unit = CODE_TYPE_UNITS[codeType] || ''
 370:         await createLog(
 371:           user.id,
 372:           'checkin',
 373:           'redeem.success',
 374:           `Redeemed system code ${trimmedCode} for instance "${currentInstance.name}": ${typeName} +${actualAdded}${unit}`,
 375:           'success',
 376:           { instanceId }
 377:         )
 378: 
 379:         // è®°å½•åˆ°èµ„æºæ± æ—¥å¿—ï¼ˆä¸åŠ èµ„æºæ± ï¼Œå› ä¸ºèµ„æºç›´æŽ¥åº”ç”¨åˆ°å®žä¾‹ï¼‰
 380:         if (codeType !== 'p') {
 381:           await db.logSystemRedeemToInstance(
 382:             user.id,
 383:             codeType as any,
 384:             actualAdded,
 385:             instanceId,
 386:             `ç³»ç»Ÿå…‘æ¢ç  ${trimmedCode} åº”ç”¨åˆ° ${currentInstance.name}`
 387:           )
