  19: const POSITIVE_ID_RE = /^[1-9]\d*$/
  20: const CAMPAIGN_STATUSES = new Set<FlashSaleCampaignStatus>(['draft', 'scheduled', 'active', 'paused', 'ended', 'cancelled'])
  21: 
  22: function parsePositiveId(value: unknown): number | null {
  23:   if (typeof value === 'number') return Number.isSafeInteger(value) && value > 0 ? value : null
  24:   if (typeof value !== 'string' || !POSITIVE_ID_RE.test(value)) return null
  25:   const parsed = Number(value)
  26:   return Number.isSafeInteger(parsed) ? parsed : null
  27: }
  28: 
  29: function normalizeText(value: unknown, max = 200): string | null {
  30:   if (typeof value !== 'string') return null
  31:   const trimmed = value.trim()
  32:   return trimmed ? trimmed.slice(0, max) : null
  33: }
  34: 
  35: function parseOptionalDate(value: unknown): Date | undefined | null {
  36:   if (value === undefined || value === null || value === '') return undefined
  37:   if (typeof value !== 'string') return null
  38:   const parsed = new Date(value)
  39:   return Number.isNaN(parsed.getTime()) ? null : parsed
  40: }
  41: 
  42: function parseRequiredDate(value: unknown): Date | null {
  43:   const parsed = parseOptionalDate(value)
  44:   return parsed instanceof Date ? parsed : null
  45: }
  46: 
  47: function parseStatus(value: unknown): FlashSaleCampaignStatus | null | undefined {
  48:   if (value === undefined || value === null || value === '') return undefined
  49:   return typeof value === 'string' && CAMPAIGN_STATUSES.has(value as FlashSaleCampaignStatus)
  50:     ? value as FlashSaleCampaignStatus
  51:     : null
  52: }
  53: 
  54: function parseNonNegativeInteger(value: unknown, fallback = 0): number | null {
  55:   if (value === undefined || value === null || value === '') return fallback
  56:   return typeof value === 'number' && Number.isInteger(value) && value >= 0 ? value : null
  57: }
  58: 
  59: function parsePositiveInteger(value: unknown, fallback = 1): number | null {
  60:   if (value === undefined || value === null || value === '') return fallback
  61:   return typeof value === 'number' && Number.isInteger(value) && value > 0 ? value : null
  62: }
  63: 
  64: function parseMoneyCents(value: unknown): number | null {
  65:   return typeof value === 'number' && Number.isInteger(value) && value >= 0 ? value : null
  66: }
  67: 
  68: function parseOptionalMoneyCents(value: unknown): number | null | undefined {
  69:   if (value === undefined || value === null || value === '') return undefined
  70:   return parseMoneyCents(value)
  71: }
  72: 
  73: function parseOptionalNonNegativeInteger(value: unknown): number | null | undefined {
  74:   if (value === undefined || value === null || value === '') return undefined
  75:   return typeof value === 'number' && Number.isInteger(value) && value >= 0 ? value : null
  76: }
  77: 
  78: function parseOptionalPositiveInteger(value: unknown): number | null | undefined {
  79:   if (value === undefined || value === null || value === '') return undefined
  80:   return typeof value === 'number' && Number.isInteger(value) && value > 0 ? value : null
  81: }
