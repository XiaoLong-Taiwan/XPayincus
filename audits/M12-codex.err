 253:  * 
 254:  * ä½¿ç”¨æ¡ä»¶æ›´æ–°ç¡®ä¿ usedCount < maxUses æ‰èƒ½æˆåŠŸæ›´æ–°
 255:  * å¦‚æžœæ›´æ–°å½±å“0è¡Œï¼Œè¯´æ˜Žå·²è¾¾ä¸Šé™æˆ–å¹¶å‘å†²çª
 256:  * 
 257:  * @throws Error å½“å…‘æ¢ç å·²è¾¾ä¸Šé™æˆ–å¹¶å‘å†²çªæ—¶æŠ›å‡ºé”™è¯¯
 258:  */
 259: export async function useSystemRedeemCode(
 260:   redeemCodeId: number,
 261:   userId: number,
 262:   instanceId: number,
 263:   batchId: string | null
 264: ): Promise<void> {
 265:   const LOCK_RETRY_LIMIT = 10
 266:   const LOCK_RETRY_DELAY_MS = 50
 267: 
 268:   for (let attempt = 0; attempt < LOCK_RETRY_LIMIT; attempt++) {
 269:     const completed = await prisma.$transaction(async (tx) => {
 270:       const locked = await tryAdvisoryTransactionLock(tx, REDEEM_CODE_LOCK_NAMESPACE, redeemCodeId)
 271:       if (!locked) return null
 272: 
 273:       const existingUsage = await tx.redeemCodeUsage.findFirst({
 274:         where: { redeemCodeId, userId }
 275:       })
 276:       if (existingUsage) {
 277:         throw new Error('REDEEM_CODE_ALREADY_USED_BY_USER')
 278:       }
 279: 
 280:       if (batchId) {
 281:         const existingBatchUsage = await tx.redeemCodeUsage.findFirst({
 282:           where: { userId, batchId }
 283:         })
 284:         if (existingBatchUsage) {
 285:           throw new Error('REDEEM_CODE_BATCH_LIMIT')
 286:         }
 287:       }
 288: 
 289:       const result = await tx.$executeRaw`
 290:         UPDATE "redeem_codes" 
 291:         SET "used_count" = "used_count" + 1 
 292:         WHERE "id" = ${redeemCodeId} 
 293:           AND ("target_user_id" IS NULL OR "target_user_id" = ${userId})
 294:           AND "used_count" < "max_uses"
 295:       `
 296: 
 297:       if (result === 0) {
 298:         throw new Error('REDEEM_CODE_EXHAUSTED')
 299:       }
 300: 
 301:       try {
 302:         await tx.redeemCodeUsage.create({
 303:           data: {
 304:             redeemCodeId,
 305:             userId,
 306:             instanceId,
 307:             batchId
 308:           }
 309:         })
 310:       } catch (error) {
 311:         if (error instanceof Prisma.PrismaClientKnownRequestError && error.code === 'P2002' && batchId) {
 312:           throw new Error('REDEEM_CODE_BATCH_LIMIT')
 313:         }
 314:         throw error
 315:       }
 316: 
 317:       return true
 318:     })
 319: 
 320:     if (completed) {
 321:       return
 322:     }
 323: 
 324:     await new Promise(resolve => setTimeout(resolve, LOCK_RETRY_DELAY_MS * (attempt + 1)))
 325:   }
 326: 
 327:   throw new Error('REDEEM_CODE_BUSY')
 328: }
 329: 
 330: /**
 331:  * è®°å½•ç³»ç»Ÿå…‘æ¢ç åº”ç”¨ç»“æžœã€‚
 332:  *
 333:  * å¤–éƒ¨ Incus èµ„æºå˜æ›´æˆåŠŸåŽè°ƒç”¨ï¼›å…‘æ¢ç æ¶ˆè´¹ã€å®žä¾‹èµ„æºå’Œå®¿ä¸»æœºç”¨é‡å¿…é¡»åœ¨åŒä¸€äº‹åŠ¡ä¸­æäº¤ï¼Œ
 334:  * é¿å…å‡ºçŽ°å…‘æ¢ç å·²æ¶ˆè€—ä½†é¢æ¿èµ„æºçŠ¶æ€æœªè½åº“çš„åŠæˆåŠŸçŠ¶æ€ã€‚
 335:  */
 336: export async function applySystemRedeemCodeToInstance(data: {
 337:   redeemCodeId: number
 338:   userId: number
 339:   instanceId: number
 340:   hostId: number
 341:   batchId: string | null
 342:   instanceResources?: {
 343:     cpu?: number
 344:     memory?: number
 345:     disk?: number
 346:   }
 347:   hostResourceDelta?: {
 348:     cpuUsed?: number
 349:     memoryUsed?: number
 350:     diskUsed?: number
 351:   }
 352:   monthlyTrafficDelta?: bigint
 353: }): Promise<void> {
 354:   await prisma.$transaction(async (tx) => {
 355:     await advisoryTransactionLock(tx, REDEEM_CODE_LOCK_NAMESPACE, data.redeemCodeId)
 356:     await advisoryTransactionLock(tx, INSTANCE_OPERATION_LOCK_NAMESPACE, data.instanceId)
 357: 
 358:     const existingUsage = await tx.redeemCodeUsage.findFirst({
 359:       where: { redeemCodeId: data.redeemCodeId, userId: data.userId }
 360:     })
 361:     if (existingUsage) {
 362:       throw new Error('REDEEM_CODE_ALREADY_USED_BY_USER')
 363:     }
 364: 
 365:     if (data.batchId) {
 366:       const existingBatchUsage = await tx.redeemCodeUsage.findFirst({
 367:         where: { userId: data.userId, batchId: data.batchId }
 368:       })
 369:       if (existingBatchUsage) {
 370:         throw new Error('REDEEM_CODE_BATCH_LIMIT')
 371:       }
 372:     }
 373: 
 374:     const now = new Date()
 375:     const result = await tx.$executeRaw`
 376:       UPDATE "redeem_codes"
 377:       SET "used_count" = "used_count" + 1
 378:       WHERE "id" = ${data.redeemCodeId}
 379:         AND "enabled" = true
 380:         AND ("expires_at" IS NULL OR "expires_at" > ${now})
 381:         AND ("target_user_id" IS NULL OR "target_user_id" = ${data.userId})
 382:         AND "used_count" < "max_uses"
 383:     `
 384: 
 385:     if (result === 0) {
 386:       throw new Error('REDEEM_CODE_EXHAUSTED')
 387:     }
 388: 
 389:     if (data.hostResourceDelta) {
 390:       await tx.host.update({
 391:         where: { id: data.hostId },
 392:         data: {
 393:           ...(data.hostResourceDelta.cpuUsed !== undefined ? { cpuUsed: { increment: data.hostResourceDelta.cpuUsed } } : {}),
 394:           ...(data.hostResourceDelta.memoryUsed !== undefined ? { memoryUsed: { increment: data.hostResourceDelta.memoryUsed } } : {}),
 395:           ...(data.hostResourceDelta.diskUsed !== undefined ? { diskUsed: { increment: data.hostResourceDelta.diskUsed } } : {})
 396:         }
 397:       })
 398:     }
 399: 
 400:     if (data.instanceResources) {
 401:       await tx.instance.update({
 402:         where: { id: data.instanceId },
 403:         data: data.instanceResources
 404:       })
 405:     }
 406: 
 407:     if (data.monthlyTrafficDelta !== undefined) {
 408:       await tx.$executeRaw`
 409:         UPDATE "instances"
 410:         SET "monthly_traffic_limit" = COALESCE("monthly_traffic_limit", 0) + ${data.monthlyTrafficDelta}
 411:         WHERE "id" = ${data.instanceId}
 412:       `
 413:     }
 414: 
 415:     try {
 416:       await tx.redeemCodeUsage.create({
 417:         data: {
 418:           redeemCodeId: data.redeemCodeId,
 419:           userId: data.userId,
 420:           instanceId: data.instanceId,
 421:           batchId: data.batchId
 422:         }
 423:       })
 424:     } catch (error) {
 425:       if (error instanceof Prisma.PrismaClientKnownRequestError && error.code === 'P2002' && data.batchId) {
 426:         throw new Error('REDEEM_CODE_BATCH_LIMIT')
 427:       }
 428:       throw error
 429:     }
 430:   })
 431: }
