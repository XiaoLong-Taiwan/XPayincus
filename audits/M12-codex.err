 112: async function createGiftCardInTransaction(
 113:   tx: Prisma.TransactionClient,
 114:   input: GiftCardCreateInput
 115: ) {
 116:   return tx.giftCard.create({
 117:     data: {
 118:       code: generateGiftCardCode(),
 119:       faceValue: toDecimal(input.faceValue),
 120:       balanceValue: toDecimal(input.balanceValue),
 121:       createdById: input.createdById ?? null,
 122:       ownerId: input.ownerId ?? null,
 123:       expiresAt: input.expiresAt ?? null,
 124:       remark: input.remark,
 125:       batchId: input.batchId
 126:     },
 127:     select: {
 128:       id: true,
 129:       code: true,
 130:       faceValue: true,
 131:       balanceValue: true,
 132:       status: true,
 133:       expiresAt: true,
 134:       batchId: true,
 135:       createdAt: true
 136:     }
 137:   })
 138: }
 139: 
 140: export async function createGiftCard(input: GiftCardCreateInput) {
 141:   for (let attempt = 0; attempt < 3; attempt++) {
 142:     try {
 143:       const card = await prisma.$transaction((tx) => createGiftCardInTransaction(tx, input))
 144:       return serializeGiftCard(card, { revealCode: true })
 145:     } catch (error) {
 146:       if (!isUniqueConstraintError(error) || attempt === 2) throw error
 147:     }
 148:   }
 149:   throw new Error('GIFT_CARD_CODE_COLLISION')
 150: }
 151: 
 152: export async function createGiftCardBatch(
 153:   count: number,
 154:   input: Omit<GiftCardCreateInput, 'batchId'>
 155: ) {
 156:   if (!Number.isSafeInteger(count) || count < 1 || count > MAX_GIFT_CARD_BATCH_COUNT) {
 157:     throw new Error('GIFT_CARD_BATCH_TOO_LARGE')
 158:   }
 159: 
 160:   for (let attempt = 0; attempt < 3; attempt++) {
 161:     try {
 162:       return await prisma.$transaction(async (tx) => {
 163:         const batchId = generateBatchId()
 164:         const cards = []
 165:         for (let i = 0; i < count; i++) {
 166:           cards.push(await createGiftCardInTransaction(tx, { ...input, batchId }))
 167:         }
 168:         return {
 169:           codes: cards.map(card => serializeGiftCard(card, { revealCode: true })),
 170:           batchId,
 171:           count: cards.length
 172:         }
 173:       })
 174:     } catch (error) {
 175:       if (!isUniqueConstraintError(error) || attempt === 2) throw error
 176:     }
 177:   }
 178:   throw new Error('GIFT_CARD_CODE_COLLISION')
 179: }
