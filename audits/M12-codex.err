 332:             const client = await getIncusClient(host)
 333:             await patchInstanceResources(client, currentInstance.incus_id, { disk: newDisk })
 334:             patchedRollback = async () => {
 335:               await patchInstanceResources(client, currentInstance.incus_id, { disk: currentInstance.disk })
 336:             }
 337:             await db.applySystemRedeemCodeToInstance({
 338:               redeemCodeId: currentCodeRecord.id,
 339:               userId: user.id,
 340:               instanceId,
 341:               hostId: currentInstance.host_id,
 342:               batchId: currentCodeRecord.batchId,
 343:               instanceResources: { disk: newDisk },
