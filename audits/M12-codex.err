 184: export default async function flashSaleRoutes(fastify: FastifyInstance): Promise<void> {
 185:   fastify.get('/flash-sales', {
 186:     onRequest: [fastify.authenticate]
 187:   }, async () => {
 188:     return listPublicFlashSales()
 189:   })
 190: 
 191:   fastify.get<{
 192:     Querystring: { page?: string; pageSize?: string }
 193:   }>('/flash-sales/my-reservations', {
 194:     onRequest: [fastify.authenticate]
 195:   }, async (request: FastifyRequest<{ Querystring: { page?: string; pageSize?: string } }>) => {
 196:     const page = Math.max(1, Number(request.query.page || 1) || 1)
 197:     const pageSize = Math.min(100, Math.max(1, Number(request.query.pageSize || 20) || 20))
 198:     const where = { userId: request.user.id }
 199:     const [total, reservations] = await Promise.all([
 200:       prisma.flashSaleReservation.count({ where }),
 201:       prisma.flashSaleReservation.findMany({
 202:         where,
 203:         include: {
 204:           campaign: { select: { id: true, name: true } },
 205:           item: {
 206:             include: {
 207:               packagePlan: {
 208:                 include: { package: true }
 209:               }
 210:             }
 211:           },
 212:           instance: { select: { id: true, name: true, status: true } }
 213:         },
 214:         orderBy: { createdAt: 'desc' },
 215:         skip: (page - 1) * pageSize,
 216:         take: pageSize
 217:       })
 218:     ])
 219: 
 220:     return {
 221:       reservations: reservations.map((reservation) => ({
 222:         id: reservation.id,
 223:         campaignId: reservation.campaignId,
 224:         campaignName: reservation.campaign.name,
 225:         itemId: reservation.itemId,
 226:         packageName: reservation.item.packagePlan.package.name,
 227:         planName: reservation.item.packagePlan.name,
 228:         instance: reservation.instance,
 229:         status: reservation.status,
 230:         amount: Number(reservation.amount),
 231:         failureReason: reservation.failureReason,
 232:         createdAt: reservation.createdAt.toISOString(),
 233:         paidAt: reservation.paidAt?.toISOString() ?? null,
 234:         deliveredAt: reservation.deliveredAt?.toISOString() ?? null,
 235:         refundedAt: reservation.refundedAt?.toISOString() ?? null
 236:       })),
 237:       total,
 238:       page,
