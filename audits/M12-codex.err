  90: function buildCampaignInput(body: Record<string, unknown>, actorUserId: number, partial = false) {
  91:   const name = normalizeText(body.name)
  92:   const startAt = parseOptionalDate(body.startAt)
  93:   const endAt = parseOptionalDate(body.endAt)
  94:   const status = parseStatus(body.status)
  95:   const minAccountAgeHours = parseNonNegativeInteger(body.minAccountAgeHours, 0)
  96:   const maxPerUser = parsePositiveInteger(body.maxPerUser, 1)
  97: 
  98:   if (!partial && !name) {
  99:     throw new FlashSaleError('FLASH_SALE_NAME_REQUIRED', 'æ´»åŠ¨åç§°ä¸èƒ½ä¸ºç©º')
 100:   }
 101:   if (!partial && !(startAt instanceof Date)) {
 102:     throw new FlashSaleError('FLASH_SALE_START_REQUIRED', 'å¼€å§‹æ—¶é—´æ— æ•ˆ')
 103:   }
 104:   if (!partial && !(endAt instanceof Date)) {
 105:     throw new FlashSaleError('FLASH_SALE_END_REQUIRED', 'ç»“æŸæ—¶é—´æ— æ•ˆ')
 106:   }
 107:   if (status === null || minAccountAgeHours === null || maxPerUser === null) {
 108:     throw new FlashSaleError('FLASH_SALE_INVALID_PARAMS', 'æ´»åŠ¨å‚æ•°æ— æ•ˆ')
 109:   }
 110: 
 111:   const input: Record<string, unknown> = {
 112:     actorUserId
 113:   }
 114:   if (name !== null) input.name = name
 115:   if (body.description !== undefined) input.description = normalizeText(body.description, 1000)
 116:   if (status !== undefined) input.status = status
 117:   if (startAt instanceof Date) input.startAt = startAt
 118:   if (endAt instanceof Date) input.endAt = endAt
 119:   if (typeof body.requireTurnstile === 'boolean') input.requireTurnstile = body.requireTurnstile
 120:   if (minAccountAgeHours !== undefined) input.minAccountAgeHours = minAccountAgeHours
 121:   if (typeof body.requireEmail === 'boolean') input.requireEmail = body.requireEmail
 122:   if (typeof body.blockRiskRestricted === 'boolean') input.blockRiskRestricted = body.blockRiskRestricted
 123:   if (maxPerUser !== undefined) input.maxPerUser = maxPerUser
 124:   if (body.notes !== undefined) input.notes = normalizeText(body.notes, 2000)
 125:   return input
 126: }
