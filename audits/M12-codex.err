  21: import type { FastifyInstance, FastifyReply, FastifyRequest } from 'fastify'
  22: import * as giftCardDb from '../db/gift-cards.js'
  23: import { createLog } from '../db/logs.js'
  24: import { apiError, ErrorCode } from '../lib/errors.js'
  25: import { createTurnstileVerifier } from '../lib/turnstile.js'
  26: import { getCombinedAdminIdAllowlist } from '../lib/runtime-settings.js'
  27: 
  28: const turnstileRequired = createTurnstileVerifier(true)
  29: 
  30: const GIFT_CARD_CODE_REGEX = /^gc-[A-Za-z0-9_-]{24}$/
  31: const POSITIVE_ID_PATTERN = /^[1-9]\d*$/
  32: 
  33: function parsePositiveId(value: string): number | null {
  34:   if (!POSITIVE_ID_PATTERN.test(value)) return null
  35:   const parsed = Number(value)
  36:   return Number.isSafeInteger(parsed) ? parsed : null
  37: }
  38: 
  39: function parsePositiveMoney(value: unknown): number | null {
  40:   if (typeof value !== 'number' || !Number.isFinite(value) || value <= 0) return null
  41:   const normalized = Math.round(value * 100) / 100
  42:   return normalized > giftCardDb.GIFT_CARD_CONSTANTS.MAX_FACE_VALUE ? null : normalized
  43: }
  44: 
  45: function parseClampedPositiveInteger(value: unknown, fallback: number, max: number): number {
  46:   if (typeof value !== 'number' || !Number.isSafeInteger(value) || value < 1) return fallback
  47:   return Math.min(value, max)
  48: }
  49: 
  50: function normalizeOptionalString(value: unknown, maxLength: number): string | undefined {
  51:   if (value === undefined || value === null) return undefined
  52:   if (typeof value !== 'string') return undefined
  53:   const trimmed = value.trim()
  54:   if (!trimmed || trimmed.length > maxLength || /[\u0000-\u001F\u007F]/.test(trimmed)) return undefined
  55:   return trimmed
  56: }
  57: 
  58: function normalizeGiftCardCode(value: unknown): string | null {
  59:   if (typeof value !== 'string') return null
  60:   const trimmed = value.trim()
  61:   return GIFT_CARD_CODE_REGEX.test(trimmed) ? trimmed : null
  62: }
  63: 
  64: function normalizeStatus(value: unknown): 'active' | 'used' | 'disabled' | 'expired' | undefined {
  65:   return value === 'active' || value === 'used' || value === 'disabled' || value === 'expired'
  66:     ? value
  67:     : undefined
  68: }
  69: 
  70: function normalizeIdList(value: unknown): number[] | null {
  71:   if (!Array.isArray(value) || value.length === 0 || value.length > giftCardDb.GIFT_CARD_CONSTANTS.MAX_BATCH_COUNT) {
  72:     return null
  73:   }
  74:   const ids = new Set<number>()
  75:   for (const item of value) {
  76:     if (typeof item !== 'number' || !Number.isSafeInteger(item) || item <= 0 || ids.has(item)) {
  77:       return null
  78:     }
  79:     ids.add(item)
  80:   }
  81:   return Array.from(ids)
  82: }
  83: 
  84: async function requireGiftCardManager(request: FastifyRequest, reply: FastifyReply): Promise<void> {
  85:   const user = request.user
  86:   if (!user || user.role !== 'admin') {
  87:     return reply.code(403).send(apiError(ErrorCode.ADMIN_REQUIRED))
  88:   }
  89:   const { ids: allowedIds, configured } = await getCombinedAdminIdAllowlist(
  90:     'payincus_gift_card_admin_ids',
  91:     'PAYINCUS_GIFT_CARD_ADMIN_IDS'
  92:   )
  93:   const requiresAllowlist = configured || process.env.NODE_ENV === 'production'
  94:   if (requiresAllowlist && !allowedIds.has(user.id)) {
  95:     return reply.code(403).send(apiError(ErrorCode.FORBIDDEN, 'Gift card management requires gift card admin allowlist'))
  96:   }
  97: }
  98: 
  99: function mapGiftCardError(reply: FastifyReply, message: string) {
 100:   if (message === 'GIFT_CARD_NOT_FOUND') {
 101:     return reply.code(404).send(apiError(ErrorCode.GIFT_CARD_NOT_FOUND))
 102:   }
 103:   if (message === 'GIFT_CARD_USED') {
 104:     return reply.code(400).send(apiError(ErrorCode.GIFT_CARD_USED))
 105:   }
 106:   if (message === 'GIFT_CARD_ALREADY_USED_BY_USER') {
 107:     return reply.code(400).send(apiError(ErrorCode.GIFT_CARD_ALREADY_USED_BY_USER))
 108:   }
 109:   if (message === 'GIFT_CARD_SELF_REDEEM') {
 110:     return reply.code(400).send(apiError(ErrorCode.GIFT_CARD_SELF_REDEEM))
 111:   }
 112:   if (message === 'GIFT_CARD_EXPIRED') {
 113:     return reply.code(400).send(apiError(ErrorCode.GIFT_CARD_EXPIRED))
 114:   }
 115:   if (message === 'GIFT_CARD_DISABLED') {
 116:     return reply.code(400).send(apiError(ErrorCode.GIFT_CARD_DISABLED))
 117:   }
 118:   if (message === 'GIFT_CARD_INSUFFICIENT_BALANCE') {
 119:     return reply.code(400).send(apiError(ErrorCode.GIFT_CARD_INSUFFICIENT_BALANCE))
 120:   }
 121:   if (message === 'GIFT_CARD_BATCH_TOO_LARGE') {
 122:     return reply.code(400).send(apiError(ErrorCode.GIFT_CARD_BATCH_TOO_LARGE))
 123:   }
 124:   return null
 125: }
