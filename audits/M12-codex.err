   5: import crypto from 'crypto'
   6: import { Prisma, type GiftCardStatus } from '@prisma/client'
   7: import { prisma } from './prisma.js'
   8: import {
   9:   GIFT_CARD_LOCK_NAMESPACE,
  10:   USER_BALANCE_LOCK_NAMESPACE,
  11:   advisoryTransactionLock
  12: } from './advisory-locks.js'
  13: 
  14: const GIFT_CARD_RANDOM_LENGTH = 24
  15: const GIFT_CARD_CODE_PREFIX = 'gc-'
  16: const MAX_GIFT_CARD_BATCH_COUNT = 500
  17: const MAX_GIFT_CARD_REMARK_LENGTH = 200
  18: const MAX_GIFT_CARD_FACE_VALUE = 10000
  19: const MAX_GIFT_CARD_LIST_PAGE_SIZE = 100
  20: 
  21: export const GIFT_CARD_CONSTANTS = {
  22:   CODE_LENGTH: GIFT_CARD_RANDOM_LENGTH,
  23:   CODE_PREFIX: GIFT_CARD_CODE_PREFIX,
  24:   MAX_BATCH_COUNT: MAX_GIFT_CARD_BATCH_COUNT,
  25:   MAX_REMARK_LENGTH: MAX_GIFT_CARD_REMARK_LENGTH,
  26:   MAX_FACE_VALUE: MAX_GIFT_CARD_FACE_VALUE
  27: } as const
  28: 
  29: export interface GiftCardCreateInput {
  30:   faceValue: number
  31:   balanceValue: number
  32:   createdById?: number | null
  33:   ownerId?: number | null
  34:   expiresAt?: Date | null
  35:   remark?: string
  36:   batchId?: string
  37: }
  38: 
  39: export interface GiftCardAdminListOptions {
  40:   page?: number
  41:   pageSize?: number
  42:   status?: GiftCardStatus
  43:   batchId?: string
  44:   revealCode?: boolean
  45: }
  46: 
  47: export interface GiftCardUserListOptions {
  48:   page?: number
  49:   pageSize?: number
  50:   status?: GiftCardStatus
  51: }
  52: 
  53: export interface GiftCardBalanceResult {
  54:   balanceValue: number
  55:   balanceBefore: number
  56:   balanceAfter: number
  57: }
  58: 
  59: type GiftCardRedeemTransactionResult = GiftCardBalanceResult | { error: 'GIFT_CARD_EXPIRED' }
  60: 
  61: function generateGiftCardCode(): string {
  62:   const encoded = crypto.randomBytes(18).toString('base64url')
  63:   return GIFT_CARD_CODE_PREFIX + encoded.substring(0, GIFT_CARD_RANDOM_LENGTH)
  64: }
  65: 
  66: function generateBatchId(): string {
  67:   return crypto.randomBytes(8).toString('hex')
  68: }
  69: 
  70: function toMoney(value: unknown): number {
  71:   const numberValue = Number(value)
  72:   return Number.isFinite(numberValue) ? Number(numberValue.toFixed(2)) : 0
  73: }
  74: 
  75: function toDecimal(value: number): Prisma.Decimal {
  76:   return new Prisma.Decimal(value.toFixed(2))
  77: }
  78: 
  79: function clampPage(value: number | undefined): number {
  80:   return Number.isInteger(value) && value !== undefined && value > 0 ? value : 1
  81: }
  82: 
  83: function clampPageSize(value: number | undefined): number {
  84:   return Number.isInteger(value) && value !== undefined
  85:     ? Math.min(Math.max(value, 1), MAX_GIFT_CARD_LIST_PAGE_SIZE)
  86:     : 20
  87: }
  88: 
  89: function maskGiftCardCode(code: string): string {
  90:   if (code.length <= 12) return code
  91:   return `${code.slice(0, 7)}...${code.slice(-4)}`
  92: }
  93: 
  94: function isUniqueConstraintError(error: unknown): boolean {
  95:   return error instanceof Prisma.PrismaClientKnownRequestError && error.code === 'P2002'
  96: }
  97: 
  98: function serializeGiftCard<T extends { faceValue: unknown; balanceValue: unknown; code?: string }>(
  99:   record: T,
 100:   options: { revealCode?: boolean } = {}
 101: ): T & { faceValue: number; balanceValue: number; codeMasked?: string } {
 102:   const code = record.code
 103:   return {
 104:     ...record,
 105:     ...(code && !options.revealCode ? { code: maskGiftCardCode(code) } : {}),
 106:     ...(code ? { codeMasked: maskGiftCardCode(code) } : {}),
 107:     faceValue: toMoney(record.faceValue),
 108:     balanceValue: toMoney(record.balanceValue)
 109:   }
 110: }
