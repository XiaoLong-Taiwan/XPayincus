 237:     try {
 238:       const response = await withSystemRedeemLocks(systemCodeRecord.id, user.id, systemCodeRecord.batchId, async () => {
 239:         const currentCodeRecord = await db.getRedeemCodeByCode(trimmedCode)
 240:         if (!currentCodeRecord) {
 241:           throw new Error('REDEEM_CODE_NOT_FOUND')
 242:         }
 243:         if (!currentCodeRecord.enabled) {
 244:           throw new Error('REDEEM_CODE_DISABLED')
 245:         }
 246:         if (currentCodeRecord.targetUserId !== null && currentCodeRecord.targetUserId !== user.id) {
 247:           throw new Error('REDEEM_CODE_TARGET_USER_MISMATCH')
 248:         }
 249:         if (currentCodeRecord.expiresAt && currentCodeRecord.expiresAt < new Date()) {
 250:           throw new Error('REDEEM_CODE_EXPIRED')
 251:         }
 252:         if (currentCodeRecord.usedCount >= currentCodeRecord.maxUses) {
 253:           throw new Error('REDEEM_CODE_EXHAUSTED')
 254:         }
 255:         if (await db.hasUserUsedCode(currentCodeRecord.id, user.id)) {
 256:           throw new Error('REDEEM_CODE_ALREADY_USED_BY_USER')
 257:         }
 258:         if (currentCodeRecord.batchId && await db.hasUserUsedBatch(currentCodeRecord.batchId, user.id)) {
 259:           throw new Error('REDEEM_CODE_BATCH_LIMIT')
 260:         }
 261: 
 262:         const currentInstance = await db.getInstanceById(instanceId)
 263:         if (!currentInstance) {
 264:           throw new Error('INSTANCE_NOT_FOUND')
 265:         }
 266:         if (currentInstance.user_id !== user.id) {
 267:           throw new Error('FORBIDDEN')
 268:         }
 269:         if (currentInstance.status !== 'running' && currentInstance.status !== 'stopped') {
 270:           throw new Error('INSTANCE_STATUS_INVALID')
