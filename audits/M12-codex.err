 139: /**
 140:  * èŽ·å–å®¿ä¸»æœºçš„å…‘æ¢ç åˆ—è¡¨
 141:  */
 142: export async function getRedeemCodesByHost(
 143:   hostId: number,
 144:   options: {
 145:     limit?: number
 146:     offset?: number
 147:     enabled?: boolean
 148:   } = {}
 149: ) {
 150:   const { limit, offset } = clampRedeemCodeListBounds(options.limit, options.offset, 50)
 151:   const { enabled } = options
 152: 
 153:   const where = {
 154:     hostId,
 155:     ...(enabled !== undefined ? { enabled } : {})
 156:   }
 157: 
 158:   const [codes, total] = await Promise.all([
 159:     prisma.redeemCode.findMany({
 160:       where,
 161:       orderBy: { createdAt: 'desc' },
 162:       take: limit,
 163:       skip: offset,
 164:       include: {
 165:         createdBy: {
 166:           select: { id: true, username: true }
 167:         },
 168:         _count: {
 169:           select: { usages: true }
 170:         }
 171:       }
 172:     }),
 173:     prisma.redeemCode.count({ where })
 174:   ])
 175: 
 176:   return {
 177:     codes: codes.map(c => ({
 178:       id: c.id,
 179:       code: c.code,
 180:       codeType: c.codeType,
 181:       codeValue: c.codeValue,
 182:       maxUses: c.maxUses,
 183:       usedCount: c.usedCount,
 184:       expiresAt: c.expiresAt?.toISOString() ?? null,
 185:       enabled: c.enabled,
 186:       remark: c.remark,
 187:       batchId: c.batchId,
 188:       targetUserId: c.targetUserId,
 189:       createdBy: c.createdBy,
 190:       createdAt: c.createdAt.toISOString(),
 191:       isExpired: c.expiresAt ? c.expiresAt < new Date() : false,
 192:       isExhausted: c.usedCount >= c.maxUses
 193:     })),
 194:     total
 195:   }
 196: }
