   6: import type { FastifyInstance } from 'fastify'
   7: import * as db from '../db/index.js'
   8: import { createLog } from '../db/logs.js'
   9: import { apiError, ErrorCode } from '../lib/errors.js'
  10: import type { RedeemCodeType } from '@prisma/client'
  11: 
  12: const REDEEM_CODE_TYPES: RedeemCodeType[] = ['c', 'r', 'd', 't']
  13: const MAX_REDEEM_CODE_BATCH_COUNT = 100
  14: const MAX_REDEEM_CODE_MAX_USES = 1000
  15: const MAX_REDEEM_CODE_REMARK_LENGTH = 200
  16: 
  17: // èµ„æºç±»åž‹åç§°æ˜ å°„
  18: const CODE_TYPE_NAMES: Record<string, string> = {
  19:   c: 'CPU',
  20:   r: 'Memory',
  21:   d: 'Disk',
  22:   t: 'Traffic'
  23: }
  24: 
  25: // èµ„æºå•ä½æ˜ å°„
  26: const CODE_TYPE_UNITS: Record<string, string> = {
  27:   c: '%',
  28:   r: 'MB',
  29:   d: 'MB',
  30:   t: 'GB'
  31: }
  32: 
  33: function parsePositiveId(value: string): number | null {
  34:   if (!/^\d+$/.test(value)) {
  35:     return null
  36:   }
  37: 
  38:   const parsed = Number(value)
  39:   return Number.isSafeInteger(parsed) && parsed > 0 ? parsed : null
  40: }
  41: 
  42: function normalizePositiveUniqueIds(values: unknown[]): number[] | null {
  43:   const ids = new Set<number>()
  44: 
  45:   for (const value of values) {
  46:     if (typeof value !== 'number' || !Number.isSafeInteger(value) || value <= 0 || ids.has(value)) {
  47:       return null
  48:     }
  49:     ids.add(value)
  50:   }
  51: 
  52:   return Array.from(ids)
  53: }
  54: 
  55: function isPlainRecord(value: unknown): value is Record<string, unknown> {
  56:   return typeof value === 'object' && value !== null && !Array.isArray(value)
  57: }
  58: 
  59: function requireRedeemCodeInteger(value: unknown, field: string, min: number, max: number): number {
  60:   if (typeof value !== 'number' || !Number.isSafeInteger(value)) {
  61:     throw apiError(ErrorCode.INVALID_PARAMS, `${field} must be an integer`)
  62:   }
  63:   if (value < min || value > max) {
  64:     throw apiError(ErrorCode.INVALID_PARAMS, `${field} must be between ${min} and ${max}`)
  65:   }
  66:   return value
  67: }
  68: 
  69: function normalizeRedeemCodeType(value: unknown): RedeemCodeType {
  70:   if (typeof value !== 'string' || !REDEEM_CODE_TYPES.includes(value as RedeemCodeType)) {
  71:     throw apiError(ErrorCode.INVALID_PARAMS, 'Invalid redeem code type')
  72:   }
  73:   return value as RedeemCodeType
  74: }
  75: 
  76: function normalizeOptionalRedeemCodeRemark(value: unknown): string | undefined {
  77:   if (value === undefined) return undefined
  78:   if (typeof value !== 'string') {
  79:     throw apiError(ErrorCode.INVALID_PARAMS, 'Invalid remark')
  80:   }
  81:   const trimmed = value.trim()
  82:   if (trimmed.length > MAX_REDEEM_CODE_REMARK_LENGTH || /[\u0000-\u001F\u007F]/.test(trimmed)) {
  83:     throw apiError(ErrorCode.INVALID_PARAMS, 'Invalid remark')
  84:   }
  85:   return trimmed || undefined
  86: }
  87: 
  88: function normalizeOptionalExpiryDate(value: string | null | undefined): Date | null | undefined {
  89:   if (value === undefined) {
  90:     return undefined
  91:   }
  92:   if (value === null || value.trim() === '') {
  93:     return null
  94:   }
  95: 
  96:   const date = new Date(value)
  97:   return Number.isNaN(date.getTime()) ? undefined : date
  98: }
  99: 
 100: function normalizeRedeemCodeCreateBody(input: unknown): {
 101:   codeType: RedeemCodeType
 102:   codeValue: number
 103:   maxUses?: number
 104:   expiresAt?: string | null
 105:   remark?: string
 106:   batchCount?: number
 107: } {
 108:   if (!isPlainRecord(input)) {
 109:     throw apiError(ErrorCode.INVALID_PARAMS, 'Invalid request body')
 110:   }
 111: 
 112:   const codeType = normalizeRedeemCodeType(input.codeType)
 113:   const codeValueRange = db.CODE_VALUE_RANGES[codeType]
 114:   const codeValue = requireRedeemCodeInteger(input.codeValue, 'codeValue', codeValueRange.min, codeValueRange.max)
 115:   const maxUses = input.maxUses === undefined
 116:     ? undefined
 117:     : requireRedeemCodeInteger(input.maxUses, 'maxUses', 1, MAX_REDEEM_CODE_MAX_USES)
 118:   const batchCount = input.batchCount === undefined
 119:     ? undefined
 120:     : requireRedeemCodeInteger(input.batchCount, 'batchCount', 1, MAX_REDEEM_CODE_BATCH_COUNT)
 121:   if (input.expiresAt !== undefined && input.expiresAt !== null && typeof input.expiresAt !== 'string') {
 122:     throw apiError(ErrorCode.INVALID_PARAMS, 'Invalid expiry date')
 123:   }
 124: 
 125:   return {
 126:     codeType,
 127:     codeValue,
 128:     maxUses,
 129:     expiresAt: input.expiresAt as string | null | undefined,
 130:     remark: normalizeOptionalRedeemCodeRemark(input.remark),
 131:     batchCount
 132:   }
 133: }
 134: 
 135: function normalizeRedeemCodeUpdateBody(input: unknown): {
 136:   enabled?: boolean
 137:   remark?: string
 138:   maxUses?: number
 139:   expiresAt?: string | null
 140: } {
 141:   if (!isPlainRecord(input)) {
 142:     throw apiError(ErrorCode.INVALID_PARAMS, 'Invalid request body')
 143:   }
 144: 
 145:   if (input.enabled !== undefined && typeof input.enabled !== 'boolean') {
 146:     throw apiError(ErrorCode.INVALID_PARAMS, 'enabled must be a boolean')
 147:   }
 148:   if (input.expiresAt !== undefined && input.expiresAt !== null && typeof input.expiresAt !== 'string') {
 149:     throw apiError(ErrorCode.INVALID_PARAMS, 'Invalid expiry date')
 150:   }
 151: 
 152:   return {
 153:     enabled: input.enabled as boolean | undefined,
 154:     remark: normalizeOptionalRedeemCodeRemark(input.remark),
 155:     maxUses: input.maxUses === undefined
 156:       ? undefined
 157:       : requireRedeemCodeInteger(input.maxUses, 'maxUses', 1, MAX_REDEEM_CODE_MAX_USES),
 158:     expiresAt: input.expiresAt as string | null | undefined
 159:   }
 160: }
 161: 
 162: function normalizeRedeemCodeBatchDeleteBody(input: unknown): number[] | null {
 163:   if (!isPlainRecord(input) || !Array.isArray(input.ids) || input.ids.length === 0 || input.ids.length > 100) {
 164:     return null
 165:   }
 166:   return normalizePositiveUniqueIds(input.ids)
 167: }
