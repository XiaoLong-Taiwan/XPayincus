 181: export async function generateGiftCardFromBalance(input: {
 182:   userId: number
 183:   faceValue: number
 184:   remark?: string
 185: }) {
 186:   for (let attempt = 0; attempt < 3; attempt++) {
 187:     try {
 188:       return await prisma.$transaction(async (tx) => {
 189:         await advisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, input.userId)
 190: 
 191:         const user = await tx.user.findUnique({
 192:           where: { id: input.userId },
 193:           select: { balance: true }
 194:         })
 195:         if (!user) throw new Error('USER_NOT_FOUND')
 196: 
 197:         const balanceBefore = toMoney(user.balance)
 198:         const amount = toMoney(input.faceValue)
 199:         const updateResult = await tx.user.updateMany({
 200:           where: { id: input.userId, balance: { gte: amount } },
 201:           data: { balance: { decrement: toDecimal(amount) } }
 202:         })
 203:         if (updateResult.count !== 1) {
 204:           throw new Error('GIFT_CARD_INSUFFICIENT_BALANCE')
 205:         }
 206: 
 207:         const updatedUser = await tx.user.findUnique({
 208:           where: { id: input.userId },
 209:           select: { balance: true }
 210:         })
 211:         if (!updatedUser) throw new Error('USER_NOT_FOUND')
 212: 
 213:         const balanceAfter = toMoney(updatedUser.balance)
 214:         const balanceLog = await tx.balanceLog.create({
 215:           data: {
 216:             // ç¤¼å“å¡æ˜¯ä¿å€¼å‡­è¯ï¼ˆå¯è½¬èµ /ä»–è´¦å…‘æ¢ï¼‰ï¼Œå‘è¡Œæ‰£æ¬¾ä¸æ˜¯çœŸå®žæœåŠ¡æ¶ˆè´¹ï¼Œ
 217:             // å¿…é¡»ç”¨ç‹¬ç«‹ç±»åž‹ï¼Œé¿å…è¢« getUsersTotalConsumeMap è®¡å…¥å¯å…‘æ¢ç§¯åˆ†çš„æ¶ˆè´¹é¢è€Œè¢«åˆ·åˆ†ã€‚
 218:             userId: input.userId,
 219:             type: 'gift_card_issue',
 220:             amount: toDecimal(-amount),
 221:             balanceBefore: toDecimal(balanceBefore),
 222:             balanceAfter: toDecimal(balanceAfter),
 223:             remark: input.remark || 'ç”Ÿæˆç¤¼å“å¡'
 224:           }
 225:         })
 226: 
 227:         const giftCard = await createGiftCardInTransaction(tx, {
 228:           faceValue: amount,
 229:           balanceValue: amount,
 230:           createdById: input.userId,
 231:           ownerId: input.userId,
 232:           remark: input.remark || 'ç”¨æˆ·ä½™é¢ç”Ÿæˆç¤¼å“å¡'
 233:         })
 234: 
 235:         return {
 236:           giftCard: serializeGiftCard(giftCard, { revealCode: true }),
 237:           balanceLog,
 238:           balanceBefore,
 239:           balanceAfter
 240:         }
 241:       })
 242:     } catch (error) {
 243:       if (!isUniqueConstraintError(error) || attempt === 2) throw error
 244:     }
 245:   }
 246:   throw new Error('GIFT_CARD_CODE_COLLISION')
 247: }
