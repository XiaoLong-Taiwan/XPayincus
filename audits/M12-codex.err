 127: export default async function giftCardsRoutes(fastify: FastifyInstance) {
 128:   // ==================== ç®¡ç†å‘˜ ====================
 129: 
 130:   // ç”Ÿæˆå•ä¸ªå…‘æ¢ç 
 131:   fastify.post('/admin/generate', {
 132:     onRequest: [fastify.authenticate, fastify.requireAdmin, requireGiftCardManager],
 133:     config: { rateLimit: { max: 30, timeWindow: '1 minute' } },
 134:     schema: {
 135:       body: {
 136:         type: 'object',
 137:         required: ['faceValue'],
 138:         properties: {
 139:           faceValue: { type: 'number', minimum: 0.01, maximum: 10000 },
 140:           balanceValue: { type: 'number', minimum: 0.01, maximum: 10000 },
 141:           expiresAt: { type: ['string', 'null'] },
 142:           remark: { type: 'string', maxLength: 200 }
 143:         }
 144:       }
 145:     }
 146:   }, async (request, reply) => {
 147:     const { user } = request
 148:     const body = request.body as Record<string, unknown>
 149: 
 150:     const faceValue = parsePositiveMoney(body.faceValue)
 151:     if (faceValue === null) {
 152:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid face value'))
 153:     }
 154: 
 155:     const balanceValue = body.balanceValue !== undefined
 156:       ? parsePositiveMoney(body.balanceValue)
 157:       : faceValue
 158:     if (balanceValue === null) {
 159:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid balance value'))
 160:     }
 161: 
 162:     const expiresAtRaw = normalizeOptionalString(body.expiresAt, 64)
 163:     let expiresAt: Date | null = null
 164:     if (expiresAtRaw) {
 165:       const d = new Date(expiresAtRaw)
 166:       if (Number.isNaN(d.getTime())) {
 167:         return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid expiry date'))
 168:       }
 169:       expiresAt = d
 170:     }
 171: 
 172:     const remark = normalizeOptionalString(body.remark, 200)
 173: 
 174:     try {
 175:       const giftCard = await giftCardDb.createGiftCard({
 176:         faceValue,
 177:         balanceValue: balanceValue ?? faceValue,
 178:         createdById: user.id,
 179:         expiresAt,
 180:         remark
 181:       })
 182: 
 183:       await createLog(user.id, 'gift_card', 'admin_generate',
 184:         `Generated gift card ${giftCard.code.substring(0, 10)}..., face=${faceValue} balance=${balanceValue ?? faceValue}`,
 185:         'success')
 186: 
 187:       return reply.code(201).send({ giftCard })
 188:     } catch (err) {
 189:       const msg = err instanceof Error ? err.message : String(err)
 190:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, msg))
 191:     }
 192:   })
 193: 
 194:   // æ‰¹é‡ç”Ÿæˆå…‘æ¢ç 
 195:   fastify.post('/admin/batch', {
 196:     onRequest: [fastify.authenticate, fastify.requireAdmin, requireGiftCardManager],
 197:     config: { rateLimit: { max: 5, timeWindow: '1 minute' } },
 198:     schema: {
 199:       body: {
 200:         type: 'object',
 201:         required: ['faceValue', 'count'],
 202:         properties: {
 203:           faceValue: { type: 'number', minimum: 0.01, maximum: 10000 },
 204:           balanceValue: { type: 'number', minimum: 0.01, maximum: 10000 },
 205:           count: { type: 'integer', minimum: 1, maximum: 500 },
 206:           expiresAt: { type: ['string', 'null'] },
 207:           remark: { type: 'string', maxLength: 200 }
 208:         }
 209:       }
 210:     }
 211:   }, async (request, reply) => {
 212:     const { user } = request
 213:     const body = request.body as Record<string, unknown>
 214: 
 215:     const faceValue = parsePositiveMoney(body.faceValue)
 216:     if (faceValue === null) {
 217:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid face value'))
 218:     }
 219: 
 220:     const balanceValue = body.balanceValue !== undefined
 221:       ? parsePositiveMoney(body.balanceValue)
 222:       : faceValue
 223:     if (balanceValue === null) {
 224:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid balance value'))
 225:     }
 226: 
 227:     const count = parseClampedPositiveInteger(body.count, 1, giftCardDb.GIFT_CARD_CONSTANTS.MAX_BATCH_COUNT)
 228: 
 229:     const expiresAtRaw = normalizeOptionalString(body.expiresAt, 64)
 230:     let expiresAt: Date | null = null
 231:     if (expiresAtRaw) {
 232:       const d = new Date(expiresAtRaw)
 233:       if (Number.isNaN(d.getTime())) {
 234:         return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid expiry date'))
 235:       }
 236:       expiresAt = d
 237:     }
 238: 
 239:     const remark = normalizeOptionalString(body.remark, 200)
 240: 
 241:     try {
 242:       const result = await giftCardDb.createGiftCardBatch(count, {
 243:         faceValue,
 244:         balanceValue: balanceValue ?? faceValue,
 245:         createdById: user.id,
 246:         expiresAt,
 247:         remark
 248:       })
 249: 
 250:       await createLog(user.id, 'gift_card', 'admin_batch_generate',
 251:         `Batch generated ${result.count} gift cards (${result.batchId}), face=${faceValue}`,
 252:         'success')
 253: 
 254:       return reply.code(201).send({
 255:         batchId: result.batchId,
 256:         count: result.count,
 257:         codes: result.codes.map(c => ({
 258:           id: c.id,
 259:           code: c.code,
 260:           faceValue: Number(c.faceValue),
 261:           balanceValue: Number(c.balanceValue)
 262:         }))
 263:       })
 264:     } catch (err) {
 265:       const msg = err instanceof Error ? err.message : String(err)
 266:       return reply.code(500).send(apiError(ErrorCode.INTERNAL_ERROR, msg))
 267:     }
 268:   })
 269: 
 270:   // ç®¡ç†å‘˜åˆ—è¡¨
 271:   fastify.get('/admin/list', {
 272:     onRequest: [fastify.authenticate, fastify.requireAdmin, requireGiftCardManager],
 273:     config: { rateLimit: { max: 60, timeWindow: '1 minute' } },
 274:     schema: {
 275:       querystring: {
 276:         type: 'object',
 277:         properties: {
 278:           page: { type: 'integer', minimum: 1, default: 1 },
 279:           pageSize: { type: 'integer', minimum: 1, maximum: 100, default: 20 },
 280:           status: { type: 'string', enum: ['active', 'used', 'disabled', 'expired'] },
 281:           batchId: { type: 'string' },
 282:           revealCode: { type: 'boolean', default: false }
 283:         }
 284:       }
 285:     }
 286:   }, async (request) => {
 287:     const query = request.query as Record<string, unknown>
 288:     return giftCardDb.listGiftCardsByAdmin({
 289:       page: parseClampedPositiveInteger(query.page, 1, 999999),
 290:       pageSize: parseClampedPositiveInteger(query.pageSize, 20, 100),
 291:       status: normalizeStatus(query.status),
 292:       batchId: normalizeOptionalString(query.batchId, 64),
 293:       revealCode: query.revealCode === true
 294:     })
 295:   })
 296: 
 297:   // ç®¡ç†å‘˜ç»Ÿè®¡
 298:   fastify.get('/admin/stats', {
 299:     onRequest: [fastify.authenticate, fastify.requireAdmin, requireGiftCardManager]
 300:   }, async () => {
 301:     return giftCardDb.getGiftCardStats()
 302:   })
 303: 
 304:   // å¯ç”¨å…‘æ¢ç 
 305:   fastify.patch('/admin/:id/enable', {
 306:     onRequest: [fastify.authenticate, fastify.requireAdmin, requireGiftCardManager],
 307:     config: { rateLimit: { max: 30, timeWindow: '1 minute' } }
 308:   }, async (request, reply) => {
 309:     const id = parsePositiveId((request.params as { id: string }).id)
 310:     if (id === null) return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 311: 
 312:     const result = await giftCardDb.enableGiftCard(id)
 313:     if (result.count === 0) return reply.code(404).send(apiError(ErrorCode.GIFT_CARD_NOT_FOUND))
 314:     return { success: true }
 315:   })
 316: 
 317:   // ç¦ç”¨å…‘æ¢ç 
 318:   fastify.patch('/admin/:id/disable', {
 319:     onRequest: [fastify.authenticate, fastify.requireAdmin, requireGiftCardManager],
 320:     config: { rateLimit: { max: 30, timeWindow: '1 minute' } }
 321:   }, async (request, reply) => {
 322:     const id = parsePositiveId((request.params as { id: string }).id)
