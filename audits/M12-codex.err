 296: export async function redeemGiftCard(code: string, userId: number): Promise<GiftCardBalanceResult> {
 297:   const result = await prisma.$transaction(async (tx): Promise<GiftCardRedeemTransactionResult> => {
 298:     const initialGiftCard = await tx.giftCard.findUnique({
 299:       where: { code },
 300:       select: { id: true }
 301:     })
 302:     if (!initialGiftCard) {
 303:       throw new Error('GIFT_CARD_NOT_FOUND')
 304:     }
 305: 
 306:     await advisoryTransactionLock(tx, GIFT_CARD_LOCK_NAMESPACE, initialGiftCard.id)
 307:     await advisoryTransactionLock(tx, USER_BALANCE_LOCK_NAMESPACE, userId)
 308: 
 309:     const giftCard = await tx.giftCard.findUnique({
 310:       where: { id: initialGiftCard.id },
 311:       select: {
 312:         id: true,
 313:         code: true,
 314:         status: true,
 315:         balanceValue: true,
 316:         expiresAt: true,
 317:         ownerId: true
 318:       }
 319:     })
 320: 
 321:     if (!giftCard) {
 322:       throw new Error('GIFT_CARD_NOT_FOUND')
 323:     }
 324:     if (giftCard.status !== 'active') {
 325:       throw new Error(giftCard.status === 'used' ? 'GIFT_CARD_USED' : 'GIFT_CARD_DISABLED')
 326:     }
 327:     if (giftCard.ownerId === userId) {
 328:       throw new Error('GIFT_CARD_SELF_REDEEM')
 329:     }
 330:     if (giftCard.expiresAt && giftCard.expiresAt < new Date()) {
 331:       const expired = await tx.giftCard.updateMany({
 332:         where: { id: giftCard.id, status: 'active' },
 333:         data: { status: 'expired' }
 334:       })
 335:       if (expired.count === 0) {
 336:         throw new Error('GIFT_CARD_USED')
 337:       }
 338:       return { error: 'GIFT_CARD_EXPIRED' }
 339:     }
 340: 
 341:     const user = await tx.user.findUnique({
 342:       where: { id: userId },
 343:       select: { balance: true }
 344:     })
 345:     if (!user) throw new Error('USER_NOT_FOUND')
 346: 
 347:     const amount = toMoney(giftCard.balanceValue)
 348:     const balanceBefore = toMoney(user.balance)
 349:     const updated = await tx.giftCard.updateMany({
 350:       where: { id: giftCard.id, status: 'active' },
 351:       data: { status: 'used', usedById: userId, usedAt: new Date() }
 352:     })
 353:     if (updated.count !== 1) {
 354:       throw new Error('GIFT_CARD_USED')
 355:     }
 356: 
 357:     const updatedUser = await tx.user.update({
 358:       where: { id: userId },
 359:       data: { balance: { increment: toDecimal(amount) } },
 360:       select: { balance: true }
 361:     })
 362:     const balanceAfter = toMoney(updatedUser.balance)
 363: 
 364:     await tx.balanceLog.create({
 365:       data: {
 366:         userId,
 367:         type: 'gift',
 368:         amount: toDecimal(amount),
 369:         balanceBefore: toDecimal(balanceBefore),
 370:         balanceAfter: toDecimal(balanceAfter),
 371:         remark: `ç¤¼å“å¡å…‘æ¢ï¼š${maskGiftCardCode(giftCard.code)}`
 372:       }
 373:     })
 374: 
 375:     return { balanceValue: amount, balanceBefore, balanceAfter }
 376:   })
 377: 
 378:   if ('error' in result) {
 379:     throw new Error(result.error)
 380:   }
 381: 
 382:   return result
 383: }
