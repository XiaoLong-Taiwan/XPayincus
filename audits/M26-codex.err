 1789:   // 套餐管理
 1790:   packages: {
 1791:     // 公开 API（无需登录）
 1792:     listPublic: (options?: { source?: 'official' | 'market' }): Promise<{ packages: Package[]; total: number }> => {
 1793:       const params = new URLSearchParams()
 1794:       if (options?.source) params.append('source', options.source)
 1795:       const queryString = params.toString()
 1796:       return http.get(queryString ? `/packages/public?${queryString}` : '/packages/public')
 1797:     },
 1798:     getPublicRegions: (options?: { source?: 'official' | 'market' }): Promise<{
 1799:       regions: Array<{
 1800:         code: string
 1801:         name: string
 1802:         packageIds: number[]
 1803:         hostCount: number
 1804:       }>
 1805:     }> => {
 1806:       const params = new URLSearchParams()
 1807:       if (options?.source) params.append('source', options.source)
 1808:       const queryString = params.toString()
 1809:       return http.get(queryString ? `/packages/public/regions?${queryString}` : '/packages/public/regions')
 1810:     },
 1811:     // 需要登录的 API
 1812:     list: (options?: { all?: boolean; source?: 'official' | 'market' | 'friends' | 'zone'; zoneId?: number; scope?: 'mine' | 'official' | 'hosted' }): Promise<{ packages: Package[]; total: number }> => {
 1813:       const params = new URLSearchParams()
 1814:       if (options?.all) params.append('all', 'true')
 1815:       if (options?.source) params.append('source', options.source)
 1816:       if (options?.zoneId) params.append('zoneId', String(options.zoneId))
 1817:       if (options?.scope) params.append('scope', options.scope)
 1818:       const queryString = params.toString()
 1819:       return http.get(queryString ? `/packages?${queryString}` : '/packages')
 1820:     },
 1821:     getHostingZones: (): Promise<{
 1822:       zones: Array<{
 1823:         id: number
 1824:         name: string
 1825:         ownerId: number
 1826:         ownerUsername: string
 1827:         logoUrl: string
 1828:         sortOrder: number
 1829:       }>
 1830:     }> => http.get('/packages/hosting-zones'),
 1831:     // 管理员专用：获取托管套餐列表
 1832:     listHosted: (params: { userId?: number } = {}): Promise<{ packages: Package[] }> =>
 1833:       http.get('/packages', { params: { ...params, scope: 'hosted' } }),
 1834:     get: (id: number): Promise<Package> => http.get(`/packages/${id}`),
 1835:     create: (data: CreatePackageRequest): Promise<Package> => http.post('/packages', data),
 1836:     update: (id: number, data: UpdatePackageRequest): Promise<Package> =>
 1837:       http.patch(`/packages/${id}`, data),
 1838:     delete: (id: number): Promise<void> => http.delete(`/packages/${id}`),
