    1: import { computed, ref, shallowRef } from 'vue'
    2: import { defineStore } from 'pinia'
    3: import api from '@/api'
    4: import { isAdminEntry } from '@/utils/app-paths'
    5: import type { BadgeCatalogItem, BadgeSeriesItem } from '@/types/api'
    6: 
    7: interface AdminBadgeCatalogApi {
    8:   entertainment: {
    9:     adminGetBadgeCatalog: () => Promise<{
   10:       series: BadgeSeriesItem[]
   11:       badges: BadgeCatalogItem[]
   12:     }>
   13:   }
   14: }
   15: 
   16: export const useBadgeStore = defineStore('badges', () => {
   17:   const series = ref<BadgeSeriesItem[]>([])
   18:   const badges = ref<BadgeCatalogItem[]>([])
   19:   const loaded = ref(false)
   20:   const loading = ref(false)
   21:   const loadingPromise = shallowRef<Promise<void> | null>(null)
   22:   const missingReloads = new Set<string>()
   23: 
   24:   const badgeMap = computed(() => new Map(badges.value.map(badge => [badge.id, badge])))
   25: 
   26:   async function loadCatalog(force = false) {
   27:     if (loading.value && loadingPromise.value) return loadingPromise.value
   28:     if (loaded.value && !force) return
   29: 
   30:     loading.value = true
   31:     loadingPromise.value = (async () => {
   32:       try {
   33:         const res = isAdminEntry
   34:           ? await (api as typeof api & AdminBadgeCatalogApi).entertainment.adminGetBadgeCatalog()
   35:           : await api.entertainment.getBadgeCatalog()
   36:         series.value = res.series || []
   37:         badges.value = res.badges || []
   38:         loaded.value = true
   39:       } catch (error) {
   40:         console.warn('Failed to load badge catalog:', error)
   41:       } finally {
   42:         loading.value = false
   43:         loadingPromise.value = null
   44:       }
   45:     })()
   46: 
   47:     return loadingPromise.value
   48:   }
   49: 
   50:   function getBadge(id: string | null | undefined): BadgeCatalogItem | null {
   51:     if (!id) return null
   52:     return badgeMap.value.get(id) || null
   53:   }
   54: 
   55:   async function ensureBadge(id: string | null | undefined) {
   56:     if (!id) return
   57:     await loadCatalog()
   58:     if (!getBadge(id) && !missingReloads.has(id)) {
   59:       missingReloads.add(id)
   60:       await loadCatalog(true)
   61:     }
   62:   }
   63: 
   64:   return {
   65:     series,
   66:     badges,
   67:     loaded,
   68:     loading,
   69:     badgeMap,
   70:     loadCatalog,
   71:     ensureBadge,
   72:     getBadge
   73:   }
   74: })
FILE client/src/stores/inbox.ts
    1: /**
    2:  * 站内信状态管理
    3:  */
    4: 
    5: import { defineStore } from 'pinia'
    6: import { ref } from 'vue'
    7: import api from '@/api'
    8: 
    9: export const useInboxStore = defineStore('inbox', () => {
   10:   // 未读消息数量
   11:   const unreadCount = ref(0)
   12:   
   13:   // 轮询定时器
   14:   let pollTimer: number | null = null
   15:   
   16:   // 是否已初始化
   17:   const initialized = ref(false)
   18: 
   19:   /**
   20:    * 获取未读消息数量
   21:    */
   22:   async function fetchUnreadCount(): Promise<void> {
   23:     try {
   24:       const res = await api.inbox.getUnreadCount()
   25:       unreadCount.value = res.count
   26:     } catch {
   27:       // 静默失败，不影响用户体验
   28:     }
   29:   }
   30: 
   31:   /**
   32:    * 启动轮询（登录后调用）
   33:    */
   34:   function startPolling(): void {
   35:     if (initialized.value) return
   36:     
   37:     initialized.value = true
   38:     fetchUnreadCount() // 立即获取一次
   39:     
   40:     // 每 15 秒轮询一次
   41:     pollTimer = window.setInterval(fetchUnreadCount, 15000)
   42:     
   43:     // 监听页面可见性变化
   44:     document.addEventListener('visibilitychange', handleVisibilityChange)
   45:   }
   46: 
   47:   /**
   48:    * 停止轮询（登出时调用）
   49:    */
   50:   function stopPolling(): void {
   51:     if (pollTimer) {
   52:       clearInterval(pollTimer)
   53:       pollTimer = null
   54:     }
   55:     document.removeEventListener('visibilitychange', handleVisibilityChange)
   56:     initialized.value = false
   57:     unreadCount.value = 0
   58:   }
   59: 
   60:   /**
   61:    * 主动刷新（用户操作后调用）
   62:    */
   63:   function refresh(): void {
   64:     fetchUnreadCount()
   65:   }
   66: 
   67:   /**
   68:    * 页面可见性变化时刷新
   69:    */
   70:   function handleVisibilityChange(): void {
   71:     if (document.visibilityState === 'visible') {
   72:       refresh()
   73:     }
   74:   }
   75: 
   76:   /**
   77:    * 减少未读数量（标记已读后调用）
   78:    */
   79:   function decrementUnread(count: number = 1): void {
   80:     unreadCount.value = Math.max(0, unreadCount.value - count)
   81:   }
   82: 
   83:   /**
   84:    * 清零未读数量（全部标记已读后调用）
   85:    */
   86:   function clearUnread(): void {
   87:     unreadCount.value = 0
   88:   }
   89: 
   90:   return {
   91:     unreadCount,
   92:     initialized,
   93:     fetchUnreadCount,
   94:     startPolling,
   95:     stopPolling,
   96:     refresh,
   97:     decrementUnread,
   98:     clearUnread
   99:   }
  100: })
FILE client/src/stores/restoreTask.ts
    1: /**
    2:  * 全局恢复任务状态管理
    3:  * 用于在页面切换时保持恢复任务的轮询状态
    4:  */
    5: import { ref, type Ref } from 'vue'
    6: import api from '@/api'
    7: import { useToast } from './toast'
    8: 
    9: export type RestoreTaskStatus =
   10:     | 'idle'
   11:     | 'pending'
   12:     | 'processing'
   13:     | 'stopping'
   14:     | 'restoring'
   15:     | 'replacing'
   16:     | 'completed'
   17:     | 'failed'
   18:     | 'rolled_back'
   19: 
   20: export interface RestoreTask {
   21:     instanceId: number
   22:     backupId: number
   23:     backupName: string
   24:     taskId: string
   25:     status: RestoreTaskStatus
   26:     error?: string
   27:     notificationId: number | null
   28:     queuePosition?: number
   29:     duration?: number | null
   30:     createdAt?: string
   31:     startedAt?: string | null
   32:     finishedAt?: string | null
   33: }
   34: 
   35: // 全局状态 - 在模块级别定义，所有组件共享
   36: const activeTask: Ref<RestoreTask | null> = ref(null)
   37: let pollInterval: ReturnType<typeof setInterval> | null = null
   38: 
   39: export function useRestoreTask() {
   40:     const toast = useToast()
   41: 
   42:     /**
   43:      * 开始恢复任务
   44:      */
   45:     async function startRestore(
   46:         instanceId: number,
   47:         backupId: number,
   48:         backupName: string,
   49:         t: (key: string, params?: Record<string, unknown>) => string
   50:     ): Promise<boolean> {
   51:         // 检查是否已有进行中的任务
   52:         if (activeTask.value && !['completed', 'failed', 'rolled_back', 'idle'].includes(activeTask.value.status)) {
   53:             toast.warning(t('backup.messages.restoreInProgress'))
   54:             return false
   55:         }
   56: 
   57:         try {
   58:             const res = await api.instances.restoreBackup(instanceId, backupId)
   59: 
   60:             // 显示持久通知
   61:             const notificationId = toast.show(
   62:                 t('backup.messages.restoreStarted', { name: backupName }),
   63:                 'info',
   64:                 0 // 不自动消失
   65:             )
   66: 
   67:             activeTask.value = {
   68:                 instanceId,
   69:                 backupId,
   70:                 backupName,
   71:                 taskId: res.taskId,
   72:                 status: 'pending',
   73:                 notificationId
   74:             }
   75: 
   76:             // 开始轮询
   77:             startPolling(t)
   78:             return true
   79:         } catch (err: any) {
   80:             toast.error(t('backup.messages.restoreFailed') + ': ' + (err?.message || String(err)))
   81:             return false
   82:         }
   83:     }
   84: 
   85:     /**
   86:      * 开始轮询任务状态
   87:      */
   88:     function startPolling(t: (key: string, params?: Record<string, unknown>) => string): void {
   89:         stopPolling()
   90: 
   91:         pollInterval = setInterval(async () => {
   92:             if (!activeTask.value || !activeTask.value.taskId) {
   93:                 stopPolling()
   94:                 return
   95:             }
   96: 
   97:             try {
   98:                 const res = await api.instances.getRestoreStatus(
   99:                     activeTask.value.instanceId,
  100:                     activeTask.value.taskId
  101:                 )
  102: 
  103:                 // 后端返回大写状态，转为小写
  104:                 const status = res.status.toLowerCase() as RestoreTaskStatus
  105:                 activeTask.value.status = status
  106:                 if (res.error) {
  107:                     activeTask.value.error = res.error
  108:                 }
  109:                 // 更新任务时间信息
  110:                 if (res.queuePosition !== undefined) activeTask.value.queuePosition = res.queuePosition
  111:                 if (res.duration !== undefined) activeTask.value.duration = res.duration
  112:                 if (res.createdAt) activeTask.value.createdAt = res.createdAt
  113:                 if (res.startedAt !== undefined) activeTask.value.startedAt = res.startedAt
  114:                 if (res.finishedAt !== undefined) activeTask.value.finishedAt = res.finishedAt
  115: 
  116:                 // 处理完成状态
  117:                 if (status === 'completed') {
  118:                     if (activeTask.value.notificationId !== null) {
  119:                         toast.remove(activeTask.value.notificationId)
  120:                     }
  121:                     toast.success(t('backup.messages.restoreCompleted'))
  122:                     stopPolling()
  123:                     // 刷新页面以显示恢复后的实例
  124:                     setTimeout(() => {
  125:                         window.location.reload()
  126:                     }, 1500)
  127:                 } else if (status === 'failed') {
  128:                     if (activeTask.value.notificationId !== null) {
  129:                         toast.remove(activeTask.value.notificationId)
  130:                     }
  131:                     toast.error(t('backup.messages.restoreFailed') + ': ' + (res.error || ''))
  132:                     stopPolling()
  133:                 }
  134:             } catch (err) {
  135:                 console.error('Failed to poll restore status:', err)
  136:             }
  137:         }, 2000)
  138:     }
  139: 
  140:     /**
  141:      * 停止轮询
  142:      */
  143:     function stopPolling(): void {
  144:         if (pollInterval) {
  145:             clearInterval(pollInterval)
  146:             pollInterval = null
  147:         }
  148:     }
  149: 
  150:     /**
  151:      * 回滚恢复操作
  152:      */
  153:     async function rollback(t: (key: string, params?: Record<string, unknown>) => string): Promise<boolean> {
  154:         if (!activeTask.value || activeTask.value.status !== 'failed') {
  155:             return false
  156:         }
  157: 
  158:         try {
  159:             await api.instances.rollbackRestore(activeTask.value.instanceId, activeTask.value.taskId)
  160:             activeTask.value.status = 'rolled_back'
  161:             toast.success(t('backup.messages.rollbackCompleted'))
  162:             return true
  163:         } catch (err: any) {
  164:             toast.error(t('backup.messages.rollbackFailed') + ': ' + (err?.message || String(err)))
  165:             return false
  166:         }
  167:     }
  168: 
  169:     /**
  170:      * 清除任务状态
  171:      */
  172:     function clearTask(): void {
  173:         stopPolling()
  174:         if (activeTask.value && activeTask.value.notificationId !== null) {
  175:             toast.remove(activeTask.value.notificationId)
  176:         }
  177:         activeTask.value = null
  178:     }
  179: 
  180:     /**
  181:      * 获取指定实例的恢复状态
  182:      */
  183:     function getTaskForInstance(instanceId: number): RestoreTask | null {
  184:         if (activeTask.value && activeTask.value.instanceId === instanceId) {
  185:             return activeTask.value
  186:         }
  187:         return null
  188:     }
  189: 
  190:     /**
  191:      * 检查指定备份是否正在恢复
  192:      */
  193:     function isBackupRestoring(instanceId: number, backupId: number): boolean {
  194:         if (!activeTask.value) return false
  195:         return activeTask.value.instanceId === instanceId &&
  196:             activeTask.value.backupId === backupId &&
  197:             ['pending', 'processing', 'stopping', 'restoring', 'replacing'].includes(activeTask.value.status)
  198:     }
  199: 
  200:     /**
  201:      * 检查指定备份是否恢复失败（可回滚）
  202:      */
  203:     function canRollbackBackup(instanceId: number, backupId: number): boolean {
  204:         if (!activeTask.value) return false
  205:         return activeTask.value.instanceId === instanceId &&
  206:             activeTask.value.backupId === backupId &&
  207:             activeTask.value.status === 'failed'
  208:     }
  209: 
  210:     return {
  211:         activeTask,
  212:         startRestore,
  213:         rollback,
  214:         clearTask,
  215:         getTaskForInstance,
  216:         isBackupRestoring,
  217:         canRollbackBackup
  218:     }
  219: }
FILE client/src/stores/terminal.ts
    1: /**
    2:  * 终端设置 Store
    3:  * 
    4:  * 管理终端的所有可配置项，并持久化到 localStorage
    5:  * 被 TerminalModal.vue 和 TerminalView.vue 共享
    6:  */
    7: 
    8: import { defineStore } from 'pinia'
    9: import { ref, computed, watch } from 'vue'
   10: 
   11: // 终端主题类型
   12: export type TerminalThemeType = 'dark' | 'light' | 'highContrast'
   13: 
   14: // 终端主题定义
   15: export const TERMINAL_THEMES = {
   16:     // Vercel 极简风格 - 纯黑背景（默认）
