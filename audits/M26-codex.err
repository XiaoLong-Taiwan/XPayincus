    6: export const useAuthStore = defineStore('auth', () => {
    7:   const user: Ref<AuthUser | null> = ref(null)
    8:   const token: Ref<string | null> = ref(localStorage.getItem('token') || null)
    9:   const quota = ref<any>(null)
   10: 
   11:   // 同步 token 的方法（用于 token 刷新后同步）
   12:   function syncToken() {
   13:     token.value = localStorage.getItem('token')
   14:   }
   15: 
   16:   // 监听 localStorage 变化（跨窗口同步）
   17:   if (typeof window !== 'undefined') {
   18:     window.addEventListener('storage', (e) => {
   19:       if (e.key === 'token') {
   20:         token.value = e.newValue
   21:       }
   22:     })
   23:   }
   24: 
   25:   const isAuthenticated = computed(() => !!token.value)
   26:   const isAdmin = computed(() => user.value?.role === 'admin')
   27: 
   28:   function applyAuthUser(rawUser: any) {
   29:     user.value = {
   30:       id: rawUser.id,
   31:       username: rawUser.username,
   32:       email: rawUser.email || '',
   33:       role: rawUser.role,
   34:       avatarStyle: rawUser.avatarStyle || 'bigSmile',
   35:       avatarBadgeId: rawUser.avatarBadgeId || null,
   36:       hasCreatedHostBefore: rawUser.hasCreatedHostBefore || false,
   37:       canAccessHostingFeature: rawUser.canAccessHostingFeature ?? true
   38:     }
   39:   }
   40: 
   41:   async function login(username: string, password: string, totpCode?: string, recoveryCode?: string, turnstileToken?: string) {
   42:     const response = await api.auth.login(username, password, totpCode, recoveryCode, turnstileToken)
   43: 
   44:     token.value = response.token
   45:     applyAuthUser(response.user)
   46:     localStorage.setItem('token', response.token)
   47:     return response
   48:   }
   49: 
   50:   async function fetchCurrentUser(): Promise<AuthUser | null> {
   51:     if (!token.value) return null
   52:     try {
   53:       const response = await api.auth.me()
   54:       applyAuthUser(response.user)
   55:       // 保存配额信息
   56:       quota.value = (response.user as any).quota || null
   57:       return user.value
   58:     } catch (error: any) {
   59:       if (error?.code === 'UNAUTHORIZED' || error?.response?.status === 401) {
   60:         // 只清除本地状态，不调用后端logout（因为token可能已经无效）
   61:         clearLocalAuth()
   62:       }
   63:       throw error
   64:     }
   65:   }
   66: 
   67:   // 清除本地认证状态（不调用后端API）
   68:   function clearLocalAuth() {
   69:     token.value = null
   70:     user.value = null
   71:     quota.value = null
   72:     localStorage.removeItem('token')
   73:   }
   74: 
   75:   // 仅清除当前标签页内存中的认证状态，保留共享的 localStorage.token。
   76:   // 用于“管理员误入用户端 / 非管理员误入管理端”这类跨端驱离场景：
   77:   // 不能清共享 token，否则会通过 storage 事件把另一端（合法会话）一起登出。
   78:   function clearInMemoryAuth() {
   79:     token.value = null
   80:     user.value = null
   81:     quota.value = null
   82:   }
   83: 
   84:   async function logout() {
   85:     // 先调用后端登出 API（清除服务端会话和记录日志）
   86:     // 必须在清除本地状态之前调用，否则请求拦截器无法获取 token
   87:     if (token.value) {
   88:       try {
   89:         await api.auth.logout()
   90:       } catch (error) {
   91:         // 后端调用失败不影响本地登出
   92:         console.warn('登出 API 调用失败:', error)
   93:       }
   94:     }
   95: 
   96:     // 最后清除本地状态
   97:     clearLocalAuth()
   98:   }
   99: 
  100:   // 初始化：如果存在 token 则获取用户信息
  101:   // 使用 setTimeout 延迟执行，避免在 store 初始化时立即触发请求
  102:   if (token.value && typeof window !== 'undefined') {
  103:     setTimeout(() => {
  104:       fetchCurrentUser().catch(() => {
  105:         // 初始化时静默失败，如果 token 无效会自动清除
  106:       })
  107:     }, 0)
  108:   }
  109: 
  110:   // 检查会话是否有效（用于页面可见性变化时检查）
  111:   async function checkSession(): Promise<boolean> {
  112:     if (!token.value) {
  113:       return false
  114:     }
  115:     try {
  116:       const response = await api.auth.me()
  117:       applyAuthUser(response.user)
  118:       quota.value = (response.user as any).quota || null
  119:       return true
  120:     } catch (error: any) {
  121:       // 如果是401，说明会话已过期
  122:       if (error?.code === 'UNAUTHORIZED' || error?.response?.status === 401) {
  123:         clearLocalAuth()
  124:         return false
  125:       }
  126:       // 其他错误（如网络错误），不清除状态
  127:       return true
  128:     }
  129:   }
  130: 
  131:   return {
  132:     user,
  133:     token,
  134:     quota,
  135:     isAuthenticated,
  136:     isAdmin,
  137:     login,
  138:     fetchCurrentUser,
  139:     logout,
  140:     syncToken,
  141:     clearLocalAuth,
  142:     clearInMemoryAuth,
  143:     checkSession
  144:   }
  145: })
