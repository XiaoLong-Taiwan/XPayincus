   22: // 处理 OAuth 登录码的函数
   23: async function handleOAuthCode(): Promise<boolean> {
   24:   if (oauthProcessed) return true
   25:   
   26:   const urlParams = new URLSearchParams(window.location.search)
   27:   const oauthCode = urlParams.get('oauth_code')
   28:   
   29:   if (!oauthCode) return false
   30:   
   31:   // 防止重复处理
   32:   if (oauthProcessing) {
   33:     // 等待处理完成
   34:     while (oauthProcessing) {
   35:       await new Promise(resolve => setTimeout(resolve, 50))
   36:     }
   37:     return oauthProcessed
   38:   }
   39:   
   40:   oauthProcessing = true
   41:   
   42:   try {
   43:     const response = await api.oauth.exchangeCode(oauthCode)
   44:     // 保存 token 到 localStorage
   45:     localStorage.setItem('token', response.token)
   46:     // 同步到 auth store
   47:     const authStore = useAuthStore()
   48:     authStore.syncToken()
   49:     // 获取用户信息
   50:     await authStore.fetchCurrentUser()
   51:     
   52:     // 清除 URL 中的 oauth_code 参数
   53:     urlParams.delete('oauth_code')
   54:     const newSearch = urlParams.toString()
   55:     const newUrl = window.location.pathname + (newSearch ? '?' + newSearch : '')
   56:     window.history.replaceState({}, '', newUrl)
   57:     
   58:     oauthProcessed = true
   59:     return true
   60:   } catch (err) {
   61:     console.error('OAuth login code exchange failed:', err)
   62:     // 清除 URL 参数，避免重复尝试
   63:     urlParams.delete('oauth_code')
   64:     const newSearch = urlParams.toString()
   65:     const newUrl = window.location.pathname + (newSearch ? '?' + newSearch : '')
   66:     window.history.replaceState({}, '', newUrl)
   67:     return false
   68:   } finally {
   69:     oauthProcessing = false
   70:   }
   71: }
