  416: // 路由错误处理 - 捕获组件加载失败
  417: router.onError((error) => {
  418:   console.error('路由错误:', error)
  419:   console.error('错误详情:', {
  420:     message: error.message,
  421:     name: error.name,
  422:     stack: error.stack,
  423:     url: window.location.href
  424:   })
  425:   // 如果是组件加载失败，说明客户端还持有旧版本 chunk，刷新到新版本。
  426:   if (isStaleAssetLoadError(error)) {
  427:     scheduleStaleAssetReload('admin-router-error', error)
  428:   }
  429: })
  430: 
  431: // Route guard
  432: router.beforeEach(async (to: RouteLocationNormalized, _from: RouteLocationNormalized, next: NavigationGuardNext) => {
  433:   const authStore = useAuthStore()
  434:   // 检查是否有 OAuth 登录码需要处理
  435:   const urlParams = new URLSearchParams(window.location.search)
  436:   if (urlParams.has('oauth_code')) {
  437:     // 先处理 OAuth 登录码，等待完成
  438:     await handleOAuthCode()
  439:   }
  440: 
  441:   // 如果有 token 但用户信息还没加载，先等待加载完成
  442:   if (authStore.isAuthenticated && !authStore.user) {
  443:     try {
  444:       await authStore.fetchCurrentUser()
  445:     } catch {
  446:       // 加载失败，token 可能无效，会被 logout 清除
  447:     }
  448:   }
  449:   
  450:   // Pages requiring authentication
  451:   if (to.meta.requiresAuth && !authStore.isAuthenticated) {
  452:     next({ name: 'login', query: { redirect: to.fullPath } })
  453:     return
  454:   }
  455: 
  456:   // Pages requiring admin permission
  457:   if (to.meta.requiresAdmin && !authStore.isAdmin) {
  458:     next({ name: 'login', query: { redirect: to.fullPath } })
  459:     return
  460:   }
  461: 
  462:   // 仅在明确得知是非管理员账号时才驱离；user 为空（/auth/me 瞬时失败/部署抖动）时
  463:   // 不能把管理员误当作非管理员整段登出。驱离只清本标签页内存态，保留共享 token 不影响用户端会话。
  464:   if (authStore.isAuthenticated && authStore.user && !authStore.isAdmin) {
  465:     authStore.clearInMemoryAuth()
  466:     next({ name: 'login' })
  467:     return
  468:   }
  469: 
  470:   // Authenticated admins accessing the admin login page
  471:   if (to.meta.guest && authStore.isAuthenticated) {
  472:     // 根据用户角色跳转
  473:     next({ name: 'admin-users' })
  474:     return
  475:   }
  476: 
  477:   next()
  478: })
  479: 
  480: // 预加载常用页面，提升切换速度
  481: router.isReady().then(() => {
  482:   // 延迟预加载，避免影响首屏加载
  483:   setTimeout(() => {
  484:     // 预加载核心页面
  485:     import('@/views/admin/UsersView.vue')
  486:     import('@/views/admin/BillingView.vue')
  487:     import('@/views/admin/OrdersView.vue')
  488:     import('@/views/admin/SystemConfigView.vue')
  489:     import('@/views/admin/HostingView.vue')
  490:   }, 1000)
  491: })
  492: 
  493: export default router

