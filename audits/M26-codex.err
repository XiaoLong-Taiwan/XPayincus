    7: // OAuth 登录码处理状态
    8: let oauthProcessing = false
    9: let oauthProcessed = false
   10: // 处理 OAuth 登录码的函数
   11: async function handleOAuthCode(): Promise<boolean> {
   12:   if (oauthProcessed) return true
   13:   
   14:   const urlParams = new URLSearchParams(window.location.search)
   15:   const oauthCode = urlParams.get('oauth_code')
   16:   
   17:   if (!oauthCode) return false
   18:   
   19:   // 防止重复处理
   20:   if (oauthProcessing) {
   21:     // 等待处理完成
   22:     while (oauthProcessing) {
   23:       await new Promise(resolve => setTimeout(resolve, 50))
   24:     }
   25:     return oauthProcessed
   26:   }
   27:   
   28:   oauthProcessing = true
   29:   
   30:   try {
   31:     const response = await api.oauth.exchangeCode(oauthCode)
   32:     // 保存 token 到 localStorage
   33:     localStorage.setItem('token', response.token)
   34:     // 同步到 auth store
   35:     const authStore = useAuthStore()
   36:     authStore.syncToken()
   37:     // 获取用户信息
   38:     await authStore.fetchCurrentUser()
   39:     
   40:     // 清除 URL 中的 oauth_code 参数
   41:     urlParams.delete('oauth_code')
   42:     const newSearch = urlParams.toString()
   43:     const newUrl = window.location.pathname + (newSearch ? '?' + newSearch : '')
   44:     window.history.replaceState({}, '', newUrl)
   45:     
   46:     oauthProcessed = true
   47:     return true
   48:   } catch (err) {
   49:     console.error('OAuth login code exchange failed:', err)
   50:     // 清除 URL 参数，避免重复尝试
   51:     urlParams.delete('oauth_code')
   52:     const newSearch = urlParams.toString()
   53:     const newUrl = window.location.pathname + (newSearch ? '?' + newSearch : '')
   54:     window.history.replaceState({}, '', newUrl)
   55:     return false
   56:   } finally {
   57:     oauthProcessing = false
   58:   }
   59: }
