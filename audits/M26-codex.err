    1: /**
    2:  * Service Worker - 静态资源缓存
    3:  * 提升二次加载速度，支持离线访问静态资源
    4:  */
    5: 
    6: // 从 SW 注册 URL 的 ?v= 版本参数推导缓存名（前端以 /sw.js?v=<version> 注册），
    7: // 发版时缓存名自动随版本变化，无需再手动 bump；缺参数时回退到内置字面量。
    8: const SW_VERSION = (() => {
    9:   try {
   10:     return new URL(self.location.href).searchParams.get('v') || '1.3.5'
   11:   } catch {
   12:     return '1.3.5'
   13:   }
   14: })()
   15: const CACHE_NAME = `incudal-cache-v${SW_VERSION}`
   16: 
   17: // 需要缓存的静态资源类型
   18: const CACHEABLE_EXTENSIONS = ['.js', '.css', '.woff', '.woff2', '.ttf', '.svg', '.png', '.jpg', '.jpeg', '.gif', '.ico']
   19: 
   20: // 需要始终从网络获取的路径（不缓存）
   21: const NETWORK_ONLY_PATTERNS = [
   22:   '/api/',           // API 请求
   23:   '/auth/',          // 认证请求
   24:   '/oauth/',         // OAuth 请求
   25:   '/__vite_ping',    // Vite HMR
   26:   '/sw.js'           // Service Worker 自身
   27: ]
   28: 
   29: // 安装事件
   30: self.addEventListener('install', (event) => {
   31:   console.log('[SW] Installing service worker...')
   32:   // 跳过等待，立即激活
   33:   event.waitUntil(self.skipWaiting())
   34: })
   35: 
   36: // 激活事件
   37: self.addEventListener('activate', (event) => {
   38:   console.log('[SW] Activating service worker...')
   39:   event.waitUntil(
   40:     Promise.all([
   41:       // 清理旧版本缓存
   42:       caches.keys().then(cacheNames => {
   43:         return Promise.all(
   44:           cacheNames
   45:             .filter(cacheName => cacheName !== CACHE_NAME)
