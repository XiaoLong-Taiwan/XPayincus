  345: const API_BASE_URL = import.meta.env.VITE_API_BASE_URL || '/api'
  346: 
  347: // 创建 axios 实例
  348: const http: AxiosInstance = axios.create({
  349:   baseURL: API_BASE_URL,
  350:   withCredentials: true,
  351:   timeout: TIMEOUT.DEFAULT,
  352:   headers: {
  353:     'Content-Type': 'application/json'
  354:   }
  355: })
  356: 
  357: // 刷新 token 的锁，防止多个请求同时触发刷新
  358: let isRefreshing = false
  359: let failedQueue: Array<{
  360:   resolve: (value?: unknown) => void
  361:   reject: (reason?: unknown) => void
  362: }> = []
  363: // 记录最后一次刷新尝试的时间，避免过于频繁的刷新
  364: let lastRefreshAttempt = 0
  365: const MIN_REFRESH_INTERVAL = 5000 // 5秒内最多刷新一次
  366: // 记录认证失败的时间，防止在短时间内重复清除状态
  367: let lastAuthFailureTime = 0
  368: const AUTH_FAILURE_COOLDOWN = 10000 // 10秒内最多清除一次认证状态
  369: 
  370: // 处理队列中的请求
  371: const processQueue = (error: any, token: string | null = null) => {
  372:   failedQueue.forEach(prom => {
  373:     if (error) {
  374:       prom.reject(error)
  375:     } else {
  376:       prom.resolve(token)
  377:     }
  378:   })
  379:   failedQueue = []
  380: }
  381: 
  382: /**
  383:  * 解析 JWT token，获取过期时间
  384:  */
  385: function parseJWT(token: string): { exp?: number; iat?: number } | null {
  386:   try {
  387:     const base64Url = token.split('.')[1]
  388:     const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/')
  389:     const jsonPayload = decodeURIComponent(
  390:       atob(base64)
  391:         .split('')
  392:         .map(c => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2))
  393:         .join('')
  394:     )
  395:     return JSON.parse(jsonPayload)
  396:   } catch {
  397:     return null
  398:   }
  399: }
  400: 
  401: /**
  402:  * 检查 token 是否即将过期（简化版：剩余时间少于 1 天）
  403:  */
  404: function isTokenExpiringSoon(token: string): boolean {
  405:   const decoded = parseJWT(token)
  406:   if (!decoded || !decoded.exp) {
  407:     return false
  408:   }
  409:   const exp = decoded.exp * 1000 // 转换为毫秒
  410:   const now = Date.now()
  411:   const timeUntilExpiry = exp - now
  412:   // 简化版：如果剩余时间少于 1 天，则认为即将过期
  413:   return timeUntilExpiry < 24 * 60 * 60 * 1000
  414: }
  415: 
  416: /**
  417:  * 主动刷新 token（在 token 即将过期前）
  418:  */
  419: async function proactiveRefreshToken(): Promise<string | null> {
  420:   if (isRefreshing) {
  421:     // 如果正在刷新，等待刷新完成
  422:     return new Promise((resolve, reject) => {
  423:       failedQueue.push({ resolve, reject })
  424:     }).then(token => token as string | null).catch(() => null)
  425:   }
  426: 
  427:   // 检查刷新频率，避免过于频繁
  428:   const now = Date.now()
  429:   if (now - lastRefreshAttempt < MIN_REFRESH_INTERVAL) {
  430:     // 最近刚刷新过，直接返回 null，使用当前 token
  431:     return null
  432:   }
  433: 
  434:   isRefreshing = true
  435:   lastRefreshAttempt = now
  436: 
  437:   try {
  438:     // 刷新请求加超时兜底：/auth/refresh 挂起时避免 isRefreshing 长期为真导致全站请求排队卡死
  439:     const refreshController = new AbortController()
  440:     const refreshTimeoutId = setTimeout(() => refreshController.abort(), 15_000)
  441:     let refreshResponse: Response
  442:     try {
  443:       refreshResponse = await fetch(buildApiUrl('/auth/refresh'), {
  444:         method: 'POST',
  445:         credentials: 'include', // 重要：发送 Cookie（包含 refreshToken）
  446:         headers: {
  447:           'Content-Type': 'application/json'
  448:         },
  449:         signal: refreshController.signal
  450:       })
  451:     } finally {
  452:       clearTimeout(refreshTimeoutId)
  453:     }
  454: 
  455:     if (!refreshResponse.ok) {
  456:       // 如果是 401 或 400，说明 refreshToken 也失效了，需要重新登录
  457:       // 400 通常表示 refresh token 无效、过期或格式错误
  458:       if (refreshResponse.status === 401 || refreshResponse.status === 400) {
  459:         throw new Error('REFRESH_TOKEN_INVALID')
  460:       }
  461:       throw new Error(`Refresh token failed: ${refreshResponse.status}`)
  462:     }
  463: 
  464:     const refreshData = await refreshResponse.json()
  465:     const newToken = refreshData?.token
  466:     if (newToken) {
  467:       localStorage.setItem('token', newToken)
  468:       // 同步更新 auth store 中的 token
  469:       try {
  470:         const authStore = useAuthStore()
  471:         authStore.syncToken()
  472:       } catch {
  473:         // 如果 store 未初始化，忽略
  474:       }
  475:       processQueue(null, newToken)
  476:       return newToken
  477:     } else {
  478:       throw new Error('No token in refresh response')
  479:     }
  480:   } catch (refreshError: any) {
  481:     processQueue(refreshError, null)
  482:     // 如果是 refreshToken 失效，需要清除并跳转登录
  483:     if (refreshError?.message === 'REFRESH_TOKEN_INVALID') {
  484:       localStorage.removeItem('token')
  485:       if (!window.location.pathname.startsWith('/login') && !window.location.pathname.startsWith('/register')) {
  486:         window.location.href = '/login'
  487:       }
  488:       return null
  489:     }
  490:     // 其他错误（如网络错误）不立即跳转登录页，让响应拦截器处理
  491:     // 这样可以避免因为临时网络问题导致用户被退出
  492:     console.warn('Proactive token refresh failed:', refreshError)
  493:     return null
  494:   } finally {
  495:     isRefreshing = false
  496:   }
  497: }
  498: 
  499: // 请求拦截器 - 添加 token 并检查是否需要刷新
  500: http.interceptors.request.use(
  501:   async (config) => {
  502:     let token = localStorage.getItem('token')
  503:     if (token) {
  504:       // 检查 token 是否即将过期，如果是则先刷新
  505:       if (isTokenExpiringSoon(token)) {
  506:         const newToken = await proactiveRefreshToken()
  507:         if (newToken) {
  508:           token = newToken
  509:         }
  510:         // 如果刷新失败，继续使用旧 token，让响应拦截器处理 401
  511:       }
  512:       config.headers.Authorization = `Bearer ${token}`
  513:     }
  514:     return config
  515:   },
  516:   (error) => Promise.reject(error)
  517: )
  518: 
  519: // 响应拦截器 - 处理错误和自动刷新 token
  520: http.interceptors.response.use(
  521:   (response) => response.data,
  522:   async (error) => {
  523:     const responseData = error.response?.data
  524:     const requestUrl = error.config?.url || ''
  525:     const originalRequest = error.config
  526: 
  527:     // 401 未授权，尝试刷新 token
  528:     if (error.response?.status === 401) {
  529:       // 排除登录、注册、刷新和check-2fa接口本身
  530:       const isAuthEndpoint = requestUrl.startsWith('/auth/login') ||
  531:         requestUrl.startsWith('/auth/register') ||
  532:         requestUrl.startsWith('/auth/refresh') ||
  533:         requestUrl.startsWith('/auth/check-2fa')
  534: 
  535:       // 如果是认证相关接口的 401，不尝试刷新，直接返回错误
  536:       if (isAuthEndpoint) {
  537:         // 创建带有错误码的错误对象
  538:         const apiError = {
  539:           message: responseData?.error || 'Unauthorized',
  540:           code: responseData?.code || null,
  541:           details: responseData?.details || null
  542:         }
  543:         return Promise.reject(apiError)
  544:       }
  545: 
  546:       // 如果已经重试过，说明刷新也失败了，清除所有认证状态并跳转登录页
  547:       if (originalRequest?._retry) {
  548:         const now = Date.now()
  549:         // 防止在短时间内重复清除状态和跳转
  550:         if (now - lastAuthFailureTime > AUTH_FAILURE_COOLDOWN) {
  551:           lastAuthFailureTime = now
  552:           // 清除 auth store 状态
  553:           try {
  554:             const authStore = useAuthStore()
  555:             authStore.clearLocalAuth()
  556:           } catch {
  557:             // 如果 store 未初始化，只清除 localStorage
  558:             localStorage.removeItem('token')
  559:           }
  560:           if (!window.location.pathname.startsWith('/login') && !window.location.pathname.startsWith('/register')) {
  561:             window.location.href = '/login'
  562:           }
  563:         }
  564:         return Promise.reject(error)
  565:       }
  566: 
  567:       // 如果正在刷新，将请求加入队列
  568:       if (isRefreshing) {
  569:         return new Promise((resolve, reject) => {
  570:           failedQueue.push({ resolve, reject })
  571:         }).then(token => {
  572:           if (token) {
  573:             originalRequest.headers.Authorization = `Bearer ${token}`
  574:           }
  575:           return http(originalRequest)
  576:         }).catch(err => {
  577:           return Promise.reject(err)
  578:         })
  579:       }
  580: 
  581:       // 检查刷新频率，避免过于频繁
  582:       const now = Date.now()
  583:       if (now - lastRefreshAttempt < MIN_REFRESH_INTERVAL && lastRefreshAttempt > 0) {
  584:         // 最近刚刷新过，可能是网络问题，等待一下再重试原请求
  585:         await new Promise(resolve => setTimeout(resolve, 1000))
  586:         if (originalRequest) {
  587:           return http(originalRequest)
  588:         }
  589:         return Promise.reject(error)
  590:       }
  591: 
  592:       // 标记正在刷新，防止重复刷新
  593:       if (originalRequest) {
  594:         originalRequest._retry = true
  595:       }
  596:       isRefreshing = true
  597:       lastRefreshAttempt = now
  598: 
  599:       try {
  600:         // 尝试刷新 token（使用 fetch API，避免触发拦截器循环）
  601:         // 刷新请求加超时兜底：避免 /auth/refresh 挂起时后续请求全部排队卡死
  602:         const refreshController = new AbortController()
  603:         const refreshTimeoutId = setTimeout(() => refreshController.abort(), 15_000)
  604:         let refreshResponse: Response
  605:         try {
  606:           refreshResponse = await fetch(buildApiUrl('/auth/refresh'), {
  607:             method: 'POST',
  608:             credentials: 'include', // 重要：发送 Cookie（包含 refreshToken）
  609:             headers: {
  610:               'Content-Type': 'application/json'
  611:             },
  612:             signal: refreshController.signal
  613:           })
  614:         } finally {
  615:           clearTimeout(refreshTimeoutId)
  616:         }
  617: 
  618:         if (!refreshResponse.ok) {
  619:           // 如果是 401 或 400，说明 refreshToken 也失效了，需要重新登录
  620:           // 400 通常表示 refresh token 无效、过期或格式错误
  621:           if (refreshResponse.status === 401 || refreshResponse.status === 400) {
  622:             throw new Error('REFRESH_TOKEN_INVALID')
  623:           }
  624:           throw new Error(`Refresh token failed: ${refreshResponse.status}`)
  625:         }
  626: 
  627:         const refreshData = await refreshResponse.json()
  628:         const newToken = refreshData?.token
  629:         if (newToken) {
  630:           // 更新 localStorage 中的 token
  631:           localStorage.setItem('token', newToken)
  632:           // 同步更新 auth store 中的 token
  633:           try {
  634:             const authStore = useAuthStore()
  635:             authStore.syncToken()
  636:           } catch {
  637:             // 如果 store 未初始化，忽略
  638:           }
  639:           // 处理队列中的请求
  640:           processQueue(null, newToken)
  641:           // 更新请求头并重试原请求
  642:           if (originalRequest) {
  643:             originalRequest.headers.Authorization = `Bearer ${newToken}`
  644:             return http(originalRequest)
  645:           }
  646:           return Promise.reject(error)
  647:         } else {
  648:           throw new Error('No token in refresh response')
  649:         }
  650:       } catch (refreshError: any) {
  651:         // 刷新失败，根据错误类型决定是否跳转登录
  652:         processQueue(refreshError, null)
  653:         
  654:         // 如果是 refreshToken 失效（401 或 400），清除所有认证状态并跳转到登录页
  655:         // 400 通常表示 refresh token 无效、过期或格式错误
  656:         if (refreshError?.message === 'REFRESH_TOKEN_INVALID' || 
  657:             (refreshError?.response?.status === 401) ||
  658:             (refreshError?.response?.status === 400)) {
  659:           const now = Date.now()
  660:           // 防止在短时间内重复清除状态和跳转
  661:           if (now - lastAuthFailureTime > AUTH_FAILURE_COOLDOWN) {
  662:             lastAuthFailureTime = now
  663:             // 清除 auth store 状态
  664:             try {
  665:               const authStore = useAuthStore()
  666:               authStore.clearLocalAuth()
  667:             } catch {
  668:               // 如果 store 未初始化，只清除 localStorage
  669:               localStorage.removeItem('token')
  670:             }
  671:             if (!window.location.pathname.startsWith('/login') && !window.location.pathname.startsWith('/register')) {
  672:               window.location.href = '/login'
  673:             }
  674:           }
  675:         } else {
  676:           // 其他错误（如网络错误），不立即跳转，记录日志
  677:           console.warn('Token refresh failed, but not invalidating session:', refreshError)
  678:         }
  679:         return Promise.reject(refreshError)
  680:       } finally {
  681:         isRefreshing = false
  682:       }
  683:     }
  684: 
  685:     // 创建带有错误码的错误对象，用于前端翻译
  686:     // 保留原始响应数据中的额外字段（如 conflicts, availableCount 等）
  687:     const apiError = {
  688:       message: responseData?.error || responseData?.message || 'Request failed',
  689:       code: responseData?.code || null,
  690:       details: responseData?.details || null,
  691:       ...responseData  // 保留原始响应中的所有字段
  692:     }
  693: 
  694:     return Promise.reject(apiError)
  695:   }
  696: )
  697: 
  698: // API 模块
  699: const api = {
  700:   // 认证
  701:   auth: {
  702:     check2FA: (username: string): Promise<{ requires2FA: boolean }> =>
  703:       http.post('/auth/check-2fa', { username }),
  704:     login: (username: string, password: string, totpCode?: string, recoveryCode?: string, turnstileToken?: string): Promise<LoginResponse> =>
  705:       http.post('/auth/login', { username, password, totpCode, recoveryCode, turnstileToken } as LoginRequest & { totpCode?: string; recoveryCode?: string; turnstileToken?: string }),
  706:     register: (data: RegisterRequest & { emailCode?: string }): Promise<RegisterResponse> =>
  707:       http.post('/auth/register', data),
  708:     sendVerificationCode: (email: string, turnstileToken?: string): Promise<{ message: string; expiresAt: string }> =>
  709:       http.post('/auth/send-verification-code', { email, turnstileToken }),
  710:     sendForgotPasswordCode: (email: string, turnstileToken?: string): Promise<{ message: string; expiresAt: string }> =>
  711:       http.post('/auth/forgot-password/send-code', { email, turnstileToken }),
  712:     resetPassword: (email: string, code: string, password: string, turnstileToken?: string): Promise<{ message: string; twoFactorDisabled: boolean }> =>
  713:       http.post('/auth/forgot-password/reset', { email, code, password, turnstileToken }),
  714:     me: (): Promise<{ user: User }> => http.get('/auth/me'),
  715:     logout: (): Promise<void> => http.post('/auth/logout'),
  716:     generateInvite: (data: GenerateInviteRequest = {}): Promise<{ code: string; codes?: string[]; count?: number; expiresAt?: string; url?: string }> =>
  717:       http.post('/auth/invite', data),
  718:     getInvites: (params: { page?: number; pageSize?: number; status?: 'used' | 'unused' } = {}): Promise<InviteListResponse> =>
  719:       http.get('/auth/invites', { params }),
  720:     deleteInvite: (id: number): Promise<void> => http.delete(`/auth/invites/${id}`),
  721:     // 双因素认证
  722:     get2FAStatus: (): Promise<{ enabled: boolean }> => http.get('/auth/2fa/status'),
  723:     setup2FA: (): Promise<{ secret: string; qrCode: string; recoveryCodes: string[] }> =>
  724:       http.post('/auth/2fa/setup'),
  725:     enable2FA: (code: string): Promise<{ message: string }> =>
  726:       http.post('/auth/2fa/enable', { code }),
  727:     disable2FA: (password: string, code: string): Promise<{ message: string }> =>
  728:       http.post('/auth/2fa/disable', { password, code }),
  729:     getRecoveryCodes: (): Promise<{ total: number; remaining: number; used: number }> =>
  730:       http.get('/auth/2fa/recovery-codes'),
  731:     regenerateRecoveryCodes: (password: string, code: string): Promise<{ recoveryCodes: string[] }> =>
  732:       http.post('/auth/2fa/regenerate-recovery-codes', { password, code }),
  733:     // 登录历史
  734:     getLoginHistory: (params?: { page?: number; pageSize?: number }): Promise<{
  735:       records: Array<{
  736:         id: number
  737:         ip: string
  738:         country: string | null
  739:         region: string | null
  740:         city: string | null
  741:         isp: string | null
  742:         timezone: string | null
  743:         userAgent: string | null
  744:         createdAt: string
  745:       }>
  746:       total: number
  747:       page: number
  748:       pageSize: number
  749:       totalPages: number
  750:     }> => http.get('/auth/login-history', { params })
  751:   },
  752: 
  753:   userInvites: {
  754:     summary: (): Promise<UserInviteSummary> => http.get('/user-invites/summary'),
  755:     list: (params: { page?: number; pageSize?: number } = {}): Promise<{
  756:       invites: UserInvite[]
  757:       total: number
  758:       page: number
  759:       pageSize: number
  760:       totalPages: number
  761:     }> => http.get('/user-invites', { params }),
  762:     generate: (data: { costResource: string; count?: number }): Promise<{
  763:       invites: UserInvite[]
  764:       count: number
  765:     }> => http.post('/user-invites', data)
  766:   },
  767: 
  768:   // 用户管理
  769:   users: {
