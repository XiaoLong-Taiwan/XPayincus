  307: // API 超时配置（毫秒）
  308: const TIMEOUT = {
  309:   DEFAULT: 30000,           // 30秒 - 普通请求
  310:   MEDIUM: 60000,            // 60秒 - 中等耗时操作
  311:   LONG: 120000,             // 120秒 - 较长操作（启动/停止/重启，需等待IP获取）
  312:   SNAPSHOT: 180000,         // 3分钟 - 快照/备份操作
  313:   REBUILD: 300000,          // 5分钟 - 重装系统
  314:   CLONE: 600000,            // 10分钟 - 复制实例
  315:   BATCH: 900000,            // 15分钟 - 批量操作
  316: }
  317: 
  318: function buildTicketFormData(
  319:   data: CreateTicketRequest | { content: string; attachments?: File[] }
  320: ): FormData {
  321:   const formData = new FormData()
  322: 
  323:   if ('instanceId' in data && data.instanceId !== undefined && data.instanceId !== null) {
  324:     formData.append('instanceId', String(data.instanceId))
  325:   }
  326:   if ('subject' in data) {
  327:     formData.append('subject', data.subject)
  328:   }
  329:   if ('category' in data && data.category) {
  330:     formData.append('category', data.category)
  331:   }
  332:   if ('priority' in data && data.priority) {
  333:     formData.append('priority', data.priority)
  334:   }
  335: 
  336:   formData.append('content', data.content ?? '')
  337: 
  338:   for (const file of data.attachments || []) {
  339:     formData.append('images', file)
  340:   }
  341: 
  342:   return formData
  343: }
