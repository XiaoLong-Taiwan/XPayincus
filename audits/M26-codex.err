FILE client/src/stores/auth.ts [1-180]
    1: import { defineStore } from 'pinia'
    2: import { ref, computed, type Ref } from 'vue'
    3: import api from '@/api'
    4: import type { AuthUser } from '@/types/store.js'
    5: 
    6: export const useAuthStore = defineStore('auth', () => {
    7:   const user: Ref<AuthUser | null> = ref(null)
    8:   const token: Ref<string | null> = ref(localStorage.getItem('token') || null)
    9:   const quota = ref<any>(null)
   10: 
   11:   // 同步 token 的方法（用于 token 刷新后同步）
   12:   function syncToken() {
   13:     token.value = localStorage.getItem('token')
   14:   }
   15: 
   16:   // 监听 localStorage 变化（跨窗口同步）
   17:   if (typeof window !== 'undefined') {
   18:     window.addEventListener('storage', (e) => {
   19:       if (e.key === 'token') {
   20:         token.value = e.newValue
   21:       }
   22:     })
   23:   }
   24: 
   25:   const isAuthenticated = computed(() => !!token.value)
   26:   const isAdmin = computed(() => user.value?.role === 'admin')
   27: 
   28:   function applyAuthUser(rawUser: any) {
   29:     user.value = {
   30:       id: rawUser.id,
   31:       username: rawUser.username,
   32:       email: rawUser.email || '',
   33:       role: rawUser.role,
   34:       avatarStyle: rawUser.avatarStyle || 'bigSmile',
   35:       avatarBadgeId: rawUser.avatarBadgeId || null,
   36:       hasCreatedHostBefore: rawUser.hasCreatedHostBefore || false,
   37:       canAccessHostingFeature: rawUser.canAccessHostingFeature ?? true
   38:     }
   39:   }
   40: 
   41:   async function login(username: string, password: string, totpCode?: string, recoveryCode?: string, turnstileToken?: string) {
   42:     const response = await api.auth.login(username, password, totpCode, recoveryCode, turnstileToken)
   43: 
   44:     token.value = response.token
   45:     applyAuthUser(response.user)
   46:     localStorage.setItem('token', response.token)
   47:     return response
   48:   }
   49: 
   50:   async function fetchCurrentUser(): Promise<AuthUser | null> {
   51:     if (!token.value) return null
   52:     try {
   53:       const response = await api.auth.me()
   54:       applyAuthUser(response.user)
   55:       // 保存配额信息
   56:       quota.value = (response.user as any).quota || null
   57:       return user.value
   58:     } catch (error: any) {
   59:       if (error?.code === 'UNAUTHORIZED' || error?.response?.status === 401) {
   60:         // 只清除本地状态，不调用后端logout（因为token可能已经无效）
   61:         clearLocalAuth()
   62:       }
   63:       throw error
   64:     }
   65:   }
   66: 
   67:   // 清除本地认证状态（不调用后端API）
   68:   function clearLocalAuth() {
   69:     token.value = null
   70:     user.value = null
   71:     quota.value = null
   72:     localStorage.removeItem('token')
   73:   }
   74: 
   75:   // 仅清除当前标签页内存中的认证状态，保留共享的 localStorage.token。
   76:   // 用于“管理员误入用户端 / 非管理员误入管理端”这类跨端驱离场景：
   77:   // 不能清共享 token，否则会通过 storage 事件把另一端（合法会话）一起登出。
   78:   function clearInMemoryAuth() {
   79:     token.value = null
   80:     user.value = null
   81:     quota.value = null
   82:   }
   83: 
   84:   async function logout() {
   85:     // 先调用后端登出 API（清除服务端会话和记录日志）
   86:     // 必须在清除本地状态之前调用，否则请求拦截器无法获取 token
   87:     if (token.value) {
   88:       try {
   89:         await api.auth.logout()
   90:       } catch (error) {
   91:         // 后端调用失败不影响本地登出
   92:         console.warn('登出 API 调用失败:', error)
   93:       }
   94:     }
   95: 
   96:     // 最后清除本地状态
   97:     clearLocalAuth()
   98:   }
   99: 
  100:   // 初始化：如果存在 token 则获取用户信息
  101:   // 使用 setTimeout 延迟执行，避免在 store 初始化时立即触发请求
  102:   if (token.value && typeof window !== 'undefined') {
  103:     setTimeout(() => {
  104:       fetchCurrentUser().catch(() => {
  105:         // 初始化时静默失败，如果 token 无效会自动清除
  106:       })
  107:     }, 0)
  108:   }
  109: 
  110:   // 检查会话是否有效（用于页面可见性变化时检查）
  111:   async function checkSession(): Promise<boolean> {
  112:     if (!token.value) {
  113:       return false
  114:     }
  115:     try {
  116:       const response = await api.auth.me()
  117:       applyAuthUser(response.user)
  118:       quota.value = (response.user as any).quota || null
  119:       return true
  120:     } catch (error: any) {
  121:       // 如果是401，说明会话已过期
  122:       if (error?.code === 'UNAUTHORIZED' || error?.response?.status === 401) {
  123:         clearLocalAuth()
  124:         return false
  125:       }
  126:       // 其他错误（如网络错误），不清除状态
  127:       return true
  128:     }
  129:   }
  130: 
  131:   return {
  132:     user,
  133:     token,
  134:     quota,
  135:     isAuthenticated,
  136:     isAdmin,
  137:     login,
  138:     fetchCurrentUser,
  139:     logout,
  140:     syncToken,
  141:     clearLocalAuth,
  142:     clearInMemoryAuth,
  143:     checkSession
  144:   }
  145: })
FILE client/src/utils/staleAssetRecovery.ts [1-160]
    1: const STALE_ASSET_ERROR_PATTERNS = [
    2:   'Failed to fetch dynamically imported module',
    3:   'Importing a module script failed',
    4:   'error loading dynamically imported module',
    5:   'dynamically imported module',
    6:   'Loading chunk',
    7:   'ChunkLoadError'
    8: ]
    9: 
   10: let reloadScheduled = false
   11: const STALE_ASSET_RELOAD_SIGNATURE_KEY = 'incudal:stale-asset-reload-signature'
   12: const SERVICE_WORKER_RELOAD_KEY_PREFIX = 'incudal:service-worker-controller-reloaded:'
   13: 
   14: function describeError(error: unknown): string {
   15:   if (!error) return ''
   16:   if (typeof error === 'string') return error
   17:   if (error instanceof Error) {
   18:     return `${error.name} ${error.message}`.trim()
   19:   }
   20:   if (typeof error === 'object') {
   21:     const maybeError = error as { name?: unknown; message?: unknown; reason?: unknown }
   22:     const parts = [
   23:       typeof maybeError.name === 'string' ? maybeError.name : '',
   24:       typeof maybeError.message === 'string' ? maybeError.message : '',
   25:       describeError(maybeError.reason)
   26:     ].filter(Boolean)
   27:     if (parts.length > 0) return parts.join(' ')
   28:   }
   29:   return String(error)
   30: }
   31: 
   32: export function isStaleAssetLoadError(error: unknown): boolean {
   33:   const description = describeError(error)
   34:   return STALE_ASSET_ERROR_PATTERNS.some(pattern => description.includes(pattern))
   35: }
   36: 
   37: async function clearIncudalStaticCaches(): Promise<void> {
   38:   if (!('caches' in window)) return
   39:   const cacheNames = await caches.keys()
   40:   await Promise.all(
   41:     cacheNames
   42:       .filter(cacheName => cacheName.startsWith('incudal-cache-'))
   43:       .map(cacheName => caches.delete(cacheName))
   44:   )
   45: }
   46: 
   47: function currentAssetSignature(): string {
   48:   const assets = [
   49:     ...Array.from(document.querySelectorAll<HTMLScriptElement>('script[type="module"][src]')).map(element => element.src),
   50:     ...Array.from(document.querySelectorAll<HTMLLinkElement>('link[rel="modulepreload"][href], link[rel="stylesheet"][href]')).map(element => element.href)
   51:   ]
   52:   return assets.sort().join('|') || window.location.href
   53: }
   54: 
   55: function shouldReloadForStaleAsset(): boolean {
   56:   try {
   57:     const signature = currentAssetSignature()
   58:     if (window.sessionStorage.getItem(STALE_ASSET_RELOAD_SIGNATURE_KEY) === signature) {
   59:       console.warn('检测到前端静态资源仍然不一致，但当前资源版本已刷新过一次，停止自动刷新以避免循环')
   60:       return false
   61:     }
   62:     window.sessionStorage.setItem(STALE_ASSET_RELOAD_SIGNATURE_KEY, signature)
   63:   } catch {
   64:     // sessionStorage may be unavailable in restricted browsing contexts.
   65:   }
   66:   return true
   67: }
   68: 
   69: export function shouldReloadForServiceWorkerControllerChange(version: string): boolean {
   70:   try {
   71:     const key = `${SERVICE_WORKER_RELOAD_KEY_PREFIX}${version}`
   72:     if (window.sessionStorage.getItem(key) === '1') {
   73:       console.warn('Service Worker 已触发过当前版本刷新，跳过重复刷新以避免循环')
   74:       return false
   75:     }
   76:     window.sessionStorage.setItem(key, '1')
   77:   } catch {
   78:     // If sessionStorage is unavailable, keep the existing one-shot in-memory guard.
   79:   }
   80:   return true
   81: }
   82: 
   83: export function scheduleStaleAssetReload(reason: string, error?: unknown): void {
   84:   if (reloadScheduled) return
   85:   if (!shouldReloadForStaleAsset()) return
   86:   reloadScheduled = true
   87:   console.warn('检测到前端静态资源版本不一致，正在刷新页面', { reason, error })
   88: 
   89:   void clearIncudalStaticCaches().finally(() => {
   90:     window.setTimeout(() => {
   91:       window.location.reload()
   92:     }, 250)
   93:   })
   94: }
   95: 
   96: export function installStaleAssetRecovery(): void {
   97:   window.addEventListener('vite:preloadError', event => {
   98:     event.preventDefault()
   99:     scheduleStaleAssetReload('vite:preloadError', (event as Event & { payload?: unknown }).payload)
  100:   })
  101: 
  102:   window.addEventListener('unhandledrejection', event => {
  103:     if (!isStaleAssetLoadError(event.reason)) return
  104:     event.preventDefault()
  105:     scheduleStaleAssetReload('unhandledrejection', event.reason)
  106:   })
  107: 
  108:   window.addEventListener('error', event => {
  109:     const error = event.error || event.message
  110:     if (!isStaleAssetLoadError(error)) return
  111:     event.preventDefault()
  112:     scheduleStaleAssetReload('window.error', error)
  113:   })
  114: }
FILE client/src/utils/api-url.ts [1-80]
    1: const API_BASE_URL = import.meta.env.VITE_API_BASE_URL || '/api'
    2: 
    3: function normalizePath(path: string): string {
    4:   return path.startsWith('/') ? path : `/${path}`
    5: }
    6: 
    7: export function buildApiUrl(path: string): string {
    8:   const baseUrl = API_BASE_URL.replace(/\/+$/, '')
    9:   return `${baseUrl}${normalizePath(path)}`
   10: }
   11: 
   12: export function buildAbsoluteApiUrl(path: string): string {
   13:   return new URL(buildApiUrl(path), window.location.origin).toString()
   14: }
   15: 
   16: export function getFrontendOrigin(): string {
   17:   return window.location.origin
   18: }
   19: 
   20: export function buildPublicApiUrl(path: string): string {
   21:   return new URL(`/api${normalizePath(path)}`, getFrontendOrigin()).toString()
   22: }
   23: 
   24: export function buildApiWebSocketUrl(path: string): string {
   25:   const apiUrl = new URL(API_BASE_URL, window.location.origin)
   26:   const protocol = apiUrl.protocol === 'https:' ? 'wss:' : 'ws:'
   27:   const apiPath = apiUrl.pathname.replace(/\/+$/, '')
   28:   return `${protocol}//${apiUrl.host}${apiPath}${normalizePath(path)}`
   29: }
