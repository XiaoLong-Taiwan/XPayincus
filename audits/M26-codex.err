   41:     },
   42:     // 亮色主题
   43:     light: {
   44:         name: 'light',
   45:         background: '#ffffff',
   46:         foreground: '#1a1a1a',
   47:         cursor: '#1a1a1a',
   48:         cursorAccent: '#ffffff',
   49:         selectionBackground: '#b4d7ff',
   50:         selectionForeground: '#1a1a1a',
   51:         black: '#1a1a1a',
   52:         red: '#c41a16',
   53:         green: '#007400',
   54:         yellow: '#aa5500',
   55:         blue: '#0451a5',
   56:         magenta: '#bc05bc',
   57:         cyan: '#0598bc',
   58:         white: '#e0e0e0',
   59:         brightBlack: '#666666',
   60:         brightRed: '#ff6b6b',
   61:         brightGreen: '#5cb85c',
   62:         brightYellow: '#f0ad4e',
   63:         brightBlue: '#5bc0de',
