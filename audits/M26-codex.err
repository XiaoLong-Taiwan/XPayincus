  401: const router = createRouter({
  402:   history: createWebHistory(),
  403:   routes,
  404:   // 页面切换时滚动到顶部，解决页面切换后空白问题
  405:   scrollBehavior(_to, _from, savedPosition) {
  406:     if (_to.path === _from.path && _to.hash === _from.hash) {
  407:       return false
  408:     }
  409:     if (savedPosition) {
  410:       return savedPosition
  411:     }
  412:     return { top: 0, behavior: 'instant' }
  413:   }
  414: })
  415: 
  416: // 路由错误处理 - 捕获组件加载失败
