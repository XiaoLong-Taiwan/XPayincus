    1: import { ref, type Ref } from 'vue'
    2: import type { Toast } from '@/types/store.js'
    3: 
    4: const toasts: Ref<Toast[]> = ref([])
    5: let nextId = 0
    6: 
    7: type ToastType = 'success' | 'error' | 'warning' | 'info'
    8: 
    9: export function useToast() {
   10:   function show(message: string, type: ToastType = 'info', duration: number = 3000): number {
   11:     const id = nextId++
   12:     toasts.value.push({ id, message, type, duration, visible: true })
   13:     
   14:     if (duration > 0) {
   15:       setTimeout(() => {
   16:         remove(id)
   17:       }, duration)
   18:     }
   19:     
   20:     return id
   21:   }
   22: 
   23:   function remove(id: number) {
   24:     const index = toasts.value.findIndex(t => t.id === id)
   25:     if (index > -1) {
   26:       toasts.value[index].visible = false
   27:       setTimeout(() => {
   28:         toasts.value = toasts.value.filter(t => t.id !== id)
   29:       }, 200)
   30:     }
   31:   }
   32: 
   33:   function success(message: string, duration?: number): number {
   34:     return show(message, 'success', duration)
   35:   }
   36: 
   37:   function error(message: string, duration?: number): number {
   38:     return show(message, 'error', duration)
   39:   }
   40: 
   41:   function warning(message: string, duration?: number): number {
   42:     return show(message, 'warning', duration)
   43:   }
   44: 
   45:   function info(message: string, duration?: number): number {
   46:     return show(message, 'info', duration)
   47:   }
   48: 
   49:   return {
   50:     toasts,
   51:     show,
   52:     remove,
   53:     success,
   54:     error,
   55:     warning,
   56:     info
   57:   }
   58: }
