   58: // 判断是否应该缓存该请求
   59: function shouldCache(url) {
   60:   // 检查是否是网络优先的路径
   61:   for (const pattern of NETWORK_ONLY_PATTERNS) {
   62:     if (url.pathname.includes(pattern)) {
   63:       return false
   64:     }
   65:   }
   66: 
   67:   // 只缓存同源请求
   68:   if (url.origin !== self.location.origin) {
   69:     return false
   70:   }
   71: 
   72:   // 检查文件扩展名
   73:   const pathname = url.pathname.toLowerCase()
   74:   return CACHEABLE_EXTENSIONS.some(ext => pathname.endsWith(ext))
   75: }
   76: 
   77: // 拦截请求
   78: self.addEventListener('fetch', (event) => {
   79:   const url = new URL(event.request.url)
   80: 
   81:   // 只处理 GET 请求
   82:   if (event.request.method !== 'GET') {
   83:     return
   84:   }
   85: 
   86:   // 页面导航请求不做离线接管：
   87:   // 当前策略不缓存 HTML，如果这里兜底到缓存首页，会把瞬时网络抖动放大成“离线状态”。
   88:   if (event.request.mode === 'navigate') {
   89:     return
   90:   }
   91: 
   92:   // 可缓存的静态资源 - 网络优先，缓存兜底。
   93:   // OTA 后旧客户端可能还持有上一版 worker；网络优先可以避免继续使用旧 chunk/CSS。
   94:   if (shouldCache(url)) {
   95:     event.respondWith(
   96:       fetch(event.request)
   97:         .then(networkResponse => {
   98:           if (networkResponse && networkResponse.status === 200) {
   99:             const responseToCache = networkResponse.clone()
  100:             event.waitUntil(
  101:               caches.open(CACHE_NAME).then(cache => {
  102:                 cache.put(event.request, responseToCache)
  103:               })
  104:             )
  105:           }
  106:           return networkResponse
  107:         })
  108:         .catch(() => {
  109:           return caches.match(event.request).then(cachedResponse => cachedResponse || Response.error())
  110:         })
  111:     )
  112:     return
  113:   }
  114: 
  115:   // 其他请求直接走网络
  116: })
  117: 
  118: // 监听消息（用于手动清除缓存等操作）
  119: self.addEventListener('message', (event) => {
  120:   if (event.data && event.data.type === 'CLEAR_CACHE') {
