  307: const router = createRouter({
  308:   history: createWebHistory(),
  309:   routes,
  310:   // 页面切换时滚动到顶部，解决页面切换后空白问题
  311:   scrollBehavior(_to, _from, savedPosition) {
  312:     if (_to.path === _from.path && _to.hash === _from.hash) {
  313:       return false
  314:     }
  315:     if (savedPosition) {
  316:       return savedPosition
  317:     }
  318:     return { top: 0, behavior: 'instant' }
  319:   }
  320: })
  321: 
  322: // 路由错误处理 - 捕获组件加载失败
  323: router.onError((error) => {
  324:   console.error('路由错误:', error)
  325:   console.error('错误详情:', {
  326:     message: error.message,
  327:     name: error.name,
  328:     stack: error.stack,
  329:     url: window.location.href
  330:   })
  331:   // 如果是组件加载失败，说明客户端还持有旧版本 chunk，刷新到新版本。
  332:   if (isStaleAssetLoadError(error)) {
  333:     scheduleStaleAssetReload('user-router-error', error)
  334:   }
  335: })
  336: 
  337: // Route guard
  338: router.beforeEach(async (to: RouteLocationNormalized, _from: RouteLocationNormalized, next: NavigationGuardNext) => {
  339:   const authStore = useAuthStore()
  340:   const configStore = useConfigStore()
  341: 
  342:   // 检查是否有 OAuth 登录码需要处理
  343:   const urlParams = new URLSearchParams(window.location.search)
  344:   if (urlParams.has('oauth_code')) {
  345:     // 先处理 OAuth 登录码，等待完成
  346:     await handleOAuthCode()
  347:   }
  348: 
  349:   // 如果有 token 但用户信息还没加载，先等待加载完成
  350:   if (authStore.isAuthenticated && !authStore.user) {
  351:     try {
  352:       await authStore.fetchCurrentUser()
  353:     } catch {
  354:       // 加载失败，token 可能无效，会被 logout 清除
  355:     }
  356:   }
  357:   
  358:   // 如果配额信息未加载，尝试重新获取
  359:   if (authStore.isAuthenticated && !authStore.quota && authStore.user) {
  360:     try {
  361:       await authStore.fetchCurrentUser()
  362:     } catch {
  363:       // 静默失败
  364:     }
  365:   }
  366: 
  367:   // Pages requiring authentication
  368:   if (to.meta.requiresAuth && !authStore.isAuthenticated) {
  369:     next({ name: 'login', query: { redirect: to.fullPath } })
  370:     return
  371:   }
  372: 
  373:   if (to.name === 'tickets' && authStore.isAuthenticated && !authStore.isAdmin) {
  374:     await configStore.loadPublicConfig()
  375:     if (!configStore.ticketEnabled) {
  376:       next({ name: 'dashboard' })
  377:       return
  378:     }
  379:   }
  380: 
  381:   if (
  382:     authStore.isAuthenticated &&
  383:     !authStore.isAdmin &&
  384:     typeof to.name === 'string' &&
  385:     hiddenMailRouteNames.has(to.name)
  386:   ) {
  387:     await configStore.loadPublicConfig()
  388:     if (!configStore.mailAvailable) {
  389:       next({ name: 'dashboard' })
  390:       return
  391:     }
  392:   }
  393: 
  394:   // Pages requiring user (non-admin) permission
  395:   // 管理员误入用户端：只清本标签页内存态并跳转，不调用后端登出/不清共享 token，
  396:   // 否则会通过 storage 事件把管理端的合法会话一起登出（跨端 ping-pong）。
  397:   if ((to.meta.requiresAuth || to.meta.requiresUser) && authStore.isAdmin) {
  398:     authStore.clearInMemoryAuth()
  399:     next({ name: 'login', query: { adminOnly: '1' } })
  400:     return
  401:   }
  402: 
  403:   if (
  404:     !authStore.isAdmin &&
  405:     typeof to.name === 'string' &&
  406:     hiddenHostingRouteNames.has(to.name) &&
  407:     authStore.user?.canAccessHostingFeature === false
  408:   ) {
  409:     next({ name: 'dashboard' })
  410:     return
  411:   }
  412: 
  413:   // 配额检查：普通用户不再需要配额检查（好友、节点、套餐功能已移除）
  414: 
  415:   // Authenticated users accessing login/register pages
  416:   if (to.meta.guest && authStore.isAuthenticated) {
  417:     if (authStore.isAdmin) {
  418:       // 同上：不清共享 token，避免把管理端会话一起登出
  419:       authStore.clearInMemoryAuth()
  420:       next({ name: 'login', query: { adminOnly: '1' } })
  421:       return
  422:     }
  423:     next({ name: 'dashboard', replace: true })
  424:     return
  425:   }
  426: 
  427:   next()
