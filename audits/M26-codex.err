   70:         name: 'highContrast',
   71:         background: '#000000',
   72:         foreground: '#ffffff',
   73:         cursor: '#00ff00',
   74:         cursorAccent: '#000000',
   75:         selectionBackground: '#ffff00',
   76:         selectionForeground: '#000000',
   77:         black: '#000000',
   78:         red: '#ff0000',
   79:         green: '#00ff00',
   80:         yellow: '#ffff00',
   81:         blue: '#0080ff',
   82:         magenta: '#ff00ff',
   83:         cyan: '#00ffff',
   84:         white: '#ffffff',
   85:         brightBlack: '#808080',
   86:         brightRed: '#ff8080',
   87:         brightGreen: '#80ff80',
   88:         brightYellow: '#ffff80',
   89:         brightBlue: '#80c0ff',
   90:         brightMagenta: '#ff80ff',
   91:         brightCyan: '#80ffff',
   92:         brightWhite: '#ffffff'
   93:     }
   94: } as const
   95: 
   96: // localStorage 存储键
   97: const STORAGE_KEY = 'incudal_terminal_settings'
   98: 
   99: // 默认设置
  100: const DEFAULT_SETTINGS = {
  101:     fontSize: 14,
  102:     theme: 'dark' as TerminalThemeType,
  103:     bellEnabled: false,           // 终端铃声（默认关闭）
  104:     autoCopyOnSelect: false,      // 选中自动复制（默认关闭）
  105:     linkPreview: true,            // 链接预览（默认开启）
  106:     touchEnabled: true,           // 触控优化（默认开启）
  107:     commandHistory: [] as string[], // 命令历史
  108:     commandHistoryLimit: 100,     // 历史命令数量限制
  109: }
  110: 
  111: type TerminalSettings = typeof DEFAULT_SETTINGS
  112: 
  113: /**
  114:  * 从 localStorage 读取设置
  115:  */
  116: function loadSettings(): TerminalSettings {
  117:     try {
  118:         const stored = localStorage.getItem(STORAGE_KEY)
  119:         if (stored) {
  120:             const parsed = JSON.parse(stored)
  121:             // 合并默认值，确保新增字段有默认值
  122:             return { ...DEFAULT_SETTINGS, ...parsed }
  123:         }
  124:     } catch (err) {
  125:         console.warn('[Terminal Store] Failed to load settings:', err)
  126:     }
  127:     return { ...DEFAULT_SETTINGS }
  128: }
  129: 
  130: /**
  131:  * 保存设置到 localStorage
  132:  */
  133: function saveSettings(settings: TerminalSettings): void {
  134:     try {
  135:         localStorage.setItem(STORAGE_KEY, JSON.stringify(settings))
  136:     } catch (err) {
  137:         console.warn('[Terminal Store] Failed to save settings:', err)
  138:     }
  139: }
  140: 
  141: export const useTerminalStore = defineStore('terminal', () => {
  142:     // 从 localStorage 加载初始设置
  143:     const initialSettings = loadSettings()
  144:     
  145:     // 响应式设置
  146:     const fontSize = ref(initialSettings.fontSize)
  147:     const theme = ref<TerminalThemeType>(initialSettings.theme)
  148:     const bellEnabled = ref(initialSettings.bellEnabled)
  149:     const autoCopyOnSelect = ref(initialSettings.autoCopyOnSelect)
  150:     const linkPreview = ref(initialSettings.linkPreview)
  151:     const touchEnabled = ref(initialSettings.touchEnabled)
  152:     const commandHistory = ref<string[]>(initialSettings.commandHistory)
  153:     const commandHistoryLimit = ref(initialSettings.commandHistoryLimit)
  154:     
  155:     // 计算属性：当前主题配置
  156:     const currentTheme = computed(() => TERMINAL_THEMES[theme.value])
  157:     
  158:     // 监听变化并自动保存
  159:     watch(
  160:         [fontSize, theme, bellEnabled, autoCopyOnSelect, linkPreview, touchEnabled, commandHistory, commandHistoryLimit],
  161:         () => {
  162:             saveSettings({
  163:                 fontSize: fontSize.value,
  164:                 theme: theme.value,
  165:                 bellEnabled: bellEnabled.value,
  166:                 autoCopyOnSelect: autoCopyOnSelect.value,
  167:                 linkPreview: linkPreview.value,
  168:                 touchEnabled: touchEnabled.value,
  169:                 commandHistory: commandHistory.value,
  170:                 commandHistoryLimit: commandHistoryLimit.value,
  171:             })
  172:         },
  173:         { deep: true }
  174:     )
  175:     
  176:     /**
  177:      * 设置字体大小
  178:      */
  179:     function setFontSize(size: number) {
  180:         fontSize.value = Math.max(8, Math.min(32, size))
  181:     }
  182:     
  183:     /**
  184:      * 增大字体
  185:      */
  186:     function increaseFontSize() {
  187:         setFontSize(fontSize.value + 2)
  188:     }
  189:     
  190:     /**
  191:      * 减小字体
  192:      */
  193:     function decreaseFontSize() {
  194:         setFontSize(fontSize.value - 2)
  195:     }
  196:     
  197:     /**
  198:      * 重置字体大小
  199:      */
  200:     function resetFontSize() {
  201:         setFontSize(DEFAULT_SETTINGS.fontSize)
  202:     }
  203:     
  204:     /**
  205:      * 设置主题
  206:      */
  207:     function setTheme(newTheme: TerminalThemeType) {
  208:         theme.value = newTheme
  209:     }
  210:     
  211:     /**
  212:      * 切换终端铃声
  213:      */
  214:     function toggleBell() {
  215:         bellEnabled.value = !bellEnabled.value
  216:     }
  217:     
  218:     /**
  219:      * 切换选中自动复制
  220:      */
  221:     function toggleAutoCopy() {
  222:         autoCopyOnSelect.value = !autoCopyOnSelect.value
  223:     }
  224:     
  225:     /**
  226:      * 切换触控优化
  227:      */
  228:     function toggleTouch() {
  229:         touchEnabled.value = !touchEnabled.value
  230:     }
  231:     
  232:     /**
  233:      * 添加命令到历史
  234:      */
  235:     function addToHistory(command: string) {
  236:         if (!command.trim()) return
  237:         
  238:         // 去除重复
  239:         const index = commandHistory.value.indexOf(command)
  240:         if (index !== -1) {
  241:             commandHistory.value.splice(index, 1)
  242:         }
  243:         
  244:         // 添加到开头
  245:         commandHistory.value.unshift(command)
  246:         
  247:         // 限制数量
  248:         if (commandHistory.value.length > commandHistoryLimit.value) {
  249:             commandHistory.value = commandHistory.value.slice(0, commandHistoryLimit.value)
  250:         }
  251:     }
  252:     
  253:     /**
  254:      * 清空命令历史
  255:      */
  256:     function clearHistory() {
  257:         commandHistory.value = []
  258:     }
  259:     
  260:     /**
  261:      * 播放终端铃声
  262:      */
  263:     function playBell() {
  264:         if (!bellEnabled.value) return
  265:         
  266:         try {
  267:             // 使用 Web Audio API 生成简短的铃声
  268:             const audioContext = new (window.AudioContext || (window as unknown as { webkitAudioContext: typeof AudioContext }).webkitAudioContext)()
  269:             const oscillator = audioContext.createOscillator()
  270:             const gainNode = audioContext.createGain()
  271:             
  272:             oscillator.connect(gainNode)
  273:             gainNode.connect(audioContext.destination)
  274:             
  275:             oscillator.frequency.value = 800 // Hz
  276:             oscillator.type = 'sine'
  277:             
  278:             gainNode.gain.setValueAtTime(0.1, audioContext.currentTime)
  279:             gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.1)
  280:             
  281:             oscillator.start(audioContext.currentTime)
  282:             oscillator.stop(audioContext.currentTime + 0.1)
  283:             
  284:             // 铃声结束后关闭 AudioContext 释放资源
  285:             oscillator.onended = () => {
  286:                 audioContext.close().catch(() => {})
  287:             }
  288:         } catch {
  289:             // 音频 API 不可用，静默失败
  290:         }
  291:     }
  292:     
  293:     /**
  294:      * 重置所有设置
  295:      */
  296:     function resetAllSettings() {
  297:         fontSize.value = DEFAULT_SETTINGS.fontSize
  298:         theme.value = DEFAULT_SETTINGS.theme
  299:         bellEnabled.value = DEFAULT_SETTINGS.bellEnabled
  300:         autoCopyOnSelect.value = DEFAULT_SETTINGS.autoCopyOnSelect
  301:         linkPreview.value = DEFAULT_SETTINGS.linkPreview
  302:         touchEnabled.value = DEFAULT_SETTINGS.touchEnabled
  303:         // 保留命令历史
  304:     }
  305:     
  306:     return {
  307:         // 状态
  308:         fontSize,
  309:         theme,
  310:         bellEnabled,
  311:         autoCopyOnSelect,
  312:         linkPreview,
  313:         touchEnabled,
  314:         commandHistory,
  315:         commandHistoryLimit,
  316:         currentTheme,
  317:         
  318:         // 方法
  319:         setFontSize,
  320:         increaseFontSize,
  321:         decreaseFontSize,
  322:         resetFontSize,
  323:         setTheme,
  324:         toggleBell,
  325:         toggleAutoCopy,
  326:         toggleTouch,
  327:         addToHistory,
  328:         clearHistory,
  329:         playBell,
  330:         resetAllSettings,
  331:     }
  332: })
FILE client/src/stores/theme.ts
    1: /**
    2:  * 主题管理 Store
    3:  * 支持浅色/深色/跟随系统模式
    4:  */
    5: import { defineStore } from 'pinia'
    6: import { ref, watch, computed, type Ref } from 'vue'
    7: import { buildApiUrl } from '@/utils/api-url'
    8: 
    9: type ThemeMode = 'light' | 'dark' | 'system'
   10: const ACTIVE_THEME_LINK_ID = 'payincus-active-theme-css'
   11: 
   12: export const useThemeStore = defineStore('theme', () => {
   13:   // 主题模式: 'light' | 'dark' | 'system'
   14:   const mode: Ref<ThemeMode> = ref((localStorage.getItem('theme') as ThemeMode) || 'system')
   15:   const activeThemeId = ref<string | null>(null)
   16:   const activeThemeCssUrl = ref<string | null>(null)
   17:   const activeThemeTemplateUrls = ref<Record<string, { title: string; url: string }>>({})
   18: 
   19:   // 实际应用的主题
   20:   const resolvedTheme = computed(() => {
   21:     if (mode.value === 'system') {
   22:       return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
   23:     }
   24:     return mode.value
   25:   })
   26: 
   27:   // 是否为深色主题
   28:   const isDark = computed(() => resolvedTheme.value === 'dark')
   29: 
   30:   // 将主题应用到 DOM
   31:   function applyTheme() {
   32:     const theme = resolvedTheme.value
   33:     document.documentElement.classList.remove('light', 'dark')
   34:     document.documentElement.classList.add(theme)
   35: 
   36:     // 更新 meta 主题色
   37:     const metaThemeColor = document.querySelector('meta[name="theme-color"]')
   38:     if (metaThemeColor) {
   39:       metaThemeColor.setAttribute('content', theme === 'dark' ? '#0a0a0a' : '#ffffff')
   40:     }
   41:   }
   42: 
   43:   function normalizeAssetUrl(url: string): string {
   44:     if (/^https?:\/\//i.test(url)) return url
   45:     if (url.startsWith('/api/')) return url
   46:     return buildApiUrl(url)
   47:   }
   48: 
   49:   function removeActiveThemeLink() {
   50:     const existing = document.getElementById(ACTIVE_THEME_LINK_ID)
   51:     if (existing?.parentNode) existing.parentNode.removeChild(existing)
   52:     activeThemeId.value = null
   53:     activeThemeCssUrl.value = null
   54:     activeThemeTemplateUrls.value = {}
   55:   }
   56: 
   57:   function applyActiveThemeLink(cssUrl: string) {
   58:     const href = normalizeAssetUrl(cssUrl)
   59:     let link = document.getElementById(ACTIVE_THEME_LINK_ID) as HTMLLinkElement | null
   60:     if (!link) {
   61:       link = document.createElement('link')
   62:       link.id = ACTIVE_THEME_LINK_ID
   63:       link.rel = 'stylesheet'
   64:       document.head.appendChild(link)
   65:     }
   66:     if (link.href !== new URL(href, window.location.origin).href) {
   67:       link.href = href
   68:     }
   69:     activeThemeCssUrl.value = href
   70:   }
   71: 
   72:   async function loadActiveTheme() {
   73:     try {
   74:       const response = await fetch(buildApiUrl('/themes/active'), {
   75:         headers: { Accept: 'application/json' },
   76:         credentials: 'include'
   77:       })
   78:       if (!response.ok) {
   79:         removeActiveThemeLink()
   80:         return
   81:       }
   82:       const data = await response.json() as { theme?: { themeId?: string; cssUrl?: string; templateUrls?: Record<string, { title: string; url: string }> } | null }
   83:       if (!data.theme?.themeId || !data.theme.cssUrl) {
   84:         removeActiveThemeLink()
   85:         return
   86:       }
   87:       activeThemeId.value = data.theme.themeId
   88:       activeThemeTemplateUrls.value = data.theme.templateUrls || {}
   89:       applyActiveThemeLink(data.theme.cssUrl)
   90:     } catch {
   91:       removeActiveThemeLink()
   92:     }
   93:   }
   94: 
   95:   function getActiveThemeTemplateUrl(slot: string): string | null {
   96:     const template = activeThemeTemplateUrls.value[slot]
   97:     return template?.url ? normalizeAssetUrl(template.url) : null
   98:   }
   99: 
  100:   // 设置主题模式
  101:   function setTheme(newMode: ThemeMode) {
  102:     mode.value = newMode
  103:     localStorage.setItem('theme', newMode)
  104:     applyTheme()
  105:   }
  106: 
  107:   // 切换主题 (dark -> light -> system -> dark)
  108:   function toggleTheme() {
  109:     const modes: ThemeMode[] = ['dark', 'light', 'system']
  110:     const currentIndex = modes.indexOf(mode.value)
  111:     const nextIndex = (currentIndex + 1) % modes.length
  112:     setTheme(modes[nextIndex])
  113:   }
  114: 
  115:   // 监听系统主题变化
  116:   function setupSystemThemeListener() {
  117:     const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)')
  118:     mediaQuery.addEventListener('change', () => {
  119:       if (mode.value === 'system') {
  120:         applyTheme()
  121:       }
  122:     })
  123:   }
