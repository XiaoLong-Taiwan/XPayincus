 2578:   // 工单系统
 2579:   tickets: {
 2580:     // 创建工单
 2581:     create: (data: CreateTicketRequest): Promise<{ message: string; ticket: { id: number; messageId: number } }> =>
 2582:       (data.attachments && data.attachments.length > 0)
 2583:         ? http.post('/tickets', buildTicketFormData(data), { headers: { 'Content-Type': 'multipart/form-data' }, timeout: TIMEOUT.MEDIUM })
 2584:         : http.post('/tickets', {
 2585:             instanceId: data.instanceId,
 2586:             subject: data.subject,
 2587:             category: data.category,
 2588:             priority: data.priority,
 2589:             content: data.content
 2590:           }),
 2591: 
 2592:     // 获取我的工单列表（支持 active 状态筛选和搜索）
 2593:     list: (params?: { status?: TicketStatus | 'active'; search?: string; page?: number; pageSize?: number }): Promise<PaginatedTickets> =>
 2594:       http.get('/tickets', { params }),
 2595: 
 2596:     // 获取工单详情
 2597:     get: (id: number): Promise<{ ticket: Ticket; isOwner: boolean; isCreator: boolean }> =>
 2598:       http.get(`/tickets/${id}`),
 2599: 
 2600:     // 获取工单消息列表
 2601:     getMessages: (id: number, params?: { page?: number; pageSize?: number }): Promise<PaginatedTicketMessages> =>
 2602:       http.get(`/tickets/${id}/messages`, { params }),
 2603: 
 2604:     // 获取后台客服工作台上下文（仅管理员）
 2605:     getSupportContext: (id: number): Promise<TicketSupportContext> =>
 2606:       http.get(`/tickets/${id}/support-context`),
 2607: 
 2608:     // 生成 AI 回复草稿（仅管理员，插件启用后可用，不会自动发送）
 2609:     generateAiDraft: (id: number): Promise<TicketAiDraftResponse> =>
 2610:       http.post(`/tickets/${id}/ai/draft`, {}, { timeout: TIMEOUT.MEDIUM }),
 2611: 
 2612:     // 由 AI 工单插件生成并发送回复（仅管理员，要求插件 reply 权限和非草稿模式）
 2613:     sendAiReply: (id: number): Promise<TicketAiReplyResponse> =>
 2614:       http.post(`/tickets/${id}/ai/reply`, {}, { timeout: TIMEOUT.MEDIUM }),
 2615: 
 2616:     // 创建内部备注（仅管理员）
 2617:     createInternalNote: (id: number, content: string): Promise<{ note: TicketInternalNote }> =>
 2618:       http.post(`/tickets/${id}/internal-notes`, { content }),
 2619: 
 2620:     // 关联客服处理对象（仅管理员）
 2621:     linkObject: (id: number, objectType: TicketObjectLinkType, objectId: number): Promise<{ link: TicketObjectLink }> =>
 2622:       http.post(`/tickets/${id}/links`, { objectType, objectId }),
 2623: 
 2624:     // 从客服工作台发送用户通知（仅管理员）
 2625:     notifyUser: (id: number, content: string): Promise<{ message: string }> =>
 2626:       http.post(`/tickets/${id}/notify`, { content }),
 2627: 
 2628:     // 回复工单
 2629:     reply: (id: number, content: string, attachments?: File[]): Promise<{ message: string; data: TicketMessage }> =>
 2630:       (attachments && attachments.length > 0)
 2631:         ? http.post(`/tickets/${id}/messages`, buildTicketFormData({ content, attachments }), { headers: { 'Content-Type': 'multipart/form-data' }, timeout: TIMEOUT.MEDIUM })
 2632:         : http.post(`/tickets/${id}/messages`, { content }),
 2633: 
 2634:     // 读取工单图片内容
 2635:     getAttachmentContent: (attachmentId: number): Promise<Blob> =>
 2636:       http.get(`/tickets/attachments/${attachmentId}/content`, { responseType: 'blob', timeout: TIMEOUT.MEDIUM }),
 2637: 
 2638:     // 删除工单消息（仅管理员）
 2639:     deleteMessage: (ticketId: number, messageId: number): Promise<{ message: string }> =>
 2640:       http.delete(`/tickets/${ticketId}/messages/${messageId}`),
 2641: 
 2642:     // 更新工单状态（宿主机所有者）
