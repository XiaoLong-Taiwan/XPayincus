   56: 
   57: function validateTarEntryLine(line: string): void {
   58:   const trimmed = line.trim()
   59:   if (!trimmed) return
   60:   const name = trimmed.split(/\s+/).slice(5).join(' ')
   61:   const type = trimmed[0]
   62:   if (!name) throw new Error('Plugin package contains an unreadable tar entry')
   63:   if (type === 'l' || type === 'h') throw new Error('Plugin package cannot contain links')
   64:   if (name.startsWith('/') || name.includes('../') || name === '..' || name.includes('\\')) {
   65:     throw new Error(`Plugin package contains unsafe path: ${name}`)
   66:   }
   67: }
   68: 
   69: async function validateTarball(path: string): Promise<void> {
   70:   const { stdout } = await execFileAsync('tar', ['-tvf', path], { timeout: 30000, maxBuffer: 1024 * 1024 * 4 })
   71:   const lines = stdout.split(/\r?\n/).filter(Boolean)
   72:   if (!lines.some(line => line.endsWith(' payincus.plugin.json') || line.endsWith('/payincus.plugin.json'))) {
   73:     throw new Error('Plugin package is missing payincus.plugin.json')
   74:   }
   75:   for (const line of lines) validateTarEntryLine(line)
   76: }
   77: 
   78: export async function validateAndExtractPluginPackage(packagePath: string, taskId: number): Promise<ValidatedPluginPackage> {
   79:   await validateTarball(packagePath)
   80: 
   81:   const sha256 = await sha256File(packagePath)
   82:   const stagingRoot = getPluginStagingDir()
   83:   await mkdir(stagingRoot, { recursive: true })
   84:   const stagingDir = join(stagingRoot, `plugin-task-${taskId}`)
   85:   await rm(stagingDir, { recursive: true, force: true })
   86:   await mkdir(stagingDir, { recursive: true })
   87:   await execFileAsync('tar', ['-xzf', packagePath, '-C', stagingDir], { timeout: 30000 })
   88: 
   89:   const manifestPath = resolveInside(stagingDir, 'payincus.plugin.json')
   90:   const manifest = parsePluginManifest(JSON.parse(await readFile(manifestPath, 'utf8')))
   91: 
   92:   for (const page of [...(manifest.entrypoints.adminPages || []), ...(manifest.entrypoints.userPages || [])]) {
   93:     await readFile(resolveInside(stagingDir, page.entry))
   94:   }
   95:   for (const template of manifest.templates || []) {
   96:     await readFile(resolveInside(stagingDir, template.path))
   97:   }
   98: 
   99:   return { manifest, sha256, stagingDir }
  100: }

