  918:       LogModule.PLUGIN,
  919:       'plugin.market_submission.scan',
  920:       `Scanned plugin market submission ${submission.pluginId}@${submission.version}: ${result.status}/${result.riskLevel}`,
  921:       result.status === 'failed' ? LogResult.WARNING : LogResult.SUCCESS
  922:     )
  923: 
