  161: async function finalizePluginEventDedupeLock(input: {
  162:   pluginId: string
  163:   eventName: string
  164:   handler: string
  165:   dedupeKey: string | null
  166:   eventLogId: number
  167:   status: 'success' | 'retry_pending' | 'dead_letter'
  168: }): Promise<void> {
  169:   if (!input.dedupeKey) return
  170:   await prisma.pluginEventDedupeLock.updateMany({
  171:     where: {
  172:       pluginId: input.pluginId,
  173:       eventName: input.eventName,
  174:       handler: input.handler,
  175:       dedupeKey: input.dedupeKey
  176:     },
  177:     data: {
  178:       status: input.status,
  179:       eventLogId: input.eventLogId,
  180:       expiresAt: null
  181:     }
  182:   })
  183: }
