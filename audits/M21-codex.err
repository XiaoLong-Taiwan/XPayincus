  250: async function canManagePlugins(user: { id: number; username: string; role: 'admin' | 'user' }): Promise<boolean> {
  251:   if (user.role !== 'admin') return false
  252:   const { ids: allowedIds } = await getCombinedAdminIdAllowlist(
  253:     'plugin_manager_allowed_admin_ids',
  254:     ['PLUGIN_MANAGER_ALLOWED_ADMIN_IDS', 'SYSTEM_UPDATE_ALLOWED_ADMIN_IDS']
  255:   )
  256:   if (allowedIds.size > 0) return allowedIds.has(user.id)
  257:   return user.username === 'admin'
  258: }
  259: 
  260: async function requirePluginManager(request: FastifyRequest, reply: FastifyReply): Promise<boolean> {
  261:   const user = getRequestUser(request)
  262:   if (!(await canManagePlugins(user))) {
  263:     await createLog(
  264:       user.id,
  265:       LogModule.PLUGIN,
  266:       'plugin.manager.denied',
  267:       `Denied plugin management access for ${user.username}`,
  268:       LogResult.WARNING
  269:     )
  270:     reply.code(403).send({ error: 'Super administrator privileges required', code: 'SUPER_ADMIN_REQUIRED' })
  271:     return false
  272:   }
  273:   return true
  274: }
