  314: function normalizePluginConfigKey(value: string): string | null {
  315:   const trimmed = value.trim()
  316:   return /^[A-Za-z][A-Za-z0-9_.-]{0,79}$/.test(trimmed) ? trimmed : null
  317: }
  318: 
  319: function pluginConfigFileContentType(filename: string): string {
  320:   const ext = extname(filename).toLowerCase()
  321:   if (ext === '.png') return 'image/png'
  322:   if (ext === '.jpg' || ext === '.jpeg') return 'image/jpeg'
  323:   if (ext === '.webp') return 'image/webp'
  324:   return 'application/octet-stream'
  325: }
  326: 
  327: async function writePluginConfigFileUpload(request: FastifyRequest, pluginId: string, key: string): Promise<{
  328:   filename: string
  329:   mimeType: string
  330:   sizeBytes: number
  331:   value: string
  332: }> {
  333:   const multipartRequest = request as FastifyRequest & {
  334:     parts: () => AsyncIterable<any>
  335:   }
  336:   const uploadDir = resolveInside(getPluginDataDir(), join('config-files', pluginId, key))
  337:   await mkdir(uploadDir, { recursive: true })
  338: 
  339:   for await (const part of multipartRequest.parts()) {
  340:     if (part.type !== 'file') continue
  341:     const mimeType = String(part.mimetype || '').toLowerCase()
  342:     const ext = PLUGIN_CONFIG_FILE_MIME_EXTENSIONS.get(mimeType)
  343:     if (!ext) {
  344:       await part.toBuffer()
  345:       throw new Error('Plugin config file must be a PNG, JPEG, or WebP image')
  346:     }
  347:     const buffer = await part.toBuffer()
  348:     if (buffer.length === 0) throw new Error('Plugin config file is empty')
  349:     if (buffer.length > PLUGIN_CONFIG_FILE_MAX_BYTES) throw new Error('Plugin config file exceeds 2MB')
  350:     const filename = `${Date.now()}-${randomUUID()}${ext}`
  351:     const filePath = resolveInside(uploadDir, filename)
  352:     await writeFile(filePath, buffer, { mode: 0o600 })
  353:     return {
  354:       filename,
  355:       mimeType: pluginConfigFileContentType(filename),
  356:       sizeBytes: buffer.length,
  357:       value: `/api/plugins/${encodeURIComponent(pluginId)}/config-files/${encodeURIComponent(key)}/${encodeURIComponent(filename)}`
  358:     }
  359:   }
  360: 
  361:   throw new Error('Missing plugin config file')
  362: }
  363: 
  364: async function installPackage(input: {
  365:   packagePath: string
  366:   sourceType: 'upload' | 'market'
  367:   sourceUrl?: string | null
  368:   sourceRepo?: string | null
  369:   userId: number
  370: }) {
  371:   const task = await createPluginTask({
  372:     action: input.sourceType === 'market' ? 'market_install' : 'upload_install',
  373:     sourceType: input.sourceType,
  374:     sourceUrl: input.sourceUrl || null,
  375:     startedByUserId: input.userId
  376:   })
  377:   const logPath = join(getPluginLogDir(), `plugin-task-${task.id}.log`)
  378:   await markPluginTaskRunning(task.id, logPath)
  379:   try {
  380:     await appendPluginTaskLog(logPath, `Validating ${input.sourceType} plugin package`)
  381:     const validated = await validateAndExtractPluginPackage(input.packagePath, task.id)
  382:     await appendPluginTaskLog(logPath, `Validated plugin ${validated.manifest.id}@${validated.manifest.version}`)
  383:     await installValidatedPlugin({
  384:       taskId: task.id,
  385:       stagingDir: validated.stagingDir,
  386:       manifest: validated.manifest,
  387:       packageSha256: validated.sha256,
  388:       sourceType: input.sourceType,
  389:       sourceRepo: input.sourceRepo || null,
  390:       installedByUserId: input.userId,
  391:       logPath
  392:     })
  393:     await markPluginTaskFinished(task.id, 'success')
  394:     await dispatchPluginLifecycleEvent({
  395:       event: 'plugin.installed',
  396:       pluginId: validated.manifest.id,
  397:       version: validated.manifest.version,
  398:       sourceType: input.sourceType,
  399:       sourceRepo: input.sourceRepo || null,
  400:       actor: { id: input.userId, role: 'admin' },
  401:       dedupeKey: `plugin.installed:${validated.manifest.id}:${validated.manifest.version}:${task.id}`
  402:     }).catch(error => {
  403:       const message = error instanceof Error ? error.message : String(error)
  404:       void appendPluginTaskLog(logPath, `Lifecycle event plugin.installed failed: ${message}`).catch(() => undefined)
  405:     })
  406:     return await getPluginTask(task.id)
  407:   } catch (error) {
  408:     const message = error instanceof Error ? error.message : String(error)
  409:     await appendPluginTaskLog(logPath, `FAILED: ${message}`).catch(() => undefined)
  410:     await markPluginTaskFinished(task.id, 'failed', message)
  411:     throw error
  412:   }
  413: }
