  415: function sanitizeConfigString(value: unknown, maxLength: number): string | null {
  416:   if (typeof value !== 'string') return null
  417:   const trimmed = value.trim()
  418:   if (!trimmed || trimmed.length > maxLength) return null
  419:   return trimmed
  420: }
  421: 
  422: function normalizePluginConfigValue(field: PluginConfigFieldManifest, rawValue: unknown, key: string): unknown {
  423:   const value = rawValue === undefined ? field.default : rawValue
  424:   if (field.type === 'placeholder') return undefined
  425:   if (field.secret && (value === undefined || value === null || value === '')) return undefined
  426:   if (value === undefined || value === null || value === '') {
  427:     if (field.required) throw new Error(`${key} is required`)
  428:     return undefined
  429:   }
  430: 
  431:   if (field.type === 'checkbox') return value === true
  432: 
  433:   if (field.type === 'number') {
  434:     const numericValue = typeof value === 'number' ? value : Number(value)
  435:     if (!Number.isFinite(numericValue)) throw new Error(`${key} must be a number`)
  436:     if (field.min !== undefined && numericValue < field.min) throw new Error(`${key} is below the minimum`)
  437:     if (field.max !== undefined && numericValue > field.max) throw new Error(`${key} exceeds the maximum`)
  438:     return numericValue
  439:   }
  440: 
  441:   if (field.type === 'tags') {
  442:     if (!Array.isArray(value)) throw new Error(`${key} must be an array`)
  443:     return Array.from(new Set(
  444:       value
  445:         .map(item => sanitizeConfigString(item, 80))
  446:         .filter((item): item is string => !!item)
  447:     )).slice(0, 60)
  448:   }
  449: 
  450:   const stringValue = sanitizeConfigString(value, field.type === 'textarea' || field.type === 'markdown' ? 4000 : 500)
  451:   if (!stringValue) {
  452:     if (field.required) throw new Error(`${key} is required`)
  453:     return undefined
  454:   }
  455:   if (field.type === 'select' && field.options?.length && !field.options.some(option => option.value === stringValue)) {
  456:     throw new Error(`${key} must match one of the configured options`)
  457:   }
  458:   if (field.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(stringValue)) {
  459:     throw new Error(`${key} must be a valid email`)
  460:   }
  461:   if (field.type === 'color' && !/^#(?:[0-9a-fA-F]{3}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$/.test(stringValue)) {
  462:     throw new Error(`${key} must be a hex color`)
  463:   }
  464:   if (field.type === 'file' && !/^\/api\/plugins\/[A-Za-z0-9.%_-]+\/config-files\/[A-Za-z0-9_.%-]+\/[0-9]+-[0-9a-f-]{36}\.(?:png|jpg|webp)$/.test(stringValue)) {
  465:     throw new Error(`${key} must be an uploaded plugin config file URL`)
  466:   }
  467:   return stringValue
  468: }
  469: 
  470: function normalizeConfigUpdates(body: ConfigUpdateBody, manifest?: PayIncusPluginManifest | null): Array<{ key: string; value: unknown; isSecret?: boolean }> {
  471:   if (!Array.isArray(body.configs)) throw new Error('configs must be an array')
  472:   const schema = manifest?.configSchema || {}
  473:   const schemaEntries = Object.entries(schema)
  474:   if (schemaEntries.length === 0) {
  475:     return body.configs.slice(0, 100).map(item => {
  476:       const key = String(item.key || '').trim()
  477:       if (!/^[A-Za-z0-9_.:-]{1,120}$/.test(key)) throw new Error('Invalid plugin config key')
  478:       return { key, value: item.value ?? null, isSecret: item.isSecret === true }
  479:     })
  480:   }
  481: 
  482:   const submitted = new Map<string, { value: unknown; isSecret?: boolean }>()
  483:   for (const item of body.configs.slice(0, 100)) {
  484:     const key = String(item.key || '').trim()
  485:     if (!schema[key]) throw new Error(`Plugin config key is not declared in manifest: ${key}`)
  486:     submitted.set(key, { value: item.value, isSecret: item.isSecret })
  487:   }
  488: 
  489:   const normalized: Array<{ key: string; value: unknown; isSecret?: boolean }> = []
  490:   for (const [key, field] of schemaEntries) {
  491:     const item = submitted.get(key)
  492:     const value = normalizePluginConfigValue(field, item?.value, key)
  493:     if (value === undefined) continue
  494:     normalized.push({
  495:       key,
  496:       value,
  497:       isSecret: field.secret === true || field.type === 'password' || item?.isSecret === true
  498:     })
  499:   }
  500:   return normalized
  501: }
  502: 
  503: function summarizeConfigKeys(keys: string[]): string {
  504:   if (keys.length === 0) return 'none'
  505:   const sorted = Array.from(new Set(keys)).sort()
  506:   const visible = sorted.slice(0, 20).join(', ')
  507:   return sorted.length > 20 ? `${visible}, +${sorted.length - 20} more` : visible
  508: }
  509: 
  510: function pluginConfigAuditSummary(input: {
  511:   pluginId: string
  512:   previousKeys: Set<string>
  513:   configs: Array<{ key: string; isSecret?: boolean }>
  514:   manifest?: PayIncusPluginManifest | null
  515: }): string {
  516:   const changedKeys = input.configs.map(config => config.key)
  517:   const createdKeys = changedKeys.filter(key => !input.previousKeys.has(key))
  518:   const updatedKeys = changedKeys.filter(key => input.previousKeys.has(key))
  519:   const secretKeys = input.configs.filter(config => config.isSecret === true).map(config => config.key)
  520:   const fileKeys = input.configs
  521:     .filter(config => input.manifest?.configSchema?.[config.key]?.type === 'file')
  522:     .map(config => config.key)
  523:   return [
  524:     `Updated plugin config for ${input.pluginId}`,
  525:     `changed=${changedKeys.length}`,
  526:     `created=[${summarizeConfigKeys(createdKeys)}]`,
  527:     `updated=[${summarizeConfigKeys(updatedKeys)}]`,
  528:     `secret=[${summarizeConfigKeys(secretKeys)}]`,
  529:     `file=[${summarizeConfigKeys(fileKeys)}]`,
  530:     'values=redacted'
  531:   ].join('; ')
  532: }
