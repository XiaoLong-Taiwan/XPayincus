  276: function validateLogPath(taskLogPath: string): string {
  277:   const logDir = resolve(getPluginLogDir())
  278:   const logPath = resolve(taskLogPath)
  279:   if (logPath !== logDir && !logPath.startsWith(`${logDir}${sep}`)) {
  280:     throw new Error('Plugin task log path is outside plugin log directory')
  281:   }
  282:   return logPath
  283: }
