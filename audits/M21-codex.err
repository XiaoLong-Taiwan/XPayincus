  905:     const status = normalizeCapabilityReviewStatus(request.body?.status)
  906:     if (!status) return reply.code(400).send({ error: 'Invalid capability review status', code: 'INVALID_PLUGIN_CAPABILITY_REVIEW_STATUS' })
  907:     const reviewNotes = normalizeCapabilityReviewNotes(request.body?.reviewNotes)
