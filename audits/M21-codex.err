  545:         prisma.pluginEventLog.count({ where: { ...scopedRecentWhere, result: 'retry_pending' } }),
  546:         prisma.pluginEventLog.count({ where: { ...scopedRecentWhere, result: 'dead_letter' } }),
  547:         prisma.pluginEventLog.count({ where: { ...scopedRecentWhere, result: 'duplicate_skipped' } }),
  548:         prisma.pluginEventLog.count({ where: { ...scopedRecentWhere, result: 'retry_pending', deadLetterAt: null, nextRetryAt: { lte: now } } }),
  549:         prisma.pluginEventLog.findFirst({ where: scopedWhere, orderBy: [{ lastAttemptAt: 'desc' }, { createdAt: 'desc' }] }),
  550:         prisma.pluginEventLog.findFirst({ where: { ...scopedWhere, result: 'success' }, orderBy: [{ lastAttemptAt: 'desc' }, { createdAt: 'desc' }] }),
  551:         prisma.pluginEventLog.findFirst({ where: { ...scopedWhere, result: { in: ['failed', 'retry_pending', 'dead_letter'] } }, orderBy: [{ lastAttemptAt: 'desc' }, { createdAt: 'desc' }] })
  552:       ])
  553:       const itemRecentSuccessRate = calculateSuccessRate(itemRecentSuccess, itemRecentTotal)
  554: 
  555:       return {
  556:         eventName,
  557:         handler,
  558:         total: itemTotal,
  559:         success: itemSuccess,
  560:         failed: itemFailed,

