 1421:   fastify.get<{ Params: PluginParams }>('/:pluginId/storage-usage', {
 1422:     onRequest: [fastify.authenticateAdmin]
 1423:   }, async (request, reply) => {
 1424:     const pluginId = normalizePluginId(request.params.pluginId)
 1425:     if (!pluginId) return reply.code(400).send({ error: 'Invalid plugin id', code: 'INVALID_PLUGIN_ID' })
 1426:     const plugin = await getPlugin(pluginId)
 1427:     const latest = plugin ? latestManifest(plugin) : null
 1428:     if (!plugin || !latest) return reply.code(404).send({ error: 'Plugin not found', code: 'PLUGIN_NOT_FOUND' })
 1429: 
 1430:     const storage = latest.manifest.capabilities?.storage
 1431:     const declaredScopes = storage?.scopes?.length ? storage.scopes : ['user']
 1432:     const [legacyUserKeyCount, kvCounts, tableCounts, migrationCounts] = await Promise.all([
 1433:       countPluginUserDataItems(pluginId),
 1434:       listPluginStorageScopeCounts(pluginId),
 1435:       listPluginTableScopeCounts(pluginId),
 1436:       listPluginTableMigrationCounts(pluginId)
 1437:     ])
 1438: 
 1439:     const kvCountByScope = new Map(kvCounts.map(item => [item.scopeType, item.count]))
 1440:     const scopeNames = Array.from(new Set([...declaredScopes, ...kvCounts.map(item => item.scopeType)])).sort()
 1441:     const kv = scopeNames.map(scopeType => ({
 1442:       scopeType,
 1443:       keyCount: kvCountByScope.get(scopeType) || 0,
 1444:       maxKeys: storage?.maxKeys ?? null,
 1445:       declared: declaredScopes.includes(scopeType as 'user' | 'global' | 'service')
 1446:     }))
 1447: 
 1448:     const migrationCountByTable = new Map(migrationCounts.map(item => [item.tableName, item.count]))
 1449:     const tableCountByKey = new Map(tableCounts.map(item => [`${item.tableName}:${item.scopeType}`, item.count]))
 1450:     const declaredTableKeys = new Set<string>()
 1451:     const tables = (storage?.tables || []).flatMap(table => {
 1452:       const tableScopes = table.scopes?.length ? table.scopes : declaredScopes
 1453:       return tableScopes.map(scopeType => {
 1454:         declaredTableKeys.add(`${table.name}:${scopeType}`)
 1455:         return {
 1456:           tableName: table.name,
 1457:           scopeType,
 1458:           rowCount: tableCountByKey.get(`${table.name}:${scopeType}`) || 0,
 1459:           maxRows: table.maxRows ?? null,
 1460:           migrationCount: migrationCountByTable.get(table.name) || 0,
 1461:           declared: true
 1462:         }
 1463:       })
 1464:     })
 1465: 
 1466:     for (const item of tableCounts) {
 1467:       const key = `${item.tableName}:${item.scopeType}`
 1468:       if (!declaredTableKeys.has(key)) {
 1469:         tables.push({
 1470:           tableName: item.tableName,
 1471:           scopeType: item.scopeType,
 1472:           rowCount: item.count,
 1473:           maxRows: null,
 1474:           migrationCount: migrationCountByTable.get(item.tableName) || 0,
 1475:           declared: false
 1476:         })
 1477:       }
 1478:     }
 1479:     const warnings = buildPluginStorageWarnings({ kv, tables })
 1480: 
 1481:     return {
 1482:       usage: {
 1483:         pluginId,
 1484:         storageDeclared: storage?.kind === 'kv',
 1485:         retention: storage?.retention || 'delete_on_uninstall',
 1486:         legacyUserKeyCount,
 1487:         kv,
 1488:         tables,
 1489:         warnings,
 1490:         totals: {
 1491:           kvKeys: kv.reduce((sum, item) => sum + item.keyCount, 0),
 1492:           tableRows: tables.reduce((sum, item) => sum + item.rowCount, 0),
 1493:           tableMigrations: migrationCounts.reduce((sum, item) => sum + item.count, 0)
 1494:         }
 1495:       }
 1496:     }
 1497:   })
