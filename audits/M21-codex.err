  227: async function listPublicPluginActionRateLimitPolicies(): Promise<PublicPluginActionRateLimitPolicyRow[]> {
  228:   return prisma.$queryRaw<PublicPluginActionRateLimitPolicyRow[]>`
  229:     SELECT
  230:       "id",
  231:       "plugin_id" AS "pluginId",
  232:       "action_name" AS "actionName",
  233:       "rate_limit" AS "rateLimit",
  234:       "max_requests" AS "maxRequests",
  235:       "window_seconds" AS "windowSeconds",
  236:       "enabled",
  237:       "updated_by_user_id" AS "updatedByUserId",
  238:       "created_at" AS "createdAt",
  239:       "updated_at" AS "updatedAt"
  240:     FROM "public_plugin_action_rate_limit_policies"

### 240-540
  240:     FROM "public_plugin_action_rate_limit_policies"
  241:     ORDER BY
  242:       CASE WHEN "plugin_id" = ${PUBLIC_PLUGIN_ACTION_RATE_LIMIT_GLOBAL_SCOPE} THEN 0 ELSE 1 END,
  243:       "plugin_id" ASC,
  244:       CASE WHEN "action_name" = ${PUBLIC_PLUGIN_ACTION_RATE_LIMIT_GLOBAL_SCOPE} THEN 0 ELSE 1 END,
  245:       "action_name" ASC,
  246:       "rate_limit" ASC
  247:   `
  248: }
