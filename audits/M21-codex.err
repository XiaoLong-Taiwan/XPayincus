   16: function parsePluginAssetUrl(url: string): { pluginId: string; assetPath: string } | null {
   17:   if (!url.startsWith('/api/plugins/assets/')) return null
   18:   const parsed = new URL(url, window.location.origin)
   19:   const prefix = '/api/plugins/assets/'
   20:   if (!parsed.pathname.startsWith(prefix)) return null
   21: 
   22:   const rest = parsed.pathname.slice(prefix.length)
   23:   const slashIndex = rest.indexOf('/')
   24:   if (slashIndex <= 0) return null
   25: 
   26:   return {
   27:     pluginId: decodeURIComponent(rest.slice(0, slashIndex)),
   28:     assetPath: rest.slice(slashIndex + 1)
   29:   }
   30: }
   31: 
   32: function currentPluginAsset(): { pluginId: string; assetPath: string } | null {
   33:   return parsePluginAssetUrl(props.url)
   34: }
   35: 
   36: function postPluginConfig(pluginId: string, config: Record<string, unknown>): void {
   37:   frameRef.value?.contentWindow?.postMessage({
   38:     type: 'payincus:plugin-config',
   39:     pluginId,
   40:     config,
   41:     updatedAt: new Date().toISOString()
   42:   }, window.location.origin)
