  493: function assertStoragePayload(value: unknown): void {
  494:   if (value === undefined) throw new Error('Plugin storage value is required')
  495:   const serialized = JSON.stringify(value)
  496:   if (serialized === undefined) throw new Error('Plugin storage value must be JSON serializable')
  497:   if (Buffer.byteLength(serialized, 'utf8') > 64 * 1024) {
  498:     throw new Error('Plugin storage value exceeds 64KB')
  499:   }
  500: }
  501: 
  502: function jsonValueForStorage(value: unknown) {
  503:   return value === null ? Prisma.JsonNull : value as Prisma.InputJsonValue
  504: }
  505: 
  506: function assertPluginTablePayload(value: unknown): void {
  507:   if (value === undefined) throw new Error('Plugin table row value is required')
  508:   const serialized = JSON.stringify(value)
  509:   if (serialized === undefined) throw new Error('Plugin table row value must be JSON serializable')
  510:   if (Buffer.byteLength(serialized, 'utf8') > 64 * 1024) {
  511:     throw new Error('Plugin table row value exceeds 64KB')
  512:   }
  513: }
  514: 
  515: function isRecord(value: unknown): value is Record<string, unknown> {
  516:   return !!value && typeof value === 'object' && !Array.isArray(value)
  517: }
  518: 
  519: function normalizeBackupString(value: unknown, maxLength: number): string | null {
  520:   if (typeof value !== 'string') return null
  521:   const trimmed = value.trim()
  522:   return trimmed && trimmed.length <= maxLength ? trimmed : null
  523: }
  524: 
  525: function normalizeBackupNullableUserId(value: unknown): number | null {
  526:   if (value === null || value === undefined) return null
  527:   return parsePositiveId(value)
  528: }
  529: 
  530: function normalizePluginStorageBackupPayload(pluginId: string, value: unknown) {
  531:   const backup = isRecord(value) && isRecord(value.backup) ? value.backup : value
  532:   if (!isRecord(backup)) throw new Error('Plugin storage backup must be an object')
  533:   if (backup.schemaVersion !== 1) throw new Error('Unsupported plugin storage backup schema version')
  534:   if (backup.pluginId !== pluginId) throw new Error('Plugin storage backup pluginId mismatch')
  535: 
  536:   const legacyInput = Array.isArray(backup.legacyUserData) ? backup.legacyUserData : []
  537:   const scopedInput = Array.isArray(backup.scopedStorage) ? backup.scopedStorage : []
  538:   const tableRowInput = Array.isArray(backup.tableRows) ? backup.tableRows : []
  539:   const migrationInput = Array.isArray(backup.tableMigrations) ? backup.tableMigrations : []
  540:   const totalItems = legacyInput.length + scopedInput.length + tableRowInput.length + migrationInput.length
  541:   if (totalItems > 20000) throw new Error('Plugin storage backup exceeds restore item limit')
  542: 
  543:   const legacyUserData = legacyInput.map(item => {
  544:     if (!isRecord(item)) throw new Error('Invalid legacy user storage backup item')
  545:     const userId = parsePositiveId(item.userId)
  546:     const key = normalizeStorageKey(String(item.key ?? ''))
  547:     if (!userId || !key) throw new Error('Invalid legacy user storage backup key')
  548:     assertStoragePayload(item.value)
  549:     return { userId, key, value: item.value ?? null }
  550:   })
  551: 
  552:   const scopedStorage = scopedInput.map(item => {
  553:     if (!isRecord(item)) throw new Error('Invalid scoped storage backup item')
  554:     const scopeType = normalizeStorageScope(String(item.scopeType ?? ''))
  555:     const scopeId = normalizeBackupString(item.scopeId, 120)
  556:     const key = normalizeStorageKey(String(item.key ?? ''))
  557:     if (!scopeType || !scopeId || !key) throw new Error('Invalid scoped storage backup key')
  558:     assertStoragePayload(item.value)
  559:     return {
  560:       scopeType,
  561:       scopeId,
  562:       key,
  563:       value: item.value ?? null,
  564:       createdByUserId: normalizeBackupNullableUserId(item.createdByUserId),
  565:       updatedByUserId: normalizeBackupNullableUserId(item.updatedByUserId)
  566:     }
  567:   })
  568: 
  569:   const tableRows = tableRowInput.map(item => {
  570:     if (!isRecord(item)) throw new Error('Invalid table storage backup item')
  571:     const tableName = normalizePluginTableName(String(item.tableName ?? ''))
  572:     const scopeType = normalizeStorageScope(String(item.scopeType ?? ''))
  573:     const scopeId = normalizeBackupString(item.scopeId, 120)
  574:     const rowKey = normalizePluginTableRowKey(String(item.rowKey ?? ''))
  575:     if (!tableName || !scopeType || !scopeId || !rowKey) throw new Error('Invalid table storage backup key')
  576:     assertPluginTablePayload(item.value)
  577:     return {
  578:       tableName,
  579:       scopeType,
  580:       scopeId,
  581:       rowKey,
  582:       value: item.value ?? null,
  583:       createdByUserId: normalizeBackupNullableUserId(item.createdByUserId),
  584:       updatedByUserId: normalizeBackupNullableUserId(item.updatedByUserId)
  585:     }
  586:   })
  587: 
  588:   const tableMigrations = migrationInput.map(item => {
  589:     if (!isRecord(item)) throw new Error('Invalid table migration backup item')
  590:     const tableName = normalizePluginTableName(String(item.tableName ?? ''))
  591:     const version = normalizeBackupString(item.version, 64)
  592:     const name = normalizeBackupString(item.name, 120)
  593:     const appliedByUserId = parsePositiveId(item.appliedByUserId)
  594:     if (!tableName || !version || !name || !appliedByUserId) throw new Error('Invalid table migration backup item')
  595:     return { tableName, version, name, appliedByUserId }
  596:   })
  597: 
  598:   return { legacyUserData, scopedStorage, tableRows, tableMigrations }
  599: }
  600: 
  601: function buildPluginStorageBackupSummary(backup: ReturnType<typeof normalizePluginStorageBackupPayload>) {
  602:   const counts = {
  603:     legacyUserData: backup.legacyUserData.length,
  604:     scopedStorage: backup.scopedStorage.length,
  605:     tableRows: backup.tableRows.length,
  606:     tableMigrations: backup.tableMigrations.length
  607:   }
  608:   return {
  609:     ...counts,
  610:     totalItems: counts.legacyUserData + counts.scopedStorage + counts.tableRows + counts.tableMigrations
