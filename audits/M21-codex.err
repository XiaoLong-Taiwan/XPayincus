  187: export async function reviewPluginMarketSubmission(input: {
  188:   id: number
  189:   reviewStatus: PluginMarketSubmissionReviewStatus
  190:   riskLevel: PluginMarketSubmissionRiskLevel
  191:   reviewNotes?: string | null
  192:   reviewedByUserId: number
  193: }) {
  194:   return prisma.pluginMarketSubmission.update({
  195:     where: { id: input.id },
  196:     data: {
  197:       reviewStatus: input.reviewStatus,
  198:       riskLevel: input.riskLevel,
  199:       reviewNotes: input.reviewNotes ?? null,
  200:       reviewedByUserId: input.reviewedByUserId,
  201:       reviewedAt: new Date()
  202:     },
  203:     include: {
  204:       submittedBy: { select: { username: true } },
  205:       reviewedBy: { select: { username: true } }
  206:     }
  207:   })
  208: }

