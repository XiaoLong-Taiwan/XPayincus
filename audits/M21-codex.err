 1743:   fastify.post<{
 1744:     Params: PluginStorageBackupRemoteArchiveParams
 1745:     Querystring: PluginStorageBackupRestoreQuery
 1746:   }>('/:pluginId/storage-backup/archives/:backupId/remote/:remoteArchiveId/restore', {
 1747:     onRequest: [fastify.authenticateAdmin]
 1748:   }, async (request, reply) => {
 1749:     const pluginId = normalizePluginId(request.params.pluginId)
 1750:     const backupId = normalizePluginStorageBackupArchiveId(request.params.backupId)
 1751:     const remoteArchiveId = parsePositiveId(request.params.remoteArchiveId)
 1752:     if (!pluginId || !backupId || !remoteArchiveId) return reply.code(400).send({ error: 'Invalid plugin storage remote backup archive', code: 'INVALID_PLUGIN_STORAGE_REMOTE_BACKUP_ARCHIVE' })
 1753:     const plugin = await getPlugin(pluginId)
 1754:     if (!plugin || !latestManifest(plugin)) return reply.code(404).send({ error: 'Plugin not found', code: 'PLUGIN_NOT_FOUND' })
 1755: 
 1756:     const remoteArchive = await prisma.pluginStorageBackupRemoteArchive.findFirst({
 1757:       where: { id: remoteArchiveId, pluginId, backupId, status: 'available' }
 1758:     })
 1759:     if (!remoteArchive) {
 1760:       return reply.code(404).send({ error: 'Plugin storage remote backup archive not found', code: 'PLUGIN_STORAGE_REMOTE_BACKUP_ARCHIVE_NOT_FOUND' })
 1761:     }
 1762: 
 1763:     const user = getRequestUser(request)
 1764:     const storageConfig = await getStorageConfigById(remoteArchive.storageConfigId)
 1765:     if (!storageConfig || storageConfig.userId !== user.id) {
 1766:       return reply.code(404).send({ error: 'Storage config not found', code: 'STORAGE_CONFIG_NOT_FOUND' })
 1767:     }
 1768: 
 1769:     let backupPayload: unknown
 1770:     try {
 1771:       const provider = StorageFactory.create(storageConfig)
 1772:       const stream = await provider.downloadStream(remoteArchive.remoteFileName)
 1773:       const text = await readRemotePluginStorageBackupStream(stream)
 1774:       backupPayload = JSON.parse(text)
 1775:     } catch (error) {
 1776:       const message = error instanceof Error ? error.message : String(error)
 1777:       return reply.code(400).send({ error: message, code: 'PLUGIN_STORAGE_BACKUP_REMOTE_DOWNLOAD_FAILED' })
 1778:     }
 1779: 
 1780:     let backup: ReturnType<typeof normalizePluginStorageBackupPayload>
 1781:     try {
 1782:       const normalized = await resolvePluginStorageBackupArchiveForRestore(pluginId, backupPayload)
 1783:       const contentSha256 = buildPluginStorageBackupContentHash(normalized)
 1784:       if (contentSha256 !== remoteArchive.contentSha256) {
 1785:         throw new Error('Plugin storage remote backup checksum mismatch')
 1786:       }
 1787:       backup = normalized
 1788:     } catch (error) {
 1789:       const message = error instanceof Error ? error.message : String(error)
 1790:       return reply.code(400).send({ error: message, code: 'INVALID_PLUGIN_STORAGE_BACKUP' })
 1791:     }
 1792: 
 1793:     const result = await restorePluginStorageBackup({
 1794:       pluginId,
 1795:       userId: user.id,
 1796:       backup,
 1797:       dryRun: request.query?.dryRun === 'true',
 1798:       archiveId: `remote:${remoteArchive.id}:${backupId}`
 1799:     })
 1800:     if (request.query?.dryRun !== 'true') {
 1801:       await prisma.pluginStorageBackupRemoteArchive.update({
 1802:         where: { id: remoteArchive.id },
 1803:         data: { lastRestoredAt: new Date() }
 1804:       })
 1805:     }
 1806:     return result
 1807:   })
