  187:   if (!secret || secret.length < 32) {
  188:     throw new Error('PLUGIN_WEBHOOK_SIGNING_SECRET must be configured with at least 32 characters before executing plugin webhooks')
  189:   }
  190:   return secret
  191: }
  192: 
  193: function getPluginWebhookTimeoutMs(action: PluginActionManifest): number {
  194:   const configured = Number(process.env.PLUGIN_WEBHOOK_TIMEOUT_MS || '')
  195:   const fallback = Number.isSafeInteger(configured) && configured >= 1000 && configured <= 30000
  196:     ? configured
  197:     : DEFAULT_PLUGIN_WEBHOOK_TIMEOUT_MS
  198:   return action.rateLimit === 'strict' ? Math.min(fallback, 5000) : fallback
  199: }
  200: 
  201: function findDeclaredAction(manifest: PayIncusPluginManifest, actionName: string): PluginActionManifest | null {
  202:   return (manifest.capabilities?.actions || []).find(action => action.name === actionName) || null
  203: }
  204: 
  205: function assertActionPermissions(manifest: PayIncusPluginManifest, action: PluginActionManifest): void {
  206:   const permissions = new Set(manifest.permissions || [])
  207:   if (!permissions.has('plugin-action:run')) {
  208:     throw new Error('Plugin manifest must grant plugin-action:run before actions can execute')
  209:   }
  210:   for (const scope of action.scopes || []) {
  211:     if (!permissions.has(scope)) {
  212:       throw new Error(`Plugin manifest must grant action scope ${scope}`)
  213:     }
  214:   }
  215: }
