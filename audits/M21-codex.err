  422: export async function replayPluginEventLog(logId: number, actorOverride?: PluginRuntimeActor): Promise<PluginEventReplayResult> {
  423:   const log = await prisma.pluginEventLog.findUnique({ where: { id: logId } })
  424:   if (!log || log.action !== 'plugin.event.dispatch' || !log.eventName || !log.handler) {
  425:     throw new Error('Plugin event log is not replayable')
  426:   }
  427:   if (log.result === 'duplicate_skipped') {
  428:     throw new Error('Deduplicated plugin event log is not replayable')
  429:   }
  430: 
  431:   const plugin = await prisma.plugin.findUnique({
  432:     where: { pluginId: log.pluginId },
  433:     include: { versions: { orderBy: { installedAt: 'desc' }, take: 1 } }
  434:   })
  435:   if (!plugin || !plugin.enabled || plugin.status !== 'enabled') {
  436:     throw new Error('Plugin is not enabled')
  437:   }
  438:   const manifest = plugin.versions[0]?.manifest as unknown as PayIncusPluginManifest | undefined
  439:   if (!manifest) throw new Error('Plugin manifest is missing')
  440: 
  441:   const actor = actorOverride || normalizeRuntimeActor(log.actor)
  442:   const payload = log.payload ?? {}
  443:   try {
  444:     await executePluginAction({
  445:       pluginId: log.pluginId,
  446:       manifest,
  447:       actionName: log.handler,
  448:       actor,
  449:       payload,
  450:       source: 'event',
  451:       eventName: log.eventName,
  452:       idempotencyKey: `event-log-${log.id}-retry-${log.retryCount + 1}`
  453:     })
  454:     const updated = await prisma.pluginEventLog.update({
  455:       where: { id: log.id },
  456:       data: {
  457:         result: 'success',
  458:         message: `${log.eventName} -> ${log.handler}: replayed successfully`,
  459:         nextRetryAt: null,
  460:         deadLetterAt: null,
  461:         lastError: null,
  462:         lastAttemptAt: new Date(),
  463:         retryCount: { increment: 1 }
  464:       }
  465:     })
  466:     await finalizePluginEventDedupeLock({
  467:       pluginId: updated.pluginId,
  468:       eventName: log.eventName,
  469:       handler: log.handler,
  470:       dedupeKey: updated.dedupeKey,
  471:       eventLogId: updated.id,
  472:       status: 'success'
  473:     }).catch(() => undefined)
  474:     return {
  475:       id: updated.id,
  476:       pluginId: updated.pluginId,
  477:       eventName: log.eventName,
  478:       handler: log.handler,
  479:       result: 'success',
  480:       retryCount: updated.retryCount
  481:     }
  482:   } catch (error) {
  483:     const message = error instanceof Error ? error.message : String(error)
  484:     const retryCount = log.retryCount + 1
  485:     const shouldDeadLetter = retryCount >= log.maxRetries
  486:     const updated = await prisma.pluginEventLog.update({
  487:       where: { id: log.id },
  488:       data: {
  489:         result: shouldDeadLetter ? 'dead_letter' : 'retry_pending',
  490:         message: `${log.eventName} -> ${log.handler}: ${message}`,
  491:         retryCount,
  492:         nextRetryAt: shouldDeadLetter ? null : nextPluginEventRetryAt(retryCount + 1),
  493:         deadLetterAt: shouldDeadLetter ? new Date() : null,
  494:         lastAttemptAt: new Date(),
  495:         lastError: message
  496:       }
  497:     })
  498:     await finalizePluginEventDedupeLock({
  499:       pluginId: updated.pluginId,
  500:       eventName: log.eventName,
  501:       handler: log.handler,
  502:       dedupeKey: updated.dedupeKey,
  503:       eventLogId: updated.id,
  504:       status: shouldDeadLetter ? 'dead_letter' : 'retry_pending'
  505:     }).catch(() => undefined)
  506:     return {
  507:       id: updated.id,
  508:       pluginId: updated.pluginId,
  509:       eventName: log.eventName,
  510:       handler: log.handler,
  511:       result: shouldDeadLetter ? 'dead_letter' : 'retry_pending',
  512:       retryCount: updated.retryCount
  513:     }
  514:   }
  515: }
  516: 
  517: export async function processDuePluginEventRetries(limit = 20): Promise<{ processed: number; succeeded: number; failed: number; deadLettered: number }> {
  518:   const logs = await prisma.pluginEventLog.findMany({
  519:     where: {
  520:       action: 'plugin.event.dispatch',
  521:       result: 'retry_pending',
  522:       nextRetryAt: { lte: new Date() },
  523:       deadLetterAt: null
  524:     },
  525:     orderBy: { nextRetryAt: 'asc' },
  526:     take: Math.min(Math.max(limit, 1), 100)
  527:   })
  528: 
  529:   let succeeded = 0
  530:   let failed = 0
  531:   let deadLettered = 0
  532:   for (const log of logs) {
  533:     const result = await replayPluginEventLog(log.id).catch(() => null)
  534:     if (!result) {
  535:       failed += 1
  536:       continue
  537:     }
  538:     if (result.result === 'success') succeeded += 1
  539:     if (result.result === 'retry_pending') failed += 1
  540:     if (result.result === 'dead_letter') deadLettered += 1
  541:   }
  542:   return { processed: logs.length, succeeded, failed, deadLettered }
  543: }

