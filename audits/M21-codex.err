  120: function getRequestUser(request: FastifyRequest): { id: number; username: string; role: 'admin' | 'user' } {
  121:   return request.user as { id: number; username: string; role: 'admin' | 'user' }
  122: }
  123: 
  124: function parsePositiveId(value: string): number | null {
  125:   const id = Number(value)
  126:   return Number.isSafeInteger(id) && id > 0 ? id : null
  127: }
  128: 
  129: function normalizePluginId(value: string): string | null {
  130:   const trimmed = value.trim()
  131:   return /^[a-z][a-z0-9]*(?:\.[a-z][a-z0-9-]*){2,}$/.test(trimmed) ? trimmed : null
  132: }
  133: 
  134: function normalizePluginEventName(value: string): string | null {
  135:   const trimmed = value.trim()
  136:   return /^[A-Za-z0-9_.:-]{1,120}$/.test(trimmed) ? trimmed : null
  137: }
  138: 
  139: function normalizePluginEventResult(value: string): string | null {
  140:   const trimmed = value.trim()
  141:   return ['pending', 'success', 'failed', 'retry_pending', 'dead_letter', 'duplicate_skipped'].includes(trimmed) ? trimmed : null
  142: }
  143: 
  144: function normalizePluginEventHandler(value: string): string | null {
  145:   const trimmed = value.trim()
  146:   if (!trimmed) return null
  147:   return trimmed.length <= 300 ? trimmed : null
  148: }
  149: 
  150: function normalizeCapabilityReviewStatus(value: unknown): 'pending' | 'approved' | 'rejected' | 'revoked' | null {
  151:   if (typeof value !== 'string') return null
  152:   const trimmed = value.trim()
  153:   return PLUGIN_CAPABILITY_REVIEW_STATUSES.has(trimmed)
  154:     ? trimmed as 'pending' | 'approved' | 'rejected' | 'revoked'
  155:     : null
  156: }
  157: 
  158: function normalizeCapabilityReviewNotes(value: unknown): string | null {
  159:   if (value === undefined || value === null) return null
  160:   if (typeof value !== 'string') return null
  161:   const trimmed = value.trim()
  162:   if (!trimmed) return null
  163:   return trimmed.slice(0, 2000)
  164: }
  165: 
  166: function normalizePluginActionName(value: unknown): string | null {
  167:   if (value === undefined || value === null || value === '') return PUBLIC_PLUGIN_ACTION_RATE_LIMIT_GLOBAL_SCOPE
  168:   if (typeof value !== 'string') return null
  169:   const trimmed = value.trim()
  170:   if (trimmed === PUBLIC_PLUGIN_ACTION_RATE_LIMIT_GLOBAL_SCOPE) return PUBLIC_PLUGIN_ACTION_RATE_LIMIT_GLOBAL_SCOPE
  171:   return /^[A-Za-z][A-Za-z0-9_.:-]{0,79}$/.test(trimmed) ? trimmed : null
  172: }
  173: 
  174: function normalizePublicPluginActionRateLimitPolicy(input: ActionRateLimitPolicyUpdateBody['policies'][number]): PublicPluginActionRateLimitPolicyInput {
  175:   const pluginId = input.pluginId === undefined || input.pluginId === null || input.pluginId === ''
  176:     ? PUBLIC_PLUGIN_ACTION_RATE_LIMIT_GLOBAL_SCOPE
  177:     : typeof input.pluginId === 'string' && input.pluginId.trim() === PUBLIC_PLUGIN_ACTION_RATE_LIMIT_GLOBAL_SCOPE
  178:       ? PUBLIC_PLUGIN_ACTION_RATE_LIMIT_GLOBAL_SCOPE
  179:       : typeof input.pluginId === 'string'
  180:         ? normalizePluginId(input.pluginId)
  181:         : null
  182:   if (!pluginId) throw new Error('Invalid plugin rate limit pluginId')
  183: 
  184:   const actionName = normalizePluginActionName(input.actionName)
  185:   if (!actionName) throw new Error('Invalid plugin rate limit actionName')
  186: 
  187:   const rateLimit = input.rateLimit === 'strict' ? 'strict' : input.rateLimit === 'normal' ? 'normal' : null
  188:   if (!rateLimit) throw new Error('Invalid plugin rate limit policy')
  189: 
  190:   const maxRequests = Number(input.maxRequests)
  191:   if (!Number.isSafeInteger(maxRequests) || maxRequests < 1 || maxRequests > 10_000) {
  192:     throw new Error('Plugin action rate limit maxRequests must be between 1 and 10000')
  193:   }
  194: 
  195:   const windowSeconds = input.windowSeconds === undefined || input.windowSeconds === null || input.windowSeconds === ''
  196:     ? 60
  197:     : Number(input.windowSeconds)
  198:   if (!Number.isSafeInteger(windowSeconds) || windowSeconds < 10 || windowSeconds > 3600) {
  199:     throw new Error('Plugin action rate limit windowSeconds must be between 10 and 3600')
  200:   }
  201: 
  202:   return {
  203:     pluginId,
  204:     actionName,
  205:     rateLimit,
  206:     maxRequests,
  207:     windowSeconds,
  208:     enabled: input.enabled !== false
  209:   }
  210: }
  211: 
  212: function serializePublicPluginActionRateLimitPolicy(row: PublicPluginActionRateLimitPolicyRow) {
  213:   return {
  214:     id: row.id,
  215:     pluginId: row.pluginId,
  216:     actionName: row.actionName,
  217:     rateLimit: row.rateLimit,
  218:     maxRequests: row.maxRequests,
  219:     windowSeconds: row.windowSeconds,
  220:     enabled: row.enabled,
  221:     updatedByUserId: row.updatedByUserId,
  222:     createdAt: row.createdAt.toISOString(),
  223:     updatedAt: row.updatedAt.toISOString()
  224:   }
  225: }
