  587:   fastify.get<{ Querystring: PluginEventQuery }>('/events', {
  588:     onRequest: [fastify.authenticateAdmin]
  589:   }, async (request, reply) => {
  590:     const limit = Math.min(Math.max(Number(request.query.limit || 50), 1), 100)
  591:     const result = typeof request.query.result === 'string' && request.query.result.trim()
  592:       ? normalizePluginEventResult(request.query.result)
  593:       : undefined
  594:     if (request.query.result && !result) return reply.code(400).send({ error: 'Invalid event result', code: 'INVALID_EVENT_RESULT' })
  595: 
  596:     const pluginId = typeof request.query.pluginId === 'string' && request.query.pluginId.trim()
  597:       ? normalizePluginId(request.query.pluginId)
  598:       : undefined
  599:     if (request.query.pluginId && !pluginId) return reply.code(400).send({ error: 'Invalid plugin id', code: 'INVALID_PLUGIN_ID' })
  600: 
  601:     const eventName = typeof request.query.eventName === 'string' && request.query.eventName.trim()
  602:       ? normalizePluginEventName(request.query.eventName)
  603:       : undefined
  604:     if (request.query.eventName && !eventName) return reply.code(400).send({ error: 'Invalid event name', code: 'INVALID_EVENT_NAME' })
  605: 
  606:     const handler = typeof request.query.handler === 'string' && request.query.handler.trim()
  607:       ? normalizePluginEventHandler(request.query.handler)
  608:       : undefined
  609:     if (request.query.handler && !handler) return reply.code(400).send({ error: 'Invalid event handler filter', code: 'INVALID_EVENT_HANDLER' })
  610: 
  611:     const baseWhere = {
  612:       action: 'plugin.event.dispatch',
  613:       ...(pluginId ? { pluginId } : {}),
  614:       ...(eventName ? { eventName } : {}),
  615:       ...(handler ? { handler: { contains: handler } } : {})
  616:     }
  617:     const where = {
  618:       ...baseWhere,
  619:       ...(result ? { result } : {})
  620:     }
  621: 
  622:     const [logs, total, success, failed, retryPending, deadLetter, deduped, dueRetry] = await Promise.all([
  623:       prisma.pluginEventLog.findMany({
  624:         where,
  625:         orderBy: [{ lastAttemptAt: 'desc' }, { createdAt: 'desc' }],
  626:         take: limit
  627:       }),
  628:       prisma.pluginEventLog.count({ where: baseWhere }),
  629:       prisma.pluginEventLog.count({ where: { ...baseWhere, result: 'success' } }),
  630:       prisma.pluginEventLog.count({ where: { ...baseWhere, result: 'failed' } }),
  631:       prisma.pluginEventLog.count({ where: { ...baseWhere, result: 'retry_pending' } }),
  632:       prisma.pluginEventLog.count({ where: { ...baseWhere, result: 'dead_letter' } }),
  633:       prisma.pluginEventLog.count({ where: { ...baseWhere, result: 'duplicate_skipped' } }),
  634:       prisma.pluginEventLog.count({
  635:         where: {
  636:           ...baseWhere,
  637:           result: 'retry_pending',
  638:           deadLetterAt: null,
  639:           nextRetryAt: { lte: new Date() }
  640:         }
  641:       })
  642:     ])
  643:     return {
  644:       events: logs.map(serializePluginEventLog),
  645:       summary: {
  646:         total,
  647:         success,
  648:         failed,
  649:         retryPending,
  650:         deadLetter,
  651:         deduped,
  652:         dueRetry,
  653:         updatedAt: new Date().toISOString()
  654:       }
  655:     }
  656:   })
