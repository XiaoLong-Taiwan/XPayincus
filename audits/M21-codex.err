  141: export async function listPluginMarketSubmissions(options: {
  142:   reviewStatus?: PluginMarketSubmissionReviewStatus
  143:   limit?: number
  144: }) {
  145:   return prisma.pluginMarketSubmission.findMany({
  146:     where: options.reviewStatus ? { reviewStatus: options.reviewStatus } : {},
  147:     orderBy: { createdAt: 'desc' },
  148:     take: Math.min(Math.max(options.limit ?? 100, 1), 200),
  149:     include: {
  150:       submittedBy: { select: { username: true } },
  151:       reviewedBy: { select: { username: true } }
  152:     }
  153:   })
  154: }
