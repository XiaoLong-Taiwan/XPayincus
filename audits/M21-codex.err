  924:         LogResult.SUCCESS
  925:       )
  926:       await appendPluginTaskLog(join(getPluginLogDir(), `plugin-capability-review-${review.pluginId}.log`), `Reviewed ${review.capabilityKey}: ${status}`)
  927:         .catch(() => undefined)
  928:       return { review: serializePluginCapabilityReview(review) }
  929:     } catch (error) {
  930:       const message = error instanceof Error ? error.message : String(error)
  931:       return reply.code(400).send({ error: message, code: 'PLUGIN_CAPABILITY_REVIEW_FAILED' })
  932:     }
  933:   })
