    1: import { mkdir, readFile, writeFile } from 'fs/promises'
    2: import { dirname, join, resolve } from 'path'
    3: import { createHash } from 'crypto'
    4: import { prisma } from '../db/prisma.js'
    5: import type { PluginMarketEntry, PluginMarketIndex } from './plugin-market.js'
    6: import { getRuntimeConfigString } from './runtime-settings.js'
