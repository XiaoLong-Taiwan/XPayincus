  285: async function writeUploadPackage(request: FastifyRequest): Promise<{ packagePath: string; sourceName: string }> {
  286:   const multipartRequest = request as FastifyRequest & {
  287:     parts: () => AsyncIterable<any>
  288:   }
  289:   const uploadDir = join(getPluginStagingDir(), 'uploads')
  290:   await mkdir(uploadDir, { recursive: true })
  291:   const maxBytes = getPluginPackageMaxBytes()
  292: 
  293:   for await (const part of multipartRequest.parts()) {
  294:     if (part.type !== 'file') continue
  295:     if (part.fieldname !== 'package') {
  296:       await part.toBuffer()
  297:       continue
  298:     }
  299:     const filename = String(part.filename || 'plugin.tar.gz')
  300:     if (!filename.endsWith('.tar.gz')) {
  301:       throw new Error('Plugin package must be a .tar.gz file')
  302:     }
  303:     const buffer = await part.toBuffer()
  304:     if (buffer.length === 0) throw new Error('Plugin package is empty')
  305:     if (buffer.length > maxBytes) throw new Error(`Plugin package exceeds ${Math.round(maxBytes / 1024 / 1024)}MB`)
  306:     const packagePath = join(uploadDir, `${Date.now()}-${randomUUID()}.tar.gz`)
  307:     await writeFile(packagePath, buffer, { mode: 0o600 })
  308:     return { packagePath, sourceName: filename }
  309:   }
  310: 
  311:   throw new Error('Missing plugin package file')
  312: }
