  101: export async function createPluginMarketSubmission(input: CreatePluginMarketSubmissionInput) {
  102:   return prisma.pluginMarketSubmission.create({
  103:     data: {
  104:       pluginId: input.pluginId,
  105:       version: input.version,
  106:       name: input.name,
  107:       repoUrl: input.repoUrl,
  108:       releaseUrl: input.releaseUrl,
  109:       manifestUrl: input.manifestUrl,
  110:       packageUrl: input.packageUrl,
  111:       sha256: input.sha256,
  112:       developerName: input.developerName,
  113:       developerHomepage: input.developerHomepage ?? null,
  114:       developerGithub: input.developerGithub ?? null,
  115:       contactEmail: input.contactEmail,
  116:       permissions: input.permissions as Prisma.InputJsonObject,
  117:       compatibility: input.compatibility as Prisma.InputJsonObject,
  118:       pricing: input.pricing as Prisma.InputJsonObject,
  119:       notes: input.notes ?? null,
  120:       submittedByUserId: input.submittedByUserId
  121:     },
  122:     include: {
  123:       submittedBy: { select: { username: true } },
  124:       reviewedBy: { select: { username: true } }
