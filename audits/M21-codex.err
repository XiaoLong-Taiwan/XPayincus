   45: async function refreshPluginConfig(): Promise<void> {
   46:   const asset = currentPluginAsset()
   47:   if (!asset) return
   48:   try {
   49:     const response = await api.plugins.getPublicConfig(asset.pluginId)
   50:     postPluginConfig(asset.pluginId, response.config)
   51:   } catch {
   52:     postPluginConfig(asset.pluginId, {})
   53:   }
   54: }
   55: 
   56: function handlePluginConfigRefresh(event: Event): void {
   57:   const asset = currentPluginAsset()
   58:   if (!asset) return
   59:   const detail = (event as CustomEvent<{ pluginId?: string }>).detail
   60:   if (detail?.pluginId && detail.pluginId !== asset.pluginId) return
   61:   void refreshPluginConfig()
   62: }
   63: 
   64: async function refreshFrameUrl(): Promise<void> {
   65:   frameUrl.value = props.url
   66:   const asset = parsePluginAssetUrl(props.url)
   67:   if (!asset) return
   68: 
   69:   const data = await requestPluginAssetToken(asset)
   70:   if (!data?.assetToken) return
   71: 
   72:   const separator = props.url.includes('?') ? '&' : '?'
   73:   frameUrl.value = `${props.url}${separator}assetToken=${encodeURIComponent(data.assetToken)}`
   74: }
