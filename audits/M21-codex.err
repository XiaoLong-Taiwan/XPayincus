  997:   fastify.post<{ Params: PluginParams }>('/:pluginId/enable', {
  998:     onRequest: [fastify.authenticateAdmin]
  999:   }, async (request, reply) => {
 1000:     if (!(await requirePluginManager(request, reply))) return
 1001:     const pluginId = normalizePluginId(request.params.pluginId)
 1002:     if (!pluginId) return reply.code(400).send({ error: 'Invalid plugin id', code: 'INVALID_PLUGIN_ID' })
 1003:     const user = getRequestUser(request)
 1004:     const capabilityGate = await assertPluginCapabilitiesApprovedForEnable(pluginId)
 1005:     if (!capabilityGate.ok) {
 1006:       await createLog(
 1007:         user.id,
 1008:         LogModule.PLUGIN,
 1009:         'plugin.capability_review.required',
 1010:         `Blocked plugin enable for ${pluginId}: ${capabilityGate.reviews.length} capability review(s) are not approved`,
 1011:         LogResult.WARNING
 1012:       )
 1013:       return reply.code(409).send({
 1014:         error: 'High-risk plugin capabilities must be approved before enabling this extension',
 1015:         code: 'PLUGIN_CAPABILITY_REVIEW_REQUIRED',
 1016:         reviews: capabilityGate.reviews
 1017:       })
 1018:     }
 1019:     const plugin = await enablePlugin(pluginId, user.id)
 1020:     await dispatchPluginLifecycleEvent({
 1021:       event: 'plugin.enabled',
 1022:       pluginId,
 1023:       version: plugin.currentVersion,
 1024:       sourceType: plugin.sourceType,
 1025:       sourceRepo: plugin.sourceRepo,
 1026:       actor: { id: user.id, role: 'admin', username: user.username },
 1027:       dedupeKey: `plugin.enabled:${pluginId}:${plugin.currentVersion}:${plugin.enabledAt?.getTime() || Date.now()}`
 1028:     }).catch(() => undefined)
 1029:     return { plugin: serializePlugin(plugin) }
 1030:   })
