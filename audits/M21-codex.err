    8: export interface PluginMarketPublishResult {
    9:   indexPath: string
   10:   publishedEntries: number
   11:   totalEntries: number
   12:   updatedAt: string
   13: }
   14: 
   15: function isRecord(value: unknown): value is Record<string, unknown> {
   16:   return !!value && typeof value === 'object' && !Array.isArray(value)
   17: }
   18: 
   19: function pickString(value: unknown, fallback = ''): string {
   20:   return typeof value === 'string' && value.trim() ? value.trim() : fallback
   21: }
   22: 
   23: function pickStringArray(value: unknown): string[] {
   24:   return Array.isArray(value)
   25:     ? value.filter((item): item is string => typeof item === 'string' && item.trim().length > 0).map(item => item.trim())
   26:     : []
   27: }
   28: 
   29: function normalizePermissions(value: unknown): PluginMarketEntry['permissions'] {
   30:   const record = isRecord(value) ? value : {}
   31:   return {
   32:     adminPages: pickStringArray(record.adminPages),
   33:     userPages: pickStringArray(record.userPages),
   34:     api: pickStringArray(record.api),
   35:     storage: pickStringArray(record.storage)
   36:   }
   37: }
   38: 
   39: function normalizeCompatibility(value: unknown): PluginMarketEntry['compatibility'] {
   40:   const record = isRecord(value) ? value : {}
   41:   return {
   42:     minPayincus: pickString(record.minPayincus) || undefined,
   43:     maxPayincus: pickString(record.maxPayincus) || undefined
   44:   }
   45: }
   46: 
   47: function normalizePricing(value: unknown): PluginMarketEntry['pricing'] {
   48:   const record = isRecord(value) ? value : {}
   49:   const type = record.type === 'paid' ? 'paid' : 'free'
   50:   return {
   51:     type,
   52:     price: pickString(record.price) || undefined,
   53:     currency: pickString(record.currency) || undefined,
   54:     revenueSharePercent: typeof record.revenueSharePercent === 'number'
   55:       ? Math.min(Math.max(record.revenueSharePercent, 0), 100)
   56:       : record.revenueSharePercent === null
   57:         ? null
   58:         : undefined
   59:   }
   60: }
   61: 
   62: function getScanNotes(scanResult: unknown, riskLevel: string): string[] {
   63:   const notes = [`Submission scan risk level: ${riskLevel}`]
   64:   if (!isRecord(scanResult)) return notes
   65:   const status = pickString(scanResult.status)
   66:   if (status) notes.push(`Submission scan status: ${status}`)
   67:   const findings = Array.isArray(scanResult.findings) ? scanResult.findings : []
   68:   for (const finding of findings.slice(0, 5)) {
   69:     if (!isRecord(finding)) continue
   70:     const code = pickString(finding.code)
   71:     const message = pickString(finding.message)
   72:     if (code || message) notes.push(`${code || 'finding'}: ${message}`)
   73:   }
   74:   return notes
   75: }
   76: 
   77: function getPluginMarketPublishDir(): string {
   78:   return resolve(process.env.PLUGIN_MARKET_PUBLISH_DIR || join(process.cwd(), 'docs-site/docs/public/plugin-market'))
   79: }
   80: 
   81: async function getPluginMarketPublicBaseUrl(): Promise<string> {
   82:   return (await getRuntimeConfigString(
   83:     'plugin_market_public_base_url',
   84:     'PLUGIN_MARKET_PUBLIC_BASE_URL',
   85:     'https://payincus.com/plugin-market'
   86:   )).replace(/\/+$/, '')
   87: }
   88: 
   89: function submissionToMarketEntry(submission: Awaited<ReturnType<typeof prisma.pluginMarketSubmission.findMany>>[number], publicBaseUrl: string): PluginMarketEntry {
   90:   const manifestUrl = submission.manifestUrl || `${publicBaseUrl}/manifests/${submission.pluginId}/${submission.version}.json`
   91:   return {
   92:     id: submission.pluginId,
   93:     name: submission.name,
   94:     latest: submission.version,
   95:     repo: submission.repoUrl,
   96:     manifestUrl,
   97:     downloadUrl: submission.packageUrl,
   98:     sha256: submission.sha256,
   99:     description: submission.notes || undefined,
  100:     author: submission.developerName,
  101:     reviewStatus: 'listed',
  102:     trustLevel: submission.developerGithub ? 'verified' : 'third_party',
  103:     developer: {
  104:       name: submission.developerName,
  105:       homepage: submission.developerHomepage || undefined,
  106:       github: submission.developerGithub || undefined,
  107:       verified: Boolean(submission.developerGithub),
  108:       contact: submission.contactEmail
  109:     },
  110:     permissions: normalizePermissions(submission.permissions),
  111:     compatibility: normalizeCompatibility(submission.compatibility),
  112:     security: {
  113:       checksumPinned: true,
  114:       signature: { status: 'unsigned' },
  115:       notes: getScanNotes(submission.scanResult, submission.riskLevel)
  116:     },
  117:     pricing: normalizePricing(submission.pricing),
  118:     rating: { average: 0, count: 0 },
  119:     installCount: 0,
  120:     releaseNotes: submission.notes || undefined,
  121:     upgradeNotes: 'Install from the stable PayIncus extension market after reviewing permissions and SHA256.',
  122:     rollbackNotes: 'Disable or uninstall the extension from the extension center.'
  123:   }
  124: }
  125: 
  126: async function readExistingMarketEntries(indexPath: string): Promise<PluginMarketEntry[]> {
  127:   try {
  128:     const payload = JSON.parse(await readFile(indexPath, 'utf8')) as unknown
  129:     if (!isRecord(payload) || !Array.isArray(payload.plugins)) return []
  130:     return payload.plugins.filter((entry): entry is PluginMarketEntry => isRecord(entry) && typeof entry.id === 'string')
  131:   } catch {
  132:     return []
  133:   }
  134: }
  135: 
  136: export async function publishPluginMarketIndex(): Promise<PluginMarketPublishResult> {
  137:   const publishDir = getPluginMarketPublishDir()
  138:   const indexPath = join(publishDir, 'index.json')
  139:   const [existingEntries, listedSubmissions, publicBaseUrl] = await Promise.all([
  140:     readExistingMarketEntries(indexPath),
  141:     prisma.pluginMarketSubmission.findMany({
  142:       where: {
  143:         reviewStatus: 'listed',
  144:         scanStatus: { in: ['passed', 'warning'] }
  145:       },
  146:       orderBy: [{ pluginId: 'asc' }, { version: 'desc' }]
  147:     }),
  148:     getPluginMarketPublicBaseUrl()
  149:   ])
  150: 
  151:   const entriesById = new Map<string, PluginMarketEntry>()
  152:   for (const entry of existingEntries) {
  153:     entriesById.set(entry.id, entry)
  154:   }
  155:   for (const submission of listedSubmissions) {
  156:     entriesById.set(submission.pluginId, submissionToMarketEntry(submission, publicBaseUrl))
  157:   }
  158: 
  159:   const updatedAt = new Date().toISOString()
  160:   const plugins = Array.from(entriesById.values()).sort((left, right) => left.id.localeCompare(right.id))
  161:   const fingerprint = createHash('sha256').update(JSON.stringify(plugins.map(entry => ({
  162:     id: entry.id,
  163:     latest: entry.latest,
  164:     reviewStatus: entry.reviewStatus,
  165:     downloadUrl: entry.downloadUrl,
  166:     sha256: entry.sha256,
  167:     compatibility: entry.compatibility,
  168:     permissions: entry.permissions
  169:   })))).digest('hex')
  170: 
  171:   const index: PluginMarketIndex & { version: number; updatedAt: string } = {
  172:     version: 1,
  173:     updatedAt,
  174:     plugins,
  175:     governance: {
  176:       totalEntries: entriesById.size,
  177:       visibleEntries: entriesById.size,
  178:       hiddenEntries: 0,
  179:       indexHost: null,
  180:       fingerprint,
  181:       defaultReviewStatus: 'pending',
  182:       installPolicy: ['listed entries only', 'SHA256 required', 'submission scan required before publishing']
  183:     }
  184:   }
  185: 
  186:   await mkdir(dirname(indexPath), { recursive: true })
  187:   await writeFile(indexPath, `${JSON.stringify(index, null, 2)}\n`, 'utf8')
  188:   return {
  189:     indexPath,
  190:     publishedEntries: listedSubmissions.length,
  191:     totalEntries: index.plugins.length,
  192:     updatedAt
  193:   }
  194: }

