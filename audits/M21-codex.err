  762:   fastify.put<{ Body: ActionRateLimitPolicyUpdateBody }>('/action-rate-limits', {
  763:     onRequest: [fastify.authenticateAdmin],
  764:     schema: {
  765:       body: {
  766:         type: 'object',
  767:         required: ['policies'],
  768:         properties: {
  769:           policies: {
  770:             type: 'array',
  771:             maxItems: 100,
  772:             items: {
  773:               type: 'object',
  774:               required: ['rateLimit', 'maxRequests'],
  775:               properties: {
  776:                 pluginId: { type: 'string' },
  777:                 actionName: { type: 'string' },
  778:                 rateLimit: { type: 'string', enum: ['normal', 'strict'] },
  779:                 maxRequests: { type: 'integer', minimum: 1, maximum: 10000 },
  780:                 windowSeconds: { type: 'integer', minimum: 10, maximum: 3600 },
  781:                 enabled: { type: 'boolean' }
  782:               }
  783:             }
  784:           }
  785:         }
  786:       }
  787:     }
  788:   }, async (request, reply) => {
  789:     if (!(await requirePluginManager(request, reply))) return
  790:     if (!Array.isArray(request.body?.policies)) {
  791:       return reply.code(400).send({ error: 'policies must be an array', code: 'INVALID_PLUGIN_ACTION_RATE_LIMIT_POLICIES' })
  792:     }
  793: 
  794:     let policies: PublicPluginActionRateLimitPolicyInput[]
  795:     try {
  796:       policies = request.body.policies.slice(0, 100).map(normalizePublicPluginActionRateLimitPolicy)
  797:     } catch (error) {
  798:       return reply.code(400).send({
  799:         error: error instanceof Error ? error.message : 'Invalid plugin action rate limit policy',
  800:         code: 'INVALID_PLUGIN_ACTION_RATE_LIMIT_POLICY'
  801:       })
  802:     }
  803: 
  804:     const user = getRequestUser(request)
  805:     await prisma.$transaction(async tx => {
  806:       for (const policy of policies) {
  807:         await tx.$executeRaw`
  808:           INSERT INTO "public_plugin_action_rate_limit_policies" (
  809:             "plugin_id",
  810:             "action_name",
  811:             "rate_limit",
  812:             "max_requests",
  813:             "window_seconds",
  814:             "enabled",
  815:             "updated_by_user_id",
  816:             "created_at",
  817:             "updated_at"
  818:           )
  819:           VALUES (
  820:             ${policy.pluginId},

### 820-1130
  820:             ${policy.pluginId},
  821:             ${policy.actionName},
  822:             ${policy.rateLimit},
  823:             ${policy.maxRequests},
  824:             ${policy.windowSeconds},
  825:             ${policy.enabled},
  826:             ${user.id},
  827:             NOW(),
  828:             NOW()
  829:           )
  830:           ON CONFLICT ("plugin_id", "action_name", "rate_limit")
  831:           DO UPDATE SET
  832:             "max_requests" = ${policy.maxRequests},
  833:             "window_seconds" = ${policy.windowSeconds},
  834:             "enabled" = ${policy.enabled},
  835:             "updated_by_user_id" = ${user.id},
  836:             "updated_at" = NOW()
  837:         `
  838:       }
  839: 
  840:       if (policies.length > 0) {
  841:         await tx.$executeRaw`
  842:           DELETE FROM "public_plugin_action_rate_limit_buckets"
  843:           WHERE "policy" IN (
  844:             ${policies.some(policy => policy.rateLimit === 'normal') ? 'normal' : '__none__'},
  845:             ${policies.some(policy => policy.rateLimit === 'strict') ? 'strict' : '__none__'}
  846:           )
  847:         `
  848:       }
  849:     })
  850: 
  851:     await createLog(
  852:       user.id,
  853:       LogModule.PLUGIN,
  854:       'public_api.plugin_action_rate_limits.update',
  855:       `Updated ${policies.length} public plugin action rate limit policies`,
  856:       LogResult.SUCCESS
  857:     )
  858:     const updatedPolicies = await listPublicPluginActionRateLimitPolicies()
  859:     return {
  860:       defaults: PUBLIC_PLUGIN_ACTION_RATE_LIMIT_DEFAULTS,
  861:       policies: updatedPolicies.map(serializePublicPluginActionRateLimitPolicy)
  862:     }
  863:   })
