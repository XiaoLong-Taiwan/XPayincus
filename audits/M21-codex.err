  391: function normalizeAction(value: unknown, index: number): PluginActionManifest {
  392:   if (!isRecord(value)) throw new Error(`capabilities.actions[${index}] must be an object`)
  393:   const name = sanitizeString(value.name, 80)
  394:   const method = sanitizeString(value.method, 12)?.toUpperCase()
  395:   const path = sanitizeString(value.path, 160)
  396:   const runtime = sanitizeString(value.runtime, 20)
  397:   const url = sanitizeString(value.url, 500) ?? undefined
  398:   if (!name || !ACTION_NAME_PATTERN.test(name)) throw new Error(`capabilities.actions[${index}].name is invalid`)
  399:   if (!method || !['GET', 'POST', 'PUT', 'PATCH', 'DELETE'].includes(method)) throw new Error(`capabilities.actions[${index}].method is invalid`)
  400:   if (!path || !ACTION_PATH_PATTERN.test(path) || path.includes('..') || path.includes('//')) throw new Error(`capabilities.actions[${index}].path is invalid`)
  401:   if (runtime !== undefined && runtime !== 'webhook') throw new Error(`capabilities.actions[${index}].runtime is invalid`)
  402:   if (url !== undefined && !WEBHOOK_URL_PATTERN.test(url)) throw new Error(`capabilities.actions[${index}].url must be an HTTPS webhook URL`)
  403:   const idempotency = sanitizeString(value.idempotency, 20)
  404:   const rateLimit = sanitizeString(value.rateLimit, 20)
  405:   const requestSchema = normalizeActionSchema(value.requestSchema, `capabilities.actions[${index}].requestSchema`)
  406:   const responseSchema = normalizeActionSchema(value.responseSchema, `capabilities.actions[${index}].responseSchema`)
  407:   return {
  408:     name,
  409:     method: method as PluginActionManifest['method'],
  410:     path,
  411:     runtime: runtime === 'webhook' ? 'webhook' : undefined,
  412:     url,
  413:     scopes: normalizeScopes(value.scopes, `capabilities.actions[${index}].scopes`),
  414:     ...(requestSchema ? { requestSchema } : {}),
  415:     ...(responseSchema ? { responseSchema } : {}),
  416:     idempotency: idempotency === 'optional' || idempotency === 'required' ? idempotency : idempotency === 'none' ? 'none' : undefined,
  417:     rateLimit: rateLimit === 'strict' ? 'strict' : rateLimit === 'normal' ? 'normal' : undefined
  418:   }

