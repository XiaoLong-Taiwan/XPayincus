  629: async function listSubmittedPluginIds(userId: number): Promise<string[]> {
  630:   const submissions = await prisma.pluginMarketSubmission.findMany({
  631:     where: { submittedByUserId: userId },
  632:     select: { pluginId: true },
  633:     distinct: ['pluginId'],
  634:     orderBy: { pluginId: 'asc' }
  635:   })
  636:   return submissions.map(submission => submission.pluginId)
  637: }
