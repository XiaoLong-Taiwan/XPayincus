  429: async function buildDeveloperPluginEventHealth(userId: number): Promise<DeveloperPluginEventHealth[]> {
  430:   const submissions = await prisma.pluginMarketSubmission.findMany({
  431:     where: { submittedByUserId: userId },
  432:     select: { pluginId: true },
  433:     distinct: ['pluginId'],
  434:     orderBy: { pluginId: 'asc' }
  435:   })
  436:   const pluginIds = submissions.map(submission => submission.pluginId)
  437:   if (pluginIds.length === 0) return []
  438:   const now = new Date()
  439:   const recentWindowHours = 24
  440:   const recentSince = new Date(now.getTime() - recentWindowHours * 60 * 60 * 1000)
  441:   const trendWindowDays = 7
  442:   const trendSince = new Date(now.getTime() - trendWindowDays * 24 * 60 * 60 * 1000)
  443: 
  444:   return await Promise.all(pluginIds.map(async pluginId => {
  445:     const baseWhere = { pluginId, action: 'plugin.event.dispatch' }
  446:     const recentWhere = {
  447:       ...baseWhere,
  448:       OR: [
  449:         { lastAttemptAt: { gte: recentSince } },
  450:         { lastAttemptAt: null, createdAt: { gte: recentSince } }
  451:       ]
  452:     }
  453:     const [
  454:       total,
  455:       success,
  456:       failed,
  457:       retryPending,
  458:       deadLetter,
  459:       deduped,
  460:       dueRetry,
  461:       recentTotal,
  462:       recentSuccess,
  463:       recentFailed,
  464:       recentRetryPending,
  465:       recentDeadLetter,
  466:       recentDeduped,
  467:       recentDueRetry,
  468:       trendLogs,
  469:       latest,
  470:       latestSuccess,
  471:       latestFailure
  472:     ] = await Promise.all([
  473:       prisma.pluginEventLog.count({ where: baseWhere }),
  474:       prisma.pluginEventLog.count({ where: { ...baseWhere, result: 'success' } }),
  475:       prisma.pluginEventLog.count({ where: { ...baseWhere, result: 'failed' } }),
  476:       prisma.pluginEventLog.count({ where: { ...baseWhere, result: 'retry_pending' } }),
  477:       prisma.pluginEventLog.count({ where: { ...baseWhere, result: 'dead_letter' } }),
  478:       prisma.pluginEventLog.count({ where: { ...baseWhere, result: 'duplicate_skipped' } }),
  479:       prisma.pluginEventLog.count({ where: { ...baseWhere, result: 'retry_pending', deadLetterAt: null, nextRetryAt: { lte: now } } }),
  480:       prisma.pluginEventLog.count({ where: recentWhere }),
  481:       prisma.pluginEventLog.count({ where: { ...recentWhere, result: 'success' } }),
  482:       prisma.pluginEventLog.count({ where: { ...recentWhere, result: 'failed' } }),
  483:       prisma.pluginEventLog.count({ where: { ...recentWhere, result: 'retry_pending' } }),
  484:       prisma.pluginEventLog.count({ where: { ...recentWhere, result: 'dead_letter' } }),
  485:       prisma.pluginEventLog.count({ where: { ...recentWhere, result: 'duplicate_skipped' } }),
  486:       prisma.pluginEventLog.count({ where: { ...recentWhere, result: 'retry_pending', deadLetterAt: null, nextRetryAt: { lte: now } } }),
  487:       prisma.pluginEventLog.findMany({
  488:         where: {
  489:           ...baseWhere,
  490:           OR: [
  491:             { lastAttemptAt: { gte: trendSince } },
  492:             { lastAttemptAt: null, createdAt: { gte: trendSince } }
  493:           ]
  494:         },
  495:         select: { result: true, createdAt: true, lastAttemptAt: true }
  496:       }),
  497:       prisma.pluginEventLog.findFirst({ where: baseWhere, orderBy: [{ lastAttemptAt: 'desc' }, { createdAt: 'desc' }] }),
  498:       prisma.pluginEventLog.findFirst({ where: { ...baseWhere, result: 'success' }, orderBy: [{ lastAttemptAt: 'desc' }, { createdAt: 'desc' }] }),
  499:       prisma.pluginEventLog.findFirst({ where: { ...baseWhere, result: { in: ['failed', 'retry_pending', 'dead_letter'] } }, orderBy: [{ lastAttemptAt: 'desc' }, { createdAt: 'desc' }] })
  500:     ])
  501:     const pairs = await prisma.pluginEventLog.findMany({
  502:       where: {
  503:         ...baseWhere,
  504:         eventName: { not: null },
  505:         handler: { not: null }
  506:       },
  507:       distinct: ['eventName', 'handler'],
  508:       select: { eventName: true, handler: true },
  509:       orderBy: [{ eventName: 'asc' }, { handler: 'asc' }]
  510:     })
  511:     const breakdown = await Promise.all(pairs.slice(0, 50).map(async pair => {
  512:       const eventName = pair.eventName || ''
  513:       const handler = pair.handler || ''
  514:       const scopedWhere = { ...baseWhere, eventName, handler }
  515:       const scopedRecentWhere = { ...recentWhere, eventName, handler }
  516:       const [
  517:         itemTotal,
  518:         itemSuccess,
  519:         itemFailed,
