  570:         recentTotal: itemRecentTotal,
  571:         recentSuccess: itemRecentSuccess,
  572:         recentFailed: itemRecentFailed,
  573:         recentRetryPending: itemRecentRetryPending,
  574:         recentDeadLetter: itemRecentDeadLetter,
  575:         recentDeduped: itemRecentDeduped,
  576:         recentDueRetry: itemRecentDueRetry,
  577:         recentSuccessRate: itemRecentSuccessRate,
  578:         alerts: buildDeveloperEventAlerts({
  579:           deadLetter: itemDeadLetter,
  580:           dueRetry: itemDueRetry,
  581:           recentTotal: itemRecentTotal,
  582:           recentFailed: itemRecentFailed,
  583:           recentRetryPending: itemRecentRetryPending,
  584:           recentDeadLetter: itemRecentDeadLetter,
  585:           recentSuccessRate: itemRecentSuccessRate
  586:         })
  587:       }
  588:     }))
  589:     const recentSuccessRate = calculateSuccessRate(recentSuccess, recentTotal)
  590: 
  591:     return {
  592:       pluginId,
  593:       total,
  594:       success,
  595:       failed,
  596:       retryPending,
  597:       deadLetter,
  598:       deduped,
  599:       dueRetry,
  600:       lastEventAt: (latest?.lastAttemptAt || latest?.createdAt)?.toISOString() || null,
  601:       lastSuccessAt: (latestSuccess?.lastAttemptAt || latestSuccess?.createdAt)?.toISOString() || null,
  602:       lastFailureAt: (latestFailure?.lastAttemptAt || latestFailure?.createdAt)?.toISOString() || null,
  603:       lastError: latestFailure?.lastError || latestFailure?.message || null,
  604:       recentWindowHours,
  605:       recentTotal,
  606:       recentSuccess,
  607:       recentFailed,
  608:       recentRetryPending,
  609:       recentDeadLetter,
  610:       recentDeduped,
  611:       recentDueRetry,
  612:       recentSuccessRate,
  613:       trendWindowDays,
  614:       trend: buildDeveloperEventTrend(trendLogs, now, trendWindowDays),
  615:       alerts: buildDeveloperEventAlerts({
  616:         deadLetter,
  617:         dueRetry,
  618:         recentTotal,
  619:         recentFailed,
  620:         recentRetryPending,
  621:         recentDeadLetter,
  622:         recentSuccessRate
  623:       }),
  624:       breakdown
  625:     }
  626:   }))
  627: }
