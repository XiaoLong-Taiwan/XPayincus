626:async function loadAiVisibleInstances(userId: number, linkedInstanceId: number | null) {
627:  const select = {
628:    id: true,
629:    name: true,
630:    status: true,
631:    cpu: true,
632:    memory: true,
633:    disk: true,
634:    ipv4: true,
635:    ipv6: true,
636:    expiresAt: true,
637:    monthlyTrafficUsed: true,
638:    monthlyTrafficLimit: true,
639:    trafficStatus: true,
640:    createdAt: true,
641:    package: { select: { name: true } },
642:    packagePlan: { select: { name: true } },
643:    _count: { select: { portMappings: true } },
644:    instanceTasks: {
645:      orderBy: { createdAt: 'desc' as const },
646:      take: 1,
647:      select: {
648:        taskType: true,
649:        status: true,
650:        progress: true,
651:        createdAt: true,
652:        finishedAt: true
653:      }
654:    }
655:  }
656:
657:  const linkedInstance = linkedInstanceId
658:    ? await prisma.instance.findFirst({
659:        where: {
660:          id: linkedInstanceId,
661:          userId,
662:          status: { not: 'deleted' }
663:        },
664:        select
665:      })
666:    : null
667:
668:  const recentInstances = await prisma.instance.findMany({
669:    where: {
670:      userId,
671:      status: { not: 'deleted' },
672:      ...(linkedInstanceId ? { id: { not: linkedInstanceId } } : {})
673:    },
674:    orderBy: { createdAt: 'desc' },
675:    take: linkedInstance ? MAX_USER_INSTANCES - 1 : MAX_USER_INSTANCES,
676:    select
677:  })
678:
679:  return linkedInstance ? [linkedInstance, ...recentInstances] : recentInstances
680:}
