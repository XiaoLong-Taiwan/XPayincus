538:  fastify.post<{
539:    Params: { id: string }
540:  }>('/:id/ai/context', {
541:    onRequest: [fastify.authenticate, fastify.requireAdmin],
542:    schema: {
543:      params: {
544:        type: 'object',
545:        required: ['id'],
546:        properties: {
547:          id: { type: 'string', pattern: '^[1-9]\\d*$' }
548:        }
549:      }
550:    }
551:  }, async (request: FastifyRequest<{
552:    Params: { id: string }
553:  }>, reply: FastifyReply) => {
554:    const { user } = request
555:    const ticketId = parsePositiveId(request.params.id)
556:
557:    if (ticketId === null) {
558:      return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
559:    }
560:
561:    const permission = await getAiTicketContextPermission()
562:    if (!permission.allowed) {
563:      await auditAiTicketContextRead({
564:        actorUserId: user.id,
565:        ticketId,
566:        result: 'denied',
567:        reason: permission.code
568:      })
569:      return reply.code(403).send({
