47:function normalizeBaseUrl(baseUrl: string): string {
48:  return baseUrl.trim().replace(/\/+$/, '')
49:}
50:
51:function resolveLskyApiBase(baseUrl: string, apiVersion: LskyApiVersion): string {
52:  const normalized = normalizeBaseUrl(baseUrl)
53:  const apiPrefix = apiVersion === 'v2' ? '/api/v2' : '/api/v1'
54:
55:  if (normalized.toLowerCase().endsWith(apiPrefix)) {
56:    return normalized
57:  }
58:
59:  return `${normalized}${apiPrefix}`
60:}
61:
62:function asNullableString(value: unknown): string | null {
63:  if (typeof value !== 'string') {
64:    return null
65:  }
66:
67:  const trimmed = value.trim()
68:  return trimmed.length > 0 ? trimmed : null
69:}
70:
71:function pickString(...values: unknown[]): string | null {
72:  for (const value of values) {
73:    const str = asNullableString(value)
74:    if (str) {
75:      return str
76:    }
77:  }
78:
79:  return null
80:}
81:
82:function pickNumber(...values: unknown[]): number | null {
83:  for (const value of values) {
84:    if (typeof value === 'number' && Number.isFinite(value)) {
85:      return value
86:    }
87:    if (typeof value === 'string' && value.trim().length > 0) {
88:      const parsed = Number(value)
89:      if (Number.isFinite(parsed)) {
90:        return parsed
91:      }
92:    }
93:  }
94:
95:  return null
96:}
97:
98:function normalizeAllowedImageMimeType(value: string | null | undefined): string | null {
99:  const normalized = value?.split(';')[0]?.trim().toLowerCase()
100:  return normalized && ALLOWED_LSKY_IMAGE_MIME_TYPES.has(normalized) ? normalized : null
101:}
102:
103:function parseJsonResponse(text: string): unknown {
104:  const normalizedText = text.replace(/^\uFEFF/, '')
105:  if (!normalizedText.trim()) {
106:    return null
107:  }
108:
109:  try {
110:    return JSON.parse(normalizedText)
111:  } catch {
112:    return null
113:  }
114:}
115:
116:function sanitizeResponsePreview(text: string): string {
117:  return sanitizeTokensInString(text.slice(0, 500))
118:}
119:
120:function extractUrlFromHtmlSnippet(html: string | null): string | null {
121:  if (!html) {
122:    return null
123:  }
124:
125:  const srcMatch = html.match(/src="([^"]+)"/i)
126:  if (srcMatch?.[1]) {
127:    return srcMatch[1]
128:  }
129:
130:  const markdownMatch = html.match(/\((https?:\/\/[^)]+)\)/i)
131:  if (markdownMatch?.[1]) {
132:    return markdownMatch[1]
133:  }
134:
135:  return null
136:}
137:
138:function joinUrl(baseUrl: string, pathname: string | null): string | null {
139:  const normalizedPath = asNullableString(pathname)?.replace(/^\/+/, '')
140:  if (!normalizedPath) {
141:    return null
142:  }
143:
144:  return `${normalizeBaseUrl(baseUrl)}/${normalizedPath}`
145:}
146:
147:function pickProviderFileId(...values: unknown[]): string | null {
148:  for (const value of values) {
149:    const picked = typeof value === 'number' && Number.isFinite(value)
150:      ? String(value)
151:      : asNullableString(value)
152:    if (picked) {
153:      return picked.replace(/^\/+/, '')
154:    }
155:  }
156:
157:  return null
158:}
159:
160:function parseProviderNumericId(providerFileId: string): number | null {
161:  if (!/^[1-9][0-9]*$/.test(providerFileId)) {
162:    return null
163:  }
164:
165:  const id = Number(providerFileId)
166:  return Number.isSafeInteger(id) ? id : null
167:}
168:
169:function extractLskyErrorMessage(payload: any, fallback: string): string {
170:  return pickString(
171:    payload?.message,
172:    payload?.msg,
173:    payload?.error?.message,
174:    payload?.error,
175:    payload?.errors?.[0]?.message
176:  ) || fallback
177:}
178:
179:function extractUploadDataCandidates(payload: any): any[] {
180:  const candidates = [
181:    payload?.data?.data,
182:    payload?.data?.photo,
183:    payload?.data?.image,
184:    payload?.data,
185:    payload?.result?.data,
186:    payload?.result?.photo,
187:    payload?.result,
188:    payload
189:  ]
190:
191:  return candidates.filter(candidate => candidate && typeof candidate === 'object')
192:}
