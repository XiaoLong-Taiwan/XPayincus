523:async function requestAiTicketDraft(context: AiTicketContext, config: AiTicketAgentConfig): Promise<string> {
524:  const controller = new AbortController()
525:  const timeout = setTimeout(() => controller.abort(), config.timeoutMs)
526:
527:  try {
528:    let response: Response
529:    try {
530:      response = await fetch(resolveChatCompletionsUrl(config.apiBaseUrl), {
531:        method: 'POST',
532:        headers: {
533:          'Content-Type': 'application/json',
534:          Authorization: `Bearer ${config.apiKey}`
535:        },
536:        body: JSON.stringify({
537:          model: config.model,
538:          temperature: config.temperature,
539:          messages: [
540:            { role: 'system', content: buildAiTicketSystemPrompt(config) },
541:            { role: 'user', content: buildAiTicketUserPrompt(context, config) }
542:          ]
543:        }),
544:        signal: controller.signal
545:      })
546:    } catch {
547:      throw new Error('AI_TICKET_MODEL_REQUEST_FAILED')
548:    }
549:
550:    if (!response.ok) {
551:      throw new Error('AI_TICKET_MODEL_REQUEST_FAILED')
552:    }
553:
554:    const body = await response.json() as {
555:      choices?: Array<{ message?: { content?: string } }>
556:    }
557:    const draft = body.choices?.[0]?.message?.content?.trim()
558:    if (!draft) {
559:      throw new Error('AI_TICKET_MODEL_EMPTY_RESPONSE')
560:    }
561:
562:    return draft.slice(0, MAX_AI_DRAFT_LENGTH)
563:  } finally {
564:    clearTimeout(timeout)
565:  }
566:}
567:
568:async function requestAiTicketDecision(
569:  context: AiTicketContext,
570:  config: AiTicketAgentConfig
571:): Promise<{ draft: string; confidence: number; handoffRequired: boolean; handoffReason: string | null }> {
572:  const controller = new AbortController()
573:  const timeout = setTimeout(() => controller.abort(), config.timeoutMs)
574:
575:  try {
576:    let response: Response
577:    try {
578:      response = await fetch(resolveChatCompletionsUrl(config.apiBaseUrl), {
579:        method: 'POST',
580:        headers: {
581:          'Content-Type': 'application/json',
582:          Authorization: `Bearer ${config.apiKey}`
583:        },
584:        body: JSON.stringify({
585:          model: config.model,
586:          temperature: Math.min(config.temperature, 0.2),
587:          messages: [
588:            { role: 'system', content: buildAiTicketSystemPrompt(config) },
589:            { role: 'user', content: buildAiTicketDecisionPrompt(context, config) }
590:          ]
591:        }),
592:        signal: controller.signal
593:      })
594:    } catch {
595:      throw new Error('AI_TICKET_MODEL_REQUEST_FAILED')
596:    }
597:
598:    if (!response.ok) {
599:      throw new Error('AI_TICKET_MODEL_REQUEST_FAILED')
600:    }
601:
602:    const body = await response.json() as {
603:      choices?: Array<{ message?: { content?: string } }>
604:    }
605:    const content = body.choices?.[0]?.message?.content?.trim()
606:    if (!content) {
607:      throw new Error('AI_TICKET_MODEL_EMPTY_RESPONSE')
608:    }
609:
610:    const decision = parseAiDecisionJson(content)
611:    if (!decision) {
612:      throw new Error('AI_TICKET_MODEL_DECISION_INVALID')
613:    }
614:
615:    return {
616:      draft: decision.reply.slice(0, MAX_AI_DRAFT_LENGTH),
617:      confidence: decision.confidence,
618:      handoffRequired: decision.handoffRequired,
619:      handoffReason: decision.handoffReason
620:    }
621:  } finally {
622:    clearTimeout(timeout)
623:  }
624:}
