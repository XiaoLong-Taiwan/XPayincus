594:
595:  /**
596:   * ç”Ÿæˆ AI å·¥å•å›žå¤è‰ç¨¿ï¼ˆä»…ç®¡ç†å‘˜ + å·²å¯ç”¨ AI å·¥å•æ’ä»¶ï¼‰
597:   * POST /tickets/:id/ai/draft
598:   */
599:  fastify.post<{
600:    Params: { id: string }
601:  }>('/:id/ai/draft', {
602:    onRequest: [fastify.authenticate, fastify.requireAdmin],
603:    schema: {
604:      params: {
605:        type: 'object',
606:        required: ['id'],
607:        properties: {
608:          id: { type: 'string', pattern: '^[1-9]\\d*$' }
609:        }
610:      }
611:    }
612:  }, async (request: FastifyRequest<{
613:    Params: { id: string }
614:  }>, reply: FastifyReply) => {
615:    const { user } = request
616:    const ticketId = parsePositiveId(request.params.id)
617:
618:    if (ticketId === null) {
619:      return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
620:    }
621:
622:    const permission = await getAiTicketPermission(AI_TICKET_DRAFT_PERMISSION)
623:    if (!permission.allowed) {
624:      await auditAiTicketDraft({
625:        actorUserId: user.id,
626:        ticketId,
627:        result: 'denied',
628:        reason: permission.code
629:      })
630:      return reply.code(403).send({
631:        error: permission.message || 'AI ticket draft is not available',
632:        code: permission.code || 'AI_TICKET_DRAFT_DENIED'
633:      })
634:    }
635:
636:    try {
637:      const result = await generateAiTicketDraft(ticketId)
638:      if (!result.safety.passed) {
639:        await auditAiTicketDraft({
640:          actorUserId: user.id,
641:          ticketId,
642:          result: 'blocked',
643:          reason: result.safety.blockedReasons.join(',')
644:        })
645:        return reply.code(422).send({
646:          error: 'AI draft failed safety checks',
647:          code: 'AI_TICKET_DRAFT_BLOCKED',
648:          safety: result.safety
649:        })
650:      }
651:
652:      await auditAiTicketDraft({
653:        actorUserId: user.id,
654:        ticketId,
655:        result: 'success'
656:      })
657:      return reply.send(result)
658:    } catch (error) {
659:      const message = error instanceof Error ? error.message : String(error)
660:      const knownStatus: Record<string, number> = {
661:        AI_TICKET_AGENT_DISABLED: 403,
662:        AI_TICKET_AGENT_MODEL_NOT_CONFIGURED: 400,
663:        TICKET_NOT_FOUND: 404
664:      }
665:      const statusCode = knownStatus[message] || 502
666:      await auditAiTicketDraft({
667:        actorUserId: user.id,
668:        ticketId,
669:        result: 'failed',
670:        reason: message
671:      })
672:
673:      if (message === 'TICKET_NOT_FOUND') {
674:        return reply.code(404).send(apiError(ErrorCode.NOT_FOUND))
675:      }
676:
677:      return reply.code(statusCode).send({
678:        error: statusCode === 502 ? 'AI draft generation failed' : message,
679:        code: message.startsWith('AI_TICKET_') ? message : 'AI_TICKET_DRAFT_FAILED'
680:      })
681:    }
682:  })
