985:          expiresAt: toIso(instance.expiresAt),
986:          monthlyTrafficUsed: valueToString(instance.monthlyTrafficUsed),
987:          monthlyTrafficLimit: nullableValueToString(instance.monthlyTrafficLimit),
988:          trafficStatus: instance.trafficStatus,
989:          portCount: instance._count.portMappings,
990:          latestTask: latestTask ? {
