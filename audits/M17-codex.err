311:  /**
312:   * èŽ·å–æˆ‘çš„å·¥å•åˆ—è¡¨
313:   * GET /tickets
314:   * æ”¯æŒ active çŠ¶æ€ç­›é€‰ï¼ˆæŽ’é™¤å·²å…³é—­ï¼‰ã€æœç´¢
315:   */
316:  fastify.get<{
317:    Querystring: {
318:      status?: ExtendedTicketStatus
319:      search?: string
320:      page?: number
321:      pageSize?: number
322:    }
323:  }>('/', {
324:    onRequest: [fastify.authenticate]
325:  }, async (request: FastifyRequest<{
326:    Querystring: {
327:      status?: ExtendedTicketStatus
328:      search?: string
329:      page?: number
330:      pageSize?: number
331:    }
332:  }>, reply: FastifyReply) => {
333:    const { user } = request
334:    const { status, search, page, pageSize } = request.query
335:
336:    // éªŒè¯çŠ¶æ€
337:    if (status && status !== 'active' && !VALID_STATUSES.includes(status as TicketStatus)) {
338:      return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid status'))
339:    }
340:
341:    const result = await ticketDb.getUserTickets(user.id, {
342:      status: status as TicketStatus | 'active' | undefined,
343:      search,
344:      page: parsePositiveInteger(page, 1),
345:      pageSize: parsePositiveInteger(pageSize, 10, 100)
346:    })
347:
348:    return reply.send(result)
349:  })
350:
351:  /**
352:   * è¯»å–å·¥å•å›¾ç‰‡å†…å®¹ï¼ˆé‰´æƒä»£ç†ï¼‰
353:   * GET /tickets/attachments/:attachmentId/content
354:   */
355:  fastify.get<{
356:    Params: { attachmentId: string }
357:  }>('/attachments/:attachmentId/content', {
358:    onRequest: [fastify.authenticate]
359:  }, async (request: FastifyRequest<{
360:    Params: { attachmentId: string }
361:  }>, reply: FastifyReply) => {
362:    const { user } = request
363:    const attachmentId = parsePositiveId(request.params.attachmentId)
364:
365:    if (attachmentId === null) {
366:      return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
367:    }
368:
369:    const attachment = await ticketDb.getTicketMessageAttachmentById(attachmentId)
370:    if (!attachment) {
371:      return reply.code(404).send(apiError(ErrorCode.NOT_FOUND))
372:    }
373:
374:    const access = await ticketDb.canUserAccessTicket(user.id, attachment.ticketId, user.role)
375:    if (!access.canAccess) {
376:      return reply.code(404).send(apiError(ErrorCode.NOT_FOUND))
377:    }
378:
379:    let upstream: Response
380:    try {
381:      const safeImageUrl = await assertSafeHttpUrl(attachment.url, 'Ticket attachment image URL')
382:      upstream = await fetch(safeImageUrl.toString(), {
383:        redirect: 'manual',
384:        signal: AbortSignal.timeout(TICKET_PROXY_FETCH_TIMEOUT_MS)
385:      })
386:    } catch {
387:      return reply.code(502).send(apiError(ErrorCode.INTERNAL_ERROR, 'Failed to load remote image'))
388:    }
389:
390:    if (!upstream.ok) {
391:      return reply.code(502).send(apiError(ErrorCode.INTERNAL_ERROR, 'Failed to load remote image'))
392:    }
393:
394:    const upstreamMimeType = normalizeAllowedImageMimeType(upstream.headers.get('content-type'))
395:    const storedMimeType = normalizeAllowedImageMimeType(attachment.mimeType)
396:    if (upstream.headers.get('content-type') && !upstreamMimeType) {
397:      return reply.code(502).send(apiError(ErrorCode.INTERNAL_ERROR, 'Remote file is not an allowed image type'))
398:    }
399:    const responseMimeType = upstreamMimeType ?? storedMimeType
400:    if (!responseMimeType) {
401:      return reply.code(502).send(apiError(ErrorCode.INTERNAL_ERROR, 'Attachment image type is not allowed'))
402:    }
403:
404:    let imageBuffer: Buffer
405:    try {
406:      imageBuffer = await readRemoteImageBody(upstream)
407:    } catch {
408:      return reply.code(502).send(apiError(ErrorCode.INTERNAL_ERROR, 'Remote image is too large'))
409:    }
410:
411:    reply.header('Cache-Control', 'private, max-age=300')
412:    reply.header('X-Content-Type-Options', 'nosniff')
413:    reply.header('Content-Type', responseMimeType)
414:    return reply.send(imageBuffer)
415:  })
