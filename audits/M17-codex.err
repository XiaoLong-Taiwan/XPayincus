6:export class OutboundTargetValidationError extends Error {
7:  constructor(message: string) {
8:    super(message)
9:    this.name = 'OutboundTargetValidationError'
10:  }
11:}
12:
13:type SupportedProtocol = 'http' | 'https' | 'ftp' | 'sftp'
14:
15:function buildUrl(input: string, defaultProtocol: SupportedProtocol): URL {
16:  const trimmed = input.trim()
17:  if (!trimmed) {
18:    throw new OutboundTargetValidationError('Target cannot be empty')
19:  }
20:
21:  try {
22:    if (trimmed.includes('://')) {
23:      return new URL(trimmed)
24:    }
25:    return new URL(`${defaultProtocol}://${trimmed}`)
26:  } catch {
27:    throw new OutboundTargetValidationError('Target format is invalid')
28:  }
29:}
