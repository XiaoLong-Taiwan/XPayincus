98:async function isStillAutoReplyEligible(ticketId: number): Promise<boolean> {
99:  const ticket = await loadTicketForAutoReply(ticketId)
100:  if (!ticket) return false
101:  if (ticket.status !== 'open' && ticket.status !== 'in_progress') return false
102:  if (ticket.hostId && ticket.host?.user.role !== 'admin') return false
103:  return ticket.messages[0]?.isFromOwner === false
104:}
