 succeeded in 582ms:
1:import { nanoid } from 'nanoid'
2:
3:export type ActionTicketType = 'oauth-bind' | 'terminal'
4:
5:interface BaseActionTicket {
6:  type: ActionTicketType
7:  userId: number
8:  issuedAt: number
9:  sessionId?: string
10:  expiresAt: number
11:  createdAt: number
12:  usageCount: number
13:  maxUsage: number
14:}
15:
16:interface OAuthBindTicket extends BaseActionTicket {
17:  type: 'oauth-bind'
18:}
19:
20:interface TerminalTicket extends BaseActionTicket {
21:  type: 'terminal'
22:  instanceId: number
23:}
24:
25:type ActionTicket = OAuthBindTicket | TerminalTicket
26:
27:const actionTickets = new Map<string, ActionTicket>()
28:
29:const ACTION_TICKET_TTL_MS = {
30:  'oauth-bind': 60 * 1000,
31:  terminal: 60 * 1000
32:} as const
33:
34:setInterval(() => {
35:  const now = Date.now()
36:  for (const [token, data] of actionTickets.entries()) {
37:    if (now > data.expiresAt || data.usageCount >= data.maxUsage) {
38:      actionTickets.delete(token)
39:    }
40:  }
41:}, 60 * 1000)
42:
43:function createTicket<T extends ActionTicket>(ticket: T): string {
44:  const token = nanoid(32)
45:  actionTickets.set(token, ticket)
46:  return token
47:}
48:
49:export function generateOAuthBindTicket(
50:  userId: number,
51:  issuedAt: number,
52:  sessionId?: string
53:): string {
54:  const now = Date.now()
55:  return createTicket({
56:    type: 'oauth-bind',
57:    userId,
58:    issuedAt,
59:    sessionId,
60:    expiresAt: now + ACTION_TICKET_TTL_MS['oauth-bind'],
61:    createdAt: now,
62:    usageCount: 0,
63:    maxUsage: 1
64:  })
65:}
66:
67:export function generateTerminalAccessTicket(
68:  userId: number,
69:  instanceId: number,
70:  issuedAt: number,
71:  sessionId?: string
72:): string {
73:  const now = Date.now()
74:  return createTicket({
75:    type: 'terminal',
76:    userId,
77:    instanceId,
78:    issuedAt,
79:    sessionId,
80:    expiresAt: now + ACTION_TICKET_TTL_MS.terminal,
81:    createdAt: now,
82:    usageCount: 0,
83:    maxUsage: 1
84:  })
85:}
86:
87:export interface OAuthBindTicketConsumeResult {
88:  valid: boolean
89:  userId?: number
90:  issuedAt?: number
91:  sessionId?: string
92:  error?: string
93:}
94:
95:export interface TerminalTicketConsumeResult {
96:  valid: boolean
97:  userId?: number
98:  instanceId?: number
99:  issuedAt?: number
100:  sessionId?: string
101:  error?: string
102:}
103:
104:export function consumeOAuthBindTicket(token: string): OAuthBindTicketConsumeResult {
105:  const ticket = actionTickets.get(token)
106:  if (!ticket || ticket.type !== 'oauth-bind') {
107:    return { valid: false, error: 'Ticket not found or already used' }
108:  }
109:
110:  if (Date.now() > ticket.expiresAt) {
111:    actionTickets.delete(token)
112:    return { valid: false, error: 'Ticket expired' }
113:  }
114:
115:  ticket.usageCount += 1
116:  if (ticket.usageCount >= ticket.maxUsage) {
117:    actionTickets.delete(token)
118:  } else {
119:    actionTickets.set(token, ticket)
120:  }
121:
122:  return {
123:    valid: true,
124:    userId: ticket.userId,
125:    issuedAt: ticket.issuedAt,
126:    sessionId: ticket.sessionId
127:  }
128:}
129:
130:export function consumeTerminalAccessTicket(
131:  token: string,
132:  expectedInstanceId?: number
133:): TerminalTicketConsumeResult {
134:  const ticket = actionTickets.get(token)
135:  if (!ticket || ticket.type !== 'terminal') {
136:    return { valid: false, error: 'Ticket not found or already used' }
137:  }
138:
139:  if (Date.now() > ticket.expiresAt) {
140:    actionTickets.delete(token)
141:    return { valid: false, error: 'Ticket expired' }
142:  }
143:
144:  if (expectedInstanceId !== undefined && ticket.instanceId !== expectedInstanceId) {
145:    actionTickets.delete(token)
146:    return { valid: false, error: 'Instance mismatch' }
147:  }
148:
149:  ticket.usageCount += 1
150:  if (ticket.usageCount >= ticket.maxUsage) {
151:    actionTickets.delete(token)
152:  } else {
153:    actionTickets.set(token, ticket)
154:  }
155:
156:  return {
157:    valid: true,
158:    userId: ticket.userId,
159:    instanceId: ticket.instanceId,
160:    issuedAt: ticket.issuedAt,
161:    sessionId: ticket.sessionId
162:  }
163:}
164:
165:export function revokeActionTicketsForSession(sessionId: string): number {
166:  let revoked = 0
167:  for (const [token, data] of actionTickets.entries()) {
168:    if (data.sessionId === sessionId) {
169:      actionTickets.delete(token)
170:      revoked += 1
171:    }
172:  }
173:  return revoked
174:}

