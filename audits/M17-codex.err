784:export async function buildAiTicketContext(ticketId: number): Promise<AiTicketContext | null> {
785:  const ticket = await prisma.ticket.findUnique({
786:    where: { id: ticketId },
787:    select: {
788:      id: true,
789:      userId: true,
790:      instanceId: true,
791:      subject: true,
792:      category: true,
793:      priority: true,
794:      status: true,
795:      createdAt: true,
796:      updatedAt: true,
797:      messages: {
798:        orderBy: { createdAt: 'desc' },
799:        take: MAX_TICKET_MESSAGES,
800:        select: {
801:          content: true,
802:          isFromOwner: true,
803:          createdAt: true
804:        }
805:      }
806:    }
807:  })
808:
809:  if (!ticket) return null
810:
811:  const knowledgeQuestion = [
812:    ticket.subject,
813:    ...ticket.messages.map(message => message.content)
814:  ].join(' ')
815:
816:  const [user, payments, instances, publicPackages, helpArticles] = await Promise.all([
817:    prisma.user.findUnique({
818:      where: { id: ticket.userId },
819:      select: {
820:        username: true,
821:        status: true,
822:        balance: true,
823:        createdAt: true,
824:        _count: {
825:          select: {
826:            instances: true,
827:            rechargeRecords: true,
828:            ticketsCreated: true
829:          }
830:        }
831:      }
832:    }),
833:    prisma.rechargeRecord.findMany({
834:      where: { userId: ticket.userId },
835:      orderBy: { createdAt: 'desc' },
836:      take: MAX_RECENT_PAYMENTS,
837:      select: {
838:        id: true,
839:        orderNo: true,
840:        amount: true,
841:        actualAmount: true,
842:        status: true,
843:        paymentMethod: true,
844:        createdAt: true,
845:        completedAt: true,
846:        provider: {
847:          select: {
848:            name: true
849:          }
850:        }
851:      }
852:    }),
853:    loadAiVisibleInstances(ticket.userId, ticket.instanceId),
854:    prisma.package.findMany({
855:      where: {
856:        active: true,
857:        globalShared: true
858:      },
859:      orderBy: { createdAt: 'desc' },
860:      take: MAX_PUBLIC_PACKAGES,
861:      select: {
862:        id: true,
863:        name: true,
864:        description: true,
865:        networkMode: true,
866:        instanceType: true,
867:        active: true,
868:        plans: {
869:          where: { isActive: true },
870:          orderBy: [{ sortOrder: 'asc' }, { price: 'asc' }],
871:          take: 6,
872:          select: {
873:            id: true,
874:            name: true,
875:            description: true,
876:            cpu: true,
877:            memory: true,
878:            disk: true,
879:            price: true,
880:            billingCycle: true,
881:            setupFee: true,
882:            isSoldOut: true
883:          }
884:        }
885:      }
886:    }),
887:    prisma.helpArticle.findMany({
888:      where: { published: true },
889:      orderBy: [
890:        { pinned: 'desc' },
891:        { sortOrder: 'asc' },
892:        { updatedAt: 'desc' }
893:      ],
894:      take: 40,
895:      select: {
896:        title: true,
897:        slug: true,
898:        category: true,
899:        content: true,
900:        updatedAt: true
901:      }
902:    })
903:  ])
904:
905:  const questionTokens = tokenize(knowledgeQuestion)
906:  const knowledge = helpArticles
907:    .map(article => ({ article, score: scoreKnowledge(questionTokens, article) }))
908:    .sort((a, b) => b.score - a.score)
909:    .slice(0, MAX_KNOWLEDGE_ITEMS)
910:    .map(({ article }) => ({
911:      title: article.title,
912:      slug: article.slug,
913:      category: article.category,
914:      excerpt: cleanText(stripMarkdown(article.content), MAX_KNOWLEDGE_EXCERPT_LENGTH),
915:      updatedAt: article.updatedAt.toISOString()
916:    }))
917:
918:  return {
919:    policy: {
920:      dataScope: 'ticket_user_only',
921:      redaction: 'ai_safe_summary',
922:      forbiddenData: [
923:        'admin_internal_notes',
924:        'payment_callback_payloads',
925:        'provider_secret_config',
926:        'root_passwords',
927:        'ssh_keys',
928:        'host_certificates',
929:        'agent_secrets',
930:        'login_ip_or_user_agent',
931:        'server_paths',
