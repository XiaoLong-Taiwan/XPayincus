245:export async function getTicketImageLskyConfig(): Promise<TicketImageLskyConfig | null> {
246:  const [baseUrl, token, apiVersionValue, targetId] = await Promise.all([
247:    getSystemConfig('ticket_image_lsky_base_url'),
248:    getSystemConfig('ticket_image_lsky_token'),
249:    getSystemConfig('ticket_image_lsky_api_version'),
250:    getSystemConfig('ticket_image_lsky_target_id')
251:  ])
252:
253:  const normalizedBaseUrl = asNullableString(baseUrl)
254:  const normalizedToken = asNullableString(token)
255:  if (!normalizedBaseUrl || !normalizedToken) {
256:    return null
257:  }
258:
259:  const apiVersion: LskyApiVersion = apiVersionValue === 'v2' ? 'v2' : 'v1'
260:  const safeBaseUrl = await assertSafeHttpUrl(normalizedBaseUrl, 'Lsky base URL')
261:
262:  return {
263:    baseUrl: normalizeBaseUrl(safeBaseUrl.toString()),
264:    token: normalizedToken,
265:    apiVersion,
266:    targetId: asNullableString(targetId)
267:  }
268:}
