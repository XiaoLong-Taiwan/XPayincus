179:function toIso(value: Date | string | null | undefined): string | null {
180:  if (!value) return null
179:function toIso(value: Date | string | null | undefined): string | null {
180:  if (!value) return null
181:  return value instanceof Date ? value.toISOString() : new Date(value).toISOString()
182:}
183:
184:function valueToString(value: unknown): string {
185:  if (value === null || value === undefined) return ''
186:  if (typeof value === 'bigint') return value.toString()
187:  if (typeof value === 'number') return Number.isFinite(value) ? String(value) : ''
188:  if (typeof value === 'string') return value
189:  if (typeof value === 'object' && 'toString' in value && typeof value.toString === 'function') {
190:    return value.toString()
191:  }
192:  return String(value)
193:}
194:
195:function nullableValueToString(value: unknown): string | null {
196:  if (value === null || value === undefined) return null
197:  return valueToString(value)
198:}
199:
200:function maskIdentifier(value: string | null | undefined, visible = 6): string {
201:  const normalized = value?.trim()
202:  if (!normalized) return ''
203:  if (normalized.length <= visible) return normalized
204:  return `***${normalized.slice(-visible)}`
205:}
206:
207:function cleanText(value: string, maxLength: number): string {
208:  return value
209:    .replace(/\s+/g, ' ')
210:    .trim()
211:    .slice(0, maxLength)
212:}
213:
214:function stripMarkdown(content: string): string {
215:  return content
216:    .replace(/```[\s\S]*?```/g, ' ')
217:    .replace(/`([^`]+)`/g, '$1')
218:    .replace(/!\[[^\]]*]\([^)]*\)/g, ' ')
219:    .replace(/\[([^\]]+)]\([^)]*\)/g, '$1')
220:    .replace(/[#>*_\-~|]/g, ' ')
221:}
222:
223:function tokenize(input: string): string[] {
224:  return Array.from(new Set(
225:    input
226:      .toLowerCase()
227:      .replace(/[^\p{L}\p{N}\s]/gu, ' ')
228:      .split(/\s+/)
229:      .map(token => token.trim())
230:      .filter(token => token.length >= 2)
231:  ))
232:}
233:
234:function scoreKnowledge(questionTokens: string[], article: { title: string; category: string; content: string }): number {
235:  if (questionTokens.length === 0) return 0
236:  const title = article.title.toLowerCase()
237:  const category = article.category.toLowerCase()
238:  const content = stripMarkdown(article.content).toLowerCase()
239:  let score = 0
240:
241:  for (const token of questionTokens) {
242:    if (title.includes(token)) score += 6
243:    if (category.includes(token)) score += 3
244:    if (content.includes(token)) score += 1
245:  }
246:
247:  return score
248:}
249:
250:function parseJsonConfigValue(value: unknown): unknown {
251:  if (typeof value !== 'string') return value
252:  try {
253:    return JSON.parse(value)
254:  } catch {
255:    return value
256:  }
257:}
258:
259:function parseSecretConfigValue(value: string | null): unknown {
260:  if (!value) return null
261:  const decrypted = decryptSensitiveData(value)
262:  return parseJsonConfigValue(decrypted)
263:}
264:
265:function getConfigString(configs: Map<string, unknown>, key: string, fallback = ''): string {
266:  const value = configs.get(key)
267:  return typeof value === 'string' ? value.trim() : fallback
268:}
269:
270:function getConfigBoolean(configs: Map<string, unknown>, key: string, fallback: boolean): boolean {
271:  const value = configs.get(key)
272:  return typeof value === 'boolean' ? value : fallback
273:}
274:
275:function getConfigNumber(configs: Map<string, unknown>, key: string, fallback: number): number {
276:  const value = configs.get(key)
277:  return typeof value === 'number' && Number.isFinite(value) ? value : fallback
278:}
279:
280:function getConfigStringArray(configs: Map<string, unknown>, key: string, fallback: string[]): string[] {
281:  const value = configs.get(key)
282:  if (!Array.isArray(value)) return fallback
283:
284:  const normalized = value
285:    .filter(item => typeof item === 'string')
286:    .map(item => item.trim())
287:    .filter(Boolean)
288:
289:  return normalized.length > 0 ? normalized : fallback
290:}
291:
292:function normalizeAiMode(value: string): AiTicketAgentConfig['mode'] {
293:  return value === 'semi_auto' || value === 'auto' ? value : 'draft'
294:}
295:
296:function resolveChatCompletionsUrl(apiBaseUrl: string): string {
297:  const trimmed = apiBaseUrl.trim().replace(/\/+$/, '')
298:  return trimmed.endsWith('/chat/completions') ? trimmed : `${trimmed}/chat/completions`
299:}
