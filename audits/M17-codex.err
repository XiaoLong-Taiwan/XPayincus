191:function revokeAttachmentUrls(): void {
192:  for (const url of Object.values(attachmentObjectUrls.value)) {
193:    URL.revokeObjectURL(url)
194:  }
195:  attachmentObjectUrls.value = {}
196:  attachmentLoadingIds.value = {}
197:}
198:
199:async function ensureAttachmentObjectUrl(attachment: TicketMessageAttachment): Promise<void> {
200:  if (attachmentObjectUrls.value[attachment.id] || attachmentLoadingIds.value[attachment.id]) {
201:    return
202:  }
203:
204:  attachmentLoadingIds.value = {
205:    ...attachmentLoadingIds.value,
206:    [attachment.id]: true
207:  }
208:
209:  try {
210:    const blob = await api.tickets.getAttachmentContent(attachment.id)
211:    attachmentObjectUrls.value = {
212:      ...attachmentObjectUrls.value,
213:      [attachment.id]: URL.createObjectURL(blob)
214:    }
215:  } catch (error) {
216:    console.error('Failed to load ticket attachment:', error)
217:  } finally {
218:    const nextLoadingIds = { ...attachmentLoadingIds.value }
219:    delete nextLoadingIds[attachment.id]
220:    attachmentLoadingIds.value = nextLoadingIds
221:  }
222:}
223:
224:async function ensureMessageAttachmentUrls(messageList: TicketMessage[]): Promise<void> {
225:  await Promise.all(messageList.flatMap(message => message.attachments.map(attachment => ensureAttachmentObjectUrl(attachment))))
226:}
