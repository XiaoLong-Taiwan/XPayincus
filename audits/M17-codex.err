435:function inspectAiReplySendEligibility(context: AiTicketContext, config: AiTicketAgentConfig): string[] {
436:  const blockedReasons: string[] = []
437:  const searchableText = [
438:    context.ticket.subject,
439:    context.ticket.category,
440:    context.ticket.priority,
441:    ...context.ticket.recentMessages.map(message => message.content)
442:  ].join(' ')
443:
444:  const sensitivePatterns: Array<[string, RegExp]> = [
445:    ['refund_or_dispute_requires_handoff', /é€€æ¬¾|é€€è´¹|äº‰è®®|æ‹’ä»˜|chargeback|dispute|refund/i],
446:    ['risk_or_account_security_requires_handoff', /é£ŽæŽ§|å°ç¦|è§£å°|å†»ç»“|ç›—å·|è´¦å·å®‰å…¨|risk|abuse|ban/i],
447:    ['destructive_instance_operation_requires_handoff', /åˆ é™¤|é”€æ¯|é‡è£…|è¿ç§»|æ¢å¤æ•°æ®|æ•°æ®æ¢å¤|æ•°æ®ä¸¢å¤±|delete|destroy|reinstall|migrate|recovery/i],
448:    ['credential_or_backend_request_requires_handoff', /root|å¯†ç |ssh|å¯†é’¥|åŽå°|æ•°æ®åº“|è·¯å¾„|password|secret|token/i],
449:    ['resource_delivery_exception_requires_handoff', /å¼€é€šå¤±è´¥|äº¤ä»˜å¤±è´¥|æœºå™¨å¼‚å¸¸|å®žä¾‹å¼‚å¸¸|æ— æ³•è¿žæŽ¥|æ•…éšœ|å®•æœº|delivery failed|outage/i]
450:  ]
451:
452:  if (context.ticket.category === 'abuse') {
453:    blockedReasons.push('abuse_category_requires_handoff')
454:  }
455:  if (context.ticket.priority === 'urgent') {
456:    blockedReasons.push('urgent_priority_requires_handoff')
457:  }
458:  if (config.mode === 'auto' && !config.autoReplyCategories.includes(context.ticket.category)) {
459:    blockedReasons.push('category_not_allowed_for_auto_reply')
460:  }
461:
462:  for (const [reason, pattern] of sensitivePatterns) {
463:    if (pattern.test(searchableText)) {
464:      blockedReasons.push(reason)
465:    }
466:  }
467:
468:  return Array.from(new Set(blockedReasons))
469:}
