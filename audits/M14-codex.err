  318: export function getActiveSessionStats(): {
  319:     total: number
  320:     byInstance: Map<number, number>
  321:     byUser: Map<number, number>
  322: } {
  323:     const byInstance = new Map<number, number>()
  324:     const byUser = new Map<number, number>()
  325: 
