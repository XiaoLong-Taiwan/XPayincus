  518:     function downloadLog(filename?: string): boolean {
  519:         const content = exportContent('text')
  520:         if (!content) return false
  521:         
  522:         try {
  523:             const blob = new Blob([content], { type: 'text/plain;charset=utf-8' })
  524:             const url = URL.createObjectURL(blob)
  525:             const a = document.createElement('a')
  526:             a.href = url
  527:             a.download = filename || `terminal-${Date.now()}.log`
  528:             document.body.appendChild(a)
