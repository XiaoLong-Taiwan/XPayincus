  488:     function stripAnsiSequences(text: string): string {
  489:         // åŒ¹é…æ‰€æœ‰ ANSI è½¬ä¹‰åºåˆ—ï¼šESC [ ... å­—æ¯
  490:         // åŒ…æ‹¬é¢œè‰²ã€å…‰æ ‡ç§»åŠ¨ã€æ¸…å±ç­‰æŽ§åˆ¶ç 
  491:         // ä½¿ç”¨ RegExp æž„é€ å‡½æ•°é¿å… ESLint æŠ¥é”™
  492:         const ansiRegex = new RegExp(String.fromCharCode(27) + '\\[[0-9;]*[a-zA-Z]', 'g')
