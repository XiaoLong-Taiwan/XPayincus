   52: // ç»ˆç«¯ä¼šè¯é…ç½®
   53: // ä¿æ´»ç­–ç•¥ï¼šåªè¦ WebSocket é€šé“æ­£å¸¸å°±ä¸æ–­å¼€
   54: export const TERMINAL_CONFIG = {
   55:     heartbeatInterval: 25 * 1000,      // å¿ƒè·³é—´éš” 25 ç§’ï¼ˆé¿å…ä»£ç†å±‚ç©ºé—²æ–­å¼€ï¼‰
   56:     heartbeatTimeout: 30000,           // å¿ƒè·³è¶…æ—¶ 30ç§’ï¼ˆç»™è¶³å¤Ÿæ—¶é—´å“åº”ï¼‰
   57:     idleTimeout: 12 * 60 * 60 * 1000,  // ç©ºé—²è¶…æ—¶ 12 å°æ—¶ï¼ˆSSH é£Žæ ¼é•¿è¿žæŽ¥ï¼‰
   58:     maxMessageSize: 1048576,           // æœ€å¤§æ¶ˆæ¯ 1MB
   59:     reconnectDelay: 1000,              // é‡è¿žå»¶è¿Ÿ
   60:     maxReconnectAttempts: 10,          // æœ€å¤§é‡è¿žæ¬¡æ•°
