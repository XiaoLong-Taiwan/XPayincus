   81:   }
   82: 
   83:   if (data instanceof Blob) {
   84:     void data.arrayBuffer().then(buffer => {
   85:       getTerminal()?.write(new Uint8Array(buffer))
   86:     }).catch(() => {
   87:       // ignore
   88:     })
   89:   }
   90: }
