  315: /**
  316:  * èŽ·å–æ´»è·ƒä¼šè¯ç»Ÿè®¡
  317:  */
  318: export function getActiveSessionStats(): {
  319:     total: number
  320:     byInstance: Map<number, number>
  321:     byUser: Map<number, number>
  322: } {
  323:     const byInstance = new Map<number, number>()
  324:     const byUser = new Map<number, number>()
  325: 
  326:     for (const session of activeSessions.values()) {
  327:         byInstance.set(session.instanceId, (byInstance.get(session.instanceId) || 0) + 1)
  328:         byUser.set(session.userId, (byUser.get(session.userId) || 0) + 1)
  329:     }
  330: 
  331:     return {
  332:         total: activeSessions.size,
  333:         byInstance,
  334:         byUser
  335:     }
  336: }
