   91:     fastify.post<{
   92:         Params: { id: string }
   93:     }>('/:id/terminal-ticket', {
   94:         onRequest: [fastify.authenticate]
   95:     }, async (request, reply) => {
   96:         const instanceId = parsePositiveRouteId(request.params.id)
   97:         if (instanceId === null) {
   98:             return reply.code(400).send({ error: 'Invalid instance ID', code: 'INVALID_ID' })
   99:         }
  100: 
  101:         const issuedAt = request.user.iat
  102:         if (!issuedAt) {
  103:             return reply.code(401).send({ error: 'Unauthorized', code: 'UNAUTHORIZED' })
  104:         }
  105: 
  106:         const dbUser = await db.findUserById(request.user.id)
  107:         if (!dbUser || dbUser.status === 'banned') {
  108:             return reply.code(401).send({ error: 'Unauthorized', code: 'UNAUTHORIZED' })
  109:         }
  110: 
  111:         const instance = await db.getInstanceById(instanceId)
