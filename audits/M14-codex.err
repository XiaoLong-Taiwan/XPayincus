   11: const POSITIVE_ROUTE_ID_PATTERN = /^[1-9]\d*$/
   12: 
   13: function parsePositiveRouteId(value: string): number | null {
   14:   if (!POSITIVE_ROUTE_ID_PATTERN.test(value)) {
   15:     return null
   16:   }
   17: 
   18:   const parsed = Number(value)
   19:   return Number.isSafeInteger(parsed) ? parsed : null
   20: }
