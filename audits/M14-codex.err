  686: /**
  687:  * å…³é—­ç»ˆç«¯ä¼šè¯
  688:  */
  689: export function closeTerminalSession(sessionId: string, reason: string = 'Session closed'): void {
  690:     const session = activeSessions.get(sessionId)
  691:     if (!session) return
  692: 
  693:     console.log(`[Terminal] Closing session ${sessionId}: ${reason}`)
  694: 
  695:     // æ¸…é™¤å¿ƒè·³å®šæ—¶å™¨
  696:     if (session.heartbeatTimer) {
  697:         clearInterval(session.heartbeatTimer)
  698:     }
  699: 
  700:     cleanupIncusSockets(session)
  701: 
  702:     // é€šçŸ¥å®¢æˆ·ç«¯å¹¶å…³é—­
  703:     if (session.clientWebSocket.readyState === session.clientWebSocket.OPEN) {
  704:         try {
  705:             session.clientWebSocket.send(JSON.stringify({
  706:                 type: 'disconnected',
  707:                 reason
  708:             }))
  709:         } catch (err) {
  710:             // å‘é€å¤±è´¥ï¼ˆå¯èƒ½è¿žæŽ¥å·²å…³é—­ï¼‰ï¼Œé™é»˜å¿½ç•¥
  711:             console.debug(`[Terminal] Failed to send disconnected message:`, err)
  712:         }
  713:         try {
  714:             session.clientWebSocket.close()
  715:         } catch (err) {
  716:             console.debug(`[Terminal] Failed to close client WebSocket:`, err)
  717:         }
  718:     }
  719: 
  720:     // ç§»é™¤ä¼šè¯
  721:     activeSessions.delete(sessionId)
  722: }
