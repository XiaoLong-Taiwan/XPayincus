  495: // è¿žæŽ¥æ ‡ç­¾åˆ°ç»ˆç«¯æœåŠ¡å™¨
  496: async function connectTab(tabId: string) {
  497:     const tab = tabs.value.find(t => t.id === tabId)
  498:     if (!tab || !props.instanceId) return
  499:     
  500:     const token = authStore.token
  501:     if (!token) {
  502:         tab.status = 'error'
  503:         tab.error = 'Authentication required'
  504:         return
  505:     }
  506:     
  507:     if (tab.ws && (tab.ws.readyState === WebSocket.OPEN || tab.ws.readyState === WebSocket.CONNECTING)) {
  508:         return
  509:     }
  510:     
  511:     tab.status = 'connecting'
  512:     tab.error = null
  513:     tab.connectAttempt += 1
  514:     const connectAttempt = tab.connectAttempt
  515:     
  516:     try {
  517:         const ticketResponse = await api.instances.createTerminalTicket(props.instanceId)
  518:         const currentTab = tabs.value.find(t => t.id === tabId)
  519:         if (!currentTab || currentTab.connectAttempt !== connectAttempt) {
  520:             return
  521:         }
  522: 
  523:         const wsUrl = buildTerminalWebSocketUrl(props.instanceId, ticketResponse.ticket)
  524:         const ws = new WebSocket(wsUrl)
  525:         // ä½¿ç”¨ arraybuffer ç¡®ä¿äºŒè¿›åˆ¶æ•°æ®æŒ‰é¡ºåºå¤„ç†ï¼ˆé¿å… Blob å¼‚æ­¥å¯¼è‡´çš„ä¹±åºï¼‰
  526:         ws.binaryType = 'arraybuffer'
  527:         currentTab.ws = ws
  528:         
  529:         ws.onopen = () => {
  530:             console.log(`[Terminal Tab ${tabId}] WebSocket connected`)
  531:         }
  532:         
  533:         ws.onmessage = (event) => {
  534:             handleTerminalSocketPayload(event.data, () => tab.terminal, (message) => {
  535:                 handleControlMessage(tabId, message)
  536:             })
  537:         }
  538:         
  539:         ws.onerror = () => {
  540:             currentTab.error = 'Connection error'
  541:         }
  542:         
  543:         ws.onclose = (event) => {
  544:             // åªæœ‰å½“è¿™ä¸ª ws ä»ç„¶æ˜¯å½“å‰æ ‡ç­¾çš„ ws æ—¶æ‰æ›´æ–°çŠ¶æ€ï¼Œé¿å…å¿«é€Ÿé‡è¿žæ—¶çš„ç«žæ€æ¡ä»¶
  545:             if (currentTab.ws !== ws) return
  546: 
  547:             console.log(`[Terminal Tab ${tabId}] WebSocket closed:`, event.code)
  548: 
  549:             // æ„å¤–æ–­å¼€æ—¶è‡ªåŠ¨é‡è¿ž
  550:             if (shouldRetryTerminalClose(event.code) && (currentTab.status === 'connected' || currentTab.status === 'connecting' || currentTab.status === 'reconnecting')) {
  551:                 const attempts = reconnectAttempts.value.get(tabId) || 0
  552:                 if (attempts < TERMINAL_MAX_RECONNECT_ATTEMPTS) {
  553:                     reconnectAttempts.value.set(tabId, attempts + 1)
  554:                     currentTab.status = 'reconnecting'
  555:                     // çº¿æ€§é€€é¿ï¼š1ç§’, 3ç§’, 5ç§’... æœ€å¤š 15ç§’
  556:                     const delay = Math.min(1000 + attempts * 2000, 15000)
  557:                     console.log(`[Terminal Tab ${tabId}] Auto reconnecting in ${delay}ms (attempt ${attempts + 1}/${TERMINAL_MAX_RECONNECT_ATTEMPTS})`)
  558:                     const existingTimer = reconnectTimers.value.get(tabId)
  559:                     if (existingTimer) {
  560:                         clearTimeout(existingTimer)
  561:                     }
  562:                     const timer = setTimeout(() => {
  563:                         reconnectTimers.value.delete(tabId)
  564:                         if (currentTab.terminal) {
  565:                             printReconnectMessage(currentTab.terminal)
  566:                         }
  567:                         void connectTab(tabId)
  568:                     }, delay)
  569:                     reconnectTimers.value.set(tabId, timer)
  570:                 } else {
  571:                     currentTab.status = 'error'
  572:                     currentTab.error = 'Connection lost'
  573:                     reconnectAttempts.value.delete(tabId)
  574:                 }
  575:             } else {
  576:                 currentTab.status = 'disconnected'
  577:             }
  578:         }
  579:         
  580:         // ç»‘å®šç»ˆç«¯è¾“å…¥
  581:         if (currentTab.terminal && !currentTab.eventsBound) {
  582:             currentTab.eventsBound = true
  583:             
  584:             currentTab.terminal.onData((data) => {
  585:                 if (currentTab.ws && currentTab.ws.readyState === WebSocket.OPEN) {
  586:                     try {
  587:                         currentTab.ws.send(data)
  588:                     } catch {
  589:                         // WebSocket may be closed during send, ignore
  590:                     }
  591:                 }
  592:             })
  593:             
  594:             currentTab.terminal.onResize(({ cols, rows }) => {
  595:                 sendResize(tabId, cols, rows)
  596:             })
  597:         }
  598:     } catch (err) {
  599:         const currentTab = tabs.value.find(t => t.id === tabId)
  600:         if (!currentTab || currentTab.connectAttempt !== connectAttempt) {
  601:             return
  602:         }
  603: 
  604:         currentTab.status = 'error'
  605:         currentTab.error = err instanceof Error ? err.message : 'Failed to connect'
  606:     }
  607: }
  608: 
  609: // å¤„ç†æŽ§åˆ¶æ¶ˆæ¯
  610: function handleControlMessage(tabId: string, message: { type: string; sessionId?: string; message?: string; reason?: string; mode?: 'exec' | 'console' }) {
  611:     const tab = tabs.value.find(t => t.id === tabId)
  612:     if (!tab) return
  613:     
  614:     switch (message.type) {
  615:         case 'connected':
  616:             tab.status = 'connected'
  617:             tab.error = null
  618:             if (message.mode) {
  619:                 tab.connectionMode = message.mode
  620:                 if (message.mode !== 'console') {
  621:                     tab.consoleWarningShown = false
  622:                 }
  623:             }
  624:             // è¿žæŽ¥æˆåŠŸï¼Œé‡ç½®é‡è¿žè®¡æ•°
  625:             reconnectAttempts.value.delete(tabId)
  626:             if (tab.terminal && tab.fitAddon) {
  627:                 tab.fitAddon.fit()
  628:                 sendResize(tabId, tab.terminal.cols, tab.terminal.rows)
  629:             }
  630:             maybePrintConsoleFallbackWarning(tab)
  631:             break
  632:         case 'reconnecting':
  633:             tab.status = 'reconnecting'
  634:             tab.error = message.reason || null
  635:             if (message.mode) {
  636:                 tab.connectionMode = message.mode
  637:             }
  638:             break
  639:         case 'disconnected':
  640:             tab.status = 'disconnected'
  641:             tab.error = message.reason || null
  642:             break
  643:         case 'error':
  644:             tab.status = 'error'
  645:             tab.error = message.message || 'Unknown error'
  646:             if (tab.terminal) {
  647:                 tab.terminal.write(`\r\n\x1b[31mError: ${message.message}\x1b[0m\r\n`)
  648:             }
  649:             break
  650:     }
  651: }
  652: 
  653: // å‘é€è°ƒæ•´å¤§å°å‘½ä»¤
  654: function sendResize(tabId: string, cols: number, rows: number) {
  655:     const tab = tabs.value.find(t => t.id === tabId)
  656:     if (tab?.ws && tab.ws.readyState === WebSocket.OPEN) {
  657:         try {
  658:             tab.ws.send(JSON.stringify({ type: 'resize', cols, rows }))
  659:         } catch {
  660:             // WebSocket may be closed during send, ignore
  661:         }
  662:     }
  663: }
