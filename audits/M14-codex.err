  477: async function manualCompleteCloudInitAndConnect() {
  478:     if (!props.instanceId || !activeTabId.value) return
  479: 
  480:     cloudInitManualCompleting.value = true
  481:     try {
  482:         const result = await api.instances.manualCompleteCloudInit(props.instanceId) as CloudInitStatusResponse
  483:         cloudInitState.value = result.state
  484:         cloudInitStatus.value = 'ready'
  485:         emit('cloud-init-manual-complete')
  486:         toast.success(t('terminal.cloudInitManualCompleteSuccess'))
  487:         connectTab(activeTabId.value)
  488:     } catch (err: any) {
  489:         toast.error(err?.message || t('common.operationFailed'))
  490:     } finally {
  491:         cloudInitManualCompleting.value = false
  492:     }
  493: }
