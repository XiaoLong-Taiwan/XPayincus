   22: export default async function terminalSavedCommandRoutes(fastify: FastifyInstance) {
   23:   fastify.get('/', {
   24:     onRequest: [fastify.authenticate]
   25:   }, async (request: FastifyRequest) => {
   26:     const commands = await getTerminalSavedCommandsByUserId(request.user.id)
   27: 
   28:     return { commands }
   29:   })
   30: 
   31:   fastify.post<{
   32:     Body: {
   33:       name: string
   34:       command: string
   35:       description?: string | null
   36:     }
   37:   }>('/', {
   38:     onRequest: [fastify.authenticate],
   39:     schema: {
   40:       body: {
   41:         type: 'object',
   42:         additionalProperties: false,
   43:         required: ['name', 'command'],
   44:         properties: {
   45:           name: { type: 'string', minLength: 1, maxLength: 80 },
   46:           command: { type: 'string', minLength: 1, maxLength: 16384 },
   47:           description: { type: ['string', 'null'], maxLength: 300 }
   48:         }
   49:       }
   50:     }
   51:   }, async (request: FastifyRequest<{
   52:     Body: {
   53:       name: string
   54:       command: string
   55:       description?: string | null
   56:     }
   57:   }>, reply: FastifyReply) => {
   58:     const result = await createTerminalSavedCommand({
   59:       userId: request.user.id,
   60:       name: request.body.name,
   61:       command: request.body.command,
   62:       description: request.body.description
   63:     })
   64: 
   65:     if (!result.success) {
   66:       const errorMap: Record<string, { status: number; message: string }> = {
   67:         INVALID_NAME: { status: 400, message: 'Command name is required' },
   68:         INVALID_COMMAND: { status: 400, message: 'Command content is required' },
   69:         COMMAND_TOO_LARGE: { status: 400, message: 'Command content too large (max 16KB)' },
   70:         MAX_COMMANDS_REACHED: { status: 400, message: 'Maximum saved terminal commands reached (100)' }
   71:       }
   72:       const target = errorMap[result.error] || { status: 400, message: result.error }
   73:       return reply.code(target.status).send({ error: target.message, code: result.error })
   74:     }
   75: 
   76:     await createLog(
   77:       request.user.id,
   78:       'terminal',
   79:       'terminal.saved_command.create',
   80:       `Created terminal saved command "${result.command.name}"`,
   81:       'success'
   82:     )
   83: 
   84:     return reply.code(201).send({
   85:       message: 'Saved terminal command created',
   86:       command: result.command
   87:     })
   88:   })
   89: 
   90:   fastify.put<{
   91:     Params: { id: string }
   92:     Body: {
   93:       name?: string
   94:       command?: string
   95:       description?: string | null
   96:     }
   97:   }>('/:id', {
   98:     onRequest: [fastify.authenticate],
   99:     schema: {
  100:       body: {
  101:         type: 'object',
  102:         additionalProperties: false,
  103:         properties: {
  104:           name: { type: 'string', minLength: 1, maxLength: 80 },
  105:           command: { type: 'string', minLength: 1, maxLength: 16384 },
  106:           description: { type: ['string', 'null'], maxLength: 300 }
  107:         }
  108:       }
  109:     }
  110:   }, async (request: FastifyRequest<{
  111:     Params: { id: string }
  112:     Body: {
  113:       name?: string
  114:       command?: string
  115:       description?: string | null
  116:     }
  117:   }>, reply: FastifyReply) => {
  118:     const commandId = parsePositiveRouteId(request.params.id)
  119:     if (!commandId) {
  120:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
  121:     }
  122: 
  123:     const result = await updateTerminalSavedCommand(commandId, request.user.id, request.body)
  124:     if (!result.success) {
  125:       const errorMap: Record<string, { status: number; message: string }> = {
  126:         NOT_FOUND: { status: 404, message: 'Saved command not found' },
  127:         INVALID_NAME: { status: 400, message: 'Command name is required' },
  128:         INVALID_COMMAND: { status: 400, message: 'Command content is required' },
  129:         COMMAND_TOO_LARGE: { status: 400, message: 'Command content too large (max 16KB)' }
  130:       }
  131:       const target = errorMap[result.error] || { status: 400, message: result.error }
  132:       return reply.code(target.status).send({ error: target.message, code: result.error })
  133:     }
  134: 
  135:     await createLog(
  136:       request.user.id,
  137:       'terminal',
  138:       'terminal.saved_command.update',
  139:       `Updated terminal saved command "${result.command.name}" (#${commandId})`,
  140:       'success'
  141:     )
  142: 
  143:     return {
  144:       message: 'Saved terminal command updated',
  145:       command: result.command
  146:     }
  147:   })
  148: 
  149:   fastify.delete<{
  150:     Params: { id: string }
  151:   }>('/:id', {
  152:     onRequest: [fastify.authenticate]
  153:   }, async (request: FastifyRequest<{ Params: { id: string } }>, reply: FastifyReply) => {
  154:     const commandId = parsePositiveRouteId(request.params.id)
  155:     if (!commandId) {
  156:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
  157:     }
  158: 
  159:     const deleted = await deleteTerminalSavedCommand(commandId, request.user.id)
  160:     if (!deleted) {
  161:       return reply.code(404).send(apiError(ErrorCode.NOT_FOUND))
  162:     }
  163: 
  164:     await createLog(
  165:       request.user.id,
  166:       'terminal',
  167:       'terminal.saved_command.delete',
  168:       `Deleted terminal saved command #${commandId}`,
  169:       'success'
  170:     )
  171: 
  172:     return { message: 'Saved terminal command deleted' }
  173:   })
  174: }

