  120:   const fitAddon = new FitAddon()
  121:   const webLinksAddon = new WebLinksAddon(
  122:     (_event, uri) => {
  123:       window.open(uri, '_blank', 'noopener,noreferrer')
  124:     },
  125:     {
  126:       hover: (event, uri) => {
  127:         options.onLinkHover?.(event, uri)
  128:       },
  129:       leave: () => {
  130:         options.onLinkLeave?.()
  131:       }
  132:     }
  133:   )
  134:   const searchAddon = new SearchAddon()
  135:   const unicodeAddon = new Unicode11Addon()
  136:   const serializeAddon = new SerializeAddon()
  137:   const clipboardAddon = new ClipboardAddon()
  138: 
  139:   terminal.loadAddon(fitAddon)
  140:   terminal.loadAddon(webLinksAddon)
  141:   terminal.loadAddon(searchAddon)
  142:   terminal.loadAddon(unicodeAddon)
  143:   terminal.loadAddon(serializeAddon)
  144:   terminal.loadAddon(clipboardAddon)
  145:   terminal.unicode.activeVersion = '11'
  146:   terminal.open(options.container)
  147: 
  148:   let webglAddon: WebglAddon | null = null
  149:   let isWebGLEnabled = false
  150: 
  151:   if (options.enableWebgl !== false && !options.isMobileDevice) {
  152:     try {
  153:       const webgl = new WebglAddon()
  154:       webgl.onContextLoss(() => {
  155:         webgl.dispose()
  156:       })
  157:       terminal.loadAddon(webgl)
  158:       webglAddon = webgl
  159:       isWebGLEnabled = true
  160:     } catch {
  161:       webglAddon = null
  162:       isWebGLEnabled = false
  163:     }
  164:   }
  165: 
  166:   if (options.onBell) {
  167:     terminal.onBell(options.onBell)
  168:   }
  169: 
  170:   if (options.onSelectionCopy) {
  171:     terminal.onSelectionChange(() => {
  172:       if (!terminal.hasSelection()) return
  173:       const selection = terminal.getSelection()
  174:       if (selection) {
  175:         options.onSelectionCopy?.(selection)
  176:       }
  177:     })
  178:   }
  179: 
  180:   setTimeout(() => fitAddon.fit(), 0)
  181: 
  182:   return {
  183:     terminal,
  184:     fitAddon,
  185:     searchAddon,
  186:     unicodeAddon,
  187:     webglAddon,
  188:     serializeAddon,
  189:     clipboardAddon,
  190:     isWebGLEnabled
  191:   }
  192: }
  193: 
  194: export function disposeTerminalRuntime(target: TerminalRuntimeTarget): void {
  195:   if (target.webglAddon) {
  196:     target.webglAddon.dispose()
  197:     target.webglAddon = null
  198:   }
  199: 
  200:   target.fitAddon = null
  201:   target.searchAddon = null
  202:   target.unicodeAddon = null
  203:   target.serializeAddon = null
  204:   target.clipboardAddon = null
  205: 
  206:   if (target.terminal) {
  207:     target.terminal.dispose()
  208:     target.terminal = null
  209:   }
  210: 
  211:   target.eventsBound = false
  212:   target.isWebGLEnabled = false
  213: }

