  371: // åˆå§‹åŒ–æ ‡ç­¾çš„ç»ˆç«¯
  372: function initTabTerminal(tabId: string) {
  373:     const tab = tabs.value.find(t => t.id === tabId)
  374:     if (!tab) return
  375:     
  376:     const container = containerRefs.value.get(tabId)
  377:     if (!container) return
  378:     
  379:     tab.container = container
  380:     
  381:     const runtime = createTerminalRuntime({
  382:         container,
  383:         fontSize: fontSize.value,
  384:         fontFamily: "'JetBrains Mono', 'Fira Code', 'Consolas', monospace",
  385:         theme: terminalStore.currentTheme,
  386:         isMobileDevice,
  387:         enableWebgl: false,
  388:         onBell: () => terminalStore.playBell(),
  389:         onSelectionCopy: (selection) => {
  390:             if (terminalStore.autoCopyOnSelect) {
  391:                 navigator.clipboard.writeText(selection).catch(() => {
  392:                     // ignore
  393:                 })
  394:             }
  395:         },
  396:         onLinkHover: (event, uri) => {
  397:             if (terminalStore.linkPreview) {
  398:                 linkTooltip.visible = true
  399:                 linkTooltip.url = uri
  400:                 linkTooltip.x = event.clientX + 10
  401:                 linkTooltip.y = event.clientY + 10
  402:             }
  403:         },
  404:         onLinkLeave: () => {
  405:             linkTooltip.visible = false
  406:         }
  407:     })
  408: 
  409:     tab.terminal = runtime.terminal
  410:     tab.fitAddon = runtime.fitAddon
  411:     tab.searchAddon = runtime.searchAddon
  412:     tab.unicodeAddon = runtime.unicodeAddon
  413:     tab.webglAddon = runtime.webglAddon
  414:     tab.serializeAddon = runtime.serializeAddon
  415:     tab.clipboardAddon = runtime.clipboardAddon
  416:     tab.isWebGLEnabled = runtime.isWebGLEnabled
  417:     
  418:     // è¾“å‡ºæ¬¢è¿Žä¿¡æ¯ï¼ˆé¦–æ¬¡åˆ›å»ºæ—¶ï¼‰
  419:     printWelcomeBanner(runtime.terminal, props.instanceName || `Instance #${props.instanceId}`)
  420:     
  421:     // æ£€æŸ¥ Cloud-init çŠ¶æ€åŽå†è¿žæŽ¥
  422:     checkCloudInitAndConnect(tabId)
  423: }
  424: 
  425: // æ£€æŸ¥ Cloud-init çŠ¶æ€å¹¶è¿žæŽ¥
  426: async function checkCloudInitAndConnect(tabId: string) {
  427:     if (!props.instanceId) return
  428:     
  429:     // å¦‚æžœå·²ç»æ£€æŸ¥è¿‡ä¸”ç»“æžœæ˜¯ ready æˆ– skippedï¼Œç›´æŽ¥è¿žæŽ¥
  430:     if (cloudInitStatus.value === 'ready' || cloudInitStatus.value === 'skipped') {
  431:         connectTab(tabId)
  432:         return
  433:     }
  434:     
  435:     cloudInitStatus.value = 'checking'
  436:     cloudInitChecking.value = true
  437:     
  438:     try {
  439:         const result = await api.instances.checkCloudInitStatus(props.instanceId) as CloudInitStatusResponse
  440:         cloudInitState.value = result.state
  441:         if (result.ready) {
  442:             cloudInitStatus.value = 'ready'
  443:             connectTab(tabId)
  444:         } else {
  445:             cloudInitStatus.value = 'not_ready'
  446:             // ç»ˆç«¯æ˜¾ç¤ºæç¤ºä¿¡æ¯
  447:             const tab = tabs.value.find(t => t.id === tabId)
  448:             if (tab?.terminal) {
  449:                 tab.terminal.writeln('')
  450:                 tab.terminal.writeln('\x1b[33mâš  ' + cloudInitPromptTitle.value + '\x1b[0m')
  451:                 tab.terminal.writeln('\x1b[90m' + cloudInitPromptHint.value + '\x1b[0m')
  452:                 tab.terminal.writeln('')
  453:             }
  454:         }
  455:     } catch (err) {
  456:         console.error('[CloudInit] Check failed:', err)
  457:         cloudInitState.value = 'unknown'
  458:         cloudInitStatus.value = 'not_ready'
  459:     } finally {
  460:         cloudInitChecking.value = false
  461:     }
  462: }
  463: 
  464: // é‡æ–°æ£€æŸ¥ Cloud-init çŠ¶æ€
  465: async function retryCloudInitCheck() {
  466:     if (!activeTabId.value) return
  467:     await checkCloudInitAndConnect(activeTabId.value)
  468: }
  469: 
  470: // è·³è¿‡ Cloud-init æ£€æŸ¥å¹¶è¿žæŽ¥
  471: function skipCloudInitAndConnect() {
  472:     if (!activeTabId.value) return
  473:     cloudInitStatus.value = 'skipped'
  474:     connectTab(activeTabId.value)
  475: }
