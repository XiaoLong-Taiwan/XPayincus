  338: /**
  339:  * åˆ›å»º Incus Console WebSocket è¿žæŽ¥
  340:  */
  341: export async function createIncusConsoleConnection(
  342:     host: Host,
  343:     instanceName: string,
  344:     instanceType: 'container' | 'vm' = 'container'
  345: ): Promise<{ controlWs: WsWebSocket | null; dataWs: WsWebSocket; operationId: string; mode: 'exec' | 'console' }> {
  346:     // æž„å»º Incus API URL
  347:     const baseUrl = host.url
  348: 
  349:     // åˆ›å»º mTLS Agent
  350:     if (!host.cert_path || !host.key_path) {
  351:         throw new Error('Host certificate configuration missing')
  352:     }
  353: 
  354:     // ä½¿ç”¨ç¼“å­˜çš„è¯ä¹¦ï¼ˆé¿å…æ¯æ¬¡è¿žæŽ¥éƒ½è¯»å–æ–‡ä»¶ï¼‰
  355:     const { cert, key } = getCachedCertificates(host.cert_path, host.key_path)
  356: 
  357:     const agent = new Agent({
  358:         connect: {
  359:             cert,
  360:             key,
  361:             rejectUnauthorized: false
  362:         }
  363:     })
  364: 
  365:     // å¯¹äºŽå®¹å™¨å§‹ç»ˆä½¿ç”¨ execã€‚
  366:     // å¯¹äºŽ VM ä¼˜å…ˆä½¿ç”¨ execï¼ˆä¾èµ– qemu-guest-agentï¼Œæ›´æŽ¥è¿‘ SSH ä½“éªŒï¼‰ï¼Œå¤±è´¥æ—¶å›žé€€åˆ° consoleã€‚
  367:     const encodedInstanceName = encodeURIComponent(instanceName)
  368:     let operationId = ''
  369:     let fds: Record<string, string> = {}
  370:     let mode: 'exec' | 'console' = 'exec'
  371: 
  372:     try {
  373:         if (instanceType === 'vm') {
  374:             try {
  375:                 const execResult = await requestTerminalOperation(
  376:                     baseUrl,
  377:                     agent,
  378:                     `/1.0/instances/${encodedInstanceName}/exec`,
  379:                     buildExecPayload()
  380:                 )
  381:                 operationId = execResult.operationId
  382:                 fds = execResult.fds
  383:                 mode = 'exec'
  384:             } catch (execError) {
  385:                 console.warn(`[Terminal] VM exec unavailable for ${instanceName}, falling back to console:`, execError)
  386:                 const consoleResult = await requestTerminalOperation(
  387:                     baseUrl,
  388:                     agent,
  389:                     `/1.0/instances/${encodedInstanceName}/console`,
  390:                     buildConsolePayload()
  391:                 )
  392:                 operationId = consoleResult.operationId
  393:                 fds = consoleResult.fds
  394:                 mode = 'console'
  395:             }
  396:         } else {
  397:             const execResult = await requestTerminalOperation(
  398:                 baseUrl,
  399:                 agent,
  400:                 `/1.0/instances/${encodedInstanceName}/exec`,
  401:                 buildExecPayload()
  402:             )
  403:             operationId = execResult.operationId
  404:             fds = execResult.fds
  405:             mode = 'exec'
  406:         }
  407:     } finally {
  408:         await agent.close()
  409:     }
  410: 
  411:     // æ£€æŸ¥æ•°æ® WebSocket fd æ˜¯å¦å­˜åœ¨
  412:     const dataSecret = fds['0']
  413:     if (!dataSecret) {
  414:         throw new Error('No data file descriptor (fd 0) returned from console operation')
  415:     }
  416: 
  417:     // æž„å»º WebSocket URL
  418:     const wsBaseUrl = baseUrl.replace('https://', 'wss://').replace('http://', 'ws://')
  419: 
  420:     // åˆ›å»ºæ•°æ® WebSocketï¼ˆfd 0 æ˜¯æ ‡å‡†è¾“å…¥è¾“å‡ºï¼Œå·²åœ¨ä¸Šé¢æ£€æŸ¥è¿‡ï¼‰
  421:     const dataWsUrl = `${wsBaseUrl}/1.0/operations/${operationId}/websocket?secret=${dataSecret}`
  422: 
  423:     // åˆ›å»ºæŽ§åˆ¶ WebSocketï¼ˆç”¨äºŽè°ƒæ•´ç»ˆç«¯å¤§å°ç­‰ï¼‰
  424:     const controlSecret = fds['control']
  425:     const controlWsUrl = controlSecret 
  426:         ? `${wsBaseUrl}/1.0/operations/${operationId}/websocket?secret=${controlSecret}`
  427:         : null
  428: 
  429:     // ä½¿ç”¨åŽŸç”Ÿ WebSocketï¼ˆéœ€è¦ mTLSï¼‰
  430:     const WebSocket = (await import('ws')).default
  431: 
  432:     const dataWs = new WebSocket(dataWsUrl, {
  433:         cert,
  434:         key,
  435:         rejectUnauthorized: false
  436:     })
  437: 
  438:     let controlWs: WsWebSocket | null = null
  439:     if (controlWsUrl) {
  440:         controlWs = new WebSocket(controlWsUrl, {
  441:             cert,
  442:             key,
  443:             rejectUnauthorized: false
  444:         }) as WsWebSocket
  445:     }
  446: 
  447:     // ç­‰å¾…è¿žæŽ¥å»ºç«‹ï¼ˆå¸¦èµ„æºæ¸…ç†ï¼‰
  448:     try {
  449:         await Promise.all([
  450:             new Promise<void>((resolve, reject) => {
  451:                 const timeout = setTimeout(() => reject(new Error('Data WebSocket connection timeout')), 10000)
  452:                 dataWs.once('open', () => {
  453:                     clearTimeout(timeout)
  454:                     resolve()
  455:                 })
  456:                 dataWs.once('error', (err) => {
  457:                     clearTimeout(timeout)
  458:                     reject(err)
  459:                 })
  460:             }),
  461:             controlWs ? new Promise<void>((resolve, reject) => {
  462:                 const timeout = setTimeout(() => reject(new Error('Control WebSocket connection timeout')), 10000)
  463:                 controlWs.once('open', () => {
  464:                     clearTimeout(timeout)
  465:                     resolve()
  466:                 })
  467:                 controlWs.once('error', (err) => {
  468:                     clearTimeout(timeout)
  469:                     reject(err)
  470:                 })
  471:             }) : Promise.resolve()
  472:         ])
  473:     } catch (error) {
  474:         // è¿žæŽ¥å¤±è´¥æ—¶ï¼Œå…³é—­å·²æˆåŠŸçš„è¿žæŽ¥ï¼Œé¿å…èµ„æºæ³„æ¼
  475:         if (dataWs.readyState === dataWs.OPEN || dataWs.readyState === dataWs.CONNECTING) {
  476:             dataWs.close()
  477:         }
  478:         if (controlWs && (controlWs.readyState === controlWs.OPEN || controlWs.readyState === controlWs.CONNECTING)) {
  479:             controlWs.close()
  480:         }
  481:         throw error
  482:     }
  483: 
  484:     return { controlWs, dataWs: dataWs as WsWebSocket, operationId, mode }
  485: }
