  136: async function requestTerminalOperation(
  137:     baseUrl: string,
  138:     agent: Agent,
  139:     endpoint: string,
  140:     payload: Record<string, unknown>
  141: ): Promise<{ operationId: string; fds: Record<string, string> }> {
  142:     const response = await request(`${baseUrl}${endpoint}`, {
  143:         method: 'POST',
  144:         dispatcher: agent,
  145:         headers: {
  146:             'Content-Type': 'application/json'
  147:         },
  148:         body: JSON.stringify(payload)
  149:     })
  150: 
  151:     const data = await response.body.json() as {
  152:         type: string
  153:         operation: string
  154:         error_code: number
  155:         error: string
  156:         metadata: {
  157:             id: string
  158:             metadata: {
  159:                 fds: Record<string, string>
  160:             }
  161:         }
  162:     }
  163: 
  164:     if (data.type === 'error' || (data.error_code !== undefined && data.error_code !== 0)) {
  165:         throw new Error(data.error || 'Failed to create terminal session')
  166:     }
  167: 
  168:     const operationId = data.operation?.split('/').pop() || data.metadata?.id
  169:     if (!operationId) {
  170:         throw new Error('No operation ID returned from terminal request')
  171:     }
  172: 
  173:     const fds = data.metadata?.metadata?.fds
  174:     if (!fds) {
  175:         throw new Error('No file descriptors returned from terminal operation')
  176:     }
  177: 
  178:     return { operationId, fds }
  179: }
  180: 
  181: function safeSendClientMessage(clientWs: WsWebSocket, message: Record<string, unknown>): void {
  182:     if (clientWs.readyState !== clientWs.OPEN) {
  183:         return
  184:     }
  185: 
  186:     try {
  187:         clientWs.send(JSON.stringify(message))
  188:     } catch (err) {
  189:         console.debug('[Terminal] Failed to send control message to client:', err)
  190:     }
  191: }
  192: 
  193: function cleanupIncusSockets(session: TerminalSession): void {
  194:     if (session.incusWebSocket) {
  195:         session.incusWebSocket.removeAllListeners()
  196:         try {
  197:             if (session.incusWebSocket.readyState === session.incusWebSocket.OPEN || session.incusWebSocket.readyState === session.incusWebSocket.CONNECTING) {
  198:                 session.incusWebSocket.close()
  199:             }
  200:         } catch (err) {
  201:             console.debug('[Terminal] Failed to close Incus data WebSocket:', err)
  202:         }
  203:         session.incusWebSocket = null
  204:     }
  205: 
  206:     if (session.controlWebSocket) {
  207:         session.controlWebSocket.removeAllListeners()
  208:         try {
  209:             if (session.controlWebSocket.readyState === session.controlWebSocket.OPEN || session.controlWebSocket.readyState === session.controlWebSocket.CONNECTING) {
  210:                 session.controlWebSocket.close()
  211:             }
  212:         } catch (err) {
  213:             console.debug('[Terminal] Failed to close Incus control WebSocket:', err)
  214:         }
  215:         session.controlWebSocket = null
  216:     }
  217: }
  218: 
  219: function bindIncusSocketHandlers(session: TerminalSession, dataWs: WsWebSocket, controlWs: WsWebSocket | null): void {
  220:     dataWs.on('message', (data: Buffer) => {
  221:         session.lastActivity = Date.now()
  222:         if (session.clientWebSocket.readyState === session.clientWebSocket.OPEN) {
  223:             try {
  224:                 session.clientWebSocket.send(data)
  225:             } catch (err) {
  226:                 console.debug('[Terminal] Failed to send terminal data to client:', err)
  227:             }
  228:         }
  229:     })
  230: 
  231:     dataWs.on('pong', () => {
  232:         session.lastActivity = Date.now()
  233:     })
  234: 
  235:     dataWs.on('error', (err) => {
  236:         console.error(`[Terminal] Incus WebSocket error for session ${session.id}:`, err.message)
  237:         void reconnectIncusConnection(session.id, 'Incus connection error')
  238:     })
  239: 
  240:     dataWs.on('close', () => {
  241:         console.log(`[Terminal] Incus WebSocket closed for session ${session.id}`)
  242:         void reconnectIncusConnection(session.id, 'Incus connection closed')
  243:     })
  244: 
  245:     if (controlWs) {
  246:         controlWs.on('pong', () => {
  247:             session.lastActivity = Date.now()
  248:         })
  249: 
  250:         controlWs.on('error', (err) => {
  251:             console.error(`[Terminal] Control WebSocket error for session ${session.id}:`, err.message)
  252:         })
  253:     }
  254: }
  255: 
  256: async function reconnectIncusConnection(sessionId: string, reason: string): Promise<void> {
  257:     const session = activeSessions.get(sessionId)
  258:     if (!session) return
  259:     if (session.clientWebSocket.readyState !== session.clientWebSocket.OPEN) {
  260:         closeTerminalSession(sessionId, reason)
  261:         return
  262:     }
  263:     if (session.reconnectingIncus) {
  264:         return
  265:     }
  266: 
  267:     session.reconnectingIncus = true
  268:     session.incusReconnectAttempts += 1
  269: 
  270:     if (session.incusReconnectAttempts > TERMINAL_CONFIG.maxReconnectAttempts) {
  271:         closeTerminalSession(sessionId, 'Terminal backend reconnection limit exceeded')
  272:         return
  273:     }
  274: 
  275:     safeSendClientMessage(session.clientWebSocket, {
  276:         type: 'reconnecting',
  277:         reason,
  278:         mode: session.connectionMode
  279:     })
  280: 
  281:     cleanupIncusSockets(session)
  282: 
  283:     const delay = Math.min(TERMINAL_CONFIG.reconnectDelay + (session.incusReconnectAttempts - 1) * 2000, 15000)
  284:     await new Promise(resolve => setTimeout(resolve, delay))
  285: 
  286:     try {
  287:         const { controlWs, dataWs, mode } = await createIncusConsoleConnection(
  288:             session.host,
  289:             session.instanceName,
  290:             session.instanceType
  291:         )
  292: 
  293:         session.connectionMode = mode
  294:         session.incusWebSocket = dataWs
  295:         session.controlWebSocket = controlWs
  296:         session.lastActivity = Date.now()
  297:         session.reconnectingIncus = false
  298:         session.incusReconnectAttempts = 0
  299: 
  300:         bindIncusSocketHandlers(session, dataWs, controlWs)
  301: 
  302:         safeSendClientMessage(session.clientWebSocket, {
  303:             type: 'connected',
  304:             sessionId: session.id,
  305:             message: 'Terminal backend reconnected',
  306:             mode
  307:         })
  308:     } catch (error) {
  309:         session.reconnectingIncus = false
  310:         console.error(`[Terminal] Failed to reconnect Incus backend for session ${session.id}:`, error)
  311:         await reconnectIncusConnection(sessionId, 'Incus reconnection failed')
  312:     }
  313: }
