  578: // å¤„ç†æŽ§åˆ¶æ¶ˆæ¯
  579: function handleControlMessage(tabId: string, message: { type: string; sessionId?: string; message?: string; reason?: string; mode?: 'exec' | 'console' }) {
  580:     const tab = tabs.value.find(t => t.id === tabId)
  581:     if (!tab) return
  582:     
  583:     switch (message.type) {
  584:         case 'connected':
  585:             tab.status = 'connected'
  586:             tab.error = null
  587:             if (message.mode) {
  588:                 tab.connectionMode = message.mode
  589:                 if (message.mode !== 'console') {
  590:                     tab.consoleWarningShown = false
  591:                 }
  592:             }
  593:             // è¿žæŽ¥æˆåŠŸï¼Œé‡ç½®é‡è¿žè®¡æ•°
  594:             reconnectAttempts.value.delete(tabId)
  595:             if (tab.terminal && tab.fitAddon) {
  596:                 tab.fitAddon.fit()
  597:                 // æ£€æŸ¥ç»ˆç«¯æ˜¯å¦ä»ç„¶å­˜åœ¨ï¼Œé˜²æ­¢åœ¨å¼‚æ­¥æ“ä½œæœŸé—´è¢«é”€æ¯
  598:                 if (tab.terminal) {
  599:                     sendResize(tabId, tab.terminal.cols, tab.terminal.rows)
  600:                 }
  601:             }
  602:             maybePrintConsoleFallbackWarning(tab)
  603:             break
  604:         case 'reconnecting':
  605:             tab.status = 'reconnecting'
  606:             tab.error = message.reason || null
  607:             if (message.mode) {
  608:                 tab.connectionMode = message.mode
  609:             }
  610:             break
  611:         case 'disconnected':
  612:             tab.status = 'disconnected'
  613:             tab.error = message.reason || null
  614:             break
  615:         case 'error':
  616:             tab.status = 'error'
  617:             tab.error = message.message || 'Unknown error'
  618:             if (tab.terminal) {
  619:                 tab.terminal.write(`\r\n\x1b[31mError: ${message.message}\x1b[0m\r\n`)
  620:             }
  621:             break
  622:     }
  623: }
