  397: // æ£€æŸ¥ Cloud-init çŠ¶æ€å¹¶è¿žæŽ¥
  398: async function checkCloudInitAndConnect(tabId: string) {
  399:     const tab = tabs.value.find(t => t.id === tabId)
  400:     if (!tab) return
  401:     
  402:     // å¦‚æžœå·²ç»æ£€æŸ¥è¿‡ä¸”ç»“æžœæ˜¯ ready æˆ– skippedï¼Œç›´æŽ¥è¿žæŽ¥
  403:     const status = cloudInitStatus.value.get(tabId)
  404:     if (status === 'ready' || status === 'skipped') {
  405:         connectTab(tabId)
  406:         return
  407:     }
  408:     
  409:     cloudInitStatus.value.set(tabId, 'checking')
  410:     cloudInitChecking.value.set(tabId, true)
  411:     
  412:     try {
  413:         const result = await api.instances.checkCloudInitStatus(tab.instanceId)
  414:         if (result.ready) {
  415:             cloudInitStatus.value.set(tabId, 'ready')
  416:             connectTab(tabId)
  417:         } else {
  418:             cloudInitStatus.value.set(tabId, 'not_ready')
  419:             // ç»ˆç«¯æ˜¾ç¤ºæç¤ºä¿¡æ¯
  420:             if (tab.terminal) {
  421:                 tab.terminal.writeln('')
  422:                 tab.terminal.writeln('\x1b[33mâš  ' + t('terminal.cloudInitInProgress') + '\x1b[0m')
  423:                 tab.terminal.writeln('\x1b[90m' + t('terminal.cloudInitInProgressHint') + '\x1b[0m')
  424:                 tab.terminal.writeln('')
  425:             }
  426:         }
  427:     } catch (err) {
  428:         console.error('[CloudInit] Check failed:', err)
  429:         // æ£€æŸ¥å¤±è´¥æ—¶å…è®¸ç»§ç»­è¿žæŽ¥
  430:         cloudInitStatus.value.set(tabId, 'ready')
  431:         connectTab(tabId)
  432:     } finally {
  433:         cloudInitChecking.value.set(tabId, false)
  434:     }
  435: }
  436: 
  437: // é‡æ–°æ£€æŸ¥ Cloud-init çŠ¶æ€
  438: async function retryCloudInitCheck(tabId: string) {
  439:     await checkCloudInitAndConnect(tabId)
  440: }
