  487: /**
  488:  * åˆ›å»ºç»ˆç«¯ä¼šè¯
  489:  */
  490: export async function createTerminalSession(
  491:     clientWs: WsWebSocket,
  492:     host: Host,
  493:     instanceId: number,
  494:     instanceName: string,
  495:     userId: number,
  496:     instanceType: 'container' | 'vm' = 'container',
  497:     authSessionId?: string
  498: ): Promise<TerminalSession> {
  499:     const sessionId = generateSessionId()
