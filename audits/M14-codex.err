  369:             if (terminalStore.linkPreview) {
  370:                 linkTooltip.visible = true
  371:                 linkTooltip.url = uri
  372:                 linkTooltip.x = event.clientX + 10
  373:                 linkTooltip.y = event.clientY + 10
  374:             }
  375:         },
  376:         onLinkLeave: () => {
  377:             linkTooltip.visible = false
  378:         }
  379:     })
  380: 
  381:     tab.terminal = runtime.terminal
  382:     tab.fitAddon = runtime.fitAddon
  383:     tab.searchAddon = runtime.searchAddon
  384:     tab.unicodeAddon = runtime.unicodeAddon
  385:     tab.webglAddon = runtime.webglAddon
  386:     tab.serializeAddon = runtime.serializeAddon
  387:     tab.clipboardAddon = runtime.clipboardAddon
  388:     tab.isWebGLEnabled = runtime.isWebGLEnabled
  389:     
  390:     // è¾“å‡ºæ¬¢è¿Žä¿¡æ¯
  391:     printWelcomeBanner(runtime.terminal, tab.instanceName)
  392:     
  393:     // æ£€æŸ¥ Cloud-init çŠ¶æ€åŽå†è¿žæŽ¥
  394:     checkCloudInitAndConnect(tabId)
  395: }
