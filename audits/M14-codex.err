  625: // å‘é€è°ƒæ•´å¤§å°å‘½ä»¤
  626: function sendResize(tabId: string, cols: number, rows: number) {
  627:     const tab = tabs.value.find(t => t.id === tabId)
  628:     if (tab?.ws && tab.ws.readyState === WebSocket.OPEN) {
  629:         try {
  630:             tab.ws.send(JSON.stringify({ type: 'resize', cols, rows }))
  631:         } catch {
  632:             // WebSocket may be closed during send, ignore
  633:         }
  634:     }
  635: }
