  254:   }
  255: 
  256:   const updatedRows = await prisma.$queryRawUnsafe<Array<{
  257:     id: number
  258:     userId: number
  259:     name: string
  260:     command: string
  261:     description: string | null
  262:     createdAt: Date
  263:     updatedAt: Date
  264:   }>>(
  265:     `
  266:       UPDATE terminal_saved_commands
  267:       SET
  268:         name = $1,
  269:         command = $2,
  270:         description = $3,
  271:         updated_at = NOW()
  272:       WHERE id = $4 AND user_id = $5
  273:       RETURNING
  274:         id,
  275:         user_id AS "userId",
  276:         name,
  277:         command,
  278:         description,
  279:         created_at AS "createdAt",
  280:         updated_at AS "updatedAt"
  281:     `,
  282:     encryptSensitiveData(nextName),
  283:     encryptSensitiveData(nextCommand),
  284:     nextDescription ? encryptSensitiveData(nextDescription) : null,
  285:     id,
  286:     userId
  287:   )
  288:   const updated = updatedRows[0]
  289: 
  290:   return {
  291:     success: true,
  292:     command: mapTerminalSavedCommand(updated)
  293:   }
  294: }
  295: 
  296: export async function deleteTerminalSavedCommand(id: number, userId: number): Promise<boolean> {
  297:   const result = await prisma.$executeRawUnsafe(
  298:     `
  299:       DELETE FROM terminal_saved_commands
  300:       WHERE id = $1 AND user_id = $2
  301:     `,
  302:     id,
  303:     userId
  304:   )
  305: 
  306:   return Number(result) > 0
  307: }

