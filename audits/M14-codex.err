  343: // åˆå§‹åŒ–æ ‡ç­¾çš„ç»ˆç«¯
  344: function initTabTerminal(tabId: string) {
  345:     const tab = tabs.value.find(t => t.id === tabId)
  346:     if (!tab) return
  347:     
  348:     const container = containerRefs.value.get(tabId)
  349:     if (!container) return
  350:     
  351:     tab.container = container
  352:     
  353:     const runtime = createTerminalRuntime({
  354:         container,
  355:         fontSize: fontSize.value,
  356:         fontFamily: "'JetBrains Mono', 'Fira Code', 'Consolas', monospace",
  357:         theme: terminalStore.currentTheme,
  358:         isMobileDevice,
  359:         enableWebgl: false,
  360:         onBell: () => terminalStore.playBell(),
  361:         onSelectionCopy: (selection) => {
  362:             if (terminalStore.autoCopyOnSelect) {
  363:                 navigator.clipboard.writeText(selection).catch(() => {
  364:                     // ignore
  365:                 })
  366:             }
  367:         },
