  564: // å¸¦é‡è¿žæç¤ºçš„è¿žæŽ¥å‡½æ•°
  565: function reconnectTab(tabId: string) {
  566:     const tab = tabs.value.find(t => t.id === tabId)
  567:     if (!tab) return
  568:     
  569:     if (tab.status === 'connecting' || tab.status === 'reconnecting') return
  570:     
  571:     if (tab.terminal) {
  572:         printReconnectMessage(tab.terminal)
  573:     }
  574:     
  575:     void connectTab(tabId)
  576: }
