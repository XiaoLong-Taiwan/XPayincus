  442: // è·³è¿‡ Cloud-init æ£€æŸ¥å¹¶è¿žæŽ¥
  443: function skipCloudInitAndConnect(tabId: string) {
  444:     cloudInitStatus.value.set(tabId, 'skipped')
  445:     connectTab(tabId)
  446: }
