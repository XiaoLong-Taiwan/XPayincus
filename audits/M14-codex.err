  448: // è¿žæŽ¥æ ‡ç­¾åˆ°ç»ˆç«¯æœåŠ¡å™¨
  449: async function connectTab(tabId: string) {
  450:     const tab = tabs.value.find(t => t.id === tabId)
  451:     if (!tab) return
  452:     
  453:     const token = authStore.token
  454:     if (!token) {
  455:         tab.status = 'error'
  456:         tab.error = 'Authentication required'
  457:         return
  458:     }
  459:     
  460:     if (tab.ws && (tab.ws.readyState === WebSocket.OPEN || tab.ws.readyState === WebSocket.CONNECTING)) {
  461:         return
  462:     }
  463:     
  464:     tab.status = 'connecting'
  465:     tab.error = null
  466:     tab.connectAttempt += 1
  467:     const connectAttempt = tab.connectAttempt
  468:     
  469:     try {
  470:         const ticketResponse = await api.instances.createTerminalTicket(tab.instanceId)
  471:         const currentTab = tabs.value.find(t => t.id === tabId)
  472:         if (!currentTab || currentTab.connectAttempt !== connectAttempt) {
  473:             return
  474:         }
  475: 
  476:         const wsUrl = buildTerminalWebSocketUrl(currentTab.instanceId, ticketResponse.ticket)
  477:         const ws = new WebSocket(wsUrl)
  478:         // ä½¿ç”¨ arraybuffer ç¡®ä¿äºŒè¿›åˆ¶æ•°æ®æŒ‰é¡ºåºå¤„ç†ï¼ˆé¿å… Blob å¼‚æ­¥å¯¼è‡´çš„ä¹±åºï¼‰
  479:         ws.binaryType = 'arraybuffer'
  480:         currentTab.ws = ws
  481:         
  482:         ws.onopen = () => {
  483:             console.log(`[Terminal Tab ${tabId}] WebSocket connected`)
  484:         }
  485:         
  486:         ws.onmessage = (event) => {
  487:             handleTerminalSocketPayload(event.data, () => tab.terminal, (message) => {
  488:                 handleControlMessage(tabId, message)
  489:             })
  490:         }
  491:         
  492:         ws.onerror = () => {
  493:             currentTab.error = 'Connection error'
  494:         }
  495:         
  496:         ws.onclose = (event) => {
  497:             if (currentTab.ws !== ws) return
  498: 
  499:             console.log(`[Terminal Tab ${tabId}] WebSocket closed:`, event.code)
  500: 
  501:             // æ„å¤–æ–­å¼€æ—¶è‡ªåŠ¨é‡è¿ž
  502:             if (shouldRetryTerminalClose(event.code) && (currentTab.status === 'connected' || currentTab.status === 'connecting' || currentTab.status === 'reconnecting')) {
  503:                 const attempts = reconnectAttempts.value.get(tabId) || 0
  504:                 if (attempts < TERMINAL_MAX_RECONNECT_ATTEMPTS) {
  505:                     reconnectAttempts.value.set(tabId, attempts + 1)
  506:                     currentTab.status = 'reconnecting'
  507:                     // çº¿æ€§é€€é¿ï¼š1ç§’, 3ç§’, 5ç§’... æœ€å¤š 15ç§’
  508:                     const delay = Math.min(1000 + attempts * 2000, 15000)
  509:                     console.log(`[Terminal Tab ${tabId}] Auto reconnecting in ${delay}ms (attempt ${attempts + 1}/${TERMINAL_MAX_RECONNECT_ATTEMPTS})`)
  510:                     const existingTimer = reconnectTimers.value.get(tabId)
  511:                     if (existingTimer) {
  512:                         clearTimeout(existingTimer)
  513:                     }
  514:                     const timer = setTimeout(() => {
  515:                         reconnectTimers.value.delete(tabId)
  516:                         if (currentTab.terminal) {
  517:                             printReconnectMessage(currentTab.terminal)
  518:                         }
  519:                         void connectTab(tabId)
  520:                     }, delay)
  521:                     reconnectTimers.value.set(tabId, timer)
  522:                 } else {
  523:                     currentTab.status = 'error'
  524:                     currentTab.error = 'Connection lost'
  525:                     reconnectAttempts.value.delete(tabId)
  526:                 }
  527:             } else {
  528:                 currentTab.status = 'disconnected'
  529:             }
  530:         }
  531:         
  532:         // ç»‘å®šç»ˆç«¯è¾“å…¥
  533:         if (currentTab.terminal && !currentTab.eventsBound) {
  534:             currentTab.eventsBound = true
  535:             
  536:             currentTab.terminal.onData((data) => {
  537:                 if (currentTab.ws && currentTab.ws.readyState === WebSocket.OPEN) {
  538:                     try {
  539:                         currentTab.ws.send(data)
  540:                     } catch {
  541:                         // WebSocket may be closed during send, ignore
  542:                     }
  543:                 }
  544:             })
  545:             
  546:             currentTab.terminal.onResize(({ cols, rows }) => {
  547:                 // æ£€æŸ¥æ ‡ç­¾æ˜¯å¦ä»ç„¶å­˜åœ¨ï¼Œé˜²æ­¢åœ¨å¼‚æ­¥æ“ä½œæœŸé—´è¢«é”€æ¯
  548:                 if (tabs.value.find(t => t.id === tabId)) {
  549:                     sendResize(tabId, cols, rows)
  550:                 }
  551:             })
  552:         }
  553:     } catch (err) {
  554:         const currentTab = tabs.value.find(t => t.id === tabId)
  555:         if (!currentTab || currentTab.connectAttempt !== connectAttempt) {
  556:             return
  557:         }
  558: 
  559:         currentTab.status = 'error'
  560:         currentTab.error = err instanceof Error ? err.message : 'Failed to connect'
  561:     }
  562: }
