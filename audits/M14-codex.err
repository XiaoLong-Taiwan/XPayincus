  250: // å…³é—­æ ‡ç­¾
  251: function closeTab(tabId: string) {
  252:     const index = tabs.value.findIndex(t => t.id === tabId)
  253:     if (index === -1) return
  254:     
  255:     const tab = tabs.value[index]
  256:     
  257:     // æ¸…ç†é‡è¿žå®šæ—¶å™¨
  258:     const timer = reconnectTimers.value.get(tabId)
  259:     if (timer) {
  260:         clearTimeout(timer)
  261:         reconnectTimers.value.delete(tabId)
  262:     }
  263:     reconnectAttempts.value.delete(tabId)
  264:     
  265:     // æ¸…ç†èµ„æºï¼ˆæŒ‰é¡ºåºï¼šWebSocket -> GPU Addons -> Terminalï¼‰
  266:     // 1. å…ˆå…³é—­ WebSocket è¿žæŽ¥
  267:     if (tab.ws) {
  268:         tab.ws.close(1000, 'Tab closed')
  269:         tab.ws = null
  270:     }
  271:     // 2. æ¸…ç†ç»ˆç«¯èµ„æº
  272:     disposeTerminalRuntime(tab)
  273:     
  274:     // ç§»é™¤æ ‡ç­¾
  275:     tabs.value.splice(index, 1)
  276:     containerRefs.value.delete(tabId)
  277:     emit('update:tabCount', tabs.value.length)
  278:     
  279:     // å¦‚æžœå…³é—­çš„æ˜¯å½“å‰æ ‡ç­¾ï¼Œåˆ‡æ¢åˆ°å…¶ä»–æ ‡ç­¾
  280:     if (activeTabId.value === tabId && tabs.value.length > 0) {
  281:         activeTabId.value = tabs.value[Math.min(index, tabs.value.length - 1)].id
  282:         // ç¡®ä¿æ–°æ¿€æ´»çš„æ ‡ç­¾æ­£ç¡®æ˜¾ç¤º
  283:         nextTick(() => {
  284:             const newTab = activeTab.value
  285:             if (newTab?.terminal && newTab.fitAddon) {
  286:                 newTab.fitAddon.fit()
  287:                 newTab.terminal.refresh(0, newTab.terminal.rows - 1)
  288:                 newTab.terminal.focus()
  289:             }
  290:         })
  291:     }
  292:     
  293:     // å¦‚æžœæ²¡æœ‰æ ‡ç­¾äº†ï¼Œå…³é—­æ¨¡æ€æ¡†
  294:     if (tabs.value.length === 0) {
  295:         closeModal()
  296:     }
  297: }
