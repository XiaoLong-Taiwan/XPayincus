   13: // è¯ä¹¦ç¼“å­˜ï¼ˆé¿å…æ¯æ¬¡è¿žæŽ¥éƒ½è¯»å–æ–‡ä»¶ï¼‰
   14: interface CertCache {
   15:     cert: Buffer
   16:     key: Buffer
   17:     lastModified: number
   18: }
   19: const certCache = new Map<string, CertCache>()
   20: const CERT_CACHE_TTL = 60 * 60 * 1000 // 1å°æ—¶
   21: 
   22: /**
   23:  * èŽ·å–ç¼“å­˜çš„è¯ä¹¦ï¼ˆé¿å…é‡å¤ I/O è¯»å–ï¼‰
   24:  */
   25: function getCachedCertificates(certPath: string, keyPath: string): { cert: Buffer; key: Buffer } {
   26:     const resolvedPair = resolveCertificatePair(certPath, keyPath)
   27:     if (!resolvedPair.certPath || !resolvedPair.keyPath) {
   28:         throw new Error('Failed to read certificate files: certificate or key path is missing')
   29:     }
   30: 
   31:     const cacheKey = `${resolvedPair.certPath}:${resolvedPair.keyPath}`
   32:     const cached = certCache.get(cacheKey)
   33:     const now = Date.now()
   34: 
   35:     // ç¼“å­˜æœ‰æ•ˆ
   36:     if (cached && (now - cached.lastModified) < CERT_CACHE_TTL) {
   37:         return { cert: cached.cert, key: cached.key }
   38:     }
   39: 
   40:     // è¯»å–å¹¶ç¼“å­˜ï¼ˆæ·»åŠ å¼‚å¸¸ä¿æŠ¤ï¼‰
   41:     try {
   42:         const cert = readFileSync(resolvedPair.certPath)
   43:         const key = readFileSync(resolvedPair.keyPath)
   44:         certCache.set(cacheKey, { cert, key, lastModified: now })
   45:         return { cert, key }
   46:     } catch (err) {
   47:         const errorMessage = err instanceof Error ? err.message : String(err)
   48:         throw new Error(`Failed to read certificate files: ${errorMessage}`)
   49:     }
   50: }
