   93: function buildExecPayload(): Record<string, unknown> {
   94:     return {
   95:         command: [
   96:             '/bin/sh', '-c',
   97:             'setup_term() { ' +
   98:             '  if [ -e /usr/share/terminfo/x/xterm-256color ] || [ -e /lib/terminfo/x/xterm-256color ] || ' +
   99:             '     [ -e /etc/terminfo/x/xterm-256color ] || infocmp xterm-256color >/dev/null 2>&1; then ' +
  100:             '    export TERM=xterm-256color; ' +
  101:             '  elif [ -e /usr/share/terminfo/x/xterm ] || [ -e /lib/terminfo/x/xterm ] || ' +
  102:             '       [ -e /etc/terminfo/x/xterm ] || infocmp xterm >/dev/null 2>&1; then ' +
  103:             '    export TERM=xterm; ' +
  104:             '  else ' +
  105:             '    export TERM=linux; ' +
  106:             '  fi; ' +
  107:             '}; ' +
  108:             'setup_term; ' +
  109:             'export LANG=en_US.UTF-8; export LC_ALL=en_US.UTF-8; ' +
  110:             'if [ -x /bin/bash ]; then exec /bin/bash -l; ' +
  111:             'elif [ -x /usr/bin/bash ]; then exec /usr/bin/bash -l; ' +
  112:             'else exec /bin/sh -l; fi'
  113:         ],
  114:         'wait-for-websocket': true,
  115:         interactive: true,
  116:         environment: {
  117:             TERM: 'xterm',
  118:             LANG: 'en_US.UTF-8',
  119:             LC_ALL: 'en_US.UTF-8',
  120:             HOME: '/root',
  121:             USER: 'root',
  122:             SHELL: '/bin/bash'
  123:         },
  124:         width: 120,
  125:         height: 40
  126:     }
  127: }
  128: 
  129: function buildConsolePayload(): Record<string, unknown> {
  130:     return {
  131:         'wait-for-websocket': true,
  132:         type: 'console'
  133:     }
  134: }
