  107: async function canManageThemes(user: { id: number; username: string; role: 'admin' | 'user' }): Promise<boolean> {
  108:   if (user.role !== 'admin') return false
  109:   const themeAllowlist = await getCombinedAdminIdAllowlist(
  110:     'theme_manager_allowed_admin_ids',
  111:     'THEME_MANAGER_ALLOWED_ADMIN_IDS'
  112:   )
  113:   const pluginAllowlist = await getCombinedAdminIdAllowlist(
  114:     'plugin_manager_allowed_admin_ids',
  115:     ['PLUGIN_MANAGER_ALLOWED_ADMIN_IDS', 'SYSTEM_UPDATE_ALLOWED_ADMIN_IDS']
  116:   )
  117:   const allowedIds = new Set([...themeAllowlist.ids, ...pluginAllowlist.ids])
  118:   if (allowedIds.size > 0) return allowedIds.has(user.id)
  119:   return user.username === 'admin'
  120: }
  121: 
  122: async function requireThemeManager(request: FastifyRequest, reply: FastifyReply): Promise<boolean> {
  123:   const user = getRequestUser(request)
  124:   if (!(await canManageThemes(user))) {
  125:     await createLog(
  126:       user.id,
  127:       LogModule.PLUGIN,
  128:       'theme.manager.denied',
  129:       `Denied theme management access for ${user.username}`,
  130:       LogResult.WARNING
  131:     )
  132:     reply.code(403).send({ error: 'Super administrator privileges required', code: 'SUPER_ADMIN_REQUIRED' })
  133:     return false
  134:   }
  135:   return true
  136: }
  137: 
  138: async function writeUploadPackage(request: FastifyRequest): Promise<{ packagePath: string; sourceName: string }> {
  139:   const multipartRequest = request as FastifyRequest & {
  140:     parts: () => AsyncIterable<any>
  141:   }
  142:   const uploadDir = join(getThemeStagingDir(), 'uploads')
  143:   await mkdir(uploadDir, { recursive: true })
  144:   const maxBytes = getThemePackageMaxBytes()
  145: 
  146:   for await (const part of multipartRequest.parts()) {
  147:     if (part.type !== 'file') continue
  148:     if (part.fieldname !== 'package') {
  149:       await part.toBuffer()
  150:       continue
  151:     }
  152:     const filename = String(part.filename || 'theme.tar.gz')
  153:     if (!filename.endsWith('.tar.gz')) {
  154:       throw new Error('Theme package must be a .tar.gz file')
  155:     }
  156:     const buffer = await part.toBuffer()
  157:     if (buffer.length === 0) throw new Error('Theme package is empty')
  158:     if (buffer.length > maxBytes) throw new Error(`Theme package exceeds ${Math.round(maxBytes / 1024 / 1024)}MB`)
  159:     const packagePath = join(uploadDir, `${Date.now()}-${randomUUID()}.tar.gz`)
  160:     await writeFile(packagePath, buffer, { mode: 0o600 })
  161:     return { packagePath, sourceName: filename }
  162:   }
  163: 
  164:   throw new Error('Missing theme package file')
  165: }
