  260:   fastify.patch<{ Params: ReviewParams; Body: ReviewBody }>('/admin/:id/review', {
  261:     onRequest: [fastify.authenticateAdmin]
  262:   }, async (request, reply) => {
  263:     if (!(await requireThemeMarketReviewer(request, reply))) return
