   37: function asThemeManifest(value: unknown): PayIncusThemeManifest {
   38:   return value as PayIncusThemeManifest
   39: }
   40: 
   41: function asTokens(value: unknown): Record<string, unknown> {
   42:   return value && typeof value === 'object' && !Array.isArray(value) ? value as Record<string, unknown> : {}
   43: }
   44: 
   45: function asConfigValues(value: unknown): Record<string, unknown> {
   46:   return value && typeof value === 'object' && !Array.isArray(value) ? value as Record<string, unknown> : {}
   47: }
   48: 
   49: function buildThemeAssetUrl(theme: Pick<ThemePackage, 'themeId' | 'version'>, assetPath: string): string {
   50:   return `/api/themes/assets/${encodeURIComponent(theme.themeId)}/${encodeURIComponent(theme.version)}/${assetPath}`
   51: }
   52: 
   53: function buildThemeTemplateUrls(theme: Pick<ThemePackage, 'themeId' | 'version'>, manifest: PayIncusThemeManifest): Record<string, { title: string; url: string }> {
   54:   const templates: Record<string, { title: string; url: string }> = {}
   55:   for (const template of manifest.templates || []) {
   56:     templates[template.slot] = {
   57:       title: template.title,
   58:       url: buildThemeAssetUrl(theme, template.entry)
   59:     }
   60:   }
   61:   return templates
   62: }
   63: 
   64: export function serializeThemePackage(theme: ThemeWithUsers): SerializedThemePackage {
   65:   const manifest = asThemeManifest(theme.manifest)
   66:   return {
   67:     id: theme.id,
   68:     themeId: theme.themeId,
   69:     name: theme.name,
   70:     version: theme.version,
   71:     description: theme.description,
   72:     author: theme.author,
   73:     status: theme.status,
   74:     enabled: theme.enabled,
   75:     manifest,
   76:     tokens: asTokens(theme.tokens),
   77:     configValues: asConfigValues(theme.configValues),
   78:     cssPath: theme.cssPath,
   79:     cssUrl: buildThemeAssetUrl(theme, theme.cssPath),
   80:     templateUrls: buildThemeTemplateUrls(theme, manifest),
   81:     previewImageUrl: manifest.previewImage ? buildThemeAssetUrl(theme, manifest.previewImage) : null,
   82:     previewUrl: `/api/themes/preview/${encodeURIComponent(theme.themeId)}`,
   83:     packageSha256: theme.packageSha256,
   84:     installedByUsername: theme.installedBy?.username || null,
   85:     enabledByUsername: theme.enabledBy?.username || null,
   86:     enabledAt: theme.enabledAt?.toISOString() || null,
   87:     createdAt: theme.createdAt.toISOString(),
   88:     updatedAt: theme.updatedAt.toISOString()
   89:   }
   90: }
