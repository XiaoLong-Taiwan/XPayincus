  138: async function writeUploadPackage(request: FastifyRequest): Promise<{ packagePath: string; sourceName: string }> {
  139:   const multipartRequest = request as FastifyRequest & {
  140:     parts: () => AsyncIterable<any>
  141:   }
  142:   const uploadDir = join(getThemeStagingDir(), 'uploads')
  143:   await mkdir(uploadDir, { recursive: true })
  144:   const maxBytes = getThemePackageMaxBytes()
  145: 
  146:   for await (const part of multipartRequest.parts()) {
  147:     if (part.type !== 'file') continue
  148:     if (part.fieldname !== 'package') {
  149:       await part.toBuffer()
  150:       continue
  151:     }
  152:     const filename = String(part.filename || 'theme.tar.gz')
  153:     if (!filename.endsWith('.tar.gz')) {
  154:       throw new Error('Theme package must be a .tar.gz file')
  155:     }
  156:     const buffer = await part.toBuffer()
  157:     if (buffer.length === 0) throw new Error('Theme package is empty')
  158:     if (buffer.length > maxBytes) throw new Error(`Theme package exceeds ${Math.round(maxBytes / 1024 / 1024)}MB`)
  159:     const packagePath = join(uploadDir, `${Date.now()}-${randomUUID()}.tar.gz`)
  160:     await writeFile(packagePath, buffer, { mode: 0o600 })
  161:     return { packagePath, sourceName: filename }
  162:   }
  163: 
  164:   throw new Error('Missing theme package file')
  165: }
  166: 
  167: function normalizeThemeConfigKey(value: string): string | null {
  168:   const trimmed = value.trim()
  169:   return /^[A-Za-z][A-Za-z0-9_.-]{0,79}$/.test(trimmed) ? trimmed : null
  170: }
  171: 
  172: function themeConfigFileContentType(filename: string): string {
  173:   const ext = extname(filename).toLowerCase()
  174:   if (ext === '.png') return 'image/png'
  175:   if (ext === '.jpg' || ext === '.jpeg') return 'image/jpeg'
  176:   if (ext === '.webp') return 'image/webp'
  177:   return 'application/octet-stream'
  178: }
  179: 
  180: async function writeThemeConfigFileUpload(request: FastifyRequest, themeId: string, key: string): Promise<{
  181:   filename: string
  182:   mimeType: string
  183:   sizeBytes: number
  184:   value: string
  185: }> {
  186:   const multipartRequest = request as FastifyRequest & {
  187:     parts: () => AsyncIterable<any>
  188:   }
  189:   const uploadDir = resolveThemeAsset(getThemeDataDir(), join('config-files', themeId, key))
  190:   await mkdir(uploadDir, { recursive: true })
  191: 
  192:   for await (const part of multipartRequest.parts()) {
  193:     if (part.type !== 'file') continue
  194:     const mimeType = String(part.mimetype || '').toLowerCase()
  195:     const ext = THEME_CONFIG_FILE_MIME_EXTENSIONS.get(mimeType)
  196:     if (!ext) {
  197:       await part.toBuffer()
  198:       throw new Error('Theme config file must be a PNG, JPEG, or WebP image')
  199:     }
  200:     const buffer = await part.toBuffer()
  201:     if (buffer.length === 0) throw new Error('Theme config file is empty')
  202:     if (buffer.length > THEME_CONFIG_FILE_MAX_BYTES) throw new Error('Theme config file exceeds 2MB')
  203:     const filename = `${Date.now()}-${randomUUID()}${ext}`
  204:     const filePath = resolveThemeAsset(uploadDir, filename)
  205:     await writeFile(filePath, buffer, { mode: 0o600 })
  206:     return {
  207:       filename,
  208:       mimeType: themeConfigFileContentType(filename),
  209:       sizeBytes: buffer.length,
  210:       value: `/api/themes/${encodeURIComponent(themeId)}/config-files/${encodeURIComponent(key)}/${encodeURIComponent(filename)}`
  211:     }
  212:   }
  213: 
  214:   throw new Error('Missing theme config file')
  215: }
