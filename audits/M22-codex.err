   19: const REVIEW_STATUSES: ThemeMarketSubmissionReviewStatus[] = ['pending', 'listed', 'rejected', 'delisted']
   20: const RISK_LEVELS: ThemeMarketSubmissionRiskLevel[] = ['low', 'medium', 'high', 'critical']
   21: const THEME_ID_PATTERN = /^[a-z][a-z0-9]*(?:\.[a-z][a-z0-9-]*){2,}$/
   22: const VERSION_PATTERN = /^[0-9A-Za-z][0-9A-Za-z._+-]{0,63}$/
   23: const SHA256_PATTERN = /^[a-f0-9]{64}$/i
   24: 
   25: interface SubmissionBody {
   26:   themeId?: unknown
   27:   version?: unknown
   28:   name?: unknown
   29:   repoUrl?: unknown
   30:   releaseUrl?: unknown
   31:   manifestUrl?: unknown
   32:   packageUrl?: unknown
   33:   sha256?: unknown
   34:   developerName?: unknown
   35:   developerHomepage?: unknown
   36:   developerGithub?: unknown
   37:   contactEmail?: unknown
   38:   compatibility?: unknown
   39:   tokens?: unknown
   40:   layoutSlots?: unknown
   41:   notes?: unknown
   42: }
