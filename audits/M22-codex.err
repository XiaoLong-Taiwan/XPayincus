   51: 
   52: function normalizeConfigBody(value: unknown): Record<string, unknown> | null {
   53:   if (!value || typeof value !== 'object' || Array.isArray(value)) return null
   54:   const json = JSON.stringify(value)
   55:   if (json.length > 32 * 1024) return null
   56:   return value as Record<string, unknown>
   57: }
   58: 
   59: function summarizeConfigKeys(keys: string[]): string {
   60:   if (keys.length === 0) return 'none'
   61:   const sorted = Array.from(new Set(keys)).sort()
   62:   const visible = sorted.slice(0, 20).join(', ')
   63:   return sorted.length > 20 ? `${visible}, +${sorted.length - 20} more` : visible
   64: }
   65: 
   66: function stableConfigFingerprint(value: unknown): string {
   67:   if (value === undefined) return 'undefined'
   68:   try {
   69:     return JSON.stringify(value, Object.keys(value && typeof value === 'object' && !Array.isArray(value) ? value as Record<string, unknown> : {}).sort())
   70:   } catch {
   71:     return String(value)
   72:   }
   73: }
   74: 
   75: function themeConfigAuditSummary(input: {
   76:   themeId: string
   77:   before: Record<string, unknown>
   78:   after: Record<string, unknown>
   79:   manifest: PayIncusThemeManifest
   80: }): string {
   81:   const beforeKeys = new Set(Object.keys(input.before))
   82:   const afterKeys = new Set(Object.keys(input.after))
   83:   const addedKeys = Array.from(afterKeys).filter(key => !beforeKeys.has(key))
   84:   const removedKeys = Array.from(beforeKeys).filter(key => !afterKeys.has(key))
   85:   const updatedKeys = Array.from(afterKeys).filter(key => {
   86:     if (!beforeKeys.has(key)) return false
   87:     return stableConfigFingerprint(input.before[key]) !== stableConfigFingerprint(input.after[key])
   88:   })
   89:   const changedKeys = [...addedKeys, ...updatedKeys, ...removedKeys]
   90:   const secretKeys = changedKeys.filter(key => {
   91:     const field = input.manifest.configSchema?.[key]
   92:     return field?.type === 'password' || (field as { secret?: boolean } | undefined)?.secret === true
   93:   })
   94:   const fileKeys = changedKeys.filter(key => input.manifest.configSchema?.[key]?.type === 'file')
   95:   return [
   96:     `Updated theme config for ${input.themeId}`,
   97:     `changed=${changedKeys.length}`,
   98:     `added=[${summarizeConfigKeys(addedKeys)}]`,
   99:     `updated=[${summarizeConfigKeys(updatedKeys)}]`,
  100:     `removed=[${summarizeConfigKeys(removedKeys)}]`,
  101:     `secret=[${summarizeConfigKeys(secretKeys)}]`,
  102:     `file=[${summarizeConfigKeys(fileKeys)}]`,
  103:     'values=redacted'
  104:   ].join('; ')
  105: }
