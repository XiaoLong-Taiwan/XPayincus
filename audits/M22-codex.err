  329:     throw new Error(`Failed to download theme package: HTTP ${response.status}`)
  330:   }
  331:   const arrayBuffer = await response.arrayBuffer()
  332:   const buffer = Buffer.from(arrayBuffer)
  333:   const actualSha256 = createHash('sha256').update(buffer).digest('hex')
  334:   if (actualSha256 !== entry.sha256.toLowerCase()) {
  335:     throw new Error('Theme package SHA256 mismatch')
  336:   }
  337:   const dir = join(getThemeStagingDir(), 'downloads')
  338:   await mkdir(dir, { recursive: true })
  339:   const path = join(dir, `${entry.id}-${entry.latest}-${randomUUID()}.tar.gz`)
  340:   await writeFile(path, buffer, { mode: 0o600 })
  341:   return path
  342: }

