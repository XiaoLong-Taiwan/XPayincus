  115: function compareManifestToSubmission(
  116:   manifest: PayIncusThemeManifest,
  117:   input: ThemeSubmissionScanInput,
  118:   findings: ThemeSubmissionScanFinding[]
  119: ) {
  120:   if (manifest.id !== input.themeId) {
  121:     pushFinding(findings, 'error', 'manifest_id_mismatch', `Manifest id ${manifest.id} does not match submitted id ${input.themeId}`)
  122:   }
  123:   if (manifest.version !== input.version) {
  124:     pushFinding(findings, 'error', 'manifest_version_mismatch', `Manifest version ${manifest.version} does not match submitted version ${input.version}`)
  125:   }
  126:   if (manifest.name !== input.name) {
  127:     pushFinding(findings, 'warning', 'manifest_name_mismatch', `Manifest name ${manifest.name} differs from submitted name ${input.name}`)
  128:   }
  129: }
  130: 
  131: function assessRisk(manifest: PayIncusThemeManifest, findings: ThemeSubmissionScanFinding[]): ThemeMarketSubmissionRiskLevel {
  132:   const tokenKeys = Object.keys(manifest.tokens || {})
  133:   let risk: ThemeMarketSubmissionRiskLevel = 'low'
  134:   if (manifest.layoutSlots.length > 0) {
  135:     risk = 'medium'
  136:     pushFinding(findings, 'info', 'layout_slots_declared', `Theme declares ${manifest.layoutSlots.length} layout slots`)
  137:   }
  138:   if (manifest.layoutSlots.some(slot => /admin|checkout|payment|auth|login|register/i.test(slot))) {
  139:     risk = 'high'
  140:     pushFinding(findings, 'warning', 'sensitive_layout_slot', 'Theme declares sensitive auth, checkout, payment, or admin layout slots')
  141:   }
  142:   if (tokenKeys.length > 60 && risk === 'low') {
  143:     risk = 'medium'
  144:     pushFinding(findings, 'info', 'many_tokens_declared', `Theme declares ${tokenKeys.length} design tokens`)
  145:   }
  146:   if (Object.keys(manifest.configSchema || {}).length > 40 && risk === 'low') {
  147:     risk = 'medium'
  148:     pushFinding(findings, 'info', 'large_config_schema', 'Theme declares a large config schema')
  149:   }
  150:   return risk
  151: }
  152: 
  153: function scanStatusFromFindings(findings: ThemeSubmissionScanFinding[]): ThemeSubmissionScanStatus {
  154:   if (findings.some(finding => finding.severity === 'error')) return 'failed'
  155:   if (findings.some(finding => finding.severity === 'warning')) return 'warning'
  156:   return 'passed'
  157: }
