  160:   return {
  161:     id: manifest.id,
  162:     name: manifest.name,
  163:     version: manifest.version,
  164:     payincus: manifest.payincus,
  165:     tokenCount: Object.keys(manifest.tokens || {}).length,
  166:     layoutSlotCount: manifest.layoutSlots.length
