   71: async function downloadBoundedHttpsFile(url: string, label: string, maxBytes: number): Promise<Buffer> {
   72:   const safeUrl = await assertSafeHttpUrl(url, label)
   73:   if (safeUrl.protocol !== 'https:') {
   74:     throw new Error(`${label} must use HTTPS`)
   75:   }
   76: 
   77:   const response = await fetch(safeUrl, {
   78:     method: 'GET',
   79:     redirect: 'manual',
   80:     signal: AbortSignal.timeout(30_000),
   81:     headers: {
   82:       'accept': 'application/octet-stream',
   83:       'user-agent': 'PayIncus-Theme-Submission-Scanner/1.0'
   84:     }
   85:   })
   86: 
   87:   if (!response.ok) {
   88:     throw new Error(`${label} download failed with HTTP ${response.status}`)
   89:   }
   90: 
   91:   const contentLength = Number(response.headers.get('content-length') || '0')
   92:   if (Number.isFinite(contentLength) && contentLength > maxBytes) {
   93:     throw new Error(`${label} exceeds ${Math.round(maxBytes / 1024 / 1024)}MB`)
   94:   }
   95: 
   96:   const chunks: Uint8Array[] = []
   97:   let total = 0
   98:   if (!response.body) throw new Error(`${label} response has no body`)
   99: 
  100:   const reader = response.body.getReader()
  101:   while (true) {
  102:     const { done, value } = await reader.read()
  103:     if (done) break
  104:     if (!value) continue
  105:     total += value.byteLength
  106:     if (total > maxBytes) {
  107:       throw new Error(`${label} exceeds ${Math.round(maxBytes / 1024 / 1024)}MB`)
  108:     }
  109:     chunks.push(value)
  110:   }
  111: 
  112:   return Buffer.concat(chunks)
  113: }
