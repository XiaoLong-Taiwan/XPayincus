  129: export async function installValidatedTheme(input: {
  130:   stagingDir: string
  131:   manifest: PayIncusThemeManifest
  132:   packageSha256: string
  133:   installedByUserId: number
  134: }) {
  135:   const installRoot = getThemeInstallDir()
  136:   await mkdir(installRoot, { recursive: true })
  137:   const themeRoot = resolveThemeAsset(installRoot, input.manifest.id)
  138:   await mkdir(themeRoot, { recursive: true })
  139:   const finalPath = resolveThemeAsset(themeRoot, input.manifest.version)
  140:   await rm(finalPath, { recursive: true, force: true })
  141:   await rename(input.stagingDir, finalPath)
  142: 
  143:   return await prisma.themePackage.upsert({
  144:     where: { themeId: input.manifest.id },
  145:     create: {
  146:       themeId: input.manifest.id,
  147:       name: input.manifest.name,
  148:       version: input.manifest.version,
  149:       description: input.manifest.description || null,
  150:       author: input.manifest.author || null,
  151:       status: 'installed',
  152:       enabled: false,
  153:       manifest: input.manifest as any,
  154:       tokens: input.manifest.tokens as any,
  155:       configValues: normalizeThemeConfigValues(input.manifest.configSchema, {}) as any,
  156:       cssPath: input.manifest.css,
  157:       installPath: finalPath,
  158:       packageSha256: input.packageSha256,
  159:       installedByUserId: input.installedByUserId
  160:     },
  161:     update: {
  162:       name: input.manifest.name,
  163:       version: input.manifest.version,
  164:       description: input.manifest.description || null,
  165:       author: input.manifest.author || null,
  166:       status: 'installed',
  167:       enabled: false,
  168:       enabledByUserId: null,
  169:       enabledAt: null,
  170:       manifest: input.manifest as any,
  171:       tokens: input.manifest.tokens as any,
  172:       cssPath: input.manifest.css,
  173:       installPath: finalPath,
  174:       packageSha256: input.packageSha256,
  175:       installedByUserId: input.installedByUserId
  176:     },
  177:     include: {
  178:       installedBy: { select: { username: true } },
  179:       enabledBy: { select: { username: true } }
  180:     }
  181:   })
  182: }
  183: 
  184: export async function updateThemePackageConfig(themeId: string, configValues: Record<string, unknown>) {
  185:   const theme = await prisma.themePackage.findUnique({ where: { themeId } })
  186:   if (!theme) throw new Error('Theme not found')
  187:   const manifest = asThemeManifest(theme.manifest)
  188:   const normalizedConfig = normalizeThemeConfigValues(manifest.configSchema, configValues)
  189:   return await prisma.themePackage.update({
  190:     where: { themeId },
  191:     data: { configValues: normalizedConfig as any },
  192:     include: {
  193:       installedBy: { select: { username: true } },
  194:       enabledBy: { select: { username: true } }
  195:     }
  196:   })
  197: }
  198: 
  199: export async function enableThemePackage(themeId: string, userId: number) {
  200:   return await prisma.$transaction(async tx => {
  201:     const theme = await tx.themePackage.findUnique({ where: { themeId } })
  202:     if (!theme) throw new Error('Theme not found')
  203:     await tx.themePackage.updateMany({
  204:       where: { enabled: true },
  205:       data: { enabled: false, status: 'installed', enabledByUserId: null, enabledAt: null }
  206:     })
  207:     return await tx.themePackage.update({
  208:       where: { themeId },
  209:       data: {
  210:         enabled: true,
  211:         status: 'enabled',
  212:         enabledByUserId: userId,
  213:         enabledAt: new Date()
  214:       },
  215:       include: {
  216:         installedBy: { select: { username: true } },
  217:         enabledBy: { select: { username: true } }
  218:       }
  219:     })
  220:   })
  221: }
  222: 
  223: export async function rollbackDefaultTheme() {
  224:   await prisma.themePackage.updateMany({
  225:     where: { enabled: true },
  226:     data: { enabled: false, status: 'installed', enabledByUserId: null, enabledAt: null }
  227:   })
  228: }
  229: 
  230: export async function uninstallThemePackage(themeId: string) {
  231:   const theme = await prisma.themePackage.findUnique({ where: { themeId } })
  232:   if (!theme) return
  233:   if (theme.enabled) throw new Error('Enabled theme must be rolled back before uninstall')
  234:   await prisma.themePackage.delete({ where: { themeId } })
  235:   await rm(resolveThemeAsset(getThemeInstallDir(), themeId), { recursive: true, force: true })
  236: }
===== client/src/components/theme/ThemeTemplateSlot.vue =====
    1: <script setup lang="ts">
    2: import { computed, onMounted, onUnmounted, ref, watch } from 'vue'
    3: import { useThemeStore } from '@/stores/theme'
    4: import { buildApiUrl } from '@/utils/api-url'
    5: 
    6: const props = defineProps<{
    7:   slotName: string
    8:   containerClass?: string
    9: }>()
   10: 
   11: const themeStore = useThemeStore()
   12: const html = ref('')
   13: const loading = ref(false)
   14: const failed = ref(false)
   15: let controller: AbortController | null = null
   16: 
   17: const templateUrl = computed(() => themeStore.getActiveThemeTemplateUrl(props.slotName))
   18: const shouldRender = computed(() => !!templateUrl.value && !!html.value && !failed.value)
   19: 
   20: function resolveThemeTemplateUrl(url: string): string {
   21:   if (/^https?:\/\//i.test(url) || url.startsWith('/api/')) return url
   22:   return buildApiUrl(url)
   23: }
   24: 
   25: async function loadTemplate(): Promise<void> {
   26:   const url = templateUrl.value
   27:   html.value = ''
   28:   failed.value = false
   29:   if (!url) return
   30: 
   31:   controller?.abort()
   32:   controller = new AbortController()
   33:   loading.value = true
   34:   try {
   35:     const response = await fetch(resolveThemeTemplateUrl(url), {
   36:       headers: { Accept: 'text/html' },
   37:       credentials: 'include',
   38:       signal: controller.signal
   39:     })
   40:     if (!response.ok) {
   41:       failed.value = true
   42:       return
   43:     }
   44:     html.value = await response.text()
   45:   } catch (error) {
   46:     if ((error as Error).name !== 'AbortError') failed.value = true
   47:   } finally {
   48:     loading.value = false
   49:   }
   50: }
   51: 
   52: watch(templateUrl, () => {
   53:   void loadTemplate()
   54: })
   55: 
   56: onMounted(() => {
   57:   void loadTemplate()
   58: })
   59: 
   60: onUnmounted(() => {
   61:   controller?.abort()
   62: })
   63: </script>
   64: 
   65: <template>
   66:   <div
   67:     v-if="shouldRender"
   68:     :class="['theme-template-slot', containerClass]"
   69:     :data-theme-slot="slotName"
   70:     v-html="html"
   71:   />
   72: </template>

