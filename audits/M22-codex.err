  170: export async function scanThemeMarketSubmission(input: ThemeSubmissionScanInput): Promise<ThemeSubmissionScanResult> {
  171:   const findings: ThemeSubmissionScanFinding[] = []
  172:   const maxBytes = getThemePackageMaxBytes()
  173:   const scanRoot = join(getThemeStagingDir(), 'submission-scans')
  174:   await mkdir(scanRoot, { recursive: true })
  175:   const scanDir = join(scanRoot, `${input.id}-${Date.now()}-${randomUUID()}`)
  176:   await mkdir(scanDir, { recursive: true })
  177:   const packagePath = join(scanDir, 'theme.tar.gz')
  178: 
  179:   let manifest: PayIncusThemeManifest | null = null
  180:   let packageSha256: string | null = null
  181: 
  182:   try {
  183:     const [manifestBuffer, packageBuffer] = await Promise.all([
  184:       downloadBoundedHttpsFile(input.manifestUrl, 'Theme manifest URL', 1024 * 1024),
  185:       downloadBoundedHttpsFile(input.packageUrl, 'Theme package URL', maxBytes)
  186:     ])
  187: 
  188:     manifest = parseThemeManifest(JSON.parse(manifestBuffer.toString('utf8')))
  189:     compareManifestToSubmission(manifest, input, findings)
  190: 
  191:     await writeFile(packagePath, packageBuffer, { mode: 0o600 })
  192:     packageSha256 = await sha256File(packagePath)
  193:     if (packageSha256 !== input.sha256.toLowerCase()) {
  194:       pushFinding(findings, 'error', 'sha256_mismatch', `Package SHA256 ${packageSha256} does not match submitted SHA256 ${input.sha256}`)
  195:     }
  196: 
  197:     const validated = await validateAndExtractThemePackage(packagePath, input.id)
  198:     compareManifestToSubmission(validated.manifest, input, findings)
  199:     if (validated.sha256 !== packageSha256) {
  200:       pushFinding(findings, 'error', 'package_hash_inconsistent', 'Package hash changed during validation')
  201:     }
  202:     await rm(validated.stagingDir, { recursive: true, force: true }).catch(() => undefined)
  203: 
  204:     if (JSON.stringify(validated.manifest) !== JSON.stringify(manifest)) {
  205:       pushFinding(findings, 'warning', 'manifest_url_package_mismatch', 'Manifest URL content differs from package manifest')
  206:     }
  207: 
  208:     if (isRecord(input.compatibility)) {
  209:       const minPayincus = typeof input.compatibility.minPayincus === 'string' ? input.compatibility.minPayincus : ''
  210:       const maxPayincus = typeof input.compatibility.maxPayincus === 'string' ? input.compatibility.maxPayincus : ''
  211:       if (minPayincus && manifest.payincus && !manifest.payincus.includes(minPayincus)) {
  212:         pushFinding(findings, 'info', 'compatibility_declared', `Submission minPayincus ${minPayincus}; manifest payincus range ${manifest.payincus}`)
  213:       }
  214:       if (maxPayincus) {
  215:         pushFinding(findings, 'info', 'compatibility_max_declared', `Submission maxPayincus ${maxPayincus}`)
  216:       }
  217:     }
  218: 
  219:     const riskLevel = assessRisk(validated.manifest, findings)
  220:     return {
  221:       status: scanStatusFromFindings(findings),
  222:       riskLevel,
  223:       manifest: serializeManifest(validated.manifest),
  224:       packageSha256,
  225:       findings,
  226:       scannedAt: new Date().toISOString()
  227:     }
  228:   } catch (error) {
  229:     const message = error instanceof Error ? error.message : String(error)
  230:     pushFinding(findings, 'error', 'scan_failed', message)
  231:     return {
  232:       status: 'failed',
  233:       riskLevel: 'high',
  234:       manifest: manifest ? serializeManifest(manifest) : null,
  235:       packageSha256,
  236:       findings,
  237:       scannedAt: new Date().toISOString()
  238:     }
  239:   } finally {
  240:     await rm(scanDir, { recursive: true, force: true }).catch(() => undefined)
  241:   }
  242: }
