  180: async function writeThemeConfigFileUpload(request: FastifyRequest, themeId: string, key: string): Promise<{
  181:   filename: string
  182:   mimeType: string
  183:   sizeBytes: number
  184:   value: string
  185: }> {
  186:   const multipartRequest = request as FastifyRequest & {
  187:     parts: () => AsyncIterable<any>
  188:   }
  189:   const uploadDir = resolveThemeAsset(getThemeDataDir(), join('config-files', themeId, key))
  190:   await mkdir(uploadDir, { recursive: true })
  191: 
  192:   for await (const part of multipartRequest.parts()) {
  193:     if (part.type !== 'file') continue
  194:     const mimeType = String(part.mimetype || '').toLowerCase()
  195:     const ext = THEME_CONFIG_FILE_MIME_EXTENSIONS.get(mimeType)
  196:     if (!ext) {
  197:       await part.toBuffer()
  198:       throw new Error('Theme config file must be a PNG, JPEG, or WebP image')
  199:     }
  200:     const buffer = await part.toBuffer()
  201:     if (buffer.length === 0) throw new Error('Theme config file is empty')
  202:     if (buffer.length > THEME_CONFIG_FILE_MAX_BYTES) throw new Error('Theme config file exceeds 2MB')
  203:     const filename = `${Date.now()}-${randomUUID()}${ext}`
  204:     const filePath = resolveThemeAsset(uploadDir, filename)
  205:     await writeFile(filePath, buffer, { mode: 0o600 })
  206:     return {
  207:       filename,
  208:       mimeType: themeConfigFileContentType(filename),
  209:       sizeBytes: buffer.length,
  210:       value: `/api/themes/${encodeURIComponent(themeId)}/config-files/${encodeURIComponent(key)}/${encodeURIComponent(filename)}`
  211:     }
  212:   }
  213: 
  214:   throw new Error('Missing theme config file')
  215: }
