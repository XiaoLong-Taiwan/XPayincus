  346: function parseTarEntryName(line: string): string {
  347:   return line.trim().split(/\s+/).slice(5).join(' ')
  348: }
  349: 
  350: function validateTarEntryLine(line: string): void {
  351:   const trimmed = line.trim()
  352:   if (!trimmed) return
  353:   const name = parseTarEntryName(trimmed)
  354:   const type = trimmed[0]
  355:   if (!name) throw new Error('Theme package contains an unreadable tar entry')
  356:   if (type === 'l' || type === 'h') throw new Error('Theme package cannot contain links')
  357:   if (name.startsWith('/') || name.includes('../') || name === '..' || name.includes('\\')) {
  358:     throw new Error(`Theme package contains unsafe path: ${name}`)
  359:   }
  360:   if (BLOCKED_THEME_FILE_PATTERN.test(name)) {
  361:     throw new Error(`Theme package cannot contain executable or script file: ${name}`)
  362:   }
  363: }
  364: 
  365: async function validateTarball(path: string): Promise<void> {
  366:   const { stdout } = await execFileAsync('tar', ['-tvf', path], { timeout: 30000, maxBuffer: 1024 * 1024 * 4 })
  367:   const lines = stdout.split(/\r?\n/).filter(Boolean)
  368:   if (!lines.some(line => line.endsWith(' payincus.theme.json') || line.endsWith('/payincus.theme.json'))) {
  369:     throw new Error('Theme package is missing payincus.theme.json')
  370:   }
  371:   for (const line of lines) validateTarEntryLine(line)
  372: }
  373: 
  374: function assertSafeThemeCss(css: string): void {
  375:   if (/<script[\s>]/i.test(css)) throw new Error('Theme CSS cannot contain script tags')
  376:   if (/@import\s+(?:url\()?['"]?https?:\/\//i.test(css)) {
  377:     throw new Error('Theme CSS cannot import remote stylesheets')
  378:   }
  379:   if (/javascript:/i.test(css)) throw new Error('Theme CSS cannot contain javascript URLs')
  380: }
  381: 
  382: function assertSafeThemeTemplateHtml(html: string, label: string): void {
  383:   if (Buffer.byteLength(html, 'utf8') > 64 * 1024) throw new Error(`${label} exceeds 64KB`)
  384:   if (/<\s*(script|iframe|object|embed|form|input|button|textarea|select|link|meta|style)\b/i.test(html)) {
  385:     throw new Error(`${label} contains a blocked element`)
  386:   }
  387:   if (/\son[a-z]+\s*=/i.test(html)) throw new Error(`${label} contains inline event handlers`)
  388:   if (/javascript:/i.test(html)) throw new Error(`${label} contains javascript URLs`)
  389:   if (/\b(src|href)\s*=\s*["']?https?:\/\//i.test(html)) throw new Error(`${label} contains remote URLs`)
  390: }
