   47: function normalizeThemeId(value: string): string | null {
   48:   const trimmed = value.trim()
   49:   return /^[a-z][a-z0-9]*(?:\.[a-z][a-z0-9-]*){2,}$/.test(trimmed) ? trimmed : null
