  206: export default async function themeMarketSubmissionRoutes(fastify: FastifyInstance) {
  207:   fastify.post<{ Body: SubmissionBody }>('/', {
  208:     onRequest: [fastify.authenticate]
  209:   }, async (request, reply) => {
  210:     const user = getRequestUser(request)
  211: 
  212:     try {
  213:       const normalized = normalizeSubmissionBody(request.body || {})
  214:       const submission = await createThemeMarketSubmission({
  215:         ...normalized,
  216:         submittedByUserId: user.id
  217:       })
  218:       await createLog(
  219:         user.id,
  220:         LogModule.PLUGIN,
  221:         'theme.market_submission.create',
  222:         `Submitted theme market review ${normalized.themeId}@${normalized.version}`,
  223:         LogResult.SUCCESS
  224:       )
  225:       return reply.code(201).send({ submission: serializeThemeMarketSubmission(submission) })
  226:     } catch (error) {
  227:       if (error instanceof Prisma.PrismaClientKnownRequestError && error.code === 'P2002') {
  228:         return reply.code(409).send({ error: 'Theme version is already submitted', code: 'THEME_SUBMISSION_EXISTS' })
  229:       }
  230:       const message = error instanceof Error ? error.message : String(error)
  231:       return reply.code(400).send({ error: message, code: 'THEME_SUBMISSION_INVALID' })
  232:     }
  233:   })
  234: 
  235:   fastify.get('/mine', {
  236:     onRequest: [fastify.authenticate]
  237:   }, async (request) => {
  238:     const user = getRequestUser(request)
  239:     const submissions = await listMyThemeMarketSubmissions(user.id)
  240:     return { submissions: submissions.map(serializeThemeMarketSubmission) }
  241:   })
  242: 
  243:   fastify.get<{ Querystring: SubmissionQuery }>('/admin', {
  244:     onRequest: [fastify.authenticateAdmin]
  245:   }, async (request, reply) => {
  246:     if (!(await requireThemeMarketReviewer(request, reply))) return
  247:     let reviewStatus: ThemeMarketSubmissionReviewStatus | undefined
  248:     if (request.query.reviewStatus) {
  249:       const normalizedReviewStatus = normalizeReviewStatus(request.query.reviewStatus)
  250:       if (!normalizedReviewStatus) return reply.code(400).send({ error: 'Invalid review status', code: 'INVALID_REVIEW_STATUS' })
  251:       reviewStatus = normalizedReviewStatus
  252:     }
  253:     const submissions = await listThemeMarketSubmissions({
  254:       reviewStatus,
  255:       limit: parseLimit(request.query.limit)
  256:     })
  257:     return { submissions: submissions.map(serializeThemeMarketSubmission) }
