   58: 
   59: function getRequestUser(request: FastifyRequest): { id: number; username: string; role: 'admin' | 'user' } {
   60:   return request.user as { id: number; username: string; role: 'admin' | 'user' }
   61: }
   62: 
   63: async function canManageThemeMarketSubmissions(user: { id: number; username: string; role: 'admin' | 'user' }): Promise<boolean> {
   64:   if (user.role !== 'admin') return false
   65:   const themeAllowlist = await getCombinedAdminIdAllowlist(
   66:     'theme_manager_allowed_admin_ids',
   67:     'THEME_MANAGER_ALLOWED_ADMIN_IDS'
   68:   )
   69:   const pluginAllowlist = await getCombinedAdminIdAllowlist(
   70:     'plugin_manager_allowed_admin_ids',
   71:     ['PLUGIN_MANAGER_ALLOWED_ADMIN_IDS', 'SYSTEM_UPDATE_ALLOWED_ADMIN_IDS']
   72:   )
   73:   const allowedIds = new Set([...themeAllowlist.ids, ...pluginAllowlist.ids])
   74:   if (allowedIds.size > 0) return allowedIds.has(user.id)
   75:   return user.username === 'admin'
   76: }
   77: 
   78: async function requireThemeMarketReviewer(request: FastifyRequest, reply: FastifyReply): Promise<boolean> {
   79:   const user = getRequestUser(request)
   80:   if (!(await canManageThemeMarketSubmissions(user))) {
   81:     await createLog(
   82:       user.id,
   83:       LogModule.PLUGIN,
   84:       'theme.market_submission.review_denied',
   85:       `Denied theme market submission review access for ${user.username}`,
   86:       LogResult.WARNING
   87:     )
   88:     reply.code(403).send({ error: 'Super administrator privileges required', code: 'SUPER_ADMIN_REQUIRED' })
   89:     return false
   90:   }
   91:   return true
   92: }
   93: 
   94: function normalizeText(value: unknown, maxLength: number): string | null {
   95:   if (typeof value !== 'string') return null
   96:   const trimmed = value.trim()
   97:   if (!trimmed || trimmed.length > maxLength) return null
   98:   return trimmed
   99: }
  100: 
  101: function normalizeOptionalText(value: unknown, maxLength: number): string | null {
  102:   if (value === undefined || value === null || value === '') return null
  103:   return normalizeText(value, maxLength)
  104: }
  105: 
  106: function normalizeHttpsUrl(value: unknown): string | null {
  107:   const text = normalizeText(value, 2048)
  108:   if (!text) return null
  109:   try {
  110:     const url = new URL(text)
  111:     if (url.protocol !== 'https:') return null
  112:     return url.toString()
  113:   } catch {
  114:     return null
  115:   }
  116: }
  117: 
  118: function normalizeOptionalHttpsUrl(value: unknown): string | null {
  119:   if (value === undefined || value === null || value === '') return null
  120:   return normalizeHttpsUrl(value)
  121: }
  122: 
  123: function normalizeJsonRecord(value: unknown): Record<string, unknown> {
  124:   return value && typeof value === 'object' && !Array.isArray(value)
  125:     ? value as Record<string, unknown>
  126:     : {}
  127: }
  128: 
  129: function normalizeStringArray(value: unknown, maxItems = 80, maxLength = 120): string[] {
  130:   if (!Array.isArray(value)) return []
  131:   return Array.from(new Set(
  132:     value
  133:       .slice(0, maxItems)
  134:       .map(item => typeof item === 'string' ? item.trim() : '')
  135:       .filter(item => item && item.length <= maxLength)
  136:   ))
  137: }
  138: 
  139: function normalizeSubmissionBody(body: SubmissionBody) {
  140:   const themeId = normalizeText(body.themeId, 120)
  141:   const version = normalizeText(body.version, 64)
  142:   const name = normalizeText(body.name, 120)
  143:   const repoUrl = normalizeHttpsUrl(body.repoUrl)
  144:   const releaseUrl = normalizeHttpsUrl(body.releaseUrl)
  145:   const manifestUrl = normalizeHttpsUrl(body.manifestUrl)
  146:   const packageUrl = normalizeHttpsUrl(body.packageUrl)
  147:   const sha256 = normalizeText(body.sha256, 64)?.toLowerCase() ?? null
  148:   const developerName = normalizeText(body.developerName, 120)
  149:   const contactEmail = normalizeText(body.contactEmail, 254)
  150:   const developerHomepage = normalizeOptionalHttpsUrl(body.developerHomepage)
  151:   const developerGithub = normalizeOptionalHttpsUrl(body.developerGithub)
  152:   const notes = normalizeOptionalText(body.notes, 5000)
  153: 
  154:   if (!themeId || !THEME_ID_PATTERN.test(themeId)) throw new Error('Invalid theme id')
  155:   if (!version || !VERSION_PATTERN.test(version)) throw new Error('Invalid theme version')
  156:   if (!name) throw new Error('Invalid theme name')
  157:   if (!repoUrl || !releaseUrl || !manifestUrl || !packageUrl) throw new Error('Submission URLs must be HTTPS')
  158:   if (!sha256 || !SHA256_PATTERN.test(sha256)) throw new Error('Invalid package SHA256')
  159:   if (!developerName) throw new Error('Invalid developer name')
  160:   if (!contactEmail || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(contactEmail)) throw new Error('Invalid contact email')
  161: 
  162:   return {
  163:     themeId,
  164:     version,
  165:     name,
  166:     repoUrl,
  167:     releaseUrl,
  168:     manifestUrl,
  169:     packageUrl,
  170:     sha256,
  171:     developerName,
  172:     developerHomepage,
  173:     developerGithub,
  174:     contactEmail,
  175:     compatibility: normalizeJsonRecord(body.compatibility),
  176:     tokens: normalizeStringArray(body.tokens),
  177:     layoutSlots: normalizeStringArray(body.layoutSlots),
  178:     notes
  179:   }
  180: }
  181: 
  182: function parsePositiveId(value: string): number | null {
  183:   if (!/^[1-9]\d*$/.test(value)) return null
  184:   const parsed = Number(value)
  185:   return Number.isSafeInteger(parsed) ? parsed : null
  186: }
  187: 
  188: function parseLimit(value: string | undefined): number {
  189:   if (!value || !/^[1-9]\d*$/.test(value)) return 100
  190:   const parsed = Number(value)
  191:   return Number.isSafeInteger(parsed) ? Math.min(parsed, 200) : 100
  192: }
  193: 
  194: function normalizeReviewStatus(value: unknown): ThemeMarketSubmissionReviewStatus | null {
  195:   return typeof value === 'string' && REVIEW_STATUSES.includes(value as ThemeMarketSubmissionReviewStatus)
  196:     ? value as ThemeMarketSubmissionReviewStatus
  197:     : null
  198: }
  199: 
  200: function normalizeRiskLevel(value: unknown): ThemeMarketSubmissionRiskLevel | null {
  201:   return typeof value === 'string' && RISK_LEVELS.includes(value as ThemeMarketSubmissionRiskLevel)
  202:     ? value as ThemeMarketSubmissionRiskLevel
  203:     : null
  204: }
