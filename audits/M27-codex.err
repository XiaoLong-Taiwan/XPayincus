1448:     await createLog(
1449:       apiToken.userId,
1450:       LogModule.PLUGIN,
1451:       'public_api.balance_adjustment_request_create',
1452:       `Public API ${apiToken.source} created pending balance adjustment request #${adjustmentRequest.id}`,
1453:       LogResult.SUCCESS
1454:     )
