  62: requireText(config, "const siteOrigin = 'https://payincus.com'", 'VitePress config')
  63: requireText(config, 'transformHead({ pageData })', 'VitePress config')
  64: requireText(config, 'hostname: siteOrigin', 'VitePress config')
  65: 
  66: const changelogGenerator = read('docs-site/scripts/generate-changelog.mjs')
  67: requireText(changelogGenerator, "--format=%H%x09%cs%x09%s", 'changelog generator')
  68: requireText(changelogGenerator, 'fullHash.slice(0, 9)', 'changelog generator')
  69: requireText(changelogGenerator, 'normalizeEmbeddedReleaseNoteHeadings', 'changelog generator')
  70: 
  71: const cname = read('docs-site/docs/public/CNAME').trim()
  72: if (cname !== 'payincus.com') {
  73:   throw new Error(`CNAME must be payincus.com, received ${JSON.stringify(cname)}`)
  74: }
  75: 
  76: const robots = read('docs-site/docs/public/robots.txt')
  77: requireText(robots, 'Sitemap: https://payincus.com/sitemap.xml', 'robots.txt')
