===== scripts/verify-log-header-exposure.sh =====
   1: #!/usr/bin/env bash
   2: set -Eeuo pipefail
   3: 
   4: ENV_FILE="${ENV_FILE:-.env}"
   5: FRONTEND_URL="${FRONTEND_URL:-}"
   6: BACKEND_URL="${BACKEND_URL:-}"
   7: JOURNAL_UNIT="${JOURNAL_UNIT:-incudal-backend}"
   8: JOURNAL_SINCE="${JOURNAL_SINCE:-24 hours ago}"
   9: LOG_SCAN_FILES="${LOG_SCAN_FILES:-/var/log/nginx/access.log /var/log/nginx/error.log}"
  10: SECRET_SCAN_KEYS="${SECRET_SCAN_KEYS:-ADMIN_PASSWORD JWT_SECRET COOKIE_SECRET ENCRYPTION_KEY DATABASE_URL INCUDAL_AGENT_RELEASE_TOKEN}"
  11: 
  12: log() {
  13:   printf '[verify-log-header] %s\n' "$*"
  14: }
  15: 
  16: fail() {
  17:   printf '[verify-log-header] ERROR: %s\n' "$*" >&2
  18:   exit 1
  19: }
  20: 
  21: require_command() {
  22:   command -v "$1" >/dev/null 2>&1 || fail "Missing command: $1"
  23: }
  24: 
  25: trim_slash() {
  26:   local value="$1"
  27:   printf '%s' "${value%/}"
  28: }
  29: 
  30: env_file_value() {
  31:   local key="$1"
  32:   local line value
  33: 
  34:   if [[ ! -f "$ENV_FILE" ]]; then
  35:     return 0
  36:   fi
  37: 
  38:   line="$(
  39:     grep -E "^[[:space:]]*(export[[:space:]]+)?${key}=" "$ENV_FILE" 2>/dev/null \
  40:       | tail -n 1 \
  41:       || true
  42:   )"
  43:   [[ -n "$line" ]] || return 0
  44: 
  45:   line="${line#"${line%%[![:space:]]*}"}"
  46:   line="${line#export }"
  47:   value="${line#*=}"
  48:   value="${value%%#*}"
  49:   value="${value%"${value##*[![:space:]]}"}"
  50:   value="${value%\"}"
  51:   value="${value#\"}"
  52:   value="${value%\'}"
  53:   value="${value#\'}"
  54:   printf '%s' "$value"
  55: }
  56: 
  57: config_value() {
  58:   local key="$1"
  59:   local env_value="${!key:-}"
  60:   if [[ -n "$env_value" ]]; then
  61:     printf '%s' "$env_value"
  62:     return 0
  63:   fi
  64:   env_file_value "$key"
  65: }
  66: 
  67: assert_header() {
  68:   local headers="$1"
  69:   local header="$2"
  70:   local pattern="$3"
  71: 
  72:   tr -d '\r' < "$headers" | grep -Eiq "^${header}:[[:space:]]*${pattern}" \
  73:     || fail "frontend response missing expected header: ${header}"
  74: }
  75: 
  76: require_command curl
  77: require_command grep
  78: 
  79: FRONTEND_URL="$(trim_slash "${FRONTEND_URL:-$(config_value FRONTEND_URL)}")"
  80: BACKEND_URL="$(trim_slash "${BACKEND_URL:-$(config_value BACKEND_URL)}")"
  81: PORT_VALUE="$(config_value PORT)"
  82: 
  83: [[ -n "$FRONTEND_URL" ]] || fail "FRONTEND_URL is required"
  84: if [[ -z "$BACKEND_URL" ]]; then
  85:   BACKEND_URL="http://127.0.0.1:${PORT_VALUE:-3001}"
  86: fi
  87: 
  88: tmp_dir="$(mktemp -d)"
  89: trap 'rm -rf "$tmp_dir"' EXIT
  90: 
  91: log "Checking frontend headers: ${FRONTEND_URL}/"
  92: curl -fsS --max-time 15 -D "$tmp_dir/frontend.headers" "$FRONTEND_URL/" -o "$tmp_dir/frontend.html" \
  93:   || fail "frontend header check failed: ${FRONTEND_URL}/"
  94: assert_header "$tmp_dir/frontend.headers" "content-security-policy" ".*default-src 'self'.*frame-ancestors 'none'"
  95: assert_header "$tmp_dir/frontend.headers" "x-content-type-options" "nosniff"
  96: assert_header "$tmp_dir/frontend.headers" "x-frame-options" "DENY"
  97: assert_header "$tmp_dir/frontend.headers" "referrer-policy" "strict-origin-when-cross-origin"
  98: 
  99: log "Checking backend does not serve frontend HTML: ${BACKEND_URL}/"
 100: backend_status="$(
 101:   curl -sS --max-time 10 -w '%{http_code}' "$BACKEND_URL/" -o "$tmp_dir/backend-root.txt" \
 102:     || true
 103: )"
 104: if [[ "$backend_status" == "200" ]] && grep -Eiq '<div id="?app"?|<!doctype html' "$tmp_dir/backend-root.txt"; then
 105:   fail "backend root served frontend HTML; SERVE_STATIC_CLIENT may be enabled"
 106: fi
 107: 
 108: log "Scanning logs without printing secret values"
 109: log_bundle="$tmp_dir/log-bundle.txt"
 110: : > "$log_bundle"
 111: if command -v journalctl >/dev/null 2>&1; then
 112:   journalctl -u "$JOURNAL_UNIT" --since "$JOURNAL_SINCE" --no-pager -o cat >> "$log_bundle" 2>/dev/null || true
 113: fi
 114: for file in $LOG_SCAN_FILES; do
 115:   if [[ -r "$file" ]]; then
 116:     cat "$file" >> "$log_bundle" 2>/dev/null || true
 117:   fi
 118: done
 119: 
 120: for key in $SECRET_SCAN_KEYS; do
 121:   value="$(config_value "$key")"
 122:   if [[ -n "$value" && "${#value}" -ge 8 ]]; then
 123:     if grep -Fq -- "$value" "$log_bundle"; then
 124:       fail "log output contains the current value of ${key}"
 125:     fi
 126:     log "Secret value not found in logs: ${key}"
 127:   else
 128:     log "Secret value skipped because empty or short: ${key}"
 129:   fi
 130: done
 131: 
 132: if grep -Eiq '(ADMIN_PASSWORD=|JWT_SECRET=|COOKIE_SECRET=|ENCRYPTION_KEY=|DATABASE_URL=postgresql://|refreshToken=|Bearer [A-Za-z0-9_-]{12,}|merchantPrivateKey|merchant_private_key|smtpPassword|botToken|webhookSecret)' "$log_bundle"; then
 133:   fail "log output contains a sensitive-looking token, credential assignment, or secret field"
 134: fi
 135: 
 136: log "Log/header exposure verification passed"
===== scripts/verify-production-readiness.sh =====
   1: #!/usr/bin/env bash
   2: set -Eeuo pipefail
   3: 
   4: ENV_FILE="${ENV_FILE:-.env}"
   5: RUN_LIVE_CHECKS="${RUN_LIVE_CHECKS:-1}"
   6: RUN_DB_CHECKS="${RUN_DB_CHECKS:-$RUN_LIVE_CHECKS}"
   7: ALLOW_MISSING_AGENT_RELEASE="${ALLOW_MISSING_AGENT_RELEASE:-false}"
   8: 
   9: log() {
  10:   printf '[verify-production] %s\n' "$*"
  11: }
  12: 
  13: warn() {
  14:   printf '[verify-production] WARN: %s\n' "$*" >&2
  15: }
  16: 
  17: fail() {
  18:   printf '[verify-production] ERROR: %s\n' "$*" >&2
  19:   exit 1
  20: }
  21: 
  22: require_command() {
  23:   command -v "$1" >/dev/null 2>&1 || fail "Missing command: $1"
  24: }
  25: 
  26: trim_slash() {
  27:   local value="$1"
  28:   printf '%s' "${value%/}"
  29: }
  30: 
  31: env_file_value() {
  32:   local key="$1"
  33:   local line value
  34: 
  35:   if [[ ! -f "$ENV_FILE" ]]; then
  36:     return 0
  37:   fi
  38: 
  39:   line="$(
  40:     grep -E "^[[:space:]]*(export[[:space:]]+)?${key}=" "$ENV_FILE" 2>/dev/null \
  41:       | tail -n 1 \
  42:       || true
  43:   )"
  44:   [[ -n "$line" ]] || return 0
  45: 
  46:   line="${line#"${line%%[![:space:]]*}"}"
  47:   line="${line#export }"
  48:   value="${line#*=}"
  49:   value="${value%%#*}"
  50:   value="${value%"${value##*[![:space:]]}"}"
  51:   value="${value%\"}"
  52:   value="${value#\"}"
  53:   value="${value%\'}"
  54:   value="${value#\'}"
  55:   printf '%s' "$value"
  56: }
  57: 
  58: config_value() {
  59:   local key="$1"
  60:   local env_value="${!key:-}"
  61:   if [[ -n "$env_value" ]]; then
  62:     printf '%s' "$env_value"
  63:     return 0
  64:   fi
  65:   env_file_value "$key"
  66: }
  67: 
  68: require_value() {
  69:   local key="$1"
  70:   local value="$2"
  71:   [[ -n "$value" ]] || fail "${key} is required"
  72: }
  73: 
  74: require_equals() {
  75:   local key="$1"
  76:   local actual="$2"
  77:   local expected="$3"
  78:   [[ "$actual" == "$expected" ]] || fail "${key} must be ${expected}, got ${actual:-<empty>}"
  79: }
  80: 
  81: require_sha256() {
  82:   local key="$1"
  83:   local value="$2"
  84:   [[ "$value" =~ ^[A-Fa-f0-9]{64}$ ]] || fail "${key} must be a 64-character hex sha256"
  85: }
  86: 
  87: validate_http_url() {
  88:   local key="$1"
  89:   local value="$2"
  90:   node - "$key" "$value" <<'NODE'
  91: const [key, value] = process.argv.slice(2)
  92: let url
  93: try {
  94:   url = new URL(value)
  95: } catch {
  96:   console.error(`${key} must be a valid URL`)
  97:   process.exit(1)
  98: }
  99: if (url.protocol !== 'http:' && url.protocol !== 'https:') {
 100:   console.error(`${key} must use HTTP(S)`)
 101:   process.exit(1)
 102: }
 103: NODE
 104: }
 105: 
 106: validate_https_public_url() {
 107:   local key="$1"
 108:   local value="$2"
 109:   node - "$key" "$value" <<'NODE'
 110: const net = require('node:net')
 111: const [key, value] = process.argv.slice(2)
 112: let url
 113: try {
 114:   url = new URL(value)
 115: } catch {
 116:   console.error(`${key} must be a valid URL`)
 117:   process.exit(1)
 118: }
 119: if (url.protocol !== 'https:') {
 120:   console.error(`${key} must use HTTPS in production`)
 121:   process.exit(1)
 122: }
 123: const host = url.hostname.toLowerCase()
 124: if (!host || host === 'localhost' || host.endsWith('.localhost') || !host.includes('.')) {
 125:   console.error(`${key} must use a browser-accessible public hostname`)
 126:   process.exit(1)
 127: }
 128: const ipVersion = net.isIP(host)
 129: if (ipVersion === 4) {
 130:   const parts = host.split('.').map(Number)
 131:   const privateIp = parts[0] === 10 ||
 132:     parts[0] === 127 ||
 133:     (parts[0] === 169 && parts[1] === 254) ||
 134:     (parts[0] === 172 && parts[1] >= 16 && parts[1] <= 31) ||
 135:     (parts[0] === 192 && parts[1] === 168)
 136:   if (privateIp) {
 137:     console.error(`${key} must not use a private or loopback IP in production`)
 138:     process.exit(1)
 139:   }
 140: }
 141: if (ipVersion === 6) {
 142:   const normalized = host.replace(/^\[/, '').replace(/\]$/, '')
 143:   if (normalized === '::1' || normalized.startsWith('fc') || normalized.startsWith('fd') || normalized.startsWith('fe80:')) {
 144:     console.error(`${key} must not use a private or loopback IPv6 address in production`)
 145:     process.exit(1)
 146:   }
 147: }
 148: NODE
 149: }
 150: 
 151: validate_ip_whitelist() {
 152:   local value="$1"
 153:   node - "$value" <<'NODE'
 154: const net = require('node:net')
 155: const value = process.argv[2] || ''
 156: const ips = value.split(',').map(ip => ip.trim()).filter(Boolean)
 157: for (const ip of ips) {
 158:   const normalized = ip.startsWith('::ffff:') ? ip.slice(7) : ip
 159:   if (net.isIP(normalized) === 0) {
 160:     console.error(`PAYMENT_CALLBACK_IP_WHITELIST contains an invalid IP: ${ip}`)
 161:     process.exit(1)
 162:   }
 163: }
 164: NODE
 165: }
 166: 
 167: require_command node
 168: require_command curl
 169: 
 170: NODE_ENV_VALUE="$(config_value NODE_ENV)"
 171: PORT_VALUE="$(config_value PORT)"
 172: SERVE_STATIC_CLIENT_VALUE="$(config_value SERVE_STATIC_CLIENT)"
 173: VITE_API_BASE_URL_VALUE="$(config_value VITE_API_BASE_URL)"
 174: TRUST_PROXY_VALUE="$(config_value TRUST_PROXY)"
 175: FRONTEND_URL_VALUE="$(trim_slash "$(config_value FRONTEND_URL)")"
 176: ADMIN_FRONTEND_URL_VALUE="$(trim_slash "$(config_value ADMIN_FRONTEND_URL)")"
 177: SITE_URL_VALUE="$(trim_slash "$(config_value SITE_URL)")"
 178: PAYMENT_CALLBACK_BASE_URL_VALUE="$(trim_slash "$(config_value PAYMENT_CALLBACK_BASE_URL)")"
 179: PAYMENT_CALLBACK_IP_WHITELIST_VALUE="$(config_value PAYMENT_CALLBACK_IP_WHITELIST)"
 180: PAYMENT_CALLBACK_IP_WHITELIST_REQUIRED_VALUE="$(config_value PAYMENT_CALLBACK_IP_WHITELIST_REQUIRED)"
 181: PAYMENT_CALLBACK_SKIP_IP_WHITELIST_VALUE="$(config_value PAYMENT_CALLBACK_SKIP_IP_WHITELIST)"
 182: COOKIE_DOMAIN_VALUE="$(config_value COOKIE_DOMAIN)"
 183: BACKEND_URL_VALUE="$(trim_slash "${BACKEND_URL:-$(config_value BACKEND_URL)}")"
 184: AGENT_RELEASE_REPOSITORY_VALUE="$(config_value INCUDAL_AGENT_RELEASE_REPOSITORY)"
 185: AGENT_RELEASE_DIR_VALUE="$(config_value INCUDAL_AGENT_RELEASE_DIR)"
 186: AGENT_BINARY_URL_VALUE="$(config_value INCUDAL_AGENT_BINARY_URL)"
 187: AGENT_BINARY_SHA256_VALUE="$(config_value INCUDAL_AGENT_BINARY_SHA256)"
 188: 
 189: require_equals NODE_ENV "$NODE_ENV_VALUE" production
 190: require_equals PORT "$PORT_VALUE" 3001
 191: require_equals SERVE_STATIC_CLIENT "$SERVE_STATIC_CLIENT_VALUE" false
 192: require_equals VITE_API_BASE_URL "$VITE_API_BASE_URL_VALUE" /api
 193: require_equals TRUST_PROXY "$TRUST_PROXY_VALUE" true
 194: 
 195: require_value FRONTEND_URL "$FRONTEND_URL_VALUE"
 196: require_value ADMIN_FRONTEND_URL "$ADMIN_FRONTEND_URL_VALUE"
 197: require_value SITE_URL "$SITE_URL_VALUE"
 198: require_value PAYMENT_CALLBACK_BASE_URL "$PAYMENT_CALLBACK_BASE_URL_VALUE"
 199: validate_https_public_url FRONTEND_URL "$FRONTEND_URL_VALUE"
 200: validate_https_public_url ADMIN_FRONTEND_URL "$ADMIN_FRONTEND_URL_VALUE"
 201: validate_https_public_url SITE_URL "$SITE_URL_VALUE"
 202: validate_https_public_url PAYMENT_CALLBACK_BASE_URL "$PAYMENT_CALLBACK_BASE_URL_VALUE"
 203: 
 204: if [[ "$ADMIN_FRONTEND_URL_VALUE" == "$FRONTEND_URL_VALUE" ]]; then
 205:   fail "ADMIN_FRONTEND_URL must be a separate admin frontend origin"
 206: fi
 207: if [[ -n "$COOKIE_DOMAIN_VALUE" ]]; then
 208:   fail "COOKIE_DOMAIN must stay empty so customer and admin subdomains do not share refresh cookies"
 209: fi
 210: if [[ "$SITE_URL_VALUE" != "$FRONTEND_URL_VALUE" ]]; then
 211:   warn "SITE_URL differs from FRONTEND_URL; verify OAuth and public links intentionally use ${SITE_URL_VALUE}"
 212: fi
 213: if [[ "$PAYMENT_CALLBACK_BASE_URL_VALUE" != "$FRONTEND_URL_VALUE" ]]; then
 214:   warn "PAYMENT_CALLBACK_BASE_URL differs from FRONTEND_URL; verify the payment provider can reach ${PAYMENT_CALLBACK_BASE_URL_VALUE}"
 215: fi
 216: require_equals PAYMENT_CALLBACK_SKIP_IP_WHITELIST "$PAYMENT_CALLBACK_SKIP_IP_WHITELIST_VALUE" false
 217: if [[ -n "$PAYMENT_CALLBACK_IP_WHITELIST_VALUE" ]]; then
 218:   validate_ip_whitelist "$PAYMENT_CALLBACK_IP_WHITELIST_VALUE"
 219: elif [[ "$PAYMENT_CALLBACK_IP_WHITELIST_REQUIRED_VALUE" == "false" ]]; then
 220:   log "PAYMENT_CALLBACK_IP_WHITELIST is intentionally empty; callbacks still require signature/status/amount/idempotency checks"
 221: else
 222:   warn "PAYMENT_CALLBACK_IP_WHITELIST is empty; callbacks still require signature/status/amount/idempotency checks, but provider source IPs should be configured when available"
 223: fi
 224: 
 225: if [[ -n "$AGENT_BINARY_URL_VALUE" || -n "$AGENT_BINARY_SHA256_VALUE" ]]; then
 226:   require_value INCUDAL_AGENT_BINARY_URL "$AGENT_BINARY_URL_VALUE"
 227:   require_value INCUDAL_AGENT_BINARY_SHA256 "$AGENT_BINARY_SHA256_VALUE"
 228:   validate_http_url INCUDAL_AGENT_BINARY_URL "$AGENT_BINARY_URL_VALUE"
 229:   require_sha256 INCUDAL_AGENT_BINARY_SHA256 "$AGENT_BINARY_SHA256_VALUE"
 230: elif [[ -n "$AGENT_RELEASE_DIR_VALUE" ]]; then
 231:   [[ "$AGENT_RELEASE_DIR_VALUE" == /* ]] || fail "INCUDAL_AGENT_RELEASE_DIR must be an absolute path"
 232: elif [[ -z "$AGENT_RELEASE_REPOSITORY_VALUE" ]]; then
 233:   fail "INCUDAL_AGENT_RELEASE_REPOSITORY or INCUDAL_AGENT_RELEASE_DIR is required unless INCUDAL_AGENT_BINARY_URL and INCUDAL_AGENT_BINARY_SHA256 are configured"
 234: fi
 235: 
 236: log "Static production environment checks passed"
 237: 
 238: if [[ "$RUN_DB_CHECKS" == "1" ]]; then
 239:   log "Running production database readiness checks"
 240:   ENV_FILE="$ENV_FILE" pnpm --filter server verify:production-db
 241: else
 242:   log "Database checks skipped because RUN_DB_CHECKS=${RUN_DB_CHECKS}"
 243: fi
 244: 
 245: if [[ "$RUN_LIVE_CHECKS" != "1" ]]; then
 246:   log "Live checks skipped because RUN_LIVE_CHECKS=${RUN_LIVE_CHECKS}"
 247:   exit 0
 248: fi
 249: 
 250: if [[ -z "$BACKEND_URL_VALUE" ]]; then
 251:   BACKEND_URL_VALUE="http://127.0.0.1:${PORT_VALUE}"
 252: fi
 253: 
 254: FRONTEND_URL="$FRONTEND_URL_VALUE" ADMIN_FRONTEND_URL="$ADMIN_FRONTEND_URL_VALUE" BACKEND_URL="$BACKEND_URL_VALUE" bash scripts/verify-split-host.sh
 255: 
 256: if [[ -z "$AGENT_BINARY_URL_VALUE" ]]; then
 257:   manifest_body="$(mktemp)"
 258:   manifest_headers="$(mktemp)"
 259:   trap 'rm -f "$manifest_body" "$manifest_headers"' EXIT
 260:   manifest_status="$(
 261:     curl -sS --max-time 15 \
 262:       -H 'Accept: application/json' \
 263:       -D "$manifest_headers" \
 264:       -o "$manifest_body" \
 265:       -w '%{http_code}' \
 266:       "${FRONTEND_URL_VALUE}/api/agent/manifest.json" \
 267:       || true
 268:   )"
 269: 
 270:   if [[ "$manifest_status" == "404" && "$ALLOW_MISSING_AGENT_RELEASE" == "true" ]]; then
 271:     warn "Agent manifest returned 404, allowed by ALLOW_MISSING_AGENT_RELEASE=true"
 272:   elif [[ "$manifest_status" != "200" ]]; then
 273:     fail "Agent manifest must return 200 before production Agent install, got HTTP ${manifest_status}"
 274:   else
 275:     node - "$manifest_body" <<'NODE'
 276: const fs = require('node:fs')
 277: const manifest = JSON.parse(fs.readFileSync(process.argv[2], 'utf8'))
 278: const sha256Pattern = /^[a-f0-9]{64}$/i
 279: if (!manifest.version || !manifest.files) {
 280:   console.error('Agent manifest must include version and files')
 281:   process.exit(1)
 282: }
 283: for (const platform of ['linux-amd64', 'linux-arm64']) {
 284:   const file = manifest.files[platform]
 285:   if (!file || !file.name || !sha256Pattern.test(file.sha256 || '')) {
 286:     console.error(`Agent manifest must include ${platform} name and sha256`)
 287:     process.exit(1)
 288:   }
 289: }
 290: NODE
 291:     log "Agent manifest check passed"
 292:   fi
 293: else
 294:   log "Agent manifest check skipped because INCUDAL_AGENT_BINARY_URL is configured"
 295: fi
 296: 
 297: log "Production readiness verification passed"
===== scripts/verify-split-host.sh =====
   1: #!/usr/bin/env bash
   2: set -Eeuo pipefail
   3: 
   4: FRONTEND_URL="${FRONTEND_URL:-http://127.0.0.1}"
   5: ADMIN_FRONTEND_URL="${ADMIN_FRONTEND_URL:-}"
   6: BACKEND_URL="${BACKEND_URL:-http://127.0.0.1:3001}"
   7: VERIFY_RETRIES="${VERIFY_RETRIES:-8}"
   8: VERIFY_RETRY_DELAY="${VERIFY_RETRY_DELAY:-2}"
   9: 
  10: trim_slash() {
  11:   local value="$1"
  12:   printf '%s' "${value%/}"
  13: }
  14: 
  15: log() {
  16:   printf '[verify-split-host] %s\n' "$*"
  17: }
  18: 
  19: fail() {
  20:   printf '[verify-split-host] ERROR: %s\n' "$*" >&2
  21:   exit 1
  22: }
  23: 
  24: require_command() {
  25:   command -v "$1" >/dev/null 2>&1 || fail "Missing command: $1"
  26: }
  27: 
  28: fetch_url() {
  29:   local name="$1"
  30:   local url="$2"
  31:   local output="$3"
  32:   local error_output="${output}.err"
  33:   local attempt=1
  34:   local status
  35: 
  36:   log "Checking $name: $url"
  37:   while true; do
  38:     rm -f "$output" "$error_output"
  39:     set +e
  40:     curl -fsS --max-time 10 "$url" -o "$output" 2> "$error_output"
  41:     status=$?
  42:     set -e
  43: 
  44:     if [[ "$status" -eq 0 ]]; then
  45:       return 0
  46:     fi
  47: 
  48:     if [[ "$attempt" -ge "$VERIFY_RETRIES" ]]; then
  49:       fail "$name check failed: $url ($(tr '\n' ' ' < "$error_output"))"
  50:     fi
  51: 
  52:     log "$name check attempt ${attempt}/${VERIFY_RETRIES} failed; retrying in ${VERIFY_RETRY_DELAY}s"
  53:     sleep "$VERIFY_RETRY_DELAY"
  54:     attempt=$((attempt + 1))
  55:   done
  56: }
  57: 
  58: fetch_url_with_headers() {
  59:   local name="$1"
  60:   local url="$2"
  61:   local output="$3"
  62:   local headers="$4"
  63:   local error_output="${output}.err"
  64:   local attempt=1
  65:   local status
  66: 
  67:   log "Checking $name: $url"
  68:   while true; do
  69:     rm -f "$output" "$headers" "$error_output"
  70:     set +e
  71:     curl -fsS --max-time 10 -D "$headers" "$url" -o "$output" 2> "$error_output"
  72:     status=$?
  73:     set -e
  74: 
  75:     if [[ "$status" -eq 0 ]]; then
  76:       return 0
  77:     fi
  78: 
  79:     if [[ "$attempt" -ge "$VERIFY_RETRIES" ]]; then
  80:       fail "$name check failed: $url ($(tr '\n' ' ' < "$error_output"))"
  81:     fi
  82: 
  83:     log "$name check attempt ${attempt}/${VERIFY_RETRIES} failed; retrying in ${VERIFY_RETRY_DELAY}s"
  84:     sleep "$VERIFY_RETRY_DELAY"
  85:     attempt=$((attempt + 1))
  86:   done
  87: }
  88: 
  89: fetch_static_asset() {
  90:   local asset_path="$1"
  91:   local output="$2"
  92: 
  93:   if [[ "$asset_path" != /* ]]; then
  94:     return 0
  95:   fi
  96: 
  97:   case "$asset_path" in
  98:     *.js|*.css)
  99:       fetch_url "frontend static asset" "${FRONTEND_URL}${asset_path}" "$output"
 100:       ;;
 101:     *)
 102:       return 0
 103:       ;;
 104:   esac
 105: }
 106: 
 107: fetch_websocket_probe() {
 108:   local name="$1"
 109:   local url="$2"
 110:   local output="$3"
 111:   local error_output="$4"
 112:   local status
 113: 
 114:   log "Checking $name: $url"
 115:   set +e
 116:   curl --http1.1 -sS -i -N --max-time 10 \
 117:     -H "Connection: Upgrade" \
 118:     -H "Upgrade: websocket" \
 119:     -H "Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==" \
 120:     -H "Sec-WebSocket-Version: 13" \
 121:     -H "Origin: ${FRONTEND_URL}" \
 122:     "$url" > "$output" 2> "$error_output"
 123:   status=$?
 124:   set -e
 125: 
 126:   if [[ "$status" -ne 0 && "$status" -ne 28 ]]; then
 127:     fail "$name WebSocket probe failed: $(tr '\n' ' ' < "$error_output")"
 128:   fi
 129: }
 130: 
 131: assert_header() {
 132:   local headers="$1"
 133:   local header="$2"
 134:   local pattern="$3"
 135: 
 136:   tr -d '\r' < "$headers" | grep -Eiq "^${header}:[[:space:]]*${pattern}" \
 137:     || fail "frontend index missing expected header: ${header}"
 138: }
 139: 
 140: assert_no_frontend_backend_origin_leaks() {
 141:   local file="$1"
 142:   local name="$2"
 143: 
 144:   if grep -Eq 'https?://(localhost|127\.0\.0\.1):(3001|8888|43173)\b|VITE_API_BASE_URL' "$file"; then
 145:     fail "${name} contains a hardcoded backend/dev API origin"
 146:   fi
 147: }
 148: 
 149: require_command curl
 150: 
 151: FRONTEND_URL="$(trim_slash "$FRONTEND_URL")"
 152: ADMIN_FRONTEND_URL="$(trim_slash "$ADMIN_FRONTEND_URL")"
 153: BACKEND_URL="$(trim_slash "$BACKEND_URL")"
 154: 
 155: tmp_dir="$(mktemp -d)"
 156: trap 'rm -rf "$tmp_dir"' EXIT
 157: 
 158: fetch_url "frontend health" "$FRONTEND_URL/healthz" "$tmp_dir/frontend-health.txt"
 159: grep -q '^ok' "$tmp_dir/frontend-health.txt" || fail "frontend /healthz did not return ok"
 160: 
 161: fetch_url_with_headers "frontend index" "$FRONTEND_URL/" "$tmp_dir/frontend.html" "$tmp_dir/frontend.headers"
 162: grep -Eq '<div id="?app"?' "$tmp_dir/frontend.html" || fail "frontend index does not look like the Vue app"
 163: assert_no_frontend_backend_origin_leaks "$tmp_dir/frontend.html" "frontend index"
 164: assert_header "$tmp_dir/frontend.headers" "content-security-policy" ".*default-src 'self'.*frame-ancestors 'none'"
 165: assert_header "$tmp_dir/frontend.headers" "x-content-type-options" "nosniff"
 166: assert_header "$tmp_dir/frontend.headers" "x-frame-options" "DENY"
 167: assert_header "$tmp_dir/frontend.headers" "referrer-policy" "strict-origin-when-cross-origin"
 168: 
 169: grep -Eo '(src|href)="[^"]+"' "$tmp_dir/frontend.html" \
 170:   | sed -E 's/^(src|href)="([^"]+)"/\2/' \
 171:   | sort -u > "$tmp_dir/frontend-assets.txt"
 172: 
 173: asset_index=0
 174: while IFS= read -r asset_path; do
 175:   asset_index=$((asset_index + 1))
 176:   asset_output="$tmp_dir/frontend-asset-${asset_index}.txt"
 177:   fetch_static_asset "$asset_path" "$asset_output"
 178:   if [[ -s "$asset_output" ]]; then
 179:     assert_no_frontend_backend_origin_leaks "$asset_output" "frontend asset ${asset_path}"
 180:   fi
 181: done < "$tmp_dir/frontend-assets.txt"
 182: 
 183: fetch_url "frontend proxied API" "$FRONTEND_URL/api/health" "$tmp_dir/frontend-api.json"
 184: grep -q '"status":"ok"' "$tmp_dir/frontend-api.json" || fail "frontend proxied /api/health did not return ok"
 185: 
 186: fetch_websocket_probe "frontend proxied WebSocket" "$FRONTEND_URL/api/ws/instances/1/terminal?ticket=invalid" "$tmp_dir/frontend-ws.txt" "$tmp_dir/frontend-ws.err"
 187: grep -Eq '^HTTP/[0-9.]+ 101 ' "$tmp_dir/frontend-ws.txt" || fail "frontend /api/ws did not upgrade to WebSocket"
 188: grep -Eiq '^upgrade:[[:space:]]*websocket' "$tmp_dir/frontend-ws.txt" || fail "frontend /api/ws response missing WebSocket upgrade header"
 189: 
 190: if [[ -n "$ADMIN_FRONTEND_URL" ]]; then
 191:   fetch_url "admin frontend health" "$ADMIN_FRONTEND_URL/healthz" "$tmp_dir/admin-frontend-health.txt"
 192:   grep -q '^ok' "$tmp_dir/admin-frontend-health.txt" || fail "admin frontend /healthz did not return ok"
 193: 
 194:   fetch_url_with_headers "admin frontend index" "$ADMIN_FRONTEND_URL/" "$tmp_dir/admin-frontend.html" "$tmp_dir/admin-frontend.headers"
 195:   grep -Eq '<div id="?app"?' "$tmp_dir/admin-frontend.html" || fail "admin frontend index does not look like the Vue app"
 196:   assert_no_frontend_backend_origin_leaks "$tmp_dir/admin-frontend.html" "admin frontend index"
 197:   assert_header "$tmp_dir/admin-frontend.headers" "content-security-policy" ".*default-src 'self'.*frame-ancestors 'none'"
 198:   assert_header "$tmp_dir/admin-frontend.headers" "x-content-type-options" "nosniff"
 199:   assert_header "$tmp_dir/admin-frontend.headers" "x-frame-options" "DENY"
 200:   assert_header "$tmp_dir/admin-frontend.headers" "referrer-policy" "strict-origin-when-cross-origin"
 201: 
 202:   grep -Eo '(src|href)="[^"]+"' "$tmp_dir/admin-frontend.html" \
 203:     | sed -E 's/^(src|href)="([^"]+)"/\2/' \
 204:     | sort -u > "$tmp_dir/admin-frontend-assets.txt"
 205: 
 206:   admin_asset_index=0
 207:   while IFS= read -r asset_path; do
 208:     admin_asset_index=$((admin_asset_index + 1))
 209:     asset_output="$tmp_dir/admin-frontend-asset-${admin_asset_index}.txt"
 210:     if [[ "$asset_path" == /* ]]; then
 211:       fetch_url "admin static asset ${asset_path}" "${ADMIN_FRONTEND_URL}${asset_path}" "$asset_output"
 212:       if [[ -s "$asset_output" ]]; then
 213:         assert_no_frontend_backend_origin_leaks "$asset_output" "admin frontend asset ${asset_path}"
 214:       fi
 215:     fi
 216:   done < "$tmp_dir/admin-frontend-assets.txt"
 217: 
 218:   fetch_url "admin frontend proxied API" "$ADMIN_FRONTEND_URL/api/health" "$tmp_dir/admin-frontend-api.json"
 219:   grep -q '"status":"ok"' "$tmp_dir/admin-frontend-api.json" || fail "admin frontend proxied /api/health did not return ok"
 220: 
 221:   fetch_websocket_probe "admin frontend proxied WebSocket" "$ADMIN_FRONTEND_URL/api/ws/instances/1/terminal?ticket=invalid" "$tmp_dir/admin-frontend-ws.txt" "$tmp_dir/admin-frontend-ws.err"
 222:   grep -Eq '^HTTP/[0-9.]+ 101 ' "$tmp_dir/admin-frontend-ws.txt" || fail "admin frontend /api/ws did not upgrade to WebSocket"
 223:   grep -Eiq '^upgrade:[[:space:]]*websocket' "$tmp_dir/admin-frontend-ws.txt" || fail "admin frontend /api/ws response missing WebSocket upgrade header"
 224: fi
 225: 
 226: fetch_url "backend direct API" "$BACKEND_URL/api/health" "$tmp_dir/backend-api.json"
 227: grep -q '"status":"ok"' "$tmp_dir/backend-api.json" || fail "backend direct /api/health did not return ok"
 228: 
 229: log "Host-process split deployment verification passed"
