===== deploy/incudal-backend.service.example =====
   1: [Unit]
   2: Description=PayIncus backend API
   3: Documentation=https://github.com/XiaoLong-Taiwan/payincus
   4: After=network.target postgresql.service redis-server.service
   5: Wants=network.target
   6: 
   7: [Service]
   8: Type=simple
   9: User=incudal
  10: Group=incudal
  11: WorkingDirectory=/opt/incudal/current
  12: EnvironmentFile=/opt/incudal/.env
  13: Environment=HOME=/opt/incudal
  14: Environment=NPM_CONFIG_CACHE=/opt/incudal/.npm
  15: Environment=XDG_CACHE_HOME=/opt/incudal/.cache
  16: 
  17: ExecStartPre=/usr/bin/bash -lc 'cd /opt/incudal/current/server && pnpm exec prisma migrate deploy'
  18: ExecStart=/usr/bin/node /opt/incudal/current/server/dist/app.js
  19: 
  20: Restart=on-failure
  21: RestartSec=10
  22: KillMode=mixed
  23: KillSignal=SIGTERM
  24: TimeoutStopSec=30
  25: LimitNOFILE=65536
  26: 
  27: # Online updates start root-owned systemd oneshot units through a restricted
  28: # sudoers rule. Keep this false or sudo cannot elevate from the backend service.
  29: NoNewPrivileges=false
  30: ProtectSystem=strict
  31: ProtectHome=true
  32: ReadWritePaths=/opt/incudal /opt/incudal/current /opt/incudal/releases /opt/incudal/server/certs /opt/incudal/plugins /opt/incudal/plugin-data /opt/incudal/plugin-logs /opt/incudal/plugin-staging /opt/incudal/themes /opt/incudal/theme-data /opt/incudal/theme-staging /opt/incudal/.npm /opt/incudal/.cache /opt/incudal/.git /opt/incudal/update-logs
  33: PrivateTmp=true
  34: 
  35: StandardOutput=journal
  36: StandardError=journal
  37: SyslogIdentifier=incudal-backend
  38: 
  39: [Install]
  40: WantedBy=multi-user.target
===== deploy/incudal-online-rollback@.service.example =====
   1: [Unit]
   2: Description=PayIncus online update rollback task %i
   3: Documentation=https://github.com/XiaoLong-Taiwan/payincus
   4: After=network.target postgresql.service redis-server.service
   5: Requires=postgresql.service redis-server.service
   6: 
   7: [Service]
   8: Type=oneshot
   9: User=root
  10: Group=root
  11: WorkingDirectory=/opt/incudal/current
  12: EnvironmentFile=/opt/incudal/.env
  13: Environment=HOME=/opt/incudal
  14: Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
  15: Environment=NPM_CONFIG_CACHE=/opt/incudal/.npm
  16: Environment=XDG_CACHE_HOME=/opt/incudal/.cache
  17: Environment=INCUDAL_APP_DIR=/opt/incudal/current
  18: Environment=INSTALL_DIR=/opt/incudal
  19: Environment=SERVICE_NAME=incudal-backend
  20: ExecStart=/usr/bin/node /opt/incudal/current/server/dist/scripts/rollback-system-update-task.js %i
  21: TimeoutStartSec=900
  22: StandardOutput=journal
  23: StandardError=journal
  24: SyslogIdentifier=incudal-online-rollback
===== deploy/incudal-online-update@.service.example =====
   1: [Unit]
   2: Description=PayIncus online update task %i
   3: Documentation=https://github.com/XiaoLong-Taiwan/payincus
   4: After=network.target postgresql.service redis-server.service
   5: Requires=postgresql.service redis-server.service
   6: 
   7: [Service]
   8: Type=oneshot
   9: User=root
  10: Group=root
  11: WorkingDirectory=/opt/incudal/current
  12: EnvironmentFile=/opt/incudal/.env
  13: Environment=HOME=/opt/incudal
  14: Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
  15: Environment=NPM_CONFIG_CACHE=/opt/incudal/.npm
  16: Environment=XDG_CACHE_HOME=/opt/incudal/.cache
  17: Environment=INCUDAL_APP_DIR=/opt/incudal/current
  18: Environment=INSTALL_DIR=/opt/incudal
  19: Environment=SERVICE_NAME=incudal-backend
  20: ExecStart=/usr/bin/node /opt/incudal/current/server/dist/scripts/run-system-update-task.js %i
  21: TimeoutStartSec=1800
  22: StandardOutput=journal
  23: StandardError=journal
  24: SyslogIdentifier=incudal-online-update
===== deploy/nginx-split-intranet.conf.example =====
   1: # PayIncus host-process split deployment example.
   2: # Replace:
   3: #   pay.payincus.com       -> your customer panel domain
   4: #   admin.payincus.com  -> your admin backend domain
   5: #   /opt/incudal/current/client/dist/user  -> customer frontend build output
   6: #   /opt/incudal/current/client/dist/admin -> admin frontend build output
   7: #   10.0.0.12:3001          -> backend private IP and port
   8: 
   9: map $http_x_forwarded_proto $incudal_forwarded_proto {
  10:   default $http_x_forwarded_proto;
  11:   "" $scheme;
  12: }
  13: 
  14: map $http_x_forwarded_host $incudal_forwarded_host {
  15:   default $http_x_forwarded_host;
  16:   "" $host;
  17: }
  18: 
  19: server {
  20:   listen 80;
  21:   listen [::]:80;
  22:   server_name pay.payincus.com;
  23: 
  24:   root /opt/incudal/current/client/dist/user;
  25:   index index.html;
  26: 
  27:   client_max_body_size 100m;
  28: 
  29:   add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: http: https: https://kkksr.com https://api.dicebear.com https://dicebear.incudal.com https://*.githubusercontent.com https://avatars.githubusercontent.com https://lh3.googleusercontent.com; connect-src 'self' ws: wss: https://challenges.cloudflare.com https://cloudflareinsights.com https://api.dicebear.com https://dicebear.incudal.com; frame-src 'self' https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'" always;
  30:   add_header X-Content-Type-Options nosniff always;
  31:   add_header X-Frame-Options DENY always;
  32:   add_header Referrer-Policy strict-origin-when-cross-origin always;
  33:   add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
  34: 
  35:   location = /healthz {
  36:     add_header Content-Type text/plain;
  37:     return 200 "ok\n";
  38:   }
  39: 
  40:   location = /index.html {
  41:     expires epoch;
  42:   }
  43: 
  44:   location /assets/ {
  45:     try_files $uri =404;
  46:     expires 1y;
  47:   }
  48: 
  49:   location /api/ws/ {
  50:     proxy_pass http://10.0.0.12:3001/api/ws/;
  51:     proxy_http_version 1.1;
  52:     proxy_set_header Upgrade $http_upgrade;
  53:     proxy_set_header Connection "upgrade";
  54:     proxy_set_header Host $host;
  55:     proxy_set_header X-Forwarded-Host $incudal_forwarded_host;
  56:     proxy_set_header X-Real-IP $remote_addr;
  57:     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  58:     proxy_set_header X-Forwarded-Proto $incudal_forwarded_proto;
  59:     proxy_read_timeout 3600s;
  60:     proxy_send_timeout 3600s;
  61:     proxy_buffering off;
  62:   }
  63: 
  64:   location /api/ {
  65:     proxy_pass http://10.0.0.12:3001/api/;
  66:     proxy_http_version 1.1;
  67:     proxy_set_header Host $host;
  68:     proxy_set_header X-Forwarded-Host $incudal_forwarded_host;
  69:     proxy_set_header X-Real-IP $remote_addr;
  70:     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  71:     proxy_set_header X-Forwarded-Proto $incudal_forwarded_proto;
  72:     proxy_read_timeout 300s;
  73:     proxy_send_timeout 300s;
  74:   }
  75: 
  76:   location / {
  77:     try_files $uri $uri/ /index.html;
  78:   }
  79: }
  80: 
  81: server {
  82:   listen 80;
  83:   listen [::]:80;
  84:   server_name admin.payincus.com;
  85: 
  86:   root /opt/incudal/current/client/dist/admin;
  87:   index index.html;
  88: 
  89:   client_max_body_size 100m;
  90: 
  91:   add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: http: https: https://kkksr.com https://api.dicebear.com https://dicebear.incudal.com https://*.githubusercontent.com https://avatars.githubusercontent.com https://lh3.googleusercontent.com; connect-src 'self' ws: wss: https://challenges.cloudflare.com https://cloudflareinsights.com https://api.dicebear.com https://dicebear.incudal.com; frame-src 'self' https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'" always;
  92:   add_header X-Content-Type-Options nosniff always;
  93:   add_header X-Frame-Options DENY always;
  94:   add_header Referrer-Policy strict-origin-when-cross-origin always;
  95:   add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
  96: 
  97:   location = /healthz {
  98:     add_header Content-Type text/plain;
  99:     return 200 "ok\n";
 100:   }
 101: 
 102:   location = /index.html {
 103:     expires epoch;
 104:   }
