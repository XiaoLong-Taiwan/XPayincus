 278: export interface PayIncusPublicApiClientOptions {
 279:   baseUrl: string
 280:   token: string
 281: }
 282: 
 283: export class PayIncusPublicApiClient {
 284:   private baseUrl: string
 285:   private token: string
 286: 
 287:   constructor(options: PayIncusPublicApiClientOptions) {
 288:     this.baseUrl = options.baseUrl.replace(/\/+$/, '')
 289:     this.token = options.token
 290:   }
 291: 
 292:   private query(options: Record<string, unknown> = {}): string {
 293:     const params = new URLSearchParams()
 294:     for (const [key, value] of Object.entries(options)) {
 295:       if (value === undefined || value === null) continue
 296:       params.set(key, Array.isArray(value) ? value.join(',') : String(value))
 297:     }
 298:     const text = params.toString()
 299:     return text ? `?${text}` : ''
 300:   }
 301: 
 302:   private parsePayload(text: string): unknown {
 303:     if (!text) return null
 304:     try {
 305:       return JSON.parse(text)
 306:     } catch {
 307:       return { error: text }
 308:     }
 309:   }
 310: 
 311:   private errorBody(payload: unknown): PayIncusPublicApiErrorBody | null {
 312:     if (!payload || typeof payload !== 'object') return null
 313:     return payload as PayIncusPublicApiErrorBody
 314:   }
 315: 
 316:   private ticketFormData(input: PayIncusCreateTicketInput | PayIncusCreateTicketReplyInput): FormData {
 317:     const form = new FormData()
 318:     form.append('content', input.content)
 319:     if ('subject' in input) form.append('subject', input.subject)
 320:     if ('category' in input && input.category) form.append('category', input.category)
 321:     if ('priority' in input && input.priority) form.append('priority', input.priority)
 322:     for (const attachment of input.attachments || []) {
 323:       const { blob, filename } = attachment
 324:       form.append('images', blob, filename)
 325:     }
 326:     return form
 327:   }
 328: 
 329:   private async request<T>(path: string, options: { method?: string; body?: unknown } = {}): Promise<T> {
 330:     const isFormData = typeof FormData !== 'undefined' && options.body instanceof FormData
 331:     const headers = {
 332:       Authorization: `Bearer ${this.token}`,
 333:       ...(options.body === undefined || isFormData ? {} : { 'Content-Type': 'application/json' })
 334:     }
 335:     const response = await fetch(`${this.baseUrl}/api/v1${path}`, {
 336:       method: options.method || 'GET',
 337:       headers,
 338:       body: options.body === undefined ? undefined : isFormData ? options.body as BodyInit : JSON.stringify(options.body)
 339:     })
 340:     const payload = await this.parsePayload(await response.text())
 341:     if (!response.ok) {
 342:       const errorBody = this.errorBody(payload)
 343:       throw new PayIncusPublicApiError(response.status, errorBody, errorBody?.details ?? payload ? String(errorBody?.details ?? 'Request failed') : 'Request failed')
 344:     }
 345:     return payload as T
 346:   }
 347: 
 348:   private async oauthProviderRequest<T>(path: string, options: { method?: string; body?: unknown } = {}): Promise<T> {
 349:     const response = await fetch(`${this.baseUrl}/api/oauth-provider${path}`, {
 350:       method: options.method || 'GET',
 351:       headers: options.body ? { 'Content-Type': 'application/json' } : {},
 352:       body: options.body ? JSON.stringify(options.body) : undefined
 353:     })
 354:     const payload = await this.parsePayload(await response.text())
 355:     if (!response.ok) throw new PayIncusPublicApiError(response.status, this.errorBody(payload), 'OAuth provider request failed')
 356:     return payload as T
 357:   }
 358: 
 359:   listOAuthScopes() {
 360:     return this.oauthProviderRequest('/scopes') as Promise<PayIncusResponse<PayIncusPublicApiScopeMetadata[]>>
 361:   }
 362: 
 363:   getProfile() {
 364:     return this.request<PayIncusResponse<PayIncusProfile>>('/me')
 365:   }
 366: 
 367:   updateProfile(input: { avatarStyle: string }) {
 368:     return this.request('/me', { method: 'PATCH', body: input }) as Promise<PayIncusResponse<PayIncusProfile>>
 369:   }
 370: 
 371:   getBalance() {
 372:     return this.request<PayIncusResponse<PayIncusBalance>>('/balance')
 373:   }
 374: 
 375:   listBalanceLogs(options: PayIncusBalanceLogOptions = {}) {
 376:     return this.request<PayIncusListResponse<PayIncusBalanceLog>>(`/balance/logs${this.query(options)}`)
 377:   }
 378: 
 379:   listBalanceAdjustmentRequests(options: PayIncusBalanceAdjustmentRequestListOptions = {}) {
 380:     return this.request(`/balance/adjustment-requests${this.query(options)}`) as Promise<PayIncusListResponse<PayIncusBalanceAdjustmentRequest>>
 381:   }
 382: 
 383:   createBalanceAdjustmentRequest(input: PayIncusCreateBalanceAdjustmentRequestInput) {
 384:     return this.request('/balance/adjustment-requests', { method: 'POST', body: input }) as Promise<PayIncusResponse<PayIncusBalanceAdjustmentRequest>>
 385:   }
 386: 
 387:   listBillingRecords(options: PayIncusBillingRecordListOptions = {}) {
 388:     return this.request(`/billing-records${this.query(options)}`) as Promise<PayIncusListResponse<PayIncusBillingRecord>>
 389:   }
 390: 
 391:   getBillingRecord(id: number) {
 392:     return this.request(`/billing-records/${id}`) as Promise<PayIncusResponse<PayIncusBillingRecord>>
 393:   }
 394: 
 395:   listProducts(options: PayIncusListOptions = {}) {
 396:     return this.request<PayIncusListResponse<PayIncusProduct>>(`/products${this.query(options)}`)
 397:   }
 398: 
 399:   getProduct(id: number) {
 400:     return this.request<PayIncusResponse<PayIncusProduct>>(`/products/${id}`)
 401:   }
 402: 
 403:   listServices(options: PayIncusServiceListOptions = {}) {
 404:     return this.request<PayIncusServiceListResponse>(`/services${this.query(options)}`)
 405:   }
 406: 
 407:   getService(id: number, options: PayIncusServiceIncludeOptions = {}) {
 408:     return this.request<PayIncusServiceResponse>(`/services/${id}${this.query(options)}`)
 409:   }
 410: 
 411:   queueServiceAction(id: number, action: PayIncusServiceAction) {
 412:     return this.request(`/services/${id}/actions`, { method: 'POST', body: { action } }) as Promise<PayIncusResponse<PayIncusServiceActionResult>>
 413:   }
 414: 
 415:   getServiceTask(id: number, taskId: number) {
 416:     return this.request(`/services/${id}/tasks/${taskId}`) as Promise<PayIncusResponse<PayIncusServiceTask>>
 417:   }
 418: 
 419:   cancelServiceTask(id: number, taskId: number) {
 420:     return this.request(`/services/${id}/tasks/${taskId}`, { method: 'DELETE' }) as Promise<PayIncusResponse<PayIncusServiceTask>>
 421:   }
 422: 
 423:   renewService(id: number, months: number) {
 424:     return this.request(`/services/${id}/renew`, { method: 'POST', body: { months } }) as Promise<PayIncusResponse<PayIncusServiceRenewResult>>
 425:   }
 426: 
 427:   listOrders(options: PayIncusOrderListOptions = {}) {
 428:     return this.request<PayIncusListResponse<PayIncusOrder>>(`/orders${this.query(options)}`)
 429:   }
 430: 
 431:   getOrder(id: string) {
 432:     return this.request(`/orders/${encodeURIComponent(id)}`) as Promise<PayIncusResponse<PayIncusOrder>>
 433:   }
 434: 
 435:   listTickets(options: PayIncusTicketListOptions = {}) {
 436:     return this.request<PayIncusListResponse<PayIncusTicket>>(`/tickets${this.query(options)}`)
 437:   }
 438: 
 439:   createTicket(input: PayIncusCreateTicketInput) {
 440:     const attachments = input.attachments
 441:     return this.request('/tickets', {
 442:       method: 'POST',
 443:       body: attachments?.length ? this.ticketFormData(input) : input
 444:     }) as Promise<PayIncusResponse<PayIncusTicket>>
 445:   }
 446: 
 447:   getTicket(id: number) {
 448:     return this.request<PayIncusResponse<PayIncusTicket>>(`/tickets/${id}`)
 449:   }
 450: 
 451:   replyToTicket(id: number, input: string | PayIncusCreateTicketReplyInput) {
 452:     const payload = typeof input === 'string' ? { content: input } : input
 453:     const attachments = payload.attachments
 454:     return this.request<PayIncusResponse<PayIncusTicket>>(`/tickets/${id}/replies`, {
 455:       method: 'POST',
 456:       body: attachments?.length ? this.ticketFormData(payload) : payload
 457:     })
 458:   }
 459: 
 460:   updateTicketStatus(id: number, action: PayIncusTicketStatusAction) {
 461:     return this.request(`/tickets/${id}/status`, { method: 'PATCH', body: { action } }) as Promise<PayIncusResponse<PayIncusTicketStatusResult>>
 462:   }
 463: 
 464:   listNotifications(options: PayIncusNotificationListOptions = {}) {
 465:     return this.request<PayIncusListResponse<unknown>>(`/notifications${this.query(options)}`)
 466:   }
 467: 
 468:   getUnreadNotificationCount() {
 469:     return this.request<PayIncusResponse<{ count: number }>>('/notifications/unread-count')
 470:   }
 471: 
 472:   sendNotification(input: PayIncusNotificationInput) {
 473:     return this.request('/notifications', { method: 'POST', body: input }) as Promise<PayIncusResponse<unknown>>
 474:   }
 475: 
 476:   listPluginActions(options: PayIncusListOptions = {}) {
 477:     return this.request(`/plugins${this.query(options)}`) as Promise<PayIncusPluginActionCatalog>
 478:   }
 479: 
 480:   getPluginActions(pluginId: string) {
 481:     return this.request(`/plugins/${encodeURIComponent(pluginId)}/actions`) as Promise<PayIncusResponse<PayIncusPluginActionDescriptor[]>>
 482:   }
 483: 
 484:   dispatchPluginAction(pluginId: string, action: string, input: { payload?: unknown; idempotencyKey?: string } = {}) {
 485:     return this.request<PayIncusResponse<unknown>>(`/plugins/${encodeURIComponent(pluginId)}/actions/${encodeURIComponent(action)}`, { method: 'POST', body: input })
 486:   }
 487: }
===== docs-site/docs/public/sdk/examples/balance-adjustment-request.ts =====
   1: import { PayIncusPublicApiClient, PayIncusPublicApiError } from '../payincus-public-api'
   2: 
   3: const client = new PayIncusPublicApiClient({
   4:   baseUrl: process.env.PAYINCUS_BASE_URL || 'https://payincus.com',
   5:   token: process.env.PAYINCUS_API_TOKEN || ''
   6: })
   7: 
   8: async function main() {
   9:   const amount = process.env.PAYINCUS_ADJUSTMENT_AMOUNT || '10.00'
  10:   const reason = process.env.PAYINCUS_ADJUSTMENT_REASON || 'Manual balance correction request'
  11: 
  12:   const request = await client.createBalanceAdjustmentRequest({
  13:     amount,
  14:     reason,
  15:     externalReference: `example-${Date.now()}`
  16:   })
  17:   console.log(`created balance adjustment request ${request.data.id}`)
  18: 
  19:   const pending = await client.listBalanceAdjustmentRequests({ status: 'pending', sort: '-createdAt' })
  20:   console.log(`current pending requests: ${pending.data.length}`)
  21: }
  22: 
  23: main().catch(error => {
  24:   if (error instanceof PayIncusPublicApiError) {
  25:     console.error(`PayIncus API error ${error.status}: ${error.message}`, error.details)
  26:     process.exit(1)
  27:   }
  28:   throw error
  29: })
