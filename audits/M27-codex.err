===== docs-site/scripts/check-deployment-docs.mjs =====
   1: import { readFileSync } from 'node:fs'
   2: import { resolve } from 'node:path'
   3: import { fileURLToPath } from 'node:url'
   4: 
   5: const docsSiteDir = resolve(fileURLToPath(new URL('..', import.meta.url)))
   6: const repoRoot = resolve(docsSiteDir, '..')
   7: 
   8: function read(relativePath) {
   9:   return readFileSync(resolve(repoRoot, relativePath), 'utf8')
  10: }
  11: 
  12: function requireText(content, expected, label) {
  13:   if (!content.includes(expected)) {
  14:     throw new Error(`${label}: missing ${JSON.stringify(expected)}`)
  15:   }
  16: }
  17: 
  18: function rejectText(content, rejected, label) {
  19:   if (content.includes(rejected)) {
  20:     throw new Error(`${label}: contains forbidden ${JSON.stringify(rejected)}`)
  21:   }
  22: }
