  34: for (const path of [
  35:   'docs-site/docs/deployment/manual-install.md',
  36:   'docs-site/docs/en/deployment/manual-install.md'
  37: ]) {
  38:   const manual = read(path)
  39:   requireText(manual, '${PACKAGE}.sha256', path)
  40:   requireText(manual, 'sha256sum -c', path)
  41:   requireText(manual, '/opt/incudal/releases/.next-current', path)
  42: }
  43: 
  44: for (const path of [
  45:   'docs-site/docs/deployment/systemd.md',
  46:   'docs-site/docs/en/deployment/systemd.md'
  47: ]) {
  48:   const systemd = read(path)
  49:   rejectText(systemd, 'ExecStartPre=cd ', path)
  50:   requireText(systemd, "ExecStartPre=/usr/bin/bash -lc", path)
  51:   requireText(systemd, '/opt/incudal/theme-staging', path)
  52: }
  53: 
  54: for (const path of [
  55:   'deploy/incudal-backend.service.example',
  56:   'scripts/migrate-ota-atomic-layout.sh'
  57: ]) {
  58:   requireText(read(path), 'theme-staging', path)
  59: }
  60: 
