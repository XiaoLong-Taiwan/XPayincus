   5: function routeFromRelativePath(relativePath: string) {
   6:   let route = relativePath.replace(/\\/g, '/').replace(/\.md$/, '')
   7:   route = route.replace(/(^|\/)index$/, '$1')
   8:   route = route.startsWith('/') ? route : `/${route}`
   9:   return route || '/'
  10: }
  11: 
  12: function localeRoutes(route: string) {
  13:   if (route === '/en/') {
  14:     return { zh: '/', en: '/en/' }
  15:   }
  16:   if (route.startsWith('/en/')) {
  17:     return { zh: route.slice(3) || '/', en: route }
  18:   }
  19:   return { zh: route, en: route === '/' ? '/en/' : `/en${route}` }
  20: }
