 387: function normalizePublicBalanceAdjustmentAmount(value: unknown): number | null {
 388:   const amount = typeof value === 'number' ? value : typeof value === 'string' ? Number(value.trim()) : NaN
 389:   if (!Number.isFinite(amount)) return null
 390:   const normalized = Number(amount.toFixed(2))
 391:   if (normalized <= 0 || normalized > MAX_PUBLIC_BALANCE_ADJUSTMENT_AMOUNT) return null
