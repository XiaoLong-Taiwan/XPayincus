===== docs-site/docs/public/sdk/examples/flash-sale-action.ts =====
   1: import { createHash } from 'node:crypto'
   2: import { PayIncusPublicApiClient, PayIncusPublicApiError } from '../payincus-public-api'
   3: 
   4: const client = new PayIncusPublicApiClient({
   5:   baseUrl: process.env.PAYINCUS_BASE_URL || 'https://payincus.com',
   6:   token: process.env.PAYINCUS_API_TOKEN || ''
   7: })
   8: 
   9: function stableIdempotencyKey(userId: number, campaignId: string, sku: string) {
  10:   return createHash('sha256').update(`${userId}:${campaignId}:${sku}`).digest('hex')
  11: }
  12: 
  13: async function main() {
  14:   const pluginId = process.env.PAYINCUS_FLASH_SALE_PLUGIN_ID || 'com.payincus.flash-sale'
  15:   const campaignId = process.env.PAYINCUS_FLASH_SALE_CAMPAIGN_ID || 'summer-2026'
  16:   const sku = process.env.PAYINCUS_FLASH_SALE_SKU || 'starter-monthly'
  17:   const profile = await client.getProfile()
  18:   const idempotencyKey = stableIdempotencyKey(profile.data.id, campaignId, sku)
  19: 
  20:   const reserved = await client.dispatchPluginAction(pluginId, 'reserveStock', {
  21:     idempotencyKey,
  22:     payload: {
  23:       campaignId,
  24:       sku,
  25:       quantity: 1
  26:     }
  27:   })
  28: 
  29:   await client.sendNotification({
  30:     template: 'flash_sale_reminder',
  31:     variables: { campaignId, sku },
  32:     message: `Reserved flash sale stock for ${sku}`
  33:   })
  34: 
  35:   await client.createTicket({
  36:     subject: `Flash sale reservation ${campaignId}`,
  37:     category: 'billing',
  38:     priority: 'normal',
  39:     content: `Reservation response: ${JSON.stringify(reserved.data)}`
  40:   })
  41: }
  42: 
  43: main().catch(error => {
  44:   if (error instanceof PayIncusPublicApiError) {
  45:     console.error(`PayIncus API error ${error.status}: ${error.message}`, error.details)
  46:     process.exit(1)
  47:   }
  48:   throw error
  49: })
===== docs-site/docs/public/sdk/examples/oauth-authorization-code.ts =====
   1: import { randomBytes, timingSafeEqual } from 'node:crypto'
   2: import { PayIncusPublicApiClient } from '../payincus-public-api'
   3: 
   4: interface OAuthTokenResponse {
   5:   access_token: string
   6:   refresh_token: string
   7:   token_type: 'Bearer'
   8:   expires_in: number
   9: }
  10: 
  11: const baseUrl = process.env.PAYINCUS_BASE_URL || 'https://payincus.com'
  12: const clientId = process.env.PAYINCUS_OAUTH_CLIENT_ID || ''
  13: const clientSecret = process.env.PAYINCUS_OAUTH_CLIENT_SECRET || ''
  14: const redirectUri = process.env.PAYINCUS_OAUTH_REDIRECT_URI || 'https://example.com/oauth/callback'
  15: const state = randomBytes(24).toString('base64url')
  16: 
  17: function buildAuthorizationUrl() {
  18:   const url = new URL('/oauth/authorize', baseUrl)
  19:   url.searchParams.set('client_id', clientId)
  20:   url.searchParams.set('redirect_uri', redirectUri)
  21:   url.searchParams.set('response_type', 'code')
  22:   url.searchParams.set('scope', 'profile:read services:read services:operate')
  23:   url.searchParams.set('state', state)
  24:   return url.toString()
  25: }
  26: 
  27: function verifyOAuthState(receivedState: string) {
  28:   const expected = Buffer.from(state)
  29:   const received = Buffer.from(receivedState)
  30:   return expected.length === received.length && timingSafeEqual(expected, received)
  31: }
  32: 
  33: async function exchangeAuthorizationCode(code: string): Promise<OAuthTokenResponse> {
  34:   const endpoint = new URL('/api/oauth-provider/token', baseUrl)
  35:   const response = await fetch(endpoint, {
  36:     method: 'POST',
  37:     headers: { 'Content-Type': 'application/json' },
  38:     body: JSON.stringify({
  39:       grantType: 'authorization_code',
  40:       clientId,
  41:       clientSecret,
  42:       code,
  43:       redirectUri
  44:     })
  45:   })
  46:   if (!response.ok) throw new Error(`OAuth token exchange failed: ${response.status}`)
  47:   return await response.json() as OAuthTokenResponse
  48: }
  49: 
  50: async function refreshAccessToken(refreshToken: string): Promise<OAuthTokenResponse> {
  51:   const endpoint = new URL('/api/oauth-provider/token', baseUrl)
  52:   const response = await fetch(endpoint, {
  53:     method: 'POST',
  54:     headers: { 'Content-Type': 'application/json' },
  55:     body: JSON.stringify({
  56:       grantType: 'refresh_token',
  57:       clientId,
  58:       clientSecret,
  59:       refreshToken
  60:     })
  61:   })
  62:   if (!response.ok) throw new Error(`OAuth token refresh failed: ${response.status}`)
  63:   return await response.json() as OAuthTokenResponse
  64: }
  65: 
  66: async function main() {
  67:   console.log(`Open this URL in the browser: ${buildAuthorizationUrl()}`)
  68: 
  69:   const code = process.env.PAYINCUS_OAUTH_CODE || ''
  70:   const state = process.env.PAYINCUS_OAUTH_STATE || ''
  71:   if (!code || !verifyOAuthState(state)) {
  72:     throw new Error('Set PAYINCUS_OAUTH_CODE and a valid PAYINCUS_OAUTH_STATE after the callback')
  73:   }
  74: 
  75:   const token = await exchangeAuthorizationCode(code)
  76:   const api = new PayIncusPublicApiClient({ baseUrl, token: token.access_token })
  77:   const profile = await api.getProfile()
  78:   console.log(`authorized profile ${profile.data.username}`)
  79: 
  80:   const refreshed = await refreshAccessToken(token.refresh_token)
  81:   const refreshTokenRotated = refreshed.refresh_token !== token.refresh_token
  82:   console.log(`refreshTokenRotated=${refreshTokenRotated}`)
  83: }
  84: 
  85: main().catch(error => {
  86:   console.error(error)
  87:   process.exit(1)
  88: })
===== docs-site/docs/public/sdk/examples/service-power-task.ts =====
   1: import { PayIncusPublicApiClient, PayIncusPublicApiError, type PayIncusServiceAction } from '../payincus-public-api'
   2: 
   3: const client = new PayIncusPublicApiClient({
   4:   baseUrl: process.env.PAYINCUS_BASE_URL || 'https://payincus.com',
   5:   token: process.env.PAYINCUS_API_TOKEN || ''
   6: })
   7: 
   8: const sleep = (ms: number) => new Promise(resolve => setTimeout(resolve, ms))
   9: 
  10: async function queuePowerTask(serviceId: number, action: PayIncusServiceAction) {
  11:   return client.queueServiceAction(serviceId, action)
  12: }
  13: 
  14: async function waitForTask(serviceId: number, taskId: number) {
  15:   for (;;) {
  16:     const task = await client.getServiceTask(serviceId, taskId)
  17:     if (task.data.status !== 'PENDING' && task.data.status !== 'PROCESSING') {
  18:       return task
  19:     }
  20:     await sleep(3000)
  21:   }
  22: }
  23: 
  24: async function main() {
  25:   const services = await client.listServices({
  26:     status: 'running',
  27:     include: ['product', 'plan'],
  28:     sort: 'displayOrder'
  29:   })
  30:   const service = services.data[0]
  31:   if (!service) throw new Error('No running service is available for this token')
  32: 
  33:   const queued = await queuePowerTask(service.id, 'restart')
  34:   const taskId = queued.data.task.id
  35:   const finished = await waitForTask(service.id, taskId)
  36:   console.log(`service ${service.id} restart task ${taskId}: ${finished.data.status}`)
  37: }
  38: 
  39: main().catch(error => {
  40:   if (error instanceof PayIncusPublicApiError) {
  41:     console.error(`PayIncus API error ${error.status}: ${error.message}`, error.details)
  42:     process.exit(1)
  43:   }
  44:   throw error
  45: })
===== docs-site/docs/public/sdk/examples/service-renew.ts =====
   1: import { PayIncusPublicApiClient, PayIncusPublicApiError } from '../payincus-public-api'
   2: 
   3: const client = new PayIncusPublicApiClient({
   4:   baseUrl: process.env.PAYINCUS_BASE_URL || 'https://payincus.com',
   5:   token: process.env.PAYINCUS_API_TOKEN || ''
   6: })
   7: 
   8: async function main() {
   9:   const serviceId = Number(process.env.PAYINCUS_SERVICE_ID || 0)
  10:   const months = Number(process.env.PAYINCUS_RENEW_MONTHS || 1)
  11:   if (!serviceId) throw new Error('PAYINCUS_SERVICE_ID is required')
  12:   if (!Number.isInteger(months) || months < 1) throw new Error('PAYINCUS_RENEW_MONTHS must be a positive integer')
  13: 
  14:   const result = await client.renewService(serviceId, months)
  15:   console.log(`renewed service ${result.data.service.id} for ${months} month(s)`)
  16: }
  17: 
  18: main().catch(error => {
  19:   if (error instanceof PayIncusPublicApiError) {
  20:     console.error(`PayIncus API error ${error.status}: ${error.message}`, error.details)
  21:     process.exit(1)
  22:   }
  23:   throw error
  24: })
