  13: 
  14: SAFE_ARCHIVE="$WORK_DIR/incudal-v0.0.0-linux-amd64.tar.gz"
  15: tar -czf "$SAFE_ARCHIVE" -C "$WORK_DIR/payload" .
  16: sha256sum "$SAFE_ARCHIVE" > "${SAFE_ARCHIVE}.sha256"
  17: 
  18: verify_release_checksum "$SAFE_ARCHIVE"
  19: validate_release_archive "$SAFE_ARCHIVE"
  20: 
  21: printf '%064d  %s\n' 0 "$(basename "$SAFE_ARCHIVE")" > "${SAFE_ARCHIVE}.sha256"
  22: if verify_release_checksum "$SAFE_ARCHIVE"; then
  23:     echo "checksum guard accepted a mismatched archive" >&2
  24:     exit 1
  25: fi
  26: 
  27: UNSAFE_ARCHIVE="$WORK_DIR/unsafe.tar.gz"
  28: tar -czf "$UNSAFE_ARCHIVE" --transform='s#^#../#' -C "$WORK_DIR/payload" .
  29: if validate_release_archive "$UNSAFE_ARCHIVE"; then
  30:     echo "archive guard accepted a parent traversal path" >&2
  31:     exit 1
  32: fi
  33: 
