===== scripts/init-env.sh =====
   1: #!/usr/bin/env bash
   2: # ============================================================================
   3: # PayIncus æœ¬åœ° .env åˆå§‹åŒ–è„šæœ¬
   4: #
   5: # ç”¨æ³•ï¼š
   6: #   bash scripts/init-env.sh
   7: #
   8: # è¡Œä¸ºï¼š
   9: #   - å¦‚æžœ .env ä¸å­˜åœ¨ï¼Œåˆ›å»º .env
  10: #   - å¦‚æžœ .env å·²å­˜åœ¨ï¼Œåªè¡¥é½ç¼ºå¤±æˆ–ç©ºå€¼çš„å…³é”®å˜é‡
  11: #   - ä¸è¦†ç›–å·²æœ‰éžç©ºé…ç½®ï¼Œé¿å…ç ´åå·²éƒ¨ç½²å®žä¾‹
  12: # ============================================================================
  13: set -euo pipefail
  14: 
  15: ENV_FILE="${ENV_FILE:-.env}"
  16: 
  17: log() {
  18:     echo "[âœ“] $1" >&2
  19: }
  20: 
  21: info() {
  22:     echo "[i] $1" >&2
  23: }
  24: 
  25: gen_password() {
  26:     openssl rand -hex 64 | cut -c "1-${1:-24}"
  27: }
  28: 
  29: gen_secret() {
  30:     printf 'A1!%s' "$(openssl rand -hex 64)" | cut -c "1-${1:-48}"
  31: }
  32: 
  33: get_env_value() {
  34:     local key="$1"
  35:     if [[ ! -f "$ENV_FILE" ]]; then
  36:         return 0
  37:     fi
  38:     grep -E "^${key}=" "$ENV_FILE" 2>/dev/null | tail -n 1 | cut -d'=' -f2- || true
  39: }
  40: 
  41: set_env_if_missing() {
  42:     local key="$1"
  43:     local value="$2"
  44:     local label="$3"
  45:     local current
  46:     current="$(get_env_value "$key")"
  47: 
  48:     if [[ -n "$current" ]]; then
  49:         return 0
  50:     fi
  51: 
  52:     if grep -qE "^${key}=" "$ENV_FILE" 2>/dev/null; then
  53:         local tmp_file
  54:         tmp_file="$(mktemp)"
  55:         awk -v key="$key" -v value="$value" '
  56:             BEGIN { replaced = 0 }
  57:             $0 ~ "^" key "=" && replaced == 0 {
  58:                 print key "=" value
  59:                 replaced = 1
  60:                 next
  61:             }
  62:             { print }
  63:         ' "$ENV_FILE" > "$tmp_file"
  64:         cat "$tmp_file" > "$ENV_FILE"
  65:         rm -f "$tmp_file"
  66:     else
  67:         printf '\n%s=%s\n' "$key" "$value" >> "$ENV_FILE"
  68:     fi
  69: 
  70:     log "å·²è‡ªåŠ¨è¡¥å…… ${label}: ${key}"
  71: }
  72: 
  73: if [[ ! -f "$ENV_FILE" ]]; then
  74:     cat > "$ENV_FILE" <<EOF_ENV
  75: # ============================================================================
  76: # PayIncus ä¸»æœºè¿›ç¨‹éƒ¨ç½²çŽ¯å¢ƒé…ç½®
  77: # ç”± scripts/init-env.sh è‡ªåŠ¨ç”ŸæˆäºŽ $(date '+%Y-%m-%d %H:%M:%S')
  78: # ============================================================================
  79: EOF_ENV
  80:     info "å·²åˆ›å»º ${ENV_FILE}"
  81: fi
  82: 
  83: db_password="$(gen_password 24)"
  84: redis_password="$(gen_password 24)"
  85: 
  86: set_env_if_missing "NODE_ENV" "production" "è¿è¡ŒçŽ¯å¢ƒ"
  87: set_env_if_missing "HOST" "127.0.0.1" "åŽç«¯ç›‘å¬åœ°å€"
