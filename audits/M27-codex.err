1406:     config: { rateLimit: PUBLIC_API_RATE_LIMITS.balanceAdjustmentWrite }
1407:   }, async (request, reply) => {
1408:     const apiToken = await authenticatePublicApiRequest(request, reply, 'balance:write')
1409:     if (!apiToken) return
1410: 
1411:     const amount = normalizePublicBalanceAdjustmentAmount(request.body?.amount)
1412:     const reason = normalizePublicBalanceAdjustmentReason(request.body?.reason)
1413:     const requestType = normalizePublicBalanceAdjustmentType(request.body?.requestType)
1414:     const orderNo = normalizePublicBalanceAdjustmentOrderNo(request.body?.orderNo)
1415:     if (amount === null) {
1416:       return reply.code(400).send({ error: 'Invalid balance adjustment amount', code: 'INVALID_BALANCE_ADJUSTMENT_AMOUNT' })
1417:     }
1418:     if (!reason) {
1419:       return reply.code(400).send({ error: 'Invalid balance adjustment reason', code: 'INVALID_BALANCE_ADJUSTMENT_REASON' })
1420:     }
1421:     if (orderNo === null) {
1422:       return reply.code(400).send({ error: 'Invalid balance adjustment order number', code: 'INVALID_BALANCE_ADJUSTMENT_ORDER_NO' })
1423:     }
1424: 
1425:     const pendingCount = await prisma.balanceAdjustmentRequest.count({
1426:       where: {
1427:         userId: apiToken.userId,
1428:         requestedByUserId: apiToken.userId,
1429:         sourceType: 'public_api',
1430:         status: 'pending'
1431:       }
1432:     })
1433:     if (pendingCount >= 5) {
1434:       return reply.code(429).send({ error: 'Too many pending balance adjustment requests', code: 'PUBLIC_BALANCE_ADJUSTMENT_PENDING_LIMIT' })
1435:     }
1436: 
1437:     const adjustmentRequest = await createBalanceAdjustmentRequest({
1438:       userId: apiToken.userId,
1439:       requestedByUserId: apiToken.userId,
1440:       amount,
1441:       requestType,
1442:       reason: `[Public API] ${reason}`,
1443:       sourceType: 'public_api',
1444:       sourceId: apiToken.id,
1445:       orderNo
1446:     })
