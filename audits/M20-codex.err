  302: export default async function adminHostingRoutes(app: FastifyInstance): Promise<void> {
  303:   // GET /api/admin/hosting/owners - æ‰˜ç®¡æœºä¸»ç”¨æˆ·åˆ—è¡¨
  304:   app.get<{
  305:     Querystring: {
  306:       page?: string
  307:       pageSize?: string
  308:       search?: string
  309:       sortBy?: string
  310:       sortOrder?: string
  311:     }
  312:   }>('/api/admin/hosting/owners', {
  313:     onRequest: [app.authenticate, app.requireAdmin],
  314:     config: { rateLimit: { max: 30, timeWindow: '1 minute' } }
  315:   }, async (request, reply) => {
  316:     try {
  317:       const page = parseBoundedInt(request.query.page, 1, 1, 100000)
  318:       const pageSize = parseBoundedInt(request.query.pageSize, 50, 10, 100)
  319:       const skip = (page - 1) * pageSize
  320:       const search = (request.query.search || '').trim().slice(0, 100)
  321:       const sortBy = normalizeHostingOwnerSortBy(request.query.sortBy)
  322:       const sortOrder = normalizeSortOrder(request.query.sortOrder)
  323:       const searchSql = buildSearchSql(search)
  324:       const qualifiedOwnersCte = buildQualifiedOwnersCte(searchSql)
  325:       const vipRules = await getVipRules('hosting')
  326:       const orderSql = buildHostingOwnerOrderSql(sortBy, sortOrder, vipRules)
  327: 
  328:       const [owners, countRows, summaryRows] = await Promise.all([
  329:         prisma.$queryRaw<HostingOwnerRow[]>(Prisma.sql`
  330:           ${qualifiedOwnersCte}
  331:           SELECT *
  332:           FROM qualified_owners
  333:           ${orderSql}
  334:           LIMIT ${pageSize}
  335:           OFFSET ${skip}
  336:         `),
  337:         prisma.$queryRaw<CountRow[]>(Prisma.sql`
  338:           ${qualifiedOwnersCte}
  339:           SELECT COUNT(*)::int AS total
  340:           FROM qualified_owners
  341:         `),
  342:         prisma.$queryRaw<SummaryRow[]>(Prisma.sql`
  343:           ${qualifiedOwnersCte}
  344:           SELECT
  345:             COALESCE(SUM("hostCount"), 0)::int AS "totalHosts",
  346:             COALESCE(SUM("listedPackageCount"), 0)::int AS "totalListedPackages",
  347:             COALESCE(SUM("instanceCount"), 0)::int AS "totalInstances",
  348:             COALESCE(SUM("hostingBalance"), 0)::numeric AS "totalAvailableBalance",
  349:             COALESCE(SUM("frozenBalance"), 0)::numeric AS "totalFrozenBalance",
  350:             COALESCE(SUM("totalHostingIncome"), 0)::numeric AS "totalHostingIncome"
  351:           FROM qualified_owners
  352:         `)
  353:       ])
  354: 
  355:       const total = countRows[0]?.total || 0
  356:       const summary = summaryRows[0]
  357: 
  358:       return {
  359:         owners: owners.map(owner => {
  360:           const availableBalance = roundMoney(toNumber(owner.hostingBalance))
  361:           const frozenBalance = roundMoney(toNumber(owner.frozenBalance))
  362:           const totalHostingIncome = roundMoney(toNumber(owner.totalHostingIncome))
  363:           const instanceCount = Number(owner.instanceCount || 0)
  364: 
  365:           const vipLevel = calculateVipLevel('hosting', vipRules, {
  366:             totalHostingIncome,
  367:             instanceCount
  368:           })
  369: 
  370:           return {
