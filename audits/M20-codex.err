   47: export async function getBlockerIdsForUser(userId: number): Promise<number[]> {
   48:   const blocks = await prisma.hostingUserBlock.findMany({
   49:     where: { blockedUserId: userId },
   50:     select: { blockerId: true }
   51:   })
   52: 
   53:   return blocks.map(block => block.blockerId)
   54: }
