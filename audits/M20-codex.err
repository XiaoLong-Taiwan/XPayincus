  311: // åŠ è½½æ•°æ®
  312: async function loadBalance() {
  313:   try {
  314:     const res = await api.hosting.getBalance()
  315:     balance.value = res.balance
  316:     config.value = res.config
  317:   } catch (err) {
  318:     console.error('Failed to load hosting balance:', err)
  319:   }
  320: }
  321: 
  322: async function loadStats() {
  323:   try {
  324:     const res = await api.hosting.getStats()
  325:     stats.value = res.stats
  326:   } catch (err) {
  327:     console.error('Failed to load hosting stats:', err)
  328:   }
  329: }
  330: 
  331: async function loadLogs(page = 1) {
  332:   logsLoading.value = true
  333:   try {
  334:     const res = await api.hosting.getLogs({ 
  335:       page, 
  336:       pageSize: logsPageSize.value,
  337:       search: logsSearch.value || undefined,
  338:       actionType: logsFilter.value !== 'all' ? logsFilter.value : undefined
  339:     })
  340:     logs.value = res.logs
  341:     logsTotal.value = res.total
  342:     logsPage.value = page
  343:   } catch (err) {
  344:     console.error('Failed to load hosting logs:', err)
  345:   } finally {
  346:     logsLoading.value = false
  347:   }
  348: }
  349: 
  350: async function loadWithdrawals(page = 1) {
  351:   withdrawalsLoading.value = true
  352:   try {
  353:     const res = await api.hosting.getWithdrawals({ 
  354:       page, 
  355:       pageSize: withdrawalsPageSize.value
  356:     })
  357:     withdrawals.value = res.records
  358:     withdrawalsTotal.value = res.total
  359:     withdrawalsPage.value = page
  360:   } catch (err) {
  361:     console.error('Failed to load withdrawals:', err)
  362:   } finally {
  363:     withdrawalsLoading.value = false
  364:   }
  365: }
  366: 
  367: async function loadBlocks() {
  368:   blocksLoading.value = true
  369:   try {
  370:     const res = await api.hosting.getBlocks()
  371:     blocks.value = res.blocks || []
  372:   } catch (err) {
  373:     console.error('Failed to load hosting blocks:', err)
  374:   } finally {
  375:     blocksLoading.value = false
  376:   }
  377: }
