  379: async function searchBlockCandidates() {
  380:   const keyword = blockSearch.value.trim()
  381:   if (keyword.length < 2) {
  382:     blockCandidates.value = []
  383:     return
  384:   }
  385: 
  386:   blockSearching.value = true
  387:   try {
  388:     const res = await api.hosting.searchBlockUsers(keyword)
  389:     blockCandidates.value = res.users || []
  390:   } catch (err: any) {
  391:     toast.error(err?.message || t('common.loadFailed'))
  392:   } finally {
  393:     blockSearching.value = false
  394:   }
  395: }
  396: 
  397: // æœç´¢
  398: function handleLogsSearch() {
  399:   logsSearch.value = logsSearchInput.value
  400:   loadLogs(1)
  401: }
  402: 
  403: // åˆ†é¡µ
  404: function handleLogsPageSizeChange() {
  405:   loadLogs(1)
  406: }
  407: 
  408: function handleWithdrawalsPageSizeChange() {
  409:   loadWithdrawals(1)
  410: }
  411: 
  412: function handleTabChange(tab: WalletTab) {
  413:   activeTab.value = tab
  414: 
  415:   if (tab === 'logs') {
  416:     loadLogs()
  417:   } else if (tab === 'withdrawals') {
  418:     loadWithdrawals()
  419:   } else if (tab === 'blocks') {
  420:     loadBlocks()
  421:   }
  422: }
  423: 
  424: function handleLogsFilterChange(filter: LogFilter) {
  425:   logsFilter.value = filter
  426:   loadLogs(1)
  427: }
