   14: export async function isUserBlockedByHoster(blockerId: number, blockedUserId: number, tx?: typeof prisma): Promise<boolean> {
   15:   if (blockerId === blockedUserId) {
   16:     return false
   17:   }
   18: 
   19:   const client = tx || prisma
   20:   const block = await client.hostingUserBlock.findUnique({
   21:     where: {
   22:       blockerId_blockedUserId: {
   23:         blockerId,
   24:         blockedUserId
   25:       }
   26:     },
   27:     select: { id: true }
   28:   })
   29: 
   30:   return !!block
   31: }
   32: 
   33: export async function isUserBlockedFromPackage(userId: number, packageId: number, tx?: typeof prisma): Promise<boolean> {
   34:   const client = tx || prisma
   35:   const pkg = await client.package.findUnique({
   36:     where: { id: packageId },
   37:     select: { userId: true }
   38:   })
   39: 
   40:   if (!pkg || pkg.userId === userId) {
   41:     return false
   42:   }
   43: 
   44:   return isUserBlockedByHoster(pkg.userId, userId, client)
   45: }
