   28: export async function tryAdvisoryTransactionLock(
   29:   tx: Prisma.TransactionClient,
   30:   namespace: number,
   31:   key: number
   32: ): Promise<boolean> {
   33:   const result = await tx.$queryRaw<Array<{ locked: boolean }>>(Prisma.sql`
   34:     SELECT pg_try_advisory_xact_lock(${namespace}, ${key}) AS locked
   35:   `)
   36: 
   37:   return result[0]?.locked === true
   38: }
   39: 
   40: export async function advisoryTransactionLock(
   41:   tx: Prisma.TransactionClient,
   42:   namespace: number,
   43:   key: number
   44: ): Promise<void> {
   45:   await tx.$queryRaw<Array<{ locked: boolean }>>(Prisma.sql`
   46:     WITH acquired_lock AS (
   47:       SELECT pg_advisory_xact_lock(${namespace}, ${key})
   48:     )
   49:     SELECT true AS locked FROM acquired_lock
   50:   `)
   51: }
   52: 
   53: export async function advisoryTransactionLockString(
   54:   tx: Prisma.TransactionClient,
   55:   namespace: number,
   56:   key: string
   57: ): Promise<void> {
   58:   await tx.$queryRaw<Array<{ locked: boolean }>>(Prisma.sql`
   59:     WITH acquired_lock AS (
   60:       SELECT pg_advisory_xact_lock(${namespace}, hashtext(${key}))
   61:     )
