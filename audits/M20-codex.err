  331: async function loadLogs(page = 1) {
  332:   logsLoading.value = true
  333:   try {
  334:     const res = await api.hosting.getLogs({ 
  335:       page, 
  336:       pageSize: logsPageSize.value,
  337:       search: logsSearch.value || undefined,
  338:       actionType: logsFilter.value !== 'all' ? logsFilter.value : undefined
  339:     })
  340:     logs.value = res.logs
  341:     logsTotal.value = res.total
  342:     logsPage.value = page
  343:   } catch (err) {
  344:     console.error('Failed to load hosting logs:', err)
  345:   } finally {
  346:     logsLoading.value = false
  347:   }
  348: }
