   40:   'completed'
   41: ])
   42: 
   43: function parsePositiveRouteId(value: string): number | null {
   44:   if (!POSITIVE_ROUTE_ID_PATTERN.test(value)) return null
   45:   const parsed = Number(value)
   46:   return Number.isSafeInteger(parsed) ? parsed : null
   47: }
   48: 
   49: function parsePositiveIntegerQuery(value: string | undefined, fallback: number): number {
   50:   if (!value || !POSITIVE_ROUTE_ID_PATTERN.test(value)) return fallback
   51:   const parsed = Number(value)
   52:   return Number.isSafeInteger(parsed) ? parsed : fallback
   53: }
   54: 
   55: function parseClampedPositiveIntegerQuery(value: string | undefined, fallback: number, max: number): number {
   56:   return Math.min(parsePositiveIntegerQuery(value, fallback), max)
   57: }
   58: 
   59: function normalizeHostingActionType(value: string | undefined): HostingActionType | undefined {
   60:   return value && HOSTING_ACTION_TYPES.has(value as HostingActionType)
   61:     ? value as HostingActionType
   62:     : undefined
   63: }
   64: 
   65: function normalizeWithdrawalStatus(value: string | undefined): WithdrawalStatus | undefined {
   66:   return value && WITHDRAWAL_STATUSES.has(value as WithdrawalStatus)
   67:     ? value as WithdrawalStatus
   68:     : undefined
   69: }
   70: 
   71: function normalizeSearch(value: string | undefined, maxLength: number): string | undefined {
   72:   const trimmed = value?.trim()
   73:   return trimmed ? trimmed.slice(0, maxLength) : undefined
   74: }
