  382:               total: roundMoney(availableBalance + frozenBalance),
  383:               historicalTotal: totalHostingIncome
  384:             },
  385:             hostCount: Number(owner.hostCount || 0),
  386:             listedPackageCount: Number(owner.listedPackageCount || 0),
  387:             instanceCount,
