   46: 
   47: const MAX_LOGO_URL_LENGTH = 2048
   48: const POSITIVE_ROUTE_ID_PATTERN = /^[1-9]\d*$/
   49: const HOSTING_OWNER_SORT_FIELDS = [
   50:   'vipLevel',
   51:   'hostingBalance',
   52:   'frozenBalance',
   53:   'totalIncome',
   54:   'hostCount',
   55:   'packageCount',
   56:   'instanceCount'
   57: ] as const
   58: 
   59: type HostingOwnerSortBy = typeof HOSTING_OWNER_SORT_FIELDS[number]
   60: type SortOrder = 'asc' | 'desc'
   61: 
   62: function toNumber(value: unknown): number {
   63:   if (value === null || value === undefined) return 0
   64:   if (typeof value === 'number') return value
   65:   if (typeof value === 'bigint') return Number(value)
   66:   return Number.parseFloat(String(value)) || 0
   67: }
   68: 
   69: function roundMoney(value: number): number {
   70:   return Number(value.toFixed(2))
   71: }
   72: 
   73: function parsePositiveRouteId(value: string): number | null {
   74:   if (!POSITIVE_ROUTE_ID_PATTERN.test(value)) return null
   75:   const parsed = Number(value)
   76:   return Number.isSafeInteger(parsed) ? parsed : null
   77: }
   78: 
   79: function parseBoundedInt(value: string | undefined, fallback: number, min: number, max: number): number {
   80:   const parsed = Number.parseInt(value || '', 10)
   81:   if (!Number.isFinite(parsed)) return fallback
   82:   return Math.min(max, Math.max(min, parsed))
   83: }
   84: 
   85: function normalizeHostingOwnerSortBy(value: string | undefined): HostingOwnerSortBy {
   86:   return HOSTING_OWNER_SORT_FIELDS.includes(value as HostingOwnerSortBy)
   87:     ? value as HostingOwnerSortBy
   88:     : 'totalIncome'
   89: }
   90: 
   91: function normalizeSortOrder(value: string | undefined): SortOrder {
   92:   return value === 'asc' ? 'asc' : 'desc'
   93: }
   94: 
   95: function buildHostingOwnerOrderSql(sortBy: HostingOwnerSortBy, sortOrder: SortOrder, vipRules: NormalizedVipRule[]): Prisma.Sql {
   96:   const direction = Prisma.raw(sortOrder === 'asc' ? 'ASC' : 'DESC')
   97:   const expression = (() => {
   98:     switch (sortBy) {
   99:       case 'vipLevel':
  100:         return buildHostingVipSql(vipRules)
  101:       case 'hostingBalance':
  102:         return Prisma.sql`"hostingBalance"`
  103:       case 'frozenBalance':
  104:         return Prisma.sql`"frozenBalance"`
  105:       case 'hostCount':
  106:         return Prisma.sql`"hostCount"`
  107:       case 'packageCount':
  108:         return Prisma.sql`"listedPackageCount"`
  109:       case 'instanceCount':
  110:         return Prisma.sql`"instanceCount"`
  111:       case 'totalIncome':
  112:       default:
  113:         return Prisma.sql`"totalHostingIncome"`
  114:     }
  115:   })()
  116: 
  117:   return Prisma.sql`ORDER BY ${expression} ${direction}, id ASC`
  118: }
