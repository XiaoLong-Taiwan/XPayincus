  486: // æ ¼å¼åŒ–å‡½æ•°
  487: function formatMoney(amount: number): string {
  488:   return `Â¥${amount.toFixed(2)}`
  489: }
  490: 
  491: function formatDate(dateStr: string): string {
  492:   return new Date(dateStr).toLocaleString()
  493: }
  494: 
  495: function formatShortDate(dateStr: string): string {
  496:   const date = new Date(dateStr)
  497:   return `${date.getMonth() + 1}/${date.getDate()} ${date.getHours().toString().padStart(2, '0')}:${date.getMinutes().toString().padStart(2, '0')}`
  498: }
  499: 
  500: function getActionTypeLabel(actionType: string | null): string {
  501:   if (!actionType) return '-'
  502:   const key = `hostingWallet.logs.actionTypes.${actionType}`
  503:   const label = t(key)
  504:   return label === key ? actionType : label
  505: }
  506: 
  507: function getStatusLabel(status: string): string {
  508:   const key = `hostingWallet.withdrawals.status.${status}`
  509:   const label = t(key)
  510:   return label === key ? status : label
  511: }
  512: 
  513: function getStatusClass(status: string): string {
  514:   const classes: Record<string, string> = {
  515:     pending: 'text-yellow-700 bg-yellow-100 dark:text-yellow-300 dark:bg-yellow-900/30',
  516:     approved: 'text-blue-700 bg-blue-100 dark:text-blue-300 dark:bg-blue-900/30',
  517:     rejected: 'text-red-700 bg-red-100 dark:text-red-300 dark:bg-red-900/30',
  518:     completed: 'text-green-700 bg-green-100 dark:text-green-300 dark:bg-green-900/30'
  519:   }
  520:   return classes[status] || 'text-gray-600 bg-gray-100'
  521: }
  522: 
  523: function getActionTypeBadgeClass(actionType: string | null): string {
  524:   const classes: Record<string, string> = {
  525:     purchase: 'badge-success',
  526:     renew: 'badge-info',
  527:     upgrade: 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300',
  528:     destroy: 'badge-error',
  529:     unfreeze: 'badge-warning',
  530:     withdraw: 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300',
  531:     admin_adjust: 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300'
  532:   }
  533:   return classes[actionType || ''] || 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300'
  534: }
  535: 
  536: function getMetricCardClass(tone: MetricTone): string {
  537:   const classes: Record<MetricTone, string> = {
  538:     default: 'border-themed bg-themed-tertiary',
  539:     success: 'border-emerald-500/15 bg-emerald-500/[0.06]',
  540:     warning: 'border-amber-500/15 bg-amber-500/[0.06]',
  541:     info: 'border-blue-500/15 bg-blue-500/[0.06]'
  542:   }
  543: 
  544:   return classes[tone]
  545: }
  546: 
  547: function getMetricValueClass(tone: MetricTone): string {
  548:   const classes: Record<MetricTone, string> = {
  549:     default: 'text-themed',
  550:     success: 'text-emerald-600 dark:text-emerald-300',
  551:     warning: 'text-amber-600 dark:text-amber-300',
  552:     info: 'text-blue-600 dark:text-blue-300'
  553:   }
  554: 
  555:   return classes[tone]
  556: }
  557: 
  558: function getFlowCardClass(index: number): string {
  559:   const classes = [
  560:     'border-blue-500/15 bg-blue-500/[0.04]',
  561:     'border-amber-500/15 bg-amber-500/[0.04]',
  562:     'border-emerald-500/15 bg-emerald-500/[0.04]'
  563:   ]
  564: 
  565:   return classes[index] || 'border-themed bg-themed-tertiary'
  566: }
  567: 
  568: function getFlowIndexClass(index: number): string {
  569:   const classes = [
  570:     'bg-accent text-white dark:text-black',
  571:     'bg-amber-500 text-white',
  572:     'bg-emerald-600 text-white dark:bg-emerald-500'
  573:   ]
  574: 
  575:   return classes[index] || 'bg-themed-secondary text-themed'
  576: }
  577: 
  578: onMounted(async () => {
  579:   loading.value = true
  580:   await Promise.all([loadBalance(), loadStats(), loadLogs(), loadWithdrawals(), configStore.loadPublicConfig()])
