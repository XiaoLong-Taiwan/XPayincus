   26: const POSITIVE_ROUTE_ID_PATTERN = /^[1-9]\d*$/
   27: const HOSTING_ACTION_TYPES = new Set<HostingActionType>([
   28:   'purchase',
   29:   'renew',
   30:   'upgrade',
   31:   'destroy',
