  177:     if (currentRequest === zonesRequestSeq) {
  178:       zonesLoading.value = false
  179:     }
  180:   }
  181: }
  182: 
  183: async function switchTab(tab: 'owners' | 'zones' | 'hostingVipLevels') {
  184:   activeTab.value = tab
  185:   if (tab === 'owners') {
  186:     await loadOwners()
  187:   } else if (tab === 'zones') {
  188:     page.value = 1
  189:     await Promise.all([loadOwners(), loadZones()])
  190:   }
  191: }
  192: 
  193: async function refreshActiveTab() {
  194:   if (activeTab.value === 'zones') {
  195:     await Promise.all([loadOwners(), loadZones()])
  196:   } else if (activeTab.value === 'owners') {
  197:     await loadOwners()
  198:   }
  199: }
  200: 
  201: function changePage(nextPage: number) {
  202:   const normalizedPage = Math.min(Math.max(1, nextPage), totalPages.value)
  203:   if (normalizedPage === page.value) return
  204:   page.value = normalizedPage
  205:   void loadOwners()
  206: }
  207: 
  208: function changePageSize() {
  209:   page.value = 1
  210:   void loadOwners()
  211: }
  212: 
  213: function toggleOwnerSort(column: HostingOwnerSortBy) {
  214:   if (sortBy.value === column) {
  215:     sortOrder.value = sortOrder.value === 'asc' ? 'desc' : 'asc'
  216:   } else {
  217:     sortBy.value = column
  218:     sortOrder.value = 'desc'
  219:   }
  220:   page.value = 1
  221:   void loadOwners()
  222: }
  223: 
  224: function getSortAria(column: HostingOwnerSortBy): 'ascending' | 'descending' | 'none' {
  225:   if (sortBy.value !== column) return 'none'
  226:   return sortOrder.value === 'asc' ? 'ascending' : 'descending'
  227: }
  228: 
  229: function isValidLogoUrl(value: string): boolean {
  230:   if (!value || value.length > 2048 || /\s/.test(value)) return false
  231:   try {
  232:     const url = new URL(value)
  233:     return (url.protocol === 'http:' || url.protocol === 'https:') && !!url.hostname && !url.username && !url.password
  234:   } catch {
  235:     return false
  236:   }
  237: }
  238: 
  239: async function createZone() {
  240:   const name = zoneForm.value.name.trim()
  241:   const ownerId = zoneForm.value.ownerId
  242:   const logoUrl = zoneForm.value.logoUrl.trim()
  243: 
  244:   if (!name || !ownerId || !logoUrl) {
  245:     toast.error(t('admin.hosting.zones.formRequired'))
  246:     return
  247:   }
  248:   if (!isValidLogoUrl(logoUrl)) {
  249:     toast.error(t('admin.hosting.zones.logoInvalid'))
  250:     return
  251:   }
  252: 
  253:   creatingZone.value = true
  254:   try {
  255:     await api.admin.createHostingZone({ name, ownerId, logoUrl })
  256:     toast.success(t('admin.hosting.zones.createSuccess'))
  257:     zoneForm.value = { name: '', ownerId: null, logoUrl: '' }
  258:     await Promise.all([loadOwners(), loadZones()])
  259:   } catch (error: any) {
  260:     toast.error(error?.message || t('admin.hosting.zones.createFailed'))
  261:   } finally {
  262:     creatingZone.value = false
  263:   }
  264: }
  265: 
  266: async function deleteZone(zone: HostingZone) {
  267:   if (!window.confirm(t('admin.hosting.zones.deleteConfirm', { name: zone.name }))) return
  268:   deletingZoneId.value = zone.id
  269:   try {
  270:     await api.admin.deleteHostingZone(zone.id)
  271:     toast.success(t('admin.hosting.zones.deleteSuccess'))
  272:     await Promise.all([loadOwners(), loadZones()])
  273:   } catch (error: any) {
  274:     toast.error(error?.message || t('admin.hosting.zones.deleteFailed'))
  275:   } finally {
  276:     deletingZoneId.value = null
  277:   }
  278: }
  279: 
  280: function formatMoney(value: number): string {
  281:   return moneyFormatter.value.format(value || 0)
  282: }
  283: 
  284: function formatDate(value: string): string {
  285:   if (!value) return '-'
  286:   return dateTimeFormatter.value.format(new Date(value))
  287: }
  288: </script>
