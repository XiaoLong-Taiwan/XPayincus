  429: // æçŽ°
  430: async function submitWithdraw() {
  431:   if (!config.value) return
  432:   
  433:   if (withdrawForm.value.amount < config.value.minWithdrawalAmount) {
  434:     toast.error(t('hostingWallet.errors.minAmount', { amount: formatMoney(config.value.minWithdrawalAmount) }))
  435:     return
  436:   }
  437:   
  438:   if (balance.value && withdrawForm.value.amount > balance.value.available) {
  439:     toast.error(t('hostingWallet.errors.exceedBalance'))
  440:     return
  441:   }
  442:   
  443:   withdrawing.value = true
  444:   try {
  445:     const res = await api.hosting.withdraw({
  446:       amount: withdrawForm.value.amount
  447:     })
  448:     toast.success(res.message)
  449:     showWithdrawModal.value = false
  450:     await Promise.all([loadBalance(), loadLogs(), loadWithdrawals()])
  451:   } catch (err: any) {
  452:     toast.error(err?.message || t('common.error'))
  453:   } finally {
  454:     withdrawing.value = false
  455:   }
  456: }
  457: 
  458: async function blockUser(userId: number) {
  459:   blockActionLoading.value = userId
  460:   try {
  461:     await api.hosting.blockUser({ userId })
  462:     toast.success(t('hostingWallet.blocks.blockSuccess'))
  463:     blockCandidates.value = blockCandidates.value.map(user => user.id === userId ? { ...user, blocked: true } : user)
  464:     await loadBlocks()
  465:   } catch (err: any) {
  466:     toast.error(err?.message || t('common.error'))
  467:   } finally {
  468:     blockActionLoading.value = null
  469:   }
  470: }
  471: 
  472: async function unblockUser(userId: number) {
  473:   blockActionLoading.value = userId
  474:   try {
  475:     await api.hosting.unblockUser(userId)
  476:     toast.success(t('hostingWallet.blocks.unblockSuccess'))
  477:     blocks.value = blocks.value.filter(block => block.blockedUserId !== userId)
  478:     blockCandidates.value = blockCandidates.value.map(user => user.id === userId ? { ...user, blocked: false } : user)
  479:   } catch (err: any) {
  480:     toast.error(err?.message || t('common.error'))
  481:   } finally {
  482:     blockActionLoading.value = null
  483:   }
  484: }
