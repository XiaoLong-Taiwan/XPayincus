  474: function normalizePackageHostIds(input: Record<string, unknown>, requireHostIds: boolean): number[] | undefined {
  475:   const value = input.hostIds
  476:   if (value === undefined) {
  477:     if (requireHostIds) {
  478:       throw apiError(ErrorCode.VALIDATION_ERROR, 'Package must bind at least one host')
  479:     }
  480:     return undefined
  481:   }
  482:   if (!Array.isArray(value) || value.length === 0 || value.length > MAX_PACKAGE_HOST_BINDINGS) {
  483:     throw apiError(ErrorCode.VALIDATION_ERROR, 'Package must bind at least one host')
  484:   }
  485: 
  486:   const uniqueIds = new Set<number>()
  487:   for (const hostId of value) {
  488:     if (typeof hostId !== 'number' || !Number.isSafeInteger(hostId) || hostId <= 0 || uniqueIds.has(hostId)) {
  489:       throw apiError(ErrorCode.VALIDATION_ERROR, 'Invalid package host IDs')
  490:     }
  491:     uniqueIds.add(hostId)
  492:   }
  493:   return [...uniqueIds]
  494: }
  495: 
  496: function normalizePackageHostStoragePools(input: Record<string, unknown>): Record<string, string | null> | undefined {
  497:   const value = input.hostStoragePools
  498:   if (value === undefined) return undefined
  499:   if (!isPlainRecord(value)) {
  500:     throw apiError(ErrorCode.VALIDATION_ERROR, 'hostStoragePools 无效')
  501:   }
  502: 
  503:   const normalized: Record<string, string | null> = {}
  504:   for (const [hostIdKey, poolName] of Object.entries(value)) {
  505:     if (!POSITIVE_ROUTE_ID_PATTERN.test(hostIdKey)) {
  506:       throw apiError(ErrorCode.VALIDATION_ERROR, 'hostStoragePools 包含无效宿主机 ID')
  507:     }
  508:     const hostId = Number(hostIdKey)
  509:     if (!Number.isSafeInteger(hostId)) {
  510:       throw apiError(ErrorCode.VALIDATION_ERROR, 'hostStoragePools 包含无效宿主机 ID')
  511:     }
  512:     if (poolName === null) {
  513:       normalized[String(hostId)] = null
  514:       continue
  515:     }
  516:     if (typeof poolName !== 'string') {
  517:       throw apiError(ErrorCode.VALIDATION_ERROR, '存储池名称无效')
  518:     }
  519:     const trimmed = poolName.trim()
  520:     if (
  521:       trimmed.length > MAX_PACKAGE_STORAGE_POOL_NAME_LENGTH ||
  522:       removeDangerousChars(trimmed) !== trimmed
  523:     ) {
  524:       throw apiError(ErrorCode.VALIDATION_ERROR, '存储池名称无效')
  525:     }
  526:     normalized[String(hostId)] = trimmed || null
  527:   }
  528:   return normalized
  529: }
  530: 
  531: function normalizePackageHostTrafficMultipliers(input: Record<string, unknown>): Record<string, number> | undefined {
  532:   const value = input.hostTrafficMultipliers
  533:   if (value === undefined) return undefined
  534:   if (!isPlainRecord(value)) {
  535:     throw apiError(ErrorCode.VALIDATION_ERROR, 'hostTrafficMultipliers 无效')
  536:   }
  537: 
  538:   const normalized: Record<string, number> = {}
  539:   for (const [hostIdKey, multiplier] of Object.entries(value)) {
  540:     if (!POSITIVE_ROUTE_ID_PATTERN.test(hostIdKey)) {
  541:       throw apiError(ErrorCode.VALIDATION_ERROR, 'hostTrafficMultipliers 包含无效宿主机 ID')
  542:     }
  543:     const hostId = Number(hostIdKey)
  544:     if (!Number.isSafeInteger(hostId)) {
  545:       throw apiError(ErrorCode.VALIDATION_ERROR, 'hostTrafficMultipliers 包含无效宿主机 ID')
  546:     }
  547:     try {
  548:       normalized[String(hostId)] = normalizeTrafficMultiplier(multiplier)
  549:     } catch {
  550:       throw apiError(ErrorCode.VALIDATION_ERROR, '流量倍率必须在 0.001-100 之间')
  551:     }
  552:   }
  553:   return normalized
  554: }
  555: 
  556: function normalizePackageInput(input: unknown, options: { requireAll: boolean }): NormalizedPackageInput {
  557:   if (!isPlainRecord(input)) {
  558:     throw apiError(ErrorCode.VALIDATION_ERROR, '请求参数无效')
  559:   }
  560: 
  561:   if (options.requireAll) {
  562:     for (const field of ['name', 'cpuMax', 'memoryMax', 'diskMax'] as const) {
  563:       if (input[field] === undefined) {
  564:         throw apiError(ErrorCode.VALIDATION_ERROR, '请填写所有必填字段')
  565:       }
  566:     }
  567:   }
  568: 
  569:   const normalized: NormalizedPackageInput = {}
  570: 
  571:   if (input.name !== undefined) {
  572:     const nameValidation = validateName(input.name as string, 'Package name', 2, 64)
  573:     if (!nameValidation.valid) {
  574:       throw apiError(ErrorCode.VALIDATION_ERROR, nameValidation.message)
  575:     }
  576:     normalized.name = nameValidation.sanitized!
  577:   }
  578: 
  579:   if (input.description !== undefined) {
  580:     if (typeof input.description !== 'string') {
  581:       throw apiError(ErrorCode.VALIDATION_ERROR, 'Package description 无效')
  582:     }
  583:     const descValidation = validateText(input.description as string, 'Package description', 500)
  584:     if (!descValidation.valid) {
  585:       throw apiError(ErrorCode.VALIDATION_ERROR, descValidation.message)
  586:     }
  587:     normalized.description = descValidation.sanitized ?? ''
  588:   }
  589: 
  590:   normalized.cpuMax = optionalPackageInteger(input, 'cpuMax', 'CPU', 15, 10000)
  591:   normalized.memoryMax = optionalPackageInteger(input, 'memoryMax', '内存', 128, 1048576)
  592:   normalized.diskMax = optionalPackageInteger(input, 'diskMax', '磁盘', 512, 104857600)
  593:   normalized.bandwidthMax = optionalPackageInteger(input, 'bandwidthMax', '带宽', 0, POSTGRES_INT_MAX)
  594:   normalized.networkMode = optionalPackageEnum(input, 'networkMode', '网络模式', ACTIVE_PACKAGE_NETWORK_MODES)
  595:   normalized.instanceType = optionalPackageEnum(input, 'instanceType', '实例类型', ['container', 'vm'])
  596:   normalized.hostIds = normalizePackageHostIds(input, options.requireAll)
  597:   normalized.hostStoragePools = normalizePackageHostStoragePools(input)
  598:   normalized.hostTrafficMultipliers = normalizePackageHostTrafficMultipliers(input)
  599:   normalized.privileged = optionalPackageBoolean(input, 'privileged', 'privileged')
  600:   normalized.nested = optionalPackageBoolean(input, 'nested', 'nested')
  601:   normalized.active = optionalPackageBoolean(input, 'active', 'active')
  602:   normalized.monthlyTrafficLimit = optionalPackageNullableString(input, 'monthlyTrafficLimit', '月流量限制', 64)
  603:   normalized.trafficResetPrice = optionalMoneyCents(input, 'trafficResetPrice', '流量重置价格', MAX_TRAFFIC_RESET_PRICE_CENTS) as number | undefined
  604:   normalized.portLimit = optionalPackageInteger(input, 'portLimit', '端口映射数', 1, POSTGRES_INT_MAX)
  605:   normalized.snapshotLimit = optionalPackageInteger(input, 'snapshotLimit', '快照数', 0, POSTGRES_INT_MAX)
  606:   normalized.backupLimit = optionalPackageInteger(input, 'backupLimit', '备份数', 0, POSTGRES_INT_MAX)
  607:   normalized.siteLimit = optionalPackageInteger(input, 'siteLimit', '反代站点数', 0, POSTGRES_INT_MAX)
  608:   normalized.ioLimitMode = optionalPackageEnum(input, 'ioLimitMode', 'I/O限制模式', ['throughput', 'iops'])
  609:   normalized.limitsRead = optionalPackageText(input, 'limitsRead', '读取限制', MAX_PACKAGE_LIMIT_STRING_LENGTH)
  610:   normalized.limitsWrite = optionalPackageText(input, 'limitsWrite', '写入限制', MAX_PACKAGE_LIMIT_STRING_LENGTH)
  611:   normalized.limitsReadIops = optionalPackageInteger(input, 'limitsReadIops', '读取 IOPS', 0, POSTGRES_INT_MAX)
  612:   normalized.limitsWriteIops = optionalPackageInteger(input, 'limitsWriteIops', '写入 IOPS', 0, POSTGRES_INT_MAX)
  613:   normalized.limitsIngress = optionalPackageText(input, 'limitsIngress', '入站带宽限制', MAX_PACKAGE_LIMIT_STRING_LENGTH)
  614:   normalized.limitsEgress = optionalPackageText(input, 'limitsEgress', '出站带宽限制', MAX_PACKAGE_LIMIT_STRING_LENGTH)
  615:   normalized.limitsProcesses = optionalPackageInteger(input, 'limitsProcesses', '进程限制', 0, POSTGRES_INT_MAX)
  616:   normalized.limitsCpuPriority = optionalPackageInteger(input, 'limitsCpuPriority', 'CPU优先级', 0, 10)
  617:   normalized.bootAutostart = optionalPackageBoolean(input, 'bootAutostart', 'bootAutostart')
  618:   normalized.bootAutostartPriority = optionalPackageInteger(input, 'bootAutostartPriority', '启动优先级', 0, 100)
  619:   normalized.bootAutostartDelay = optionalPackageInteger(input, 'bootAutostartDelay', '启动延迟', 5, 600)
  620:   normalized.bootHostShutdownTimeout = optionalPackageInteger(input, 'bootHostShutdownTimeout', '关机超时', 30, 600)
  621:   normalized.globalShared = optionalPackageBoolean(input, 'globalShared', 'globalShared')
  622:   if (input.globalQuotaMultiplier !== undefined) {
  623:     if (input.globalQuotaMultiplier !== null && typeof input.globalQuotaMultiplier !== 'number') {
  624:       throw apiError(ErrorCode.VALIDATION_ERROR, '全局配额倍数无效')
  625:     }
  626:     normalized.globalQuotaMultiplier = null
  627:   }
  628:   normalized.globalMaxInstances = input.globalMaxInstances === undefined
  629:     ? undefined
  630:     : input.globalMaxInstances === null
  631:       ? null
  632:       : requirePackageInteger(input.globalMaxInstances, '公开套餐最大实例数', PUBLIC_PACKAGE_MAX_INSTANCES_MIN, PUBLIC_PACKAGE_MAX_INSTANCES_MAX)
  633:   normalized.requiredPackageId = normalizePackageRequiredId(input.requiredPackageId)
  634: 
  635:   return normalized
  636: }
  637: 
  638: function normalizePackageShareQuotaMultiplier(value: unknown): number | null | undefined {
  639:   if (value === undefined) return undefined
  640:   if (value === null) return null
  641:   if (typeof value !== 'number' || !Number.isFinite(value)) {
  642:     throw apiError(ErrorCode.VALIDATION_ERROR, '配额倍数必须为数字')
  643:   }
  644:   if (value < 0.1 || value > 99.9) {
  645:     throw apiError(ErrorCode.VALIDATION_ERROR, '配额倍数必须在 0.1-99.9 之间')
  646:   }
  647:   const rounded = Math.round(value * 10) / 10
  648:   if (Math.abs(value - rounded) > 1e-8) {
  649:     throw apiError(ErrorCode.VALIDATION_ERROR, '配额倍数最多支持一位小数')
  650:   }
  651:   return rounded
  652: }
  653: 
  654: function normalizePackageShareMaxInstances(value: unknown): number | null | undefined {
  655:   if (value === undefined) return undefined
  656:   if (value === null) return null
  657:   return requirePackageInteger(value, '共享最大实例数', 0, MAX_PACKAGE_HOST_BINDINGS)
  658: }
  659: 
  660: function normalizePackageShareInput(input: unknown, options: { requireFriendId: boolean }): NormalizedPackageShareInput {
  661:   if (!isPlainRecord(input)) {
  662:     throw apiError(ErrorCode.VALIDATION_ERROR, '请求参数无效')
  663:   }
  664: 
  665:   const normalized: NormalizedPackageShareInput = {}
  666:   if (options.requireFriendId) {
  667:     normalized.friendId = requirePackageInteger(input.friendId, '好友 ID', 1, Number.MAX_SAFE_INTEGER)
  668:   } else if (input.friendId !== undefined) {
  669:     throw apiError(ErrorCode.VALIDATION_ERROR, '请求参数无效')
  670:   }
  671: 
  672:   normalized.quotaMultiplier = normalizePackageShareQuotaMultiplier(input.quotaMultiplier)
  673:   normalized.maxInstances = normalizePackageShareMaxInstances(input.maxInstances)
  674:   return normalized
  675: }
  676: 
  677: function validatePublicPackageMaxInstances(value: unknown): value is number {
  678:   return typeof value === 'number' &&
  679:     Number.isInteger(value) &&
  680:     value >= PUBLIC_PACKAGE_MAX_INSTANCES_MIN &&
  681:     value <= PUBLIC_PACKAGE_MAX_INSTANCES_MAX
  682: }
  683: 
  684: function normalizePublicPackageMaxInstances(value: unknown): number {
  685:   return validatePublicPackageMaxInstances(value) ? value : PUBLIC_PACKAGE_MAX_INSTANCES_MIN
  686: }
  687: 
  688: function getPackagePrerequisiteFields(pkg: { requiredPackageId?: number | null; requiredPackageName?: string | null; required_package_id?: number | null; required_package_name?: string | null }) {
  689:   return {
  690:     required_package_id: pkg.requiredPackageId ?? pkg.required_package_id ?? null,
  691:     required_package_name: pkg.requiredPackageName ?? pkg.required_package_name ?? null
  692:   }
  693: }
  694: 
  695: const PACKAGE_PREREQUISITE_ERROR_CODES = new Set([
  696:   'PACKAGE_PREREQUISITE_INVALID',
  697:   'PACKAGE_PREREQUISITE_SELF',
  698:   'PACKAGE_PREREQUISITE_CYCLE',
  699:   'PACKAGE_PREREQUISITE_SCOPE'
  700: ])
  701: 
  702: function getPackagePrerequisiteError(error: unknown): { code: string; message: string } | null {
  703:   const message = error instanceof Error ? error.message : String(error)
  704:   const separatorIndex = message.indexOf(':')
  705:   if (separatorIndex <= 0) return null
  706: 
  707:   const code = message.slice(0, separatorIndex)
  708:   if (!PACKAGE_PREREQUISITE_ERROR_CODES.has(code)) return null
  709: 
  710:   return {
  711:     code,
  712:     message: message.slice(separatorIndex + 1).trim() || code
  713:   }
  714: }
  715: 
  716: async function shouldSyncPackageTrafficLimitsAfterUpdate(
  717:   packageId: number,
  718:   currentPackage: {
  719:     monthly_traffic_limit?: string | null
  720:     host_ids?: number[]
  721:     host_traffic_multipliers?: Record<string, number>
  722:   },
  723:   updates: {
  724:     monthlyTrafficLimit?: bigint | null
  725:     hostIds?: number[]
  726:     hostTrafficMultipliers?: Record<string, number | string | null>
  727:   }
  728: ): Promise<boolean> {
  729:   if (updates.monthlyTrafficLimit !== undefined) {
  730:     const currentLimit = currentPackage.monthly_traffic_limit ? BigInt(currentPackage.monthly_traffic_limit) : null
  731:     const nextLimit = updates.monthlyTrafficLimit
  732:     if (currentLimit !== nextLimit) {
  733:       return true
  734:     }
  735:   }
  736: 
  737:   if (updates.hostIds === undefined && updates.hostTrafficMultipliers === undefined) {
  738:     return false
  739:   }
  740: 
  741:   const instanceHosts = await prisma.instance.findMany({
  742:     where: {
  743:       packageId,
  744:       status: { not: 'deleted' }
  745:     },
  746:     select: { hostId: true },
  747:     distinct: ['hostId']
  748:   })
  749:   if (instanceHosts.length === 0) {
  750:     return false
  751:   }
  752: 
  753:   const currentHostIds = new Set(currentPackage.host_ids || [])
  754:   const nextHostIds = updates.hostIds !== undefined ? new Set(updates.hostIds) : currentHostIds
  755:   const currentMultipliers = currentPackage.host_traffic_multipliers || {}
  756:   const nextMultipliers = updates.hostTrafficMultipliers || {}
  757: 
  758:   for (const { hostId } of instanceHosts) {
  759:     const explicitMultiplierUpdate = Object.prototype.hasOwnProperty.call(nextMultipliers, String(hostId))
  760:     if (!explicitMultiplierUpdate && (updates.hostIds === undefined || !nextHostIds.has(hostId))) {
  761:       continue
  762:     }
  763: 
  764:     const currentMultiplier = currentHostIds.has(hostId)
  765:       ? normalizeTrafficMultiplier(currentMultipliers[String(hostId)] ?? 1)
  766:       : 1
  767:     const nextMultiplier = explicitMultiplierUpdate
  768:       ? normalizeTrafficMultiplier(nextMultipliers[String(hostId)])
  769:       : currentMultiplier
  770: 
  771:     if (currentMultiplier !== nextMultiplier) {
  772:       return true
  773:     }
  774:   }
  775: 
  776:   return false
  777: }
  778: 
  779: export default async function packageRoutes(fastify: FastifyInstance) {
  780:   // ==================== 公开 API（无需登录） ====================
  781:   
  782:   /**
  783:    * 公开获取套餐列表（用于门户市场页面，未登录用户可访问）
  784:    * 只返回已启用的公开套餐（官方直营 + 托管市场）
  785:    */
  786:   fastify.get<{ Querystring: { source?: string } }>('/public', {
  787:     config: { rateLimit: { max: 60, timeWindow: '1 minute' } }  // 公开接口需要限流
  788:   }, async (request: FastifyRequest<{ Querystring: { source?: string } }>) => {
  789:     const source = request.query.source || 'all'
  790:     const zoneOwnerIds = await packageShares.getActiveHostingZoneOwnerIds()
  791:     
  792:     // 构建查询条件
  793:     const where: any = {
  794:       active: true,        // 只返回已启用的套餐
  795:       globalShared: true   // 只返回公开套餐
  796:     }
  797:     
  798:     // 根据 source 过滤
  799:     if (source === 'official') {
  800:       where.user = { role: 'admin' }  // 管理员创建的套餐为官方直营
  801:     } else if (source === 'market') {
  802:       where.user = { role: { not: 'admin' } }  // 普通用户的套餐为托管市场
  803:       if (zoneOwnerIds.length > 0) {
  804:         where.userId = { notIn: zoneOwnerIds }
  805:       }
  806:     } else if (zoneOwnerIds.length > 0) {
  807:       where.userId = { notIn: zoneOwnerIds }
  808:     }
  809:     
  810:     const packages = await prisma.package.findMany({
  811:       where,
  812:       select: {
  813:         id: true,
  814:         userId: true,
  815:         name: true,
  816:         description: true,
  817:         cpuMax: true,
  818:         memoryMax: true,
  819:         diskMax: true,
  820:         monthlyTrafficLimit: true,
  821:         trafficResetPrice: true,
  822:         networkMode: true,
  823:         instanceType: true,
  824:         privileged: true,
  825:         nested: true,
  826:         // 公开套餐的额外配置
  827:         globalMaxInstances: true,
  828:         user: {
  829:           select: {
  830:             role: true
  831:           }
  832:         },
  833:         // 获取绑定的宿主机关系
  834:         packageHosts: {
  835:           select: {
  836:             hostId: true
  837:           }
  838:         }
  839:         // 不返回敏感字段：I/O限制、起动参数等
  840:       },
  841:       orderBy: { name: 'asc' }
  842:     })
  843:     
  844:     const checkoutExtensionTargets = await listEnabledServiceExtensionTargets('checkoutConfig')
  845: 
  846:     // 查询每个套餐是否有定价方案，并计算售罄状态
  847:     const packagesWithDetails = await Promise.all(packages.map(async (pkg) => {
  848:       // 获取套餐的定价方案
  849:       const plans = await prisma.packagePlan.findMany({
  850:         where: { packageId: pkg.id, isActive: true },
  851:         select: {
  852:           id: true,
  853:           name: true,
  854:           description: true,
  855:           cpu: true,
  856:           memory: true,
  857:           disk: true,
  858:           portLimit: true,
  859:           snapshotLimit: true,
  860:           backupLimit: true,
  861:           siteLimit: true,
  862:           swapSize: true,
  863:           trafficLimit: true,
  864:           trafficLimitSpeed: true,
  865:           price: true,
  866:           billingCycle: true,
  867:           setupFee: true,
  868:           isSoldOut: true,
  869:           slaGuarantee: true,
  870:           sortOrder: true
  871:         },
  872:         orderBy: { sortOrder: 'asc' }
  873:       })
  874:       
  875:       const isPaid = plans.length > 0
  876:       const availablePlans = plans.filter(plan => !plan.isSoldOut)
  877:       const hostIds = pkg.packageHosts.map(ph => ph.hostId)
  878:       
  879:       // 检查是否售罄（所有绑定的宿主机资源不足）
  880:       let soldOut = isPaid && availablePlans.length === 0
  881:       if (hostIds.length > 0) {
  882:         const hosts = await prisma.host.findMany({
  883:           where: { id: { in: hostIds }, status: 'online' },
  884:           select: { id: true, cpuAllowanceMax: true, memoryMax: true, cpuUsed: true, memoryUsed: true }
  885:         })
  886:         
  887:         // 如果没有在线的宿主机，则售罄
  888:         if (hosts.length === 0) {
  889:           soldOut = true
  890:         } else if (!soldOut) {
  891:           // 检查是否所有宿主机资源都不足
  892:           const minCpu = isPaid ? Math.min(...availablePlans.map(plan => plan.cpu)) : 15
  893:           const minMemory = isPaid ? Math.min(...availablePlans.map(plan => plan.memory)) : 128
  894:           
  895:           const hasAvailable = hosts.some(h => {
  896:             const cpuAvailable = (h.cpuAllowanceMax || 0) - (h.cpuUsed || 0) >= minCpu
  897:             const memoryAvailable = (h.memoryMax || 0) - (h.memoryUsed || 0) >= minMemory
  898:             return cpuAvailable && memoryAvailable
  899:           })
  900:           
  901:           soldOut = !hasAvailable
  902:         }
  903:       } else {
  904:         // 没有绑定宿主机，视为售罄
  905:         soldOut = true
  906:       }
  907:       
  908:       // 判断是否为托管市场套餐
  909:       const sourceType = pkg.user.role === 'admin' ? 'official' : 'market'
  910:       const checkoutExtensions = checkoutExtensionTargets.filter(target =>
  911:         target.productId === null || target.productId === String(pkg.id)
  912:       )
  913:       
  914:       return {
  915:         id: pkg.id,
  916:         name: pkg.name,
  917:         description: pkg.description,
  918:         cpu_max: pkg.cpuMax,
  919:         memory_max: pkg.memoryMax,
  920:         disk_max: pkg.diskMax,
  921:         monthly_traffic_limit: pkg.monthlyTrafficLimit?.toString() || null,
  922:         traffic_reset_price: Number(pkg.trafficResetPrice),
  923:         network_mode: pkg.networkMode,
  924:         instance_type: pkg.instanceType,
  925:         host_ids: hostIds,
  926:         privileged: pkg.privileged,
  927:         nested: pkg.nested,
  928:         global_quota_multiplier: null,
  929:         global_max_instances: normalizePublicPackageMaxInstances(pkg.globalMaxInstances),
  930:         required_package_id: null,
  931:         required_package_name: null,
  932:         sourceType,
  933:         checkoutExtensions,
  934:         soldOut,
  935:         isPaid,
  936:         plans: plans.map(p => ({
  937:           id: p.id,
  938:           name: p.name,
  939:           description: p.description,
  940:           cpu: p.cpu,
  941:           memory: p.memory,
  942:           disk: p.disk,
  943:           portLimit: p.portLimit,
  944:           snapshotLimit: p.snapshotLimit,
  945:           backupLimit: p.backupLimit,
  946:           siteLimit: p.siteLimit,
  947:           swapSize: pkg.instanceType === 'vm' ? 0 : p.swapSize,
  948:           trafficLimit: p.trafficLimit?.toString() || null,
  949:           trafficLimitSpeed: p.trafficLimitSpeed,
  950:           price: p.price,
  951:           billingCycle: p.billingCycle,
  952:           setupFee: p.setupFee,
  953:           isSoldOut: p.isSoldOut,
  954:           slaGuarantee: p.slaGuarantee,
  955:           monthlyPrice: Number(p.price) / (p.billingCycle || 1)
  956:         }))
  957:       }
  958:     }))
  959:     
  960:     // 售罄的套餐排在最后
  961:     packagesWithDetails.sort((a, b) => {
  962:       if (a.soldOut === b.soldOut) return 0
  963:       return a.soldOut ? 1 : -1
  964:     })
  965:     
  966:     return {
  967:       packages: packagesWithDetails,
  968:       total: packagesWithDetails.length
  969:     }
  970:   })
  971: 
  972:   /**
  973:    * 公开获取地区列表（用于门户市场页面）
  974:    */
  975:   fastify.get<{ Querystring: { source?: string } }>('/public/regions', {
  976:     config: { rateLimit: { max: 60, timeWindow: '1 minute' } }
  977:   }, async (request: FastifyRequest<{ Querystring: { source?: string } }>) => {
  978:     const source = request.query.source || 'all'
  979:     const zoneOwnerIds = await packageShares.getActiveHostingZoneOwnerIds()
  980:     
  981:     // 构建查询条件
  982:     const where: any = {
  983:       active: true,
  984:       globalShared: true
  985:     }
  986:     
  987:     if (source === 'official') {
  988:       where.user = { role: 'admin' }
  989:     } else if (source === 'market') {
  990:       where.user = { role: { not: 'admin' } }
  991:       if (zoneOwnerIds.length > 0) {
  992:         where.userId = { notIn: zoneOwnerIds }
  993:       }
  994:     } else if (zoneOwnerIds.length > 0) {
  995:       where.userId = { notIn: zoneOwnerIds }
  996:     }
  997:     
  998:     // 获取所有符合条件的套餐及其绑定的宿主机
  999:     const packages = await prisma.package.findMany({
 1000:       where,
 1001:       select: {
 1002:         id: true,
 1003:         packageHosts: {
 1004:           select: {
 1005:             hostId: true
 1006:           }
 1007:         }
 1008:       }
 1009:     })
 1010:     
 1011:     // 收集所有宿主机 ID
 1012:     const allHostIds = new Set<number>()
 1013:     packages.forEach(pkg => {
 1014:       pkg.packageHosts.forEach(ph => allHostIds.add(ph.hostId))
 1015:     })
 1016:     
 1017:     // 获取宿主机信息
 1018:     const hosts = await prisma.host.findMany({
 1019:       where: { id: { in: Array.from(allHostIds) }, status: 'online' },
 1020:       select: {
 1021:         id: true,
 1022:         countryCode: true,
 1023:         location: true
 1024:       }
 1025:     })
 1026:     
 1027:     // 按地区分组
 1028:     const regionMap = new Map<string, { name: string; packageIds: Set<number>; hostIds: Set<number> }>()
 1029:     
 1030:     packages.forEach(pkg => {
 1031:       pkg.packageHosts.forEach(ph => {
 1032:         const host = hosts.find(h => h.id === ph.hostId)
 1033:         if (host) {
 1034:           const code = host.countryCode?.toUpperCase() || 'UNKNOWN'
 1035:           if (!regionMap.has(code)) {
 1036:             regionMap.set(code, {
 1037:               name: host.location || code,
 1038:               packageIds: new Set(),
 1039:               hostIds: new Set()
 1040:             })
 1041:           }
 1042:           const region = regionMap.get(code)!
 1043:           region.packageIds.add(pkg.id)
 1044:           region.hostIds.add(ph.hostId)
 1045:         }
 1046:       })
 1047:     })
 1048:     
 1049:     // 转换为数组格式
 1050:     const regions = Array.from(regionMap.entries()).map(([code, data]) => ({
 1051:       code,
 1052:       name: data.name,
 1053:       packageIds: Array.from(data.packageIds),
 1054:       hostCount: data.hostIds.size
 1055:     }))
 1056:     
 1057:     // 按名称排序
 1058:     regions.sort((a, b) => a.name.localeCompare(b.name, 'zh'))
 1059:     
 1060:     return { regions }
 1061:   })
 1062: 
 1063:   // ==================== 需要登录的 API ====================
 1064: 
 1065:   // 获取套餐列表
 1066:   // 查询参数：
 1067:   // - all=true: 返回所有套餐（包括停用/归档的），用于套餐管理页面
 1068:   // - source: 套餐来源过滤，可选值：official（面板直营）、zone（托管专区）、market（托管市场）、friends（好友共享）
 1069:   // - zoneId: source=zone 时指定托管专区 ID
 1070:   //           不传或传 all 时返回全部（保持向后兼容）
 1071:   // - scope: 管理员专用，mine(我的) / official(自营) / hosted(托管的)
 1072:   // - userId: 管理员专用，筛选特定用户（仅 scope=hosted 时有效）
 1073:   fastify.get<{ Querystring: { all?: string; source?: string; zoneId?: string; scope?: string; userId?: string } }>('/', {
 1074:     onRequest: [fastify.authenticate]
 1075:   }, async (request: FastifyRequest<{ Querystring: { all?: string; source?: string; zoneId?: string; scope?: string; userId?: string } }>, reply: FastifyReply) => {
 1076:     const { user } = request
 1077:     // all=true 时返回所有套餐（用于套餐管理页面），否则只返回启用的套餐（用于创建实例页面）
 1078:     const activeOnly = request.query.all !== 'true'
 1079:     const source = request.query.source || 'all'
 1080:     const scope = request.query.scope
 1081:     const filterUserId = request.query.userId
 1082:     const isAdmin = user.role === 'admin'
 1083: 
 1084:     // 管理员专用：scope 参数处理
 1085:     if (isAdmin && scope) {
 1086:       if (scope === 'mine') {
 1087:         // 查看自己的套餐
 1088:         const ownPackages = await db.getAllPackages(activeOnly, { userId: user.id })
 1089:         const packageIds = ownPackages.map(p => p.id)
 1090:         const [soldOutMap, instanceCountMap] = await Promise.all([
 1091:           db.checkPackagesSoldOut(packageIds),
 1092:           db.getNormalInstanceCountsByPackages(packageIds)
 1093:         ])
 1094:         return {
 1095:           packages: ownPackages.map(p => ({
 1096:             ...p,
 1097:             sourceType: 'own',
 1098:             isOwn: true,
 1099:             isShared: false,
 1100:             soldOut: soldOutMap.get(p.id) ?? false,
 1101:             instance_count: instanceCountMap.get(p.id) ?? 0
 1102:           })),
 1103:           total: ownPackages.length
 1104:         }
 1105:       } else if (scope === 'official') {
 1106:         // 查看自营套餐：仅显示管理员创建的套餐
 1107:         const officialPackages = await db.getAllPackages(activeOnly, { ownerRole: 'admin' })
 1108:         const officialPackageIds = officialPackages.map(p => p.id)
 1109:         const [officialSoldOutMap, officialInstanceCountMap] = await Promise.all([
 1110:           db.checkPackagesSoldOut(officialPackageIds),
 1111:           db.getNormalInstanceCountsByPackages(officialPackageIds)
 1112:         ])
 1113:         return {
 1114:           packages: officialPackages.map(p => ({
 1115:             ...p,
 1116:             sourceType: 'official',
 1117:             isOwn: p.user_id === user.id,
 1118:             isShared: false,
 1119:             soldOut: officialSoldOutMap.get(p.id) ?? false,
 1120:             instance_count: officialInstanceCountMap.get(p.id) ?? 0
 1121:           })),
 1122:           total: officialPackages.length
 1123:         }
 1124:       } else if (scope === 'hosted') {
 1125:         // 查看托管套餐：仅显示普通用户的套餐
 1126:         let queryOptions: { userId?: number; ownerRole?: 'admin' | 'user'; includeOwnerEmail: boolean } = {
 1127:           includeOwnerEmail: true,
 1128:           ownerRole: 'user'
 1129:         }
 1130:         
 1131:         const parsedFilterUserId = parseOptionalPositiveQueryInteger(filterUserId)
 1132:         if (parsedFilterUserId === null) {
 1133:           return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid package owner filter'))
 1134:         }
 1135:         if (parsedFilterUserId && parsedFilterUserId !== user.id) {
 1136:           queryOptions.userId = parsedFilterUserId
 1137:         }
 1138:         
 1139:         const hostedPackages = await db.getAllPackages(activeOnly, queryOptions)
 1140:         const hostedPackageIds = hostedPackages.map(p => p.id)
 1141:         const [hostedSoldOutMap, hostedInstanceCountMap] = await Promise.all([
 1142:           db.checkPackagesSoldOut(hostedPackageIds),
 1143:           db.getNormalInstanceCountsByPackages(hostedPackageIds)
 1144:         ])
 1145:         return {
 1146:           packages: hostedPackages.map(p => ({
 1147:             id: p.id,
 1148:             name: p.name,
 1149:             description: p.description,
 1150:             cpu_max: p.cpu_max,
 1151:             memory_max: p.memory_max,
 1152:             disk_max: p.disk_max,
 1153:             bandwidth_max: p.bandwidth_max,
 1154:             network_mode: p.network_mode,
 1155:             instance_type: p.instance_type,
 1156:             host_ids: p.host_ids || [],
 1157:             host_storage_pools: (p as any).host_storage_pools || {},
 1158:             host_traffic_multipliers: (p as any).host_traffic_multipliers || {},
 1159:             privileged: p.privileged,
 1160:             nested: p.nested,
 1161:             active: p.active,
 1162:             monthly_traffic_limit: p.monthly_traffic_limit,
 1163:             port_limit: p.port_limit,
 1164:             snapshot_limit: p.snapshot_limit,
 1165:             backup_limit: p.backup_limit,
 1166:             site_limit: p.site_limit,
 1167:             global_shared: p.global_shared,
 1168:             allow_instance_deletion: p.allow_instance_deletion,
 1169:             required_package_id: (p as any).required_package_id ?? null,
 1170:             required_package_name: (p as any).required_package_name ?? null,
 1171:             sourceType: 'hosted',
 1172:             isOwn: false,
 1173:             isShared: false,
 1174:             soldOut: hostedSoldOutMap.get(p.id) ?? false,
 1175:             instance_count: hostedInstanceCountMap.get(p.id) ?? 0,
 1176:             // 所有者信息
 1177:             owner: {
 1178:               id: p.user_id,
 1179:               username: p.owner_username,
 1180:               email: p.owner_email,
 1181:               avatarStyle: p.owner_avatar_style || 'bigSmile',
 1182:               avatarBadgeId: (p as any).owner_avatar_badge_id || null
 1183:             }
 1184:           })),
 1185:           total: hostedPackages.length
 1186:         }
 1187:       }
 1188:     }
 1189:     // 用于转换共享套餐为响应格式的辅助函数
 1190:     const formatSharedPackage = async (p: any, isGlobalShared: boolean, sourceType: 'official' | 'market' | 'friends' | 'zone', zone?: packageShares.HostingZoneInfo) => ({
 1191:       id: p.id,
 1192:       name: p.name,
 1193:       description: p.description,
 1194:       cpu_max: p.cpuMax,
 1195:       memory_max: p.memoryMax,
 1196:       disk_max: p.diskMax,
 1197:       bandwidth_max: p.bandwidthMax,
 1198:       network_mode: p.networkMode,
 1199:       instance_type: p.instanceType,
 1200:       host_ids: p.hostIds || [],
 1201:       privileged: p.privileged,
 1202:       nested: p.nested,
 1203:       active: 1,
 1204:       monthly_traffic_limit: p.monthlyTrafficLimit,
 1205:       port_limit: p.portLimit,
 1206:       snapshot_limit: p.snapshotLimit,
 1207:       backup_limit: p.backupLimit,
 1208:       site_limit: p.siteLimit,
 1209:       // 存储 I/O 限制
 1210:       io_limit_mode: p.ioLimitMode || p.io_limit_mode || 'throughput',
 1211:       limits_read: p.limitsRead || p.limits_read || '100MB',
 1212:       limits_write: p.limitsWrite || p.limits_write || '100MB',
 1213:       limits_read_iops: p.limitsReadIops || p.limits_read_iops || 500,
 1214:       limits_write_iops: p.limitsWriteIops || p.limits_write_iops || 500,
 1215:       limits_ingress: '300Mbit',
 1216:       limits_egress: '300Mbit',
 1217:       limits_processes: 500,
 1218:       limits_cpu_priority: 10,
 1219:       boot_autostart: true,
 1220:       boot_autostart_priority: 20,
 1221:       boot_autostart_delay: 15,
 1222:       boot_host_shutdown_timeout: 30,
 1223:       // 实例操作权限
 1224:       allow_instance_deletion: p.allowInstanceDeletion ?? true,
 1225:       ...getPackagePrerequisiteFields(p),
 1226:       // 所有者信息
 1227:       ownerId: p.ownerId,
 1228:       ownerUsername: p.ownerUsername,
 1229:       isOwn: false,
 1230:       isShared: true,
 1231:       isGlobalShared,
 1232:       sharedAt: p.sharedAt,
 1233:       // 新增：套餐来源类型
 1234:       sourceType,
 1235:       has_required_package_instance: p.requiredPackageId
 1236:         ? await db.userHasNormalInstanceForPackage(user.id, p.requiredPackageId)
 1237:         : true,
 1238:       ...(zone ? {
 1239:         hostingZoneId: zone.id,
 1240:         hostingZoneName: zone.name,
 1241:         hostingZoneLogoUrl: zone.logoUrl
 1242:       } : {})
 1243:     })
 1244: 
 1245:     // 根据 source 参数返回对应的套餐
 1246:     if (source === 'official') {
 1247:       // 面板直营：仅返回管理员创建的全局共享套餐
 1248:       const globalPackages = await packageShares.getGlobalSharedPackages()
 1249:       const officialIds = globalPackages.map(p => p.id)
 1250:       const officialSoldOutMap = await db.checkPackagesSoldOut(officialIds)
 1251:       return {
 1252:         packages: await Promise.all(globalPackages.map(async p => ({
 1253:           ...await formatSharedPackage(p, true, 'official'),
 1254:           soldOut: officialSoldOutMap.get(p.id) ?? false
 1255:         }))),
 1256:         total: globalPackages.length
 1257:       }
 1258:     }
 1259: 
 1260:     if (source === 'market') {
 1261:       // 托管市场：仅返回用户托管的全局共享套餐
 1262:       const zoneOwnerIds = await packageShares.getActiveHostingZoneOwnerIds()
 1263:       const marketPackages = await packageShares.getHostedMarketPackages(user.id, {
 1264:         excludeOwnerIds: zoneOwnerIds
 1265:       })
 1266:       const marketIds = marketPackages.map(p => p.id)
 1267:       const marketSoldOutMap = await db.checkPackagesSoldOut(marketIds)
 1268:       return {
 1269:         packages: await Promise.all(marketPackages.map(async p => ({
 1270:           ...await formatSharedPackage(p, true, 'market'),
 1271:           soldOut: marketSoldOutMap.get(p.id) ?? false
 1272:         }))),
 1273:         total: marketPackages.length
 1274:       }
 1275:     }
 1276: 
 1277:     if (source === 'zone') {
 1278:       const zoneId = parseOptionalPositiveQueryInteger(request.query.zoneId)
 1279:       if (zoneId === null) {
 1280:         return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid hosting zone filter'))
 1281:       }
 1282:       if (zoneId === undefined) {
 1283:         return { packages: [], total: 0 }
 1284:       }
 1285: 
 1286:       const zone = await packageShares.getActiveHostingZoneById(zoneId, user.id)
 1287:       if (!zone) {
 1288:         return { packages: [], total: 0 }
 1289:       }
 1290: 
 1291:       const zonePackages = await packageShares.getHostedMarketPackages(user.id, {
 1292:         ownerId: zone.ownerId
 1293:       })
 1294:       const zonePackageIds = zonePackages.map(p => p.id)
 1295:       const zoneSoldOutMap = await db.checkPackagesSoldOut(zonePackageIds)
 1296: 
 1297:       return {
 1298:         packages: await Promise.all(zonePackages.map(async p => ({
 1299:           ...await formatSharedPackage(p, true, 'zone', zone),
 1300:           soldOut: zoneSoldOutMap.get(p.id) ?? false
 1301:         }))),
 1302:         total: zonePackages.length
 1303:       }
 1304:     }
 1305: 
 1306:     if (source === 'friends') {
 1307:       // 好友共享：仅返回好友共享的套餐
 1308:       const friendPackages = await packageShares.getSharedToUser(user.id)
 1309:       const friendIds = friendPackages.map(p => p.id)
 1310:       const friendSoldOutMap = await db.checkPackagesSoldOut(friendIds)
 1311:       return {
 1312:         packages: await Promise.all(friendPackages.map(async p => ({
 1313:           ...await formatSharedPackage(p, false, 'friends'),
 1314:           soldOut: friendSoldOutMap.get(p.id) ?? false
 1315:         }))),
 1316:         total: friendPackages.length
 1317:       }
 1318:     }
 1319: 
 1320:     // source=all 或不传：返回全部（保持向后兼容）
 1321:     // 获取套餐：管理员查看系统所有套餐，普通用户查看自己的套餐
 1322:     const ownPackages = await db.getAllPackages(activeOnly, {
 1323:       userId: isAdmin ? undefined : user.id
 1324:     })
 1325:     const ownPackageIds = ownPackages.map(p => p.id)
 1326:     const ownInstanceCountMap = await db.getNormalInstanceCountsByPackages(ownPackageIds)
 1327: 
 1328:     // 获取共享给用户的套餐（好友共享）
 1329:     const sharedPackages = await packageShares.getSharedToUser(user.id)
 1330: 
 1331:     // 获取全局共享的套餐（官方）
 1332:     const globalPackages = await packageShares.getGlobalSharedPackages()
 1333: 
 1334:     // 获取托管市场套餐
 1335:     const hostingZones = await packageShares.getHostingZonesForViewer(user.id)
 1336:     const zoneOwnerIds = hostingZones.map(zone => zone.ownerId)
 1337:     const marketPackages = await packageShares.getHostedMarketPackages(user.id, {
 1338:       excludeOwnerIds: zoneOwnerIds
 1339:     })
 1340: 
 1341:     const zonePackagesByZone = await Promise.all(
 1342:       hostingZones.map(async zone => ({
 1343:         zone,
 1344:         packages: await packageShares.getHostedMarketPackages(user.id, {
 1345:           ownerId: zone.ownerId
 1346:         })
 1347:       }))
 1348:     )
 1349: 
 1350:     // 合并并去重，优先级：自己的 > 好友分享 > 托管专区 > 托管市场 > 官方直营
 1351:     // 使用 Set 记录已添加的套餐 ID，避免重复
 1352:     const addedPackageIds = new Set<number>()
 1353:     const allPackages: any[] = []
 1354: 
 1355:     // 1. 首先添加自己的套餐（最高优先级）
 1356:     for (const p of ownPackages) {
 1357:       addedPackageIds.add(p.id)
 1358:       allPackages.push({
 1359:         id: p.id,
 1360:         name: p.name,
 1361:         description: p.description,
 1362:         cpu_max: p.cpu_max,
 1363:         memory_max: p.memory_max,
 1364:         disk_max: p.disk_max,
 1365:         bandwidth_max: p.bandwidth_max,
 1366:         network_mode: p.network_mode,
 1367:         instance_type: p.instance_type,
 1368:         host_ids: (p as { host_ids?: number[] }).host_ids || [],
 1369:         host_storage_pools: (p as any).host_storage_pools || {},
 1370:         host_traffic_multipliers: (p as any).host_traffic_multipliers || {},
 1371:         privileged: p.privileged,
 1372:         nested: p.nested,
 1373:         active: p.active,
 1374:         monthly_traffic_limit: p.monthly_traffic_limit,
 1375:         port_limit: p.port_limit,
 1376:         snapshot_limit: p.snapshot_limit,
 1377:         backup_limit: p.backup_limit,
 1378:         site_limit: p.site_limit,
 1379:         global_shared: p.global_shared,
 1380:         // 存储 I/O 限制
 1381:         io_limit_mode: (p as any).io_limit_mode ?? 'throughput',
 1382:         limits_read: p.limits_read,
 1383:         limits_write: p.limits_write,
 1384:         limits_read_iops: p.limits_read_iops,
 1385:         limits_write_iops: p.limits_write_iops,
 1386:         // 网络限制
 1387:         limits_ingress: p.limits_ingress,
 1388:         limits_egress: p.limits_egress,
 1389:         // 进程与调度
 1390:         limits_processes: p.limits_processes,
 1391:         limits_cpu_priority: p.limits_cpu_priority,
 1392:         // 启动配置
 1393:         boot_autostart: p.boot_autostart,
 1394:         boot_autostart_priority: p.boot_autostart_priority,
 1395:         boot_autostart_delay: p.boot_autostart_delay,
 1396:         boot_host_shutdown_timeout: p.boot_host_shutdown_timeout,
 1397:         // 实例操作权限
 1398:         allow_instance_deletion: (p as any).allow_instance_deletion ?? true,
 1399:         required_package_id: (p as any).required_package_id ?? null,
 1400:         required_package_name: (p as any).required_package_name ?? null,
 1401:         has_required_package_instance: (p as any).required_package_id
 1402:           ? await db.userHasNormalInstanceForPackage(user.id, (p as any).required_package_id)
 1403:           : true,
 1404:         // 所有者信息
 1405:         ownerId: p.user_id,
 1406:         ownerUsername: p.owner_username,
 1407:         isOwn: true,
 1408:         isShared: false,
 1409:         sourceType: 'own',
 1410:         instance_count: ownInstanceCountMap.get(p.id) ?? 0
 1411:       })
 1412:     }
 1413: 
 1414:     // 2. 添加好友分享的套餐（跳过已有的）
 1415:     for (const p of sharedPackages) {
 1416:       if (addedPackageIds.has(p.id)) continue
 1417:       addedPackageIds.add(p.id)
 1418:       allPackages.push(await formatSharedPackage(p, false, 'friends'))
 1419:     }
 1420: 
 1421:     // 3. 添加托管专区套餐（跳过已有的）
 1422:     for (const group of zonePackagesByZone) {
 1423:       for (const p of group.packages) {
 1424:         if (addedPackageIds.has(p.id)) continue
 1425:         addedPackageIds.add(p.id)
 1426:         allPackages.push(await formatSharedPackage(p, true, 'zone', group.zone))
 1427:       }
 1428:     }
 1429: 
 1430:     // 4. 添加托管市场套餐（跳过已有的）
 1431:     for (const p of marketPackages) {
 1432:       if (addedPackageIds.has(p.id)) continue
 1433:       addedPackageIds.add(p.id)
 1434:       allPackages.push(await formatSharedPackage(p, true, 'market'))
 1435:     }
 1436: 
 1437:     // 5. 添加官方直营套餐（跳过已有的）
 1438:     for (const p of globalPackages) {
 1439:       if (addedPackageIds.has(p.id)) continue
 1440:       addedPackageIds.add(p.id)
 1441:       allPackages.push(await formatSharedPackage(p, true, 'official'))
 1442:     }
 1443: 
 1444:     // 6. 批量计算售罄状态
 1445:     const packageIds = allPackages.map(p => p.id)
 1446:     const soldOutMap = await db.checkPackagesSoldOut(packageIds)
 1447: 
 1448:     // 7. 添加 soldOut 字段到每个套餐
 1449:     const packagesWithSoldOut = allPackages.map(p => ({
 1450:       ...p,
 1451:       soldOut: soldOutMap.get(p.id) ?? false
 1452:     }))
 1453: 
 1454:     return {
 1455:       packages: packagesWithSoldOut,
 1456:       total: packagesWithSoldOut.length
 1457:     }
 1458:   })
 1459: 
 1460:   // 获取当前用户可见的托管专区列表
 1461:   fastify.get('/hosting-zones', {
 1462:     onRequest: [fastify.authenticate]
 1463:   }, async (request) => {
 1464:     const zones = await packageShares.getHostingZonesForViewer(request.user.id)
 1465:     return { zones }
 1466:   })
 1467: 
 1468:   // 获取套餐详情
 1469:   fastify.get<{ Params: { id: string } }>('/:id', {
 1470:     onRequest: [fastify.authenticate]
 1471:   }, async (request: FastifyRequest<{ Params: { id: string } }>, reply: FastifyReply) => {
 1472:     const { id } = request.params
 1473:     const { user } = request
 1474:     const packageId = parsePositiveRouteId(id)
 1475: 
 1476:     if (!packageId) {
 1477:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 1478:     }
 1479: 
 1480:     const pkg = await db.getPackageById(packageId)
 1481: 
 1482:     if (!pkg) {
 1483:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 1484:     }
 1485: 
 1486:     // 检查访问权限：自己的套餐、共享给自己的套餐、或者自己的实例绑定了这个套餐
 1487:     const canAccess = await packageShares.canUserAccessPackage(user.id, packageId)
 1488: 
 1489:     // 额外检查：用户是否有实例绑定了这个套餐（用于修改配置时查看套餐限制）
 1490:     let hasInstanceWithPackage = false
 1491:     if (!canAccess) {
 1492:       const userInstances = await db.getInstancesByUserId(user.id)
 1493:       hasInstanceWithPackage = userInstances.some(inst => inst.package_id === packageId)
 1494:     }
 1495: 
 1496:     // 管理员可以访问任何套餐
 1497:     const isAdmin = user.role === 'admin'
 1498:     if (!canAccess && !hasInstanceWithPackage && !isAdmin) {
 1499:       // 添加调试日志，帮助排查套餐访问权限问题
 1500:       console.warn(`[PACKAGE_ACCESS_DENIED] GET /packages/${id} - packageId=${packageId}, userId=${user.id}, username=${user.username}, pkgOwnerId=${pkg.user_id}, canAccess=${canAccess}, hasInstanceWithPackage=${hasInstanceWithPackage}, isAdmin=${isAdmin}`)
 1501:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 1502:     }
 1503: 
 1504:     const isOwn = pkg.user_id === user.id
 1505: 
 1506:     // 计算剩余配额信息
 1507:     // 安全注意：只有在用户有权限访问套餐（canAccess）时才计算配额信息
 1508:     // 如果只是通过hasInstanceWithPackage获得访问权限，不计算配额（因为不能创建新实例）
 1509:     let quotaInfo: {
 1510:       maxInstances: number | null
 1511:       remainingInstances: number | null
 1512:       maxCpu: number | null
 1513:       remainingCpu: number | null
 1514:       maxMemory: number | null
 1515:       remainingMemory: number | null
 1516:       ownerUsername: string | null
 1517:     } = {
 1518:       maxInstances: null,
 1519:       remainingInstances: null,
 1520:       maxCpu: null,
 1521:       remainingCpu: null,
 1522:       maxMemory: null,
 1523:       remainingMemory: null,
 1524:       ownerUsername: null
 1525:     }
 1526: 
 1527:     // 只有在用户有权限访问套餐时才计算配额信息
 1528:     if (canAccess) {
 1529:       if (!isOwn) {
 1530:         // 如果是共享套餐，计算剩余配额
 1531:         const shareInfo = await packageShares.getPackageShareForUser(packageId, user.id)
 1532:         if (shareInfo) {
 1533:           const usage = await packageShares.getSharedPackageUsage(packageId, user.id)
 1534:           
 1535:           // 获取套餐所有者用户名
 1536:           if (pkg.user_id) {
 1537:             const owner = await db.findUserById(pkg.user_id)
 1538:             quotaInfo.ownerUsername = owner?.username || null
 1539:           }
 1540: 
 1541:           // 实例数量配额
 1542:           if (shareInfo.maxInstances !== null) {
 1543:             quotaInfo.maxInstances = shareInfo.maxInstances
 1544:             quotaInfo.remainingInstances = Math.max(0, shareInfo.maxInstances - usage.instanceCount)
 1545:           } else {
 1546:             quotaInfo.maxInstances = null
 1547:             quotaInfo.remainingInstances = null // 无限制
 1548:           }
 1549: 
 1550:           // CPU/内存配额
 1551:           if (shareInfo.quotaMultiplier !== null) {
 1552:             quotaInfo.maxCpu = Math.floor(pkg.cpu_max * shareInfo.quotaMultiplier)
 1553:             quotaInfo.remainingCpu = Math.max(0, quotaInfo.maxCpu - usage.totalCpu)
 1554:             quotaInfo.maxMemory = Math.floor(pkg.memory_max * shareInfo.quotaMultiplier)
 1555:             quotaInfo.remainingMemory = Math.max(0, quotaInfo.maxMemory - usage.totalMemory)
 1556:           } else {
 1557:             quotaInfo.maxCpu = null
 1558:             quotaInfo.remainingCpu = null // 无限制
 1559:             quotaInfo.maxMemory = null
 1560:             quotaInfo.remainingMemory = null // 无限制
 1561:           }
 1562:         }
 1563:       } else {
 1564:         // 自己的套餐，获取所有者用户名
 1565:         quotaInfo.ownerUsername = user.username
 1566:         // 自己的套餐无限制
 1567:         quotaInfo.maxInstances = null
 1568:         quotaInfo.remainingInstances = null
 1569:         quotaInfo.maxCpu = null
 1570:         quotaInfo.remainingCpu = null
 1571:         quotaInfo.maxMemory = null
 1572:         quotaInfo.remainingMemory = null
 1573:       }
 1574:     } else if (hasInstanceWithPackage) {
 1575:       // 用户只是有实例绑定了这个套餐，但没有访问权限（不能创建新实例）
 1576:       // 这种情况下，不计算配额信息，但可以显示套餐所有者用户名（用于显示）
 1577:       if (pkg.user_id) {
 1578:         const owner = await db.findUserById(pkg.user_id)
 1579:         quotaInfo.ownerUsername = owner?.username || null
 1580:       }
 1581:       // 配额信息保持为null，前端会不显示
 1582:     }
 1583: 
 1584:     const requiredPackageId = (pkg as any).required_package_id ?? null
 1585:     const hasRequiredPackageInstance = requiredPackageId !== null
 1586:       ? await db.userHasNormalInstanceForPackage(user.id, requiredPackageId)
 1587:       : true
 1588: 
 1589:     return {
 1590:       package: {
 1591:         id: pkg.id,
 1592:         name: pkg.name,
 1593:         description: pkg.description,
 1594:         cpu_max: pkg.cpu_max,
 1595:         memory_max: pkg.memory_max,
 1596:         disk_max: pkg.disk_max,
 1597:         bandwidth_max: pkg.bandwidth_max,
 1598:         network_mode: pkg.network_mode,
 1599:         instance_type: pkg.instance_type,  // 实例类型
 1600:         host_ids: (pkg as { host_ids?: number[] }).host_ids || [],
 1601:         host_storage_pools: isOwn || isAdmin ? ((pkg as any).host_storage_pools || {}) : undefined,
 1602:         host_traffic_multipliers: isOwn || isAdmin ? ((pkg as any).host_traffic_multipliers || {}) : undefined,
 1603:         privileged: isOwn ? pkg.privileged : 0,
 1604:         nested: isOwn ? pkg.nested : 0,
 1605:         active: pkg.active,
 1606:         monthly_traffic_limit: pkg.monthly_traffic_limit,
 1607:         traffic_reset_price: (pkg as any).traffic_reset_price ?? 0,
 1608:         port_limit: pkg.port_limit,
 1609:         snapshot_limit: pkg.snapshot_limit,
 1610:         backup_limit: pkg.backup_limit,
 1611:         site_limit: pkg.site_limit,
 1612:         // 存储 I/O 限制
 1613:         io_limit_mode: (pkg as any).io_limit_mode ?? 'throughput',
 1614:         limits_read: pkg.limits_read,
 1615:         limits_write: pkg.limits_write,
 1616:         limits_read_iops: pkg.limits_read_iops,
 1617:         limits_write_iops: pkg.limits_write_iops,
 1618:         // 网络限制
 1619:         limits_ingress: pkg.limits_ingress,
 1620:         limits_egress: pkg.limits_egress,
 1621:         // 进程与调度
 1622:         limits_processes: pkg.limits_processes,
 1623:         limits_cpu_priority: pkg.limits_cpu_priority,
 1624:         // 启动配置
 1625:         boot_autostart: pkg.boot_autostart,
 1626:         boot_autostart_priority: pkg.boot_autostart_priority,
 1627:         boot_autostart_delay: pkg.boot_autostart_delay,
 1628:         boot_host_shutdown_timeout: pkg.boot_host_shutdown_timeout,
 1629:         // 全局共享配置（仅套餐所有者查看时返回）
 1630:         global_shared: isOwn ? ((pkg as any).global_shared ?? false) : undefined,
 1631:         global_quota_multiplier: isOwn ? null : undefined,
 1632:         global_max_instances: isOwn
 1633:           ? (((pkg as any).global_shared ?? false) ? normalizePublicPackageMaxInstances((pkg as any).global_max_instances) : null)
 1634:           : undefined,
 1635:         // 实例操作权限（所有用户都需要知道是否可以删除）
 1636:         allow_instance_deletion: (pkg as any).allow_instance_deletion ?? true,
 1637:         required_package_id: (pkg as any).required_package_id ?? null,
 1638:         required_package_name: (pkg as any).required_package_name ?? null,
 1639:         has_required_package_instance: hasRequiredPackageInstance,
 1640:         ownerId: pkg.user_id,
 1641:         isOwn,
 1642:         // 剩余配额信息
 1643:         quotaInfo
 1644:       }
 1645:     }
 1646:   })
 1647: 
 1648:   // 创建套餐（管理员或满足准入条件的用户）
 1649:   fastify.post<{ Body: CreatePackageRequest }>('/', {
 1650:     onRequest: [fastify.authenticate],
 1651:     config: { rateLimit: { max: 20, timeWindow: '1 minute' } },
 1652:     schema: {
 1653:       body: {
 1654:         type: 'object',
 1655:         required: ['name', 'cpuMax', 'memoryMax', 'diskMax'],
 1656:         properties: {
 1657:           name: { type: 'string', minLength: 2 },
 1658:           description: { type: 'string' },
 1659:           cpuMax: { type: 'integer', minimum: 15 },
 1660:           memoryMax: { type: 'integer', minimum: 128 },
 1661:           diskMax: { type: 'integer', minimum: 512 },
 1662:           bandwidthMax: { type: 'integer' },
 1663:           networkMode: { type: 'string', enum: ACTIVE_PACKAGE_NETWORK_MODES },
 1664:           instanceType: { type: 'string', enum: ['container', 'vm'] },
 1665:           hostIds: { type: 'array', items: { type: 'integer' }, minItems: 1 },
 1666:           hostStoragePools: {
 1667:             type: 'object',
 1668:             additionalProperties: { type: ['string', 'null'] }
 1669:           },
 1670:           hostTrafficMultipliers: {
 1671:             type: 'object',
 1672:             additionalProperties: { type: ['number', 'string', 'null'] }
 1673:           },
 1674:           privileged: { type: 'boolean' },
 1675:           nested: { type: 'boolean' },
 1676:           active: { type: 'boolean' },
 1677:           monthlyTrafficLimit: { type: 'string' },
 1678:           trafficResetPrice: { type: 'integer', minimum: 0, maximum: MAX_TRAFFIC_RESET_PRICE_CENTS },
 1679:           portLimit: { type: 'integer', minimum: 1 },
 1680:           snapshotLimit: { type: 'integer', minimum: 0 },
 1681:           backupLimit: { type: 'integer', minimum: 0 },
 1682:           siteLimit: { type: 'integer', minimum: 0 },
 1683:           // 存储 I/O 限制
 1684:           ioLimitMode: { type: 'string', enum: ['throughput', 'iops'] },
 1685:           limitsRead: { type: 'string' },
 1686:           limitsWrite: { type: 'string' },
 1687:           limitsReadIops: { type: 'integer', minimum: 0 },
 1688:           limitsWriteIops: { type: 'integer', minimum: 0 },
 1689:           // 网络限制
 1690:           limitsIngress: { type: 'string' },
 1691:           limitsEgress: { type: 'string' },
 1692:           // 进程与调度
 1693:           limitsProcesses: { type: 'integer', minimum: 0 },
 1694:           limitsCpuPriority: { type: 'integer', minimum: 0, maximum: 10 },
 1695:           // 启动配置
 1696:           bootAutostart: { type: 'boolean' },
 1697:           bootAutostartPriority: { type: 'integer', minimum: 0, maximum: 100 },
 1698:           bootAutostartDelay: { type: 'integer', minimum: 5, maximum: 600 },
 1699:           bootHostShutdownTimeout: { type: 'integer', minimum: 30, maximum: 600 },
 1700:           // 全局共享配置
 1701:           globalShared: { type: 'boolean' },
 1702:           globalQuotaMultiplier: { type: ['number', 'null'] },
 1703:           globalMaxInstances: { type: ['integer', 'null'] },
 1704:           requiredPackageId: { type: ['integer', 'null'], minimum: 1 },
 1705:           // 实例操作权限
 1706:           allowInstanceDeletion: { type: 'boolean' }
 1707:         }
 1708:       }
 1709:     }
 1710:   }, async (request: FastifyRequest<{ Body: CreatePackageRequest }>, reply: FastifyReply) => {
 1711:     let packageInput: NormalizedPackageInput
 1712:     try {
 1713:       packageInput = normalizePackageInput(request.body, { requireAll: true })
 1714:     } catch (error) {
 1715:       return reply.code(400).send(error)
 1716:     }
 1717:     const {
 1718:       name, description, cpuMax, memoryMax, diskMax, bandwidthMax, networkMode, instanceType, hostIds, privileged, nested, active,
 1719:       monthlyTrafficLimit, portLimit, snapshotLimit, backupLimit, siteLimit,
 1720:       trafficResetPrice,
 1721:       ioLimitMode, limitsRead, limitsWrite, limitsReadIops, limitsWriteIops,
 1722:       limitsIngress, limitsEgress, limitsProcesses, limitsCpuPriority,
 1723:       bootAutostart, bootAutostartPriority, bootHostShutdownTimeout,
 1724:       globalShared, globalMaxInstances, hostStoragePools, hostTrafficMultipliers, requiredPackageId
 1725:     } = packageInput
 1726: 
 1727:     // 验证必须至少绑定一个宿主机
 1728:     if (!hostIds || hostIds.length === 0) {
 1729:       return reply.code(400).send({ error: 'Package must bind at least one host', code: 'NO_HOSTS' })
 1730:     }
 1731: 
 1732:     // 验证套餐名称（防止危险字符注入）
 1733:     const packageNetworkModeError = validatePackageNetworkModeForInstanceType(instanceType, networkMode)
 1734:     if (packageNetworkModeError) {
 1735:       return reply.code(400).send({ error: packageNetworkModeError, code: 'KVM_NETWORK_MODE_UNSUPPORTED' })
 1736:     }
 1737: 
 1738:     const incompatibleHosts = await getIncompatiblePackageHosts(hostIds, instanceType || 'container')
 1739:     if (incompatibleHosts.length > 0) {
 1740:       return reply.code(400).send(incompatiblePackageHostsResponse(incompatibleHosts, instanceType || 'container'))
 1741:     }
 1742: 
 1743:     const storageUnavailableHosts = await getHostsWithoutSystemDiskPool(hostIds, { hostStoragePools })
 1744:     if (storageUnavailableHosts.length > 0) {
 1745:       return reply.code(400).send(storagePoolUnavailableResponse(storageUnavailableHosts))
 1746:     }
 1747: 
 1748:     // 检查名称是否已存在（同一用户下）
 1749:     const existing = await db.getPackageByUserAndName(request.user.id, name!)
 1750:     if (existing) {
 1751:       return reply.code(400).send({ error: 'Package name already exists', code: 'NAME_EXISTS' })
 1752:     }
 1753: 
 1754:     const prerequisiteValidation = await db.validatePackagePrerequisiteReferenceLocked(null, requiredPackageId, request.user.id)
 1755:     if (!prerequisiteValidation.valid) {
 1756:       return reply.code(400).send({ error: prerequisiteValidation.message, code: prerequisiteValidation.code })
 1757:     }
 1758:     if (globalShared && !validatePublicPackageMaxInstances(globalMaxInstances)) {
 1759:       return reply.code(400).send({
 1760:         error: '公开套餐最大实例数必须是 1-5 之间的整数',
 1761:         code: 'INVALID_MAX_INSTANCES'
 1762:       })
 1763:     }
 1764: 
 1765:     const trafficLimit = parseNullablePostgresBigIntInput(monthlyTrafficLimit)
 1766:     if (trafficLimit === undefined) {
 1767:       return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid monthly traffic limit'))
 1768:     }
 1769: 
 1770:     let id: number
 1771:     try {
 1772:       id = await db.createPackage({
 1773:         userId: request.user.id,  // 所有者为当前用户
 1774:         name: name!,
 1775:         description,
 1776:         cpuMax: cpuMax!,
 1777:         memoryMax: memoryMax!,
 1778:         diskMax: diskMax!,
 1779:         bandwidthMax,
 1780:         networkMode: networkMode || 'nat',
 1781:         instanceType: instanceType || 'container',
 1782:         hostIds,
 1783:         hostStoragePools,
 1784:         hostTrafficMultipliers,
 1785:         privileged,
 1786:         nested,
 1787:         active,
 1788:         portLimit,
 1789:         snapshotLimit,
 1790:         backupLimit,
 1791:         siteLimit,
 1792:         monthlyTrafficLimit: trafficLimit,
 1793:         trafficResetPrice,
 1794:         // 存储 I/O 限制
 1795:         ioLimitMode,
 1796:         limitsRead,
 1797:         limitsWrite,
 1798:         limitsReadIops,
 1799:         limitsWriteIops,
 1800:         // 网络限制
 1801:         limitsIngress,
 1802:         limitsEgress,
 1803:         // 进程与调度
 1804:         limitsProcesses,
 1805:         limitsCpuPriority,
 1806:         // 启动配置
 1807:         bootAutostart,
 1808:         bootAutostartPriority,
 1809:         bootAutostartDelay: packageInput.bootAutostartDelay,
 1810:         bootHostShutdownTimeout,
 1811:         // 全局共享配置
 1812:         globalShared,
 1813:         globalQuotaMultiplier: null,
 1814:         globalMaxInstances: globalShared ? globalMaxInstances : null,
 1815:         requiredPackageId: requiredPackageId ?? null,
 1816:         // 实例操作权限不再暴露配置入口，新套餐默认允许删除
 1817:         allowInstanceDeletion: true
 1818:       }, request.user.role === 'admin')  // 管理员可以绑定任何节点
 1819:     } catch (error) {
 1820:       const prerequisiteError = getPackagePrerequisiteError(error)
 1821:       if (prerequisiteError) {
 1822:         return reply.code(400).send({ error: prerequisiteError.message, code: prerequisiteError.code })
 1823:       }
 1824:       const errorMessage = error instanceof Error ? error.message : String(error)
 1825:       return reply.code(400).send({ error: errorMessage, code: 'INVALID_PACKAGE_CONFIG' })
 1826:     }
 1827: 
 1828:     // 注意：已取消配额限制，不再更新 packageUsed
 1829: 
 1830:     await createLog(request.user.id, 'package', 'package.create', `Created package "${name}" [CPU: ${cpuMax}%, Memory: ${memoryMax}MB, Disk: ${diskMax}MB, instanceType: ${instanceType || 'container'}, network: ${networkMode || 'nat'}, hosts: ${hostIds.join(',')}]`, 'success')
 1831: 
 1832:     reply.code(201).send({
 1833:       message: 'Package created',
 1834:       package: { id, name: name! }
 1835:     })
 1836:   })
 1837: 
 1838:   // 更新套餐（管理员或套餐所有者）
 1839:   fastify.patch<{
 1840:     Params: { id: string }
 1841:     Body: UpdatePackageRequest
 1842:   }>('/:id', {
 1843:     onRequest: [fastify.authenticate],
 1844:     config: { rateLimit: { max: 20, timeWindow: '1 minute' } },
 1845:     schema: {
 1846:       body: {
 1847:         type: 'object',
 1848:         properties: {
 1849:           name: { type: 'string', minLength: 2 },
 1850:           description: { type: 'string' },
 1851:           cpuMax: { type: 'integer', minimum: 15 },
 1852:           memoryMax: { type: 'integer', minimum: 128 },
 1853:           diskMax: { type: 'integer', minimum: 512 },
 1854:           bandwidthMax: { type: 'integer' },
 1855:           networkMode: { type: 'string', enum: ACTIVE_PACKAGE_NETWORK_MODES },
 1856:           instanceType: { type: 'string', enum: ['container', 'vm'] },
 1857:           hostIds: { type: 'array', items: { type: 'integer' }, minItems: 1 },
 1858:           hostStoragePools: {
 1859:             type: 'object',
 1860:             additionalProperties: { type: ['string', 'null'] }
 1861:           },
 1862:           hostTrafficMultipliers: {
 1863:             type: 'object',
 1864:             additionalProperties: { type: ['number', 'string', 'null'] }
 1865:           },
 1866:           privileged: { type: 'boolean' },
 1867:           nested: { type: 'boolean' },
 1868:           active: { type: 'boolean' },
 1869:           monthlyTrafficLimit: { type: ['string', 'null'] },
 1870:           trafficResetPrice: { type: 'integer', minimum: 0, maximum: MAX_TRAFFIC_RESET_PRICE_CENTS },
 1871:           portLimit: { type: 'integer', minimum: 1 },
 1872:           snapshotLimit: { type: 'integer', minimum: 0 },
 1873:           backupLimit: { type: 'integer', minimum: 0 },
 1874:           siteLimit: { type: 'integer', minimum: 0 },
 1875:           // 存储 I/O 限制
 1876:           ioLimitMode: { type: 'string', enum: ['throughput', 'iops'] },
 1877:           limitsRead: { type: 'string' },
 1878:           limitsWrite: { type: 'string' },
 1879:           limitsReadIops: { type: 'integer', minimum: 0 },
 1880:           limitsWriteIops: { type: 'integer', minimum: 0 },
 1881:           // 网络限制
 1882:           limitsIngress: { type: 'string' },
 1883:           limitsEgress: { type: 'string' },
 1884:           // 进程与调度
 1885:           limitsProcesses: { type: 'integer', minimum: 0 },
 1886:           limitsCpuPriority: { type: 'integer', minimum: 0, maximum: 10 },
 1887:           // 启动配置
 1888:           bootAutostart: { type: 'boolean' },
 1889:           bootAutostartPriority: { type: 'integer', minimum: 0, maximum: 100 },
 1890:           bootAutostartDelay: { type: 'integer', minimum: 5, maximum: 600 },
 1891:           bootHostShutdownTimeout: { type: 'integer', minimum: 30, maximum: 600 },
 1892:           // 全局共享配置
 1893:           globalShared: { type: 'boolean' },
 1894:           globalQuotaMultiplier: { type: ['number', 'null'] },
 1895:           globalMaxInstances: { type: ['integer', 'null'] },
 1896:           requiredPackageId: { type: ['integer', 'null'], minimum: 1 },
 1897:           // 实例操作权限
 1898:           allowInstanceDeletion: { type: 'boolean' }
 1899:         }
 1900:       }
 1901:     }
 1902:   }, async (request: FastifyRequest<{
 1903:     Params: { id: string }
 1904:     Body: UpdatePackageRequest
 1905:   }>, reply: FastifyReply) => {
 1906:     const { id } = request.params
 1907:     const packageId = parsePositiveRouteId(id)
 1908: 
 1909:     if (!packageId) {
 1910:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 1911:     }
 1912: 
 1913:     const pkg = await db.getPackageById(packageId)
 1914:     if (!pkg) {
 1915:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 1916:     }
 1917: 
 1918:     // 权限检查：只有管理员或套餐所有者可以更新
 1919:     if (pkg.user_id !== request.user.id && request.user.role !== 'admin') {
 1920:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 1921:     }
 1922: 
 1923:     let packageInput: NormalizedPackageInput
 1924:     try {
 1925:       packageInput = normalizePackageInput(request.body, { requireAll: false })
 1926:     } catch (error) {
 1927:       return reply.code(400).send(error)
 1928:     }
 1929: 
 1930:     // 如果更新名称，检查是否冲突（同一用户下）
 1931:     if (packageInput.name && packageInput.name !== pkg.name) {
 1932:       const existing = await db.getPackageByUserAndName(pkg.user_id!, packageInput.name)
 1933:       if (existing) {
 1934:         return reply.code(400).send({ error: 'Package name already exists', code: 'NAME_EXISTS' })
 1935:       }
 1936:     }
 1937: 
 1938:     // 处理流量限额和套餐资源限制
 1939:     const {
 1940:       monthlyTrafficLimit, trafficResetPrice, portLimit, snapshotLimit, backupLimit, siteLimit, hostIds, hostStoragePools, hostTrafficMultipliers,
 1941:       ioLimitMode, limitsRead, limitsWrite, limitsReadIops, limitsWriteIops,
 1942:       limitsIngress, limitsEgress, limitsProcesses, limitsCpuPriority,
 1943:       bootAutostart, bootAutostartPriority, bootAutostartDelay, bootHostShutdownTimeout,
 1944:       globalShared, globalQuotaMultiplier, globalMaxInstances,
 1945:       requiredPackageId
 1946:     } = packageInput
 1947:     const updateData: Parameters<typeof db.updatePackage>[1] = {}
 1948:     if (packageInput.name !== undefined) updateData.name = packageInput.name
 1949:     if (packageInput.description !== undefined) updateData.description = packageInput.description
 1950:     if (packageInput.cpuMax !== undefined) updateData.cpuMax = packageInput.cpuMax
 1951:     if (packageInput.memoryMax !== undefined) updateData.memoryMax = packageInput.memoryMax
 1952:     if (packageInput.diskMax !== undefined) updateData.diskMax = packageInput.diskMax
 1953:     if (packageInput.bandwidthMax !== undefined) updateData.bandwidthMax = packageInput.bandwidthMax
 1954:     if (packageInput.networkMode !== undefined) updateData.networkMode = packageInput.networkMode
 1955:     if (packageInput.instanceType !== undefined) updateData.instanceType = packageInput.instanceType
 1956:     if (packageInput.privileged !== undefined) updateData.privileged = packageInput.privileged
 1957:     if (packageInput.nested !== undefined) updateData.nested = packageInput.nested
 1958:     if (packageInput.active !== undefined) updateData.active = packageInput.active
 1959:     updateData.allowInstanceDeletion = true
 1960:     const nextInstanceType = packageInput.instanceType ?? pkg.instance_type ?? 'container'
 1961:     const nextNetworkMode = packageInput.networkMode ?? pkg.network_mode ?? 'nat'
 1962: 
 1963:     const packageNetworkModeError = validatePackageNetworkModeForInstanceType(nextInstanceType, nextNetworkMode)
 1964:     if (packageNetworkModeError) {
 1965:       return reply.code(400).send({ error: packageNetworkModeError, code: 'KVM_NETWORK_MODE_UNSUPPORTED' })
 1966:     }
 1967: 
 1968:     // 如果提供了 hostIds，验证必须至少绑定一个宿主机
 1969:     if (hostIds !== undefined) {
 1970:       if (hostIds.length === 0) {
 1971:         return reply.code(400).send({ error: 'Package must bind at least one host', code: 'NO_HOSTS' })
 1972:       }
 1973:       updateData.hostIds = hostIds
 1974:     }
 1975: 
 1976:     const nextHostIds = hostIds ?? ((pkg as { host_ids?: number[] }).host_ids || [])
 1977:     const incompatibleHosts = await getIncompatiblePackageHosts(nextHostIds, nextInstanceType)
 1978:     if (incompatibleHosts.length > 0) {
 1979:       return reply.code(400).send(incompatiblePackageHostsResponse(incompatibleHosts, nextInstanceType))
 1980:     }
 1981: 
 1982:     const storageUnavailableHosts = await getHostsWithoutSystemDiskPool(nextHostIds, {
 1983:       packageId,
 1984:       hostStoragePools
 1985:     })
 1986:     if (storageUnavailableHosts.length > 0) {
 1987:       return reply.code(400).send(storagePoolUnavailableResponse(storageUnavailableHosts))
 1988:     }
 1989: 
 1990:     if (hostStoragePools !== undefined) updateData.hostStoragePools = hostStoragePools
 1991:     if (hostTrafficMultipliers !== undefined) updateData.hostTrafficMultipliers = hostTrafficMultipliers
 1992: 
 1993:     let parsedMonthlyTrafficLimit: bigint | null | undefined
 1994:     if (monthlyTrafficLimit !== undefined) {
 1995:       parsedMonthlyTrafficLimit = parseNullablePostgresBigIntInput(monthlyTrafficLimit)
 1996:       if (parsedMonthlyTrafficLimit === undefined) {
 1997:         return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid monthly traffic limit'))
 1998:       }
 1999:       updateData.monthlyTrafficLimit = parsedMonthlyTrafficLimit
 2000:     }
 2001:     if (trafficResetPrice !== undefined) updateData.trafficResetPrice = trafficResetPrice
 2002:     if (portLimit !== undefined) updateData.portLimit = portLimit
 2003:     if (snapshotLimit !== undefined) updateData.snapshotLimit = snapshotLimit
 2004:     if (backupLimit !== undefined) updateData.backupLimit = backupLimit
 2005:     if (siteLimit !== undefined) updateData.siteLimit = siteLimit
 2006: 
 2007:     // 存储 I/O 限制
 2008:     if (ioLimitMode !== undefined) updateData.ioLimitMode = ioLimitMode
 2009:     if (limitsRead !== undefined) updateData.limitsRead = limitsRead
 2010:     if (limitsWrite !== undefined) updateData.limitsWrite = limitsWrite
 2011:     if (limitsReadIops !== undefined) updateData.limitsReadIops = limitsReadIops
 2012:     if (limitsWriteIops !== undefined) updateData.limitsWriteIops = limitsWriteIops
 2013: 
 2014:     // 网络限制
 2015:     if (limitsIngress !== undefined) updateData.limitsIngress = limitsIngress
 2016:     if (limitsEgress !== undefined) updateData.limitsEgress = limitsEgress
 2017: 
 2018:     // 进程与调度
 2019:     if (limitsProcesses !== undefined) updateData.limitsProcesses = limitsProcesses
 2020:     if (limitsCpuPriority !== undefined) updateData.limitsCpuPriority = limitsCpuPriority
 2021: 
 2022:     // 启动配置
 2023:     if (bootAutostart !== undefined) updateData.bootAutostart = bootAutostart
 2024:     if (bootAutostartPriority !== undefined) updateData.bootAutostartPriority = bootAutostartPriority
 2025:     if (bootAutostartDelay !== undefined) updateData.bootAutostartDelay = bootAutostartDelay
 2026:     if (bootHostShutdownTimeout !== undefined) updateData.bootHostShutdownTimeout = bootHostShutdownTimeout
 2027:     
 2028:     // 验证全局共享配置的数值有效性（Fastify schema 已经验证，这里做额外检查以防万一）
 2029:     const currentGlobalShared = (pkg as any).global_shared ?? false
 2030:     if (globalShared !== undefined) {
 2031:       updateData.globalShared = globalShared
 2032:       // 如果 globalShared 被设置为 false，确保相关字段为 null
 2033:       if (globalShared === false) {
 2034:         updateData.globalQuotaMultiplier = null
 2035:         updateData.globalMaxInstances = null
 2036:       }
 2037:     }
 2038:     
 2039:     // 只有在 globalShared 不为 false 时才处理这两个字段
 2040:     // 如果 globalShared 未提供，但当前套餐是全局共享的，允许更新这两个字段
 2041:     const willBeGlobalShared = globalShared !== undefined ? globalShared : currentGlobalShared
 2042:     if (willBeGlobalShared !== false) {
 2043:       updateData.globalQuotaMultiplier = null
 2044:       const nextMaxInstances = globalMaxInstances !== undefined
 2045:         ? globalMaxInstances
 2046:         : normalizePublicPackageMaxInstances((pkg as any).global_max_instances)
 2047:       if (!validatePublicPackageMaxInstances(nextMaxInstances)) {
 2048:         return reply.code(400).send({
 2049:           error: '公开套餐最大实例数必须是 1-5 之间的整数',
 2050:           code: 'INVALID_MAX_INSTANCES'
 2051:         })
 2052:       }
 2053:       updateData.globalMaxInstances = nextMaxInstances
 2054:     } else if ((globalQuotaMultiplier !== undefined || globalMaxInstances !== undefined) && globalShared === undefined) {
 2055:       // 如果当前套餐不是全局共享的，但用户试图更新这些字段，应该拒绝
 2056:       return reply.code(400).send({ 
 2057:         error: 'Cannot update globalQuotaMultiplier or globalMaxInstances when globalShared is false', 
 2058:         code: 'INVALID_GLOBAL_SHARED_STATE' 
 2059:       })
 2060:     }
 2061: 
 2062:     if (requiredPackageId !== undefined) {
 2063:       const prerequisiteValidation = await db.validatePackagePrerequisiteReferenceLocked(packageId, requiredPackageId, pkg.user_id!)
 2064:       if (!prerequisiteValidation.valid) {
 2065:         return reply.code(400).send({ error: prerequisiteValidation.message, code: prerequisiteValidation.code })
 2066:       }
 2067:       updateData.requiredPackageId = requiredPackageId
 2068:     }
 2069: 
 2070:     try {
 2071:       const shouldSyncTrafficLimits = await shouldSyncPackageTrafficLimitsAfterUpdate(packageId, pkg, {
 2072:         monthlyTrafficLimit: parsedMonthlyTrafficLimit,
 2073:         hostIds,
 2074:         hostTrafficMultipliers
 2075:       })
 2076:       await db.updatePackage(packageId, updateData, request.user.role === 'admin')  // 管理员可以绑定任何节点
 2077:       if (shouldSyncTrafficLimits) {
 2078:         const syncResult = await db.syncPackageTrafficLimitsToInstances(packageId)
 2079:         if (syncResult.instanceIds.length > 0) {
 2080:           try {
 2081:             const { reconcileTrafficStateForInstanceIds } = await import('../services/traffic-scheduler.js')
 2082:             await reconcileTrafficStateForInstanceIds(syncResult.instanceIds)
 2083:           } catch (err) {
 2084:             request.log.warn(err, '套餐流量限额已同步，流量状态即时复核失败')
 2085:           }
 2086:         }
 2087:       }
 2088:     } catch (error) {
 2089:       const prerequisiteError = getPackagePrerequisiteError(error)
 2090:       if (prerequisiteError) {
 2091:         return reply.code(400).send({ error: prerequisiteError.message, code: prerequisiteError.code })
 2092:       }
 2093:       const errorMessage = error instanceof Error ? error.message : String(error)
 2094:       return reply.code(400).send({ error: errorMessage, code: 'INVALID_PACKAGE_CONFIG' })
 2095:     }
 2096: 
 2097: 
 2098:     // 构建变更详情
 2099:     const pkgChanges: string[] = []
 2100:     if (packageInput.name && packageInput.name !== pkg.name) pkgChanges.push(`name -> "${packageInput.name}"`)
 2101:     if (packageInput.cpuMax !== undefined) pkgChanges.push(`cpuMax -> ${packageInput.cpuMax}%`)
 2102:     if (packageInput.memoryMax !== undefined) pkgChanges.push(`memoryMax -> ${packageInput.memoryMax}MB`)
 2103:     if (packageInput.diskMax !== undefined) pkgChanges.push(`diskMax -> ${packageInput.diskMax}MB`)
 2104:     if (packageInput.instanceType) pkgChanges.push(`instanceType -> ${packageInput.instanceType}`)
 2105:     if (packageInput.active !== undefined) pkgChanges.push(`active -> ${packageInput.active}`)
 2106:     if (hostIds !== undefined) pkgChanges.push(`hosts -> [${hostIds.join(',')}]`)
 2107: 
 2108:     await createLog(request.user.id, 'package', 'package.update', `Updated package "${pkg.name}" [${pkgChanges.length > 0 ? pkgChanges.join(', ') : 'minor changes'}]`, 'success')
 2109: 
 2110:     return { message: 'Package updated' }
 2111:   })
 2112: 
 2113:   // 删除套餐（管理员或套餐所有者）
 2114:   fastify.delete<{ Params: { id: string } }>('/:id', {
 2115:     onRequest: [fastify.authenticate],
 2116:     config: { rateLimit: { max: 10, timeWindow: '1 minute' } }  // 高危操作，更严格限制
 2117:   }, async (request: FastifyRequest<{ Params: { id: string } }>, reply: FastifyReply) => {
 2118:     const { id } = request.params
 2119:     const packageId = parsePositiveRouteId(id)
 2120: 
 2121:     if (!packageId) {
 2122:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 2123:     }
 2124: 
 2125:     const pkg = await db.getPackageById(packageId)
 2126:     if (!pkg) {
 2127:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 2128:     }
 2129: 
 2130:     // 权限检查：只有管理员或套餐所有者可以删除
 2131:     if (pkg.user_id !== request.user.id && request.user.role !== 'admin') {
 2132:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 2133:     }
 2134: 
 2135:     const dependentPackages = await db.getPackagesDependingOnPackage(packageId)
 2136:     if (dependentPackages.length > 0) {
 2137:       return reply.code(400).send({
 2138:         error: `Package is required by other packages: ${dependentPackages.map(p => p.name).join(', ')}`,
 2139:         code: 'PACKAGE_PREREQUISITE_IN_USE',
 2140:         details: `请先删除后置套餐：${dependentPackages.map(p => p.name).join('、')}`
 2141:       })
 2142:     }
 2143: 
 2144:     // 检查是否有实例使用此套餐
 2145:     const instanceCount = await db.getInstanceCountByPackage(packageId)
 2146:     if (instanceCount > 0) {
 2147:       return reply.code(400).send(apiError(ErrorCode.PACKAGE_HAS_INSTANCES, `${instanceCount}`))
 2148:     }
 2149: 
 2150:     // 删除套餐会自动删除所有共享记录（级联删除）
 2151:     await db.deletePackage(packageId)
 2152: 
 2153:     // 更新套餐配额使用量（减少）
 2154:     const { decrementUserQuotaUsed } = await import('../db/quota-operations.js')
 2155:     await decrementUserQuotaUsed(request.user.id, 'package')
 2156: 
 2157:     await createLog(request.user.id, 'package', 'package.delete', `Deleted package "${pkg.name}" [CPU: ${pkg.cpu_max}%, Memory: ${pkg.memory_max}MB]`, 'success')
 2158: 
 2159:     return { message: 'Package deleted' }
 2160:   })
 2161: 
 2162:   // ==================== 套餐共享 API（已禁用 - 好友系统已移除） ====================
 2163: 
 2164:   // 共享套餐给好友
 2165:   fastify.post<{
 2166:     Params: { id: string }
 2167:     Body: { friendId: number; quotaMultiplier?: number | null; maxInstances?: number | null }
 2168:   }>('/:id/share', {
 2169:     onRequest: [fastify.authenticateUser]
 2170:   }, async (request, reply: FastifyReply) => {
 2171:     const { id } = request.params
 2172:     const { user } = request
 2173:     const packageId = parsePositiveRouteId(id)
 2174:     let shareInput: NormalizedPackageShareInput
 2175:     try {
 2176:       shareInput = normalizePackageShareInput(request.body, { requireFriendId: true })
 2177:     } catch (error) {
 2178:       return reply.code(400).send(error)
 2179:     }
 2180:     const { friendId, quotaMultiplier, maxInstances } = shareInput
 2181: 
 2182:     if (!packageId) {
 2183:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 2184:     }
 2185: 
 2186:     // 获取套餐并验证所有权
 2187:     const pkg = await db.getPackageById(packageId)
 2188:     if (!pkg) {
 2189:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 2190:     }
 2191:     if (pkg.user_id !== user.id) {
 2192:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 2193:     }
 2194: 
 2195:     // 验证好友关系
 2196:     const areFriends = await db.areFriends(user.id, friendId!)
 2197:     if (!areFriends) {
 2198:       return reply.code(400).send(apiError(ErrorCode.NOT_FRIENDS))
 2199:     }
 2200: 
 2201:     // 检查是否已共享
 2202:     const existingShare = await packageShares.isPackageSharedTo(packageId, friendId!)
 2203:     if (existingShare) {
 2204:       return reply.code(400).send(apiError(ErrorCode.PACKAGE_ALREADY_SHARED))
 2205:     }
 2206: 
 2207:     // 创建共享
 2208:     const shareId = await packageShares.sharePackage(packageId, user.id, friendId!, quotaMultiplier, maxInstances)
 2209:     return { success: true, shareId }
 2210:   })
 2211: 
 2212:   // 取消套餐共享
 2213:   fastify.delete<{
 2214:     Params: { id: string; userId: string }
 2215:   }>('/:id/share/:userId', {
 2216:     onRequest: [fastify.authenticateUser]
 2217:   }, async (request, reply: FastifyReply) => {
 2218:     const { id, userId } = request.params
 2219:     const { user } = request
 2220:     const packageId = parsePositiveRouteId(id)
 2221:     const targetUserId = parsePositiveRouteId(userId)
 2222: 
 2223:     if (!packageId || !targetUserId) {
 2224:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 2225:     }
 2226: 
 2227:     // 获取套餐并验证所有权
 2228:     const pkg = await db.getPackageById(packageId)
 2229:     if (!pkg) {
 2230:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 2231:     }
 2232:     if (pkg.user_id !== user.id) {
 2233:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 2234:     }
 2235: 
 2236:     // 取消共享
 2237:     const success = await packageShares.unsharePackage(packageId, targetUserId)
 2238:     return { success }
 2239:   })
 2240: 
 2241:   // 修改共享配额限制
 2242:   fastify.patch<{
 2243:     Params: { id: string; shareId: string }
 2244:     Body: { quotaMultiplier?: number | null; maxInstances?: number | null }
 2245:   }>('/:id/shares/:shareId', {
 2246:     onRequest: [fastify.authenticateUser]
 2247:   }, async (request, reply: FastifyReply) => {
 2248:     const { id, shareId } = request.params
 2249:     const { user } = request
 2250:     const packageId = parsePositiveRouteId(id)
 2251:     const shareIdNum = parsePositiveRouteId(shareId)
 2252:     let shareInput: NormalizedPackageShareInput
 2253:     try {
 2254:       shareInput = normalizePackageShareInput(request.body, { requireFriendId: false })
 2255:     } catch (error) {
 2256:       return reply.code(400).send(error)
 2257:     }
 2258:     const { quotaMultiplier, maxInstances } = shareInput
 2259: 
 2260:     if (!packageId || !shareIdNum) {
 2261:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 2262:     }
 2263: 
 2264:     // 获取套餐并验证所有权
 2265:     const pkg = await db.getPackageById(packageId)
 2266:     if (!pkg) {
 2267:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 2268:     }
 2269:     if (pkg.user_id !== user.id) {
 2270:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 2271:     }
 2272: 
 2273:     // 更新共享配额
 2274:     const success = await packageShares.updateShareQuota(shareIdNum, packageId, quotaMultiplier, maxInstances)
 2275:     if (!success) {
 2276:       return reply.code(404).send(apiError(ErrorCode.SHARE_NOT_FOUND))
 2277:     }
 2278:     return { success: true }
 2279:   })
 2280: 
 2281:   // 获取套餐的共享列表
 2282:   fastify.get<{ Params: { id: string } }>('/:id/shares', {
 2283:     onRequest: [fastify.authenticateUser]
 2284:   }, async (request, reply: FastifyReply) => {
 2285:     const { id } = request.params
 2286:     const { user } = request
 2287:     const packageId = parsePositiveRouteId(id)
 2288: 
 2289:     if (!packageId) {
 2290:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 2291:     }
 2292: 
 2293:     // 获取套餐并验证所有权
 2294:     const pkg = await db.getPackageById(packageId)
 2295:     if (!pkg) {
 2296:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 2297:     }
 2298:     if (pkg.user_id !== user.id) {
 2299:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 2300:     }
 2301: 
 2302:     // 获取共享列表
 2303:     const shares = await packageShares.getPackageShares(packageId)
 2304:     return { shares }
 2305:   })
 2306: 
 2307:   // 获取用户共享出去的所有套餐
 2308:   fastify.get('/my-shares', {
