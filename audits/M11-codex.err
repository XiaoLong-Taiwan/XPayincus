  143: function isHostTypeCompatibleWithPackage(
  144:   hostType: string | null | undefined,
  145:   packageType: string | null | undefined
  146: ): boolean {
  147:   const normalizedHostType = hostType || 'container'
  148:   const normalizedPackageType = packageType || 'container'
  149:   return normalizedHostType === 'both' || normalizedHostType === normalizedPackageType
  150: }
