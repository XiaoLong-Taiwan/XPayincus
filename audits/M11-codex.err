  702: function getPackagePrerequisiteError(error: unknown): { code: string; message: string } | null {
  703:   const message = error instanceof Error ? error.message : String(error)
  704:   const separatorIndex = message.indexOf(':')
  705:   if (separatorIndex <= 0) return null
  706: 
  707:   const code = message.slice(0, separatorIndex)
  708:   if (!PACKAGE_PREREQUISITE_ERROR_CODES.has(code)) return null
  709: 
  710:   return {
  711:     code,
  712:     message: message.slice(separatorIndex + 1).trim() || code
  713:   }
  714: }
