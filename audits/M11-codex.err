  133: function validatePackageNetworkModeForInstanceType(
  134:   instanceType: string | undefined,
  135:   networkMode: string | undefined
  136: ): string | null {
  137:   if (instanceType === 'vm' && networkMode && KVM_UNSUPPORTED_NETWORK_MODES.has(networkMode)) {
  138:     return 'KVM packages do not support IPv4 NAT & IPv6 NAT or IPv6 NAT network modes'
  139:   }
  140:   return null
  141: }
