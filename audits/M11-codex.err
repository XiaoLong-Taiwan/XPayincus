  103: function parsePositiveRouteId(value: string): number | null {
  104:   if (!POSITIVE_ROUTE_ID_PATTERN.test(value)) return null
  105:   const parsed = Number(value)
  106:   return Number.isSafeInteger(parsed) ? parsed : null
  107: }
  108: 
  109: function parseOptionalPositiveQueryInteger(value: string | undefined): number | null | undefined {
  110:   if (value === undefined || value === '') return undefined
  111:   return parsePositiveRouteId(value)
  112: }
