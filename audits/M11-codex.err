 1522:       maxMemory: null,
 1523:       remainingMemory: null,
 1524:       ownerUsername: null
 1525:     }
 1526: 
 1527:     // 只有在用户有权限访问套餐时才计算配额信息
 1528:     if (canAccess) {
 1529:       if (!isOwn) {
 1530:         // 如果是共享套餐，计算剩余配额
 1531:         const shareInfo = await packageShares.getPackageShareForUser(packageId, user.id)
 1532:         if (shareInfo) {
 1533:           const usage = await packageShares.getSharedPackageUsage(packageId, user.id)
 1534:           
 1535:           // 获取套餐所有者用户名
 1536:           if (pkg.user_id) {
 1537:             const owner = await db.findUserById(pkg.user_id)
 1538:             quotaInfo.ownerUsername = owner?.username || null
 1539:           }
 1540: 
 1541:           // 实例数量配额
 1542:           if (shareInfo.maxInstances !== null) {
 1543:             quotaInfo.maxInstances = shareInfo.maxInstances
 1544:             quotaInfo.remainingInstances = Math.max(0, shareInfo.maxInstances - usage.instanceCount)
 1545:           } else {
 1546:             quotaInfo.maxInstances = null
 1547:             quotaInfo.remainingInstances = null // 无限制
 1548:           }
 1549: 
 1550:           // CPU/内存配额
 1551:           if (shareInfo.quotaMultiplier !== null) {
 1552:             quotaInfo.maxCpu = Math.floor(pkg.cpu_max * shareInfo.quotaMultiplier)
 1553:             quotaInfo.remainingCpu = Math.max(0, quotaInfo.maxCpu - usage.totalCpu)
 1554:             quotaInfo.maxMemory = Math.floor(pkg.memory_max * shareInfo.quotaMultiplier)
 1555:             quotaInfo.remainingMemory = Math.max(0, quotaInfo.maxMemory - usage.totalMemory)
 1556:           } else {
 1557:             quotaInfo.maxCpu = null
 1558:             quotaInfo.remainingCpu = null // 无限制
 1559:             quotaInfo.maxMemory = null
 1560:             quotaInfo.remainingMemory = null // 无限制
 1561:           }
 1562:         }
 1563:       } else {
 1564:         // 自己的套餐，获取所有者用户名
 1565:         quotaInfo.ownerUsername = user.username
 1566:         // 自己的套餐无限制
 1567:         quotaInfo.maxInstances = null
 1568:         quotaInfo.remainingInstances = null
 1569:         quotaInfo.maxCpu = null
 1570:         quotaInfo.remainingCpu = null
 1571:         quotaInfo.maxMemory = null
 1572:         quotaInfo.remainingMemory = null
