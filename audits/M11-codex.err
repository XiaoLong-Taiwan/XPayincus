 2114:   fastify.delete<{ Params: { id: string } }>('/:id', {
 2115:     onRequest: [fastify.authenticate],
 2116:     config: { rateLimit: { max: 10, timeWindow: '1 minute' } }  // 高危操作，更严格限制
 2117:   }, async (request: FastifyRequest<{ Params: { id: string } }>, reply: FastifyReply) => {
 2118:     const { id } = request.params
 2119:     const packageId = parsePositiveRouteId(id)
 2120: 
 2121:     if (!packageId) {
 2122:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 2123:     }
 2124: 
 2125:     const pkg = await db.getPackageById(packageId)
 2126:     if (!pkg) {
 2127:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 2128:     }
 2129: 
 2130:     // 权限检查：只有管理员或套餐所有者可以删除
 2131:     if (pkg.user_id !== request.user.id && request.user.role !== 'admin') {
 2132:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 2133:     }
 2134: 
 2135:     const dependentPackages = await db.getPackagesDependingOnPackage(packageId)
 2136:     if (dependentPackages.length > 0) {
 2137:       return reply.code(400).send({
 2138:         error: `Package is required by other packages: ${dependentPackages.map(p => p.name).join(', ')}`,
 2139:         code: 'PACKAGE_PREREQUISITE_IN_USE',
 2140:         details: `请先删除后置套餐：${dependentPackages.map(p => p.name).join('、')}`
 2141:       })
 2142:     }
 2143: 
 2144:     // 检查是否有实例使用此套餐
 2145:     const instanceCount = await db.getInstanceCountByPackage(packageId)
 2146:     if (instanceCount > 0) {
 2147:       return reply.code(400).send(apiError(ErrorCode.PACKAGE_HAS_INSTANCES, `${instanceCount}`))
 2148:     }
 2149: 
 2150:     // 删除套餐会自动删除所有共享记录（级联删除）
 2151:     await db.deletePackage(packageId)
 2152: 
 2153:     // 更新套餐配额使用量（减少）
 2154:     const { decrementUserQuotaUsed } = await import('../db/quota-operations.js')
 2155:     await decrementUserQuotaUsed(request.user.id, 'package')
 2156: 
 2157:     await createLog(request.user.id, 'package', 'package.delete', `Deleted package "${pkg.name}" [CPU: ${pkg.cpu_max}%, Memory: ${pkg.memory_max}MB]`, 'success')
 2158: 
 2159:     return { message: 'Package deleted' }
 2160:   })
