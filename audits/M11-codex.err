 1901:     }
 1902:   }, async (request: FastifyRequest<{
 1903:     Params: { id: string }
 1904:     Body: UpdatePackageRequest
 1905:   }>, reply: FastifyReply) => {
 1906:     const { id } = request.params
 1907:     const packageId = parsePositiveRouteId(id)
 1908: 
 1909:     if (!packageId) {
 1910:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 1911:     }
 1912: 
 1913:     const pkg = await db.getPackageById(packageId)
 1914:     if (!pkg) {
 1915:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 1916:     }
 1917: 
 1918:     // 权限检查：只有管理员或套餐所有者可以更新
 1919:     if (pkg.user_id !== request.user.id && request.user.role !== 'admin') {
 1920:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 1921:     }
 1922: 
 1923:     let packageInput: NormalizedPackageInput
 1924:     try {
 1925:       packageInput = normalizePackageInput(request.body, { requireAll: false })
 1926:     } catch (error) {
 1927:       return reply.code(400).send(error)
 1928:     }
 1929: 
 1930:     // 如果更新名称，检查是否冲突（同一用户下）
 1931:     if (packageInput.name && packageInput.name !== pkg.name) {
 1932:       const existing = await db.getPackageByUserAndName(pkg.user_id!, packageInput.name)
 1933:       if (existing) {
 1934:         return reply.code(400).send({ error: 'Package name already exists', code: 'NAME_EXISTS' })
 1935:       }
 1936:     }
 1937: 
 1938:     // 处理流量限额和套餐资源限制
 1939:     const {
 1940:       monthlyTrafficLimit, trafficResetPrice, portLimit, snapshotLimit, backupLimit, siteLimit, hostIds, hostStoragePools, hostTrafficMultipliers,
 1941:       ioLimitMode, limitsRead, limitsWrite, limitsReadIops, limitsWriteIops,
 1942:       limitsIngress, limitsEgress, limitsProcesses, limitsCpuPriority,
 1943:       bootAutostart, bootAutostartPriority, bootAutostartDelay, bootHostShutdownTimeout,
 1944:       globalShared, globalQuotaMultiplier, globalMaxInstances,
 1945:       requiredPackageId
 1946:     } = packageInput
 1947:     const updateData: Parameters<typeof db.updatePackage>[1] = {}
 1948:     if (packageInput.name !== undefined) updateData.name = packageInput.name
 1949:     if (packageInput.description !== undefined) updateData.description = packageInput.description
 1950:     if (packageInput.cpuMax !== undefined) updateData.cpuMax = packageInput.cpuMax
 1951:     if (packageInput.memoryMax !== undefined) updateData.memoryMax = packageInput.memoryMax
 1952:     if (packageInput.diskMax !== undefined) updateData.diskMax = packageInput.diskMax
 1953:     if (packageInput.bandwidthMax !== undefined) updateData.bandwidthMax = packageInput.bandwidthMax
 1954:     if (packageInput.networkMode !== undefined) updateData.networkMode = packageInput.networkMode
 1955:     if (packageInput.instanceType !== undefined) updateData.instanceType = packageInput.instanceType
 1956:     if (packageInput.privileged !== undefined) updateData.privileged = packageInput.privileged
 1957:     if (packageInput.nested !== undefined) updateData.nested = packageInput.nested
 1958:     if (packageInput.active !== undefined) updateData.active = packageInput.active
 1959:     updateData.allowInstanceDeletion = true
 1960:     const nextInstanceType = packageInput.instanceType ?? pkg.instance_type ?? 'container'
 1961:     const nextNetworkMode = packageInput.networkMode ?? pkg.network_mode ?? 'nat'
 1962: 
 1963:     const packageNetworkModeError = validatePackageNetworkModeForInstanceType(nextInstanceType, nextNetworkMode)
 1964:     if (packageNetworkModeError) {
 1965:       return reply.code(400).send({ error: packageNetworkModeError, code: 'KVM_NETWORK_MODE_UNSUPPORTED' })
 1966:     }
 1967: 
 1968:     // 如果提供了 hostIds，验证必须至少绑定一个宿主机
 1969:     if (hostIds !== undefined) {
 1970:       if (hostIds.length === 0) {
 1971:         return reply.code(400).send({ error: 'Package must bind at least one host', code: 'NO_HOSTS' })
 1972:       }
 1973:       updateData.hostIds = hostIds
 1974:     }
 1975: 
 1976:     const nextHostIds = hostIds ?? ((pkg as { host_ids?: number[] }).host_ids || [])
 1977:     const incompatibleHosts = await getIncompatiblePackageHosts(nextHostIds, nextInstanceType)
 1978:     if (incompatibleHosts.length > 0) {
 1979:       return reply.code(400).send(incompatiblePackageHostsResponse(incompatibleHosts, nextInstanceType))
 1980:     }
 1981: 
 1982:     const storageUnavailableHosts = await getHostsWithoutSystemDiskPool(nextHostIds, {
 1983:       packageId,
 1984:       hostStoragePools
 1985:     })
 1986:     if (storageUnavailableHosts.length > 0) {
 1987:       return reply.code(400).send(storagePoolUnavailableResponse(storageUnavailableHosts))
 1988:     }
 1989: 
 1990:     if (hostStoragePools !== undefined) updateData.hostStoragePools = hostStoragePools
 1991:     if (hostTrafficMultipliers !== undefined) updateData.hostTrafficMultipliers = hostTrafficMultipliers
 1992: 
 1993:     let parsedMonthlyTrafficLimit: bigint | null | undefined
 1994:     if (monthlyTrafficLimit !== undefined) {
 1995:       parsedMonthlyTrafficLimit = parseNullablePostgresBigIntInput(monthlyTrafficLimit)
 1996:       if (parsedMonthlyTrafficLimit === undefined) {
 1997:         return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid monthly traffic limit'))
 1998:       }
 1999:       updateData.monthlyTrafficLimit = parsedMonthlyTrafficLimit
 2000:     }
 2001:     if (trafficResetPrice !== undefined) updateData.trafficResetPrice = trafficResetPrice
