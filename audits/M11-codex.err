 2315: 
 2316:   // ==================== 资源释放功能 ====================
 2317: 
 2318:   // 获取套餐绑定的宿主机详情（用于释放配额界面）
 2319:   fastify.get<{ Params: { id: string } }>('/:id/hosts-detail', {
 2320:     onRequest: [fastify.authenticate]
 2321:   }, async (request: FastifyRequest<{ Params: { id: string } }>, reply: FastifyReply) => {
 2322:     const { id } = request.params
 2323:     const { user } = request
 2324:     const packageId = parsePositiveRouteId(id)
 2325: 
 2326:     if (!packageId) {
 2327:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 2328:     }
 2329: 
 2330:     const pkg = await db.getPackageById(packageId)
 2331:     if (!pkg) {
 2332:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 2333:     }
 2334:     if (pkg.user_id !== user.id && user.role !== 'admin') {
 2335:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 2336:     }
 2337: 
 2338:     const hosts = await db.getPackageHostsDetail(packageId)
 2339: 
 2340:     return {
 2341:       hosts,
 2342:       packageName: pkg.name,
 2343:       cpuMax: pkg.cpu_max,
 2344:       memoryMax: pkg.memory_max
 2345:     }
 2346:   })
 2347: 
 2348:   // 获取套餐所有者的托管信息（用于创建实例页面显示托管者详情）
 2349:   fastify.get<{ Params: { id: string } }>('/:id/owner-info', {
 2350:     onRequest: [fastify.authenticateUser]
 2351:   }, async (request: FastifyRequest<{ Params: { id: string } }>, reply: FastifyReply) => {
 2352:     const { id } = request.params
 2353:     const { user } = request
 2354:     const packageId = parsePositiveRouteId(id)
 2355: 
 2356:     if (!packageId) {
 2357:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 2358:     }
 2359: 
 2360:     const pkg = await db.getPackageById(packageId)
 2361:     if (!pkg) {
 2362:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 2363:     }
 2364: 
 2365:     // 套餐必须有所有者，且必须是普通用户的托管套餐
 2366:     if (!pkg.user_id) {
 2367:       return reply.code(404).send(apiError(ErrorCode.NOT_FOUND, '该套餐不是托管套餐'))
 2368:     }
 2369: 
 2370:     if (pkg.user_id !== user.id && await db.isUserBlockedFromPackage(user.id, packageId)) {
 2371:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 2372:     }
 2373: 
 2374:     const owner = await prisma.user.findUnique({
 2375:       where: { id: pkg.user_id },
 2376:       select: {
 2377:         id: true,
 2378:         username: true,
 2379:         email: true,
 2380:         avatarStyle: true,
 2381:         avatarBadgeId: true,
 2382:         createdAt: true,
 2383:         role: true
 2384:       }
 2385:     })
 2386: 
 2387:     if (!owner || !owner.email || owner.role === 'admin') {
 2388:       return reply.code(404).send(apiError(ErrorCode.NOT_FOUND, '该套餐不是托管套餐'))
 2389:     }
 2390: 
 2391:     // 获取所有者详细信息
 2392:     const [hostCount, instanceCount, totalHostingIncome] = await Promise.all([
 2393:       // 该用户持有的托管节点数
 2394:       prisma.host.count({
 2395:         where: { userId: pkg.user_id }
 2396:       }),
 2397:       // 该用户托管节点的总实例数（不含已删除）
 2398:       prisma.instance.count({
 2399:         where: {
 2400:           host: { userId: pkg.user_id },
 2401:           status: { not: 'deleted' }
 2402:         }
 2403:       }),
 2404:       // 计算历史托管总收入（用于VIP等级）
 2405:       prisma.hostingBalanceLog.aggregate({
 2406:         where: {
 2407:           userId: pkg.user_id,
 2408:           type: 'income'  // 只计算收入记录
 2409:         },
 2410:         _sum: { amount: true }
 2411:       })
 2412:     ])
 2413: 
 2414:     // 计算注册天数
 2415:     const registeredDays = Math.floor((Date.now() - owner.createdAt.getTime()) / (1000 * 60 * 60 * 24))
 2416: 
 2417:     // 计算VIP等级（基于后台配置的托管 VIP 规则）
 2418:     const totalIncome = Number(totalHostingIncome._sum.amount || 0)
 2419:     const vipRules = await getVipRules('hosting')
 2420:     const vipLevel = calculateVipLevel('hosting', vipRules, {
 2421:       totalHostingIncome: totalIncome,
 2422:       instanceCount
 2423:     })
 2424:     const vipBadgeStyle = getVipBadgeStyleForLevel(vipRules, 'hosting', vipLevel)
 2425: 
 2426:     return {
 2427:       id: owner.id,
 2428:       username: owner.username,
 2429:       email: owner.email,
 2430:       avatarStyle: owner.avatarStyle,
 2431:       avatarBadgeId: owner.avatarBadgeId,
 2432:       hostCount,
 2433:       instanceCount,
 2434:       registeredDays,
 2435:       vipLevel,
 2436:       vipBadgeStyle
 2437:     }
 2438:   })
 2439: 
 2440: 
 2441:   // 释放配额
 2442:   fastify.post<{
 2443:     Params: { id: string }
 2444:     Body: {
 2445:       hostIds: number[]
 2446:       cpuAdd: number
 2447:       memoryAdd: number
 2448:       notify?: boolean
 2449:     }
 2450:   }>('/:id/release-quota', {
 2451:     onRequest: [fastify.authenticate],
 2452:     config: { rateLimit: { max: 10, timeWindow: '1 minute' } },  // 修改资源配额，严格限制
 2453:     schema: {
 2454:       body: {
 2455:         type: 'object',
 2456:         required: ['hostIds', 'cpuAdd', 'memoryAdd'],
 2457:         properties: {
 2458:           hostIds: { type: 'array', items: { type: 'integer' }, minItems: 1, maxItems: 100 },
 2459:           cpuAdd: { type: 'integer', minimum: 0, maximum: 10000 },
 2460:           memoryAdd: { type: 'integer', minimum: 0, maximum: 1048576 },
 2461:           notify: { type: 'boolean' }
 2462:         }
 2463:       }
 2464:     }
 2465:   }, async (request: FastifyRequest<{
 2466:     Params: { id: string }
 2467:     Body: {
 2468:       hostIds: number[]
 2469:       cpuAdd: number
 2470:       memoryAdd: number
 2471:       notify?: boolean
 2472:     }
 2473:   }>, reply: FastifyReply) => {
 2474:     const { id } = request.params
 2475:     const { hostIds, cpuAdd, memoryAdd, notify } = request.body
 2476:     const { user } = request
 2477:     const packageId = parsePositiveRouteId(id)
 2478: 
 2479:     if (!packageId) {
 2480:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 2481:     }
 2482: 
 2483:     // 验证至少有一个配额大于 0
 2484:     if (cpuAdd <= 0 && memoryAdd <= 0) {
 2485:       return reply.code(400).send({ error: 'At least one quota must be greater than 0' })
 2486:     }
 2487: 
 2488:     const pkg = await db.getPackageById(packageId)
 2489:     if (!pkg) {
 2490:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 2491:     }
 2492:     if (pkg.user_id !== user.id && user.role !== 'admin') {
 2493:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 2494:     }
 2495: 
 2496:     // 验证所有 hostIds 都属于该套餐
 2497:     const packageHostIds = pkg.host_ids || []
 2498:     const invalidHosts = hostIds.filter(hid => !packageHostIds.includes(hid))
 2499:     if (invalidHosts.length > 0) {
 2500:       return reply.code(400).send({ error: 'Some hosts are not bound to this package' })
 2501:     }
 2502: 
 2503:     // 为每个宿主机增加配额
 2504:     const results: Array<{
 2505:       hostId: number
 2506:       hostName: string
 2507:       countryCode: string
 2508:       cpuAllowanceMax: number
 2509:       memoryMax: number
 2510:       cpuAvailable: number
 2511:       memoryAvailable: number
 2512:     }> = []
 2513: 
 2514:     for (const hostId of hostIds) {
 2515:       const host = await db.getHostById(hostId)
 2516:       if (!host) continue
 2517: 
 2518:       const updated = await db.increaseHostQuota(hostId, cpuAdd, memoryAdd)
 2519:       results.push({
 2520:         hostId: host.id,
 2521:         hostName: host.name,
 2522:         countryCode: host.country_code || 'us',
 2523:         cpuAllowanceMax: updated.cpuAllowanceMax,
 2524:         memoryMax: updated.memoryMax,
 2525:         cpuAvailable: updated.cpuAllowanceMax - (host.cpu_used || 0),
 2526:         memoryAvailable: updated.memoryMax - (host.memory_used || 0)
 2527:       })
 2528:     }
 2529: 
 2530:     // 记录日志
 2531:     await createLog(
 2532:       user.id,
 2533:       'package',
 2534:       'package.release_quota',
 2535:       `Released quota for package "${pkg.name}": CPU +${cpuAdd}%, Memory +${memoryAdd}MB on ${hostIds.length} host(s)`,
 2536:       'success'
 2537:     )
 2538: 
 2539:     // 发送通知（仅当 notify=true 且全局渠道存在时）
 2540:     if (notify) {
 2541:       const globalChannel = await prisma.notificationChannel.findFirst({
 2542:         where: { isGlobal: true },
 2543:         select: { id: true }
 2544:       })
 2545:       if (globalChannel) {
 2546:         // 构建通知消息
 2547:         const hostDetails = results.map(r => 
 2548:           `• ${r.hostName.toUpperCase()}: CPU ${r.cpuAvailable}% | 内存 ${formatMemory(r.memoryAvailable)}`
 2549:         ).join('\n')
 2550: 
 2551:         const notifyTitle = `📦 资源释放 - ${pkg.name}`
 2552:         // 判断套餐来源：管理员创建的套餐为 official，普通用户创建的为 market
 2553:         const pkgOwner = await prisma.user.findUnique({ where: { id: pkg.user_id }, select: { role: true } })
 2554:         const pkgSource = pkgOwner?.role === 'admin' ? 'official' : 'market'
 2555:         const buyLink = process.env.SITE_URL
 2556:           ? { label: '🛒 立即开通', url: `${process.env.SITE_URL}/instances/create?source=${pkgSource}&package=${packageId}` }
 2557:           : undefined
 2558:         const notifyMessage = [
 2559:           `+${cpuAdd}% CPU / +${formatMemory(memoryAdd)} 内存`,
 2560:           '',
 2561:           '当前可用配额：',
 2562:           hostDetails,
 2563:           '',
 2564:           `⏰ ${new Date().toLocaleString('zh-CN', { timeZone: 'Asia/Shanghai' })}`
 2565:         ].join('\n')
 2566: 
 2567:         try {
 2568:           await sendToChannel(globalChannel.id, notifyTitle, notifyMessage, buyLink)
 2569:         } catch {
 2570:           // 通知发送失败不影响主流程
 2571:         }
 2572:       }
 2573:     }
 2574: 
 2575:     return {
 2576:       message: 'Quota released successfully',
 2577:       results
 2578:     }
 2579:   })
 2580: 
 2581:   // ==================== 套餐方案管理 API ====================
 2582: 
 2583:   // 获取套餐下的所有方案
 2584:   fastify.get<{ Params: { id: string }; Querystring: { activeOnly?: string } }>('/:id/plans', {
 2585:     onRequest: [fastify.authenticate]
 2586:   }, async (request: FastifyRequest<{ Params: { id: string }; Querystring: { activeOnly?: string } }>, reply: FastifyReply) => {
 2587:     const { id } = request.params
 2588:     const { user } = request
 2589:     const packageId = parsePositiveRouteId(id)
 2590:     const activeOnly = request.query.activeOnly === 'true'
 2591: 
 2592:     if (!packageId) {
 2593:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 2594:     }
 2595: 
 2596:     const pkg = await db.getPackageById(packageId)
 2597:     if (!pkg) {
 2598:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 2599:     }
 2600: 
 2601:     if (pkg.user_id !== user.id && user.role !== 'admin') {
 2602:       const canAccess = await packageShares.canUserAccessPackage(user.id, packageId)
 2603:       if (!canAccess) {
 2604:         return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 2605:       }
 2606:     }
 2607: 
 2608:     const plans = await db.getPlansByPackageId(packageId, { activeOnly })
 2609: 
 2610:     return {
 2611:       plans: plans.map(plan => ({
 2612:         id: plan.id,
 2613:         name: plan.name,
 2614:         description: plan.description,
 2615:         cpu: plan.cpu,
 2616:         memory: plan.memory,
 2617:         disk: plan.disk,
 2618:         portLimit: plan.portLimit,
 2619:         snapshotLimit: plan.snapshotLimit,
 2620:         backupLimit: plan.backupLimit,
 2621:         siteLimit: plan.siteLimit,
 2622:         swapSize: pkg.instance_type === 'vm' ? 0 : plan.swapSize,
 2623:         trafficLimit: plan.trafficLimit.toString(),
 2624:         trafficLimitSpeed: plan.trafficLimitSpeed,
 2625:         price: Number(plan.price),
 2626:         trafficResetPrice: plan.trafficResetPrice === null ? null : Number(plan.trafficResetPrice),
 2627:         billingCycle: plan.billingCycle,
 2628:         setupFee: Number(plan.setupFee),
 2629:         monthlyPrice: db.calculateMonthlyPrice(plan),
 2630:         isActive: plan.isActive,
 2631:         isSoldOut: plan.isSoldOut,
 2632:         sortOrder: plan.sortOrder,
 2633:         slaGuarantee: plan.slaGuarantee ? Number(plan.slaGuarantee) : null
 2634:       }))
 2635:     }
 2636:   })
 2637: 
 2638:   // 创建套餐方案
 2639:   fastify.post<{
 2640:     Params: { id: string }
 2641:     Body: {
 2642:       name: string
 2643:       description?: string
 2644:       cpu: number
 2645:       memory: number
 2646:       disk: number
 2647:       portLimit: number
 2648:       snapshotLimit: number
 2649:       backupLimit: number
 2650:       siteLimit: number
 2651:       swapSize: number
 2652:       trafficLimit: string // BigInt 作为字符串传输
 2653:       trafficLimitSpeed?: string
 2654:       price: number
 2655:       trafficResetPrice?: number | null
 2656:       billingCycle?: number
 2657:       setupFee?: number
 2658:       isActive?: boolean
 2659:       isSoldOut?: boolean
 2660:       sortOrder?: number
 2661:       slaGuarantee?: number | null
 2662:     }
 2663:   }>('/:id/plans', {
 2664:     onRequest: [fastify.authenticate],
 2665:     config: { rateLimit: { max: 20, timeWindow: '1 minute' } }
 2666:   }, async (request, reply) => {
 2667:     const { id } = request.params
 2668:     const { user } = request
 2669:     const packageId = parsePositiveRouteId(id)
 2670: 
 2671:     if (!packageId) {
 2672:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 2673:     }
 2674: 
 2675:     // 验证套餐存在且属于当前用户
 2676:     const pkg = await db.getPackageById(packageId)
 2677:     if (!pkg) {
 2678:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 2679:     }
 2680:     if (pkg.user_id !== user.id && user.role !== 'admin') {
 2681:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 2682:     }
 2683: 
 2684:     let planInput: NormalizedPackagePlanInput
 2685:     try {
 2686:       planInput = normalizePackagePlanInput(request.body, {
 2687:         requireAll: true,
 2688:         isVm: pkg.instance_type === 'vm'
 2689:       })
 2690:     } catch (error) {
 2691:       return reply.code(400).send(error)
 2692:     }
 2693:     const planName = planInput.name!
 2694: 
 2695:     // 验证名称唯一性
 2696:     const isUnique = await db.isPlanNameUnique(packageId, planName)
 2697:     if (!isUnique) {
 2698:       return reply.code(400).send({ error: '该套餐下已存在同名方案' })
 2699:     }
 2700: 
 2701:     // 用户托管节点的方案只能按月计费
 2702:     if (user.role !== 'admin') {
 2703:       const actualBillingCycle = planInput.billingCycle ?? 1
 2704:       if (actualBillingCycle !== 1) {
 2705:         return reply.code(400).send({
 2706:           error: '用户托管节点的方案仅支持按月计费',
 2707:           code: 'HOSTING_MONTHLY_ONLY'
 2708:         })
 2709:       }
 2710:     }
 2711: 
 2712:     try {
 2713:       const parsedTrafficLimit = parseRequiredPostgresBigIntInput(planInput.trafficLimit)
 2714:       if (parsedTrafficLimit === undefined) {
 2715:         return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid plan traffic limit'))
 2716:       }
 2717:       let normalizedTrafficLimitSpeed: string | undefined
 2718:       if (planInput.trafficLimitSpeed !== undefined) {
 2719:         const parsedTrafficLimitSpeed = normalizePlanTrafficLimitSpeed(planInput.trafficLimitSpeed)
 2720:         if (parsedTrafficLimitSpeed === undefined) {
 2721:           return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid plan traffic limit speed'))
 2722:         }
 2723:         normalizedTrafficLimitSpeed = parsedTrafficLimitSpeed ?? '0'
 2724:       }
 2725: 
 2726:       const plan = await db.createPlan({
 2727:         packageId,
 2728:         name: planName,
 2729:         description: planInput.description,
 2730:         cpu: planInput.cpu!,
 2731:         memory: planInput.memory!,
 2732:         disk: planInput.disk!,
 2733:         portLimit: planInput.portLimit!,
 2734:         snapshotLimit: planInput.snapshotLimit!,
 2735:         backupLimit: planInput.backupLimit!,
 2736:         siteLimit: planInput.siteLimit!,
 2737:         swapSize: planInput.swapSize!,
 2738:         trafficLimit: parsedTrafficLimit,
 2739:         trafficLimitSpeed: normalizedTrafficLimitSpeed,
 2740:         price: planInput.price!,
 2741:         trafficResetPrice: planInput.trafficResetPrice ?? null,
 2742:         billingCycle: planInput.billingCycle,
 2743:         setupFee: 0,  // 开通费固定为0
 2744:         isActive: planInput.isActive,
 2745:         isSoldOut: planInput.isSoldOut,
 2746:         sortOrder: planInput.sortOrder,
 2747:         slaGuarantee: planInput.slaGuarantee
 2748:       })
 2749: 
 2750:       await createLog(
 2751:         user.id,
 2752:         'package',
 2753:         'plan.create',
 2754:         `Created plan "${planName}" for package "${pkg.name}"`,
 2755:         'success'
 2756:       )
 2757: 
 2758:       return {
 2759:         id: plan.id,
 2760:         name: plan.name,
 2761:         message: '方案创建成功'
 2762:       }
 2763:     } catch (error) {
 2764:       return reply.code(500).send({ error: '创建方案失败' })
 2765:     }
 2766:   })
 2767: 
 2768:   // 更新套餐方案
 2769:   fastify.put<{
 2770:     Params: { id: string; planId: string }
 2771:     Body: {
 2772:       name?: string
 2773:       description?: string
 2774:       cpu?: number
 2775:       memory?: number
 2776:       disk?: number
 2777:       portLimit?: number
 2778:       snapshotLimit?: number
 2779:       backupLimit?: number
 2780:       siteLimit?: number
 2781:       swapSize?: number
 2782:       trafficLimit?: string
 2783:       trafficLimitSpeed?: string
 2784:       price?: number
 2785:       trafficResetPrice?: number | null
 2786:       billingCycle?: number
 2787:       setupFee?: number
 2788:       isActive?: boolean
 2789:       isSoldOut?: boolean
 2790:       sortOrder?: number
 2791:       slaGuarantee?: number | null
 2792:     }
 2793:   }>('/:id/plans/:planId', {
 2794:     onRequest: [fastify.authenticate],
 2795:     config: { rateLimit: { max: 20, timeWindow: '1 minute' } }
 2796:   }, async (request, reply) => {
 2797:     const { id, planId } = request.params
 2798:     const { user } = request
 2799:     const packageId = parsePositiveRouteId(id)
 2800:     const planIdNum = parsePositiveRouteId(planId)
 2801: 
 2802:     if (!packageId || !planIdNum) {
 2803:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 2804:     }
 2805: 
 2806:     // 验证套餐存在且属于当前用户
 2807:     const pkg = await db.getPackageById(packageId)
 2808:     if (!pkg) {
 2809:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 2810:     }
 2811:     if (pkg.user_id !== user.id && user.role !== 'admin') {
 2812:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 2813:     }
 2814: 
 2815:     // 验证方案存在且属于该套餐
 2816:     const existingPlan = await db.getPlanById(planIdNum)
 2817:     if (!existingPlan || existingPlan.packageId !== packageId) {
 2818:       return reply.code(404).send({ error: '方案不存在' })
 2819:     }
 2820: 
 2821:     let planInput: NormalizedPackagePlanInput
 2822:     try {
 2823:       planInput = normalizePackagePlanInput(request.body, {
 2824:         requireAll: false,
 2825:         isVm: pkg.instance_type === 'vm'
 2826:       })
 2827:     } catch (error) {
 2828:       return reply.code(400).send(error)
 2829:     }
 2830:     const planName = planInput.name
 2831: 
 2832:     // 如果修改了名称，验证唯一性
 2833:     if (planName !== undefined && planName !== existingPlan.name) {
 2834:       const isUnique = await db.isPlanNameUnique(packageId, planName, planIdNum)
 2835:       if (!isUnique) {
 2836:         return reply.code(400).send({ error: '该套餐下已存在同名方案' })
 2837:       }
 2838:     }
 2839: 
 2840:     // 用户托管节点的方案只能按月计费
 2841:     if (user.role !== 'admin' && planInput.billingCycle !== undefined && planInput.billingCycle !== 1) {
 2842:       return reply.code(400).send({
 2843:         error: '用户托管节点的方案仅支持按月计费',
 2844:         code: 'HOSTING_MONTHLY_ONLY'
 2845:       })
 2846:     }
 2847: 
 2848:     try {
 2849:       const updateData: any = {}
 2850:       if (planName !== undefined) updateData.name = planName
 2851:       if (planInput.description !== undefined) updateData.description = planInput.description
 2852:       if (planInput.cpu !== undefined) updateData.cpu = planInput.cpu
 2853:       if (planInput.memory !== undefined) updateData.memory = planInput.memory
 2854:       if (planInput.disk !== undefined) updateData.disk = planInput.disk
 2855:       if (planInput.portLimit !== undefined) updateData.portLimit = planInput.portLimit
 2856:       if (planInput.snapshotLimit !== undefined) updateData.snapshotLimit = planInput.snapshotLimit
 2857:       if (planInput.backupLimit !== undefined) updateData.backupLimit = planInput.backupLimit
 2858:       if (planInput.siteLimit !== undefined) updateData.siteLimit = planInput.siteLimit
 2859:       if (pkg.instance_type === 'vm') {
 2860:         updateData.swapSize = 0
 2861:       } else if (planInput.swapSize !== undefined) {
 2862:         updateData.swapSize = planInput.swapSize
 2863:       }
 2864:       if (planInput.trafficLimit !== undefined) {
 2865:         const parsedTrafficLimit = parseRequiredPostgresBigIntInput(planInput.trafficLimit)
 2866:         if (parsedTrafficLimit === undefined) {
 2867:           return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid plan traffic limit'))
 2868:         }
 2869:         updateData.trafficLimit = parsedTrafficLimit
 2870:       }
 2871:       if (planInput.trafficLimitSpeed !== undefined) {
 2872:         const parsedTrafficLimitSpeed = normalizePlanTrafficLimitSpeed(planInput.trafficLimitSpeed)
 2873:         if (parsedTrafficLimitSpeed === undefined) {
 2874:           return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid plan traffic limit speed'))
 2875:         }
 2876:         updateData.trafficLimitSpeed = parsedTrafficLimitSpeed ?? '0'
 2877:       }
 2878:       if (planInput.price !== undefined) updateData.price = planInput.price
 2879:       if (planInput.trafficResetPrice !== undefined) updateData.trafficResetPrice = planInput.trafficResetPrice
 2880:       if (planInput.billingCycle !== undefined) updateData.billingCycle = planInput.billingCycle
 2881:       // setupFee 已废弃，不再接受更新
 2882:       if (planInput.isActive !== undefined) updateData.isActive = planInput.isActive
 2883:       if (planInput.isSoldOut !== undefined) updateData.isSoldOut = planInput.isSoldOut
 2884:       if (planInput.sortOrder !== undefined) updateData.sortOrder = planInput.sortOrder
 2885:       if (planInput.slaGuarantee !== undefined) updateData.slaGuarantee = planInput.slaGuarantee
 2886: 
 2887:       const updatedPlan = await db.updatePlan(planIdNum, updateData)
 2888: 
 2889:       // 如果修改了配额相关字段，同步到所有关联实例
 2890:       const quotaFields = ['portLimit', 'snapshotLimit', 'backupLimit', 'siteLimit', 'swapSize', 'trafficLimit']
 2891:       const hasQuotaChange = quotaFields.some(f => updateData[f] !== undefined)
 2892:       if (hasQuotaChange) {
 2893:         const syncResult = await db.syncPlanQuotaToInstances(planIdNum, updatedPlan, existingPlan.swapSize)
 2894:         if (syncResult.count > 0) {
 2895:           if (syncResult.instanceIds.length > 0) {
 2896:             try {
 2897:               const { reconcileTrafficStateForInstanceIds } = await import('../services/traffic-scheduler.js')
 2898:               await reconcileTrafficStateForInstanceIds(syncResult.instanceIds)
 2899:             } catch (err) {
 2900:               request.log.warn(err, '方案配额已同步，流量状态即时复核失败')
 2901:             }
 2902:           }
 2903:           await createLog(
 2904:             user.id,
 2905:             'package',
 2906:             'plan.sync_quota',
 2907:             `Synced quota to ${syncResult.count} instance(s) for plan "${updatedPlan.name}"`,
 2908:             'success'
 2909:           )
 2910:         }
 2911:       }
 2912: 
 2913:       await createLog(
 2914:         user.id,
 2915:         'package',
 2916:         'plan.update',
 2917:         `Updated plan "${updatedPlan.name}" for package "${pkg.name}"`,
 2918:         'success'
 2919:       )
 2920: 
 2921:       return {
 2922:         id: updatedPlan.id,
 2923:         name: updatedPlan.name,
 2924:         message: '方案更新成功'
 2925:       }
 2926:     } catch (error) {
 2927:       return reply.code(500).send({ error: '更新方案失败' })
 2928:     }
 2929:   })
 2930: 
 2931:   // 删除套餐方案
 2932:   fastify.delete<{ Params: { id: string; planId: string } }>('/:id/plans/:planId', {
 2933:     onRequest: [fastify.authenticate],
 2934:     config: { rateLimit: { max: 10, timeWindow: '1 minute' } }  // 删除操作，更严格限制
 2935:   }, async (request, reply) => {
 2936:     const { id, planId } = request.params
 2937:     const { user } = request
 2938:     const packageId = parsePositiveRouteId(id)
 2939:     const planIdNum = parsePositiveRouteId(planId)
 2940: 
 2941:     if (!packageId || !planIdNum) {
 2942:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 2943:     }
 2944: 
 2945:     // 验证套餐存在且属于当前用户
 2946:     const pkg = await db.getPackageById(packageId)
 2947:     if (!pkg) {
 2948:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 2949:     }
 2950:     if (pkg.user_id !== user.id && user.role !== 'admin') {
 2951:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 2952:     }
 2953: 
 2954:     // 验证方案存在且属于该套餐
 2955:     const existingPlan = await db.getPlanById(planIdNum)
 2956:     if (!existingPlan || existingPlan.packageId !== packageId) {
 2957:       return reply.code(404).send({ error: '方案不存在' })
 2958:     }
 2959: 
 2960:     // 检查是否可以删除
 2961:     const canDelete = await db.canDeletePlan(planIdNum)
 2962:     if (!canDelete.canDelete) {
 2963:       return reply.code(400).send({ error: canDelete.reason })
 2964:     }
 2965: 
 2966:     try {
 2967:       await db.deletePlan(planIdNum)
 2968: 
 2969:       await createLog(
 2970:         user.id,
 2971:         'package',
 2972:         'plan.delete',
 2973:         `Deleted plan "${existingPlan.name}" from package "${pkg.name}"`,
 2974:         'success'
 2975:       )
 2976: 
 2977:       return { message: '方案删除成功' }
 2978:     } catch (error) {
 2979:       return reply.code(500).send({ error: '删除方案失败' })
 2980:     }
 2981:   })
 2982: 
 2983:   // 获取可用地区列表（拥有付费方案的公开套餐所在的国家/地区）
 2984:   fastify.get<{
 2985:     Querystring: { source?: 'official' | 'market' | 'friends' | 'zone'; zoneId?: string }
 2986:   }>('/regions', {
 2987:     onRequest: [fastify.authenticate]
 2988:   }, async (request, reply) => {
 2989:     const { source = 'official' } = request.query
 2990:     const user = request.user
 2991:     
 2992:     // 好友共享需要特殊处理：从好友共享套餐中提取地区
 2993:     if (source === 'friends') {
 2994:       // 获取好友共享给当前用户的套餐
 2995:       const friendPackages = await packageShares.getSharedToUser(user.id)
 2996:       
 2997:       if (friendPackages.length === 0) {
 2998:         return { regions: [] }
 2999:       }
 3000:       
 3001:       // 获取这些套餐绑定的宿主机信息
 3002:       const hostIds = [...new Set(friendPackages.flatMap(p => p.hostIds))]
 3003:       const hosts = await db.prisma.host.findMany({
 3004:         where: {
 3005:           id: { in: hostIds },
 3006:           status: 'online'
 3007:         },
 3008:         select: {
 3009:           id: true,
 3010:           countryCode: true,
 3011:           packageHosts: {
 3012:             select: { packageId: true }
 3013:           }
 3014:         }
 3015:       })
 3016:       
 3017:       // 按国家分组统计套餐数量
 3018:       const regionPackages = new Map<string, Set<number>>()
 3019:       const friendPackageIds = new Set(friendPackages.map(p => p.id))
 3020:       
 3021:       for (const host of hosts) {
 3022:         const countryCode = (host.countryCode || 'us').toLowerCase()
 3023:         for (const ph of host.packageHosts) {
 3024:           // 只统计属于好友共享的套餐
 3025:           if (!friendPackageIds.has(ph.packageId)) continue
 3026:           
 3027:           if (!regionPackages.has(countryCode)) {
 3028:             regionPackages.set(countryCode, new Set())
 3029:           }
 3030:           regionPackages.get(countryCode)!.add(ph.packageId)
 3031:         }
 3032:       }
 3033:       
 3034:       const regions = Array.from(regionPackages.entries()).map(([code, packageIds]) => ({
 3035:         code,
 3036:         name: getCountryName(code),
 3037:         packageCount: packageIds.size,
 3038:         packageIds: Array.from(packageIds)
 3039:       }))
 3040:       
 3041:       regions.sort((a, b) => b.packageCount - a.packageCount)
 3042:       return { regions }
 3043:     }
 3044:     
 3045:     // 官方/托管市场/托管专区：使用统一公开套餐逻辑
 3046:     let whereCondition: any = {
 3047:       active: true,
 3048:       plans: {
 3049:         some: {
 3050:           isActive: true
 3051:         }
 3052:       }
 3053:     }
 3054:     
 3055:     if (source === 'official') {
 3056:       // 官方套餐：管理员创建的公开套餐（不再排除用户自己的，与套餐列表保持一致）
 3057:       whereCondition.globalShared = true
 3058:       whereCondition.user = { role: 'admin' }
 3059:     } else if (source === 'market') {
 3060:       // 托管市场：非管理员创建的公开套餐（不再排除用户自己的，与套餐列表保持一致）
 3061:       const blockerIds = await db.getBlockerIdsForUser(user.id)
 3062:       const zoneOwnerIds = await packageShares.getActiveHostingZoneOwnerIds()
 3063:       const excludedOwnerIds = Array.from(new Set([...blockerIds, ...zoneOwnerIds]))
 3064:       whereCondition.globalShared = true
 3065:       whereCondition.user = { role: { not: 'admin' } }
 3066:       if (excludedOwnerIds.length > 0) {
 3067:         whereCondition.userId = { notIn: excludedOwnerIds }
 3068:       }
 3069:     } else if (source === 'zone') {
 3070:       const zoneId = parseOptionalPositiveQueryInteger(request.query.zoneId)
 3071:       if (zoneId === null) {
 3072:         return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid hosting zone filter'))
 3073:       }
 3074:       if (zoneId === undefined) {
 3075:         return { regions: [] }
 3076:       }
 3077: 
 3078:       const zone = await packageShares.getActiveHostingZoneById(zoneId, user.id)
 3079:       if (!zone) {
 3080:         return { regions: [] }
 3081:       }
 3082: 
 3083:       whereCondition.globalShared = true
 3084:       whereCondition.userId = zone.ownerId
 3085:       whereCondition.user = { role: { not: 'admin' } }
 3086:     }
 3087:     
 3088:     // 1. 获取所有有活跃方案的套餐，并包含它们绑定的宿主机信息
 3089:     const packagesWithPlans = await db.prisma.package.findMany({
 3090:       where: whereCondition,
 3091:       select: {
 3092:         id: true,
 3093:         packageHosts: {
 3094:           select: {
 3095:             host: {
 3096:               select: {
 3097:                 id: true,
 3098:                 countryCode: true,
 3099:                 status: true
 3100:               }
 3101:             }
 3102:           }
 3103:         }
 3104:       }
 3105:     })
 3106: 
 3107:     // 2. 按国家分组统计套餐数量
 3108:     const regionPackages = new Map<string, Set<number>>()  // countryCode -> packageIds
 3109:     
 3110:     for (const pkg of packagesWithPlans) {
 3111:       for (const ph of pkg.packageHosts) {
 3112:         // 只计算在线的宿主机
 3113:         if (ph.host.status !== 'online') continue
 3114:         
 3115:         const countryCode = (ph.host.countryCode || 'us').toLowerCase()
 3116:         if (!regionPackages.has(countryCode)) {
 3117:           regionPackages.set(countryCode, new Set())
 3118:         }
 3119:         regionPackages.get(countryCode)!.add(pkg.id)
 3120:       }
 3121:     }
 3122: 
 3123:     // 3. 构建地区列表
 3124:     const regions = Array.from(regionPackages.entries()).map(([code, packageIds]) => ({
 3125:       code,
 3126:       name: getCountryName(code),
 3127:       packageCount: packageIds.size,
 3128:       packageIds: Array.from(packageIds)  // 返回该地区包含的套餐 ID 列表
 3129:     }))
 3130: 
 3131:     // 按套餐数量降序排列
 3132:     regions.sort((a, b) => b.packageCount - a.packageCount)
 3133: 
 3134:     return { regions }
 3135:   })
 3136: }
 3137: 
 3138: const englishRegionDisplayNames =
 3139:   typeof Intl.DisplayNames === 'function'
 3140:     ? new Intl.DisplayNames(['en'], { type: 'region' })
 3141:     : null
 3142: 
 3143: const intlRegionCodePattern = /^([a-z]{2}|\d{3})$/i
 3144: 
 3145: const specialCountryNames: Record<string, string> = {
 3146:   pc: 'Pacific Community',
 3147:   xx: 'Unknown'
 3148: }
 3149: 
 3150: // 获取国家名称
 3151: function getCountryName(code: string): string {
 3152:   const normalizedCode = code.toLowerCase()
 3153:   const upperCode = normalizedCode.toUpperCase()
 3154: 
 3155:   if (intlRegionCodePattern.test(normalizedCode)) {
 3156:     const displayName = englishRegionDisplayNames?.of(upperCode)
 3157:     if (displayName && displayName !== upperCode) {
 3158:       return displayName
 3159:     }
 3160:   }
 3161: 
 3162:   return specialCountryNames[normalizedCode] || upperCode
 3163: }
 3164: 
 3165: // 格式化内存显示
 3166: function formatMemory(mb: number): string {
 3167:   if (mb >= 1024) {
 3168:     return `${(mb / 1024).toFixed(1)} GB`
 3169:   }
 3170:   return `${mb} MB`
 3171: }

