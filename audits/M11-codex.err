  152: async function getIncompatiblePackageHosts(
  153:   hostIds: number[],
  154:   instanceType: string | null | undefined
  155: ): Promise<Array<{ id: number; name: string; instanceType: string }>> {
  156:   const uniqueHostIds = [...new Set(hostIds.filter(id => Number.isInteger(id) && id > 0))]
  157:   if (uniqueHostIds.length === 0) {
  158:     return []
  159:   }
  160: 
  161:   const hosts = await prisma.host.findMany({
  162:     where: { id: { in: uniqueHostIds } },
  163:     select: {
  164:       id: true,
  165:       name: true,
  166:       instanceType: true
  167:     }
  168:   })
  169:   return hosts
  170:     .filter(host => !isHostTypeCompatibleWithPackage(host.instanceType, instanceType))
  171:     .map(host => ({
  172:       id: host.id,
  173:       name: host.name,
  174:       instanceType: host.instanceType || 'container'
  175:     }))
  176: }
  177: 
  178: function incompatiblePackageHostsResponse(
  179:   hosts: Array<{ id: number; name: string; instanceType: string }>,
  180:   instanceType: string | null | undefined
  181: ) {
  182:   return {
  183:     error: `Package instance type "${instanceType || 'container'}" is not supported by the selected host`,
  184:     code: 'HOST_INSTANCE_TYPE_MISMATCH',
  185:     hosts
  186:   }
  187: }
