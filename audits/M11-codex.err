  300: function normalizePackagePlanDescription(value: unknown): string | undefined {
  301:   if (value === undefined) return undefined
  302:   if (typeof value !== 'string') {
  303:     throw apiError(ErrorCode.VALIDATION_ERROR, '方案描述无效')
  304:   }
  305:   const trimmed = value.trim()
  306:   if (Array.from(trimmed).length > 500) {
  307:     throw apiError(ErrorCode.VALIDATION_ERROR, '方案描述不能超过 500 个字符')
  308:   }
  309:   return trimmed
  310: }
