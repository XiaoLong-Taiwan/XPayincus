 2164:   // 共享套餐给好友
--- 2440-2638 ---
 2440: 
 2441:   // 释放配额
 2442:   fastify.post<{
 2443:     Params: { id: string }
 2444:     Body: {
 2445:       hostIds: number[]
 2446:       cpuAdd: number
 2447:       memoryAdd: number
 2448:       notify?: boolean
 2449:     }
 2450:   }>('/:id/release-quota', {
 2451:     onRequest: [fastify.authenticate],
 2452:     config: { rateLimit: { max: 10, timeWindow: '1 minute' } },  // 修改资源配额，严格限制
 2453:     schema: {
 2454:       body: {
 2455:         type: 'object',
 2456:         required: ['hostIds', 'cpuAdd', 'memoryAdd'],
 2457:         properties: {
 2458:           hostIds: { type: 'array', items: { type: 'integer' }, minItems: 1, maxItems: 100 },
 2459:           cpuAdd: { type: 'integer', minimum: 0, maximum: 10000 },
 2460:           memoryAdd: { type: 'integer', minimum: 0, maximum: 1048576 },
 2461:           notify: { type: 'boolean' }
 2462:         }
 2463:       }
 2464:     }
 2465:   }, async (request: FastifyRequest<{
 2466:     Params: { id: string }
 2467:     Body: {
 2468:       hostIds: number[]
 2469:       cpuAdd: number
 2470:       memoryAdd: number
 2471:       notify?: boolean
 2472:     }
 2473:   }>, reply: FastifyReply) => {
 2474:     const { id } = request.params
 2475:     const { hostIds, cpuAdd, memoryAdd, notify } = request.body
 2476:     const { user } = request
 2477:     const packageId = parsePositiveRouteId(id)
 2478: 
 2479:     if (!packageId) {
 2480:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 2481:     }
 2482: 
 2483:     // 验证至少有一个配额大于 0
 2484:     if (cpuAdd <= 0 && memoryAdd <= 0) {
 2485:       return reply.code(400).send({ error: 'At least one quota must be greater than 0' })
 2486:     }
 2487: 
 2488:     const pkg = await db.getPackageById(packageId)
 2489:     if (!pkg) {
 2490:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 2491:     }
 2492:     if (pkg.user_id !== user.id && user.role !== 'admin') {
 2493:       return reply.code(403).send(apiError(ErrorCode.FORBIDDEN))
 2494:     }
 2495: 
 2496:     // 验证所有 hostIds 都属于该套餐
 2497:     const packageHostIds = pkg.host_ids || []
 2498:     const invalidHosts = hostIds.filter(hid => !packageHostIds.includes(hid))
 2499:     if (invalidHosts.length > 0) {
 2500:       return reply.code(400).send({ error: 'Some hosts are not bound to this package' })
 2501:     }
 2502: 
 2503:     // 为每个宿主机增加配额
 2504:     const results: Array<{
 2505:       hostId: number
 2506:       hostName: string
 2507:       countryCode: string
 2508:       cpuAllowanceMax: number
 2509:       memoryMax: number
 2510:       cpuAvailable: number
 2511:       memoryAvailable: number
 2512:     }> = []
 2513: 
 2514:     for (const hostId of hostIds) {
 2515:       const host = await db.getHostById(hostId)
 2516:       if (!host) continue
 2517: 
 2518:       const updated = await db.increaseHostQuota(hostId, cpuAdd, memoryAdd)
 2519:       results.push({
 2520:         hostId: host.id,
 2521:         hostName: host.name,
 2522:         countryCode: host.country_code || 'us',
 2523:         cpuAllowanceMax: updated.cpuAllowanceMax,
 2524:         memoryMax: updated.memoryMax,
 2525:         cpuAvailable: updated.cpuAllowanceMax - (host.cpu_used || 0),
 2526:         memoryAvailable: updated.memoryMax - (host.memory_used || 0)
 2527:       })
 2528:     }
 2529: 
 2530:     // 记录日志
 2531:     await createLog(
 2532:       user.id,
 2533:       'package',
 2534:       'package.release_quota',
 2535:       `Released quota for package "${pkg.name}": CPU +${cpuAdd}%, Memory +${memoryAdd}MB on ${hostIds.length} host(s)`,
 2536:       'success'
 2537:     )
 2538: 
 2539:     // 发送通知（仅当 notify=true 且全局渠道存在时）
 2540:     if (notify) {
 2541:       const globalChannel = await prisma.notificationChannel.findFirst({
 2542:         where: { isGlobal: true },
 2543:         select: { id: true }
 2544:       })
 2545:       if (globalChannel) {
 2546:         // 构建通知消息
 2547:         const hostDetails = results.map(r => 
 2548:           `• ${r.hostName.toUpperCase()}: CPU ${r.cpuAvailable}% | 内存 ${formatMemory(r.memoryAvailable)}`
 2549:         ).join('\n')
 2550: 
 2551:         const notifyTitle = `📦 资源释放 - ${pkg.name}`
 2552:         // 判断套餐来源：管理员创建的套餐为 official，普通用户创建的为 market
 2553:         const pkgOwner = await prisma.user.findUnique({ where: { id: pkg.user_id }, select: { role: true } })
 2554:         const pkgSource = pkgOwner?.role === 'admin' ? 'official' : 'market'
 2555:         const buyLink = process.env.SITE_URL
 2556:           ? { label: '🛒 立即开通', url: `${process.env.SITE_URL}/instances/create?source=${pkgSource}&package=${packageId}` }
 2557:           : undefined
 2558:         const notifyMessage = [
 2559:           `+${cpuAdd}% CPU / +${formatMemory(memoryAdd)} 内存`,
 2560:           '',
 2561:           '当前可用配额：',
 2562:           hostDetails,
 2563:           '',
 2564:           `⏰ ${new Date().toLocaleString('zh-CN', { timeZone: 'Asia/Shanghai' })}`
 2565:         ].join('\n')
 2566: 
 2567:         try {
 2568:           await sendToChannel(globalChannel.id, notifyTitle, notifyMessage, buyLink)
 2569:         } catch {
 2570:           // 通知发送失败不影响主流程
 2571:         }
 2572:       }
 2573:     }
 2574: 
 2575:     return {
 2576:       message: 'Quota released successfully',
 2577:       results
 2578:     }
 2579:   })
