  716: async function shouldSyncPackageTrafficLimitsAfterUpdate(
  717:   packageId: number,
  718:   currentPackage: {
  719:     monthly_traffic_limit?: string | null
  720:     host_ids?: number[]
  721:     host_traffic_multipliers?: Record<string, number>
  722:   },
  723:   updates: {
  724:     monthlyTrafficLimit?: bigint | null
  725:     hostIds?: number[]
  726:     hostTrafficMultipliers?: Record<string, number | string | null>
  727:   }
  728: ): Promise<boolean> {
  729:   if (updates.monthlyTrafficLimit !== undefined) {
  730:     const currentLimit = currentPackage.monthly_traffic_limit ? BigInt(currentPackage.monthly_traffic_limit) : null
  731:     const nextLimit = updates.monthlyTrafficLimit
  732:     if (currentLimit !== nextLimit) {
  733:       return true
  734:     }
  735:   }
  736: 
  737:   if (updates.hostIds === undefined && updates.hostTrafficMultipliers === undefined) {
  738:     return false
  739:   }
  740: 
  741:   const instanceHosts = await prisma.instance.findMany({
  742:     where: {
  743:       packageId,
  744:       status: { not: 'deleted' }
  745:     },
  746:     select: { hostId: true },
  747:     distinct: ['hostId']
  748:   })
  749:   if (instanceHosts.length === 0) {
  750:     return false
  751:   }
  752: 
  753:   const currentHostIds = new Set(currentPackage.host_ids || [])
  754:   const nextHostIds = updates.hostIds !== undefined ? new Set(updates.hostIds) : currentHostIds
  755:   const currentMultipliers = currentPackage.host_traffic_multipliers || {}
  756:   const nextMultipliers = updates.hostTrafficMultipliers || {}
  757: 
  758:   for (const { hostId } of instanceHosts) {
  759:     const explicitMultiplierUpdate = Object.prototype.hasOwnProperty.call(nextMultipliers, String(hostId))
  760:     if (!explicitMultiplierUpdate && (updates.hostIds === undefined || !nextHostIds.has(hostId))) {
  761:       continue
  762:     }
  763: 
  764:     const currentMultiplier = currentHostIds.has(hostId)
  765:       ? normalizeTrafficMultiplier(currentMultipliers[String(hostId)] ?? 1)
  766:       : 1
  767:     const nextMultiplier = explicitMultiplierUpdate
  768:       ? normalizeTrafficMultiplier(nextMultipliers[String(hostId)])
  769:       : currentMultiplier
  770: 
  771:     if (currentMultiplier !== nextMultiplier) {
  772:       return true
  773:     }
  774:   }
  775: 
  776:   return false
  777: }
