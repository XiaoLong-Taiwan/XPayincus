  289: function getRouteSignatureFromState(): string {
  290:   return JSON.stringify({
  291:     source: packageSource.value,
  292:     region: selectedRegion.value || '',
  293:     packageId: selectedPackageId.value || '',
  294:     planId: selectedPlanId.value || '',
  295:     q: searchQuery.value.trim()
  296:   })
  297: }
  298: 
  299: function getRouteSignatureFromQuery(): string {
  300:   return JSON.stringify({
  301:     source: normalizePublicPackageSource(route.query.source),
  302:     region: parseTextQuery(route.query.region),
  303:     packageId: parsePackageIdQuery(route.query.package) || '',
  304:     planId: parsePackageIdQuery(route.query.plan) || '',
  305:     q: parseTextQuery(route.query.q)
  306:   })
  307: }
  308: 
  309: function syncRouteQuery(): void {
  310:   if (getRouteSignatureFromState() === getRouteSignatureFromQuery()) {
  311:     return
  312:   }
  313: 
  314:   const nextQuery: Record<string, string> = {}
  315: 
  316:   if (packageSource.value !== 'official') {
  317:     nextQuery.source = packageSource.value
  318:   }
  319: 
  320:   if (selectedRegion.value) {
  321:     nextQuery.region = selectedRegion.value
  322:   }
  323: 
  324:   if (selectedPackageId.value) {
  325:     nextQuery.package = String(selectedPackageId.value)
  326:   }
  327: 
  328:   if (selectedPlanId.value) {
  329:     nextQuery.plan = String(selectedPlanId.value)
  330:   }
  331: 
  332:   const trimmedSearch = searchQuery.value.trim()
  333:   if (trimmedSearch) {
  334:     nextQuery.q = trimmedSearch
  335:   }
  336: 
  337:   void router.replace({
  338:     name: 'market',
  339:     query: nextQuery
  340:   })
  341: }
  342: 
  343: function ensureSelectedPackage(
  344:   preferredPackageId: number | null = selectedPackageId.value,
  345:   options: { syncRegionWithPackage?: boolean } = {}
  346: ): void {
  347:   const { syncRegionWithPackage = true } = options
  348: 
  349:   if (selectedRegion.value && !regions.value.some(region => region.code === selectedRegion.value)) {
  350:     selectedRegion.value = null
  351:   }
  352: 
  353:   if (preferredPackageId && syncRegionWithPackage) {
  354:     const preferredPackage = packages.value.find(pkg => pkg.id === preferredPackageId)
  355:     if (preferredPackage) {
  356:       const currentRegion = selectedRegion.value
  357:         ? regions.value.find(region => region.code === selectedRegion.value)
  358:         : null
  359: 
  360:       if (currentRegion && !currentRegion.packageIds.includes(preferredPackage.id)) {
  361:         const preferredRegion = regions.value.find(region => region.packageIds.includes(preferredPackage.id))
  362:         if (preferredRegion) {
  363:           selectedRegion.value = preferredRegion.code
  364:         }
  365:       }
  366:     }
  367:   }
  368: 
  369:   if (filteredPackages.value.length === 0 && selectedRegion.value !== null) {
  370:     selectedRegion.value = null
  371:   }
  372: 
  373:   if (filteredPackages.value.length === 0) {
  374:     selectedPackageId.value = null
  375:     return
  376:   }
  377: 
  378:   if (!selectedPackageId.value || !filteredPackages.value.some(pkg => pkg.id === selectedPackageId.value)) {
  379:     selectedPackageId.value = filteredPackages.value[0].id
  380:   }
  381: }
  382: 
  383: function ensureSelectedPlan(preferredPlanId: number | null = selectedPlanId.value): void {
  384:   if (!selectedPackage.value || selectedPackage.value.plans.length === 0) {
  385:     selectedPlanId.value = null
  386:     return
  387:   }
  388: 
  389:   const matchedPlan = preferredPlanId
  390:     ? selectedPackage.value.plans.find(plan => plan.id === preferredPlanId && !plan.isSoldOut)
  391:     : null
  392: 
  393:   const firstAvailablePlan = selectedPackage.value.plans.find(plan => !plan.isSoldOut)
  394:   selectedPlanId.value = matchedPlan?.id || firstAvailablePlan?.id || null
  395: }
  396: 
  397: async function loadData(
  398:   preferredPackageId: number | null = selectedPackageId.value,
  399:   preferredPlanId: number | null = selectedPlanId.value
  400: ): Promise<void> {
  401:   loading.value = true
  402:   loadError.value = ''
  403: 
  404:   try {
  405:     const [packagesResponse, regionsResponse] = await Promise.all([
  406:       api.packages.listPublic({ source: packageSource.value }),
  407:       api.packages.getPublicRegions({ source: packageSource.value })
  408:     ])
  409: 
  410:     packages.value = (packagesResponse.packages || []) as unknown as PublicPackage[]
  411:     regions.value = regionsResponse.regions || []
  412: 
  413:     ensureSelectedPackage(preferredPackageId)
  414:     ensureSelectedPlan(preferredPlanId)
  415:     syncRouteQuery()
  416:   } catch (error) {
  417:     console.error('Failed to load public market:', error)
  418:     packages.value = []
  419:     regions.value = []
  420:     loadError.value = t('common.loadFailed')
  421:   } finally {
  422:     loading.value = false
  423:   }
  424: }
  425: 
  426: async function syncFromRoute(): Promise<void> {
  427:   const nextSource = normalizePublicPackageSource(route.query.source)
  428:   const nextRegion = parseTextQuery(route.query.region) || null
  429:   const nextPackageId = parsePackageIdQuery(route.query.package)
  430:   const nextPlanId = parsePackageIdQuery(route.query.plan)
  431:   const nextSearch = parseTextQuery(route.query.q)
  432:   const sourceChanged = nextSource !== packageSource.value
  433: 
  434:   packageSource.value = nextSource
  435:   selectedRegion.value = nextRegion
  436:   selectedPackageId.value = nextPackageId
  437:   selectedPlanId.value = nextPlanId
  438:   searchQuery.value = nextSearch
  439: 
  440:   if (sourceChanged || packages.value.length === 0) {
  441:     await loadData(nextPackageId, nextPlanId)
  442:     return
  443:   }
  444: 
  445:   ensureSelectedPackage(nextPackageId)
  446:   ensureSelectedPlan(nextPlanId)
  447:   syncRouteQuery()
  448: }
  449: 
  450: async function switchSource(source: PublicPackageSource): Promise<void> {
  451:   if (source === packageSource.value) {
  452:     return
  453:   }
  454: 
  455:   packageSource.value = source
  456:   selectedRegion.value = null
  457:   selectedPackageId.value = null
  458:   selectedPlanId.value = null
  459:   searchQuery.value = ''
  460:   await loadData(null, null)
  461: }
  462: 
  463: function selectRegion(code: string | null): void {
  464:   const currentPackageId = selectedPackageId.value
  465:   selectedRegion.value = code
  466: 
  467:   // 用户主动切换地区时，优先尊重新地区筛选；
  468:   // 只有当前套餐仍在筛选结果内时才保留，避免把地区强行改回旧值。
  469:   const preferredPackageId = currentPackageId !== null && filteredPackages.value.some(pkg => pkg.id === currentPackageId)
  470:     ? currentPackageId
  471:     : null
  472: 
  473:   if (preferredPackageId === null) {
  474:     selectedPlanId.value = null
  475:   }
  476: 
  477:   ensureSelectedPackage(preferredPackageId, { syncRegionWithPackage: false })
  478:   ensureSelectedPlan(selectedPlanId.value)
  479:   syncRouteQuery()
  480: }
  481: 
  482: function selectPackage(pkg: PublicPackage): void {
  483:   selectedPackageId.value = pkg.id
  484:   ensureSelectedPlan(null)
  485:   syncRouteQuery()
  486: }
  487: 
  488: function selectPlan(planId: number): void {
  489:   const plan = selectedPackage.value?.plans.find(item => item.id === planId)
  490:   if (!plan || plan.isSoldOut) {
  491:     return
  492:   }
  493: 
  494:   selectedPlanId.value = planId
  495:   syncRouteQuery()
  496: }
  497: 
  498: function handleSearchInput(): void {
  499:   ensureSelectedPackage(selectedPackageId.value)
  500: 
  501:   if (searchTimer !== null) {
  502:     window.clearTimeout(searchTimer)
  503:   }
  504: 
  505:   searchTimer = window.setTimeout(() => {
  506:     syncRouteQuery()
  507:     searchTimer = null
  508:   }, 120)
  509: }
  510: 
  511: function clearSearch(): void {
  512:   searchQuery.value = ''
  513:   ensureSelectedPackage(selectedPackageId.value)
  514:   syncRouteQuery()
