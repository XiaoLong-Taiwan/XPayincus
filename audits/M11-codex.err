  431: function optionalPackageText(
  432:   input: Record<string, unknown>,
  433:   key: string,
  434:   field: string,
  435:   maxLength: number
  436: ): string | undefined {
  437:   const value = input[key]
  438:   if (value === undefined) return undefined
  439:   if (typeof value !== 'string') {
  440:     throw apiError(ErrorCode.VALIDATION_ERROR, `${field} 无效`)
