  114: function validatePackagePlanName(value: unknown): { valid: boolean; message?: string; sanitized?: string } {
  115:   if (typeof value !== 'string') {
  116:     return { valid: false, message: '方案名称不能为空' }
  117:   }
  118: 
  119:   const trimmed = value.trim()
  120:   if (trimmed.length === 0) {
  121:     return { valid: false, message: '方案名称不能为空' }
  122:   }
  123:   if (Array.from(trimmed).length > MAX_PACKAGE_PLAN_NAME_LENGTH) {
  124:     return { valid: false, message: `方案名称不能超过 ${MAX_PACKAGE_PLAN_NAME_LENGTH} 个字符` }
  125:   }
  126:   if (/[\u0000-\u001F\u007F]/.test(trimmed) || removeDangerousChars(trimmed) !== trimmed) {
  127:     return { valid: false, message: '方案名称包含非法字符' }
  128:   }
  129: 
  130:   return { valid: true, sanitized: trimmed }
  131: }
