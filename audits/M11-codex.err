  250: function requirePlanInteger(value: unknown, field: string, min: number, max: number): number {
  251:   if (typeof value !== 'number' || !Number.isSafeInteger(value)) {
  252:     throw apiError(ErrorCode.VALIDATION_ERROR, `${field} 必须为整数`)
  253:   }
  254:   if (value < min || value > max) {
  255:     throw apiError(ErrorCode.VALIDATION_ERROR, `${field} 必须在 ${min}-${max} 之间`)
  256:   }
  257:   return value
  258: }
