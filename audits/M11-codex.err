 2012:     if (limitsWriteIops !== undefined) updateData.limitsWriteIops = limitsWriteIops
 2013: 
 2014:     // 网络限制
 2015:     if (limitsIngress !== undefined) updateData.limitsIngress = limitsIngress
 2016:     if (limitsEgress !== undefined) updateData.limitsEgress = limitsEgress
 2017: 
 2018:     // 进程与调度
 2019:     if (limitsProcesses !== undefined) updateData.limitsProcesses = limitsProcesses
 2020:     if (limitsCpuPriority !== undefined) updateData.limitsCpuPriority = limitsCpuPriority
 2021: 
 2022:     // 启动配置
 2023:     if (bootAutostart !== undefined) updateData.bootAutostart = bootAutostart
 2024:     if (bootAutostartPriority !== undefined) updateData.bootAutostartPriority = bootAutostartPriority
 2025:     if (bootAutostartDelay !== undefined) updateData.bootAutostartDelay = bootAutostartDelay
 2026:     if (bootHostShutdownTimeout !== undefined) updateData.bootHostShutdownTimeout = bootHostShutdownTimeout
 2027:     
 2028:     // 验证全局共享配置的数值有效性（Fastify schema 已经验证，这里做额外检查以防万一）
 2029:     const currentGlobalShared = (pkg as any).global_shared ?? false
 2030:     if (globalShared !== undefined) {
 2031:       updateData.globalShared = globalShared
 2032:       // 如果 globalShared 被设置为 false，确保相关字段为 null
 2033:       if (globalShared === false) {
 2034:         updateData.globalQuotaMultiplier = null
 2035:         updateData.globalMaxInstances = null
 2036:       }
 2037:     }
 2038:     
 2039:     // 只有在 globalShared 不为 false 时才处理这两个字段
 2040:     // 如果 globalShared 未提供，但当前套餐是全局共享的，允许更新这两个字段
 2041:     const willBeGlobalShared = globalShared !== undefined ? globalShared : currentGlobalShared
 2042:     if (willBeGlobalShared !== false) {
 2043:       updateData.globalQuotaMultiplier = null
 2044:       const nextMaxInstances = globalMaxInstances !== undefined
 2045:         ? globalMaxInstances
 2046:         : normalizePublicPackageMaxInstances((pkg as any).global_max_instances)
 2047:       if (!validatePublicPackageMaxInstances(nextMaxInstances)) {
 2048:         return reply.code(400).send({
 2049:           error: '公开套餐最大实例数必须是 1-5 之间的整数',
 2050:           code: 'INVALID_MAX_INSTANCES'
 2051:         })
 2052:       }
 2053:       updateData.globalMaxInstances = nextMaxInstances
 2054:     } else if ((globalQuotaMultiplier !== undefined || globalMaxInstances !== undefined) && globalShared === undefined) {
 2055:       // 如果当前套餐不是全局共享的，但用户试图更新这些字段，应该拒绝
 2056:       return reply.code(400).send({ 
 2057:         error: 'Cannot update globalQuotaMultiplier or globalMaxInstances when globalShared is false', 
 2058:         code: 'INVALID_GLOBAL_SHARED_STATE' 
 2059:       })
 2060:     }
 2061: 
 2062:     if (requiredPackageId !== undefined) {
 2063:       const prerequisiteValidation = await db.validatePackagePrerequisiteReferenceLocked(packageId, requiredPackageId, pkg.user_id!)
 2064:       if (!prerequisiteValidation.valid) {
 2065:         return reply.code(400).send({ error: prerequisiteValidation.message, code: prerequisiteValidation.code })
 2066:       }
 2067:       updateData.requiredPackageId = requiredPackageId
 2068:     }
 2069: 
 2070:     try {
 2071:       const shouldSyncTrafficLimits = await shouldSyncPackageTrafficLimitsAfterUpdate(packageId, pkg, {
 2072:         monthlyTrafficLimit: parsedMonthlyTrafficLimit,
 2073:         hostIds,
 2074:         hostTrafficMultipliers
 2075:       })
 2076:       await db.updatePackage(packageId, updateData, request.user.role === 'admin')  // 管理员可以绑定任何节点
 2077:       if (shouldSyncTrafficLimits) {
 2078:         const syncResult = await db.syncPackageTrafficLimitsToInstances(packageId)
 2079:         if (syncResult.instanceIds.length > 0) {
 2080:           try {
 2081:             const { reconcileTrafficStateForInstanceIds } = await import('../services/traffic-scheduler.js')
 2082:             await reconcileTrafficStateForInstanceIds(syncResult.instanceIds)
 2083:           } catch (err) {
 2084:             request.log.warn(err, '套餐流量限额已同步，流量状态即时复核失败')
 2085:           }
 2086:         }
 2087:       }
 2088:     } catch (error) {
 2089:       const prerequisiteError = getPackagePrerequisiteError(error)
 2090:       if (prerequisiteError) {
 2091:         return reply.code(400).send({ error: prerequisiteError.message, code: prerequisiteError.code })
 2092:       }
 2093:       const errorMessage = error instanceof Error ? error.message : String(error)
 2094:       return reply.code(400).send({ error: errorMessage, code: 'INVALID_PACKAGE_CONFIG' })
 2095:     }
 2096: 
 2097: 
 2098:     // 构建变更详情
 2099:     const pkgChanges: string[] = []
 2100:     if (packageInput.name && packageInput.name !== pkg.name) pkgChanges.push(`name -> "${packageInput.name}"`)
 2101:     if (packageInput.cpuMax !== undefined) pkgChanges.push(`cpuMax -> ${packageInput.cpuMax}%`)
 2102:     if (packageInput.memoryMax !== undefined) pkgChanges.push(`memoryMax -> ${packageInput.memoryMax}MB`)
 2103:     if (packageInput.diskMax !== undefined) pkgChanges.push(`diskMax -> ${packageInput.diskMax}MB`)
 2104:     if (packageInput.instanceType) pkgChanges.push(`instanceType -> ${packageInput.instanceType}`)
 2105:     if (packageInput.active !== undefined) pkgChanges.push(`active -> ${packageInput.active}`)
 2106:     if (hostIds !== undefined) pkgChanges.push(`hosts -> [${hostIds.join(',')}]`)
 2107: 
 2108:     await createLog(request.user.id, 'package', 'package.update', `Updated package "${pkg.name}" [${pkgChanges.length > 0 ? pkgChanges.join(', ') : 'minor changes'}]`, 'success')
 2109: 
 2110:     return { message: 'Package updated' }
