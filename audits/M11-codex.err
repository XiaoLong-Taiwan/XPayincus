  417: function optionalPackageEnum<T extends string>(
  418:   input: Record<string, unknown>,
  419:   key: string,
  420:   field: string,
  421:   allowed: readonly T[]
  422: ): T | undefined {
  423:   const value = input[key]
  424:   if (value === undefined) return undefined
  425:   if (typeof value !== 'string' || !allowed.includes(value as T)) {
  426:     throw apiError(ErrorCode.VALIDATION_ERROR, `${field} 无效`)
  427:   }
  428:   return value as T
