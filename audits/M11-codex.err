 1005:             hostId: true
 1006:           }
 1007:         }
 1008:       }
 1009:     })
 1010:     
 1011:     // 收集所有宿主机 ID
 1012:     const allHostIds = new Set<number>()
 1013:     packages.forEach(pkg => {
 1014:       pkg.packageHosts.forEach(ph => allHostIds.add(ph.hostId))
 1015:     })
 1016:     
 1017:     // 获取宿主机信息
 1018:     const hosts = await prisma.host.findMany({
 1019:       where: { id: { in: Array.from(allHostIds) }, status: 'online' },
 1020:       select: {
 1021:         id: true,
 1022:         countryCode: true,
 1023:         location: true
 1024:       }
 1025:     })
 1026:     
 1027:     // 按地区分组
 1028:     const regionMap = new Map<string, { name: string; packageIds: Set<number>; hostIds: Set<number> }>()
 1029:     
 1030:     packages.forEach(pkg => {
 1031:       pkg.packageHosts.forEach(ph => {
 1032:         const host = hosts.find(h => h.id === ph.hostId)
 1033:         if (host) {
 1034:           const code = host.countryCode?.toUpperCase() || 'UNKNOWN'
 1035:           if (!regionMap.has(code)) {
 1036:             regionMap.set(code, {
 1037:               name: host.location || code,
 1038:               packageIds: new Set(),
 1039:               hostIds: new Set()
 1040:             })
 1041:           }
 1042:           const region = regionMap.get(code)!
 1043:           region.packageIds.add(pkg.id)
 1044:           region.hostIds.add(ph.hostId)
 1045:         }
 1046:       })
 1047:     })
 1048:     
 1049:     // 转换为数组格式
 1050:     const regions = Array.from(regionMap.entries()).map(([code, data]) => ({
 1051:       code,
 1052:       name: data.name,
 1053:       packageIds: Array.from(data.packageIds),
 1054:       hostCount: data.hostIds.size
 1055:     }))
 1056:     
 1057:     // 按名称排序
 1058:     regions.sort((a, b) => a.name.localeCompare(b.name, 'zh'))
 1059:     
 1060:     return { regions }
 1061:   })
 1062: 
 1063:   // ==================== 需要登录的 API ====================
 1064: 
 1065:   // 获取套餐列表
 1066:   // 查询参数：
 1067:   // - all=true: 返回所有套餐（包括停用/归档的），用于套餐管理页面
 1068:   // - source: 套餐来源过滤，可选值：official（面板直营）、zone（托管专区）、market（托管市场）、friends（好友共享）
 1069:   // - zoneId: source=zone 时指定托管专区 ID
 1070:   //           不传或传 all 时返回全部（保持向后兼容）
 1071:   // - scope: 管理员专用，mine(我的) / official(自营) / hosted(托管的)
 1072:   // - userId: 管理员专用，筛选特定用户（仅 scope=hosted 时有效）
 1073:   fastify.get<{ Querystring: { all?: string; source?: string; zoneId?: string; scope?: string; userId?: string } }>('/', {
 1074:     onRequest: [fastify.authenticate]
 1075:   }, async (request: FastifyRequest<{ Querystring: { all?: string; source?: string; zoneId?: string; scope?: string; userId?: string } }>, reply: FastifyReply) => {
 1076:     const { user } = request
 1077:     // all=true 时返回所有套餐（用于套餐管理页面），否则只返回启用的套餐（用于创建实例页面）
 1078:     const activeOnly = request.query.all !== 'true'
 1079:     const source = request.query.source || 'all'
 1080:     const scope = request.query.scope
 1081:     const filterUserId = request.query.userId
 1082:     const isAdmin = user.role === 'admin'
 1083: 
 1084:     // 管理员专用：scope 参数处理
 1085:     if (isAdmin && scope) {
 1086:       if (scope === 'mine') {
 1087:         // 查看自己的套餐
 1088:         const ownPackages = await db.getAllPackages(activeOnly, { userId: user.id })
 1089:         const packageIds = ownPackages.map(p => p.id)
 1090:         const [soldOutMap, instanceCountMap] = await Promise.all([
 1091:           db.checkPackagesSoldOut(packageIds),
 1092:           db.getNormalInstanceCountsByPackages(packageIds)
 1093:         ])
 1094:         return {
 1095:           packages: ownPackages.map(p => ({
 1096:             ...p,
 1097:             sourceType: 'own',
 1098:             isOwn: true,
 1099:             isShared: false,
 1100:             soldOut: soldOutMap.get(p.id) ?? false,
--- 1101-1460 ---
 1101:             instance_count: instanceCountMap.get(p.id) ?? 0
 1102:           })),
 1103:           total: ownPackages.length
 1104:         }
 1105:       } else if (scope === 'official') {
 1106:         // 查看自营套餐：仅显示管理员创建的套餐
 1107:         const officialPackages = await db.getAllPackages(activeOnly, { ownerRole: 'admin' })
 1108:         const officialPackageIds = officialPackages.map(p => p.id)
 1109:         const [officialSoldOutMap, officialInstanceCountMap] = await Promise.all([
 1110:           db.checkPackagesSoldOut(officialPackageIds),
 1111:           db.getNormalInstanceCountsByPackages(officialPackageIds)
 1112:         ])
 1113:         return {
 1114:           packages: officialPackages.map(p => ({
 1115:             ...p,
 1116:             sourceType: 'official',
 1117:             isOwn: p.user_id === user.id,
 1118:             isShared: false,
 1119:             soldOut: officialSoldOutMap.get(p.id) ?? false,
 1120:             instance_count: officialInstanceCountMap.get(p.id) ?? 0
 1121:           })),
 1122:           total: officialPackages.length
 1123:         }
 1124:       } else if (scope === 'hosted') {
 1125:         // 查看托管套餐：仅显示普通用户的套餐
 1126:         let queryOptions: { userId?: number; ownerRole?: 'admin' | 'user'; includeOwnerEmail: boolean } = {
 1127:           includeOwnerEmail: true,
 1128:           ownerRole: 'user'
 1129:         }
 1130:         
 1131:         const parsedFilterUserId = parseOptionalPositiveQueryInteger(filterUserId)
 1132:         if (parsedFilterUserId === null) {
 1133:           return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid package owner filter'))
 1134:         }
 1135:         if (parsedFilterUserId && parsedFilterUserId !== user.id) {
 1136:           queryOptions.userId = parsedFilterUserId
 1137:         }
 1138:         
 1139:         const hostedPackages = await db.getAllPackages(activeOnly, queryOptions)
 1140:         const hostedPackageIds = hostedPackages.map(p => p.id)
 1141:         const [hostedSoldOutMap, hostedInstanceCountMap] = await Promise.all([
 1142:           db.checkPackagesSoldOut(hostedPackageIds),
 1143:           db.getNormalInstanceCountsByPackages(hostedPackageIds)
 1144:         ])
 1145:         return {
 1146:           packages: hostedPackages.map(p => ({
 1147:             id: p.id,
 1148:             name: p.name,
 1149:             description: p.description,
 1150:             cpu_max: p.cpu_max,
 1151:             memory_max: p.memory_max,
 1152:             disk_max: p.disk_max,
 1153:             bandwidth_max: p.bandwidth_max,
 1154:             network_mode: p.network_mode,
 1155:             instance_type: p.instance_type,
 1156:             host_ids: p.host_ids || [],
 1157:             host_storage_pools: (p as any).host_storage_pools || {},
 1158:             host_traffic_multipliers: (p as any).host_traffic_multipliers || {},
 1159:             privileged: p.privileged,
 1160:             nested: p.nested,
 1161:             active: p.active,
 1162:             monthly_traffic_limit: p.monthly_traffic_limit,
 1163:             port_limit: p.port_limit,
 1164:             snapshot_limit: p.snapshot_limit,
 1165:             backup_limit: p.backup_limit,
 1166:             site_limit: p.site_limit,
 1167:             global_shared: p.global_shared,
 1168:             allow_instance_deletion: p.allow_instance_deletion,
 1169:             required_package_id: (p as any).required_package_id ?? null,
 1170:             required_package_name: (p as any).required_package_name ?? null,
 1171:             sourceType: 'hosted',
 1172:             isOwn: false,
 1173:             isShared: false,
 1174:             soldOut: hostedSoldOutMap.get(p.id) ?? false,
 1175:             instance_count: hostedInstanceCountMap.get(p.id) ?? 0,
 1176:             // 所有者信息
 1177:             owner: {
 1178:               id: p.user_id,
 1179:               username: p.owner_username,
 1180:               email: p.owner_email,
 1181:               avatarStyle: p.owner_avatar_style || 'bigSmile',
 1182:               avatarBadgeId: (p as any).owner_avatar_badge_id || null
 1183:             }
 1184:           })),
 1185:           total: hostedPackages.length
 1186:         }
 1187:       }
 1188:     }
 1189:     // 用于转换共享套餐为响应格式的辅助函数
 1190:     const formatSharedPackage = async (p: any, isGlobalShared: boolean, sourceType: 'official' | 'market' | 'friends' | 'zone', zone?: packageShares.HostingZoneInfo) => ({
 1191:       id: p.id,
 1192:       name: p.name,
 1193:       description: p.description,
 1194:       cpu_max: p.cpuMax,
 1195:       memory_max: p.memoryMax,
 1196:       disk_max: p.diskMax,
 1197:       bandwidth_max: p.bandwidthMax,
 1198:       network_mode: p.networkMode,
 1199:       instance_type: p.instanceType,
 1200:       host_ids: p.hostIds || [],
 1201:       privileged: p.privileged,
 1202:       nested: p.nested,
 1203:       active: 1,
 1204:       monthly_traffic_limit: p.monthlyTrafficLimit,
 1205:       port_limit: p.portLimit,
 1206:       snapshot_limit: p.snapshotLimit,
 1207:       backup_limit: p.backupLimit,
 1208:       site_limit: p.siteLimit,
 1209:       // 存储 I/O 限制
 1210:       io_limit_mode: p.ioLimitMode || p.io_limit_mode || 'throughput',
 1211:       limits_read: p.limitsRead || p.limits_read || '100MB',
 1212:       limits_write: p.limitsWrite || p.limits_write || '100MB',
 1213:       limits_read_iops: p.limitsReadIops || p.limits_read_iops || 500,
 1214:       limits_write_iops: p.limitsWriteIops || p.limits_write_iops || 500,
 1215:       limits_ingress: '300Mbit',
 1216:       limits_egress: '300Mbit',
 1217:       limits_processes: 500,
 1218:       limits_cpu_priority: 10,
 1219:       boot_autostart: true,
 1220:       boot_autostart_priority: 20,
 1221:       boot_autostart_delay: 15,
 1222:       boot_host_shutdown_timeout: 30,
 1223:       // 实例操作权限
 1224:       allow_instance_deletion: p.allowInstanceDeletion ?? true,
 1225:       ...getPackagePrerequisiteFields(p),
 1226:       // 所有者信息
 1227:       ownerId: p.ownerId,
 1228:       ownerUsername: p.ownerUsername,
 1229:       isOwn: false,
 1230:       isShared: true,
 1231:       isGlobalShared,
 1232:       sharedAt: p.sharedAt,
 1233:       // 新增：套餐来源类型
 1234:       sourceType,
 1235:       has_required_package_instance: p.requiredPackageId
 1236:         ? await db.userHasNormalInstanceForPackage(user.id, p.requiredPackageId)
 1237:         : true,
 1238:       ...(zone ? {
 1239:         hostingZoneId: zone.id,
 1240:         hostingZoneName: zone.name,
 1241:         hostingZoneLogoUrl: zone.logoUrl
 1242:       } : {})
 1243:     })
 1244: 
 1245:     // 根据 source 参数返回对应的套餐
 1246:     if (source === 'official') {
 1247:       // 面板直营：仅返回管理员创建的全局共享套餐
 1248:       const globalPackages = await packageShares.getGlobalSharedPackages()
 1249:       const officialIds = globalPackages.map(p => p.id)
 1250:       const officialSoldOutMap = await db.checkPackagesSoldOut(officialIds)
 1251:       return {
 1252:         packages: await Promise.all(globalPackages.map(async p => ({
 1253:           ...await formatSharedPackage(p, true, 'official'),
 1254:           soldOut: officialSoldOutMap.get(p.id) ?? false
 1255:         }))),
 1256:         total: globalPackages.length
 1257:       }
 1258:     }
 1259: 
 1260:     if (source === 'market') {
 1261:       // 托管市场：仅返回用户托管的全局共享套餐
 1262:       const zoneOwnerIds = await packageShares.getActiveHostingZoneOwnerIds()
 1263:       const marketPackages = await packageShares.getHostedMarketPackages(user.id, {
 1264:         excludeOwnerIds: zoneOwnerIds
 1265:       })
 1266:       const marketIds = marketPackages.map(p => p.id)
 1267:       const marketSoldOutMap = await db.checkPackagesSoldOut(marketIds)
 1268:       return {
 1269:         packages: await Promise.all(marketPackages.map(async p => ({
 1270:           ...await formatSharedPackage(p, true, 'market'),
 1271:           soldOut: marketSoldOutMap.get(p.id) ?? false
 1272:         }))),
 1273:         total: marketPackages.length
 1274:       }
 1275:     }
 1276: 
 1277:     if (source === 'zone') {
 1278:       const zoneId = parseOptionalPositiveQueryInteger(request.query.zoneId)
 1279:       if (zoneId === null) {
 1280:         return reply.code(400).send(apiError(ErrorCode.INVALID_PARAMS, 'Invalid hosting zone filter'))
 1281:       }
 1282:       if (zoneId === undefined) {
 1283:         return { packages: [], total: 0 }
 1284:       }
 1285: 
 1286:       const zone = await packageShares.getActiveHostingZoneById(zoneId, user.id)
 1287:       if (!zone) {
 1288:         return { packages: [], total: 0 }
 1289:       }
 1290: 
 1291:       const zonePackages = await packageShares.getHostedMarketPackages(user.id, {
 1292:         ownerId: zone.ownerId
 1293:       })
 1294:       const zonePackageIds = zonePackages.map(p => p.id)
 1295:       const zoneSoldOutMap = await db.checkPackagesSoldOut(zonePackageIds)
 1296: 
 1297:       return {
 1298:         packages: await Promise.all(zonePackages.map(async p => ({
 1299:           ...await formatSharedPackage(p, true, 'zone', zone),
 1300:           soldOut: zoneSoldOutMap.get(p.id) ?? false
 1301:         }))),
 1302:         total: zonePackages.length
 1303:       }
 1304:     }
 1305: 
 1306:     if (source === 'friends') {
 1307:       // 好友共享：仅返回好友共享的套餐
 1308:       const friendPackages = await packageShares.getSharedToUser(user.id)
 1309:       const friendIds = friendPackages.map(p => p.id)
 1310:       const friendSoldOutMap = await db.checkPackagesSoldOut(friendIds)
 1311:       return {
 1312:         packages: await Promise.all(friendPackages.map(async p => ({
 1313:           ...await formatSharedPackage(p, false, 'friends'),
 1314:           soldOut: friendSoldOutMap.get(p.id) ?? false
 1315:         }))),
 1316:         total: friendPackages.length
 1317:       }
 1318:     }
 1319: 
 1320:     // source=all 或不传：返回全部（保持向后兼容）
 1321:     // 获取套餐：管理员查看系统所有套餐，普通用户查看自己的套餐
 1322:     const ownPackages = await db.getAllPackages(activeOnly, {
 1323:       userId: isAdmin ? undefined : user.id
 1324:     })
 1325:     const ownPackageIds = ownPackages.map(p => p.id)
 1326:     const ownInstanceCountMap = await db.getNormalInstanceCountsByPackages(ownPackageIds)
 1327: 
 1328:     // 获取共享给用户的套餐（好友共享）
 1329:     const sharedPackages = await packageShares.getSharedToUser(user.id)
 1330: 
 1331:     // 获取全局共享的套餐（官方）
 1332:     const globalPackages = await packageShares.getGlobalSharedPackages()
 1333: 
 1334:     // 获取托管市场套餐
 1335:     const hostingZones = await packageShares.getHostingZonesForViewer(user.id)
 1336:     const zoneOwnerIds = hostingZones.map(zone => zone.ownerId)
 1337:     const marketPackages = await packageShares.getHostedMarketPackages(user.id, {
 1338:       excludeOwnerIds: zoneOwnerIds
 1339:     })
 1340: 
 1341:     const zonePackagesByZone = await Promise.all(
 1342:       hostingZones.map(async zone => ({
 1343:         zone,
 1344:         packages: await packageShares.getHostedMarketPackages(user.id, {
 1345:           ownerId: zone.ownerId
 1346:         })
 1347:       }))
 1348:     )
 1349: 
 1350:     // 合并并去重，优先级：自己的 > 好友分享 > 托管专区 > 托管市场 > 官方直营
 1351:     // 使用 Set 记录已添加的套餐 ID，避免重复
 1352:     const addedPackageIds = new Set<number>()
 1353:     const allPackages: any[] = []
 1354: 
 1355:     // 1. 首先添加自己的套餐（最高优先级）
 1356:     for (const p of ownPackages) {
 1357:       addedPackageIds.add(p.id)
 1358:       allPackages.push({
 1359:         id: p.id,
 1360:         name: p.name,
 1361:         description: p.description,
 1362:         cpu_max: p.cpu_max,
 1363:         memory_max: p.memory_max,
 1364:         disk_max: p.disk_max,
 1365:         bandwidth_max: p.bandwidth_max,
 1366:         network_mode: p.network_mode,
 1367:         instance_type: p.instance_type,
 1368:         host_ids: (p as { host_ids?: number[] }).host_ids || [],
 1369:         host_storage_pools: (p as any).host_storage_pools || {},
 1370:         host_traffic_multipliers: (p as any).host_traffic_multipliers || {},
 1371:         privileged: p.privileged,
 1372:         nested: p.nested,
 1373:         active: p.active,
 1374:         monthly_traffic_limit: p.monthly_traffic_limit,
 1375:         port_limit: p.port_limit,
 1376:         snapshot_limit: p.snapshot_limit,
 1377:         backup_limit: p.backup_limit,
 1378:         site_limit: p.site_limit,
 1379:         global_shared: p.global_shared,
 1380:         // 存储 I/O 限制
 1381:         io_limit_mode: (p as any).io_limit_mode ?? 'throughput',
 1382:         limits_read: p.limits_read,
 1383:         limits_write: p.limits_write,
 1384:         limits_read_iops: p.limits_read_iops,
 1385:         limits_write_iops: p.limits_write_iops,
 1386:         // 网络限制
 1387:         limits_ingress: p.limits_ingress,
 1388:         limits_egress: p.limits_egress,
 1389:         // 进程与调度
 1390:         limits_processes: p.limits_processes,
 1391:         limits_cpu_priority: p.limits_cpu_priority,
 1392:         // 启动配置
 1393:         boot_autostart: p.boot_autostart,
 1394:         boot_autostart_priority: p.boot_autostart_priority,
 1395:         boot_autostart_delay: p.boot_autostart_delay,
 1396:         boot_host_shutdown_timeout: p.boot_host_shutdown_timeout,
 1397:         // 实例操作权限
 1398:         allow_instance_deletion: (p as any).allow_instance_deletion ?? true,
 1399:         required_package_id: (p as any).required_package_id ?? null,
 1400:         required_package_name: (p as any).required_package_name ?? null,
 1401:         has_required_package_instance: (p as any).required_package_id
 1402:           ? await db.userHasNormalInstanceForPackage(user.id, (p as any).required_package_id)
 1403:           : true,
 1404:         // 所有者信息
 1405:         ownerId: p.user_id,
 1406:         ownerUsername: p.owner_username,
 1407:         isOwn: true,
 1408:         isShared: false,
 1409:         sourceType: 'own',
 1410:         instance_count: ownInstanceCountMap.get(p.id) ?? 0
 1411:       })
 1412:     }
 1413: 
 1414:     // 2. 添加好友分享的套餐（跳过已有的）
 1415:     for (const p of sharedPackages) {
 1416:       if (addedPackageIds.has(p.id)) continue
 1417:       addedPackageIds.add(p.id)
 1418:       allPackages.push(await formatSharedPackage(p, false, 'friends'))
 1419:     }
 1420: 
 1421:     // 3. 添加托管专区套餐（跳过已有的）
 1422:     for (const group of zonePackagesByZone) {
 1423:       for (const p of group.packages) {
 1424:         if (addedPackageIds.has(p.id)) continue
 1425:         addedPackageIds.add(p.id)
 1426:         allPackages.push(await formatSharedPackage(p, true, 'zone', group.zone))
 1427:       }
 1428:     }
 1429: 
 1430:     // 4. 添加托管市场套餐（跳过已有的）
 1431:     for (const p of marketPackages) {
 1432:       if (addedPackageIds.has(p.id)) continue
 1433:       addedPackageIds.add(p.id)
 1434:       allPackages.push(await formatSharedPackage(p, true, 'market'))
 1435:     }
 1436: 
 1437:     // 5. 添加官方直营套餐（跳过已有的）
 1438:     for (const p of globalPackages) {
 1439:       if (addedPackageIds.has(p.id)) continue
 1440:       addedPackageIds.add(p.id)
 1441:       allPackages.push(await formatSharedPackage(p, true, 'official'))
 1442:     }
 1443: 
 1444:     // 6. 批量计算售罄状态
 1445:     const packageIds = allPackages.map(p => p.id)
 1446:     const soldOutMap = await db.checkPackagesSoldOut(packageIds)
 1447: 
 1448:     // 7. 添加 soldOut 字段到每个套餐
 1449:     const packagesWithSoldOut = allPackages.map(p => ({
 1450:       ...p,
 1451:       soldOut: soldOutMap.get(p.id) ?? false
 1452:     }))
 1453: 
 1454:     return {
 1455:       packages: packagesWithSoldOut,
 1456:       total: packagesWithSoldOut.length
 1457:     }
 1458:   })
