 2583:   // 获取套餐下的所有方案
 2584:   fastify.get<{ Params: { id: string }; Querystring: { activeOnly?: string } }>('/:id/plans', {
 2585:     onRequest: [fastify.authenticate]
 2586:   }, async (request: FastifyRequest<{ Params: { id: string }; Querystring: { activeOnly?: string } }>, reply: FastifyReply) => {
 2587:     const { id } = request.params
 2588:     const { user } = request
 2589:     const packageId = parsePositiveRouteId(id)
 2590:     const activeOnly = request.query.activeOnly === 'true'
 2591: 
 2592:     if (!packageId) {
 2593:       return reply.code(400).send(apiError(ErrorCode.INVALID_ID))
 2594:     }
 2595: 
 2596:     const pkg = await db.getPackageById(packageId)
 2597:     if (!pkg) {
 2598:       return reply.code(404).send(apiError(ErrorCode.PACKAGE_NOT_FOUND))
 2599:     }
